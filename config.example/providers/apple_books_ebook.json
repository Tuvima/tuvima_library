{
  "name": "apple_books_ebook",
  "version": "1.1",
  "enabled": true,
  "weight": 0.7,
  "domain": "Ebook",
  "capability_tags": ["cover", "title", "author", "description"],
  "available_fields": ["title", "author", "cover", "description"],
  "field_weights": {
    "cover": 0.85,
    "title": 0.7,
    "author": 0.7,
    "description": 0.85
  },
  "endpoints": {
    "api": "https://itunes.apple.com"
  },
  "throttle_ms": 300,
  "max_concurrency": 1,
  "hydration_stages": [1],

  "adapter_type": "config_driven",
  "provider_id": "b1000001-e000-4000-8000-000000000001",
  "display_name": "Apple Books",

  "http_client": {
    "timeout_seconds": 10
  },

  "can_handle": {
    "media_types": ["Epub"],
    "entity_types": ["Work", "MediaAsset"]
  },

  "search_strategies": [
    {
      "name": "title_search",
      "priority": 1,
      "required_fields": ["title"],
      "url_template": "{base_url}/search?term={query}&entity=ebook&limit=5",
      "query_template": "{title} {author}",
      "results_path": "results",
      "result_index": 0
    }
  ],

  "field_mappings": [
    { "claim_key": "title",       "json_path": "trackName",      "confidence": 0.7 },
    { "claim_key": "author",      "json_path": "artistName",     "confidence": 0.7 },
    { "claim_key": "cover",       "json_path": "artworkUrl100",  "confidence": 0.85, "transform": "regex_replace", "transform_args": "100x100bb\\.jpg|600x600bb.jpg" },
    { "claim_key": "description", "json_path": "description",    "confidence": 0.85, "transform": "strip_html" }
  ]
}
