{
  "name": "google_books",
  "version": "1.2",
  "enabled": false,
  "weight": 0.65,
  "domain": "Ebook",
  "icon": "images/providers/google_books.svg",
  "capability_tags": ["title", "author", "cover", "description", "isbn", "year", "rating", "publisher", "page_count", "language", "genre"],
  "available_fields": ["title", "author", "year", "description", "cover", "isbn", "rating", "publisher", "page_count", "language", "genre"],
  "field_weights": {
    "title": 0.7,
    "author": 0.75,
    "cover": 0.75,
    "description": 0.8,
    "isbn": 0.85,
    "year": 0.8,
    "rating": 0.7,
    "publisher": 0.75,
    "page_count": 0.8,
    "language": 0.7,
    "genre": 0.7
  },
  "endpoints": {
    "api": "https://www.googleapis.com/books/v1"
  },
  "throttle_ms": 200,
  "max_concurrency": 1,
  "hydration_stages": [3],
  "cache_ttl_hours": 168,

  "adapter_type": "config_driven",
  "provider_id": "b5000005-0000-4000-8000-000000000006",
  "display_name": "Google Books",
  "requires_api_key": true,

  "http_client": {
    "timeout_seconds": 10,
    "user_agent": "Tuvima Library/1.0",
    "api_key": "",
    "api_key_delivery": "query",
    "api_key_param_name": "key"
  },

  "can_handle": {
    "media_types": ["Books"],
    "entity_types": ["Work", "MediaAsset"]
  },

  "search_strategies": [
    {
      "name": "isbn_search",
      "priority": 1,
      "required_fields": ["isbn"],
      "url_template": "{base_url}/volumes?q=isbn:{isbn}&maxResults=3&key={api_key}",
      "results_path": "items",
      "result_index": 0
    },
    {
      "name": "title_search",
      "priority": 2,
      "required_fields": ["title"],
      "url_template": "{base_url}/volumes?q={query}&maxResults={limit}&key={api_key}",
      "query_template": "{title} {author}",
      "results_path": "items",
      "result_index": 0,
      "fetch_limit": 5,
      "max_results": 25
    }
  ],

  "field_mappings": [
    { "claim_key": "title",       "json_path": "volumeInfo.title",                      "confidence": 0.7 },
    { "claim_key": "author",      "json_path": "volumeInfo.authors[0]",                 "confidence": 0.75 },
    { "claim_key": "year",        "json_path": "volumeInfo.publishedDate",              "confidence": 0.8,  "transform": "first_n_chars", "transform_args": "4" },
    { "claim_key": "description", "json_path": "volumeInfo.description",                "confidence": 0.8,  "transform": "strip_html" },
    { "claim_key": "cover",       "json_path": "volumeInfo.imageLinks.thumbnail",       "confidence": 0.75, "transform": "regex_replace", "transform_args": "=s\\d+|=s0" },
    { "claim_key": "isbn",        "json_path": "volumeInfo.industryIdentifiers",        "confidence": 0.85, "transform": "prefer_isbn13" },
    { "claim_key": "rating",      "json_path": "volumeInfo.averageRating",              "confidence": 0.7,  "transform": "to_string" },
    { "claim_key": "publisher",   "json_path": "volumeInfo.publisher",                  "confidence": 0.75 },
    { "claim_key": "page_count",  "json_path": "volumeInfo.pageCount",                  "confidence": 0.8,  "transform": "to_string" },
    { "claim_key": "language",    "json_path": "volumeInfo.language",                   "confidence": 0.7 },
    { "claim_key": "genre",       "json_path": "volumeInfo.categories",                 "confidence": 0.7,  "transform": "array_join", "transform_args": ", " }
  ]
}
