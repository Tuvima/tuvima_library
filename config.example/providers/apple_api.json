{
  "name": "apple_books",
  "version": "2.0",
  "enabled": true,
  "weight": 0.7,
  "domain": "Universal",
  "icon": "images/providers/apple_books.svg",
  "capability_tags": [],
  "available_fields": [
    "cover",
    "description",
    "rating",
    "apple_books_id"
  ],
  "field_weights": {},
  "endpoints": {
    "api": "https://itunes.apple.com"
  },
  "throttle_ms": 300,
  "max_concurrency": 1,
  "hydration_stages": [
    3
  ],
  "cache_ttl_hours": null,
  "adapter_type": "config_driven",
  "provider_id": "b1000001-e000-4000-8000-000000000001",
  "display_name": "Apple Books",
  "http_client": {
    "timeout_seconds": 10,
    "user_agent": null,
    "api_key": null,
    "api_key_delivery": null,
    "api_key_param_name": null
  },
  "can_handle": {
    "media_types": [
      "Epub",
      "Audiobook"
    ],
    "entity_types": [
      "Work",
      "MediaAsset"
    ]
  },
  "search_strategies": [
    {
      "name": "isbn_lookup",
      "priority": 0,
      "required_fields": ["isbn"],
      "url_template": "{base_url}/lookup?isbn={isbn}",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": true,
      "fetch_limit": 1,
      "max_results": 1,
      "media_types": ["Epub"]
    },
    {
      "name": "apple_id_lookup",
      "priority": 1,
      "required_fields": ["apple_books_id"],
      "url_template": "{base_url}/lookup?id={apple_books_id}\u0026country={country}\u0026lang={lang}_{country}",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": true,
      "fetch_limit": 1,
      "max_results": 1
    },
    {
      "name": "ebook_search",
      "priority": 2,
      "required_fields": ["title"],
      "url_template": "{base_url}/search?term={query}\u0026entity=ebook\u0026limit={limit}\u0026country={country}\u0026lang={lang}_{country}",
      "query_template": "{title}",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": false,
      "max_results": 25,
      "fetch_limit": 5,
      "media_types": ["Epub"]
    },
    {
      "name": "audiobook_search",
      "priority": 2,
      "required_fields": ["title"],
      "url_template": "{base_url}/search?term={query}\u0026entity=audiobook\u0026limit={limit}\u0026country={country}\u0026lang={lang}_{country}",
      "query_template": "{title}",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": false,
      "max_results": 25,
      "fetch_limit": 5,
      "media_types": ["Audiobook"]
    }
  ],
  "field_mappings": [
    {
      "claim_key": "cover",
      "json_path": "artworkUrl100",
      "confidence": 0.85,
      "transform": "regex_replace",
      "transform_args": "\\d\u002Bx\\d\u002Bbb\\.jpg|9999x9999bb.jpg",
      "media_types": null
    },
    {
      "claim_key": "description",
      "json_path": "description",
      "confidence": 0.85,
      "transform": "strip_html",
      "transform_args": null,
      "media_types": null
    },
    {
      "claim_key": "rating",
      "json_path": "averageUserRating",
      "confidence": 0.7,
      "transform": "to_string",
      "transform_args": null,
      "media_types": [
        "Epub"
      ]
    },
    {
      "claim_key": "apple_books_id",
      "json_path": "trackId",
      "confidence": 0.95,
      "transform": "to_string",
      "transform_args": null,
      "media_types": [
        "Epub"
      ]
    },
    {
      "claim_key": "apple_books_id",
      "json_path": "collectionId",
      "confidence": 0.95,
      "transform": "to_string",
      "transform_args": null,
      "media_types": [
        "Audiobook"
      ]
    }
  ],
  "requires_api_key": false,
  "custom_icon_name": null
}