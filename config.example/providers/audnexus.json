{
  "name": "audnexus",
  "version": "1.1",
  "enabled": true,
  "weight": 0.7,
  "domain": "Audiobook",
  "capability_tags": ["narrator", "series", "series_position", "cover", "author", "title", "description", "asin"],
  "available_fields": ["title", "author", "narrator", "series", "series_position", "cover", "description", "asin"],
  "field_weights": {
    "narrator": 0.9,
    "series": 0.9,
    "series_position": 0.9,
    "cover": 0.9,
    "author": 0.75,
    "title": 0.7,
    "description": 0.7,
    "asin": 0.95
  },
  "endpoints": {
    "api": "https://api.audnexus.com"
  },
  "throttle_ms": 0,
  "max_concurrency": 1,
  "hydration_stages": [1, 3],

  "adapter_type": "config_driven",
  "provider_id": "b2000002-a000-4000-8000-000000000003",
  "display_name": "Audnexus",

  "http_client": {
    "timeout_seconds": 10,
    "user_agent": "Tanaste/1.0"
  },

  "can_handle": {
    "media_types": ["Audiobook"],
    "entity_types": ["Work", "MediaAsset"]
  },

  "search_strategies": [
    {
      "name": "asin_lookup",
      "priority": 1,
      "required_fields": ["asin"],
      "url_template": "{base_url}/books/{asin}",
      "tolerate_404": true
    }
  ],

  "field_mappings": [
    { "claim_key": "title",           "json_path": "title",              "confidence": 0.7 },
    { "claim_key": "author",          "json_path": "authors[*].name",    "confidence": 0.75, "transform": "array_join" },
    { "claim_key": "narrator",        "json_path": "narrators[*].name",  "confidence": 0.9,  "transform": "array_join" },
    { "claim_key": "series",          "json_path": "seriesPrimary.name", "confidence": 0.9 },
    { "claim_key": "series_position", "json_path": "seriesPrimary.position", "confidence": 0.9 },
    { "claim_key": "cover",           "json_path": "image",              "confidence": 0.9 },
    { "claim_key": "description",     "json_path": "summary",            "confidence": 0.7,  "transform": "strip_html" },
    { "claim_key": "asin",            "json_path": "asin",               "confidence": 0.95 }
  ]
}
