{
  "name": "musicbrainz",
  "version": "2.0",
  "enabled": true,
  "weight": 0.7,
  "domain": "Music",
  "icon": "images/providers/musicbrainz.svg",
  "capability_tags": ["title", "author", "year", "genre", "cover", "musicbrainz_id", "album", "track_number"],
  "available_fields": ["title", "author", "year", "genre", "cover", "musicbrainz_id", "isrc", "album", "track_number"],
  "field_weights": {
    "title": 0.8,
    "author": 0.8,
    "year": 0.85,
    "genre": 0.7,
    "cover": 0.7,
    "musicbrainz_id": 1.0,
    "isrc": 0.9,
    "album": 0.75,
    "track_number": 0.8
  },
  "endpoints": {
    "api": "https://musicbrainz.org/ws/2"
  },
  "throttle_ms": 1100,
  "max_concurrency": 1,
  "hydration_stages": [1],
  "cache_ttl_hours": 168,

  "adapter_type": "config_driven",
  "provider_id": "b6000006-0000-4000-8000-000000000007",
  "display_name": "MusicBrainz",
  "requires_api_key": false,
  "language_strategy": "source",

  "http_client": {
    "timeout_seconds": 10,
    "user_agent": "Tuvima Library/1.0 (https://github.com/shyfaruqi/tuvima-library)"
  },

  "can_handle": {
    "media_types": ["Music"],
    "entity_types": ["Work", "MediaAsset"]
  },

  "preferred_bridge_ids": {
    "Music": ["musicbrainz_id", "isrc"]
  },

  "search_strategies": [
    {
      "name": "recording_album_search",
      "priority": 1,
      "required_fields": ["title"],
      "url_template": "{base_url}/recording?query={query}&fmt=json&limit={limit}",
      "query_template": "{title} AND artist:{author}",
      "results_path": "recordings",
      "fetch_limit": 10,
      "max_results": 10,
      "release_selection": {
        "path": "releases",
        "filters": [
          { "path": "status", "equals": "Official" },
          { "path": "release-group.primary-type", "equals": "Album" }
        ],
        "sort": [
          { "path": "date", "direction": "asc" }
        ],
        "prefer": [
          { "path": "cover-art-archive.artwork", "equals": true }
        ],
        "fallback_types": ["Single", "EP"]
      }
    },
    {
      "name": "release_search",
      "priority": 2,
      "required_fields": ["title"],
      "url_template": "{base_url}/release?query={query}&fmt=json&limit={limit}",
      "query_template": "{title} AND artist:{author}",
      "results_path": "releases",
      "result_index": 0,
      "fetch_limit": 5,
      "max_results": 10
    }
  ],

  "field_mappings": [
    { "claim_key": "title",          "json_path": "title",                     "confidence": 0.8,  "source": "recording" },
    { "claim_key": "author",         "json_path": "artist-credit[*].name",     "confidence": 0.8,  "source": "recording", "transform": "array_join" },
    { "claim_key": "album",          "json_path": "title",                     "confidence": 0.75, "source": "release" },
    { "claim_key": "year",           "json_path": "date",                      "confidence": 0.85, "source": "release",   "transform": "first_n_chars", "transform_args": "4" },
    { "claim_key": "track_number",   "json_path": "track-count",               "confidence": 0.8,  "source": "release" },
    { "claim_key": "musicbrainz_id", "json_path": "id",                        "confidence": 1.0,  "source": "release" },
    { "claim_key": "cover",          "json_path": "id",                        "confidence": 0.7,  "source": "release",   "transform": "url_template", "transform_args": "https://coverartarchive.org/release/{value}/front-250",
      "condition": { "path": "cover-art-archive.artwork", "equals": true }
    }
  ]
}
