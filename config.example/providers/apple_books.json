{
  "name": "apple_books",
  "version": "2.0",
  "enabled": true,
  "weight": 0.7,
  "domain": "Universal",
  "icon": "images/providers/apple_books.svg",
  "capability_tags": ["cover", "title", "author", "description", "genre", "year"],
  "available_fields": ["title", "author", "cover", "description", "genre", "rating", "year", "apple_books_id"],
  "field_weights": {
    "cover": 0.85,
    "title": 0.7,
    "author": 0.7,
    "description": 0.85,
    "genre": 0.7,
    "rating": 0.7,
    "year": 0.8
  },
  "endpoints": {
    "api": "https://itunes.apple.com"
  },
  "throttle_ms": 300,
  "max_concurrency": 1,
  "hydration_stages": [3],
  "cache_ttl_hours": 168,

  "adapter_type": "config_driven",
  "provider_id": "b1000001-e000-4000-8000-000000000001",
  "display_name": "Apple Books",

  "http_client": {
    "timeout_seconds": 10,
    "user_agent": "Tuvima Library/1.0"
  },

  "can_handle": {
    "media_types": ["Books", "Audiobooks"],
    "entity_types": ["Work", "MediaAsset"]
  },

  "search_strategies": [
    {
      "name": "isbn_lookup",
      "priority": 0,
      "required_fields": ["isbn"],
      "url_template": "{base_url}/lookup?isbn={isbn}",
      "results_path": "results",
      "result_index": 0,
      "fetch_limit": 1,
      "max_results": 1,
      "media_types": ["Books"]
    },
    {
      "name": "ebook_search",
      "priority": 1,
      "required_fields": ["title"],
      "url_template": "{base_url}/search?term={query}&entity=ebook&limit={limit}&country={country}",
      "query_template": "{title} {author}",
      "results_path": "results",
      "result_index": 0,
      "fetch_limit": 5,
      "max_results": 25,
      "media_types": ["Books"]
    },
    {
      "name": "audiobook_search",
      "priority": 1,
      "required_fields": ["title"],
      "url_template": "{base_url}/search?term={query}&entity=audiobook&limit={limit}&country={country}",
      "query_template": "{title} {author}",
      "results_path": "results",
      "result_index": 0,
      "fetch_limit": 5,
      "max_results": 25,
      "media_types": ["Audiobooks"]
    }
  ],

  "field_mappings": [
    { "claim_key": "title",          "json_path": "trackName",          "confidence": 0.7,  "media_types": ["Books"] },
    { "claim_key": "title",          "json_path": "collectionName",     "confidence": 0.7,  "media_types": ["Audiobooks"] },
    { "claim_key": "author",         "json_path": "artistName",         "confidence": 0.7 },
    { "claim_key": "cover",          "json_path": "artworkUrl100",      "confidence": 0.85, "transform": "regex_replace", "transform_args": "\\d+x\\d+bb\\.jpg|9999x9999bb.jpg" },
    { "claim_key": "description",    "json_path": "description",        "confidence": 0.85, "transform": "strip_html" },
    { "claim_key": "year",           "json_path": "releaseDate",        "confidence": 0.8,  "transform": "first_n_chars", "transform_args": "4" },
    { "claim_key": "genre",          "json_path": "genres",             "confidence": 0.7,  "transform": "array_join", "transform_args": ", ", "media_types": ["Books"] },
    { "claim_key": "genre",          "json_path": "primaryGenreName",   "confidence": 0.7,  "media_types": ["Audiobooks"] },
    { "claim_key": "rating",         "json_path": "averageUserRating",  "confidence": 0.7,  "transform": "to_string", "media_types": ["Books"] },
    { "claim_key": "apple_books_id", "json_path": "trackId",            "confidence": 0.95, "transform": "to_string", "media_types": ["Books"] },
    { "claim_key": "apple_books_id", "json_path": "collectionId",       "confidence": 0.95, "transform": "to_string", "media_types": ["Audiobooks"] }
  ]
}
