{
  "name": "apple_podcasts",
  "version": "1.0",
  "enabled": true,
  "weight": 0.7,
  "domain": "Podcasts",
  "icon": "images/providers/apple_podcasts.svg",
  "capability_tags": ["cover", "title", "author", "description", "genre", "year", "feed_url"],
  "available_fields": ["title", "author", "cover", "description", "genre", "year", "feed_url", "apple_podcasts_id", "show_name", "episode_number"],
  "field_weights": {
    "cover": 0.85,
    "title": 0.7,
    "author": 0.7,
    "description": 0.85,
    "genre": 0.7,
    "year": 0.8,
    "feed_url": 0.95,
    "show_name": 0.8,
    "episode_number": 0.7,
    "apple_podcasts_id": 0.95
  },
  "endpoints": {
    "api": "https://itunes.apple.com"
  },
  "throttle_ms": 300,
  "max_concurrency": 1,
  "hydration_stages": [2],
  "cache_ttl_hours": 168,

  "adapter_type": "config_driven",
  "provider_id": "b9000009-0000-4000-8000-000000000010",
  "display_name": "Apple Podcasts",

  "http_client": {
    "timeout_seconds": 10,
    "user_agent": "Tuvima Library/1.0"
  },

  "can_handle": {
    "media_types": ["Podcasts"],
    "entity_types": ["Work", "MediaAsset"]
  },

  "search_strategies": [
    {
      "name": "podcast_search",
      "priority": 1,
      "required_fields": ["title"],
      "url_template": "{base_url}/search?term={query}&entity=podcast&limit={limit}&country={country}&lang={lang}_{country}",
      "query_template": "{title} {author}",
      "results_path": "results",
      "result_index": 0,
      "fetch_limit": 5,
      "max_results": 25
    },
    {
      "name": "episode_search",
      "priority": 2,
      "required_fields": ["title"],
      "url_template": "{base_url}/search?term={query}&entity=podcastEpisode&limit={limit}&country={country}&lang={lang}_{country}",
      "query_template": "{title}",
      "results_path": "results",
      "result_index": 0,
      "fetch_limit": 5,
      "max_results": 25
    }
  ],

  "field_mappings": [
    { "claim_key": "show_name",          "json_path": "collectionName",     "confidence": 0.8 },
    { "claim_key": "title",              "json_path": "trackName",          "confidence": 0.7 },
    { "claim_key": "author",             "json_path": "artistName",         "confidence": 0.7 },
    { "claim_key": "cover",              "json_path": "artworkUrl100",      "confidence": 0.85, "transform": "regex_replace", "transform_args": "\\d+x\\d+bb\\.jpg|9999x9999bb.jpg" },
    { "claim_key": "description",        "json_path": "description",        "confidence": 0.85, "transform": "strip_html" },
    { "claim_key": "year",               "json_path": "releaseDate",        "confidence": 0.8,  "transform": "first_n_chars", "transform_args": "4" },
    { "claim_key": "genre",              "json_path": "primaryGenreName",   "confidence": 0.7 },
    { "claim_key": "feed_url",           "json_path": "feedUrl",            "confidence": 0.95 },
    { "claim_key": "apple_podcasts_id",  "json_path": "collectionId",       "confidence": 0.95, "transform": "to_string" },
    { "claim_key": "episode_number",     "json_path": "trackNumber",        "confidence": 0.7,  "transform": "to_string" }
  ]
}
