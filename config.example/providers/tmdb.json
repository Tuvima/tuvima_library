{
  "name": "tmdb",
  "version": "1.1",
  "enabled": false,
  "weight": 0.8,
  "domain": "Video",
  "icon": "images/providers/tmdb.svg",
  "capability_tags": ["title", "director", "cast_member", "year", "genre", "description", "cover", "backdrop", "tmdb_id", "imdb_id", "rating"],
  "available_fields": ["title", "director", "cast_member", "year", "genre", "description", "cover", "backdrop", "tmdb_id", "imdb_id", "rating", "runtime", "language", "tagline"],
  "field_weights": {
    "title": 0.85,
    "director": 0.9,
    "cast_member": 0.9,
    "year": 0.9,
    "genre": 0.85,
    "description": 0.85,
    "cover": 0.9,
    "tmdb_id": 1.0,
    "imdb_id": 0.95,
    "rating": 0.8,
    "runtime": 0.9,
    "language": 0.85,
    "tagline": 0.7,
    "backdrop": 0.9
  },
  "endpoints": {
    "api": "https://api.themoviedb.org/3"
  },
  "throttle_ms": 250,
  "max_concurrency": 2,
  "hydration_stages": [3],
  "cache_ttl_hours": 168,

  "adapter_type": "config_driven",
  "provider_id": "b7000007-0000-4000-8000-000000000008",
  "display_name": "TMDB",
  "requires_api_key": true,

  "http_client": {
    "timeout_seconds": 10,
    "user_agent": "Tuvima Library/1.0",
    "api_key": "",
    "api_key_delivery": "bearer"
  },

  "can_handle": {
    "media_types": ["Movies", "TV"],
    "entity_types": ["Work", "MediaAsset"]
  },

  "search_strategies": [
    {
      "name": "movie_search",
      "priority": 1,
      "required_fields": ["title"],
      "url_template": "{base_url}/search/movie?query={title}&include_adult=false&language=en-US&page=1",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": false,
      "media_types": ["Movies"]
    },
    {
      "name": "tv_search",
      "priority": 1,
      "required_fields": ["title"],
      "url_template": "{base_url}/search/tv?query={title}&include_adult=false&language=en-US&page=1",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": false,
      "media_types": ["TV"]
    }
  ],

  "field_mappings": [
    { "claim_key": "title",         "json_path": "title",                    "confidence": 0.85, "media_types": ["Movies"] },
    { "claim_key": "title",         "json_path": "name",                     "confidence": 0.85, "media_types": ["TV"] },
    { "claim_key": "description",   "json_path": "overview",                 "confidence": 0.85 },
    { "claim_key": "year",          "json_path": "release_date",             "confidence": 0.9,  "transform": "first_n_chars", "transform_args": "4", "media_types": ["Movies"] },
    { "claim_key": "year",          "json_path": "first_air_date",           "confidence": 0.9,  "transform": "first_n_chars", "transform_args": "4", "media_types": ["TV"] },
    { "claim_key": "cover",         "json_path": "poster_path",              "confidence": 0.9,  "transform": "url_template", "transform_args": "https://image.tmdb.org/t/p/w500{value}" },
    { "claim_key": "backdrop",      "json_path": "backdrop_path",            "confidence": 0.9,  "transform": "url_template", "transform_args": "https://image.tmdb.org/t/p/w1280{value}" },
    { "claim_key": "tmdb_id",       "json_path": "id",                       "confidence": 1.0,  "transform": "to_string" },
    { "claim_key": "rating",        "json_path": "vote_average",             "confidence": 0.8,  "transform": "to_string" },
    { "claim_key": "language",      "json_path": "original_language",        "confidence": 0.85 },
    { "claim_key": "genre",         "json_path": "genre_ids",                "confidence": 0.85, "transform": "array_join" }
  ]
}
