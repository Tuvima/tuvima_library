{
  "version": "1.0",
  "description": "Maps media types to their primary unique identifiers. Used by the two-stage matching pipeline to determine which IDs to extract and normalise during Stage 1 (Content Match).",
  "media_types": {
    "Books": {
      "primary_ids": ["isbn"],
      "id_priority": ["isbn"]
    },
    "Audiobooks": {
      "primary_ids": ["asin", "isbn"],
      "id_priority": ["asin", "isbn"]
    },
    "Music_Songs": {
      "primary_ids": ["isrc"],
      "id_priority": ["isrc"]
    },
    "Music_Albums": {
      "primary_ids": ["upc_ean"],
      "id_priority": ["upc_ean"]
    },
    "Movies": {
      "primary_ids": ["tmdb_id", "imdb_id"],
      "id_priority": ["tmdb_id", "imdb_id", "isan", "eidr"]
    },
    "TV_Shows": {
      "primary_ids": ["tmdb_id", "imdb_id"],
      "id_priority": ["tmdb_id", "imdb_id"]
    },
    "Comics": {
      "primary_ids": ["comicvine_id"],
      "id_priority": ["comicvine_id", "isbn"]
    },
    "Academic_Journals": {
      "primary_ids": ["doi"],
      "id_priority": ["doi"]
    }
  }
}
