{
  "$schema": "signal_extraction",
  "version": "1.0",

  "global_settings": {
    "enabled": true,
    "name_separators": [" and ", " & ", ", "],
    "stop_names": ["Others", "More", "Various", "All Ages", "Various Artists",
                   "Full Cast", "Ensemble", "Multiple"],
    "min_name_words": 2,
    "max_name_length": 60,
    "min_wikidata_score": 70,
    "wikidata_person_class": "Q5",
    "confidence_from_description": 0.60,
    "confidence_from_file_metadata": 0.75,
    "confidence_verified_with_role": 0.85,
    "confidence_verified_no_role": 0.65,
    "max_extractions_per_entity": 10,
    "description_max_chars": 3000
  },

  "categories": {
    "Audiobooks": {
      "extraction_rules": [
        {
          "role": "Narrator",
          "patterns": [
            "(?i)(?:read|narrated|performed|voiced)\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|\\.|$)",
            "(?i)narrator:?\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|$)"
          ],
          "occupation_classes": ["Q1622272", "Q33999", "Q2405480", "Q4610556"],
          "source_fields": ["description", "copyright"],
          "file_metadata_keys": ["narrator", "performer"]
        }
      ]
    },
    "Books": {
      "extraction_rules": [
        {
          "role": "Translator",
          "patterns": [
            "(?i)translated\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|$)"
          ],
          "occupation_classes": ["Q333634", "Q14467526"],
          "source_fields": ["description"],
          "file_metadata_keys": ["translator"]
        },
        {
          "role": "Editor",
          "patterns": [
            "(?i)edited\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|$)"
          ],
          "occupation_classes": ["Q1607826", "Q3658608"],
          "source_fields": ["description"],
          "file_metadata_keys": ["editor"]
        },
        {
          "role": "Illustrator",
          "patterns": [
            "(?i)illustrated\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|$)"
          ],
          "occupation_classes": ["Q644687", "Q1028181", "Q3391743"],
          "source_fields": ["description"],
          "file_metadata_keys": ["illustrator"]
        },
        {
          "role": "Author",
          "patterns": [
            "(?i)(?:foreword|introduction|preface|afterword)\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|$)"
          ],
          "occupation_classes": ["Q36180", "Q482980", "Q4853732"],
          "source_fields": ["description"],
          "file_metadata_keys": []
        }
      ]
    },
    "Movies": {
      "extraction_rules": [
        {
          "role": "Director",
          "patterns": [
            "(?i)directed\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|$)"
          ],
          "occupation_classes": ["Q2526255", "Q3455803"],
          "source_fields": ["description"],
          "file_metadata_keys": ["director"]
        },
        {
          "role": "Cast Member",
          "patterns": [
            "(?i)(?:starring|featuring)\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|$)"
          ],
          "occupation_classes": ["Q33999", "Q10800557", "Q2405480"],
          "source_fields": ["description"],
          "file_metadata_keys": ["cast"]
        },
        {
          "role": "Producer",
          "patterns": [
            "(?i)produced\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|$)"
          ],
          "occupation_classes": ["Q3282637", "Q578109"],
          "source_fields": ["description"],
          "file_metadata_keys": []
        }
      ]
    },
    "TV": {
      "extraction_rules": [
        {
          "role": "Director",
          "patterns": [
            "(?i)directed\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|$)"
          ],
          "occupation_classes": ["Q2526255", "Q3455803"],
          "source_fields": ["description"],
          "file_metadata_keys": ["director"]
        },
        {
          "role": "Cast Member",
          "patterns": [
            "(?i)(?:starring|featuring)\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|$)"
          ],
          "occupation_classes": ["Q33999", "Q10800557", "Q2405480"],
          "source_fields": ["description"],
          "file_metadata_keys": ["cast"]
        }
      ]
    },
    "Comics": {
      "extraction_rules": [
        {
          "role": "Author",
          "patterns": [
            "(?i)(?:written|story)\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|$)"
          ],
          "occupation_classes": ["Q36180", "Q482980", "Q1114448"],
          "source_fields": ["description"],
          "file_metadata_keys": ["writer"]
        },
        {
          "role": "Illustrator",
          "patterns": [
            "(?i)(?:art|illustrated|pencils|inks|colors?|letters?)\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|$)"
          ],
          "occupation_classes": ["Q644687", "Q1028181", "Q3391743"],
          "source_fields": ["description"],
          "file_metadata_keys": ["artist", "illustrator"]
        }
      ]
    },
    "Podcasts": {
      "extraction_rules": [
        {
          "role": "Host",
          "patterns": [
            "(?i)(?:hosted|presented)\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|$)",
            "(?i)(?:with|featuring)\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|\\s+and\\s|$)"
          ],
          "occupation_classes": ["Q947873", "Q15077007"],
          "source_fields": ["description"],
          "file_metadata_keys": ["host"]
        }
      ]
    },
    "Music": {
      "extraction_rules": [
        {
          "role": "Producer",
          "patterns": [
            "(?i)produced\\s+by\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|$)"
          ],
          "occupation_classes": ["Q3282637", "Q578109"],
          "source_fields": ["description"],
          "file_metadata_keys": []
        },
        {
          "role": "Cast Member",
          "patterns": [
            "(?i)(?:feat\\.?|featuring)\\s+(?<name>[A-Z][\\w\\s.'-]+?)(?:\\s*[,;.(]|$)"
          ],
          "occupation_classes": ["Q177220", "Q639669", "Q488205"],
          "source_fields": ["description", "title"],
          "file_metadata_keys": []
        }
      ]
    }
  }
}
