{
  "device_class": "mobile",
  "display_name": "Mobile",
  "constraints": {
    "features_disabled": ["view_toggle", "property_mapper", "matching_pipeline", "universe_schema_editing", "chronicle_explorer"],
    "pages_disabled": [],
    "allow_text_input": true,
    "min_touch_target_px": 48
  },
  "content_padding": "pa-2",
  "content_max_width": "Full",
  "shell": {
    "appbar_style": "compact",
    "logo_variant": "icon",
    "intent_dock_items": ["Hubs", "Watch", "Read", "Listen"],
    "intent_dock_style": "normal",
    "top_bar_visible": true,
    "top_bar_style": "mobile",
    "dock_visible": false
  },
  "pages": {
    "home": {
      "hub_hero_enabled": true,
      "hub_hero_layout": "cinematic",
      "progress_cards_layout": "stacked",
      "bento_columns": 1,
      "bento_tile_style": "normal",
      "swimlane_card_width": 90,
      "pending_files_display": "badge"
    },
    "preferences": {
      "page_enabled": true,
      "tab_bar_layout": "vertical",
      "general_tab_layout": "stacked",
      "color_swatch_count": 4,
      "playback_tab_enabled": true
    },
    "server_settings": {
      "page_enabled": true,
      "tab_bar_layout": "vertical-accordion",
      "tab_content_layout": "stacked-card"
    }
  }
}

