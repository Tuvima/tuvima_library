## .NET / C# — Visual Studio / Rider / VS Code

# Build output
[Bb]in/
[Oo]bj/
out/

# NuGet packages
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets
packages/
.nuget/
project.lock.json
project.fragment.lock.json
artifacts/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
.idea/
.vscode/

# Rider
*.sln.iml

# Test results
TestResults/
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
coverage*/

# Publish output
publish/

# Claude Code local settings
.claude/

# OS artefacts
.DS_Store
Thumbs.db
desktop.ini

# Runtime data / local SQLite DB
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Provider secrets — API keys, passwords, tokens (never commit these)
config/secrets/
!config/secrets/.gitkeep

# Build-output config copies (projects that copy config/ to output directory)
src/*/config/
src/*/*/config/

# FFmpeg binaries — large platform-specific executables, downloaded by setup script.
# See tools/Download-FFmpeg.ps1 or place ffmpeg.exe + ffprobe.exe in tools/ffmpeg/ manually.
tools/ffmpeg/*.exe
tools/ffmpeg/*.dll
tools/reports/*.txt
tools/reports/*.log

# Serilog rolling log files — generated at runtime, never committed
logs/

# MkDocs / GitHub Pages local build output
site/
.mkdocs-cache/

# Local Codex-derived context
.codex/
.codex-runlogs/

# Local .NET CLI tooling
.dotnet-cli/

# Generated MudBlazor service/tag metadata
MudServices.json
MudTags.json

# Runtime logs (not under logs/)
build.log
dashboard.log
engine.log

# Integration test HTML reports
tools/reports/*.html
src/MediaEngine.Api/DevSupport/integration-test-report.html

# Cloudflare Worker — Node dependencies and local dev secrets
tools/cloudflare-api-gateway/node_modules/
tools/cloudflare-api-gateway/.dev.vars

# Local scratch directory (engine/dashboard logs during ad-hoc runs)
.tmp/

# Runtime-generated user preference files (written by the Dashboard)
config/ui/library-preferences.json
config/ui/library-preferences.json.bak
