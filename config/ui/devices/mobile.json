{
  "device_class": "mobile",
  "display_name": "Mobile",
  "constraints": {
    "features_disabled": ["view_toggle"],
    "pages_disabled": [],
    "allow_text_input": true,
    "min_touch_target_px": 48,
    "force_dark_mode": false
  },
  "content_padding": "pa-2",
  "content_max_width": "Full",
  "shell": {
    "appbar_style": "compact",
    "logo_variant": "icon",
    "intent_dock_items": ["Collections", "Watch", "Read", "Listen"],
    "intent_dock_style": "normal"
  },
  "pages": {
    "home": {
      "collection_hero_enabled": true,
      "collection_hero_layout": "stacked",
      "progress_cards_layout": "stacked",
      "bento_columns": 1,
      "bento_tile_style": "normal",
      "pending_files_display": "badge"
    },
    "preferences": {
      "page_enabled": true,
      "tab_bar_layout": "vertical",
      "general_tab_layout": "stacked",
      "color_swatch_count": 4,
      "playback_tab_enabled": true
    },
    "server_settings": {
      "page_enabled": true,
      "tab_bar_layout": "vertical-accordion",
      "tab_content_layout": "stacked-card"
    }
  }
}
