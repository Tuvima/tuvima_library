{
  "name": "Fanart.tv",
  "provider_id": "bc00000c-0000-4000-8000-000000000013",
  "adapter_type": "config_driven",
  "enabled": true,
  "hydration_stages": [3],
  "requires_api_key": true,

  "can_handle": {
    "media_types": ["Movies", "TV", "Music"],
    "entity_types": ["Work", "MediaAsset"]
  },

  "throttle_ms": 1000,
  "cache_ttl_hours": 336,
  "max_concurrency": 1,

  "endpoints": {
    "api": "https://webservice.fanart.tv/v3"
  },

  "http_client": {
    "timeout_seconds": 15,
    "user_agent": "Tuvima Library/1.0",
    "api_key": "",
    "api_key_delivery": "query",
    "api_key_param_name": "api_key"
  },

  "search_strategies": [
    {
      "name": "movie_lookup",
      "required_fields": ["tmdb_id"],
      "url_template": "{base_url}/movies/{tmdb_id}?api_key={api_key}",
      "method": "GET",
      "response_format": "json"
    },
    {
      "name": "tv_lookup",
      "required_fields": ["tvdb_id"],
      "url_template": "{base_url}/tv/{tvdb_id}?api_key={api_key}",
      "method": "GET",
      "response_format": "json"
    },
    {
      "name": "music_lookup",
      "required_fields": ["musicbrainz_id"],
      "url_template": "{base_url}/music/{musicbrainz_id}?api_key={api_key}",
      "method": "GET",
      "response_format": "json"
    }
  ],

  "image_type_reference": {
    "_note": "Reference only — consumed by ImageEnrichmentService (hardcoded), not ConfigDrivenAdapter.",
    "Movies": {
      "movieposter": { "claim_key": "cover_art", "asset_type": "CoverArt", "take_first": false },
      "moviebackground": { "claim_key": "background", "asset_type": "Background", "take_first": true },
      "hdmovielogo": { "claim_key": "logo", "asset_type": "Logo", "take_first": true },
      "moviebanner": { "claim_key": "banner", "asset_type": "Banner", "take_first": true },
      "hdmovieclearart": { "claim_key": "clearart", "asset_type": "ClearArt", "take_first": true },
      "movieclearart": { "claim_key": "clearart", "asset_type": "ClearArt", "take_first": true },
      "moviedisc": { "claim_key": "disc", "asset_type": "DiscArt", "take_first": true }
    },
    "TV": {
      "tvposter": { "claim_key": "cover_art", "asset_type": "CoverArt", "take_first": false },
      "showbackground": { "claim_key": "background", "asset_type": "Background", "take_first": true },
      "hdtvlogo": { "claim_key": "logo", "asset_type": "Logo", "take_first": true },
      "clearlogo": { "claim_key": "logo", "asset_type": "Logo", "take_first": true },
      "tvbanner": { "claim_key": "banner", "asset_type": "Banner", "take_first": true },
      "hdclearart": { "claim_key": "clearart", "asset_type": "ClearArt", "take_first": true },
      "clearart": { "claim_key": "clearart", "asset_type": "ClearArt", "take_first": true },
      "seasonposter": { "claim_key": "season_poster", "asset_type": "SeasonPoster", "take_first": true },
      "seasonthumb": { "claim_key": "season_thumb", "asset_type": "SeasonThumb", "take_first": true },
      "tvthumb": { "claim_key": "episode_still", "asset_type": "EpisodeStill", "take_first": true }
    },
    "Music": {
      "albumcover": { "claim_key": "cover_art", "asset_type": "CoverArt", "take_first": true },
      "artistbackground": { "claim_key": "background", "asset_type": "Background", "take_first": true },
      "musiclogo": { "claim_key": "logo", "asset_type": "Logo", "take_first": true },
      "cdart": { "claim_key": "disc", "asset_type": "DiscArt", "take_first": true }
    }
  },

  "character_art_fields": {
    "Movies": "characterart",
    "TV": "characterart"
  },

  "language_strategy": "source",
  "ui_metadata": {
    "accent_color": "#19C1CC",
    "material_icon": "Image",
    "external_url_template": "",
    "category": "Image",
    "requires_key": true,
    "auth_type": "api_key",
    "search_chips": {},
    "ranking_chips": {}
  }
}
