{
  "name": "comicvine",
  "version": "1.0",
  "enabled": true,
  "weight": 0.85,
  "domain": "Comic",
  "icon": "images/providers/comicvine.svg",
  "capability_tags": ["title", "author", "cover", "year", "description", "publisher", "series", "series_position", "issue_number", "comic_vine_id"],
  "available_fields": ["title", "author", "cover", "year", "description", "publisher", "series", "series_position", "issue_number", "comic_vine_id"],
  "field_weights": {
    "title": 0.85,
    "author": 0.8,
    "cover": 0.9,
    "year": 0.85,
    "description": 0.8,
    "publisher": 0.85,
    "series": 0.9,
    "series_position": 0.9,
    "issue_number": 0.95,
    "comic_vine_id": 0.95
  },
  "endpoints": {
    "api": "https://comicvine.gamespot.com/api"
  },
  "throttle_ms": 1000,
  "max_concurrency": 1,
  "hydration_stages": [1],
  "cache_ttl_hours": 168,

  "adapter_type": "config_driven",
  "provider_id": "b9000009-0000-4000-8000-000000000014",
  "display_name": "Comic Vine",
  "requires_api_key": true,
  "language_strategy": "source",

  "http_client": {
    "timeout_seconds": 15,
    "user_agent": "Tuvima Library/1.0 (https://github.com/shyfaruqi/tuvima-library)",
    "api_key": "",
    "api_key_delivery": "query",
    "api_key_param_name": "api_key"
  },

  "can_handle": {
    "media_types": ["Comics"],
    "entity_types": ["Work", "MediaAsset"]
  },

  "preferred_bridge_ids": {
    "Comics": ["comic_vine_id"]
  },

  "search_strategies": [
    {
      "name": "issue_search",
      "priority": 1,
      "required_fields": ["title"],
      "url_template": "{base_url}/search/?api_key={api_key}&query={title}&resources=issue&limit={limit}&format=json",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": false,
      "fetch_limit": 25,
      "max_results": 25,
      "media_types": ["Comics"]
    },
    {
      "name": "volume_search",
      "priority": 2,
      "required_fields": ["series"],
      "url_template": "{base_url}/search/?api_key={api_key}&query={series}&resources=volume&limit={limit}&format=json",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": false,
      "fetch_limit": 25,
      "max_results": 25,
      "media_types": ["Comics"]
    }
  ],

  "field_mappings": [
    { "claim_key": "title",           "json_path": "name",                     "confidence": 0.85 },
    { "claim_key": "issue_number",    "json_path": "issue_number",             "confidence": 0.95 },
    { "claim_key": "description",     "json_path": "description",              "confidence": 0.8,  "transform": "strip_html" },
    { "claim_key": "cover",           "json_path": "image.original_url",       "confidence": 0.9 },
    { "claim_key": "year",            "json_path": "cover_date",               "confidence": 0.85, "transform": "first_n_chars", "transform_args": "4" },
    { "claim_key": "series",          "json_path": "volume.name",              "confidence": 0.9 },
    { "claim_key": "series_position", "json_path": "issue_number",             "confidence": 0.9 },
    { "claim_key": "comic_vine_id",   "json_path": "id",                       "confidence": 0.95, "transform": "to_string" }
  ]
}
