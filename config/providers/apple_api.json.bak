  "search_strategies": [
    {
      "name": "isbn_lookup",
      "priority": 0,
      "required_fields": [
        "isbn"
      ],
      "url_template": "{base_url}/lookup?isbn={isbn}",
      "query_template": null,
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": true,
      "max_results": 1,
      "fetch_limit": 1,
      "media_types": [
        "Books"
      ],
      "release_selection": null
    },
    {
      "name": "apple_id_lookup",
      "priority": 1,
      "required_fields": [
        "apple_books_id"
      ],
      "url_template": "{base_url}/lookup?id={apple_books_id}\u0026country={country}\u0026lang={lang}_{country}",
      "query_template": null,
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": true,
      "max_results": 1,
      "fetch_limit": 1,
      "media_types": null,
      "release_selection": null
    },
    {
      "name": "ebook_search",
      "priority": 2,
      "required_fields": [
        "title"
      ],
      "url_template": "{base_url}/search?term={query}\u0026entity=ebook\u0026limit={limit}\u0026country={country}\u0026lang={lang}_{country}",
      "query_template": "{title} {author}",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": false,
      "max_results": 25,
      "fetch_limit": 5,
      "media_types": [
        "Books"
      ],
      "release_selection": null
    },
    {
      "name": "audiobook_search",
      "priority": 2,
      "required_fields": [
