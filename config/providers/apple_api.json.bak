      "results_path": "results",
      "result_index": 0,
      "tolerate_404": false,
      "max_results": 25,
      "fetch_limit": 5,
      "media_types": [
        "Audiobooks"
      ],
      "release_selection": null
    },
    {
      "name": "music_album_search",
      "priority": 3,
      "required_fields": [
        "title"
      ],
      "url_template": "{base_url}/search?term={query}\u0026entity=album\u0026limit={limit}\u0026country={country}\u0026lang={lang}_{country}",
      "query_template": "{artist} {title}",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": false,
      "max_results": 10,
      "fetch_limit": 10,
      "media_types": [
        "Music"
      ],
      "release_selection": null
    },
    {
      "name": "music_search",
      "priority": 2,
      "required_fields": [
        "title"
      ],
      "url_template": "{base_url}/search?term={query}\u0026entity=musicTrack\u0026limit={limit}\u0026country={country}\u0026lang={lang}_{country}",
      "query_template": "{title} {artist}",
      "results_path": "results",
      "result_index": 0,
      "tolerate_404": false,
      "max_results": 25,
      "fetch_limit": 5,
      "media_types": [
        "Music"
      ],
      "release_selection": null
    },
    {
