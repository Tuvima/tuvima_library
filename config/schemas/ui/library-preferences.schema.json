{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tuvima library display preferences",
  "type": "object",
  "required": ["missing_item_display", "view_modes", "lane_group_display"],
  "properties": {
    "missing_item_display": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["enabled", "default_visibility", "presentation", "page_size", "detail_hydration"],
        "properties": {
          "enabled": { "type": "boolean" },
          "default_visibility": { "enum": ["shown", "hidden"] },
          "presentation": { "enum": ["all", "paged"] },
          "page_size": { "type": "integer", "minimum": 1, "maximum": 500 },
          "detail_hydration": { "enum": ["owned_only", "on_demand", "all"] }
        },
        "additionalProperties": false
      }
    },
    "view_modes": { "type": "object", "additionalProperties": { "type": "string" } },
    "lane_group_display": { "type": "object" }
  },
  "additionalProperties": false
}
