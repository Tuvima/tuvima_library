{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tuvima provider configuration",
  "type": "object",
  "required": ["name", "enabled", "weight"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "enabled": { "type": "boolean" },
    "weight": { "type": "number", "minimum": 0, "maximum": 1 },
    "rate_limit": {
      "type": ["object", "null"],
      "properties": {
        "requests_per_second": { "type": "number", "exclusiveMinimum": 0 },
        "requests_per_minute": { "type": "integer", "minimum": 1 },
        "burst": { "type": "integer", "minimum": 1 },
        "max_concurrency": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "hydration_stages": { "type": "array", "items": { "enum": [1, 2, 3] } },
    "bridge_resolution": {
      "type": "object",
      "properties": {
        "scopes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["target_ids", "context_ids", "allow_constrained_text_fallback"],
            "properties": {
              "target_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "context_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "allow_constrained_text_fallback": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "http_client": {
      "type": "object",
      "properties": {
        "timeout_seconds": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
