{
  "stage_concurrency": 3,
  "max_concurrent_retail_provider_jobs": 2,
  "max_concurrent_wikidata_jobs": 1,
  "max_concurrent_fanart_jobs": 1,
  "max_concurrent_writeback_jobs": 1,
  "stage1_timeout_seconds": 45,
  "stage2_timeout_seconds": 15,
  "stage3_timeout_seconds": 30,
  "disambiguation_threshold": 0.7,
  "auto_review_confidence_threshold": 0.60,
  "max_qid_candidates": 5,
  "skip_wikipedia_without_qid": true,
  "continue_pipeline_on_authority_failure": true,
  "wikipedia_description_max_chars": 1000,
  "universe_title_search_auto_accept": 0.80,
  "stage3_waterfall_confidence_threshold": 0.65,
  "post_hydration_organize_threshold": 0.70,
  "universe_xml_write_debounce_seconds": 5,
  "fictional_entity_enrichment_depth": 2,
  "minimum_universe_work_count": 2,

  "two_pass_enabled": false,
  "pass1_core_properties_only": true,
  "pass2_idle_delay_seconds": 10,
  "pass2_rate_limit_ms": 2000,
  "pass2_nightly_cron": "0 2 * * *",
  "pass2_stale_threshold_hours": 24,
  "pass2_batch_size": 50,

  "fetch_temporal_qualifiers": true,
  "batch_sparql_size": 50,
  "lineage_depth": 2,
  "lore_delta_check_on_explorer_open": true,
  "canon_discrepancy_detection": true,
  "era_actor_resolution": true,

  "retail_auto_accept_threshold": 0.90,
  "retail_ambiguous_threshold": 0.65,
  "edition_aware_media_types": ["Books", "Audiobooks", "Movies", "Comics", "Music"],
  "fuzzy_match_weights": {
    "title": 0.45,
    "author": 0.35,
    "year": 0.10,
    "format": 0.10
  },
  "preserve_html_tags": ["b", "i", "em", "strong", "p", "br"],
  "wikidata_batch_size": 50,
  "local_match_enabled": true,
  "local_match_fuzzy_threshold": 0.95,

  "stage3_enabled": true,
  "stage3_schedule_cron": "0 3 * * *",
  "stage3_rate_limit_ms": 2000,
  "stage3_max_items_per_sweep": 50,
  "stage3_refresh_days": 30,
  "series_manifest_refresh_days": 30,
  "stage3_media_types_for_images": ["Movies", "TV", "Music"],
  "stage3_max_depth": 2
}
