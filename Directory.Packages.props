<Project>
  <PropertyGroup>
    <!-- Central Package Management: version numbers live here, not in .csproj files. -->
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>
  <ItemGroup Label="Production">
    <!-- Cronos: lightweight cron expression parser for configurable background schedules.
         MIT license — approved for AGPLv3 compatibility (see CLAUDE.md §5.1). -->
    <PackageVersion Include="Cronos" Version="0.8.4" />
    <!-- Dapper: micro-ORM for type-safe SQLite data access with named column mapping.
         Apache 2.0 license — approved for AGPLv3 compatibility (see CLAUDE.md §5.1). -->
    <PackageVersion Include="Dapper" Version="2.1.66" />
    <PackageVersion Include="dotNetRdf" Version="3.5.1" />
    <!-- FuzzySharp: fuzzy string matching for candidate scoring.
         MIT license — approved for AGPLv3 compatibility (see CLAUDE.md §5.1). -->
    <PackageVersion Include="FuzzySharp" Version="2.0.2" />
    <PackageVersion Include="Microsoft.AspNetCore.SignalR.Client" Version="10.0.3" />
    <PackageVersion Include="Microsoft.Data.Sqlite" Version="10.0.3" />
    <PackageVersion Include="Microsoft.Extensions.Hosting" Version="10.0.3" />
    <PackageVersion Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.3" />
    <!-- Swashbuckle 7.x: kept at 7.x intentionally — upgrading to 10.x requires
         switching Program.cs to the new .NET 9+ OpenAPI infrastructure. -->
    <PackageVersion Include="Swashbuckle.AspNetCore" Version="7.3.1" />
    <PackageVersion Include="TagLibSharp" Version="2.3.0" />
    <PackageVersion Include="VersOne.Epub" Version="3.1.0" />
    <!-- IHttpClientFactory lifecycle management for external metadata adapters.
         MIT license � approved for AGPLv3 compatibility (see CLAUDE.md �5.1). -->
    <PackageVersion Include="Microsoft.Extensions.Http" Version="10.0.3" />
    <!-- SkiaSharp: cross-platform image processing for hero banner generation.
         MIT license — approved for AGPLv3 compatibility (see CLAUDE.md §5.1). -->
    <PackageVersion Include="SkiaSharp" Version="3.119.0" />
    <PackageVersion Include="SkiaSharp.NativeAssets.Linux" Version="3.119.0" />
    <!-- Xabe.FFmpeg: fluent FFmpeg wrapper for media probing and transcoding; MIT license.
         Approved for AGPLv3 compatibility (see CLAUDE.md §5.1). -->
    <PackageVersion Include="Xabe.FFmpeg" Version="5.2.6" />
    <!-- Windows Service hosting: integrates with Service Control Manager for .exe installer.
         MIT license — no-op on Linux/macOS/Docker; safe to include unconditionally. -->
    <PackageVersion Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.3" />
    <!-- Polly / Microsoft.Extensions.Http.Resilience: standard retry, circuit-breaker,
         and timeout policies for all external HTTP calls.
         MIT license — approved for AGPLv3 compatibility (see CLAUDE.md §5.1). -->
    <PackageVersion Include="Microsoft.Extensions.Http.Resilience" Version="10.1.0" />
    <!-- Serilog: structured logging with rolling file output.
         Apache 2.0 license — approved for AGPLv3 compatibility (see CLAUDE.md §5.1). -->
    <PackageVersion Include="Serilog.AspNetCore" Version="9.0.0" />
    <PackageVersion Include="Serilog.Sinks.File" Version="6.0.0" />
    <!-- UI -->
    <PackageVersion Include="MudBlazor" Version="9.0.0" />
  </ItemGroup>
  <ItemGroup Label="Test">
    <PackageVersion Include="coverlet.collector" Version="6.0.4" />
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageVersion Include="xunit" Version="2.9.3" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="3.1.4" />
  </ItemGroup>
</Project>