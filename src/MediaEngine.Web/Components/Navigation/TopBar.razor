@namespace MediaEngine.Web.Components.Navigation
@inject NavigationManager Nav
@inject UniverseStateContainer State
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

@* TopBar — Fixed horizontal navigation bar.
   Logo (left) + nav links (Home/Read/Watch/Listen) + search icon + ProfileDropdown (right).
   Single responsive layout — no device variants, no hamburger menu. *@

<header class="top-bar">
    @* ── Logo ── *@
    <div class="top-bar-left">
        <a href="/" class="top-bar-logo-link">
            <AppLogo Style="height: 36px; display: block;" />
        </a>

        @* ── Nav links (hidden on small screens, shown in hamburger-less responsive way) ── *@
        <nav class="top-bar-nav">
            @foreach (var link in _navLinks)
            {
                <a href="@link.Path"
                   class="top-bar-nav-link @(IsActive(link.Path) ? "top-bar-nav-link-active" : "")"
                   style="border-color: @NavColor(link.Path); @(IsActive(link.Path) ? $"color: white;" : "")">
                    @link.Label
                </a>
            }
        </nav>
    </div>

    @* ── Right side: search + profile ── *@
    <div class="top-bar-right">
        <MudIconButton Icon="@MudBlazor.Icons.Material.Outlined.Search"
                       Color="Color.Inherit" Size="Size.Medium"
                       Class="top-bar-search-btn"
                       aria-label="Search" />
        <ProfileDropdown AvatarColor="@AvatarColor"
                         AvatarInitial="@AvatarInitial"
                         DisplayName="@DisplayName"
                         ReviewCount="@ReviewCount" />
    </div>
</header>

@code {
    [Parameter] public int ReviewCount { get; set; }
    [Parameter] public string AvatarColor { get; set; } = "#C9922E";
    [Parameter] public string AvatarInitial { get; set; } = "?";
    [Parameter] public string DisplayName { get; set; } = "User";

    private static readonly (string Path, string Label)[] _navLinks =
    [
        ("/", "Home"),
        ("/read", "Read"),
        ("/watch", "Watch"),
        ("/listen", "Listen"),
    ];

    private string _currentPath = "";

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        UpdateCurrentPath();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateCurrentPath();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateCurrentPath()
    {
        _currentPath = "/" + Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Split('#')[0].Trim('/');
    }

    private bool IsActive(string path) => _currentPath.Equals(path, StringComparison.OrdinalIgnoreCase)
        || (path == "/" && _currentPath == "");

    private string NavColor(string path)
    {
        if (!IsActive(path)) return "transparent";
        return path switch
        {
            "/read" => "#5DCAA5",
            "/watch" => "#60A5FA",
            "/listen" => "#1ED760",
            _ => "#C9922E",
        };
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}

<style>
    .top-bar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 64px;
        z-index: 1250;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 0.75rem;
        background: rgba(6, 10, 22, 0.60);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    @@media (min-width: 640px) {
        .top-bar {
            padding: 0 1.5rem;
        }
    }

    @@media (min-width: 768px) {
        .top-bar {
            padding: 0 2rem;
        }
    }

    @@media (min-width: 1024px) {
        .top-bar {
            padding: 0 4rem;
        }
    }

    .top-bar-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    @@media (min-width: 640px) {
        .top-bar-left {
            gap: 2rem;
        }
    }

    .top-bar-logo-link {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        cursor: pointer;
    }

    /* ── Nav links ── */
    .top-bar-nav {
        display: none;
        align-items: center;
        gap: 1.25rem;
    }

    /* Show nav tabs on tablets and large phones (≥640px). Very small phones
       fall back to the ProfileDropdown for category navigation. */
    @@media (min-width: 640px) {
        .top-bar-nav {
            display: flex;
        }
    }

    @@media (min-width: 1024px) {
        .top-bar-nav {
            gap: 2rem;
        }
    }

    .top-bar-nav-link {
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: rgba(148, 163, 184, 1);
        text-decoration: none;
        padding: 4px 0;
        border-bottom: 2px solid transparent;
        transition: all 0.2s ease;
    }

    .top-bar-nav-link:hover {
        color: white;
    }

    .top-bar-nav-link-active {
        color: white;
    }

    /* ── Right side ── */
    .top-bar-right {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .top-bar-search-btn {
        color: rgba(148, 163, 184, 1) !important;
    }

    .top-bar-search-btn:hover {
        color: white !important;
        background: rgba(255, 255, 255, 0.06) !important;
    }
</style>
