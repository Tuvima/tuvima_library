@namespace MediaEngine.Web.Components.Navigation
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

<header class="top-bar">
    <div class="top-bar-shell">
        <div class="top-bar-left">
            <button type="button"
                    class="top-bar-mobile-trigger @(_isMobileMenuOpen ? "top-bar-mobile-trigger-active" : string.Empty)"
                    @onclick="ToggleMobileMenu"
                    aria-label="@(_isMobileMenuOpen ? L["Nav_CloseNavigation"] : L["Nav_OpenNavigation"])"
                    aria-expanded="@_isMobileMenuOpen"
                    aria-controls="top-bar-mobile-panel">
                <AppIcon Name="@(_isMobileMenuOpen ? AppIcons.Close : "fa:bars")"
                         Size="1rem"
                         Class="top-bar-mobile-trigger-icon" />
            </button>

            <a href="/" class="top-bar-logo-link" aria-label="Tuvima Library">
                <AppLogo Variant="mark" Class="top-bar-logo-mark" />
            </a>

            <nav class="top-bar-nav" aria-label="Primary">
                @foreach (var link in _navLinks)
                {
                    var isActive = IsActive(link.Path);

                    <a href="@link.Path"
                       class="top-bar-nav-link @(isActive ? "top-bar-nav-link-active" : string.Empty)"
                       aria-current="@(isActive ? "page" : null)">
                        @L[link.LabelKey]
                    </a>
                }
            </nav>
        </div>

        <div class="top-bar-right">
            <form class="top-bar-search"
                  role="search"
                  @onsubmit="HandleSearchSubmit"
                  @onsubmit:preventDefault="true">
                <button type="submit"
                        class="top-bar-search-submit"
                        aria-label="@L["Nav_Search"]"
                        title="@L["Nav_Search"]">
                    <AppIcon Name="@AppIcons.Search"
                             Size="0.95rem"
                             Class="top-bar-search-submit-icon" />
                </button>

                <input type="search"
                       class="top-bar-search-input"
                       autocomplete="off"
                       placeholder="@L["Nav_SearchPlaceholder"]"
                       aria-label="@L["Nav_SearchPlaceholder"]"
                       @bind="_searchTerm"
                       @bind:event="oninput" />
            </form>

            <ProfileDropdown AvatarColor="@AvatarColor"
                             AvatarInitial="@AvatarInitial"
                             DisplayName="@DisplayName"
                             ReviewCount="@ReviewCount"
                             EngineStatusSummary="@EngineStatusSummary" />
        </div>
    </div>

    @if (_isMobileMenuOpen)
    {
        <div class="top-bar-mobile-backdrop" @onclick="CloseMobileMenu"></div>
        <div id="top-bar-mobile-panel" class="top-bar-mobile-panel">
            @foreach (var link in _navLinks)
            {
                var isActive = IsActive(link.Path);

                <a href="@link.Path"
                   class="top-bar-mobile-link @(isActive ? "top-bar-mobile-link-active" : string.Empty)"
                   aria-current="@(isActive ? "page" : null)"
                   @onclick="CloseMobileMenu">
                    <AppIcon Name="@link.Icon"
                             Size="0.95rem"
                             Class="top-bar-mobile-link-icon" />
                    <span>@L[link.LabelKey]</span>
                </a>
            }
        </div>
    }
</header>

@code {
    [Parameter] public int ReviewCount { get; set; }
    [Parameter] public string AvatarColor { get; set; } = "#C9922E";
    [Parameter] public string AvatarInitial { get; set; } = "?";
    [Parameter] public string DisplayName { get; set; } = "User";
    [Parameter] public string EngineStatusSummary { get; set; } = string.Empty;

    private readonly record struct TopBarNavLink(string Path, string Icon, string LabelKey);

    private static readonly TopBarNavLink[] _navLinks =
    [
        new("/read", AppIcons.Read, "Nav_Read"),
        new("/watch", AppIcons.Watch, "Nav_Watch"),
        new("/listen", AppIcons.Listen, "Nav_Listen"),
    ];

    private string _currentPath = "/";
    private string _searchTerm = string.Empty;
    private bool _isMobileMenuOpen;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        UpdateLocationState();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _isMobileMenuOpen = false;
        UpdateLocationState();
        InvokeAsync(StateHasChanged);
    }

    private void HandleSearchSubmit()
    {
        var trimmedSearch = _searchTerm.Trim();
        var url = string.IsNullOrWhiteSpace(trimmedSearch)
            ? "/search"
            : $"/search?q={Uri.EscapeDataString(trimmedSearch)}";

        _isMobileMenuOpen = false;
        Nav.NavigateTo(url);
    }

    private void ToggleMobileMenu() => _isMobileMenuOpen = !_isMobileMenuOpen;

    private void CloseMobileMenu() => _isMobileMenuOpen = false;

    private void UpdateLocationState()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
        var trimmedPath = relativePath.Split('?', '#')[0].Trim('/');
        _currentPath = string.IsNullOrWhiteSpace(trimmedPath)
            ? "/"
            : $"/{trimmedPath}";

        if (!_currentPath.Equals("/search", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
        _searchTerm = query.TryGetValue("q", out var searchTerm)
            ? searchTerm.ToString()
            : string.Empty;
    }

    private bool IsActive(string path)
    {
        if (path == "/")
        {
            return _currentPath == "/";
        }

        return _currentPath.Equals(path, StringComparison.OrdinalIgnoreCase)
            || _currentPath.StartsWith(path + "/", StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
