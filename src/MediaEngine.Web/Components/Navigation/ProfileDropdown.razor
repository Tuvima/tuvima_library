@namespace MediaEngine.Web.Components.Navigation
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L

<div class="profile-dropdown" style="--profile-avatar-color: @AvatarColor;">
    <button type="button"
            class="profile-trigger @(_isOpen ? "profile-trigger-active" : string.Empty)"
            @onclick="Toggle"
            aria-haspopup="menu"
            aria-expanded="@_isOpen"
            aria-label="@L["TopBar_OpenProfileMenu"]"
            title="@L["TopBar_OpenProfileMenu"]">
        <span class="profile-trigger-avatar">@AvatarInitial</span>
        <span class="profile-trigger-name">@TriggerName</span>

        @if (ReviewCount > 0)
        {
            <span class="profile-trigger-badge">@ReviewCount</span>
        }

        <AppIcon Name="@AppIcons.ChevronDown"
                 Size="0.75rem"
                 Class="@($"profile-trigger-chevron {(_isOpen ? "profile-trigger-chevron-open" : string.Empty)}")" />
    </button>

    @if (_isOpen)
    {
        <div class="profile-menu-backdrop" @onclick="Close"></div>

        <div class="profile-menu" role="menu">
            <div class="profile-menu-header">
                <span class="profile-menu-header-avatar">@AvatarInitial</span>
                <div class="profile-menu-header-copy">
                    <span class="profile-menu-header-label">@L["TopBar_SignedInAs"]</span>
                    <span class="profile-menu-header-name">@SafeDisplayName</span>
                </div>
            </div>

            <div class="profile-menu-actions">
                <button type="button" class="profile-menu-item" @onclick='() => Navigate("/settings/review")'>
                    <AppIcon Name="@AppIcons.Review"
                             Size="0.95rem"
                             Class="profile-menu-item-icon" />
                    <span class="profile-menu-item-label">@L["Nav_ReviewQueue"]</span>
                    @if (ReviewCount > 0)
                    {
                        <span class="profile-menu-item-badge">@ReviewCount</span>
                    }
                </button>

                <button type="button" class="profile-menu-item" @onclick='() => Navigate("/collections")'>
                    <AppIcon Name="@AppIcons.Collections"
                             Size="0.95rem"
                             Class="profile-menu-item-icon" />
                    <span class="profile-menu-item-label">@L["Nav_Collections"]</span>
                </button>

                <button type="button" class="profile-menu-item" @onclick='() => Navigate("/settings")'>
                    <AppIcon Name="@AppIcons.Settings"
                             Size="0.95rem"
                             Class="profile-menu-item-icon" />
                    <span class="profile-menu-item-label">@L["Nav_Settings"]</span>
                </button>
            </div>

            <div class="profile-menu-status">
                <span class="profile-menu-status-label">@L["TopBar_EngineStatus"]</span>
                <span class="profile-menu-status-text">@ResolvedEngineStatusSummary</span>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string AvatarColor { get; set; } = "#C9922E";
    [Parameter] public string AvatarInitial { get; set; } = "?";
    [Parameter] public string DisplayName { get; set; } = "User";
    [Parameter] public int ReviewCount { get; set; }
    [Parameter] public string EngineStatusSummary { get; set; } = string.Empty;

    private bool _isOpen;

    private string SafeDisplayName =>
        string.IsNullOrWhiteSpace(DisplayName)
            ? "User"
            : DisplayName.Trim();

    private string TriggerName =>
        SafeDisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()
        ?? SafeDisplayName;

    private string ResolvedEngineStatusSummary =>
        string.IsNullOrWhiteSpace(EngineStatusSummary)
            ? L["TopBar_EngineUnavailable"]
            : EngineStatusSummary;

    private void Toggle() => _isOpen = !_isOpen;

    private void Close() => _isOpen = false;

    private void Navigate(string url)
    {
        _isOpen = false;
        Nav.NavigateTo(url);
    }
}
