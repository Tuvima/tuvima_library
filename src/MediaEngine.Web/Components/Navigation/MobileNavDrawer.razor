@namespace MediaEngine.Web.Components.Navigation

@using MediaEngine.Web.Models.ViewDTOs

@inject NavigationManager Nav
@implements IDisposable

@* MobileNavDrawer -- Slide-out navigation drawer for mobile devices.
   Triggered by hamburger icon in the TopBar. Fixed content-type lanes matching the LeftDock.
   Settings expands inline as a tree node with grouped sub-items.
   Drawer renders its own hamburger at the top so the toggle stays visible while open. *@

<MudDrawer @bind-Open="@Open" Anchor="Anchor.Left" Variant="@DrawerVariant.Temporary"
           Elevation="0" Class="mobile-nav-drawer">

    @* -- Hamburger header: mirrors TopBar toggle, stays visible while drawer is open -- *@
    <div class="mobile-nav-header">
        <button class="mobile-nav-hamburger" @onclick="CloseDrawer" aria-label="Close navigation menu">
            <MudIcon Icon="@Icons.Material.Filled.Menu"
                     Style="font-size: 24px; color: rgba(248,248,248,0.80);" />
        </button>
    </div>

    @* -- Fixed content-type lanes -- *@
    <MudNavMenu Color="Color.Inherit" Class="mobile-nav-menu">

        @foreach (var lane in ContentLanes.All)
        {
            var route = lane.Key == "home" ? "/" : $"/{lane.Key}";

            <MudNavLink Href="@route"
                        Icon="@lane.Icon"
                        Match="@(lane.Key == "home" ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                        OnClick="@CloseDrawer">
                @lane.Label
            </MudNavLink>
        }

        <MudNavLink Href="/vault" Icon="@Icons.Material.Outlined.Shield"
                    Match="NavLinkMatch.Prefix" OnClick="@CloseDrawer">
            Vault
            @if (ReviewCount > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled"
                         Class="ml-auto" Style="height: 18px; font-size: 0.65rem; min-width: 0; padding: 0 6px;">
                    @ReviewCount
                </MudChip>
            }
        </MudNavLink>

        <MudNavLink Href="/universes" Icon="@Icons.Material.Outlined.Public"
                    Match="NavLinkMatch.Prefix" OnClick="@CloseDrawer">
            Universes
        </MudNavLink>

        <MudDivider Class="my-2" Style="border-color: rgba(255,255,255,0.06);" />

        @* -- Settings expandable tree -- *@
        <div class="mobile-nav-settings-toggle" @onclick="ToggleSettings">
            <MudIcon Icon="@Icons.Material.Outlined.Settings"
                     Size="Size.Medium"
                     Style="color: rgba(248,248,248,0.70); flex-shrink: 0;" />
            <span class="mobile-nav-settings-label" style="flex: 1;">Settings</span>
            <MudIcon Icon="@(_settingsExpanded
                            ? Icons.Material.Filled.ExpandMore
                            : Icons.Material.Filled.ChevronRight)"
                     Size="Size.Small"
                     Style="color: rgba(248,248,248,0.35); flex-shrink: 0;" />
        </div>

        @if (_settingsExpanded)
        {
            @foreach (var group in SettingsNav.FilteredGroups(CurrentRole))
            {
                var items = SettingsNav.FilteredItems(group, CurrentRole);
                if (items.Count == 0) continue;

                <MudText Typo="Typo.overline"
                         Style="padding: 10px 16px 2px 48px; color: rgba(248,248,248,0.35); letter-spacing: 0.1em;">
                    @group.Label
                </MudText>

                @foreach (var item in items)
                {
                    var badgeCount = GetBadgeCount(item.BadgeKey);

                    <MudNavLink Href="@(SettingsNav.RouteFor(item.Value))"
                                Icon="@item.Icon"
                                Match="NavLinkMatch.All"
                                OnClick="@CloseDrawer"
                                Style="padding-left: 48px;">
                        @item.Label
                        @if (badgeCount > 0)
                        {
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="Color.Warning"
                                     Variant="Variant.Filled"
                                     Style="height: 18px; font-size: 0.65rem; min-width: 0; padding: 0 6px; margin-left: 8px;">
                                @badgeCount
                            </MudChip>
                        }
                    </MudNavLink>
                }
            }
        }
    </MudNavMenu>

    @* -- Profile entry at the end -- *@
    <div class="mobile-nav-profile" @onclick="@NavigateToProfile">
        <MudAvatar Size="Size.Small"
                   Style="@($"background: {AvatarColor}; width: 32px; height: 32px; font-size: 0.8rem;")">
            @AvatarInitial
        </MudAvatar>
        <span class="mobile-nav-profile-name">@DisplayName</span>
    </div>
</MudDrawer>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public string AvatarColor { get; set; } = "#C9922E";
    [Parameter] public string AvatarInitial { get; set; } = "?";
    [Parameter] public string DisplayName { get; set; } = "User";
    [Parameter] public string CurrentRole { get; set; } = "Administrator";
    [Parameter] public int ReviewCount { get; set; }

    private bool _settingsExpanded;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        UpdateSettingsState();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateSettingsState();
        // Always close the drawer on navigation — handles all cases including
        // MudNavLink href navigation and programmatic Nav.NavigateTo() calls.
        if (Open)
        {
            Open = false;
            _ = OpenChanged.InvokeAsync(false);
        }
        InvokeAsync(StateHasChanged);
    }

    private void UpdateSettingsState()
    {
        // Auto-expand when already on a settings page.
        var uri = Nav.ToBaseRelativePath(Nav.Uri);
        if (uri.StartsWith("settings", StringComparison.OrdinalIgnoreCase))
            _settingsExpanded = true;
    }

    private void ToggleSettings()
    {
        _settingsExpanded = !_settingsExpanded;
    }

    private int GetBadgeCount(string? badgeKey) =>
        badgeKey switch
        {
            "review" => ReviewCount,
            _        => 0,
        };

    private async Task CloseDrawer()
    {
        Open = false;
        await OpenChanged.InvokeAsync(false);
    }

    private async Task NavigateToProfile()
    {
        await CloseDrawer();
        Nav.NavigateTo("/switch-profile");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}

<style>
    .mobile-nav-drawer {
        background: rgba(10, 10, 10, 0.95) !important;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        min-width: 260px;
        top: 0 !important;
    }

    .mobile-nav-drawer .mud-drawer-content {
        display: flex !important;
        flex-direction: column !important;
        justify-content: flex-start !important;
        align-items: stretch !important;
        height: 100% !important;
        overflow-y: auto;
        padding-top: 0 !important;  /* header provides top spacing */
    }

    /* -- Drawer header: matches TopBar hamburger height / padding exactly -- */
    .mobile-nav-header {
        display: flex;
        align-items: center;
        height: 56px;
        padding: 0 12px;
        flex-shrink: 0;
    }

    /* Unstyled button that looks like the TopBar hamburger */
    .mobile-nav-hamburger {
        background: none;
        border: none;
        padding: 8px;
        margin: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: background 0.15s ease;
    }

    .mobile-nav-hamburger:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    .mobile-nav-menu {
        padding: 0 8px;
    }

    .mobile-nav-menu .mud-nav-link {
        color: rgba(248, 248, 248, 0.70);
        border-radius: 8px;
        margin-bottom: 2px;
    }

    .mobile-nav-menu .mud-nav-link:hover {
        background: rgba(255, 255, 255, 0.06);
        color: rgba(248, 248, 248, 0.95);
    }

    /* -- Settings toggle row -- */
    .mobile-nav-settings-toggle {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        border-radius: 8px;
        cursor: pointer;
        margin-bottom: 2px;
        transition: background 0.15s ease;
    }

    .mobile-nav-settings-toggle:hover {
        background: rgba(255, 255, 255, 0.06);
    }

    .mobile-nav-settings-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.875rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.70);
    }

    .mobile-nav-profile {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 8px;
        cursor: pointer;
        color: rgba(248, 248, 248, 0.70);
        margin: 4px 8px 0;
        transition: background 0.15s ease, color 0.15s ease;
    }

    .mobile-nav-profile:hover {
        background: rgba(255, 255, 255, 0.06);
        color: rgba(248, 248, 248, 0.95);
    }

    .mobile-nav-profile-name {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.875rem;
        font-weight: 500;
    }
</style>
