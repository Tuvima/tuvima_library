@namespace MediaEngine.Web.Components.Navigation
@inject NavigationManager Nav
@inject DeviceContextService DeviceContext
@implements IDisposable

@using MediaEngine.Web.Models.ViewDTOs
@using System.Threading

@* Left Navigation Dock — Floating glassmorphic panel below the TopBar.
   Narrow state (64px): icon-only.
   Expanded state (hover, 220px): overlay with labels.
   Bottom: Settings → Profile avatar → Clock *@

<div class="left-dock @(_expanded ? "left-dock-expanded" : "")"
     @onmouseenter="@(() => _expanded = true)"
     @onmouseleave="@(() => _expanded = false)">

    @* ── Top spacer to push icons down from the very top ── *@
    <div class="dock-top-spacer"></div>

    @* ── Navigation items ── *@
    <nav class="dock-nav">

        @* Home *@
        <div class="dock-item @(IsActive("/") ? "dock-item-active dock-item-home-active" : "dock-item-home")"
             @onclick="@(() => Nav.NavigateTo("/"))"
             title="Home">
            <MudIcon Icon="@Icons.Material.Outlined.Home" Size="Size.Medium" />
            @if (_expanded)
            {
                <span class="dock-label">Home</span>
            }
        </div>

        @* Search *@
        <div class="dock-item @(IsActive("/search") ? "dock-item-active" : "")"
             @onclick="@(() => Nav.NavigateTo("/search"))"
             title="Search">
            <MudIcon Icon="@Icons.Material.Outlined.Search" Size="Size.Medium" />
            @if (_expanded)
            {
                <span class="dock-label">Search</span>
            }
        </div>

        @* Virtual Libraries *@
        @foreach (var lib in Config.Libraries.Where(l => l.Enabled))
        {
            var isShowAll = lib.MediaTypes.Count == 0;
            if (!isShowAll && !HasMatchingContent(lib)) continue;

            var isActive = string.Equals(ActiveLibraryKey, lib.Key, StringComparison.OrdinalIgnoreCase);

            <div class="dock-item @(isActive ? "dock-item-active" : "")"
                 @onclick="@(() => SelectLibrary(lib))"
                 title="@lib.Label">
                <MudIcon Icon="@NavigationDefaults.GetMudIcon(lib.Icon)" Size="Size.Medium" />
                @if (_expanded)
                {
                    <span class="dock-label">@lib.Label</span>
                }
            </div>
        }
    </nav>

    @* ── Bottom: Settings, Avatar, Clock ── *@
    <div class="dock-bottom">
        @* Settings *@
        <div class="dock-item @(IsActive("/settings") ? "dock-item-active" : "")"
             @onclick="@(() => Nav.NavigateTo("/settings"))"
             title="Settings">
            <MudIcon Icon="@Icons.Material.Outlined.Settings" Size="Size.Medium" />
            @if (_expanded)
            {
                <span class="dock-label">Settings</span>
            }
        </div>

        @* Profile avatar *@
        <div class="dock-item dock-item-avatar"
             @onclick="@(() => Nav.NavigateTo("/switch-profile"))"
             title="@DisplayName">
            <MudAvatar Style="@($"background: {AvatarColor}; width: 36px; height: 36px; font-size: 0.9rem; flex-shrink: 0;")"
                       Size="Size.Small">
                @AvatarInitial
            </MudAvatar>
            @if (_expanded)
            {
                <span class="dock-label">@DisplayName</span>
            }
        </div>

        @* Clock *@
        <div class="dock-clock" title="@_clockDate">
            <span class="dock-clock-time">@(_expanded ? _clockTime : _clockTimeNarrow)</span>
            @if (_expanded)
            {
                <span class="dock-clock-date">@_clockDate</span>
            }
            else
            {
                <span class="dock-clock-date-narrow">@_clockDateNarrow</span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public TrayConfig Config { get; set; } = new();
    [Parameter] public string? ActiveLibraryKey { get; set; }
    [Parameter] public EventCallback<VirtualLibrary?> OnLibrarySelected { get; set; }
    [Parameter] public HashSet<string> AvailableMediaTypes { get; set; } = [];

    [Parameter] public EventCallback OnSearchRequested { get; set; }
    [Parameter] public string AvatarColor { get; set; } = "#C9922E";
    [Parameter] public string AvatarInitial { get; set; } = "?";
    [Parameter] public string DisplayName { get; set; } = "User";
    [Parameter] public int ReviewCount { get; set; }

    private bool _expanded;

    // Clock state
    private string _clockTime = string.Empty;
    private string _clockTimeNarrow = string.Empty;
    private string _clockDate = string.Empty;
    private string _clockDateNarrow = string.Empty;
    private Timer? _clockTimer;

    protected override void OnInitialized()
    {
        DeviceContext.OnChanged += OnDeviceChanged;
        UpdateClock();
        _clockTimer = new Timer(_ =>
        {
            UpdateClock();
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void UpdateClock()
    {
        var now = DateTime.Now;
        // Respect system's short-time culture format (12h vs 24h) for expanded view
        _clockTime = now.ToString("t");
        // Compact 24h format (5 chars max) for narrow dock — fits inside 64px width
        _clockTimeNarrow = now.ToString("H:mm");
        _clockDate = now.ToString("ddd, MMM d");
        _clockDateNarrow = now.ToString("ddd");
    }

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    private bool IsActive(string path) =>
        Nav.Uri.EndsWith(path, StringComparison.OrdinalIgnoreCase)
        || (path == "/" && Nav.Uri.EndsWith(Nav.BaseUri.TrimEnd('/'), StringComparison.OrdinalIgnoreCase));

    private bool HasMatchingContent(VirtualLibrary lib) =>
        lib.MediaTypes.Any(mt => AvailableMediaTypes.Contains(mt, StringComparer.OrdinalIgnoreCase));

    private async Task SelectLibrary(VirtualLibrary lib)
    {
        if (lib.MediaTypes.Count == 0 ||
            string.Equals(ActiveLibraryKey, lib.Key, StringComparison.OrdinalIgnoreCase))
        {
            await OnLibrarySelected.InvokeAsync(null);
        }
        else
        {
            await OnLibrarySelected.InvokeAsync(lib);
        }
    }

    public void Dispose()
    {
        DeviceContext.OnChanged -= OnDeviceChanged;
        _clockTimer?.Dispose();
    }
}

<style>
    /* ── Floating panel — narrow (default) ───────────────────────────── */
    .left-dock {
        position: fixed;
        top: 80px;   /* Below the 64px TopBar + 16px gap */
        left: 12px;
        bottom: 12px;
        width: 64px;
        z-index: 1200;
        display: flex;
        flex-direction: column;
        padding: 0 6px 12px;

        background: var(--app-dock-bg);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid var(--app-dock-border);
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255,255,255,0.04) inset;

        border-radius: 18px;

        transition: width 0.25s ease;
        overflow: hidden;
    }

    /* ── Expanded dock (hover overlay) ───────────────────────────────── */
    .left-dock-expanded {
        width: 220px;
        box-shadow: 0 12px 48px rgba(0, 0, 0, 0.65), 0 0 0 1px rgba(255,255,255,0.06) inset;
    }

    /* ── Top spacer — pushes icons down from the rounded top ─────────── */
    .dock-top-spacer {
        height: 16px;
        flex-shrink: 0;
    }

    /* ── Navigation area ─────────────────────────────────────────────── */
    .dock-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 2px;
        overflow-y: auto;
        overflow-x: hidden;
        scrollbar-width: none;
    }

    .dock-nav::-webkit-scrollbar { display: none; }

    /* ── Dock item (shared style) ────────────────────────────────────── */
    .dock-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 10px;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.15s ease, color 0.15s ease;
        min-height: 44px;
        color: var(--app-dock-text);
    }

    .left-dock:not(.left-dock-expanded) .dock-item {
        justify-content: center;
        padding: 10px 0;
    }

    .dock-item:hover {
        background: var(--app-dock-hover);
    }

    /* Active: white icon + label, amber left-edge line */
    .dock-item-active {
        background: transparent;
        color: #F8F8F8;
        position: relative;
    }

    .dock-item-active::before {
        content: "";
        position: absolute;
        left: 0;
        top: 25%;
        height: 50%;
        width: 3px;
        background: #EAB308;
        border-radius: 0 4px 4px 0;
    }

    .dock-item-active:hover {
        background: transparent;
    }

    /* Home button: soft amber highlight when active */
    .dock-item-home-active {
        background: rgba(234, 179, 8, 0.10) !important;
        color: #EAB308 !important;
    }

    .dock-item-home-active:hover {
        background: rgba(234, 179, 8, 0.15) !important;
    }

    .dock-item-home-active::before {
        background: #EAB308 !important;
    }

    /* ── Label (only visible when expanded) ──────────────────────────── */
    .dock-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.88rem;
        font-weight: 500;
        color: inherit;
    }

    .dock-item-active .dock-label {
        font-weight: 700;
    }

    /* ── Bottom section ──────────────────────────────────────────────── */
    .dock-bottom {
        display: flex;
        flex-direction: column;
        gap: 2px;
        flex-shrink: 0;
        padding-top: 8px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        margin-top: 6px;
    }

    /* Avatar item — inherits dock-item but with avatar specifics */
    .dock-item-avatar {
        min-height: 44px;
    }

    /* ── Clock ───────────────────────────────────────────────────────── */
    .dock-clock {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 8px 0 4px;
        gap: 2px;
        cursor: default;
        overflow: hidden;
    }

    .left-dock-expanded .dock-clock {
        align-items: flex-start;
        padding-left: 12px;
    }

    .dock-clock-time {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.88rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.80);
        line-height: 1.2;
        white-space: nowrap;
    }

    .dock-clock-date {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 400;
        color: var(--app-dock-text-muted);
        white-space: nowrap;
    }

    .dock-clock-date-narrow {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        font-weight: 400;
        color: var(--app-dock-text-muted);
        white-space: nowrap;
        text-align: center;
    }
</style>
