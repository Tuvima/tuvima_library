@namespace MediaEngine.Web.Components.Navigation
@inject NavigationManager Nav
@inject DeviceContextService DeviceContext
@implements IDisposable

@using MediaEngine.Web.Models.ViewDTOs
@using System.Threading

@* Left Navigation Dock — Floating glassmorphic panel below the TopBar.
   Fixed content-type lanes: Home, Search, Books, Video, Music, Podcasts, Comics.
   Settings expands inline as a tree node with grouped sub-items.
   Narrow state (64px): icon-only.
   Expanded state (hover, 220px): overlay with labels.
   Bottom: Profile avatar → Clock *@

<div class="left-dock @(_expanded ? "left-dock-expanded" : "")"
     @onmouseenter="@(() => _expanded = true)"
     @onmouseleave="@(() => _expanded = false)">

    @* ── Top spacer to push icons down from the very top ── *@
    <div class="dock-top-spacer"></div>

    @* ── Navigation items ── *@
    <nav class="dock-nav">

        @* ── Content-type lanes ── *@
        @foreach (var lane in ContentLanes.All)
        {
            var route = lane.Key == "home" ? "/" : $"/{lane.Key}";
            var isHome = lane.Key == "home";
            var isActive = IsActive(route, lane.Key);
            var activeClass = isActive
                ? (isHome ? "dock-item-active dock-item-home-active" : "dock-item-active")
                : (isHome ? "dock-item-home" : "");

            <div class="dock-item @activeClass"
                 @onclick="@(() => Nav.NavigateTo(route))"
                 title="@lane.Label">
                <MudIcon Icon="@lane.Icon" Size="Size.Medium" />
                @if (_expanded)
                {
                    <span class="dock-label">@lane.Label</span>
                }
            </div>
        }

        @* ── Registry ── *@
        <div class="dock-settings-divider"></div>

        <div class="dock-item @(IsActive("/registry", "registry") ? "dock-item-active" : "")"
             @onclick="@(() => Nav.NavigateTo("/registry"))"
             title="@(ReviewCount > 0 ? $"Registry ({ReviewCount} pending)" : "Registry")">
            @if (ReviewCount > 0)
            {
                <MudBadge Content="@ReviewCount" Color="Color.Warning" Overlap="true" Visible="true">
                    <MudIcon Icon="@Icons.Material.Outlined.FactCheck" Size="Size.Medium" />
                </MudBadge>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Outlined.FactCheck" Size="Size.Medium" />
            }
            @if (_expanded)
            {
                <span class="dock-label">Registry</span>
            }
        </div>

        @* ── Settings tree ── *@
        <div class="dock-settings-divider"></div>

        <div class="dock-item dock-settings-toggle @(_isOnSettingsPage ? "dock-item-active" : "")"
             @onclick="ToggleSettings"
             title="Settings">
            <MudIcon Icon="@Icons.Material.Outlined.Settings" Size="Size.Medium" />
            @if (_expanded)
            {
                <span class="dock-label" style="flex: 1;">Settings</span>
                <MudIcon Icon="@(_settingsExpanded
                                ? Icons.Material.Filled.ExpandMore
                                : Icons.Material.Filled.ChevronRight)"
                         Size="Size.Small"
                         Style="color: var(--app-dock-text-muted); flex-shrink: 0;" />
            }
        </div>

        @if (_settingsExpanded)
        {
            @foreach (var group in SettingsNav.FilteredGroups(CurrentRole))
            {
                var items = SettingsNav.FilteredItems(group, CurrentRole);
                if (items.Count == 0) continue;

                @* Group divider *@
                @if (_expanded)
                {
                    <div class="dock-group-label">@group.Label</div>
                }
                else
                {
                    <div class="dock-group-rule"></div>
                }

                @* Sub-items *@
                @foreach (var item in items)
                {
                    var isItemActive = _activeSettingsSection == item.Value;
                    var badgeCount = GetBadgeCount(item.BadgeKey);

                    <div class="dock-item dock-settings-sub @(isItemActive ? "dock-item-active" : "")"
                         @onclick="@(() => Nav.NavigateTo(SettingsNav.RouteFor(item.Value)))"
                         title="@item.Label">
                        @if (badgeCount > 0)
                        {
                            <MudBadge Content="@badgeCount.ToString()"
                                      Color="Color.Error"
                                      Overlap="true"
                                      Dot="true"
                                      Visible="true">
                                <MudIcon Icon="@item.Icon" Size="Size.Small" />
                            </MudBadge>
                        }
                        else
                        {
                            <MudIcon Icon="@item.Icon" Size="Size.Small" />
                        }
                        @if (_expanded)
                        {
                            <span class="dock-label">@item.Label</span>
                            @if (badgeCount > 0)
                            {
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Color="Color.Warning"
                                         Variant="Variant.Filled"
                                         Style="height: 18px; font-size: 0.65rem; min-width: 0; padding: 0 6px;">
                                    @badgeCount
                                </MudChip>
                            }
                        }
                    </div>
                }
            }
        }
    </nav>

    @* ── Bottom: Avatar, Clock ── *@
    <div class="dock-bottom">
        @* Profile avatar *@
        <div class="dock-item dock-item-avatar"
             @onclick="@(() => Nav.NavigateTo("/switch-profile"))"
             title="@DisplayName">
            <MudAvatar Style="@($"background: {AvatarColor}; width: 36px; height: 36px; font-size: 0.9rem; flex-shrink: 0;")"
                       Size="Size.Small">
                @AvatarInitial
            </MudAvatar>
            @if (_expanded)
            {
                <span class="dock-label">@DisplayName</span>
            }
        </div>

        @* Clock *@
        <div class="dock-clock" title="@_clockDate">
            <span class="dock-clock-time">@(_expanded ? _clockTime : _clockTimeNarrow)</span>
            @if (_expanded)
            {
                <span class="dock-clock-date">@_clockDate</span>
            }
            else
            {
                <span class="dock-clock-date-narrow">@_clockDateNarrow</span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string AvatarColor { get; set; } = "#C9922E";
    [Parameter] public string AvatarInitial { get; set; } = "?";
    [Parameter] public string DisplayName { get; set; } = "User";
    [Parameter] public int ReviewCount { get; set; }
    [Parameter] public string CurrentRole { get; set; } = "Administrator";

    private bool _expanded;
    private bool _settingsExpanded;

    // Clock state
    private string _clockTime = string.Empty;
    private string _clockTimeNarrow = string.Empty;
    private string _clockDate = string.Empty;
    private string _clockDateNarrow = string.Empty;
    private Timer? _clockTimer;

    // Settings context — derived from URL
    private bool _isOnSettingsPage;
    private SettingsSection? _activeSettingsSection;

    protected override void OnInitialized()
    {
        DeviceContext.OnChanged += OnDeviceChanged;
        Nav.LocationChanged += OnLocationChanged;
        UpdateClock();
        UpdateSettingsContext();
        _clockTimer = new Timer(_ =>
        {
            UpdateClock();
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void UpdateClock()
    {
        var now = DateTime.Now;
        _clockTime = now.ToString("t");
        // Respect the regional 12/24-hour setting; AM/PM is omitted in narrow mode (no space).
        var is24Hour = System.Globalization.CultureInfo.CurrentCulture
                           .DateTimeFormat.ShortTimePattern.Contains('H');
        _clockTimeNarrow = now.ToString(is24Hour ? "H:mm" : "h:mm");
        _clockDate = now.ToString("ddd, MMM d");
        _clockDateNarrow = now.ToString("ddd");
    }

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateSettingsContext();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateSettingsContext()
    {
        var uri = Nav.ToBaseRelativePath(Nav.Uri);
        _isOnSettingsPage = uri.StartsWith("settings", StringComparison.OrdinalIgnoreCase);

        if (_isOnSettingsPage)
        {
            // Auto-expand when navigating to a settings page.
            _settingsExpanded = true;

            // Parse the active section from the URL (e.g. "settings/apikeys" → "apikeys").
            var segments = uri.Split('/', StringSplitOptions.RemoveEmptyEntries);
            var sectionSegment = segments.Length > 1 ? segments[1] : null;
            _activeSettingsSection = SettingsNav.ParseFromRoute(sectionSegment)
                                     ?? SettingsSection.General;
        }
        else
        {
            _activeSettingsSection = null;
            // Collapse settings tree when navigating away.
            _settingsExpanded = false;
        }
    }

    private void ToggleSettings()
    {
        if (_settingsExpanded)
        {
            _settingsExpanded = false;
        }
        else
        {
            _settingsExpanded = true;
            // If not already on a settings page, navigate to General.
            if (!_isOnSettingsPage)
                Nav.NavigateTo("/settings");
        }
    }

    private int GetBadgeCount(string? badgeKey) =>
        badgeKey switch
        {
            "review" => ReviewCount,
            _        => 0,
        };

    private bool IsActive(string path, string key)
    {
        var uri = Nav.ToBaseRelativePath(Nav.Uri);
        if (key == "home")
            return string.IsNullOrEmpty(uri) || uri == "/";
        return uri.StartsWith(key, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        DeviceContext.OnChanged -= OnDeviceChanged;
        Nav.LocationChanged -= OnLocationChanged;
        _clockTimer?.Dispose();
    }
}

<style>
    /* ── Floating panel — narrow (default) ───────────────────────────── */
    .left-dock {
        position: fixed;
        top: 80px;   /* Below the 64px TopBar + 16px gap */
        left: 12px;
        bottom: 12px;
        width: 64px;
        z-index: 1200;
        display: flex;
        flex-direction: column;
        padding: 0 6px 12px;

        background: var(--app-dock-bg);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid var(--app-dock-border);
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255,255,255,0.04) inset;

        border-radius: 18px;

        transition: width 0.25s ease;
        overflow: hidden;
    }

    /* ── Expanded dock (hover overlay) ───────────────────────────────── */
    .left-dock-expanded {
        width: 220px;
        box-shadow: 0 12px 48px rgba(0, 0, 0, 0.65), 0 0 0 1px rgba(255,255,255,0.06) inset;
    }

    /* ── Top spacer — pushes icons down from the rounded top ─────────── */
    .dock-top-spacer {
        height: 16px;
        flex-shrink: 0;
    }

    /* ── Navigation area ─────────────────────────────────────────────── */
    .dock-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 2px;
        overflow-y: auto;
        overflow-x: hidden;
        scrollbar-width: none;
    }

    .dock-nav::-webkit-scrollbar { display: none; }

    /* ── Dock item (shared style) ────────────────────────────────────── */
    .dock-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 10px;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.15s ease, color 0.15s ease;
        min-height: 44px;
        color: var(--app-dock-text);
    }

    .left-dock:not(.left-dock-expanded) .dock-item {
        justify-content: center;
        padding: 10px 0;
    }

    .dock-item:hover {
        background: var(--app-dock-hover);
    }

    /* Active: white icon + label, amber left-edge line */
    .dock-item-active {
        background: transparent;
        color: #F8F8F8;
        position: relative;
    }

    .dock-item-active::before {
        content: "";
        position: absolute;
        left: 0;
        top: 25%;
        height: 50%;
        width: 3px;
        background: #EAB308;
        border-radius: 0 4px 4px 0;
    }

    .dock-item-active:hover {
        background: transparent;
    }

    /* Home button: soft amber highlight when active */
    .dock-item-home-active {
        background: rgba(234, 179, 8, 0.10) !important;
        color: #EAB308 !important;
    }

    .dock-item-home-active:hover {
        background: rgba(234, 179, 8, 0.15) !important;
    }

    .dock-item-home-active::before {
        background: #EAB308 !important;
    }

    /* ── Label (only visible when expanded) ──────────────────────────── */
    .dock-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.88rem;
        font-weight: 500;
        color: inherit;
    }

    .dock-item-active .dock-label {
        font-weight: 700;
    }

    /* ── Settings tree ──────────────────────────────────────────────── */

    /* Divider above Settings */
    .dock-settings-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.06);
        margin: 6px 4px;
        flex-shrink: 0;
    }

    /* Settings toggle parent — inherits dock-item */
    .dock-settings-toggle {
        /* No extra styles needed; dock-item covers it */
    }

    /* Settings sub-items — smaller, indented */
    .dock-settings-sub {
        min-height: 36px;
        padding: 6px 8px;
        gap: 10px;
    }

    .left-dock:not(.left-dock-expanded) .dock-settings-sub {
        padding: 6px 0;
    }

    .left-dock-expanded .dock-settings-sub {
        padding-left: 20px;
    }

    .dock-settings-sub .dock-label {
        font-size: 0.8rem;
    }

    /* Group dividers */
    .dock-group-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--app-dock-text-muted, rgba(248,248,248,0.35));
        padding: 8px 20px 2px;
        white-space: nowrap;
        overflow: hidden;
    }

    .dock-group-rule {
        height: 1px;
        background: rgba(255, 255, 255, 0.04);
        margin: 4px 8px;
        flex-shrink: 0;
    }

    /* ── Bottom section ──────────────────────────────────────────────── */
    .dock-bottom {
        display: flex;
        flex-direction: column;
        gap: 2px;
        flex-shrink: 0;
        padding-top: 8px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        margin-top: 6px;
    }

    /* Avatar item — inherits dock-item but with avatar specifics */
    .dock-item-avatar {
        min-height: 44px;
    }

    /* ── Clock ───────────────────────────────────────────────────────── */
    .dock-clock {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 8px 0 4px;
        gap: 2px;
        cursor: default;
        overflow: hidden;
    }

    .left-dock-expanded .dock-clock {
        align-items: flex-start;
        padding-left: 12px;
    }

    .dock-clock-time {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.88rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.80);
        line-height: 1.2;
        white-space: nowrap;
    }

    .dock-clock-date {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 400;
        color: var(--app-dock-text-muted);
        white-space: nowrap;
    }

    .dock-clock-date-narrow {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        font-weight: 400;
        color: var(--app-dock-text-muted);
        white-space: nowrap;
        text-align: center;
    }

    /* Hide the floating dock on mobile -- the TopBar hamburger provides navigation instead. */
    @@media (max-width: 768px) {
        .left-dock {
            display: none;
        }
    }
</style>
