@namespace MediaEngine.Web.Components.Navigation
@inject DeviceContextService DeviceContext
@implements IDisposable

@using MediaEngine.Web.Models.ViewDTOs

@* Navigation Tray — content-aware bottom dock with configurable Virtual Library
   buttons and a permanent Search trigger.

   Replaces IntentDock. Each library button maps to one or more MediaType values
   with OR-logic filtering. Hidden when no matching Works exist in the library.

   Device-adaptive:
     normal    → Web/Mobile: standard pill buttons
     oversized → Television: large buttons with focus rings
     hidden    → Automotive single-mode: tray not rendered *@

@{
    var isOversized = string.Equals(
        DeviceContext.Settings.Shell.IntentDockStyle, "oversized",
        StringComparison.OrdinalIgnoreCase);

    // Automotive "single" layout hides the tray entirely.
    var sidebarLayout = DeviceContext.Settings.Pages.ServerSettings.SidebarLayout;
    if (sidebarLayout == "single") return;
}

<div class="nav-tray">
    <MudPaper Elevation="0" Class="@(isOversized ? "nav-tray-surface nav-tray-oversized" : "nav-tray-surface")">
        <MudStack Row="true" Spacing="@(isOversized ? 6 : 4)" AlignItems="AlignItems.Center"
                  Justify="Justify.Center" Class="@(isOversized ? "pa-3 px-8" : "pa-2 px-6")">

            @foreach (var lib in Config.Libraries.Where(l => l.Enabled))
            {
                // Content-aware: hide if no hubs match this library's media types.
                var isShowAll = lib.MediaTypes.Count == 0;
                if (!isShowAll && !HasMatchingContent(lib)) continue;

                var isActive = string.Equals(ActiveLibraryKey, lib.Key, StringComparison.OrdinalIgnoreCase);
                var buttonRadius = isOversized ? "20px" : "16px";
                var buttonStyle = isActive
                    ? $"background: var(--app-active-overlay); border-radius: {buttonRadius};"
                    : $"border-radius: {buttonRadius};";

                <MudTooltip Text="@lib.Label" Arrow="true" Placement="Placement.Top">
                    <MudIconButton Icon="@NavigationDefaults.GetMudIcon(lib.Icon)"
                                   Size="@(isOversized ? Size.Large : Size.Medium)"
                                   Color="@(isActive ? Color.Primary : Color.Default)"
                                   Style="@buttonStyle"
                                   OnClick="@(() => SelectLibrary(lib))"
                                   title="@lib.Label" />
                </MudTooltip>
            }

            @* ── Permanent Search button ── *@
            <MudTooltip Text="Search (Ctrl+K)" Arrow="true" Placement="Placement.Top">
                <MudIconButton Icon="@Icons.Material.Filled.Search"
                               Size="@(isOversized ? Size.Large : Size.Medium)"
                               Color="Color.Default"
                               Style="@($"border-radius: {(isOversized ? "20px" : "16px")};")"
                               OnClick="@(() => OnSearchRequested.InvokeAsync())"
                               title="Search (Ctrl+K)" />
            </MudTooltip>

        </MudStack>

        @* Active library label *@
        <div class="nav-tray-label">
            <MudText Typo="Typo.caption"
                     Style="color: var(--app-text-muted); text-align: center; padding-bottom: 6px;">
                @ActiveLabel
            </MudText>
        </div>
    </MudPaper>
</div>

@code {
    /// <summary>Tray configuration — list of Virtual Libraries.</summary>
    [Parameter] public TrayConfig Config { get; set; } = new();

    /// <summary>Key of the currently active library (null = no selection / "Hubs" show-all).</summary>
    [Parameter] public string? ActiveLibraryKey { get; set; }

    /// <summary>Fires when the user selects a library. Null means "show all" (Hubs).</summary>
    [Parameter] public EventCallback<VirtualLibrary?> OnLibrarySelected { get; set; }

    /// <summary>
    /// Set of media type strings present in the current library.
    /// Used for content-aware visibility — libraries with no matching types are hidden.
    /// </summary>
    [Parameter] public HashSet<string> AvailableMediaTypes { get; set; } = [];

    /// <summary>Fires when the user clicks the Search button.</summary>
    [Parameter] public EventCallback OnSearchRequested { get; set; }

    // ── Lifecycle ────────────────────────────────────────────────────────────

    protected override void OnInitialized() =>
        DeviceContext.OnChanged += OnDeviceChanged;

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() =>
        DeviceContext.OnChanged -= OnDeviceChanged;

    // ── Helpers ──────────────────────────────────────────────────────────────

    private string ActiveLabel
    {
        get
        {
            if (string.IsNullOrEmpty(ActiveLibraryKey))
                return "Hubs";

            var active = Config.Libraries.FirstOrDefault(l =>
                string.Equals(l.Key, ActiveLibraryKey, StringComparison.OrdinalIgnoreCase));
            return active?.Label ?? "Hubs";
        }
    }

    /// <summary>
    /// Returns true if any hub in the library has works matching the given virtual library's media types.
    /// </summary>
    private bool HasMatchingContent(VirtualLibrary lib) =>
        lib.MediaTypes.Any(mt => AvailableMediaTypes.Contains(mt, StringComparer.OrdinalIgnoreCase));

    private async Task SelectLibrary(VirtualLibrary lib)
    {
        // If "show all" (empty media types) or re-clicking the same library, clear the filter.
        if (lib.MediaTypes.Count == 0 ||
            string.Equals(ActiveLibraryKey, lib.Key, StringComparison.OrdinalIgnoreCase))
        {
            await OnLibrarySelected.InvokeAsync(null);
        }
        else
        {
            await OnLibrarySelected.InvokeAsync(lib);
        }
    }
}

<style>
    .nav-tray {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1200;
        pointer-events: auto;
    }

    .nav-tray-surface {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: var(--app-glass-bg) !important;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--app-glass-border);
        border-radius: 28px !important;
        box-shadow: var(--app-shadow);
    }

    .nav-tray-oversized {
        border-radius: 36px !important;
    }

    .nav-tray-label {
        text-align: center;
    }
</style>
