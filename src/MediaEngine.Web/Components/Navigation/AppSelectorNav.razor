@namespace MediaEngine.Web.Components.Navigation
@using MudBlazor

<nav class="@RootClass" aria-label="@AriaLabel">
    @foreach (var item in Items)
    {
        var isActive = string.Equals(item.Key, ActiveKey, StringComparison.OrdinalIgnoreCase);
        <button type="button"
                class="@BuildItemClass(isActive)"
                disabled="@item.Disabled"
                @onclick="@(() => HandleSelectAsync(item.Key))">
            @if (!string.IsNullOrWhiteSpace(item.Icon))
            {
                <MudIcon Icon="@item.Icon" Class="app-selector-nav__icon" />
            }
            <span class="app-selector-nav__copy">
                <span class="app-selector-nav__label">@item.Label</span>
                @if (!string.IsNullOrWhiteSpace(item.Description))
                {
                    <span class="app-selector-nav__description">@item.Description</span>
                }
            </span>
            @if (!string.IsNullOrWhiteSpace(item.Badge))
            {
                <span class="app-selector-nav__badge">@item.Badge</span>
            }
        </button>
    }
</nav>

@code {
    [Parameter] public IReadOnlyList<AppNavItem> Items { get; set; } = [];
    [Parameter] public string? ActiveKey { get; set; }
    [Parameter] public EventCallback<string> OnSelect { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? Class { get; set; }

    private string RootClass
        => string.Join(
            " ",
            new[]
            {
                "app-selector-nav",
                string.IsNullOrWhiteSpace(Class) ? null : Class
            }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private string BuildItemClass(bool isActive)
        => string.Join(
            " ",
            new[]
            {
                "app-selector-nav__item",
                isActive ? "is-active" : null
            }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private async Task HandleSelectAsync(string key)
    {
        if (OnSelect.HasDelegate)
            await OnSelect.InvokeAsync(key);
    }
}
