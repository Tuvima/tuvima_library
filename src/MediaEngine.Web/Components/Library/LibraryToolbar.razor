@using MediaEngine.Web.Models.ViewDTOs

@inject IStringLocalizer<SharedStrings> L

<div class="vault-toolbar">
    @if (ShowBackButton)
    {
        <MudButton Variant="Variant.Text"
                   Color="Color.Inherit"
                   StartIcon="@Icons.Material.Outlined.ArrowBack"
                   OnClick="() => OnBack.InvokeAsync()"
                   Class="vault-back-btn">
            Back
        </MudButton>
    }

    <MudTextField T="string"
                  @bind-Value="_searchDraft"
                  Placeholder="@L["VaultToolbar_SearchPlaceholder"]"
                  Variant="Variant.Outlined"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Outlined.Search"
                  Immediate="true"
                  DebounceInterval="300"
                  OnDebounceIntervalElapsed="OnSearchDebounced"
                  Class="vault-search-field" />

    @{
        var viewModes = GetViewModeOptions();
    }
    @if (viewModes.Count > 1)
    {
        <MudChipSet T="string"
                    SelectedValue="@ViewMode"
                    SelectedValueChanged="OnViewModeSelected"
                    Class="vault-view-modes">
            @foreach (var mode in viewModes)
            {
                <MudChip T="string"
                         Value="@mode.Value"
                         Icon="@mode.Icon"
                         Variant="Variant.Text">
                    @mode.Label
                </MudChip>
            }
        </MudChipSet>
    }

    <MudButton Variant="Variant.Outlined"
               Color="Color.Inherit"
               StartIcon="@Icons.Material.Outlined.Tune"
               OnClick="() => OnColumnPickerRequested.InvokeAsync()"
               Class="vault-customize-btn">
        Customize
    </MudButton>
</div>

@code {
    [Parameter] public string ActiveTab { get; set; } = "media";
    [Parameter] public string SearchText { get; set; } = "";
    [Parameter] public int PosterSize { get; set; } = 48;
    [Parameter] public EventCallback<int> PosterSizeChanged { get; set; }
    [Parameter] public EventCallback<string> SearchTextChanged { get; set; }
    [Parameter] public string? TabId { get; set; }
    [Parameter] public bool ShowBackButton { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnColumnPickerRequested { get; set; }
    [Parameter] public string ViewMode { get; set; } = "all";
    [Parameter] public EventCallback<string> ViewModeChanged { get; set; }

    private string ResolvedTabId => TabId ?? ActiveTab;
    private string _searchDraft = string.Empty;

    protected override void OnParametersSet()
    {
        if (!string.Equals(_searchDraft, SearchText, StringComparison.Ordinal))
        {
            _searchDraft = SearchText;
        }
    }

    private Task OnSearchDebounced(string text) => SearchTextChanged.InvokeAsync(text);

    private Task OnViewModeSelected(string value) => ViewModeChanged.InvokeAsync(value);

    private record ViewModeOption(string Label, string Value, string Icon);

    private List<ViewModeOption> GetViewModeOptions() => ResolvedTabId switch
    {
        "movies" =>
        [
            new("All Movies", "all", Icons.Material.Outlined.GridView),
            new("By Series", "series", Icons.Material.Outlined.AccountTree)
        ],
        "tv" =>
        [
            new("By Show", "shows", Icons.Material.Outlined.LiveTv)
        ],
        "music" =>
        [
            new("Albums", "albums", Icons.Material.Outlined.Album),
            new("Artists", "artists", Icons.Material.Outlined.Person),
            new("Tracks", "tracks", Icons.Material.Outlined.QueueMusic)
        ],
        "books" =>
        [
            new("All Books", "all", Icons.Material.Outlined.MenuBook)
        ],
        "audiobooks" =>
        [
            new("All Audiobooks", "all", Icons.Material.Outlined.Headphones)
        ],
        "comics" =>
        [
            new("By Series", "series", Icons.Material.Outlined.CollectionsBookmark),
            new("All Issues", "all", Icons.Material.Outlined.AutoStories)
        ],
        _ => [],
    };
}

<style>
    .vault-toolbar {
        display: flex;
        gap: 12px;
        align-items: center;
        flex: 1;
        flex-wrap: wrap;
    }

    .vault-back-btn,
    .vault-customize-btn {
        border-radius: 12px;
        text-transform: none;
        white-space: nowrap;
    }

    .vault-search-field {
        flex: 1 1 260px;
        max-width: 340px;
        margin: 0;
    }

    .vault-search-field .mud-input-control {
        margin: 0;
    }

    .vault-search-field .mud-input-outlined {
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.02);
    }

    .vault-search-field .mud-input-adornment {
        color: rgba(255, 255, 255, 0.35);
    }

    .vault-view-modes {
        display: flex;
        align-items: center;
        min-width: 0;
    }

    .vault-view-modes .mud-chip-set {
        gap: 6px;
    }

    .vault-view-modes .mud-chip {
        min-height: 2.5rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.02);
        color: rgba(255, 255, 255, 0.65);
    }

    .vault-view-modes .mud-chip.mud-chip-selected {
        background: rgba(96, 165, 250, 0.12);
        color: rgba(96, 165, 250, 0.92);
    }

    @@media (max-width: 1024px) {
        .vault-search-field {
            max-width: 260px;
        }
    }

    @@media (max-width: 768px) {
        .vault-search-field {
            flex-basis: 100%;
            max-width: none;
            order: -1;
        }

        .vault-view-modes {
            flex: 1 1 100%;
        }
    }

    @@media (max-width: 480px) {
        .vault-back-btn,
        .vault-customize-btn {
            min-width: 0;
            padding-inline: 0.8rem;
        }
    }
</style>
