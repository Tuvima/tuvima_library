    private async Task OnViewModeChanged(string newMode)
    {
        var normalizedMode = NormalizeViewMode(_activeTab, newMode);
        if (_viewMode == normalizedMode) return;
        _viewMode = normalizedMode;
        _selectedItems.Clear();

        // Save preference
        _vaultPrefs.ViewModes[_activeTab] = normalizedMode;
        _ = ApiClient.SaveLibraryPreferencesAsync(_vaultPrefs); // fire-and-forget

        if (IsContainerView)
            await LoadContainerItems();
        else
            await LoadMediaItems();

        UpdateUrl();
