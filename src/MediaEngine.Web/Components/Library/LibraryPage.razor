    private BatchProgressEvent? CurrentBatchProgress =>
        StateContainer.BatchProgress is { IsComplete: false } progress && ShouldShowBatchProgress(progress)
            ? progress
            : null;

    private IReadOnlyList<ActivityEntry> LivePipelineFeed =>
        StateContainer.ActivityLog
            .Where(entry => entry.Kind is ActivityKind.IngestionProgress or ActivityKind.MetadataUpdated)
            .Take(6)
            .ToList();

    private IngestionProgressEvent? CurrentIngestionProgress =>
        StateContainer.IngestionProgress is { } progress
        && !string.Equals(progress.Stage, "Complete", StringComparison.OrdinalIgnoreCase)
        && ShouldShowIngestionProgress(progress)
            ? progress
            : null;

    // -- Lifecycle --

    private static string FormatIngestionStageLabel(string stage) => stage switch
    {
        "Scanning" => "Scanning",
        "Hashing" => "Hashing",
        "Processing" => "Queuing",
        _ => stage,
    };

    private bool ShouldShowBatchProgress(BatchProgressEvent progress)
    {
        if (!ReviewOnly)
            return true;

        var hasMeaningfulProgress = progress.FilesProcessed > 0
            || progress.FilesActive > 0
            || progress.FilesReview > 0
            || progress.FilesIdentified > 0
            || progress.FilesNoMatch > 0
            || progress.FilesFailed > 0;

        return hasMeaningfulProgress || (_countsLoaded && _counts.InReview == 0);
    }

    private bool ShouldShowIngestionProgress(IngestionProgressEvent progress)
        => !ReviewOnly || progress.ProcessedCount > 0 || (_countsLoaded && _counts.InReview == 0);

    private static string FormatBatchProgressSummary(BatchProgressEvent progress)
    {
        var readyCount = progress.FilesReady + progress.FilesReadyWithoutUniverse;
        var terminalCount = readyCount + progress.FilesReview + progress.FilesNoMatch + progress.FilesFailed;
        if (progress.FilesQueued == 0 && progress.FilesActive == 0 && terminalCount == progress.FilesTotal)
        {
            if (progress.FilesReview == progress.FilesTotal)
                return $"{progress.FilesReview} of {progress.FilesTotal} waiting for review";

            return $"{terminalCount} of {progress.FilesTotal} files processed";
        }

        return $"{readyCount + progress.FilesReview + progress.FilesNoMatch + progress.FilesFailed} of {progress.FilesTotal} files processed";
    }

    protected override void OnParametersSet()
    {
        if (ReviewOnly)
        {
            _primaryTab = "action_center";
            _activeTab = "action_center";
            return;
        }

        if (IsMediaTab(_activeTab) && !IsAllowedMediaTab(_activeTab))
            _activeTab = GetConfiguredDefaultTab();
    }

    protected override async Task OnInitializedAsync()
    {
        Orchestrator.OnActivityChanged += OnActivityChanged;
        Orchestrator.OnLoreDeltaDiscovered += OnLoreDeltaDiscovered;
        Nav.LocationChanged += OnLocationChanged;
        StateContainer.OnStateChanged += OnBatchProgressChanged;

        // Load vault preferences (view modes, show unowned)
        _vaultPrefs = await ApiClient.GetLibraryPreferencesAsync() ?? new LibraryPreferencesSettings();

        if (ReviewOnly)
        {
            ReadUrlState();
            _primaryTab = "action_center";
            _activeTab = "action_center";
        }
        else
        {
            ReadUrlState();

            // Set view mode from preferences if not overridden by URL
            if (_viewMode == "all" && IsMediaTab(_activeTab))
                _viewMode = GetDefaultViewMode(_activeTab);
        }

        await LoadCounts();
        _mediaTypeCounts = await ApiClient.GetLibraryItemTypeCountsAsync();
        await LoadConflictItems();

        if (ReviewOnly)
        {
            if (_pendingItemId.HasValue)
            {
                await OpenItemFromUrl(_pendingItemId.Value);
                _pendingItemId = null;
            }

            StateHasChanged();
            return;
        }

        if (_activeTab == "overview" || _activeTab.StartsWith("ua_"))
        {
            // Overview and Universe Alignment tabs don't need media data on init
        }
        else if (IsContainerView) await LoadContainerItems();
        else if (IsMediaTab(_activeTab)) await LoadMediaItems();

        if (_pendingItemId.HasValue)
        {
            await OpenItemFromUrl(_pendingItemId.Value);
            _pendingItemId = null;
        }
    }

    public void Dispose()
    {
        Orchestrator.OnActivityChanged -= OnActivityChanged;
        Orchestrator.OnLoreDeltaDiscovered -= OnLoreDeltaDiscovered;
        Nav.LocationChanged -= OnLocationChanged;
        StateContainer.OnStateChanged -= OnBatchProgressChanged;
    }

