    /// <summary>Returns the default view mode for a given tab (from saved preferences or built-in defaults).</summary>
    private string GetDefaultViewMode(string tabId)
    {
        if (Preset?.DefaultViewModes.TryGetValue(tabId, out var presetMode) == true)
            return NormalizeViewMode(tabId, presetMode);

        // TV is always by-show  -  never flat
        if (tabId == "tv") return "shows";
        return _vaultPrefs.ViewModes.TryGetValue(tabId, out var saved) ? NormalizeViewMode(tabId, saved) : tabId switch
        {
            "music"     => "tracks",
            "comics"    => "series",
            _           => "all",
        };
    }

    /// <summary>Maps a view mode to the content group type for drill-down.</summary>
    private string? GetGroupTypeForContainerTab(string tabId) => tabId switch
    {
        "movies" => "movie-series",
        "tv" => "tv-show",
        "music" when _viewMode == "artists" => "artist",
        "music" when _viewMode == "albums" => "album",
        "books" => "book-series",
        "audiobooks" => "book-series",
        "comics" => "comic-series",
        _ => null,
    };

