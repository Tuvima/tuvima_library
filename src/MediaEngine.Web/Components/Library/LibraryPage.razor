    private async Task SwitchPrimaryTab(string primaryId)
    {
        _primaryTab = primaryId;
        if (primaryId == "action_center")
        {
            _activeTab = "action_center";
            // action center always expanded when tab is selected
            await LoadConflictItems();
        }
        else if (primaryId == "overview")
        {
            _activeTab = "overview";
            StateHasChanged();
        }
        else if (TryGetVisibleSubTabs(primaryId, out var subs))
        {
            await SwitchTab(subs[0].Id);
        }
        else
        {
            StateHasChanged();
        }
    }

    private async Task SwitchTab(string tabId)
    {
        if (IsMediaTab(tabId) && !IsAllowedMediaTab(tabId))
            tabId = GetConfiguredDefaultTab();

        if (_activeTab == tabId) return; // already on this tab
        _activeTab = tabId;
        _searchText = "";
        // groupBy removed
        _activeGroupType = null;
        _activeGroupId = null;
        _selectedItems.Clear();
        ClearStatusFilters();

        // Update primary tab to match sub-tab selection
        if (IsMediaTab(tabId))
            _primaryTab = "media";
        else if (tabId.StartsWith("ua_"))
            _primaryTab = "universe_alignment";
        else if (tabId == "overview")
            _primaryTab = "overview";

        // Set view mode from saved preferences
        _viewMode = IsMediaTab(tabId) ? NormalizeViewMode(tabId, GetDefaultViewMode(tabId)) : "all";

        if (tabId.StartsWith("ua_"))
        {
            // Universe alignment data loading  -  placeholder for Phase 3
            StateHasChanged();
        }
        else if (tabId == "overview")
        {
            StateHasChanged();
        }
        else
        {
            _sortBy = tabId == "new" ? "newest" : "title";
            if (IsContainerView)
                await LoadContainerItems();
            else
                await LoadMediaItems();
        }

        UpdateUrl();
    }

    /// <summary>Navigate to a specific tab from the Overview dashboard cards.</summary>
    private async Task OnOverviewNavigate(string target)
    {
        if (target == "action_center")
        {
            await SwitchPrimaryTab("action_center");
        }
        else if (target.StartsWith("ua_"))
        {
            await SwitchTab(target);
        }
        else if (IsMediaTab(target))
        {
            await SwitchTab(target);
        }
    }

