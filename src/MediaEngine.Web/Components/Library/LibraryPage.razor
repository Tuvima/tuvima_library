@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Library
@using MediaEngine.Storage.Models

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer StateContainer
@inject ISnackbar Snackbar
@inject MediaEditorLauncherService MediaEditorLauncher
@inject IStringLocalizer<SharedStrings> L
@inject NavigationManager Nav

@implements IDisposable

<div class="vault-layout">

    @* -- 1. TITLE ROW -- *@
    <div class="vault-header">
        @if (!HideTitleRow)
        {
            <div class="vault-title-row">
                <h1 class="vault-title">@DisplayTitle</h1>
            </div>
        }

        @* -- 2. PRIMARY TAB ROW (categories + Action Center + Add button) -- *@
        @if (!ReviewOnly)
        {
        <div class="vault-tab-row">
            @if (HidePrimaryTabsForPreset)
            {
                <MudTabs ActivePanelIndex="@ActiveVisibleMediaTabIndex"
                         ActivePanelIndexChanged="OnVisibleMediaTabChanged"
                 Rounded="false"
                         Border="false"
                         Elevation="0"
                         Class="vault-tab-bar">
                    @foreach (var tab in VisibleMediaTabsForDisplay)
                    {
                        <MudTabPanel Text="@tab.Label" Icon="@tab.Icon" />
                    }
                </MudTabs>
            }
            else
            {
                <MudTabs ActivePanelIndex="@ActivePrimaryTabIndex"
                         ActivePanelIndexChanged="OnPrimaryTabChanged"
                 Rounded="false"
                         Border="false"
                         Elevation="0"
                         Class="vault-tab-bar">
                    @foreach (var tab in PrimaryTabsForDisplay)
                    {
                        <MudTabPanel Text="@tab.Label" Icon="@tab.Icon" />
                    }
                </MudTabs>
            }
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => _addMediaOpen = true)"
                       Class="vault-add-btn">
                @L["Vault_AddMedia"]
            </MudButton>
        </div>

        @* -- 3. SUB-TAB ROW (context-aware, only when not action_center) -- *@
        @if (!HidePrimaryTabsForPreset
            && _primaryTab != "action_center"
            && _primaryTab != "overview"
            && ActiveSubTabs.Count > 0)
        {
            <div class="vault-subtab-row">
                <MudTabs ActivePanelIndex="@ActiveSubTabIndex"
                         ActivePanelIndexChanged="OnSubTabChanged"
                     Rounded="false"
                         Border="false"
                         Elevation="0"
                         SliderColor="Color.Secondary"
                         Class="vault-tab-bar vault-tab-bar--sub">
                    @foreach (var tab in ActiveSubTabs)
                    {
                        <MudTabPanel Text="@tab.Label" Icon="@tab.Icon" />
                    }
                </MudTabs>
            </div>
        }

        }

        @if (CurrentBatchProgress is { } bp)
        {
            <div class="vault-progress-banner">
                <div class="vault-progress-info">
                    @if (bp.FilesActive > 0)
                    {
                        <MudProgressCircular Class="vault-progress-spinner" Indeterminate="true" Size="Size.Small" />
                    }
                    @if (!string.IsNullOrEmpty(bp.CurrentStage))
                    {
                        <span class="vault-progress-stage">@bp.CurrentStage</span>
                    }
                    <span class="vault-progress-count">@FormatBatchProgressSummary(bp)</span>
                    @if (!string.IsNullOrWhiteSpace(bp.CurrentFileTitle))
                    {
                        <span class="vault-progress-current">@bp.CurrentFileTitle</span>
                    }
                    @if (bp.EstimatedSecondsRemaining.HasValue)
                    {
                        <span class="vault-progress-eta">~@(bp.EstimatedSecondsRemaining.Value)s remaining</span>
                    }
                </div>
                <div class="vault-progress-bar-track">
                    <div class="vault-progress-bar-fill" style="width: @(bp.FilesTotal > 0 ? bp.ProgressPercent : 0)%"></div>
                </div>
                <div class="vault-progress-breakdown">
                    <span class="vault-progress-metric">Queue @bp.FilesQueued</span>
                    <span class="vault-progress-metric">Active @bp.FilesActive</span>
                    <span class="vault-progress-metric">Review @bp.FilesReview</span>
                    <span class="vault-progress-metric">Ready @(bp.FilesReady + bp.FilesReadyWithoutUniverse)</span>
                </div>
                @if (LivePipelineFeed.Count > 0)
                {
                    <div class="vault-progress-feed">
                        @foreach (var entry in LivePipelineFeed)
                        {
                            <div class="vault-progress-feed-item">
                                <span class="vault-progress-feed-time">@entry.OccurredAt.ToLocalTime().ToString("h:mm tt")</span>
                                <span class="vault-progress-feed-summary">@entry.Summary</span>
                                @if (!string.IsNullOrWhiteSpace(entry.Detail))
                                {
                                    <span class="vault-progress-feed-detail">@entry.Detail</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (CurrentIngestionProgress is { } progress)
        {
            var queueCount = Math.Max(0, progress.TotalCount - progress.ProcessedCount);
            var pct = progress.TotalCount > 0
                ? (int)Math.Round(progress.ProcessedCount * 100.0 / progress.TotalCount)
                : 0;
            <div class="vault-progress-banner">
                <div class="vault-progress-info">
                    <span class="vault-progress-stage">@FormatIngestionStageLabel(progress.Stage)</span>
                    <span class="vault-progress-count">@progress.ProcessedCount of @progress.TotalCount files ingested</span>
                </div>
                <div class="vault-progress-bar-track">
                    <div class="vault-progress-bar-fill" style="width: @pct%"></div>
                </div>
                <div class="vault-progress-breakdown">
                    <span class="vault-progress-metric">Queue @queueCount</span>
                    @if (!string.IsNullOrWhiteSpace(progress.CurrentFile))
                    {
                        <span class="vault-progress-metric">@progress.CurrentFile</span>
                    }
                </div>
            </div>
        }
    </div>

    @* -- 3. TOOLBAR ROW -- *@
    @if (!ReviewOnly)
    {
    <div class="vault-toolbar-row">
        @if (_activeGroupId.HasValue)
        {
            <MudButton Variant="Variant.Text"
                       Color="Color.Inherit"
                       StartIcon="@Icons.Material.Outlined.ArrowBack"
                       OnClick="NavigateBackFromGroup"
                       Class="vault-back-btn">
                Back
            </MudButton>
        }

        <MudTextField T="string"
                      Value="@_searchText"
                      ValueChanged="@((string? value) => _searchText = value ?? string.Empty)"
                      Placeholder="@L["VaultToolbar_SearchPlaceholder"]"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.Search"
                      Immediate="true"
                      DebounceInterval="300"
                      OnDebounceIntervalElapsed="OnSearchChanged"
                      Class="vault-search-field" />

        @{
            var viewModes = GetToolbarViewModeOptions();
        }
        @if (viewModes.Count > 1)
        {
            <MudChipSet T="string"
                        SelectedValue="@_viewMode"
                        SelectedValueChanged="OnViewModeChanged"
                        Class="vault-view-modes">
                @foreach (var mode in viewModes)
                {
                    <MudChip T="string"
                             Value="@mode.Value"
                             Icon="@mode.Icon"
                             Variant="Variant.Text">
                        @mode.Label
                    </MudChip>
                }
            </MudChipSet>
        }

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Inherit"
                   StartIcon="@Icons.Material.Outlined.Tune"
                   OnClick="() => _showColumnPicker = true"
                   Class="vault-customize-btn">
            Customize
        </MudButton>
    </div>
    }

    @* -- 5. BODY (full-width content) -- *@
    <div class="vault-body">
        <div class="vault-content">
            @if (ReviewOnly && ShowReviewOverview)
            {
                <div class="vault-review-overview">
                    <LibraryOverviewPanel ReadOnly="true" />
                </div>
            }

            @if (_activeGroupId.HasValue && !string.IsNullOrEmpty(_activeGroupType))
            {
                @* -- Group drill-down sub-page -- *@
                <MediaGroupPage GroupType="@_activeGroupType"
                                GroupId="@_activeGroupId.Value"
                                ArtistAlbumCollectionIds="@_artistAlbumCollectionIds"
                                ArtistName="@_activeArtistName"
                                GroupName="@_activeGroupName"
                                GroupField="@_activeGroupField"
                                MediaType="@_activeGroupMediaType"
                                ShowUnowned="@_vaultPrefs.ShowUnowned"
                                ShowUnownedChanged="OnShowUnownedChanged"
                                OnBack="NavigateBackFromGroup"
                                OnItemClicked="OpenDetailDrawerFromGroup"
                                OnItemEditClicked="OpenDetailDrawerFromGroup"
                                OnAlbumTileClicked="OnAlbumTileClickedFromGroup"
                                OnAlbumNameClicked="OnAlbumNameClickedFromGroup"
                                OnPersonClicked="OnArtistPhotoClickedFromGroup"
                                OnBatchDelete="OnBatchDelete"
                                OnBatchSync="OnBatchSync"
                                OnContainerRefresh="OnContainerRefresh"
                                OnContainerDelete="OnContainerDelete" />
            }
            else if (IsMediaTab(_activeTab))
            {
                @if (IsAlbumGridView)
                {
                    <LibraryMusicGrid Items="@_mediaItems"
                                      Loading="@_loading"
                                      CardSize="196"
                                      OnCardClicked="OnMediaRowClicked"
                                      OnAlbumNameClicked="OnAlbumNameClickedFromGroup" />
                }
                else if (IsContainerView)
                {
                    @* Container view: show content groups (shows, albums, series, artists) *@
                    <LibraryConfigurableTable @ref="_configurableTableRef"
                                             Columns="@LibraryColumnDefinitions.GetColumnsByTab(_activeTab, _viewMode)"
                                             VisibleColumnKeys="@_visibleColumnKeys"
                                             Items="@_containerDisplayItems"
                                             Loading="@_loading"
                                             PosterSize="@_posterSize"
                                             OnRowClicked="OnContainerRowClicked"
                                             OnAuthorClicked="OnAuthorLinkClicked"
                                             SelectedItems="@_selectedItems"
                                             SelectedItemsChanged="OnSelectionChanged"
                                             ActiveSortKey="@_activeSortKey"
                                             SortAscending="@_sortAscending"
                                             OnSortRequested="OnColumnSortRequested"
                                             IsDrillable="@((LibraryItemViewModel _) => true)"
                                             OnEditClicked="OnManageEdit"
                                             OnDeleteClicked="OnManageDelete" />
                }
                else
                {
                    @* Flat view: show individual items *@
                    <LibraryConfigurableTable @ref="_configurableTableRef"
                                             Columns="@LibraryColumnDefinitions.GetColumnsByTab(_activeTab)"
                                             VisibleColumnKeys="@_visibleColumnKeys"
                                             Items="@_mediaItems"
                                             Loading="@_loading"
                                             PosterSize="@_posterSize"
                                             OnRowClicked="OnMediaRowClicked"
                                             OnAuthorClicked="OnAuthorLinkClicked"
                                             SelectedItems="@_selectedItems"
                                             SelectedItemsChanged="OnSelectionChanged"
                                             ActiveSortKey="@_activeSortKey"
                                             SortAscending="@_sortAscending"
                                             OnSortRequested="OnColumnSortRequested"
                                             OnEditClicked="OnManageEdit"
                                             OnDeleteClicked="OnManageDelete" />
                }
                @if (_hasMore)
                {
                    <div class="vault-load-more">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Inherit"
                                   OnClick="LoadMore"
                                   Class="vault-load-more-btn">
                            @L["Vault_LoadMore"]
                        </MudButton>
                    </div>
                }
            }
            else if (_primaryTab == "action_center")
            {
                <LibraryActionCenterCategories Items="@(_conflictItems ?? new List<LibraryItemViewModel>())"
                                              OnItemClicked="OnActionCenterEdit"
                                              OnBulkDelete="OnActionCenterBulkDelete"
                                              OnBulkRetry="OnActionCenterBulkRetry" />
            }
            else if (_activeTab == "overview")
            {
                <LibraryOverviewPanel OnNavigate="OnOverviewNavigate" />
            }
            else if (_activeTab == "ua_pending")
            {
                <LibraryUniversePendingQueue />
            }
            else if (_activeTab == "ua_assigned")
            {
                <LibraryUniverseAssigned OnRowClicked="OnUniverseRowClicked" />
            }
            else if (_activeTab == "ua_unlinked")
            {
                <LibraryUniverseUnlinked />
            }
        </div>
    </div>

    @* -- HUB DETAIL DRAWER -- *@
    @if (_selectedCollection is not null)
    {
        <LibraryCollectionDrawer Collection="@_selectedCollection"
                        Items="@_selectedCollectionItems"
                        OnClose="CloseCollectionDrawer"
                        OnEnabledToggled="OnCollectionEnabledToggled"
                        OnFeaturedToggled="OnCollectionFeaturedToggled" />
    }

    @* -- 5. DETAIL DRAWER -- *@
    @if (_selectedPerson is not null || _selectedUniverse is not null)
    {
        <LibraryDetailDrawer MediaItem="@_selectedMedia"
                           Person="@_selectedPerson"
                           Universe="@_selectedUniverse"
                           OnClose="CloseDetailDrawer"
                           OnPurge="OnPurgeItem"
                           OnApplyMatch="OnApplyMatchClicked"
                           OnPersonAliasClicked="OnPersonAliasClicked"
                           OnCreatorClicked="OnCreatorNameClicked" />
    }

    @* -- 5b. EDITOR PANEL (replaces detail drawer for batch editing) -- *@
    @* -- 6. ADD MEDIA DRAWER -- *@
    @if (_addMediaOpen)
    {
        <LibraryAddMediaDrawer OnClose="() => _addMediaOpen = false" />
    }

    @* -- 7. DELETE CONFIRM -- *@
    @if (_deleteItemId.HasValue || _showBatchDeleteConfirm)
    {
        <LibraryDeleteConfirm ItemTitle="@_deleteItemTitle"
                            Count="@(_showBatchDeleteConfirm ? _selectedItems.Count : 1)"
                            OnConfirm="OnDeleteConfirmed"
                            OnCancel="CancelDelete" />
    }

    @* -- 8. BATCH ACTION BAR -- *@
    <LibraryBatchBar SelectedCount="@_selectedItems.Count"
                   OnEdit="OnBatchEdit"
                   OnDelete="OnBatchDelete"
                   OnSyncNow="OnBatchSync"
                   OnClearSelection="() => { _selectedItems.Clear(); StateHasChanged(); }" />

    @* -- 9. COLUMN PICKER -- *@
    @if (_showColumnPicker)
    {
        <LibraryColumnPicker AllColumns="@(IsContainerView ? LibraryColumnDefinitions.GetColumnsByTab(_activeTab, _viewMode) : LibraryColumnDefinitions.GetColumnsByTab(_activeTab))"
                           VisibleKeys="@_visibleColumnKeys"
                           VisibleKeysChanged="OnColumnVisibilityChanged"
                           ViewKey="@_activeTab"
                           OnClose="() => _showColumnPicker = false" />
    }
</div>

@code {
    // -- Parameters --
    [Parameter] public string? Tab { get; set; }
    [Parameter] public bool ReviewOnly { get; set; }
    [Parameter] public bool ShowReviewOverview { get; set; } = true;
    [Parameter] public bool HideTitleRow { get; set; }
    [Parameter] public string ReviewRoute { get; set; } = "/review";
    [Parameter] public LibrarySurfacePreset? Preset { get; set; }

    // -- State --
    private string _activeTab = "overview";
    // _groupBy removed  -  grouping is no longer supported in the Vault
    private string _sortBy = "newest";
    private string? _activeSortKey;
    private bool _sortAscending = true;
    private string _searchText = "";
    private string _viewMode = "all";
    private bool _loading;
    #pragma warning disable CS0414 // Assigned but read only inside load methods (People/Universes tabs deprecated)
    private bool _loadingPeople;
    private bool _loadingUniverses;
    #pragma warning restore CS0414
    private Dictionary<Guid, int>? _universePeopleCounts;

    // -- View mode + preferences --
    private LibraryPreferencesSettings _vaultPrefs = new();
    private List<ContentGroupViewModel> _tabContentGroups = [];
    private List<LibraryItemViewModel> _containerDisplayItems = [];

    // -- Filter state --
    private bool _filterReview;
    private bool _filterQuarantine;
    private bool _filterProvisional;
    private bool _filterWaitingForProvider;

    // -- Data --
    private List<LibraryItemViewModel> _mediaItems = [];
    private List<PersonListItemDto> _people = [];
    private List<CollectionViewModel> _universes = [];
    private List<ManagedCollectionViewModel> _managedCollections = [];
    private List<ContentGroupViewModel> _contentGroups = [];
    private LibraryItemLifecycleCountsDto _counts = new();
    private bool _countsLoaded;
    private Dictionary<string, int> _mediaTypeCounts = new();
    private bool _hasMore;
    private int _loadedCount;
    // -- Collection drawer state --
    private ManagedCollectionViewModel? _selectedCollection;
    private List<CollectionItemViewModel> _selectedCollectionItems = [];

    // -- Computed counts --
    private int _needsReviewCount => _counts.InReview;
    private int _provisionalCount => _counts.Provisional;
    private int _quarantinedCount => _counts.Rejected;
    private int _waitingForProviderCount => _counts.WaitingForProvider;
    private int _actionCenterTotal => _needsReviewCount + _quarantinedCount + _waitingForProviderCount;

    /// <summary>
    /// Count of universes that have fictional entities older than 30 days -
    /// populated by a LoreDeltaDiscovered SignalR event.
    /// Shown as an informational amber banner in the Vault header.
    /// </summary>
    private int _staleUniverseCount;

    // -- Collection type filter --
    private HashSet<string> _enabledCollectionTypes = new(["Smart", "System", "Mix", "Playlist", "ContentGroups"]);

    // -- People state --
    private Dictionary<string, Dictionary<string, int>> _personPresence = new();
    private int _peopleDisplayCount = 50;
    private const int PeoplePageSize = 50;

    // -- URL state --
    private Guid? _pendingItemId;

    // -- Poster size --
    private int _posterSize = 48;

    // -- Add media drawer --
    private bool _addMediaOpen;

    // -- Batch selection state --
    private HashSet<Guid> _selectedItems = [];

    // -- Column picker state --
    private bool _showColumnPicker;
    private List<string> _visibleColumnKeys = [];

    // -- Table ref for expand/collapse all --
    private LibraryConfigurableTable? _configurableTableRef;

    // -- Group drill-down sub-page state --
    private string? _activeGroupType;
    private Guid? _activeGroupId;
    private List<Guid>? _artistAlbumCollectionIds;
    private string? _activeArtistName;
    private string? _activeGroupName;
    private string? _activeGroupField;
    private string? _activeGroupMediaType;

    // -- Detail drawer state --
    private LibraryItemViewModel? _selectedMedia;
    private PersonListItemDto? _selectedPerson;
    private CollectionViewModel? _selectedUniverse;

    // -- Delete confirm state --
    private Guid? _deleteItemId;
    private string _deleteItemTitle = "";
    private bool _showBatchDeleteConfirm;

    // -- Editor panel state --
    private List<LibraryItemViewModel> _editorPanelItems = [];

    // -- Action Center state --
    // _actionCenterExpanded removed  -  Action Center tab always shows expanded
    private List<LibraryItemViewModel>? _conflictItems;

    // -- Collection counts (used by LoadManagedCollections) --
    private Dictionary<string, int> _collectionCounts = new();

    // -- Primary tab categories --
    private static readonly (string Id, string Label, string Icon)[] _primaryTabs =
    [
        ("overview",           "Overview",           Icons.Material.Outlined.Dashboard),
        ("media",              "Media",              Icons.Material.Outlined.VideoLibrary),
        ("universe_alignment", "Universe Alignment", Icons.Material.Outlined.Collections),
    ];

    // -- Sub-tabs per primary category --
    private static readonly Dictionary<string, (string Id, string Label, string Icon)[]> _subTabs = new()
    {
        ["media"] =
        [
            ("new",        "New",        Icons.Material.Outlined.NewReleases),
            ("movies",     "Movies",     Icons.Material.Outlined.VideoLibrary),
            ("tv",         "TV",         Icons.Material.Outlined.LiveTv),
            ("music",      "Music",      Icons.Material.Outlined.MusicNote),
            ("books",      "Books",      Icons.Material.Outlined.MenuBook),
            ("audiobooks", "Audiobooks", Icons.Material.Outlined.Headphones),
            ("comics",     "Comics",     Icons.Material.Outlined.AutoStories),
        ],
        ["universe_alignment"] =
        [
            ("ua_pending",  "Pending",  Icons.Material.Outlined.PendingActions),
            ("ua_assigned", "Assigned", Icons.Material.Outlined.CheckCircle),
            ("ua_unlinked", "Unlinked", Icons.Material.Outlined.LinkOff),
        ],
    };

    private string _primaryTab = "overview";

    // -- Legacy tab list (kept for URL parsing compatibility) --
    private static readonly (string Id, string Label, string Icon)[] _tabs =
    [
        ("overview",    "Overview",           Icons.Material.Outlined.Dashboard),
        ("new",         "New",               Icons.Material.Outlined.NewReleases),
        ("movies",      "Movies",            Icons.Material.Outlined.VideoLibrary),
        ("tv",          "TV",                Icons.Material.Outlined.LiveTv),
        ("music",       "Music",             Icons.Material.Outlined.MusicNote),
        ("books",       "Books",             Icons.Material.Outlined.MenuBook),
        ("audiobooks",  "Audiobooks",        Icons.Material.Outlined.Headphones),
        ("comics",      "Comics",            Icons.Material.Outlined.AutoStories),
        ("ua_pending",  "Pending",           Icons.Material.Outlined.PendingActions),
        ("ua_assigned", "Assigned",          Icons.Material.Outlined.CheckCircle),
        ("ua_unlinked", "Unlinked",          Icons.Material.Outlined.LinkOff),
    ];

    private string DisplayTitle => ReviewOnly ? "Review" : Preset?.Title ?? "Library";

    private HashSet<string> AllowedMediaTabs => Preset?.VisibleMediaTabs.Count > 0
        ? new HashSet<string>(Preset.VisibleMediaTabs, StringComparer.OrdinalIgnoreCase)
        : new HashSet<string>(_mediaTabIds, StringComparer.OrdinalIgnoreCase);

    private bool HidePrimaryTabsForPreset => !ReviewOnly && (Preset?.HidePrimaryTabs ?? false) && Preset?.VisibleMediaTabs.Count > 0;

    private IReadOnlyList<(string Id, string Label, string Icon)> VisibleMediaTabs =>
        _subTabs["media"]
            .Where(tab => AllowedMediaTabs.Contains(tab.Id))
            .ToArray();

    private IReadOnlyList<LibraryTabDescriptor> VisibleMediaTabsForDisplay => BuildTabDescriptors(VisibleMediaTabs);
    private IReadOnlyList<LibraryTabDescriptor> PrimaryTabsForDisplay
    {
        get
        {
            var items = BuildTabDescriptors(_primaryTabs).ToList();
            if (_actionCenterTotal > 0)
            {
                items.Add(new LibraryTabDescriptor(
                    "action_center",
                    FormatTabLabel("Action Center", _actionCenterTotal),
                    Icons.Material.Outlined.Warning));
            }

            return items;
        }
    }

    private IReadOnlyList<LibraryTabDescriptor> ActiveSubTabs =>
        TryGetVisibleSubTabs(_primaryTab, out var tabs)
            ? BuildTabDescriptors(tabs)
            : [];

    private int ActiveVisibleMediaTabIndex => GetSelectedIndex(VisibleMediaTabsForDisplay.Select(tab => tab.Id), _activeTab);
    private int ActivePrimaryTabIndex => GetSelectedIndex(PrimaryTabsForDisplay.Select(tab => tab.Id), _primaryTab);
    private int ActiveSubTabIndex => GetSelectedIndex(ActiveSubTabs.Select(tab => tab.Id), _activeTab);

    // -- Tab helpers --

    private static readonly string[] _mediaTabIds = ["new", "movies", "tv", "music", "books", "audiobooks", "comics"];

    private IReadOnlyList<LibraryTabDescriptor> BuildTabDescriptors(IEnumerable<(string Id, string Label, string Icon)> tabs) =>
        tabs.Select(tab => new LibraryTabDescriptor(
            tab.Id,
            FormatTabLabel(tab.Label, GetTabBadgeCount(tab.Id)),
            tab.Icon)).ToList();

    private static string? FormatTabBadge(int count) =>
        count > 0
            ? (count >= 1000 ? $"{count / 1000.0:0.#}k" : count.ToString())
            : null;

    private static string FormatTabLabel(string label, int count) =>
        FormatTabBadge(count) is { } badge ? $"{label} ({badge})" : label;

    private static int GetSelectedIndex(IEnumerable<string> keys, string activeKey)
    {
        var index = 0;
        foreach (var key in keys)
        {
            if (string.Equals(key, activeKey, StringComparison.OrdinalIgnoreCase))
            {
                return index;
            }

            index++;
        }

        return 0;
    }

    private static bool IsMediaTab(string tabId) => _mediaTabIds.Contains(tabId);

    private bool IsAllowedMediaTab(string tabId) => AllowedMediaTabs.Contains(tabId);

    private sealed record LibraryTabDescriptor(string Id, string Label, string Icon);
    private sealed record ToolbarViewModeOption(string Label, string Value, string Icon);

    private static string? GetMediaTypeForTab(string tabId) => tabId switch
    {
        "movies"     => "Movies",
        "tv"         => "TV",
        "music"      => "Music",
        "books"      => "Books",
        "audiobooks" => "Audiobooks",
        "comics"     => "Comics",
        _            => null, // "new" tab  -  no type filter
    };

    /// <summary>True when the current tab + view mode is showing containers (not individual files).
    /// Note: "albums" is intentionally excluded  -  LibraryMusicGrid handles album grouping from the flat
    /// _mediaItems list itself, so LoadMediaItems() (not LoadContainerItems()) must run for that view.</summary>
    private bool IsContainerView => _viewMode is "shows" or "artists" or "series";

    private bool IsAlbumGridView => _activeTab == "music" && _viewMode == "albums";

    private string GetConfiguredDefaultTab()
    {
        var presetDefault = Preset?.DefaultMediaTab;
        if (!string.IsNullOrWhiteSpace(presetDefault) && IsAllowedMediaTab(presetDefault))
            return presetDefault;

        return VisibleMediaTabs.FirstOrDefault().Id ?? "new";
    }

    private bool TryGetVisibleSubTabs(string primaryId, out (string Id, string Label, string Icon)[] tabs)
    {
        tabs = [];
        if (!_subTabs.TryGetValue(primaryId, out var allTabs))
            return false;

        tabs = primaryId == "media"
            ? allTabs.Where(tab => IsAllowedMediaTab(tab.Id)).ToArray()
            : allTabs;

        return tabs.Length > 0;
    }

    private static string NormalizeViewMode(string tabId, string? viewMode)
    {
        var normalized = string.IsNullOrWhiteSpace(viewMode) ? "all" : viewMode.Trim().ToLowerInvariant();
        return (tabId, normalized) switch
        {
            ("music", "all") => "tracks",
            _ => normalized,
        };
    }

    private List<ToolbarViewModeOption> GetToolbarViewModeOptions() => _activeTab switch
    {
        "movies" =>
        [
            new("All Movies", "all", Icons.Material.Outlined.GridView),
            new("By Series", "series", Icons.Material.Outlined.AccountTree)
        ],
