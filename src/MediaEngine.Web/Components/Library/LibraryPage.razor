    private async Task OpenBatchEditorAsync()
    {
        var sourceItems = (IsContainerView ? _containerDisplayItems : _mediaItems)
            .Where(item => _selectedItems.Contains(item.EntityId))
            .ToList();

        if (sourceItems.Count == 0)
            return;

        var applied = await MediaEditorLauncher.OpenAsync(new MediaEditorLaunchRequest
        {
            EntityIds = sourceItems.Select(item => item.EntityId).ToList(),
            Mode = SharedMediaEditorMode.Batch,
            MediaType = sourceItems.Select(item => item.MediaType).FirstOrDefault(),
            HeaderTitle = $"Edit {sourceItems.Count} Items",
            PreviewItems = sourceItems.Select(item => new MediaEditorPreviewItem
            {
                EntityId = item.EntityId,
                Title = item.Title,
                CoverUrl = item.CoverUrl,
                MediaType = item.MediaType,
            }).ToList(),
        });

        if (applied)
        {
            _selectedItems.Clear();
            await RefreshMediaSurfaceAsync();
        }
    }

    private async Task<bool> OpenSharedEditorAsync(
        Guid entityId,
        LibraryItemViewModel? item,
        SharedMediaEditorMode mode,
        string? reviewTrigger = null)
    {
        var effectiveItem = item;
        if (effectiveItem is null)
        {
            var detail = await ApiClient.GetLibraryItemDetailAsync(entityId);
            if (detail is null)
                return false;

            effectiveItem = new LibraryItemViewModel
            {
                EntityId = detail.EntityId,
                Title = detail.Title,
                Author = detail.Author,
                Director = detail.Director,
                Narrator = detail.Narrator,
                Year = detail.Year,
                MediaType = detail.MediaType,
                CoverUrl = detail.CoverUrl,
                Status = detail.Status,
                ReviewTrigger = detail.ReviewTrigger,
                WikidataQid = detail.WikidataQid,
                Confidence = detail.Confidence,
                FileName = detail.FileName,
                FilePath = detail.FilePath,
            };
        }

        return await MediaEditorLauncher.OpenAsync(new MediaEditorLaunchRequest
        {
            EntityIds = [entityId],
            LaunchEntityId = entityId,
            LaunchEntityKind = "Work",
            Mode = mode,
            InitialScope = ResolveInitialEditorScope(effectiveItem.MediaType),
            ReviewTrigger = reviewTrigger ?? effectiveItem.ReviewTrigger,
            MediaType = effectiveItem.MediaType,
            HeaderTitle = effectiveItem.Title,
            HeaderSubtitle = BuildEditorSubtitle(effectiveItem),
            CoverUrl = effectiveItem.CoverUrl,
            PreviewItems =
            [
                new MediaEditorPreviewItem
                {
                    EntityId = effectiveItem.EntityId,
                    Title = effectiveItem.Title,
                    CoverUrl = effectiveItem.CoverUrl,
                    MediaType = effectiveItem.MediaType,
                },
            ],
        });
    }

    private async Task RefreshMediaSurfaceAsync()
