    private static string? BuildEditorSubtitle(LibraryItemViewModel item) =>
        item.MediaType switch
        {
            "Music" => item.Artist ?? item.Author ?? item.Album,
            "Movies" => item.Director ?? item.Year,
            "TV" => item.Series ?? item.Season,
            "Audiobooks" => item.Narrator ?? item.Author,
            _ => item.Author ?? item.Series ?? item.Year,
        };

    private static string ResolveInitialEditorScope(string? mediaType) =>
        mediaType switch
        {
            "TV" => "series",
            "Music" => "album",
            "Movies" => "movie",
            "Comics" or "Books" or "Audiobooks" => "work",
            _ => "work",
        };

