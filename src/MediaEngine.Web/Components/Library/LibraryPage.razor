    private async Task OnActionCenterBulkDelete(HashSet<Guid> entityIds)
    {
        if (entityIds.Count == 0) return;
        await ApiClient.BatchDeleteLibraryCatalogItemsAsync(entityIds.ToArray());
        Snackbar.Add($"{entityIds.Count} items deleted", Severity.Info);
        await LoadCounts();
        await LoadConflictItems();
        _mediaTypeCounts = await ApiClient.GetLibraryItemTypeCountsAsync();
        if (IsMediaTab(_activeTab))
        {
            if (IsContainerView) await LoadContainerItems();
            else await LoadMediaItems();
        }
    }

    private async Task OnActionCenterDelete(Guid entityId)
    {
        await ApiClient.BatchDeleteLibraryCatalogItemsAsync([entityId]);
        Snackbar.Add("Item deleted", Severity.Info);
        await LoadCounts();
        await LoadConflictItems();
        _mediaTypeCounts = await ApiClient.GetLibraryItemTypeCountsAsync();
        if (IsMediaTab(_activeTab))
        {
            if (IsContainerView) await LoadContainerItems();
            else await LoadMediaItems();
        }
    }

    private async Task OnActionCenterBulkRetry(HashSet<Guid> ids)
    {
        if (ids.Count == 0) return;
        foreach (var id in ids)
            await ApiClient.TriggerHydrationAsync(id);
        Snackbar.Add($"{ids.Count} item(s) queued for retry.", Severity.Info);
    }

