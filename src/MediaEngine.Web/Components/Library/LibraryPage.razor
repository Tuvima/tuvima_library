    // -- URL state management --

    private void UpdateUrl(bool replace = false)
    {
        var tab = _activeTab;
        var routeBase = string.IsNullOrWhiteSpace(Preset?.RouteBase) ? "/review" : Preset!.RouteBase.TrimEnd('/');
        var path = ReviewOnly
            ? ReviewRoute
            : tab == "overview"
                ? routeBase
                : $"{routeBase}/{tab}";
        var queryParts = new List<string>();

        // Encode drill-down group state so the browser back button works
        if (_activeGroupId.HasValue && !string.IsNullOrEmpty(_activeGroupType))
        {
            queryParts.Add($"group={_activeGroupId.Value}");
            queryParts.Add($"groupType={Uri.EscapeDataString(_activeGroupType)}");
            if (!string.IsNullOrWhiteSpace(_activeGroupName))
                queryParts.Add($"groupName={Uri.EscapeDataString(_activeGroupName)}");
            if (!string.IsNullOrWhiteSpace(_activeGroupField))
                queryParts.Add($"groupField={Uri.EscapeDataString(_activeGroupField)}");
            if (!string.IsNullOrWhiteSpace(_activeGroupMediaType))
                queryParts.Add($"groupMediaType={Uri.EscapeDataString(_activeGroupMediaType)}");
        }
        else
        {
            var selectedId = _activeTab switch
            {
                _ when _activeTab.StartsWith("people")    => _selectedPerson?.Id,
                _ when _activeTab.StartsWith("universes") => _selectedUniverse?.Id,
                _ when IsMediaTab(_activeTab)             => _selectedMedia?.EntityId,
                _ => null
            };
            if (selectedId.HasValue)
                queryParts.Add($"item={selectedId.Value}");

            if (_filterReview) queryParts.Add("filter=review");
            else if (_filterQuarantine) queryParts.Add("filter=quarantine");
            else if (_filterProvisional) queryParts.Add("filter=provisional");
            else if (_filterWaitingForProvider) queryParts.Add("filter=waiting");

            if (!string.IsNullOrWhiteSpace(_searchText))
                queryParts.Add($"search={Uri.EscapeDataString(_searchText)}");

            if (_sortBy != "newest" && _sortBy != "title" && _sortBy != "name")
                queryParts.Add($"sort={_sortBy}");
        }

        var query = queryParts.Count > 0 ? "?" + string.Join("&", queryParts) : "";
        Nav.NavigateTo(path + query, replace: replace);
    }

    private void ReadUrlState()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var resolvedTab = ReviewOnly ? "action_center" : GetConfiguredDefaultTab();

        if (!string.IsNullOrEmpty(Tab))
        {
            var tabLower = Tab.ToLowerInvariant();
            // Redirect old "media" tab to "new"
            if (tabLower == "media") tabLower = "new";
            // Redirect old "people" tab to "people_all"
            if (tabLower == "people") tabLower = "people_all";
            // Redirect old "universes" tab to "universes_all"
            if (tabLower == "universes") tabLower = "universes_all";

            // Check legacy tabs or new sub-tab IDs
            var allSubTabIds = _subTabs.Values.SelectMany(arr => arr).Select(t => t.Id).ToHashSet();
            if (_tabs.Any(t => t.Id == tabLower) || allSubTabIds.Contains(tabLower))
            {
                if (!IsMediaTab(tabLower) || IsAllowedMediaTab(tabLower))
                    resolvedTab = tabLower;
            }
        }

        _activeTab = resolvedTab;
        _primaryTab = resolvedTab switch
        {
            _ when ReviewOnly => "action_center",
            _ when IsMediaTab(resolvedTab) => "media",
            _ when resolvedTab.StartsWith("ua_", StringComparison.OrdinalIgnoreCase) => "universe_alignment",
            _ when resolvedTab.StartsWith("people", StringComparison.OrdinalIgnoreCase) => "people",
            _ when resolvedTab.StartsWith("universes", StringComparison.OrdinalIgnoreCase) => "universes",
            _ => "overview",
        };
        _viewMode = IsMediaTab(_activeTab) ? GetDefaultViewMode(_activeTab) : "all";

        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var filter = query["filter"];
        _filterReview = filter == "review";
        _filterQuarantine = filter == "quarantine";
        _filterProvisional = filter == "provisional";
        _filterWaitingForProvider = filter == "waiting";

        if (query["search"] is string search && !string.IsNullOrEmpty(search))
            _searchText = search;

        if (query["sort"] is string sort && !string.IsNullOrEmpty(sort))
            _sortBy = sort;

        _pendingItemId = query["item"] is string itemStr && Guid.TryParse(itemStr, out var itemId) ? itemId : null;

        // Restore group drill-down state from URL (enables browser back button to work)
        if (query["group"] is string groupStr && Guid.TryParse(groupStr, out var groupId)
            && query["groupType"] is string groupType && !string.IsNullOrEmpty(groupType))
        {
            _activeGroupId   = groupId;
            _activeGroupType = Uri.UnescapeDataString(groupType);
            _activeGroupName = query["groupName"] is string gn  && !string.IsNullOrEmpty(gn)  ? Uri.UnescapeDataString(gn)  : null;
            _activeGroupField = query["groupField"] is string gf && !string.IsNullOrEmpty(gf)  ? Uri.UnescapeDataString(gf)  : null;
            _activeGroupMediaType = query["groupMediaType"] is string gmt && !string.IsNullOrEmpty(gmt) ? Uri.UnescapeDataString(gmt) : null;
        }
        else
        {
            _activeGroupId   = null;
            _activeGroupType = null;
            _activeGroupName = null;
            _activeGroupField = null;
            _activeGroupMediaType = null;
        }
    }

    private async Task OpenItemFromUrl(Guid itemId)
    {
        if (ReviewOnly)
        {
            var item = _conflictItems?.FirstOrDefault(i => i.EntityId == itemId);
            var applied = await OpenSharedEditorAsync(itemId, item, SharedMediaEditorMode.Review, item?.ReviewTrigger);
            if (applied)
                await RefreshMediaSurfaceAsync();
            return;
        }

        if (IsMediaTab(_activeTab))
        {
            var item = _mediaItems.FirstOrDefault(i => i.EntityId == itemId);
            var applied = await OpenSharedEditorAsync(itemId, item, SharedMediaEditorMode.Normal);
            if (applied)
                await RefreshMediaSurfaceAsync();
        }
        else if (_activeTab.StartsWith("people"))
        {
            _selectedPerson = _people.FirstOrDefault(p => p.Id == itemId);
        }
        else if (_activeTab.StartsWith("universes"))
        {
            _selectedUniverse = _universes.FirstOrDefault(u => u.Id == itemId);
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (ReviewOnly)
        {
            _ = InvokeAsync(async () =>
            {
                ReadUrlState();
                await LoadCounts();
                await LoadConflictItems();
                if (_pendingItemId.HasValue)
                {
                    await OpenItemFromUrl(_pendingItemId.Value);
                    _pendingItemId = null;
                }
                StateHasChanged();
            });
            return;
        }

        ReadUrlState();
        _ = InvokeAsync(async () =>
        {
            if (_activeTab.StartsWith("people")) await LoadPeople();
            else if (_activeTab.StartsWith("universes")) await LoadUniverses();
            else if (IsMediaTab(_activeTab))
            {
                if (IsContainerView) await LoadContainerItems();
                else await LoadMediaItems();
            }
            StateHasChanged();
        });
    }

    private List<PersonListItemDto> FilteredPeople
    {
        get
        {
            IEnumerable<PersonListItemDto> result = _people;

            // Filter by people sub-tab
            result = _activeTab switch
            {
                "people_authors"   => result.Where(p => p.Roles.Any(r => r is "Author" or "Narrator")),
                "people_directors" => result.Where(p => p.Roles.Any(r => r is "Director")),
                "people_actors"    => result.Where(p => p.Roles.Any(r => r is "Actor" or "Voice Actor")),
                "people_musicians" => result.Where(p => p.Roles.Any(r => r is "Artist" or "Composer" or "Musician" or "Performer")),
                _                  => result, // "people_all"  -  no filter
            };

            if (!string.IsNullOrWhiteSpace(_searchText))
                result = result.Where(p => p.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

            result = _sortBy switch
            {
                "name_desc" => result.OrderByDescending(p => p.Name, StringComparer.OrdinalIgnoreCase),
                "newest" => result.OrderByDescending(p => p.Id),
                "oldest" => result.OrderBy(p => p.Id),
                "presence_asc" => result.OrderBy(p => GetPersonPresenceTotal(p)),
                "presence" => result.OrderByDescending(p => GetPersonPresenceTotal(p)),
                _ => result.OrderBy(p => p.Name, StringComparer.OrdinalIgnoreCase),
            };

            return result.Take(_peopleDisplayCount).ToList();
        }
    }

    private int FilteredPeopleTotal
    {
        get
        {
            IEnumerable<PersonListItemDto> result = _people;
            if (!string.IsNullOrWhiteSpace(_searchText))
                result = result.Where(p => p.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase));
            return result.Count();
        }
    }

    private bool HasMorePeople => FilteredPeopleTotal > _peopleDisplayCount;

    private void LoadMorePeople()
    {
        _peopleDisplayCount += PeoplePageSize;
        StateHasChanged();
    }

    private int GetPersonPresenceTotal(PersonListItemDto p)
    {
        var pid = p.Id.ToString();
        return _personPresence.TryGetValue(pid, out var counts) ? counts.Values.Sum() : 0;
    }
