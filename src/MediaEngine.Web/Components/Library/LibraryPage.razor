    // -- Data loading --

    private async Task LoadCounts()
    {
        var counts = await ApiClient.GetLibraryItemLifecycleCountsAsync();
        if (counts is not null)
            _counts = counts;

        _countsLoaded = true;
    }

    private async Task LoadMediaItems(bool append = false)
    {
        if (!append) _loading = true;
        StateHasChanged();

        string? statusFilter = null;
        if (_filterReview) statusFilter = "InReview";
        else if (_filterProvisional) statusFilter = "Provisional";
        else if (_filterQuarantine) statusFilter = "Rejected";
        else if (_filterWaitingForProvider) statusFilter = "WaitingForProvider";

        var offset = append ? _loadedCount : 0;
        var isNewTab = _activeTab == "new";

        // For flat collection views (e.g. "All Songs"), bypass the libraryItem visibility filter
        // so items that are still in the pipeline (no QID, no review) are included.
        // Only used on the first page load (append=false)  -  pagination falls back to
        // the libraryItem path to avoid duplicates.
        var flatCollectionName = GetSystemViewFlatCollectionName();
        if (flatCollectionName is not null && !append && statusFilter is null && string.IsNullOrWhiteSpace(_searchText))
        {
            var collectionItems = await ApiClient.ResolveCollectionByNameAsync(flatCollectionName, limit: 200);
            _mediaItems = collectionItems
                .Select(h => new LibraryItemViewModel
                {
                    EntityId  = h.EntityId,
                    Title     = h.Title,
                    CoverUrl  = h.CoverUrl,
                    MediaType = h.MediaType,
                    Author    = h.Creator,
                    Artist    = h.MediaType.Equals("Music", StringComparison.OrdinalIgnoreCase)
                                    ? h.Creator : null,
                    Year      = h.Year,
                })
                .ToList();
            _hasMore = false; // collection resolve returns all items up to limit
            _loadedCount = _mediaItems.Count;
            _loading = false;
            return;
        }

        var response = await ApiClient.GetLibraryCatalogItemsAsync(
            offset: offset, limit: 50,
            search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
            type: GetMediaTypeForTab(_activeTab),
            status: statusFilter,
            sort: isNewTab && _sortBy == "newest" ? "-created_at" : LibraryHelpers.GetSortParam(_sortBy),
            maxDays: isNewTab ? 30 : null);

        var items = response?.Items?.Select(LibraryItemViewModel.From).ToList() ?? [];

        if (append)
            _mediaItems.AddRange(items);
        else
            _mediaItems = items;

        _hasMore = response?.HasMore ?? false;
        _loadedCount = _mediaItems.Count;
        _loading = false;
    }

    private async Task LoadMore()
    {
        if (IsContainerView)
            return; // Containers don't paginate for now
        await LoadMediaItems(append: true);
    }

    /// <summary>
    /// Maps the current tab + view mode to the group_by_field used in System view collections.
    /// Returns null when the view is not backed by a system view collection.
    /// </summary>
    private static Guid GenerateDeterministicGuid(string name)
    {
        var bytes = System.Security.Cryptography.MD5.HashData(
            System.Text.Encoding.UTF8.GetBytes(name));
        return new Guid(bytes);
    }

    private string? GetSystemViewGroupField() => (_activeTab, _viewMode) switch
    {
        ("tv", "shows")         => "show_name",
        ("music", "artists")    => "artist",
        ("music", "albums")     => "album",
        ("books", "series")     => "series",
        ("audiobooks", "series") => "series",
        ("comics", "series")    => "series",
        _                       => null,
    };

    /// <summary>
    /// Maps tab + view mode to the name of a System flat collection (no grouping field).
    /// When this returns a non-null name, <see cref="LoadMediaItems"/> resolves the
    /// named collection via <c>GET /collections/resolve/by-name</c> instead of the libraryItem
    /// endpoint.  This bypasses the libraryItem visibility filter so music items that
    /// are still in the pipeline (no QID, no review, no provisional state) are
    /// included in the "All Songs" view rather than being silently hidden.
    /// </summary>
    private string? GetSystemViewFlatCollectionName() => (_activeTab, _viewMode) switch
    {
        ("music", "all" or "tracks") => "All Songs",
        _                            => null,
    };

    /// <summary>Loads content groups for the current tab's container view and converts to display items.</summary>
    private async Task LoadContainerItems()
    {
        _loading = true;
        StateHasChanged();

        var mediaType = GetMediaTypeForTab(_activeTab);
        var systemGroupField = GetSystemViewGroupField();

        if (systemGroupField is not null)
        {
            // This view is backed by a System view collection seeded by CollectionSeeder  -  resolve via system-views endpoint.
            var groups = await ApiClient.GetSystemViewGroupsAsync(mediaType, systemGroupField);

            if (!string.IsNullOrWhiteSpace(_searchText))
                groups = groups.Where(g =>
                    g.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)).ToList();

            _tabContentGroups = groups;
            _containerDisplayItems = groups.Select(g => new LibraryItemViewModel
            {
                // System view groups share the same CollectionId  -  generate a unique deterministic ID
                // from the display name so the click handler can distinguish them.
                EntityId = GenerateDeterministicGuid(g.DisplayName),
                Title    = g.DisplayName,
                MediaType = g.PrimaryMediaType,
                CoverUrl = g.CoverUrl,
                Author   = g.Creator,
                Year     = g.Year,
                Network  = g.Network,
                SeasonCount = g.SeasonCount?.ToString(),
                AlbumCount = g.AlbumCount?.ToString(),
                TrackCount = g.WorkCount.ToString(),
                ArtistPhotoUrl = g.ArtistPhotoUrl,
            }).ToList();
        }
        else
        {
            // Fallback: use ContentGroup collections (albums/series created during ingestion by MediaEntityChainFactory)
            if (_contentGroups.Count == 0)
                _contentGroups = await ApiClient.GetContentGroupsAsync();

            _tabContentGroups = mediaType is not null
                ? _contentGroups.Where(g =>
                    string.Equals(g.PrimaryMediaType, mediaType, StringComparison.OrdinalIgnoreCase)).ToList()
                : _contentGroups;

            if (!string.IsNullOrWhiteSpace(_searchText))
                _tabContentGroups = _tabContentGroups.Where(g =>
                    g.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)).ToList();

            _containerDisplayItems = _tabContentGroups.Select(g => new LibraryItemViewModel
            {
                EntityId = g.CollectionId,
                Title    = g.DisplayName,
                MediaType = g.PrimaryMediaType,
                CoverUrl = g.CoverUrl,
                Author   = g.Creator,
                Year     = null,
                TrackCount = g.WorkCount.ToString(),
            }).ToList();
        }

        _hasMore = false; // Containers don't paginate
        _loading = false;
    }

    private async Task LoadPeople()
    {
        _loadingPeople = true;
        StateHasChanged();

        var result = await ApiClient.GetPersonsAsync(limit: 500);
        _people = result?.ToList() ?? [];

        if (_people.Count > 0)
        {
            _personPresence = await ApiClient.GetPersonPresenceAsync(_people.Select(p => p.Id));
        }

        _loadingPeople = false;
    }

    private async Task LoadUniverses()
    {
        if (_universes.Count > 0) return; // already loaded
        _loadingUniverses = true;
        StateHasChanged();

        _universes = await ApiClient.GetParentCollectionsAsync() ?? [];

        if (_universes.Count > 0)
        {
            var counts = new Dictionary<Guid, int>();
            foreach (var u in _universes)
            {
                var people = await ApiClient.GetPersonsByCollectionAsync(u.Id);
                counts[u.Id] = people?.Count ?? 0;
            }
            _universePeopleCounts = counts;
        }

        _loadingUniverses = false;
    }

    private async Task LoadManagedCollections()
    {
        if (_managedCollections.Count > 0) return; // already loaded
        StateHasChanged();

        var activeProfile = await Orchestrator.GetActiveProfileAsync();
        var activeProfileId = activeProfile?.Id;

        var collectionsTask = ApiClient.GetManagedCollectionsAsync(activeProfileId);
        var countsTask = ApiClient.GetManagedCollectionCountsAsync(activeProfileId);
        var groupsTask = ApiClient.GetContentGroupsAsync();

        await Task.WhenAll(collectionsTask, countsTask, groupsTask);

        _managedCollections   = collectionsTask.Result;
        _collectionCounts     = countsTask.Result;
        _contentGroups = groupsTask.Result;
    }

    private async Task LoadConflictItems()
    {
        var response = await ApiClient.GetLibraryCatalogItemsAsync(
            offset: 0, limit: 20, status: "InReview");
        var reviewItems = response?.Items?.Select(LibraryItemViewModel.From).ToList() ?? [];

        var rejectedResponse = await ApiClient.GetLibraryCatalogItemsAsync(
            offset: 0, limit: 20, status: "Rejected");
        var rejectedItems = rejectedResponse?.Items?.Select(LibraryItemViewModel.From).ToList() ?? [];

        _conflictItems = [.. reviewItems, .. rejectedItems];
    }

