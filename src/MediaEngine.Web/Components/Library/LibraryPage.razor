    private async Task OnActionCenterEdit(Guid entityId)
    {
        var item = _conflictItems?.FirstOrDefault(i => i.EntityId == entityId);
        var applied = await OpenSharedEditorAsync(entityId, item, SharedMediaEditorMode.Review, item?.ReviewTrigger);
        if (applied)
            await RefreshMediaSurfaceAsync();
    }

    private async Task OnManageEdit(Guid entityId)
    {
        var item = _mediaItems.FirstOrDefault(m => m.EntityId == entityId)
                   ?? _containerDisplayItems.FirstOrDefault(m => m.EntityId == entityId);
        if (item is null)
            return;

        var applied = await OpenSharedEditorAsync(entityId, item, SharedMediaEditorMode.Normal);
        if (applied)
            await RefreshMediaSurfaceAsync();
    }

