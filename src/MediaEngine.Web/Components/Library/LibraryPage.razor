        "books"            => _mediaTypeCounts.GetValueOrDefault("Books", 0),
        "audiobooks"       => _mediaTypeCounts.GetValueOrDefault("Audiobooks", 0),
        "comics"           => _mediaTypeCounts.GetValueOrDefault("Comics", 0),
        _                  => 0,
