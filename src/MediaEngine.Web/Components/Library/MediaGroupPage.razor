@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration

@inject IEngineApiClient ApiClient
@inject IStringLocalizer<SharedStrings> L

@if (_loading)
{
    <div class="mgp-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Medium" Class="tl-u-color-tl-border-strong" />
    </div>
}
else if (_detail is null)
{
    <div class="mgp-empty">
        <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Class="tl-u-font-size-3rem tl-u-opacity-0-15" />
        <p class="tl-u-color-tl-text-muted">Group not found.</p>
    </div>
}
else
{
    @* -- BACK BUTTON -- *@
    <div class="mgp-breadcrumb">
        <AppNativeButton Class="mgp-back-btn" OnClick="() => OnBack.InvokeAsync()">
            <MudIcon Icon="@Icons.Material.Outlined.ArrowBack" Class="tl-u-font-size-18px" />
            <span>Back to @GetParentTabLabel()</span>
        </AppNativeButton>
    </div>

    @* -- HEADER -- *@
    <div class="mgp-header">
        @if (GroupType == "artist")
        {
            <div class="mgp-artist-photo @(_detail.ArtistPersonId.HasValue ? "mgp-artist-photo--clickable" : "")"
                 @onclick="HandleArtistPhotoClick"
                 title="@(_detail.ArtistPersonId.HasValue ? "View artist details" : null)">
                @if (!string.IsNullOrEmpty(_detail.ArtistPhotoUrl))
                {
                    <img src="@_detail.ArtistPhotoUrl" alt="@_detail.DisplayName" class="mgp-artist-photo-img" />
                }
                else
                {
                    <div class="mgp-artist-photo-placeholder">
                        <MudIcon Icon="@Icons.Material.Outlined.Person" Class="tl-u-font-size-96px tl-u-opacity-0-25" />
                    </div>
                }
            </div>
        }
        else
        {
            <div class="mgp-cover">
                @if (!string.IsNullOrEmpty(_detail.CoverUrl))
                {
                    <img src="@_detail.CoverUrl" alt="@_detail.DisplayName" class="mgp-cover-img" />
                }
                else
                {
                    <div class="mgp-cover-placeholder">
                        <MudIcon Icon="@GetMediaTypeIcon()" Class="tl-u-font-size-48px tl-u-opacity-0-2" />
                    </div>
                }
            </div>
        }
        <div class="mgp-meta">
            @if (GroupType == "artist" && _detail.ArtistPersonId.HasValue)
            {
                <h1 class="mgp-title mgp-title--clickable" @onclick="HandleArtistPhotoClick" title="View artist details">@_detail.DisplayName</h1>
            }
            else
            {
                <h1 class="mgp-title">@_detail.DisplayName</h1>
            }
            @* Suppress creator line when it would simply duplicate the title (e.g. artist views).
               TV shows also suppress the creator line  -  the show's top billed cast is shown as
               clickable chips below the meta-line, and the show's network is displayed as a
               badge next to the year/genre. Showing "Director: ..." on a TV row is misleading
               because TV direction is episode-scoped. *@
            @if (GroupType != "tv-show"
                 && !string.IsNullOrEmpty(_detail.Creator)
                 && !string.Equals(_detail.Creator, _detail.DisplayName, StringComparison.OrdinalIgnoreCase))
            {
                <p class="mgp-creator">@_detail.Creator</p>
            }
            <div class="mgp-meta-line">
                @if (!string.IsNullOrEmpty(_detail.YearRange))
                {
                    <span>@_detail.YearRange</span>
                }
                @if (GroupType == "tv-show" && !string.IsNullOrEmpty(_detail.Network))
                {
                    <span> -  <span class="mgp-network-badge">@_detail.Network</span></span>
                }
                @if (!string.IsNullOrEmpty(_detail.Genre))
                {
                    <span> -  @_detail.Genre</span>
                }
                @if (GroupType == "tv-show" && _detail.SeasonCount is int sc && sc > 0)
                {
                    <span> -  @sc @(sc == 1 ? "season" : "seasons")</span>
                }
                @if (_detail.TotalItems > 0)
                {
                    <span> -  @_detail.TotalItems @GetItemLabel()</span>
                }
                @if (!string.IsNullOrEmpty(_detail.TotalDuration))
                {
                    <span> -  @_detail.TotalDuration</span>
                }
            </div>
            @if ((GroupType == "tv-show" || GroupType == "movie-series") && _detail.TopCast.Count > 0)
            {
                <div class="mgp-cast-chips">
                    @foreach (var actor in _detail.TopCast)
                    {
                        var clickable = actor.PersonId.HasValue;
                        <AppNativeButton Class='@($"mgp-cast-chip {(clickable ? " mgp-cast-chip--clickable" : "")}")' Disabled="@(!clickable)" OnClick="() => HandleCastChipClick(actor)" Title="@actor.Name">
                            @if (!string.IsNullOrEmpty(actor.HeadshotUrl))
                            {
                                <img src="@actor.HeadshotUrl" alt="@actor.Name" class="mgp-cast-chip-photo" />
                            }
                            else
                            {
                                <div class="mgp-cast-chip-photo mgp-cast-chip-photo--placeholder">
                                    <MudIcon Icon="@Icons.Material.Outlined.Person" Class="tl-u-font-size-14px tl-u-opacity-0-4" />
                                </div>
                            }
                            <span class="mgp-cast-chip-name">@actor.Name</span>
                        </AppNativeButton>
                    }
                </div>
            }
            <div class="mgp-actions">
                @if (GroupType is "tv-show" or "album" or "comic-series" or "book-series" or "movie-series")
                {
                    <AppNativeButton Class="mgp-action-btn mgp-action-btn--delete" OnClick="DeleteContainer" Title="@($" Delete this {GetGroupTypeLabel().ToLowerInvariant()} and every file inside it")">
                        <MudIcon Icon="@Icons.Material.Outlined.DeleteSweep" Class="tl-u-font-size-16px" />
                        Delete @GetGroupTypeLabel()
                    </AppNativeButton>
                }
                <AppNativeButton Class='@($"mgp-action-btn mgp-action-btn--toggle {(ShowUnowned ? " mgp-action-btn--toggle-on" : "")}")' OnClick="ToggleShowUnowned">
                    <MudIcon Icon="@(ShowUnowned ? Icons.Material.Outlined.Visibility : Icons.Material.Outlined.VisibilityOff)" Class="tl-u-font-size-16px" />
                    @(ShowUnowned ? "Showing All" : "Owned Only")
                </AppNativeButton>
            </div>
        </div>
    </div>

    @* -- ITEM LIST -- *@
    <div class="mgp-content">
        @if (GroupType == "artist" && _detail.Seasons.Count > 0)
        {
            @* Artist view: one collapsible block per album, expanded by default *@
            @foreach (var season in _detail.Seasons)
            {
                var visibleTracks = ShowUnowned
                    ? season.Episodes
                    : season.Episodes.Where(e => e.IsOwned).ToList();
                if (visibleTracks.Count == 0) continue;
                <details class="mgp-album-collapsible" open>
                    <summary class="mgp-album-summary">
                        @if (!string.IsNullOrEmpty(season.CoverUrl))
                        {
                            <img src="@season.CoverUrl" class="mgp-album-summary-cover" alt="" />
                        }
                        else
                        {
                            <div class="mgp-album-summary-cover mgp-album-summary-cover--placeholder">
                                <MudIcon Icon="@Icons.Material.Outlined.Album" Class="tl-u-font-size-32px tl-u-opacity-0-2" />
                            </div>
                        }
                        <div class="mgp-album-summary-meta">
                            <div class="mgp-album-summary-title">@(season.SeasonLabel ?? "Album")</div>
                            @if (!string.IsNullOrEmpty(season.Year))
                            {
                                <div class="mgp-album-summary-year">@season.Year</div>
                            }
                        </div>
                        <span class="mgp-album-summary-count">
                            @visibleTracks.Count @(visibleTracks.Count == 1 ? "track" : "tracks")
                        </span>
                    </summary>
                    <div class="mgp-album-tracks">
                        @RenderWorkList(visibleTracks.ToList(), showTrackNumber: true)
                    </div>
                </details>
            }
        }
        else if (GroupType == "tv-show" && _detail.Seasons.Count > 0)
        {
            @* TV: season accordion sections *@
            @foreach (var season in _detail.Seasons)
            {
                var seasonNum = season.SeasonNumber;
                var sectionLabel = $"Season {seasonNum}";
                var itemWord = season.Episodes.Count == 1 ? "episode" : "episodes";
                <div class="mgp-season">
                    <AppNativeButton Class="mgp-season-header" OnClick="() => ToggleSeason(seasonNum)">
                        <MudIcon Icon="@(IsSeasonExpanded(seasonNum) ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                 Class="tl-u-font-size-16px tl-u-opacity-0-4" />
                        <span class="mgp-season-label">@sectionLabel</span>
                        <span class="mgp-season-count">@season.Episodes.Count @itemWord</span>
                    </AppNativeButton>
                    @if (IsSeasonExpanded(seasonNum))
                    {
                        @RenderWorkList(season.Episodes, showEpisodeNumber: true)
                    }
                </div>
            }
        }
        else
        {
            @* Music / Books / Movies / Comics: flat sorted list *@
            @RenderWorkList(_detail.Works,
                showTrackNumber: GroupType is "album",
                showSequence: GroupType is "book-series" or "movie-series")
        }
    </div>

    @* -- BATCH BAR -- *@
    <LibraryBatchBar SelectedCount="@_selectedItems.Count"
                   OnDelete="OnBatchDelete"
                   OnSyncNow="OnBatchSync"
                   OnClearSelection="ClearSelection" />
}

@code {
    [Parameter] public string GroupType { get; set; } = "";

    [Parameter] public Guid GroupId { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback<Guid> OnItemClicked { get; set; }
    [Parameter] public EventCallback OnBatchDelete { get; set; }
    [Parameter] public EventCallback OnBatchSync { get; set; }
    [Parameter] public EventCallback<List<Guid>> OnContainerRefresh { get; set; }
    [Parameter] public EventCallback<List<Guid>> OnContainerDelete  { get; set; }
    [Parameter] public bool ShowUnowned { get; set; } = true;
    [Parameter] public EventCallback<bool> ShowUnownedChanged { get; set; }
    [Parameter] public EventCallback<Guid> OnItemEditClicked { get; set; }
    [Parameter] public List<Guid>? ArtistAlbumCollectionIds { get; set; }
    [Parameter] public string? ArtistName { get; set; }
    [Parameter] public string? GroupName { get; set; }
    [Parameter] public string? GroupField { get; set; }
    [Parameter] public string? MediaType { get; set; }
    [Parameter] public int RefreshVersion { get; set; }
    [Parameter] public EventCallback<Guid> OnAlbumTileClicked { get; set; }
    [Parameter] public EventCallback<string> OnAlbumNameClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnPersonClicked { get; set; }

    private CollectionGroupDetailViewModel? _detail;
    private bool _loading = true;
    private HashSet<Guid> _selectedItems = [];
    private HashSet<int> _collapsedSeasons = [];
    private string? _lastLoadedCacheKey;
    private string GetCacheKey() =>
        $"{GroupId}|{GroupType}|{ArtistName}|{GroupName}|{GroupField}|{string.Join(",", ArtistAlbumCollectionIds ?? [])}|{RefreshVersion}";

    protected override async Task OnParametersSetAsync()
    {
        if (GroupId == Guid.Empty) return;

        var key = GetCacheKey();
        if (key == _lastLoadedCacheKey && _detail is not null) return;

        _loading = true;
        _lastLoadedCacheKey = key;
        _collapsedSeasons = [];
        _selectedItems = [];
        StateHasChanged();

        if (GroupType == "artist" && ArtistAlbumCollectionIds is { Count: > 0 })
        {
            _detail = await ApiClient.GetArtistGroupDetailAsync(ArtistAlbumCollectionIds);
        }
        else if (GroupType == "artist" || string.Equals(GroupField, "artist", StringComparison.OrdinalIgnoreCase))
        {
            var nameForLookup = !string.IsNullOrWhiteSpace(GroupName) ? GroupName : ArtistName;
            if (!string.IsNullOrWhiteSpace(nameForLookup))
                _detail = await ApiClient.GetArtistDetailByNameAsync(nameForLookup);
            else if (!string.IsNullOrWhiteSpace(GroupField))
                _detail = await ApiClient.GetSystemViewGroupDetailAsync(GroupField, GroupName ?? "", MediaType);
        }
        else if (!string.IsNullOrWhiteSpace(GroupName) && !string.IsNullOrWhiteSpace(GroupField))
        {
            _detail = await ApiClient.GetSystemViewGroupDetailAsync(GroupField, GroupName, MediaType);
        }
        else
        {
            _detail = await ApiClient.GetCollectionGroupDetailAsync(GroupId);
        }

        _loading = false;
        StateHasChanged();
    }

    private bool IsSeasonExpanded(int season) => !_collapsedSeasons.Contains(season);

    private void ToggleSeason(int season)
    {
        if (_collapsedSeasons.Contains(season))
            _collapsedSeasons.Remove(season);
        else
            _collapsedSeasons.Add(season);
    }

    private void ToggleSelect(Guid workId)
    {
        if (_selectedItems.Contains(workId))
            _selectedItems.Remove(workId);
        else
            _selectedItems.Add(workId);
    }

    private void ClearSelection()
    {
        _selectedItems.Clear();
        StateHasChanged();
    }

    private List<Guid> CollectAllOwnedIds()
    {
        if (_detail is null) return [];
        return _detail.Works.Select(w => w.WorkId)
            .Concat(_detail.Seasons.SelectMany(s => s.Episodes.Where(e => e.IsOwned).Select(e => e.WorkId)))
            .Distinct()
            .ToList();
    }

    private async Task DeleteContainer()
    {
        var ids = CollectAllOwnedIds();
        if (ids.Count == 0) return;
        if (OnContainerDelete.HasDelegate)
            await OnContainerDelete.InvokeAsync(ids);
        else
        {
            _selectedItems = [.. ids];
            await OnBatchDelete.InvokeAsync();
        }
    }

    private async Task ToggleShowUnowned()
    {
        await ShowUnownedChanged.InvokeAsync(!ShowUnowned);
    }

    private async Task HandleArtistPhotoClick()
    {
        if (_detail?.ArtistPersonId is { } personId && OnPersonClicked.HasDelegate)
            await OnPersonClicked.InvokeAsync(personId);
    }

    private async Task HandleCastChipClick(CollectionGroupPersonViewModel actor)
    {
        if (actor.PersonId is { } personId && OnPersonClicked.HasDelegate)
            await OnPersonClicked.InvokeAsync(personId);
    }

    private string GetGroupTypeLabel() => GroupType switch
    {
        "tv-show"       => "TV Show",
        "album"         => "Album",
        "book-series"   => "Book Series",
        "movie-series"  => "Movie Series",
        "artist"        => "Artist",
        "comic-series"  => "Comic Series",
        _               => "Group"
    };

    private string GetParentTabLabel() => GroupType switch
    {
        "tv-show"       => "TV",
        "album"         => "Music",
        "artist"        => "Music",
        "book-series"   => "Books",
        "movie-series"  => "Movies",
        "comic-series"  => "Comics",
        _               => "Library"
    };

    private string GetItemLabel() => GroupType switch
    {
        "tv-show"       => "episodes",
        "album"         => "tracks",
        "book-series"   => "books",
        "movie-series"  => "films",
        "artist"        => "tracks",
        "comic-series"  => "issues",
        _               => "items"
    };

    private string GetMediaTypeIcon() => GroupType switch
    {
        "tv-show"       => Icons.Material.Outlined.LiveTv,
        "album"         => Icons.Material.Outlined.Album,
        "book-series"   => Icons.Material.Outlined.MenuBook,
        "movie-series"  => Icons.Material.Outlined.VideoLibrary,
        "artist"        => Icons.Material.Outlined.Person,
        "comic-series"  => Icons.Material.Outlined.AutoStories,
        _               => Icons.Material.Outlined.Folder
    };

    private RenderFragment RenderWorkList(
        List<CollectionGroupWorkViewModel> items,
        bool showTrackNumber   = false,
        bool showEpisodeNumber = false,
        bool showSequence      = false) => builder =>
    {
        builder.OpenElement(0, "table");
        builder.AddAttribute(1, "class", "mgp-track-table");
        builder.OpenElement(2, "tbody");

        var seq = 3;
        foreach (var item in items)
        {
            var workId = item.WorkId;
            var isSelected = _selectedItems.Contains(workId);
            var isOwned = item.IsOwned;

            var rowClass = $"mgp-track-row{(isSelected ? " mgp-track-row--selected" : "")}{(!isOwned ? " mgp-track-row--unowned" : "")}";

            builder.OpenElement(seq++, "tr");
            builder.AddAttribute(seq++, "class", rowClass);
            if (isOwned)
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => OnItemClicked.InvokeAsync(workId)));
            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "mgp-track-td mgp-track-td--check");
            builder.OpenElement(seq++, "input");
            builder.AddAttribute(seq++, "type", "checkbox");
            builder.AddAttribute(seq++, "class", "vct-checkbox");
            builder.AddAttribute(seq++, "checked", isSelected);
            builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.MouseEventArgs>(this, _ => ToggleSelect(workId)));
            builder.AddEventStopPropagationAttribute(seq++, "onclick", true);
            builder.CloseElement(); // input
            builder.CloseElement(); // td
            var numDisplay = showTrackNumber   ? item.TrackNumber
                           : showEpisodeNumber ? item.Episode
                           : showSequence      ? item.Ordinal?.ToString()
                           : null;
            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "mgp-track-td mgp-track-td--num");
            if (numDisplay is not null)
                builder.AddContent(seq++, numDisplay);
            builder.CloseElement(); // td
            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "mgp-track-td mgp-track-td--title");
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "mgp-track-title");
            builder.AddContent(seq++, item.Title);
            builder.CloseElement(); // span (title)
            if (!string.IsNullOrEmpty(item.Year))
            {
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "mgp-track-year");
                builder.AddContent(seq++, item.Year);
                builder.CloseElement(); // span (year)
            }
            if (!isOwned)
            {
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "mgp-track-unowned-label");
                builder.AddContent(seq++, "(not in library)");
                builder.CloseElement(); // span (unowned-label)
            }
            builder.CloseElement(); // td
            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "mgp-track-td mgp-track-td--duration");
            builder.AddContent(seq++, item.Duration ?? " - ");
            builder.CloseElement(); // td
            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "mgp-track-td mgp-track-td--actions");
            if (isOwned && OnItemEditClicked.HasDelegate)
            {
                builder.OpenElement(seq++, "button");
                builder.AddAttribute(seq++, "class", "mgp-edit-btn");
                builder.AddAttribute(seq++, "title", "Edit metadata");
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => OnItemEditClicked.InvokeAsync(workId)));
                builder.AddEventStopPropagationAttribute(seq++, "onclick", true);
                builder.OpenComponent<MudIcon>(seq++);
                builder.AddComponentParameter(seq++, "Icon", Icons.Material.Outlined.Edit);
                builder.AddComponentParameter(seq++, "Size", Size.Small);
                builder.CloseComponent(); // MudIcon
                builder.CloseElement(); // button
            }
            builder.CloseElement(); // td

            builder.CloseElement(); // tr
        }

        builder.CloseElement(); // tbody
        builder.CloseElement(); // table
    };
}