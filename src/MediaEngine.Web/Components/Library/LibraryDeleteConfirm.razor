<div class="vdc-backdrop" @onclick="OnCancel">
    <div class="vdc-modal" @onclick:stopPropagation="true">
        <div class="vdc-icon-wrap">
            <MudIcon Icon="@Icons.Material.Outlined.Delete" Style="font-size: 32px;" />
        </div>
        <div class="vdc-text">
            <h2 class="vdc-title">@(Count > 1 ? $"Move {Count} Items to Quarantine?" : "Move to Quarantine?")</h2>
            <p class="vdc-desc">@(Count > 1 ? $"This will move {Count} items to quarantine. They will be hidden from your library but can be reviewed or restored from the Action Center." : "This will move the item to quarantine. It will be hidden from your library but can be reviewed or restored from the Action Center.")</p>
        </div>
        <div class="vdc-actions">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       FullWidth="true"
                       Class="vdc-delete-btn"
                       OnClick="OnConfirm">
                Quarantine
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Inherit"
                       FullWidth="true"
                       Class="vdc-cancel-btn"
                       OnClick="OnCancel">
                Cancel
            </MudButton>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ItemTitle { get; set; } = "";
    [Parameter] public int Count { get; set; } = 1;
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}

<style>
    .vdc-backdrop {
        position: fixed;
        inset: 0;
        z-index: var(--app-z-modal);
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .vdc-modal {
        background: #14181d;
        width: 100%;
        max-width: 384px;
        border-radius: var(--app-radius-md);
        border: 1px solid var(--tl-border-subtle);
        padding: 32px;
        text-align: center;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
        animation: vdc-zoom-in 0.15s ease;
    }

    @@keyframes vdc-zoom-in {
        from { transform: scale(0.95); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }

    .vdc-icon-wrap {
        width: 64px;
        height: 64px;
        background: rgba(226, 75, 74, 0.1);
        border: 1px solid rgba(226, 75, 74, 0.2);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        color: var(--tl-status-danger);
    }

    .vdc-text {
        margin-bottom: 24px;
    }

    .vdc-title {
        font-size: 20px;
        font-weight: 900;
        color: #fff;
        margin: 0 0 8px;
    }

    .vdc-desc {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.4);
        line-height: 1.5;
        margin: 0;
    }

    .vdc-actions {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .vdc-delete-btn {
        padding: 12px;
        border-radius: var(--app-radius-md);
        color: #fff;
        font-size: 14px;
        font-weight: 800;
        box-shadow: 0 4px 12px rgba(226, 75, 74, 0.2);
    }

    .vdc-cancel-btn {
        padding: 12px;
        border-radius: var(--app-radius-md);
        color: rgba(255, 255, 255, 0.4);
        font-size: 14px;
        font-weight: 700;
    }
</style>
