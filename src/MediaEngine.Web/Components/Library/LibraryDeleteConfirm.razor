<div class="vdc-backdrop" @onclick="OnCancel">
    <div class="vdc-modal" @onclick:stopPropagation="true">
        <div class="vdc-icon-wrap">
            <MudIcon Icon="@Icons.Material.Outlined.Delete" Style="font-size: 32px;" />
        </div>
        <div class="vdc-text">
            <h2 class="vdc-title">@(Count > 1 ? $"Move {Count} Items to Quarantine?" : "Move to Quarantine?")</h2>
            <p class="vdc-desc">@(Count > 1 ? $"This will move {Count} items to quarantine. They will be hidden from your library but can be reviewed or restored from the Review Queue." : "This will move the item to quarantine. It will be hidden from your library but can be reviewed or restored from the Review Queue.")</p>
        </div>
        <div class="vdc-actions">
            <AppButton Variant="Variant.Filled"
                       Color="Color.Error"
                       FullWidth="true"
                       Class="vdc-delete-btn"
                       OnClick="OnConfirm">
                Quarantine
            </AppButton>
            <AppButton Variant="Variant.Outlined"
                       Color="Color.Inherit"
                       FullWidth="true"
                       Class="vdc-cancel-btn"
                       OnClick="OnCancel">
                Cancel
            </AppButton>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ItemTitle { get; set; } = "";
    [Parameter] public int Count { get; set; } = 1;
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}