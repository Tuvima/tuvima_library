@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs

@if (Items is null || Items.Count == 0)
{
    <div class="vacc-empty">
        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">No items require review.</p>
    </div>
}
else
{
    <div class="vacc-header">
        <span class="vacc-total">@Items.Count items require attention</span>
    </div>

    @foreach (var category in GetCategories())
    {
        var isExpanded = _expanded.GetValueOrDefault(category.Key, category.IsDefaultExpanded);

        <div class="vacc-section">
            <MudButton Variant="Variant.Text"
                       Color="Color.Inherit"
                       Class="vacc-section-header"
                       OnClick="() => ToggleSection(category.Key)">
                <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                         Style="font-size: 16px; opacity: 0.4;" />
                <span class="vacc-section-label">@category.Label</span>
                <span class="vacc-section-count">@category.Items.Count</span>
            </MudButton>

            @if (isExpanded)
            {
                <div class="vacc-section-items">
                    @foreach (var item in category.Items)
                    {
                        var isSelected = _selectedIds.Contains(item.EntityId);
                        <div class="vacc-row @(isSelected ? "vacc-row--selected" : "")"
                             @onclick="() => OnItemClicked.InvokeAsync(item.EntityId)">
                            <MudCheckBox T="bool"
                                         Value="@isSelected"
                                         ValueChanged="@(value => ToggleSelection(item.EntityId))"
                                         Color="Color.Primary"
                                         Dense="true"
                                         Class="vacc-checkbox"
                                         @onclick:stopPropagation="true" />
                            <div class="vacc-row-cover">
                                @if (!string.IsNullOrEmpty(item.CoverUrl))
                                {
                                    <img src="@(item.CoverThumbUrl ?? item.CoverUrl)" alt="" class="vacc-row-cover-img" loading="lazy" />
                                }
                                else
                                {
                                    <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(item.MediaType)" Style="font-size: 14px; opacity: 0.2;" />
                                }
                            </div>
                            <div class="vacc-row-info">
                                <span class="vacc-row-title">@item.Title</span>
                                <span class="vacc-row-detail">@LibraryHelpers.FormatMediaType(item.MediaType) @(item.Year is not null ? $" Â· {item.Year}" : "")</span>
                            </div>
                            <span class="vacc-row-trigger">@LibraryHelpers.GetReviewTriggerLabel(item.ReviewTrigger)</span>
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (_selectedIds.Count > 0)
    {
        <div class="vacc-bulk-bar">
            <span class="vacc-bulk-count">@_selectedIds.Count selected</span>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       Class="vacc-bulk-btn vacc-bulk-btn--delete"
                       OnClick="OnBulkDeleteClicked">
                Delete Selected
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Info"
                       Class="vacc-bulk-btn vacc-bulk-btn--retry"
                       OnClick="OnBulkRetryClicked">
                Retry Selected
            </MudButton>
        </div>
    }
}

@code {
    [Parameter] public List<LibraryItemViewModel>? Items { get; set; }
    [Parameter] public EventCallback<Guid> OnItemClicked { get; set; }
    [Parameter] public EventCallback<HashSet<Guid>> OnBulkDelete { get; set; }
    [Parameter] public EventCallback<HashSet<Guid>> OnBulkRetry { get; set; }

    private Dictionary<string, bool> _expanded = new();
    private HashSet<Guid> _selectedIds = [];

    private sealed record Category(string Key, string Label, List<LibraryItemViewModel> Items, bool IsDefaultExpanded);

    private List<Category> GetCategories()
    {
        if (Items is null) return [];

        var categories = new List<Category>();

        var needsId = Items.Where(i => IsNeedsIdentification(i.ReviewTrigger)).ToList();
        if (needsId.Count > 0)
            categories.Add(new("needs_id", "Needs Identification", needsId, true));

        var ambiguous = Items.Where(i => IsAmbiguous(i.ReviewTrigger)).ToList();
        if (ambiguous.Count > 0)
            categories.Add(new("ambiguous", "Ambiguous Match", ambiguous, true));

        var lowConf = Items.Where(i => i.ReviewTrigger == "LowConfidence").ToList();
        if (lowConf.Count > 0)
            categories.Add(new("low_conf", "Low Confidence", lowConf, false));

        var unknownType = Items.Where(i => i.ReviewTrigger == "MediaTypeUnknown").ToList();
        if (unknownType.Count > 0)
            categories.Add(new("unknown_type", "Media Type Unknown", unknownType, false));

        var quarantined = Items.Where(i => i.LibraryDisplayStatus == LibraryStatus.Quarantined).ToList();
        if (quarantined.Count > 0)
            categories.Add(new("quarantined", "Quarantined", quarantined, false));

        var waiting = Items.Where(i => i.LibraryDisplayStatus == LibraryStatus.WaitingForProvider).ToList();
        if (waiting.Count > 0)
            categories.Add(new("waiting", "Waiting for Provider", waiting, false));

        // Items that don't fit any category
        var categorized = new HashSet<Guid>(categories.SelectMany(c => c.Items.Select(i => i.EntityId)));
        var uncategorized = Items.Where(i => !categorized.Contains(i.EntityId)).ToList();
        if (uncategorized.Count > 0)
            categories.Add(new("other", "Other", uncategorized, false));

        return categories;
    }

    private static bool IsNeedsIdentification(string? trigger) =>
        trigger is "RetailMatchFailed" or "NoRetailMatch" or "RetailMatchNone"
               or "AuthorityMatchFailed" or "ContentMatchFailed";

    private static bool IsAmbiguous(string? trigger) =>
        trigger is "RetailMatchAmbiguous" or "MultipleQidMatches" or "AmbiguousMatch"
               or "WikidataBridgeFailed" or "MissingQid";

    private void ToggleSection(string key)
    {
        _expanded[key] = !_expanded.GetValueOrDefault(key, true);
    }

    private void ToggleSelection(Guid id)
    {
        if (!_selectedIds.Add(id)) _selectedIds.Remove(id);
    }

    private async Task OnBulkDeleteClicked()
    {
        await OnBulkDelete.InvokeAsync(new HashSet<Guid>(_selectedIds));
        _selectedIds.Clear();
    }

    private async Task OnBulkRetryClicked()
    {
        await OnBulkRetry.InvokeAsync(new HashSet<Guid>(_selectedIds));
        _selectedIds.Clear();
    }
}

<style>
    .vacc-empty {
        display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px;
    }
    .vacc-header { margin-bottom: 16px; }
    .vacc-total { font-size: 0.85rem; color: rgba(255,255,255,0.4); }
    .vacc-section { margin-bottom: 4px; }
    .vacc-section-header {
        display: flex; align-items: center; gap: 8px; width: 100%; padding: 10px 12px;
        background: rgba(255,255,255,0.02); border-radius: 8px;
        color: rgba(255,255,255,0.7); font-size: 0.85rem; font-weight: 600;
        text-transform: none; transition: background 0.15s;
    }
    .vacc-section-header:hover { background: rgba(255,255,255,0.04); }
    .vacc-section-label { flex: 1; text-align: left; }
    .vacc-section-count {
        font-size: 0.75rem; font-weight: 700; color: rgba(201,146,46,0.7);
        background: rgba(201,146,46,0.1); padding: 2px 8px; border-radius: 10px;
    }
    .vacc-section-items { padding: 4px 0 4px 8px; }
    .vacc-row {
        display: flex; align-items: center; gap: 10px; padding: 8px 12px;
        border-radius: 6px; cursor: pointer; transition: background 0.15s;
        border-left: 3px solid transparent;
    }
    .vacc-row:hover { background: rgba(255,255,255,0.03); }
    .vacc-row--selected {
        border-left-color: rgba(201,146,46,0.7); background: rgba(201,146,46,0.04);
    }
    ::deep .vacc-checkbox .mud-checkbox-span { padding: 0; }
    .vacc-row-cover {
        width: 28px; height: 28px; border-radius: 4px; overflow: hidden;
        background: rgba(255,255,255,0.03); display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .vacc-row-cover-img { width: 100%; height: 100%; object-fit: cover; }
    .vacc-row-info { flex: 1; min-width: 0; }
    .vacc-row-title {
        font-size: 0.85rem; color: rgba(255,255,255,0.8); display: block;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .vacc-row-detail {
        font-size: 0.7rem; color: rgba(255,255,255,0.3);
    }
    .vacc-row-trigger {
        font-size: 0.7rem; color: rgba(201,146,46,0.6); flex-shrink: 0;
    }
    .vacc-bulk-bar {
        position: sticky; bottom: 0; display: flex; align-items: center; gap: 12px;
        padding: 12px 16px; margin-top: 12px;
        background: rgba(20,24,29,0.95); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px; backdrop-filter: blur(8px);
    }
    .vacc-bulk-count { font-size: 0.8rem; font-weight: 700; color: rgba(255,255,255,0.8); }
    .vacc-bulk-btn {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase; padding: 6px 14px;
        border-radius: 6px;
    }
    .vacc-bulk-btn--delete {
        background: rgba(226,75,74,0.12); color: rgba(226,75,74,0.8);
    }
    .vacc-bulk-btn--delete:hover { background: rgba(226,75,74,0.2); }
    .vacc-bulk-btn--retry {
        background: rgba(96,165,250,0.12); color: rgba(96,165,250,0.8);
    }
    .vacc-bulk-btn--retry:hover { background: rgba(96,165,250,0.2); }
</style>

