@using MediaEngine.Web.Models.ViewDTOs

<div class="stage-gate">
    <div class="stage-dot @(Stage.State == LibraryStageState.Running ? "stage-dot--running" : "")"
         style="background: @DotColor; box-shadow: @DotShadow;"
         title="@Stage.Label"></div>
    @if (!IsLast)
    {
        <div class="stage-line" style="background: @LineColor;"></div>
    }
</div>

@code {
    [Parameter, EditorRequired] public LibraryPipelineStage Stage { get; set; } = default!;
    [Parameter] public bool IsLast { get; set; }

    private string DotColor => Stage.State switch
    {
        LibraryStageState.Completed => "var(--tl-status-success)",
        LibraryStageState.Warning => "var(--tl-status-warning)",
        LibraryStageState.Failed => "var(--tl-status-danger)",
        LibraryStageState.Running => "#90CAF9",
        _ => "var(--tl-border-default)",
    };

    private string DotShadow => Stage.State switch
    {
        LibraryStageState.Completed => "0 0 8px var(--tl-status-success-border)",
        LibraryStageState.Warning => "0 0 8px var(--tl-status-warning-border)",
        LibraryStageState.Failed => "0 0 8px rgba(160,80,80,0.3)",
        LibraryStageState.Running => "0 0 8px rgba(144,202,249,0.4)",
        _ => "none",
    };

    private string LineColor => Stage.State == LibraryStageState.Completed
        ? "var(--tl-status-success-border)"
        : "var(--tl-border-subtle)";
}

<style>
    .stage-gate {
        display: flex;
        align-items: center;
    }

    .stage-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        z-index: 1;
        border: 2px solid #0d0f12;
        flex-shrink: 0;
    }

    .stage-dot--running {
        animation: stage-pulse 1.2s ease-in-out infinite;
    }

    @@keyframes stage-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }

    .stage-line {
        height: 2px;
        width: 20px;
        margin: 0 -2px;
        flex-shrink: 0;
    }
</style>
