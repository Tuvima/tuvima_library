@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Theming

@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar

<div class="vep-panel">
    @* -- Header -- *@
    <div class="vep-header">
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Size="Size.Small"
                       Color="Color.Inherit"
                       Class="vep-close"
                       OnClick="OnClose" />

        @if (IsSingleItem)
        {
            <div class="vep-header-single">
                <div class="vep-cover">
                    @if (!string.IsNullOrEmpty(SingleItem.CoverUrl))
                    {
                        <img src="@(SingleItem.CoverThumbUrl ?? SingleItem.CoverUrl)" alt="" class="vep-cover-img" />
                    }
                    else
                    {
                        <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(SingleItem.MediaType)"
                                 Style="font-size: 28px; opacity: 0.2;" />
                    }
                </div>
                <div class="vep-header-meta">
                    <p class="vep-header-title">@SingleItem.Title</p>
                    <div class="vep-header-badges">
                        <StatusPill Status="@SingleItem.LibraryDisplayStatus" />
                        @if (!string.IsNullOrEmpty(SingleItem.WikidataQid))
                        {
                            <a href="https://www.wikidata.org/wiki/@SingleItem.WikidataQid"
                               target="_blank" rel="noopener" class="vep-qid-badge">@SingleItem.WikidataQid</a>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="vep-header-multi">
                <p class="vep-header-title">Editing @Items.Count items</p>
                <div class="vep-thumb-strip">
                    @foreach (var item in Items.Take(6))
                    {
                        <div class="vep-thumb-mini">
                            @if (!string.IsNullOrEmpty(item.CoverUrl))
                            {
                                <img src="@(item.CoverThumbUrl ?? item.CoverUrl)" alt="" />
                            }
                            else
                            {
                                <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(item.MediaType)"
                                         Style="font-size: 12px; opacity: 0.2;" />
                            }
                        </div>
                    }
                    @if (Items.Count > 6)
                    {
                        <span class="vep-thumb-more">+@(Items.Count - 6)</span>
                    }
                </div>
            </div>
        }
    </div>

    @* -- Tabs -- *@
    <MudTabs ActivePanelIndex="@ActiveTabIndex"
             ActivePanelIndexChanged="OnTabChanged"
                         Rounded="false"
             Border="false"
             Elevation="0"
             Class="vep-tabs">
        @foreach (var tab in EditorTabs)
        {
            <MudTabPanel Text="@tab.Label" Disabled="@tab.Disabled" />
        }
    </MudTabs>

    @* -- Tab content -- *@
    <div class="vep-body">
        @switch (_activeTab)
        {
            case "details":
                <LibraryEditorFields Fields="@_editorFields"
                                   Items="@Items"
                                   EditedValues="@_editedValues"
                                   OnFieldChanged="OnFieldChanged"
                                   OnFieldReset="OnFieldReset" />

                @* Read-only file info (single item) *@
                @if (IsSingleItem)
                {
                    <div class="vep-readonly-section">
                        <div class="vef-row">
                            <label class="vef-label">Format</label>
                            <span class="vef-value vef-value--readonly">@(SingleItem.Specs ?? " - ")</span>
                        </div>
                        <div class="vef-row">
                            <label class="vef-label">Size</label>
                            <span class="vef-value vef-value--readonly">@LibraryHelpers.FormatFileSize(SingleItem.FileSizeBytes)</span>
                        </div>
                        @if (!string.IsNullOrEmpty(SingleItem.FileName))
                        {
                            <div class="vef-row">
                                <label class="vef-label">File</label>
                                <span class="vef-value vef-value--readonly vep-file-path" title="@SingleItem.FilePath">@SingleItem.FileName</span>
                            </div>
                        }
                    </div>
                }

                @* Pending changes preview *@
                @if (_editedValues.Count > 0)
                {
                    <div class="vep-preview">
                        <p class="vep-preview-header">Pending Changes</p>
                        @foreach (var kv in _editedValues)
                        {
                            <p class="vep-preview-line">
                                <span class="vep-preview-key">@LibraryHelpers.FormatClaimKey(kv.Key)</span>
                                <span class="vep-preview-arrow">&rarr;</span>
                                <span class="vep-preview-val">@(string.IsNullOrEmpty(kv.Value) ? "(clear)" : kv.Value)</span>
                            </p>
                        }
                    </div>
                }
                break;

            case "pipeline":
                @if (IsSingleItem)
                {
                    <div class="vep-pipeline-placeholder">
                        <MudIcon Icon="@Icons.Material.Outlined.Timeline" Style="font-size: 2rem; opacity: 0.15; margin-bottom: 8px;" />
                        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">Pipeline search and match UI will be migrated from the detail drawer in a subsequent phase.</p>
                    </div>
                }
                break;

            case "artwork":
                <div class="vep-artwork">
                    @if (IsSingleItem && !string.IsNullOrEmpty(SingleItem.CoverUrl))
                    {
                        <img src="@SingleItem.CoverUrl" alt="Cover art" class="vep-artwork-img" />
                    }
                    else if (!IsSingleItem)
                    {
                        <p style="color: rgba(255,255,255,0.3); font-size: 0.85rem;">@Items.Count items selected  -  artwork editing coming soon.</p>
                    }
                    else
                    {
                        <p style="color: rgba(255,255,255,0.3); font-size: 0.85rem;">No cover art available.</p>
                    }
                </div>
                break;

            case "actions":
                <div class="vep-actions">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Inherit"
                               StartIcon="@Icons.Material.Outlined.Search"
                               Class="vep-action-btn"
                               OnClick="OnReidentify">
                        Re-identify @(IsSingleItem ? "" : $"({Items.Count})")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Inherit"
                               StartIcon="@Icons.Material.Outlined.Refresh"
                               Class="vep-action-btn"
                               OnClick="OnRefresh">
                        Refresh Enrichment @(IsSingleItem ? "" : $"({Items.Count})")
                    </MudButton>
                    <div class="vep-actions-divider"></div>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Outlined.DeleteForever"
                               Class="vep-action-btn vep-action-btn--danger"
                               OnClick="OnPurgeClicked">
                        Purge @(IsSingleItem ? "Record" : $"{Items.Count} Records")
                    </MudButton>
                </div>
                break;
        }
    </div>

    @* -- Footer -- *@
    <div class="vep-footer">
        @if (IsSingleItem && _editedValues.Count == 0)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       Class="vep-footer-btn vep-footer-btn--danger"
                       OnClick="OnPurgeClicked">
                Purge
            </MudButton>
        }
        else if (_editedValues.Count > 0)
        {
            <MudButton Variant="Variant.Text"
                       Color="Color.Inherit"
                       Class="vep-footer-btn vep-footer-btn--secondary"
                       OnClick="CancelEdits">
                Cancel
            </MudButton>
        }
        <div style="flex: 1;"></div>
        @if (_editedValues.Count > 0)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Class="vep-footer-btn vep-footer-btn--primary"
                       OnClick="ApplyEdits"
                       Disabled="@_applying">
                @if (_applying)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: inherit; width: 14px; height: 14px;" />
                }
                Apply @(IsSingleItem ? "" : $"({Items.Count})")
            </MudButton>
        }
    </div>
</div>

@code {
    [Parameter] public List<LibraryItemViewModel> Items { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnApplied { get; set; }
    [Parameter] public EventCallback<List<Guid>> OnPurge { get; set; }
    [Parameter] public EventCallback<List<Guid>> OnReidentifyItems { get; set; }
    [Parameter] public EventCallback<List<Guid>> OnRefreshItems { get; set; }

    private string _activeTab = "details";
    private Dictionary<string, string> _editedValues = new();
    private bool _applying;

    private bool IsSingleItem => Items.Count == 1;
    private LibraryItemViewModel SingleItem => Items[0];

    private List<EditorFieldDef> _editorFields = [];
    private IReadOnlyList<(string Id, string Label, bool Disabled)> EditorTabs
    {
        get
        {
            var items = new List<(string Id, string Label, bool Disabled)>
            {
                ("details", "Details", false)
            };

            if (IsSingleItem)
                items.Add(("pipeline", "Pipeline", false));

            items.Add(("artwork", "Artwork", false));
            items.Add(("actions", "Actions", false));
            return items;
        }
    }

    private int ActiveTabIndex => GetSelectedIndex(EditorTabs.Select(tab => tab.Id), _activeTab);

    protected override void OnParametersSet()
    {
        _editorFields = BuildFieldsForMediaTypes();
        _editedValues.Clear();
        _activeTab = "details";
    }

    private Task OnTabChanged(int index)
    {
        if (index < 0 || index >= EditorTabs.Count)
            return Task.CompletedTask;

        _activeTab = EditorTabs[index].Id;
        return Task.CompletedTask;
    }

    private List<EditorFieldDef> BuildFieldsForMediaTypes()
    {
        if (Items.Count == 0) return [];

        var mediaTypes = Items.Select(i => i.MediaType?.ToUpperInvariant()).Distinct().ToList();

        // If all same type, show type-specific fields; if mixed, show common fields only
        if (mediaTypes.Count == 1)
            return GetFieldsForType(mediaTypes[0] ?? "");

        // Common fields across all media types
        return
        [
            new() { Key = "title", Label = "Title" },
            new() { Key = "year",  Label = "Year" },
            new() { Key = "genre", Label = "Genre" },
        ];
    }

    private static List<EditorFieldDef> GetFieldsForType(string mediaType) => mediaType switch
    {
        "BOOKS" =>
        [
            new() { Key = "title",           Label = "Title" },
            new() { Key = "author",          Label = "Author" },
            new() { Key = "series",          Label = "Series" },
            new() { Key = "series_position", Label = "Series #" },
            new() { Key = "year",            Label = "Year" },
            new() { Key = "genre",           Label = "Genre" },
        ],
        "AUDIOBOOKS" =>
        [
            new() { Key = "title",           Label = "Title" },
            new() { Key = "author",          Label = "Author" },
            new() { Key = "narrator",        Label = "Narrator" },
            new() { Key = "series",          Label = "Series" },
            new() { Key = "series_position", Label = "Series #" },
            new() { Key = "year",            Label = "Year" },
            new() { Key = "genre",           Label = "Genre" },
        ],
        "MOVIES" =>
        [
            new() { Key = "title",    Label = "Title" },
            new() { Key = "director", Label = "Director" },
            new() { Key = "year",     Label = "Year" },
            new() { Key = "genre",    Label = "Genre" },
        ],
        "TV" =>
        [
            new() { Key = "title",         Label = "Title" },
            new() { Key = "episode_title", Label = "Episode Title" },
            new() { Key = "show_name",     Label = "Show Name" },
            new() { Key = "season",        Label = "Season" },
            new() { Key = "episode",       Label = "Episode" },
            new() { Key = "network",       Label = "Network" },
            new() { Key = "year",          Label = "Year" },
            new() { Key = "genre",         Label = "Genre" },
        ],
        "MUSIC" =>
        [
            new() { Key = "title",        Label = "Title" },
            new() { Key = "artist",       Label = "Artist" },
            new() { Key = "album",        Label = "Album" },
            new() { Key = "album_artist", Label = "Album Artist" },
            new() { Key = "year",         Label = "Year" },
            new() { Key = "genre",        Label = "Genre" },
        ],
        "COMICS" =>
        [
            new() { Key = "title",           Label = "Title" },
            new() { Key = "author",          Label = "Writer" },
            new() { Key = "series",          Label = "Series" },
            new() { Key = "series_position", Label = "Issue #" },
            new() { Key = "year",            Label = "Year" },
            new() { Key = "genre",           Label = "Genre" },
        ],
        _ =>
        [
            new() { Key = "title", Label = "Title" },
            new() { Key = "year",  Label = "Year" },
            new() { Key = "genre", Label = "Genre" },
        ],
    };

    private void OnFieldChanged((string Key, string Value) change)
    {
        _editedValues[change.Key] = change.Value;
        StateHasChanged();
    }

    private void OnFieldReset(string key)
    {
        _editedValues.Remove(key);
        StateHasChanged();
    }

    private void CancelEdits()
    {
        _editedValues.Clear();
        StateHasChanged();
    }

    private async Task ApplyEdits()
    {
        if (_editedValues.Count == 0) return;
        _applying = true;
        StateHasChanged();

        try
        {
            var entityIds = Items.Select(i => i.EntityId).ToList();
            var result = await ApiClient.BatchEditAsync(entityIds, _editedValues);
            if (result is not null)
            {
                Snackbar.Add($"Updated {result.UpdatedCount} items.", Severity.Success);
                _editedValues.Clear();
                await OnApplied.InvokeAsync();
            }
            else
            {
                Snackbar.Add("Failed to apply changes.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _applying = false;
            StateHasChanged();
        }
    }

    private async Task OnReidentify()
    {
        await OnReidentifyItems.InvokeAsync(Items.Select(i => i.EntityId).ToList());
    }

    private async Task OnRefresh()
    {
        await OnRefreshItems.InvokeAsync(Items.Select(i => i.EntityId).ToList());
    }

    private async Task OnPurgeClicked()
    {
        await OnPurge.InvokeAsync(Items.Select(i => i.EntityId).ToList());
    }

    private static int GetSelectedIndex(IEnumerable<string> keys, string activeKey)
    {
        var index = 0;
        foreach (var key in keys)
        {
            if (string.Equals(key, activeKey, StringComparison.OrdinalIgnoreCase))
                return index;

            index++;
        }

        return 0;
    }
}

<style>
