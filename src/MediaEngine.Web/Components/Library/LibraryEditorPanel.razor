    }

    .vep-footer {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .vep-footer-btn {
        border-radius: 8px;
