@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs

@* -- Renders editable fields for one or more selected items -- *@

@foreach (var field in Fields)
{
    var state = GetFieldState(field.Key);
    var isEdited = EditedValues.ContainsKey(field.Key);
    var isReadOnly = field.ReadOnly;

    <div class="vef-row @(isEdited ? "vef-row--edited" : "")">
        <label class="vef-label">@field.Label</label>
        @if (isReadOnly)
        {
            <span class="vef-value vef-value--readonly">@(state.DisplayValue ?? " - ")</span>
        }
        else if (state.IsMultiple && !isEdited)
        {
            <div class="vef-input-wrap">
                <MudTextField T="string"
                              Value="@string.Empty"
                              Placeholder="Multiple Values"
                              ReadOnly="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="vef-input vef-input--multiple"
                              @onfocus="() => StartEdit(field.Key, string.Empty)" />
            </div>
        }
        else
        {
            <div class="vef-input-wrap">
                <MudTextField T="string"
                              Value="@(isEdited ? EditedValues[field.Key] : state.DisplayValue ?? string.Empty)"
                              ValueChanged="@(value => OnFieldInput(field.Key, value))"
                              Immediate="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="vef-input" />
                @if (isEdited)
                {
                    <MudIconButton Icon="@Icons.Material.Outlined.Undo"
                                   Size="Size.Small"
                                   aria-label="Reset"
                                   Class="vef-reset-btn"
                                   OnClick="() => ResetField(field.Key)" />
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public List<EditorFieldDef> Fields { get; set; } = [];
    [Parameter] public List<LibraryItemViewModel> Items { get; set; } = [];
    [Parameter] public Dictionary<string, string> EditedValues { get; set; } = new();
    [Parameter] public EventCallback<(string Key, string Value)> OnFieldChanged { get; set; }
    [Parameter] public EventCallback<string> OnFieldReset { get; set; }

    private FieldState GetFieldState(string key)
    {
        if (Items.Count == 0) return new("", false);
        if (Items.Count == 1)
        {
            var val = GetItemFieldValue(Items[0], key);
            return new(val, false);
        }

        // Multi-item: check if all share the same value
        var values = Items.Select(i => GetItemFieldValue(i, key) ?? "").Distinct().ToList();
        if (values.Count == 1)
            return new(values[0], false);
        return new(null, true);
    }

    private static string? GetItemFieldValue(LibraryItemViewModel item, string key) => key switch
    {
        "title" => item.Title,
        "author" => item.Author,
        "director" => item.Director,
        "artist" => item.Artist,
        "narrator" => item.Narrator,
        "album" => item.Album,
        "album_artist" => item.Artist, // AlbumArtist not tracked separately; falls back to Artist
        "series" => item.Series,
        "series_position" => item.SeriesPosition,
        "year" => item.Year,
        "genre" => item.Genre,
        "show_name" => item.ShowName,
        "season" => item.Season,
        "episode" => item.Episode,
        "episode_title" => item.EpisodeTitle,
        "network" => item.Network,
        _ => null,
    };

    private void StartEdit(string key, string initialValue)
    {
        OnFieldChanged.InvokeAsync((key, initialValue));
    }

    private void OnFieldInput(string key, string value)
    {
        OnFieldChanged.InvokeAsync((key, value));
    }

    private void ResetField(string key)
    {
        OnFieldReset.InvokeAsync(key);
    }

    private record FieldState(string? DisplayValue, bool IsMultiple);
}

<style>
    .vef-row {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 0;
        border-left: 3px solid transparent;
        transition: border-color 0.15s;
    }

    .vef-row--edited {
        border-left-color: rgba(201, 146, 46, 0.7);
        padding-left: 8px;
    }

    .vef-label {
        width: 90px;
        min-width: 90px;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.35);
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .vef-value {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.6);
    }

    .vef-value--readonly {
        color: rgba(255, 255, 255, 0.4);
    }

    .vef-input-wrap {
        display: flex;
        align-items: center;
        gap: 4px;
        flex: 1;
        min-width: 0;
    }

    .vef-input {
        flex: 1;
    }

    ::deep .vef-input .mud-input-control {
        margin-top: 0;
    }

    ::deep .vef-input .mud-input-outlined-border {
        border-color: rgba(255, 255, 255, 0.08);
    }

    ::deep .vef-input .mud-input-slot {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.85);
    }

    ::deep .vef-input.mud-input-root-outlined:hover .mud-input-outlined-border,
    ::deep .vef-input.mud-input-root-outlined.mud-input-focused .mud-input-outlined-border {
        border-color: rgba(201, 146, 46, 0.5);
    }

    ::deep .vef-input--multiple .mud-input-slot {
        color: rgba(255, 255, 255, 0.3);
        font-style: italic;
        cursor: pointer;
    }

    .vef-reset-btn {
        color: rgba(255, 255, 255, 0.3);
        border-radius: 4px;
    }

    .vef-reset-btn:hover,
    .vef-reset-btn:focus-visible {
        color: rgba(255, 255, 255, 0.6);
        background: rgba(255, 255, 255, 0.05);
    }
</style>

