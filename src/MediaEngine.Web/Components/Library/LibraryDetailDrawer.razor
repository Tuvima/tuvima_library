@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Domain.Constants
@using MediaEngine.Domain.Enums
@namespace MediaEngine.Web.Components.Library
@inject IStringLocalizer<SharedStrings> L
@inject IEngineApiClient ApiClient
@inject NavigationManager Nav

@* -- Backdrop -- *@
<div class="vdd-backdrop" @onclick="OnClose"></div>

@* -- Drawer Panel -- *@
<div class="vdd-drawer" @onclick:stopPropagation="true">

    @* -- 1. Pinned Header -- *@
    <div class="vdd-header">
        <MudIconButton Icon="@Icons.Material.Outlined.Close"
                       Size="Size.Small"
                       Style="position:absolute;top:24px;right:24px;color:var(--tl-text-muted);"
                       OnClick="OnClose" />

        @if (MediaItem is not null)
        {
            @* -- Media Header -- *@
            <div class="vdd-header-content">
                <div class="vdd-thumb-wrap">
                    @if (!string.IsNullOrEmpty(MediaItem.CoverUrl))
                    {
                        <img src="@MediaItem.CoverUrl" alt="" class="vdd-thumb-img" loading="lazy" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 48px; color: rgba(255,255,255,0.1);" />
                    }
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        <span class="vdd-location-chip @GetReadinessChipClass()">
                            @MediaItem.ReadinessLabel
                        </span>
                        <StatusPill Status="@MediaItem.LibraryDisplayStatus" QuarantineDays="@MediaItem.QuarantineDays" />
                        @if (!string.IsNullOrEmpty(MediaItem.WikidataQid))
                        {
                            <a href="https://www.wikidata.org/wiki/@MediaItem.WikidataQid" target="_blank" rel="noopener" class="vdd-qid-badge">
                                <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 11px;" />
                                @MediaItem.WikidataQid
                            </a>
                            @if (GetWikipediaUrl() is string mediaWikiUrl)
                            {
                                <a href="@mediaWikiUrl" target="_blank" rel="noopener" class="vdd-wiki-badge" title="Open Wikipedia article">
                                    <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 11px;" />
                                    Wikipedia
                                </a>
                            }
                        }
                    </div>
                    <h2 class="vdd-title">@MediaItem.Title</h2>
                    @{
                        var drawerCreator = MediaItem.MediaType switch
                        {
                            "Movies" => MediaItem.Director ?? MediaItem.Author,
                            "TV" => MediaItem.Director,
                            "Music" => MediaItem.Artist ?? MediaItem.Author,
                            _ => MediaItem.Author,
                        };
                    }
                    @if (!string.IsNullOrEmpty(drawerCreator))
                    {
                        <p class="vdd-subtitle vdd-subtitle--clickable" @onclick="() => NavigateToCreatorPerson(drawerCreator)">
                            @drawerCreator.ToUpperInvariant()
                        </p>
                    }
                    <div class="vdd-meta">
                        <span class="vdd-meta-item" style="color: @LibraryHelpers.GetMediaTypeColor(MediaItem.MediaType);">
                            <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(MediaItem.MediaType)" Style="font-size: 14px;" />
                            @LibraryHelpers.FormatMediaType(MediaItem.MediaType)
                        </span>
                        @if (!string.IsNullOrEmpty(MediaItem.Year))
                        {
                            <span class="vdd-meta-item">@MediaItem.Year</span>
                        }
                    </div>
                    <p class="vdd-added-date">Added @MediaItem.CreatedAt.ToString("MMM dd, yyyy")</p>
                </div>
            </div>
        }
        else if (Person is not null)
        {
            @* -- Person Header -- *@
            <div class="vdd-header-content">
                <div class="vdd-avatar-round">
                    @if (!string.IsNullOrEmpty(Person.HeadshotUrl))
                    {
                        <img src="@Person.HeadshotUrl" alt="" class="vdd-avatar-img" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 48px; color: rgba(255,255,255,0.1);" />
                    }
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        @foreach (var role in Person.Roles)
                        {
                            <span class="vdd-role-chip">@role.ToUpperInvariant()</span>
                        }
                        @if (!string.IsNullOrEmpty(Person.WikidataQid))
                        {
                            <a href="https://www.wikidata.org/wiki/@Person.WikidataQid" target="_blank" rel="noopener" class="vdd-qid-badge">
                                <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="font-size: 11px;" />
                                @Person.WikidataQid
                            </a>
                            @if (GetWikipediaUrl() is string personWikiUrl)
                            {
                                <a href="@personWikiUrl" target="_blank" rel="noopener" class="vdd-wiki-badge" title="Open Wikipedia article">
                                    <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 11px;" />
                                    Wikipedia
                                </a>
                            }
                        }
                    </div>
                    <h2 class="vdd-title">@Person.Name</h2>
                    @if (!string.IsNullOrEmpty(Person.Occupation))
                    {
                        <p class="vdd-subtitle-italic">@Person.Occupation</p>
                    }
                </div>
            </div>
        }
        else if (Universe is not null)
        {
            @* -- Universe Header -- *@
            <div class="vdd-header-content">
                <div class="vdd-universe-icon">
                    <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 48px; color: #A78BFA;" />
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        <StatusPill Status="LibraryStatus.Verified" />
                    </div>
                    <h2 class="vdd-title">@Universe.DisplayName</h2>
                    <p class="vdd-subtitle-italic">@Universe.Description</p>
                </div>
            </div>
        }
    </div>

    @* -- 2. Scrollable Body -- *@
    <div class="vdd-body">
        @if (MediaItem is not null)
        {
            @* -- NeedsReview problem banner -- *@
            @if (MediaItem.LibraryDisplayStatus == LibraryStatus.NeedsReview && !string.IsNullOrEmpty(MediaItem.ReviewTrigger))
            {
                <div class="vdd-problem-banner">
                    <div class="vdd-problem-banner-top">
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 18px; color: var(--tl-status-warning); flex-shrink: 0;" />
                        <span class="vdd-problem-banner-msg">@LibraryHelpers.GetReviewTriggerLabel(MediaItem.ReviewTrigger)</span>
                    </div>
                    <p class="vdd-problem-banner-hint">You can search for a match in the Pipeline section below, or check the Details section for clues.</p>
                </div>
            }

            @if (MediaItem.LibraryDisplayStatus == LibraryStatus.WaitingForProvider)
            {
                <div class="vdd-waiting-banner">
                    <MudIcon Icon="@Icons.Material.Outlined.Schedule" Style="font-size: 18px;" />
                    <span>
                        @if (!string.IsNullOrEmpty(MediaItem.FailedProviderName))
                        {
                            @L["VaultDetail_WaitingForProviderNamed", MediaItem.FailedProviderName]
                        }
                        else
                        {
                            @L["VaultDetail_WaitingForProvider"]
                        }
                    </span>
                </div>
            }

            var hasPipelineProblem = !IsRealRetailMatch(MediaItem.RetailMatch) || !IsWikidataMatched(MediaItem.WikidataQid);

            @* -- Details (file path + Current / Original metadata tabs) -- *@
            <DrawerSection @key="@($"details-{MediaItem.EntityId}")" Title="Details" Icon="@Icons.Material.Outlined.Description"
                           DefaultOpen="@(!hasPipelineProblem)">
                @{
                    var detailsFolder = MediaItem.FilePath;
                    if (!string.IsNullOrEmpty(MediaItem.FileName)
                        && !string.IsNullOrEmpty(detailsFolder)
                        && detailsFolder.EndsWith(MediaItem.FileName, StringComparison.OrdinalIgnoreCase))
                    {
                        detailsFolder = detailsFolder[..^MediaItem.FileName.Length].TrimEnd('/', '\\');
                    }
                }

                @* Pinned file path header *@
                <div class="vdd-details-path">
                    <div class="vdd-details-path-name">
                        <MudIcon Icon="@Icons.Material.Outlined.InsertDriveFile" Style="font-size: 14px; color: var(--tl-text-muted);" />
                        <span>@(MediaItem.FileName ?? " - ")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(detailsFolder))
                    {
                        <div class="vdd-details-path-folder" title="@detailsFolder">@detailsFolder</div>
                    }
                </div>

                @* Tab switcher *@
                <MudTabs ActivePanelIndex="@_detailsTab"
                         ActivePanelIndexChanged="OnDetailsTabChanged"
                     Rounded="false"
                         Border="false"
                         Elevation="0"
                         Class="vdd-details-tabs">
                    @foreach (var tab in DetailTabs)
                    {
                        <MudTabPanel Text="@tab.Label" />
                    }
                </MudTabs>

                @if (_detailsTab == 0)
                {
                    <div class="vdd-tab-content">
                        <div class="vdd-metadata-list">
                            @foreach (var (label, val) in GetCurrentMetadataRows())
                            {
                                <div class="vdd-claim-row">
                                    <span class="vdd-field-label">@label</span>
                                    <span class="vdd-field-value">@val</span>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(MediaItem?.CoverUrl))
                        {
                            <div class="vdd-file-cover">
                                <span class="vdd-field-label">Cover Art</span>
                                <img src="@MediaItem.CoverUrl" alt="Cover" class="vdd-file-cover-img" loading="lazy" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="vdd-tab-content">
                        <div class="vdd-metadata-list">
                            @if (_claimsLoading)
                            {
                                <div style="padding: 8px 0; text-align: center;">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: var(--tl-text-faint);" />
                                </div>
                            }
                            else
                            {
                                var fileClaims = _claims.Where(c => LibraryHelpers.IsFileSource(c.ProviderId) || LibraryHelpers.IsUserSource(c.ProviderId)).ToList();
                                @if (fileClaims.Count == 0)
                                {
                                    <p class="vdd-stage-hint">No file metadata extracted yet.</p>
                                }
                                else
                                {
                                    @foreach (var group in fileClaims.GroupBy(c => c.ClaimKey).OrderBy(g => g.Key))
                                    {
                                        var bestClaim = group.OrderByDescending(c => c.Confidence).First();
                                        <div class="vdd-claim-row">
                                            <span class="vdd-field-label">@FormatClaimKey(group.Key)</span>
                                            <span class="vdd-field-value">@bestClaim.ClaimValue</span>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>
                }
            </DrawerSection>

            @* -- Pipeline (circles + Retail/Wikidata tabs) -- *@
            <DrawerSection @key="@($"pipeline-{MediaItem.EntityId}")" Title="Pipeline" Icon="@Icons.Material.Outlined.AccountTree"
                           HasProblem="@hasPipelineProblem"
                           DefaultOpen="@hasPipelineProblem">

                @* Pipeline stage circles *@
                <div class="vdd-pipeline-circles-wrap">
                    <LibraryPipelineCircles
                        Stage1="@MediaItem.Stage1"
                        Stage2="@MediaItem.Stage2"
                        Stage3="@MediaItem.Stage3"
                        @bind-SelectedStage="_selectedStage" />
                </div>

                @* -- Tab content (selected via pipeline circles) -- *@
                @{
                    var hasRetail = IsRealRetailMatch(MediaItem?.RetailMatch) || IsRealRetailMatch(MediaItem?.RetailMatchDetail);
                    var hasWikidata = IsWikidataMatched(MediaItem?.WikidataQid);
                    var hasRetailForWiki = hasRetail;
                    var retailClaims = _claims.Where(c =>
                        !LibraryHelpers.IsFileSource(c.ProviderId) &&
                        !LibraryHelpers.IsUserSource(c.ProviderId) &&
                        !c.ProviderId.ToString().Contains("b3000003")).ToList();
                    var wikiClaims = _claims.Where(c =>
                        c.ProviderId.ToString().Contains("b3000003")).ToList();
                }
                @switch (ActiveTab)
                {
                    case 0:
                        @* -- RETAIL TAB -- *@
                        <div class="vdd-tab-content">
                            @* Always-visible filter-based search (at the top) *@
                            <div class="vdd-tab-search" style="margin-top: 0; padding-top: 0; border-top: none;">
                                <div class="vdd-search-bar-wrap" style="margin-top: 4px;">
                                    @* Media type row *@
                                    <div class="vdd-search-type-row">
                                        <span class="vdd-search-type-label">Type:</span>
                                        <MudSelect T="string"
                                                   Value="@_searchMediaType"
                                                   ValueChanged="SetRetailMediaType"
                                                   Variant="Variant.Outlined"
                                                   Dense="true"
                                                   Class="vdd-search-select">
                                            @foreach (var mt in new[] { "Books", "Audiobooks", "Movies", "TV", "Music", "Comics" })
                                            {
                                                <MudSelectItem T="string" Value="@mt">@mt</MudSelectItem>
                                            }
                                        </MudSelect>
                                        <span class="vdd-search-type-label">Quick Search:</span>
                                        <MudSelect T="string"
                                                   Value="@_canonicalTargetGroup"
                                                   ValueChanged="SetCanonicalTargetGroup"
                                                   Variant="Variant.Outlined"
                                                   Dense="true"
                                                   Class="vdd-search-select">
                                            @foreach (var target in GetCanonicalTargetOptions(_searchMediaType))
                                            {
                                                <MudSelectItem T="string" Value="@target.Key">@target.Label</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </div>

                                    @* Main search row *@
                                    <div class="vdd-search-main-row">
                                        <div class="vdd-search-input-group">
                                            <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 18px; color: var(--tl-text-muted);" />

                                            @* Primary field selector *@
                                            <MudSelect T="string"
                                                       Value="@_primarySearchField"
                                                       ValueChanged="SetPrimaryField"
                                                       Variant="Variant.Outlined"
                                                       Dense="true"
                                                       Class="vdd-primary-field-btn">
                                                @foreach (var f in GetSearchableFieldsForCurrentType())
                                                {
                                                    <MudSelectItem T="string" Value="@f.FieldKey">@f.DisplayLabel</MudSelectItem>
                                                }
                                            </MudSelect>

                                            <MudTextField T="string"
                                                          @bind-Value="_primarySearchValue"
                                                          Placeholder="@($"Search {FormatClaimKey(_primarySearchField).ToLower()}...")"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Immediate="true"
                                                          Class="vdd-search-primary-input"
                                                          OnKeyDown="OnRetailSearchKeyDown" />

                                            @* Add Filter button *@
                                            <MudMenu Variant="Variant.Outlined"
                                                     Color="Color.Inherit"
                                                     StartIcon="@Icons.Material.Outlined.Add"
                                                     Label="Add Filter"
                                                     Class="vdd-add-filter-btn">
                                                @foreach (var f in GetSearchableFieldsForCurrentType())
                                                {
                                                    if (f.FieldKey == _primarySearchField || _searchFilters.Any(sf => sf.FieldKey == f.FieldKey))
                                                    {
                                                        continue;
                                                    }

                                                    <MudMenuItem OnClick="() => AddSearchFilter(f.FieldKey)">@f.DisplayLabel</MudMenuItem>
                                                }
                                            </MudMenu>
                                        </div>

                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Class="vdd-search-execute-btn"
                                                   OnClick="RunRetailSearch"
                                                   Disabled="@(!HasAnySearchFieldValue())">
                                            Quick Search
                                        </MudButton>
                                    </div>

                                    @* Filter pills *@
                                    @if (_searchFilters.Count > 0)
                                    {
                                        <div class="vdd-filter-pills">
                                            @for (int i = 0; i < _searchFilters.Count; i++)
                                            {
                                                var idx = i;
                                                var filter = _searchFilters[idx];
                                                <div class="vdd-filter-pill">
                                                    <span class="vdd-filter-pill-label">@FormatClaimKey(filter.FieldKey):</span>
                                                    <MudTextField T="string"
                                                                  Value="@_searchFilters[idx].Value"
                                                                  ValueChanged="@(value => UpdateFilter(idx, value))"
                                                                  Placeholder="..."
                                                                  Variant="Variant.Text"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true"
                                                                  Class="vdd-filter-pill-input"
                                                                  OnKeyDown="OnRetailSearchKeyDown" />
                                                    <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                                                   Size="Size.Small"
                                                                   Class="vdd-filter-pill-remove"
                                                                   Color="Color.Inherit"
                                                                   OnClick="() => RemoveFilter(idx)" />
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>

                                @if (hasRetail && HasAnySearchFieldValue())
                                {
                                    <p class="vdd-rematch-warning">
                                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: var(--tl-status-warning);" />
                                        Quick Search lets you choose a new canonical provider-backed match for this field group.
                                    </p>
                                }
                            </div>

                            @* Search results with field comparison cards *@
                            @if (_searching)
                            {
                                <div style="padding: 8px 0; text-align: center;">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: var(--tl-text-faint);" />
                                </div>
                            }
                            else if (_hasSearched && _retailSearchResults.Count == 0)
                            {
                                <div class="vdd-canonical-empty-state">
                                    <p class="vdd-stage-hint">@(_canonicalSearchResponse?.NoResultMessage ?? "No provider-backed canonical candidates found.")</p>
                                    @if (_canonicalSearchResponse is not null)
                                    {
                                        <div class="vdd-fallback-actions">
                                            <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="vdd-cancel-match-btn" OnClick="KeepCurrentCanonicalValue">Keep current canonical value</MudButton>
                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="vdd-confirm-match-btn" OnClick="SaveCurrentDraftAsPreferenceAsync">Save as preference only</MudButton>
                                            @if (_canonicalSearchResponse.CanApplyUnlinkedCanonical)
                                            {
                                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="vdd-confirm-match-btn" OnClick="ApplyCurrentDraftAsUnlinkedCanonicalAsync">Apply as unlinked canonical value</MudButton>
                                            }
                                        </div>
                                        @if (_canonicalSearchResponse.MissingRequiredFields.Count > 0)
                                        {
                                            <p class="vdd-stage-hint">Missing required anchors: @string.Join(", ", _canonicalSearchResponse.MissingRequiredFields.Select(FormatClaimKey))</p>
                                        }
                                    }
                                </div>
                            }
                            else if (_retailSearchResults.Count > 0)
                            {
                                <div class="vdd-search-results" style="max-height: none;">
                                    @foreach (var result in _retailSearchResults)
                                    {
                                        var isExpanded = _pendingRetailMatch == result;
                                        var fieldComparisons = GetRetailFieldComparisons(result);
                                        var overallScore = result.Confidence;
                                        <div class="vdd-result-card @(isExpanded ? "vdd-result-card--expanded" : "")"
                                             @onclick="() => SelectRetailResult(result)">
                                            @* Header: cover + title + overall score *@
                                            <div class="vdd-result-header">
                                                <div class="vdd-result-cover">
                                                    @if (!string.IsNullOrEmpty(result.CoverUrl))
                                                    {
                                                        <img src="@result.CoverUrl" alt="" loading="lazy" />
                                                    }
                                                    else
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 24px; color: var(--tl-border-strong);" />
                                                    }
                                                </div>
                                                <div class="vdd-result-title-block">
                                                    <span class="vdd-result-card-title">@result.Title</span>
                                                    @{
                                                        var displayFields = GetRetailResultFields(result);
                                                    }
                                                    <span class="vdd-result-card-meta">@displayFields.Subline</span>
                                                    <span class="vdd-result-card-meta">@result.LinkStatusLabel</span>
                                                    @if (!result.IsApplicable && !string.IsNullOrWhiteSpace(result.BlockedReason))
                                                    {
                                                        <span class="vdd-result-card-meta" style="color: var(--tl-status-warning);">@result.BlockedReason</span>
                                                    }
                                                </div>
                                                <div class="vdd-result-score">
                                                    <span class="vdd-result-score-val" style="color: @GetScoreColor(overallScore);">@overallScore.ToString("F2")</span>
                                                    <div class="vdd-result-score-bar">
                                                        @for (int s = 0; s < 5; s++)
                                                        {
                                                            var filled = s < (int)Math.Round(overallScore * 5);
                                                            <div class="vdd-score-seg @(filled ? "vdd-score-seg--filled" : "")" style="@(filled ? $"background: {GetScoreColor(overallScore)};" : "")"></div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>

                                            @* Field comparison table (always visible) *@
                                            <div class="vdd-field-compare">
                                                <div class="vdd-compare-header-row">
                                                    <span class="vdd-compare-col-label">YOUR FILE</span>
                                                    <span class="vdd-compare-col-label" style="text-align: center;">&lt;-&gt;</span>
                                                    <span class="vdd-compare-col-label">PROVIDER MATCH</span>
                                                    <span class="vdd-compare-col-label" style="text-align: right;">SCORE</span>
                                                </div>
                                                @foreach (var comp in fieldComparisons)
                                                {
                                                    <div class="vdd-compare-row">
                                                        <div class="vdd-compare-cell vdd-compare-cell--yours">
                                                            <span class="vdd-compare-field-name">@comp.FieldLabel</span>
                                                            <span class="vdd-compare-field-val">@(string.IsNullOrEmpty(comp.YourValue) ? " - " : comp.YourValue)</span>
                                                        </div>
                                                        <span class="vdd-compare-arrow">&lt;-&gt;</span>
                                                        <div class="vdd-compare-cell vdd-compare-cell--theirs">
                                                            <span class="vdd-compare-field-val">@(string.IsNullOrEmpty(comp.ProviderValue) ? " - " : comp.ProviderValue)</span>
                                                        </div>
                                                        <div class="vdd-compare-cell vdd-compare-cell--score">
                                                            @if (comp.Score.HasValue)
                                                            {
                                                                <span style="color: @GetScoreColor(comp.Score.Value); font-weight: 700; font-size: 12px;">@comp.Score.Value.ToString("F2")</span>
                                                                <div class="vdd-score-mini-bar">
                                                                    <div class="vdd-score-mini-fill" style="width: @(comp.Score.Value * 100)%; background: @GetScoreColor(comp.Score.Value);"></div>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <span style="color: var(--tl-text-faint); font-size: 11px;"> - </span>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>

                                            @* Extra details: description + extra fields *@
                                            @if (!string.IsNullOrEmpty(result.Description) || (result.ExtraFields is { Count: > 0 }))
                                            {
                                                <div class="vdd-result-details">
                                                    @if (!string.IsNullOrEmpty(result.Description))
                                                    {
                                                        <div class="vdd-result-description">@result.Description</div>
                                                    }
                                                    @if (result.ExtraFields is { Count: > 0 })
                                                    {
                                                        <div class="vdd-result-extra-fields">
                                                            @foreach (var kv in result.ExtraFields.Where(kv => !string.IsNullOrEmpty(kv.Value)).Take(8))
                                                            {
                                                                <div class="vdd-extra-field-chip">
                                                                    <span class="vdd-extra-field-key">@FormatClaimKey(kv.Key)</span>
                                                                    <span class="vdd-extra-field-val">@kv.Value</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            @* Confirm button (only when expanded/selected) *@
                                            @if (isExpanded)
                                            {
                                                <div class="vdd-result-actions">
                                                    @if (result.RequiredFields.Count > 0)
                                                    {
                                                        <div class="vdd-result-details" @onclick:stopPropagation="true">
                                                            <span class="vdd-field-label">Required Fields</span>
                                                            <div class="vdd-result-extra-fields">
                                                                @foreach (var kv in result.RequiredFields)
                                                                {
                                                                    <div class="vdd-extra-field-chip">
                                                                        <span class="vdd-extra-field-key">@FormatClaimKey(kv.Key)</span>
                                                                        <span class="vdd-extra-field-val">@kv.Value</span>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (result.SuggestedFields.Count > 0)
                                                    {
                                                        <div class="vdd-result-details" @onclick:stopPropagation="true">
                                                            <span class="vdd-field-label">Optional Fields</span>
                                                            <div class="vdd-suggested-field-list">
                                                                @foreach (var kv in result.SuggestedFields)
                                                                {
                                                                    <MudCheckBox T="bool"
                                                                                 Value="@IsSuggestedFieldSelected(result.CandidateId, kv.Key)"
                                                                                 ValueChanged="@(value => SetSuggestedFieldSelected(result.CandidateId, kv.Key, value))"
                                                                                 Color="Color.Primary"
                                                                                 Dense="true"
                                                                                 Class="vdd-suggested-field-checkbox"
                                                                                 @onclick:stopPropagation="true">
                                                                        @FormatClaimKey(kv.Key): @kv.Value
                                                                    </MudCheckBox>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (!_confirmingRetailMatch)
                                                    {
                                                        <span @onclick:stopPropagation="true">
                                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="vdd-confirm-match-btn"
                                                                       OnClick="() => _confirmingRetailMatch = true"
                                                                       Disabled="@(!result.IsApplicable)">
                                                                Apply Canonical Choice
                                                            </MudButton>
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <div class="vdd-confirm-row" @onclick:stopPropagation="true">
                                                            @if (IsRealRetailMatch(MediaItem?.RetailMatch))
                                                            {
                                                                <span class="vdd-overwrite-warning">
                                                                    <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: var(--tl-status-warning);" />
                                                                    Replaces the current provider-backed canonical selection for this field group.
                                                                </span>
                                                            }
                                                            <span class="vdd-confirm-prompt">Apply this canonical provider result?</span>
                                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="vdd-confirm-match-btn" OnClick="() => ConfirmRetailMatch(result)">Yes</MudButton>
                                                            <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="vdd-cancel-match-btn" OnClick="() => _confirmingRetailMatch = false">Cancel</MudButton>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @* Existing match status (below search and results) *@
                            @if (hasRetail)
                            {
                                <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--tl-divider);">
                                    @{
                                        var retailDisplayName = GetRetailProviderDisplayName();
                                        var isManualMatch = MediaItem?.RetailMatch?.Equals("user_manual", StringComparison.OrdinalIgnoreCase) == true;
                                    }
                                    <div class="vdd-match-status vdd-match-status--ok">
                                        <span class="vdd-pipeline-dot vdd-pipeline-dot--ok"></span>
                                        <span>@(isManualMatch ? "Manually matched by user" : $"Matched automatically via {retailDisplayName}")</span>
                                    </div>
                                    @if (GetRetailProviderUrl() is { } retailUrl)
                                    {
                                        <a href="@retailUrl.Url" target="_blank" rel="noopener" class="vdd-provider-link">
                                            <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="font-size: 11px;" />
                                            @retailUrl.Label
                                        </a>
                                    }

                                    @* Show retail provider claims *@
                                    @if (retailClaims.Count > 0)
                                    {
                                        <div class="vdd-metadata-list" style="margin-top: 8px;">
                                            @foreach (var group in retailClaims.GroupBy(c => c.ClaimKey).OrderBy(g => g.Key))
                                            {
                                                var bestClaim = group.OrderByDescending(c => c.Confidence).First();
                                                <div class="vdd-claim-row">
                                                    <span class="vdd-field-label">@FormatClaimKey(group.Key)</span>
                                                    <span class="vdd-field-value">@bestClaim.ClaimValue</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        break;

                    case 1:
                        @* -- WIKIDATA TAB -- *@
                        <div class="vdd-tab-content">
                            @* Always-visible Wikidata search (at the top) *@
                            <div class="vdd-tab-search" style="margin-top: 0; padding-top: 0; border-top: none;">
                                <div class="vdd-search-bar-wrap" style="margin-top: 4px;">
                                    <div class="vdd-search-type-row">
                                        <span class="vdd-search-type-label">Type:</span>
                                        <MudSelect T="string"
                                                   Value="@_searchMediaType"
                                                   ValueChanged="SetWikiMediaType"
                                                   Variant="Variant.Outlined"
                                                   Dense="true"
                                                   Class="vdd-search-select">
                                            @foreach (var mt in new[] { "Books", "Audiobooks", "Movies", "TV", "Music", "Comics" })
                                            {
                                                <MudSelectItem T="string" Value="@mt">@mt</MudSelectItem>
                                            }
                                        </MudSelect>
                                        <span class="vdd-search-type-label">Quick Search:</span>
                                        <MudSelect T="string"
                                                   Value="@_canonicalTargetGroup"
                                                   ValueChanged="SetCanonicalTargetGroup"
                                                   Variant="Variant.Outlined"
                                                   Dense="true"
                                                   Class="vdd-search-select">
                                            @foreach (var target in GetCanonicalTargetOptions(_searchMediaType))
                                            {
                                                <MudSelectItem T="string" Value="@target.Key">@target.Label</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </div>
                                    <div class="vdd-search-main-row">
                                        <div class="vdd-search-input-group">
                                            <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 18px; color: var(--tl-text-muted);" />
                                            <MudTextField T="string"
                                                          @bind-Value="_wikidataSearchQuery"
                                                          Placeholder="@(hasWikidata ? "Search for a different canonical entity..." : "Search by name or enter a QID...")"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Immediate="true"
                                                          Class="vdd-search-primary-input"
                                                          OnKeyDown="OnWikidataSearchKeyDown" />
                                        </div>
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="vdd-search-execute-btn" OnClick="RunWikidataSearch"
                                                   Disabled="@(string.IsNullOrWhiteSpace(_wikidataSearchQuery))">
                                            Quick Search
                                        </MudButton>
                                    </div>
                                </div>
                                @if (hasWikidata && !string.IsNullOrWhiteSpace(_wikidataSearchQuery))
                                {
                                    <p class="vdd-rematch-warning">
                                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: var(--tl-status-warning);" />
                                        Quick Search lets you choose a new canonical linked entity for this field group.
                                    </p>
                                }
                            </div>

                            @* Search results with field comparison cards *@
                            @if (_searchingWikidata)
                            {
                                <div style="padding: 8px 0; text-align: center;">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: var(--tl-text-faint);" />
                                </div>
                            }
                            else if (_hasSearchedWikidata && _wikidataSearchResults.Count == 0)
                            {
                                <div class="vdd-canonical-empty-state">
                                    <p class="vdd-stage-hint">@(_canonicalSearchResponse?.NoResultMessage ?? $"No linked canonical results for \"{_wikidataSearchQuery}\".")</p>
                                    @if (_canonicalSearchResponse is not null)
                                    {
                                        <div class="vdd-fallback-actions">
                                            <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="vdd-cancel-match-btn" OnClick="KeepCurrentCanonicalValue">Keep current canonical value</MudButton>
                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="vdd-confirm-match-btn" OnClick="SaveCurrentDraftAsPreferenceAsync">Save as preference only</MudButton>
                                            @if (_canonicalSearchResponse.CanApplyUnlinkedCanonical)
                                            {
                                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="vdd-confirm-match-btn" OnClick="ApplyCurrentDraftAsUnlinkedCanonicalAsync">Apply as unlinked canonical value</MudButton>
                                            }
                                        </div>
                                        @if (_canonicalSearchResponse.MissingRequiredFields.Count > 0)
                                        {
                                            <p class="vdd-stage-hint">Missing required anchors: @string.Join(", ", _canonicalSearchResponse.MissingRequiredFields.Select(FormatClaimKey))</p>
                                        }
                                    }
                                </div>
                            }
                            else if (_wikidataSearchResults.Count > 0)
                            {
                                <div class="vdd-search-results" style="max-height: none;">
                                    @foreach (var result in _wikidataSearchResults)
                                    {
                                        var isExpanded = _pendingWikidataMatch == result;
                                        var wikiFieldComparisons = GetWikidataFieldComparisons(result);
                                        <div class="vdd-result-card @(isExpanded ? "vdd-result-card--expanded" : "")"
                                             @onclick="() => SelectWikidataResult(result)">
                                            @* Header: icon + label/QID *@
                                            <div class="vdd-result-header">
                                                <div class="vdd-result-cover" style="background: rgba(167,139,250,0.1); border-color: rgba(167,139,250,0.15);">
                                                    <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 24px; color: #A78BFA;" />
                                                </div>
                                                <div class="vdd-result-title-block">
                                                    <span class="vdd-result-card-title">@result.Label</span>
                                                    <div class="vdd-result-card-qid-row">
                                                        <a href="https://www.wikidata.org/wiki/@result.Qid" target="_blank" rel="noopener" class="vdd-result-qid-link" @onclick:stopPropagation="true">
                                                            <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="font-size: 10px;" />
                                                            @result.Qid
                                                        </a>
                                                        @if (!string.IsNullOrEmpty(result.InstanceOf))
                                                        {
                                                            <span class="vdd-result-instance-chip">@result.InstanceOf</span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(result.Year))
                                                        {
                                                            <span class="vdd-result-instance-chip">@result.Year</span>
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(result.Description))
                                                    {
                                                        <span class="vdd-result-card-meta" style="overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; white-space: normal;">@result.Description</span>
                                                    }
                                                    <span class="vdd-result-card-meta">@result.LinkStatusLabel</span>
                                                    @if (!result.IsApplicable && !string.IsNullOrWhiteSpace(result.BlockedReason))
                                                    {
                                                        <span class="vdd-result-card-meta" style="color: var(--tl-status-warning);">@result.BlockedReason</span>
                                                    }
                                                </div>
                                                <div class="vdd-result-score">
                                                    @{
                                                        var wikiScore = result.Confidence;
                                                    }
                                                    <span class="vdd-result-score-val" style="color: @GetScoreColor(wikiScore);">@wikiScore.ToString("F2")</span>
                                                    <div class="vdd-result-score-bar">
                                                        @for (int s = 0; s < 5; s++)
                                                        {
                                                            var filled = s < (int)Math.Round(wikiScore * 5);
                                                            <div class="vdd-score-seg @(filled ? "vdd-score-seg--filled" : "")" style="@(filled ? $"background: {GetScoreColor(wikiScore)};" : "")"></div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>

                                            @* Field comparison table *@
                                            @if (wikiFieldComparisons.Count > 0)
                                            {
                                                <div class="vdd-field-compare">
                                                    <div class="vdd-compare-header-row">
                                                        <span class="vdd-compare-col-label">YOUR FILE</span>
                                                        <span class="vdd-compare-col-label" style="text-align: center;">&lt;-&gt;</span>
                                                        <span class="vdd-compare-col-label">WIKIDATA</span>
                                                        <span class="vdd-compare-col-label" style="text-align: right;">SCORE</span>
                                                    </div>
                                                    @foreach (var comp in wikiFieldComparisons)
                                                    {
                                                        <div class="vdd-compare-row">
                                                            <div class="vdd-compare-cell vdd-compare-cell--yours">
                                                                <span class="vdd-compare-field-name">@comp.FieldLabel</span>
                                                                <span class="vdd-compare-field-val">@(string.IsNullOrEmpty(comp.YourValue) ? " - " : comp.YourValue)</span>
                                                            </div>
                                                            <span class="vdd-compare-arrow">&lt;-&gt;</span>
                                                            <div class="vdd-compare-cell vdd-compare-cell--theirs">
                                                                <span class="vdd-compare-field-val">@(string.IsNullOrEmpty(comp.ProviderValue) ? " - " : comp.ProviderValue)</span>
                                                            </div>
                                                            <div class="vdd-compare-cell vdd-compare-cell--score">
                                                                @if (comp.Score.HasValue)
                                                                {
                                                                    <span style="color: @GetScoreColor(comp.Score.Value); font-weight: 700; font-size: 12px;">@comp.Score.Value.ToString("F2")</span>
                                                                    <div class="vdd-score-mini-bar">
                                                                        <div class="vdd-score-mini-fill" style="width: @(comp.Score.Value * 100)%; background: @GetScoreColor(comp.Score.Value);"></div>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <span style="color: var(--tl-text-faint); font-size: 11px;"> - </span>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            @* Confirm button (only when expanded/selected) *@
                                            @if (isExpanded)
                                            {
                                                <div class="vdd-result-actions">
                                                    @if (result.RequiredFields.Count > 0)
                                                    {
                                                        <div class="vdd-result-details" @onclick:stopPropagation="true">
                                                            <span class="vdd-field-label">Required Fields</span>
                                                            <div class="vdd-result-extra-fields">
                                                                @foreach (var kv in result.RequiredFields)
                                                                {
                                                                    <div class="vdd-extra-field-chip">
                                                                        <span class="vdd-extra-field-key">@FormatClaimKey(kv.Key)</span>
                                                                        <span class="vdd-extra-field-val">@kv.Value</span>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (result.SuggestedFields.Count > 0)
                                                    {
                                                        <div class="vdd-result-details" @onclick:stopPropagation="true">
                                                            <span class="vdd-field-label">Optional Fields</span>
                                                            <div class="vdd-suggested-field-list">
                                                                @foreach (var kv in result.SuggestedFields)
                                                                {
                                                                    <MudCheckBox T="bool"
                                                                                 Value="@IsSuggestedFieldSelected(result.CandidateId, kv.Key)"
                                                                                 ValueChanged="@(value => SetSuggestedFieldSelected(result.CandidateId, kv.Key, value))"
                                                                                 Color="Color.Primary"
                                                                                 Dense="true"
                                                                                 Class="vdd-suggested-field-checkbox"
                                                                                 @onclick:stopPropagation="true">
                                                                        @FormatClaimKey(kv.Key): @kv.Value
                                                                    </MudCheckBox>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (!_confirmingWikidataMatch)
                                                    {
                                                        <span @onclick:stopPropagation="true">
                                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="vdd-confirm-match-btn"
                                                                       OnClick="() => _confirmingWikidataMatch = true"
                                                                       Disabled="@(!result.IsApplicable)">
                                                                Apply Canonical Choice
                                                            </MudButton>
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <div class="vdd-confirm-row" @onclick:stopPropagation="true">
                                                            @if (IsWikidataMatched(MediaItem?.WikidataQid))
                                                            {
                                                                <span class="vdd-overwrite-warning">
                                                                    <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: var(--tl-status-warning);" />
                                                                    Replaces the current linked canonical selection for this field group (@MediaItem?.WikidataQid).
                                                                </span>
                                                            }
                                                            <span class="vdd-confirm-prompt">Apply this linked canonical result?</span>
                                                            <span @onclick:stopPropagation="true">
                                                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="vdd-confirm-match-btn" OnClick="() => ConfirmWikidataMatch(result)">
                                                                    Yes
                                                                </MudButton>
                                                            </span>
                                                            <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="vdd-cancel-match-btn" OnClick="() => _confirmingWikidataMatch = false">
                                                                Cancel
                                                            </MudButton>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @* Existing QID status (below search and results) *@
                            @if (hasWikidata)
                            {
                                <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--tl-divider);">
                                    <div class="vdd-match-status vdd-match-status--ok">
                                        <span class="vdd-pipeline-dot vdd-pipeline-dot--ok"></span>
                                        <a href="https://www.wikidata.org/wiki/@MediaItem?.WikidataQid" target="_blank" rel="noopener" class="vdd-pipeline-qid-link">@MediaItem?.WikidataQid</a>
                                    </div>
                                    <p class="vdd-match-explanation">@GetWikidataExplanation()</p>

                                    @* Wikidata claims *@
                                    @if (wikiClaims.Count > 0)
                                    {
                                        <div class="vdd-metadata-list" style="margin-top: 8px;">
                                            @foreach (var group in wikiClaims.GroupBy(c => c.ClaimKey).OrderBy(g => g.Key))
                                            {
                                                var bestClaim = group.OrderByDescending(c => c.Confidence).First();
                                                <div class="vdd-claim-row">
                                                    <span class="vdd-field-label">@FormatClaimKey(group.Key)</span>
                                                    <span class="vdd-field-value">@bestClaim.ClaimValue</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="vdd-match-status vdd-match-status--fail" style="margin-top: 12px;">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--fail"></span>
                                    <span>No Wikidata identity assigned yet</span>
                                </div>
                            }
                        </div>
                        break;

                    case 2:
                        @* -- UNIVERSE TAB -- *@
                        <div class="vdd-tab-content">
                            @if (!string.IsNullOrEmpty(MediaItem?.UniverseName))
                            {
                                <div class="vdd-match-status vdd-match-status--ok">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--ok"></span>
                                    <span>Assigned to universe: @MediaItem.UniverseName</span>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(MediaItem?.WikidataQid) && !MediaItem.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="vdd-match-status vdd-match-status--warn">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--warn"></span>
                                    <span>Wikidata linked but universe assignment pending</span>
                                </div>
                                <p class="vdd-stage-hint">The Engine will automatically assign a universe once enrichment completes.</p>
                            }
                            else
                            {
                                <div class="vdd-match-status vdd-match-status--fail">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--fail"></span>
                                    <span>No universe assigned</span>
                                </div>
                                <p class="vdd-stage-hint">A Wikidata identity is needed before the Engine can determine universe membership.</p>
                            }
                        </div>
                        break;
                }
            </DrawerSection>

            <DrawerSection @key="@($"history-{MediaItem.EntityId}")" Title="History" Icon="@Icons.Material.Outlined.History" DefaultOpen="false">
                <LibraryTimeline EntityId="@MediaItem.EntityId" />
            </DrawerSection>

            <DrawerSection @key="@($"assets-{MediaItem.EntityId}")" Title="@L["VaultDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
                <div class="vdd-assets">
                    @* Cover Art *@
                    <div class="vdd-asset-row">
                        <span class="vdd-asset-label">@L["VaultDetail_AssetCoverArt"]</span>
                        <div class="vdd-asset-items">
                            @if (!string.IsNullOrEmpty(MediaItem.CoverUrl))
                            {
                                <div class="vdd-asset-filled">
                                    <img src="@MediaItem.CoverUrl" alt="Cover" class="vdd-asset-img" />
                                    <span class="vdd-asset-source">@L["VaultDetail_AssetSourceProvider"]</span>
                                </div>
                            }
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: var(--tl-border-strong);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetCustom"]</span>
                            </div>
                        </div>
                    </div>
                    @* Hero Banner *@
                    <div class="vdd-asset-row">
                        <span class="vdd-asset-label">@L["VaultDetail_AssetHeroBanner"]</span>
                        <div class="vdd-asset-items">
                            @if (!string.IsNullOrEmpty(MediaItem.HeroUrl))
                            {
                                <div class="vdd-asset-filled vdd-asset-filled--wide">
                                    <img src="@MediaItem.HeroUrl" alt="Hero" class="vdd-asset-img" />
                                    <span class="vdd-asset-source">@L["VaultDetail_AssetSourceGenerated"]</span>
                                </div>
                            }
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: var(--tl-border-strong);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetCustom"]</span>
                            </div>
                        </div>
                    </div>
                    @* Remaining types as upload-only *@
                    @foreach (var assetType in new[] { "Logo", "Background" })
                    {
                        <div class="vdd-asset-row">
                            <span class="vdd-asset-label">@assetType</span>
                            <div class="vdd-asset-items">
                                <div class="vdd-asset-slot">
                                    <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: var(--tl-border-strong);" />
                                    <span class="vdd-asset-upload">@L["VaultDetail_AssetUpload"]</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </DrawerSection>

        }
        else if (Person is not null)
        {
            @* -- Person: delegate to PersonBiographyDrawer -- *@
            <PersonBiographyDrawer Person="@Person"
                                   Aliases="@_aliases"
                                   PersonCredits="@_personCredits"
                                   PersonCharacterRoles="@_personCharacterRoles"
                                   GroupMembers="@_personDetail?.GroupMembers"
                                   MemberOfGroups="@_personDetail?.MemberOfGroups"
                                   OnPersonAliasClicked="@OnPersonAliasClicked" />

            @* Old person sections removed  -  all person content is now in PersonBiographyDrawer *@
        }
        else if (Universe is not null)
        {
            @* -- Universe Sections -- *@

            @* Health Score Ring *@
            @if (_universeHealth is not null)
            {
                <div class="vdd-health-ring-wrap">
                    @{
                        var hp = _universeHealth.HealthPercent;
                        var ringColor = hp >= 80 ? "var(--tl-status-success)" : hp >= 50 ? "var(--tl-accent-primary)" : "#EF4444";
                        var circumference = 2 * Math.PI * 22;
                        var dashOffset = circumference * (1 - hp / 100.0);
                    }
                    <div class="vdd-health-ring">
                        <svg width="64" height="64" viewBox="0 0 64 64">
                            <circle cx="32" cy="32" r="22" fill="none" stroke="var(--tl-border-subtle)" stroke-width="6" />
                            <circle cx="32" cy="32" r="22" fill="none"
                                    stroke="@ringColor" stroke-width="6"
                                    stroke-dasharray="@circumference.ToString("F1")"
                                    stroke-dashoffset="@dashOffset.ToString("F1")"
                                    stroke-linecap="round"
                                    transform="rotate(-90 32 32)" />
                        </svg>
                        <span class="vdd-health-pct" style="color: @ringColor;">@((int)hp)%</span>
                    </div>
                    <div class="vdd-health-label-block">
                        <span class="vdd-health-title">@L["VaultDetail_HealthScore"]</span>
                        <span class="vdd-health-sub">@_universeHealth.EntitiesEnriched / @_universeHealth.EntitiesTotal @L["VaultDetail_EntityCounts"]</span>
                    </div>
                </div>
            }

            @* Entity Counts *@
            @if (_universeHealth is not null && _universeHealth.EntitiesTotal > 0)
            {
                <DrawerSection Title="@L["VaultDetail_EntityCounts"]" Icon="@Icons.Material.Outlined.Category">
                    <div class="vdd-entity-counts">
                        <div class="vdd-entity-count-item">
                            <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 16px; color: #A78BFA;" />
                            <span class="vdd-entity-count-label">Characters</span>
                            <span class="vdd-entity-count-val">@_universeCharacters.Count</span>
                        </div>
                        <div class="vdd-entity-count-item">
                            <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Style="font-size: 16px; color: var(--tl-status-info);" />
                            <span class="vdd-entity-count-label">Locations</span>
                            <span class="vdd-entity-count-val">@(_universeHealth.EntitiesTotal - _universeCharacters.Count)</span>
                        </div>
                        <div class="vdd-entity-count-item">
                            <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Style="font-size: 16px; color: var(--tl-accent-primary);" />
                            <span class="vdd-entity-count-label">Relationships</span>
                            <span class="vdd-entity-count-val">@_universeHealth.RelationshipsTotal</span>
                        </div>
                    </div>
                </DrawerSection>
            }

            @* Characters *@
            <DrawerSection Title="@L["VaultDetail_SectionCharacters"]" Icon="@Icons.Material.Outlined.TheaterComedy">
                @if (_loadingUniverseData)
                {
                    <div style="padding: 12px 0; text-align: center;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: var(--tl-text-faint);" />
                    </div>
                }
                else if (_universeCharacters.Count == 0)
                {
                    <p class="vdd-empty-hint">@L["VaultDetail_HintNoCharacters"]</p>
                }
                else
                {
                    <div class="vdd-characters-grid">
                        @foreach (var ch in _universeCharacters.Take(12))
                        {
                            <div class="vdd-character-item">
                                <div class="vdd-character-avatar">
                                    @if (!string.IsNullOrEmpty(ch.PortraitUrl))
                                    {
                                        <img src="@ch.PortraitUrl" alt="@ch.CharacterName" loading="lazy" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 20px; color: var(--tl-border-strong);" />
                                    }
                                </div>
                                <div class="vdd-character-info">
                                    <span class="vdd-character-name">@ch.CharacterName</span>
                                    @if (!string.IsNullOrEmpty(ch.DefaultActorName))
                                    {
                                        <span class="vdd-character-actor">@ch.DefaultActorName</span>
                                    }
                                    @if (ch.ActorCount > 1)
                                    {
                                        <span class="vdd-actor-count-badge">@string.Format(L["VaultDetail_ActorsCount"].ToString(), ch.ActorCount)</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    @if (_universeCharacters.Count > 12)
                    {
                        <p class="vdd-stage-hint" style="margin-top: 8px;">+@(_universeCharacters.Count - 12) more  -  open Universe Explorer to see all</p>
                    }
                }
            </DrawerSection>

            @* Universe Content *@
            <DrawerSection Title="@L["VaultDetail_SectionUniverseContent"]" Icon="@Icons.Material.Outlined.Layers">
                <div class="vdd-universe-content">
                    @if (Universe.WorkCount > 0)
                    {
                        <p class="vdd-field-value">@Universe.WorkCount @L["VaultDetail_WorksAcross"] @(Universe.MediaTypes ?? L["VaultDetail_VariousMediaTypes"])</p>
                    }
                    else
                    {
                        <p class="vdd-empty-hint">@L["VaultDetail_HintNoSeriesLinked"]</p>
                    }
                </div>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionNotablePeople"]" Icon="@Icons.Material.Outlined.People">
                <p class="vdd-empty-hint">@L["VaultDetail_HintPeopleAssociated"]</p>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
                <div class="vdd-assets">
                    @foreach (var assetType in _assetTypes)
                    {
                        <div class="vdd-asset-row">
                            <span class="vdd-asset-label">@assetType</span>
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 20px; color: var(--tl-border-subtle);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetUpload"]</span>
                            </div>
                        </div>
                    }
                </div>
            </DrawerSection>

            @* -- History Timeline -- *@
            <DrawerSection Title="History" Icon="@Icons.Material.Outlined.History" DefaultOpen="false">
                <LibraryTimeline EntityId="@Universe.Id" />
            </DrawerSection>

            @* Trigger enrichment + open explorer actions *@
            <div class="vdd-universe-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="vdd-action-btn vdd-action-btn--primary" OnClick="OpenUniverseExplorer">
                    <MudIcon Icon="@Icons.Material.Outlined.Collections" Style="font-size: 15px;" />
                    @L["VaultDetail_OpenExplorer"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Class="vdd-action-btn" OnClick="TriggerEnrichment">
                    <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Style="font-size: 15px;" />
                    @L["VaultDetail_TriggerEnrichment"]
                </MudButton>
            </div>
        }
    </div>

    @* -- 3. Pinned Footer (Media only) -- *@
    @if (MediaItem is not null)
    {
        <div class="vdd-footer">
            @if (_confirmPurge)
            {
                <div class="vdd-purge-confirm-row">
                    <span class="vdd-purge-confirm-text">@L["VaultDetail_ConfirmPurge"]</span>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" Class="vdd-purge-btn vdd-purge-btn--confirm" OnClick="HandlePurge">
                        <span>Yes, Purge</span>
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="vdd-purge-cancel-btn" OnClick="() => _confirmPurge = false">
                        <span>Cancel</span>
                    </MudButton>
                </div>
            }
            else
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Class="vdd-purge-btn" OnClick="HandlePurge">
                    <MudIcon Icon="@Icons.Material.Outlined.DeleteForever" Style="font-size: 16px;" />
                    <span>@L["VaultDetail_ActionPurgeRecord"]</span>
                </MudButton>
            }
        </div>
    }
</div>

@code {
    [Parameter] public LibraryItemViewModel? MediaItem { get; set; }
    [Parameter] public PersonListItemDto? Person { get; set; }
    [Parameter] public CollectionViewModel? Universe { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Guid> OnPurge { get; set; }
    [Parameter] public EventCallback<Guid> OnApplyMatch { get; set; }
    [Parameter] public EventCallback<Guid> OnPersonAliasClicked { get; set; }
    [Parameter] public EventCallback<string> OnCreatorClicked { get; set; }

    private bool _confirmPurge;
    private int _selectedStage = 0;
    private int _detailsTab = 0;  // 0=Current Metadata, 1=Original Metadata
    private static readonly string[] _assetTypes = ["Cover Art", "Headshot", "Banner", "Logo", "Background"];
    private bool _searching;
    private bool _hasSearched;
    private List<LibraryCatalogItemViewModel> _searchResults = [];
    private PersonAliasesResponseDto? _aliases;
    private PersonDetailViewModel? _personDetail;
    private List<PersonLibraryCreditViewModel>? _personCredits;
    private LibraryCatalogItemViewModel? _pendingMatch;
    private string _selectedMediaType = "";
    private string _searchMediaType = "";
    private string _canonicalTargetGroup = "";
    private string _primarySearchField = "title";
    private string _primarySearchValue = "";
    private List<(string FieldKey, string Value)> _searchFilters = [];
    private List<RetailCandidateDto> _retailSearchResults = [];
    private RetailCandidateDto? _pendingRetailMatch;
    private bool _confirmingRetailMatch;
    private bool _searchingWikidata;
    private List<UniverseCandidateDto> _wikidataSearchResults = [];
    private UniverseCandidateDto? _pendingWikidataMatch;
    private bool _confirmingWikidataMatch;
    private string _wikidataSearchQuery = "";
    private bool _hasSearchedWikidata;
    private ItemCanonicalSearchResponseDto? _canonicalSearchResponse;
    private readonly Dictionary<string, HashSet<string>> _selectedSuggestedFieldKeys = new(StringComparer.OrdinalIgnoreCase);
    private List<ClaimHistoryDto> _claims = [];
    private bool _claimsLoading;

    private void OnSearchTypeChanged(ChangeEventArgs e)
    {
        _searchMediaType = e.Value?.ToString() ?? "";
        _retailSearchResults = [];
        _pendingRetailMatch = null;
        _primarySearchField = "title";
        _primarySearchValue = "";
        _searchFilters = [];
    }
    private UniverseHealthDto? _universeHealth;
    private IReadOnlyList<UniverseCharacterDto> _universeCharacters = [];
    private bool _loadingUniverseData;
    private IReadOnlyList<CharacterRoleDto> _personCharacterRoles = [];

    private bool IsInLibrary => MediaItem?.IsReadyForLibrary == true
                             && string.Equals(MediaItem?.LibraryVisibility, "visible", StringComparison.OrdinalIgnoreCase);

    private string GetReadinessChipClass()
    {
        if (MediaItem is null)
            return "vdd-location-chip--pending";

        return MediaItem.ReadinessLabel switch
        {
            "Ready" => "vdd-location-chip--library",
            "Needs review" => "vdd-location-chip--review",
            _ => "vdd-location-chip--pending",
        };
    }
    private static bool IsRealRetailMatch(string? retailMatch) =>
        retailMatch is not "none" and not "" and not null
        && !retailMatch.Equals("local_processor", StringComparison.OrdinalIgnoreCase)
        && !retailMatch.Equals("library_scanner", StringComparison.OrdinalIgnoreCase);
    private static bool IsWikidataMatched(string? qid) =>
        !string.IsNullOrEmpty(qid) && !qid.StartsWith("NF", StringComparison.OrdinalIgnoreCase);
    private string? GetWikipediaUrl()
    {
        if (_claims is not null && _claims.Count > 0)
        {
            var wikiClaim = _claims.FirstOrDefault(c =>
                c.ClaimKey.Equals("wikipedia_url", StringComparison.OrdinalIgnoreCase)
                && !string.IsNullOrEmpty(c.ClaimValue)
                && Uri.IsWellFormedUriString(c.ClaimValue, UriKind.Absolute));
            if (wikiClaim is not null) return wikiClaim.ClaimValue;
        }
        var qid = MediaItem?.WikidataQid ?? Person?.WikidataQid;
        if (!string.IsNullOrEmpty(qid) && !qid.StartsWith("NF", StringComparison.OrdinalIgnoreCase))
            return $"https://www.wikidata.org/wiki/Special:GoToLinkedPage/{qid}/enwiki";

        return null;
    }

    private int ActiveTab => _selectedStage;  // 0=Retail, 1=Wikidata, 2=Enrichment
    private IReadOnlyList<(string Id, string Label)> DetailTabs =>
    [
        ("0", "Current Metadata"),
        ("1", "Original Metadata")
    ];

    private int GetPreferredStage()
    {
        if (MediaItem is null)
            return 0;

        if (MediaItem.Stage1.State is LibraryStageState.Pending or LibraryStageState.Running or LibraryStageState.Warning or LibraryStageState.Failed)
            return 0;

        if (MediaItem.Stage2.State is LibraryStageState.Pending or LibraryStageState.Running or LibraryStageState.Warning or LibraryStageState.Failed)
            return 1;

        return 2;
    }

    private Task OnDetailsTabChanged(int index)
    {
        _detailsTab = index == 1 ? 1 : 0;
        return Task.CompletedTask;
    }

    private async Task NavigateToCreatorPerson(string creatorName)
    {
        await OnCreatorClicked.InvokeAsync(creatorName);
    }

    protected override async Task OnParametersSetAsync()
    {
        _confirmPurge = false;
        _selectedStage = GetPreferredStage();
        _detailsTab = 0;
        _searchResults = [];
        _aliases = null;
        _personDetail = null;
        _personCredits = null;
        _pendingMatch = null;
        _pendingRetailMatch = null;
        _searching = false;
        _hasSearched = false;
        _confirmingRetailMatch = false;
        _selectedMediaType = MediaItem?.MediaType ?? "";
        _searchMediaType = MediaItem?.MediaType ?? "";
        _primarySearchField = "title";
        _primarySearchValue = "";
        _searchFilters = [];
        _retailSearchResults = [];
        _searchingWikidata = false;
        _wikidataSearchResults = [];
        _pendingWikidataMatch = null;
        _confirmingWikidataMatch = false;
        _wikidataSearchQuery = "";
        _hasSearchedWikidata = false;
        _canonicalSearchResponse = null;
        _selectedSuggestedFieldKeys.Clear();
        _claims = [];
        _claimsLoading = false;
        _universeHealth = null;
        _universeCharacters = [];
        _personCharacterRoles = [];
        _canonicalTargetGroup = GetDefaultCanonicalTargetGroup(_searchMediaType);

        if (MediaItem is not null)
        {
            _claimsLoading = true;
            StateHasChanged();
            _claims = await ApiClient.GetClaimHistoryAsync(MediaItem.EntityId);
            _claimsLoading = false;
            _searchFilters = [];
            switch (MediaItem.MediaType)
            {
                case "Comics":
                    _primarySearchField = "series";
                    _primarySearchValue = MediaItem.Series ?? "";
                    if (!string.IsNullOrWhiteSpace(MediaItem.Title))
                        _searchFilters.Add(("title", MediaItem.Title));
                    if (!string.IsNullOrWhiteSpace(MediaItem.SeriesPosition))
                        _searchFilters.Add(("series_position", MediaItem.SeriesPosition));
                    if (!string.IsNullOrWhiteSpace(MediaItem.Author))
                        _searchFilters.Add(("author", MediaItem.Author));
                    break;

                case "TV":
                    _primarySearchField = "show_name";
                    _primarySearchValue = MediaItem.ShowName ?? MediaItem.Title ?? "";
                    if (!string.IsNullOrWhiteSpace(MediaItem.Season))
                        _searchFilters.Add(("season_number", MediaItem.Season));
                    if (!string.IsNullOrWhiteSpace(MediaItem.Episode))
                        _searchFilters.Add(("episode_number", MediaItem.Episode));
                    if (!string.IsNullOrWhiteSpace(MediaItem.Director))
                        _searchFilters.Add(("director", MediaItem.Director));
                    break;

                case "Music":
                    _primarySearchField = "artist";
                    _primarySearchValue = MediaItem.Artist ?? "";
                    if (!string.IsNullOrWhiteSpace(MediaItem.Album))
                        _searchFilters.Add(("album", MediaItem.Album));
                    if (!string.IsNullOrWhiteSpace(MediaItem.Title))
                        _searchFilters.Add(("title", MediaItem.Title));
                    if (!string.IsNullOrWhiteSpace(MediaItem.TrackNumber))
                        _searchFilters.Add(("track_number", MediaItem.TrackNumber));
                    break;

                default: // Books, Audiobooks, Movies
                    _primarySearchField = "title";
                    _primarySearchValue = MediaItem.Title ?? "";
                    var creatorField = MediaItem.MediaType switch
                    {
                        "Movies" => "director",
                        _ => "author",
                    };
                    var creatorValue = MediaItem.MediaType switch
                    {
                        "Movies" => MediaItem.Director,
                        _ => MediaItem.Author,
                    };
                    if (!string.IsNullOrWhiteSpace(creatorValue))
                        _searchFilters.Add((creatorField, creatorValue));
                    if (MediaItem.MediaType == "Audiobooks" && !string.IsNullOrWhiteSpace(MediaItem.Narrator))
                        _searchFilters.Add(("narrator", MediaItem.Narrator));
                    break;
            }
            if (!string.IsNullOrEmpty(MediaItem.Year) && !_searchFilters.Any(f => f.FieldKey == "year"))
                _searchFilters.Add(("year", MediaItem.Year));
            _wikidataSearchQuery = MediaItem.Title ?? "";
            _canonicalTargetGroup = GetDefaultCanonicalTargetGroup(MediaItem.MediaType);
        }
        else if (Person is not null)
        {
            var aliasTask = ApiClient.GetPersonAliasesAsync(Person.Id);
            var rolesTask = ApiClient.GetPersonCharacterRolesAsync(Person.Id);
            var detailTask = ApiClient.GetPersonDetailAsync(Person.Id);
            var creditsTask = ApiClient.GetPersonLibraryCreditsAsync(Person.Id);
            await Task.WhenAll(aliasTask, rolesTask, detailTask, creditsTask);
            _aliases = await aliasTask;
            _personCharacterRoles = await rolesTask;
            _personDetail = await detailTask;
            _personCredits = await creditsTask;
        }
        else if (Universe is not null && !string.IsNullOrWhiteSpace(Universe.FictionalUniverseQid))
        {
            _loadingUniverseData = true;
            StateHasChanged();

            var healthTask     = ApiClient.GetUniverseHealthAsync(Universe.FictionalUniverseQid);
            var charactersTask = ApiClient.GetUniverseCharactersAsync(Universe.FictionalUniverseQid);
            await Task.WhenAll(healthTask, charactersTask);
            _universeHealth     = await healthTask;
            _universeCharacters = await charactersTask;
            _loadingUniverseData = false;
        }
    }

    private void OpenUniverseExplorer()
    {
        if (Universe?.FictionalUniverseQid is { } qid)
            Nav.NavigateTo($"/universe/{qid}/explore");
    }

    private async Task TriggerEnrichment()
    {
        await ApiClient.TriggerUniverseEnrichmentAsync();
    }

    private async Task RunRetailSearch()
    {
        var hasQuery = !string.IsNullOrWhiteSpace(_primarySearchValue)
                       || _searchFilters.Any(f => !string.IsNullOrWhiteSpace(f.Value));
        if (!hasQuery || string.IsNullOrWhiteSpace(_searchMediaType) || string.IsNullOrWhiteSpace(_canonicalTargetGroup) || MediaItem is null)
            return;

        _searching = true;
        _retailSearchResults = [];
        _wikidataSearchResults = [];
        _pendingRetailMatch = null;
        _confirmingRetailMatch = false;
        _canonicalSearchResponse = null;
        _selectedSuggestedFieldKeys.Clear();
        StateHasChanged();

            var response = await ApiClient.SearchItemCanonicalAsync(
            MediaItem.EntityId,
            BuildCanonicalSearchRequest(queryOverride: null));
        if (response is not null)
        {
            _canonicalSearchResponse = response;
            _retailSearchResults = response.RetailCandidates.ToList();
            _wikidataSearchResults = response.LinkedCandidates.ToList();
        }

        _searching = false;
        _hasSearched = true;
    }

    private async Task RunWikidataSearch()
    {
        if (string.IsNullOrWhiteSpace(_wikidataSearchQuery) || string.IsNullOrWhiteSpace(_canonicalTargetGroup) || MediaItem is null)
            return;
        var trimmed = _wikidataSearchQuery.Trim();
        if (trimmed.StartsWith("Q", StringComparison.OrdinalIgnoreCase) && trimmed.Length > 1 && trimmed[1..].All(char.IsDigit))
        {
            var directQid = trimmed.ToUpperInvariant();
            _wikidataSearchResults =
            [
                new UniverseCandidateDto
                {
                    CandidateId = $"wikidata:{directQid}",
                    Qid = directQid,
                    Label = directQid,
                    LinkState = "linked",
                    LinkStatusLabel = "Linked to Wikidata",
                    IsApplicable = true,
                    RequiredFields = [],
                    SuggestedFields = [],
                    QidFields = BuildDirectQidFields(directQid),
                    Description = "Direct QID entry  -  confirm to link this item",
                }
            ];
            _canonicalSearchResponse = new ItemCanonicalSearchResponseDto
            {
                EntityId = MediaItem.EntityId,
                MediaType = _searchMediaType,
                TargetKind = GetCanonicalTargetKind(_searchMediaType, _canonicalTargetGroup),
                TargetFieldGroup = _canonicalTargetGroup,
                Query = directQid,
                LinkedCandidates = _wikidataSearchResults.ToList(),
                DraftFields = BuildCanonicalDraftFields(),
                FallbackActions = ["Keep current canonical value", "Save as preference only", "Apply as unlinked canonical value"],
            };
            _searchingWikidata = false;
            _hasSearchedWikidata = true;
            return;
        }

        _searchingWikidata = true;
        _retailSearchResults = [];
        _wikidataSearchResults = [];
        _pendingWikidataMatch = null;
        _confirmingWikidataMatch = false;
        _canonicalSearchResponse = null;
        _selectedSuggestedFieldKeys.Clear();
        StateHasChanged();

            var response = await ApiClient.SearchItemCanonicalAsync(
            MediaItem.EntityId,
            BuildCanonicalSearchRequest(_wikidataSearchQuery.Trim()));
        if (response is not null)
        {
            _canonicalSearchResponse = response;
            _retailSearchResults = response.RetailCandidates.ToList();
            _wikidataSearchResults = response.LinkedCandidates.ToList();
        }

        _searchingWikidata = false;
        _hasSearchedWikidata = true;
    }
    private List<(string Label, string Value)> GetCurrentMetadataRows()
    {
        var rows = new List<(string, string)>();
        if (MediaItem is null) return rows;

        if (!string.IsNullOrEmpty(MediaItem.Title)) rows.Add(("Title", MediaItem.Title));
        if (!string.IsNullOrEmpty(MediaItem.OriginalTitle) && MediaItem.OriginalTitle != MediaItem.Title)
            rows.Add(("Original Title", MediaItem.OriginalTitle));
        if (!string.IsNullOrEmpty(MediaItem.Author)) rows.Add(("Author", MediaItem.Author));
        if (!string.IsNullOrEmpty(MediaItem.Director)) rows.Add(("Director", MediaItem.Director));
        if (!string.IsNullOrEmpty(MediaItem.Artist)) rows.Add(("Artist", MediaItem.Artist));
        if (!string.IsNullOrEmpty(MediaItem.Narrator)) rows.Add(("Narrator", MediaItem.Narrator));
        if (!string.IsNullOrEmpty(MediaItem.Year)) rows.Add(("Year", MediaItem.Year));
        rows.Add(("Media Type", MediaItem.MediaType));
        if (!string.IsNullOrEmpty(MediaItem.Genre)) rows.Add(("Genre", MediaItem.Genre));
        if (!string.IsNullOrEmpty(MediaItem.Series))
            rows.Add(("Series", MediaItem.Series + (!string.IsNullOrEmpty(MediaItem.SeriesPosition) ? $" #{MediaItem.SeriesPosition}" : "")));
        if (!string.IsNullOrEmpty(MediaItem.UniverseName)) rows.Add(("Universe", MediaItem.UniverseName));
        if (MediaItem.MediaType == "Music")
        {
            if (!string.IsNullOrEmpty(MediaItem.Album)) rows.Add(("Album", MediaItem.Album));
            if (!string.IsNullOrEmpty(MediaItem.TrackNumber))
            {
                var trackDisplay = MediaItem.TrackNumber;
                if (!string.IsNullOrEmpty(MediaItem.TrackCount))
                    trackDisplay += $" of {MediaItem.TrackCount}";
                rows.Add(("Track", trackDisplay));
            }
            if (!string.IsNullOrEmpty(MediaItem.DiscNumber)) rows.Add(("Disc", MediaItem.DiscNumber));
            if (!string.IsNullOrEmpty(MediaItem.Duration)) rows.Add(("Duration", FormatDuration(MediaItem.Duration)));
        }
        if (MediaItem.MediaType == "TV")
        {
            if (!string.IsNullOrEmpty(MediaItem.ShowName)) rows.Add(("Show", MediaItem.ShowName));
            if (!string.IsNullOrEmpty(MediaItem.Season)) rows.Add(("Season", MediaItem.Season));
            if (!string.IsNullOrEmpty(MediaItem.Episode)) rows.Add(("Episode", MediaItem.Episode));
            if (!string.IsNullOrEmpty(MediaItem.EpisodeTitle)) rows.Add(("Episode Title", MediaItem.EpisodeTitle));
            if (!string.IsNullOrEmpty(MediaItem.Network)) rows.Add(("Network", MediaItem.Network));
            if (!string.IsNullOrEmpty(MediaItem.Duration)) rows.Add(("Runtime", FormatDuration(MediaItem.Duration)));
            if (!string.IsNullOrEmpty(MediaItem.TopCast)) rows.Add(("Top Cast", MediaItem.TopCast));
        }
        if (MediaItem.MediaType == "Audiobooks" && !string.IsNullOrEmpty(MediaItem.Duration))
            rows.Add(("Duration", FormatDuration(MediaItem.Duration)));

        if (!string.IsNullOrEmpty(MediaItem.FileName)) rows.Add(("File", MediaItem.FileName));
        if (MediaItem.FileSizeBytes.HasValue && MediaItem.FileSizeBytes.Value > 0)
            rows.Add(("Size", LibraryHelpers.FormatFileSize(MediaItem.FileSizeBytes)));

        return rows;
    }
    private string GetRetailProviderDisplayName()
    {
        if (MediaItem is null) return "a retail provider";
        var match = !string.IsNullOrEmpty(MediaItem.RetailMatchDetail) ? MediaItem.RetailMatchDetail : MediaItem.RetailMatch;
        return LibraryHelpers.FormatSourceName(match ?? "");
    }
    private string GetWikidataExplanation()
    {
        if (MediaItem is null) return "";
        var qid = MediaItem.WikidataQid;
        if (string.IsNullOrEmpty(qid)) return "";
        return $"Matched to {qid} on Wikidata. Canonical data (title, author, year, genre) is sourced from Wikidata.";
    }
    private sealed record RetailResultDisplay(
        string? Subline,
        string? Tertiary,
        List<(string Label, string Value)> Details,
        List<(string Label, string Value)> BridgeIds);
    private RetailResultDisplay GetRetailResultFields(RetailCandidateDto result)
    {
        if (!Enum.TryParse<MediaType>(_searchMediaType, true, out var mediaType))
            mediaType = MediaType.Books;

        var config = MediaTypeFieldCatalog.GetSearchDisplay(mediaType);
        var allFields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrEmpty(result.Title)) allFields["title"] = result.Title;
        if (!string.IsNullOrEmpty(result.Author))
        {
            allFields["author"] = result.Author;
            allFields.TryAdd("artist", result.Author);
        }
        if (!string.IsNullOrEmpty(result.Director)) allFields["director"] = result.Director;
        if (!string.IsNullOrEmpty(result.Year)) allFields["year"] = result.Year;
        if (!string.IsNullOrEmpty(result.Description)) allFields["description"] = result.Description;
        if (!string.IsNullOrEmpty(result.ProviderItemId)) allFields["provider_item_id"] = result.ProviderItemId;
        foreach (var (k, v) in result.ExtraFields)
        {
            if (!string.IsNullOrWhiteSpace(v))
                allFields.TryAdd(k, v);
        }
        string? subline = allFields.GetValueOrDefault(config.Subline);
        string? tertiary = allFields.GetValueOrDefault(config.Tertiary);
        var details = new List<(string, string)>();
        foreach (var fieldKey in config.DetailFields)
        {
            if (fieldKey == config.Subline || fieldKey == config.Tertiary) continue;
            if (allFields.TryGetValue(fieldKey, out var val) && !string.IsNullOrWhiteSpace(val))
                details.Add((FormatClaimKey(fieldKey), val.Length > 80 ? val[..77] + "\u2026" : val));
        }
        var bridges = new List<(string, string)>();
        foreach (var bridgeKey in config.BridgeLabels)
        {
            if (allFields.TryGetValue(bridgeKey, out var val) && !string.IsNullOrWhiteSpace(val))
                bridges.Add((FormatClaimKey(bridgeKey), val));
        }

        return new RetailResultDisplay(subline, tertiary, details, bridges);
    }

