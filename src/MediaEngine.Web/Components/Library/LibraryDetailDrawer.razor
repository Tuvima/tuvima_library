    private void EnsureSuggestedFieldSelection(string candidateId, IEnumerable<string> suggestedKeys)
    {
        if (!_selectedSuggestedFieldKeys.TryGetValue(candidateId, out var selected))
        {
            _selectedSuggestedFieldKeys[candidateId] = new HashSet<string>(suggestedKeys, StringComparer.OrdinalIgnoreCase);
            return;
        }

        foreach (var key in suggestedKeys)
            selected.Add(key);
    }

    private bool IsSuggestedFieldSelected(string candidateId, string fieldKey) =>
        _selectedSuggestedFieldKeys.TryGetValue(candidateId, out var selected) && selected.Contains(fieldKey);

    private void SetSuggestedFieldSelected(string candidateId, string fieldKey, bool isSelected)
    {
        if (!_selectedSuggestedFieldKeys.TryGetValue(candidateId, out var selected))
        {
            selected = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            _selectedSuggestedFieldKeys[candidateId] = selected;
        }

        if (isSelected)
            selected.Add(fieldKey);
        else
            selected.Remove(fieldKey);
    }

    private List<string> GetAcceptedSuggestedKeys(string candidateId, IEnumerable<string> suggestedKeys)
    {
        EnsureSuggestedFieldSelection(candidateId, suggestedKeys);
        return _selectedSuggestedFieldKeys.TryGetValue(candidateId, out var selected)
            ? selected.ToList()
            : [];
    }

