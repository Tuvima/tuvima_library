        color: var(--tl-text-primary);
        outline: none;
        transition: border-color 0.15s;
    }

    .vdd-search-input:focus {
        border-color: var(--tl-status-info-border);
    }

    .vdd-search-input::placeholder {
        color: var(--tl-text-faint);
    }

    .vdd-search-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        border-radius: 8px;
        background: var(--tl-status-info-border);
        border: 1px solid var(--tl-status-info-border);
        color: var(--tl-status-info);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .vdd-search-btn:hover:not(:disabled) {
        background: var(--tl-status-info-border);
