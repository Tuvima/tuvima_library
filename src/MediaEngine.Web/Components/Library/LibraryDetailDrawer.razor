    private static string FormatClaimKey(string key) => LibraryHelpers.FormatClaimKey(key);

    private static string FormatDuration(string? duration)
    {
        if (string.IsNullOrEmpty(duration)) return "";
        if (long.TryParse(duration, out var ms))
        {
            var ts = TimeSpan.FromMilliseconds(ms);
            return ts.TotalHours >= 1
                ? $"{(int)ts.TotalHours}h {ts.Minutes:D2}m"
                : $"{ts.Minutes}m {ts.Seconds:D2}s";
        }
        return duration; // Return as-is if not numeric
    }

    private ItemCanonicalSearchRequestDto BuildCanonicalSearchRequest(string? queryOverride)
    {
        return new ItemCanonicalSearchRequestDto
        {
            MediaType = _searchMediaType,
            TargetKind = GetCanonicalTargetKind(_searchMediaType, _canonicalTargetGroup),
            TargetFieldGroup = _canonicalTargetGroup,
            DraftFields = BuildCanonicalDraftFields(),
            QueryOverride = queryOverride,
            MaxCandidates = 8,
        };
    }

    private Dictionary<string, string> BuildCanonicalDraftFields()
    {
        var fields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        static void Add(IDictionary<string, string> target, string key, string? value)
        {
            if (!string.IsNullOrWhiteSpace(key) && !string.IsNullOrWhiteSpace(value))
                target[key] = value.Trim();
        }

        if (MediaItem is not null)
        {
            Add(fields, "title", MediaItem.Title);
            Add(fields, "original_title", MediaItem.OriginalTitle);
            Add(fields, "author", MediaItem.Author);
            Add(fields, "director", MediaItem.Director);
            Add(fields, "artist", MediaItem.Artist);
            Add(fields, "narrator", MediaItem.Narrator);
            Add(fields, "year", MediaItem.Year);
            Add(fields, "series", MediaItem.Series);
            Add(fields, "series_position", MediaItem.SeriesPosition);
            Add(fields, "album", MediaItem.Album);
            Add(fields, "track_number", MediaItem.TrackNumber);
            Add(fields, "disc_number", MediaItem.DiscNumber);
            Add(fields, "show_name", MediaItem.ShowName);
            Add(fields, "season_number", MediaItem.Season);
            Add(fields, "episode_number", MediaItem.Episode);
            Add(fields, "episode_title", MediaItem.EpisodeTitle);
            Add(fields, "genre", MediaItem.Genre);
            Add(fields, "duration", MediaItem.Duration);
            Add(fields, "network", MediaItem.Network);
        }

        Add(fields, _primarySearchField, _primarySearchValue);
        foreach (var (key, value) in _searchFilters)
            Add(fields, key, value);

        return fields;
    }

    private Dictionary<string, string> BuildCurrentStrongDraftFields()
    {
        var draftFields = BuildCanonicalDraftFields();
        var keys = _canonicalTargetGroup switch
        {
            "album" => new[] { "artist", "album" },
            "artist" => new[] { "artist" },
            "narrator" => new[] { "narrator" },
            "series" => new[] { "series", "series_position" },
            "show" => new[] { "show_name" },
            "show_episode" => new[] { "show_name", "season_number", "episode_number", "episode_title" },
            "movie_identity" => new[] { "title", "year", "director" },
            "book_identity" => new[] { "title", "author", "series", "series_position" },
            "audiobook_identity" => new[] { "title", "author", "narrator", "series", "series_position" },
            "issue" => new[] { "series", "series_position", "title" },
            _ => Array.Empty<string>(),
        };

        return keys
            .Where(draftFields.ContainsKey)
            .ToDictionary(key => key, key => draftFields[key], StringComparer.OrdinalIgnoreCase);
    }

