    private record FieldComparison(string FieldLabel, string? YourValue, string? ProviderValue, double? Score);

    private List<FieldComparison> GetRetailFieldComparisons(RetailCandidateDto result)
    {
        var comparisons = new List<FieldComparison>();

        foreach (var (key, value) in result.RequiredFields.Concat(result.SuggestedFields).Take(8))
        {
            var current = GetCurrentFieldValue(key);
            comparisons.Add(new(FormatClaimKey(key), current, value, ComputeFieldScore(current, value)));
        }

        if (comparisons.Count == 0)
            comparisons.Add(new("Title", MediaItem?.Title, result.Title, ComputeFieldScore(MediaItem?.Title, result.Title)));

        return comparisons;
    }

    private List<FieldComparison> GetWikidataFieldComparisons(UniverseCandidateDto result)
    {
        var comparisons = new List<FieldComparison>();

        foreach (var (key, value) in result.RequiredFields.Concat(result.SuggestedFields).Take(8))
        {
            var current = GetCurrentFieldValue(key);
            comparisons.Add(new(FormatClaimKey(key), current, value, ComputeFieldScore(current, value)));
        }

        if (comparisons.Count == 0)
        {
            comparisons.Add(new("Title", MediaItem?.Title, result.Label, ComputeFieldScore(MediaItem?.Title, result.Label)));
            if (!string.IsNullOrEmpty(result.InstanceOf))
                comparisons.Add(new("Type", MediaItem?.MediaType, result.InstanceOf, null));
        }

        return comparisons;
    }

