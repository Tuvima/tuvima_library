                fields["album_qid"] = qid;
                break;
            case "artist":
                fields["artist_qid"] = qid;
                break;
            case "narrator":
                fields["narrator_qid"] = qid;
                break;
            case "series":
            case "show":
                fields["series_qid"] = qid;
                break;
            default:
