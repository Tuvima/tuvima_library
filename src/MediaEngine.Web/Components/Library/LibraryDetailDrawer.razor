    .vdd-confirm-match-btn {
        padding: 4px 12px;
        border-radius: 6px;
        background: var(--tl-status-success-soft);
        border: 1px solid rgba(93, 202, 165, 0.3);
        color: var(--tl-status-success);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
