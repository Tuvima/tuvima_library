        background: var(--tl-border-subtle);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--tl-text-muted);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.15s;
    }

