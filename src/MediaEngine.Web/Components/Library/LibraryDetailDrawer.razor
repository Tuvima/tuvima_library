        _ => null,
    };

    private static double? ComputeFieldScore(string? a, string? b)
    {
        if (string.IsNullOrWhiteSpace(a) || string.IsNullOrWhiteSpace(b)) return null;
        if (string.Equals(a.Trim(), b.Trim(), StringComparison.OrdinalIgnoreCase)) return 1.0;

        var aLower = a.Trim().ToLowerInvariant();
        var bLower = b.Trim().ToLowerInvariant();

        if (aLower.Contains(bLower) || bLower.Contains(aLower))
            return 0.85;

        var maxLen = Math.Max(aLower.Length, bLower.Length);
        if (maxLen == 0) return 1.0;
        var distance = LevenshteinDistance(aLower, bLower);
        return Math.Max(0, 1.0 - (double)distance / maxLen);
    }

    private static int LevenshteinDistance(string s, string t)
    {
        var n = s.Length;
        var m = t.Length;
        var d = new int[n + 1, m + 1];
        for (int i = 0; i <= n; i++) d[i, 0] = i;
        for (int j = 0; j <= m; j++) d[0, j] = j;
        for (int i = 1; i <= n; i++)
            for (int j = 1; j <= m; j++)
                d[i, j] = Math.Min(Math.Min(d[i - 1, j] + 1, d[i, j - 1] + 1),
                    d[i - 1, j - 1] + (s[i - 1] == t[j - 1] ? 0 : 1));
        return d[n, m];
    }

    private static string GetScoreColor(double score) =>
        score >= 0.85 ? "var(--tl-status-success)" : score >= 0.60 ? "var(--tl-status-warning)" : "var(--tl-status-danger)";
    private (string Label, string Url)? GetRetailProviderUrl()
    {
        if (MediaItem is null || _claims.Count == 0) return null;
        string[] bridgeKeys = (MediaItem.MediaType ?? "").ToLowerInvariant() switch
        {
            var t when t.Contains("movie") || t.Contains("video") => ["tmdb_id", "imdb_id"],
            "tv" => ["tmdb_id", "imdb_id"],
            var t when t.Contains("book") || t.Contains("epub") => ["open_library_id", "apple_books_id"],
            var t when t.Contains("audiobook") => ["apple_books_id", "open_library_id"],
            var t when t.Contains("music") => ["musicbrainz_id"],
            _ => ["tmdb_id", "open_library_id", "musicbrainz_id"],
        };

        foreach (var key in bridgeKeys)
        {
            var claim = _claims.FirstOrDefault(c =>
                c.ClaimKey.Equals(key, StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(c.ClaimValue));
            if (claim is not null)
            {
                var result = LibraryHelpers.BuildProviderUrl(key, claim.ClaimValue, MediaItem.MediaType);
                if (result is not null) return result;
            }
        }

        return null;
    }

