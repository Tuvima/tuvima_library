@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs

@if (TotalCount > 0)
{
    <section class="vac @(HasQuarantined ? "vac--severe" : "vac--warn")">
        <div class="vac-summary">
            <div class="vac-summary-left">
                <div class="vac-icon @(HasQuarantined ? "vac-icon--severe" : "vac-icon--warn")">
                    <MudIcon Icon="@Icons.Material.Outlined.ReportProblem" Size="Size.Small" />
                </div>
                <span class="vac-label">
                    @TotalCount @(TotalCount == 1 ? "Item Requires" : "Items Require") Review
                </span>
            </div>
            <MudButton Variant="Variant.Text"
                       Color="Color.Inherit"
                       Class="@($"vac-toggle {(HasQuarantined ? "vac-toggle--severe" : "vac-toggle--warn")}")"
                       EndIcon="@(IsExpanded ? Icons.Material.Outlined.ExpandLess : Icons.Material.Outlined.ExpandMore)"
                       OnClick="ToggleExpanded">
                @(IsExpanded ? "HIDE" : "REVIEW ITEMS")
            </MudButton>
        </div>

        @if (IsExpanded && ConflictItems is { Count: > 0 })
        {
            var groups = GroupByContainer(ConflictItems);
            <div class="vac-list">
                <div class="vac-list-inner">
                    @foreach (var group in groups)
                    {
                        var first = group.Items[0];
                        var isQuarantined = first.LibraryDisplayStatus == LibraryStatus.Quarantined;
                        var isContainer = group.Items.Count > 1;
                        var displayTitle = isContainer ? group.Label : first.Title;
                        var issueLabel = isContainer
                            ? $"{group.Items.Count} items need review"
                            : LibraryHelpers.GetReviewTriggerLabel(first.ReviewTrigger);
                        var isChecked = group.Items.All(i => _selectedIds.Contains(i.EntityId));
                        <div class="vac-row @(isChecked ? "vac-row--selected" : "")">
                            <div class="vac-row-left">
                                <MudCheckBox T="bool"
                                             Value="@isChecked"
                                             ValueChanged="@(value => ToggleGroupSelection(group))"
                                             Color="Color.Primary"
                                             Dense="true"
                                             Class="vac-checkbox"
                                             @onclick:stopPropagation="true" />
                                <div class="vac-severity-dot @(isQuarantined ? "vac-dot--severe" : "vac-dot--warn")" />
                                <div class="vac-row-info">
                                    <span class="vac-row-title">@displayTitle</span>
                                    <span class="vac-row-issue">@issueLabel</span>
                                </div>
                            </div>
                            <div class="vac-row-right">
                                <span class="vac-status-badge @(isQuarantined ? "vac-badge--quarantine" : "vac-badge--warning")">
                                    @(isQuarantined ? "QUARANTINED" : (isContainer ? $"{group.Items.Count} ITEMS" : "NEEDS REVIEW"))
                                </span>
                                <span @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                                   Size="Size.Small"
                                                   aria-label="Edit"
                                                   Color="Color.Inherit"
                                                   Class="vac-action-btn"
                                                   OnClick="() => OnItemEditClicked.InvokeAsync(first.EntityId)" />
                                </span>
                                <span @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                                   Size="Size.Small"
                                                   aria-label="Delete"
                                                   Color="Color.Error"
                                                   Class="vac-action-btn vac-action-btn--danger"
                                                   OnClick="() => DeleteGroup(group)" />
                                </span>
                            </div>
                        </div>
                    }
                </div>

                @if (_selectedIds.Count > 0)
                {
                    <div class="vac-bulk-bar">
                        <span class="vac-bulk-count">@_selectedIds.Count selected</span>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Outlined.Delete"
                                   Class="vac-bulk-delete"
                                   OnClick="OnBulkDelete">
                            Delete Selected
                        </MudButton>
                    </div>
                }
            </div>
        }
    </section>
}

@code {
    [Parameter] public int NeedsReviewCount { get; set; }
    [Parameter] public int QuarantinedCount { get; set; }
    [Parameter] public int WaitingForProviderCount { get; set; }
    [Parameter] public bool IsExpanded { get; set; }
    [Parameter] public EventCallback<bool> IsExpandedChanged { get; set; }
    [Parameter] public List<LibraryItemViewModel>? ConflictItems { get; set; }
    [Parameter] public EventCallback<string> OnFilterActivated { get; set; }
    [Parameter] public EventCallback<Guid> OnItemEditClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteClicked { get; set; }
    [Parameter] public EventCallback<HashSet<Guid>> OnBulkDeleteClicked { get; set; }

    private HashSet<Guid> _selectedIds = [];

    private int TotalCount => NeedsReviewCount + QuarantinedCount + WaitingForProviderCount;
    private bool HasQuarantined => QuarantinedCount > 0;

    private async Task ToggleExpanded()
    {
        IsExpanded = !IsExpanded;
        await IsExpandedChanged.InvokeAsync(IsExpanded);
    }

    private void ToggleSelection(Guid entityId)
    {
        if (_selectedIds.Contains(entityId))
            _selectedIds.Remove(entityId);
        else
            _selectedIds.Add(entityId);
    }

    private async Task OnBulkDelete()
    {
        if (_selectedIds.Count == 0) return;
        await OnBulkDeleteClicked.InvokeAsync(new HashSet<Guid>(_selectedIds));
        _selectedIds.Clear();
    }

    /// <summary>One row per show/album/series in the Action Center; standalone items become single-item groups.</summary>
    private sealed record ContainerGroup(string Key, string Label, List<LibraryItemViewModel> Items);

    private static List<ContainerGroup> GroupByContainer(List<LibraryItemViewModel> items)
    {
        var result = new List<ContainerGroup>();
        var bucket = new Dictionary<string, List<LibraryItemViewModel>>(StringComparer.OrdinalIgnoreCase);
        var labels = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var item in items)
        {
            // Pick the most specific container key available for this media type.
            var (key, label) = item.MediaType switch
            {
                "TV"        => (item.ShowName, item.ShowName),
                "Music"     => (item.Album, item.Album),
                "Comics"    => (item.Series, item.Series),
                "Audiobooks"=> (item.Series, item.Series),
                "Books"     => (item.Series, item.Series),
                _           => (null, null),
            };

            if (string.IsNullOrWhiteSpace(key))
            {
                // No container  -  emit as a standalone single-item group.
                result.Add(new ContainerGroup(item.EntityId.ToString(), item.Title, [item]));
                continue;
            }

            if (!bucket.TryGetValue(key, out var list))
            {
                list = [];
                bucket[key] = list;
                labels[key] = label!;
            }
            list.Add(item);
        }

        foreach (var (k, list) in bucket)
            result.Add(new ContainerGroup(k, labels[k], list));

        return result;
    }

    private void ToggleGroupSelection(ContainerGroup group)
    {
        var allSelected = group.Items.All(i => _selectedIds.Contains(i.EntityId));
        if (allSelected)
            foreach (var i in group.Items) _selectedIds.Remove(i.EntityId);
        else
            foreach (var i in group.Items) _selectedIds.Add(i.EntityId);
    }

    private async Task DeleteGroup(ContainerGroup group)
    {
        // Cascade delete: route every member through the bulk delete callback.
        var ids = new HashSet<Guid>(group.Items.Select(i => i.EntityId));
        await OnBulkDeleteClicked.InvokeAsync(ids);
    }
}

<style>
    .vac {
        border: 1px solid;
        border-radius: 12px;
        transition: all 0.3s ease;
        margin-bottom: 8px;
    }

    .vac--warn {
        background: rgba(245, 158, 11, 0.04);
        border-color: rgba(245, 158, 11, 0.10);
    }

    .vac--severe {
        background: rgba(244, 63, 94, 0.04);
        border-color: rgba(244, 63, 94, 0.10);
    }

    .vac-summary {
        max-width: 1600px;
        margin: 0 auto;
        padding: 10px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .vac-summary-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .vac-icon {
        padding: 4px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .vac-icon--warn {
        background: rgba(245, 158, 11, 0.8);
        color: #080a0f;
    }

    .vac-icon--severe {
        background: rgba(244, 63, 94, 0.8);
        color: #080a0f;
    }

    .vac-label {
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.15em;
    }

    .vac--warn .vac-label {
        color: rgba(245, 158, 11, 0.8);
    }

    .vac--severe .vac-label {
        color: rgba(244, 63, 94, 0.8);
    }

    .vac-toggle {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        border-radius: 4px;
        transition: all 0.2s ease;
    }

    .vac-toggle--warn {
        color: rgba(245, 158, 11, 0.8);
        background: rgba(245, 158, 11, 0.08);
    }

    .vac-toggle--warn:hover {
        background: rgba(245, 158, 11, 0.15);
    }

    .vac-toggle--severe {
        color: rgba(244, 63, 94, 0.8);
        background: rgba(244, 63, 94, 0.08);
    }

    .vac-toggle--severe:hover {
        background: rgba(244, 63, 94, 0.15);
    }

    .vac-list {
        max-width: 1600px;
        margin: 0 auto;
        padding: 0 24px 16px;
    }

    .vac-list-inner {
        background: rgba(15, 23, 42, 0.6);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .vac--warn .vac-list-inner {
        border: 1px solid rgba(245, 158, 11, 0.12);
    }

    .vac--severe .vac-list-inner {
        border: 1px solid rgba(244, 63, 94, 0.12);
    }

    .vac-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        transition: background 0.15s ease;
    }

    .vac-row:not(:last-child) {
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .vac-row:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    .vac-row-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .vac-severity-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .vac-dot--severe {
        background: #f43f5e;
        box-shadow: 0 0 8px rgba(244, 63, 94, 0.5);
    }

    .vac-dot--warn {
        background: var(--tl-status-warning);
    }

    .vac-row-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .vac-row-title {
        font-size: 12px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.9);
