        transition: all 0.15s;
    }

    .vac-bulk-delete:hover {
        background: rgba(244, 63, 94, 0.15);
    }

    /* -- Mobile -- */
    @@media (max-width: 768px) {
        .vac-summary {
            padding: 8px 12px;
            flex-wrap: wrap;
            gap: 8px;
        }

        .vac-summary-left {
