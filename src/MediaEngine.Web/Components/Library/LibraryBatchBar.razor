@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs

@inject IStringLocalizer<SharedStrings> L

@if (SelectedCount > 0)
{
    <div class="media-batch-bar">
        <span class="media-batch-count">@SelectedCount selected</span>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Warning"
                   Class="media-batch-btn media-batch-btn--edit"
                   OnClick="() => OnEdit.InvokeAsync()">
            Edit (@SelectedCount)
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   Class="media-batch-btn media-batch-btn--delete"
                   OnClick="() => OnDelete.InvokeAsync()">
            Delete
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Info"
                   Class="media-batch-btn media-batch-btn--sync"
                   OnClick="() => OnSyncNow.InvokeAsync()">
            Sync Now
        </MudButton>

        <MudButton Variant="Variant.Text"
                   Color="Color.Inherit"
                   Class="media-batch-btn media-batch-btn--clear"
                   StartIcon="@Icons.Material.Outlined.Close"
                   OnClick="() => OnClearSelection.InvokeAsync()">
            Clear
        </MudButton>
    </div>
}

@code {
    [Parameter] public int SelectedCount { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnSyncNow { get; set; }
    [Parameter] public EventCallback OnClearSelection { get; set; }
}

<style>
    .media-batch-bar {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 24px;
        background: rgba(20, 24, 29, 0.95);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        backdrop-filter: blur(12px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
        z-index: 1000;
        animation: media-batch-slide-up 0.2s ease;
    }

    @@keyframes media-batch-slide-up {
        from { transform: translateX(-50%) translateY(20px); opacity: 0; }
        to   { transform: translateX(-50%) translateY(0); opacity: 1; }
    }

    .media-batch-count {
        font-size: 13px;
        font-weight: 700;
        color: rgba(255, 255, 255, 1);
        white-space: nowrap;
    }

    .media-batch-btn {
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-radius: 8px;
        padding: 8px 16px;
        white-space: nowrap;
        line-height: 1;
    }

    .media-batch-btn--edit {
        color: var(--tl-accent-primary);
    }

    .media-batch-btn--delete {
        color: var(--tl-status-danger);
    }

    .media-batch-btn--sync {
        color: var(--tl-status-info);
    }

    .media-batch-btn--clear {
        color: rgba(255, 255, 255, 0.4);
    }

    @@media (max-width: 768px) {
        .media-batch-bar {
            bottom: 12px;
            gap: 8px;
            padding: 10px 16px;
            left: 12px;
            right: 12px;
            transform: none;
            border-radius: 12px;
        }

        @@keyframes media-batch-slide-up {
            from { transform: translateY(20px); opacity: 0; }
            to   { transform: translateY(0); opacity: 1; }
        }

        .media-batch-count {
            font-size: 12px;
        }

        .media-batch-btn {
            padding: 6px 12px;
            font-size: 10px;
        }
    }

    @@media (max-width: 480px) {
        .media-batch-bar {
            gap: 6px;
            padding: 8px 12px;
        }

        .media-batch-btn {
            padding: 6px 8px;
            font-size: 9px;
        }
    }
</style>

