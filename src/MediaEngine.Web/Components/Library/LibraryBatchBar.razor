@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs

@inject IStringLocalizer<SharedStrings> L

@if (SelectedCount > 0)
{
    <div class="media-batch-bar">
        <span class="media-batch-count">@SelectedCount selected</span>

        <AppButton Variant="Variant.Filled"
                   Color="Color.Warning"
                   Class="media-batch-btn media-batch-btn--edit"
                   OnClick="() => OnEdit.InvokeAsync()">
            Edit (@SelectedCount)
        </AppButton>

        <AppButton Variant="Variant.Filled"
                   Color="Color.Error"
                   Class="media-batch-btn media-batch-btn--delete"
                   OnClick="() => OnDelete.InvokeAsync()">
            Delete
        </AppButton>

        <AppButton Variant="Variant.Filled"
                   Color="Color.Info"
                   Class="media-batch-btn media-batch-btn--sync"
                   OnClick="() => OnSyncNow.InvokeAsync()">
            Sync Now
        </AppButton>

        <AppButton Variant="Variant.Text"
                   Color="Color.Inherit"
                   Class="media-batch-btn media-batch-btn--clear"
                   StartIcon="@Icons.Material.Outlined.Close"
                   OnClick="() => OnClearSelection.InvokeAsync()">
            Clear
        </AppButton>
    </div>
}

@code {
    [Parameter] public int SelectedCount { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnSyncNow { get; set; }
    [Parameter] public EventCallback OnClearSelection { get; set; }
}