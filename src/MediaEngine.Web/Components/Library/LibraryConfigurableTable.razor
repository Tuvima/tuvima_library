@namespace MediaEngine.Web.Components.Library
@using System.Globalization
@using MediaEngine.Web.Models.ViewDTOs
@using Microsoft.AspNetCore.Components.Web

@inject IStringLocalizer<SharedStrings> L

@if (Items.Count == 0 && !Loading)
{
    <div class="vmt-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Inbox" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">No items match your current filters.</p>
    </div>
}
else
{
    <div class="vmt-container">
        @if (GroupBy != "none")
        {
            @foreach (var group in GetGroups())
            {
                <div class="vmt-group">
                    <div class="vmt-group-header" @onclick="() => ToggleGroup(group.Key)">
                        <MudIcon Icon="@(IsGroupExpanded(group.Key) ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                 Style="font-size: 14px; opacity: 0.4;" />
                        @{
                            var groupAllSelected = group.Items.Count > 0 && group.Items.All(i => SelectedItems.Contains(i.EntityId));
                        }
                        <span @onclick:stopPropagation="true">
                            <MudCheckBox T="bool"
                                         Value="@groupAllSelected"
                                         ValueChanged="@(_ => ToggleGroupSelection(group.Items))"
                                         Color="Color.Primary"
                                         Dense="true"
                                         Class="vct-checkbox" />
                        </span>
                        <span class="vmt-group-label">@group.Label</span>
                        <div class="vmt-group-line"></div>
                        <span class="vmt-group-count">@group.Items.Count items</span>
                    </div>
                    @if (IsGroupExpanded(group.Key))
                    {
                        <div class="vmt-table-wrap">
                            @RenderTable(group.Items)
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="vmt-table-wrap">
                @RenderTable(Items)
            </div>
        }

        @if (Loading)
        {
            <div class="vmt-loading">
                <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                     Style="color: rgba(255,255,255,0.15);" />
            </div>
        }
    </div>
}

@if (_hoverCover is not null)
{
    <div class="vmt-hover-overlay" style="top: @(_hoverY)px; left: @(_hoverX)px;">
        <img src="@_hoverCover" alt="" class="vmt-hover-img" />
    </div>
}

@code {
    [Parameter] public List<LibraryColumnDef> Columns { get; set; } = [];
    [Parameter] public List<string>? VisibleColumnKeys { get; set; }
    [Parameter] public List<LibraryItemViewModel> Items { get; set; } = [];
    [Parameter] public string GroupBy { get; set; } = "none";
    [Parameter] public bool Loading { get; set; }
    [Parameter] public int PosterSize { get; set; } = 48;
    [Parameter] public EventCallback<Guid> OnRowClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnRowDoubleClicked { get; set; }
    [Parameter] public EventCallback<LibraryRowContextMenuRequest> OnRowContextRequested { get; set; }
    [Parameter] public EventCallback<Guid> OnRowDragStarted { get; set; }
    [Parameter] public EventCallback OnRowDragEnded { get; set; }
    [Parameter] public EventCallback<string> OnAuthorClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnEditClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnFavoriteToggled { get; set; }
    [Parameter] public bool SelectOnRowClick { get; set; }
    [Parameter] public bool ActivateOnEnter { get; set; }
    [Parameter] public bool EnableRowContextMenu { get; set; }
    [Parameter] public bool EnableRowDragging { get; set; }

    // Batch selection
    [Parameter] public HashSet<Guid> SelectedItems { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedItemsChanged { get; set; }

    // Sort callback
    [Parameter] public string? ActiveSortKey { get; set; }
    [Parameter] public bool SortAscending { get; set; } = true;
    [Parameter] public EventCallback<(string sortKey, bool ascending)> OnSortRequested { get; set; }

    // Drillable row indicator
    [Parameter] public Func<LibraryItemViewModel, bool>? IsDrillable { get; set; }

    private readonly Dictionary<string, bool> _expandedGroups = new();

    public void ExpandAll()
    {
        _expandedGroups.Clear(); // default is expanded, so clearing shows all
        StateHasChanged();
    }

    public void CollapseAll()
    {
        foreach (var group in GetGroups())
            _expandedGroups[group.Key] = false;
        StateHasChanged();
    }

    private string? _hoverCover;
    private double _hoverX;
    private double _hoverY;
    private int _lastClickedIndex = -1;

    private List<LibraryColumnDef> ActiveColumns =>
        VisibleColumnKeys is { Count: > 0 }
            ? VisibleColumnKeys
                .Select(key => Columns.FirstOrDefault(c => c.Key == key))
                .Where(c => c is not null)
                .Cast<LibraryColumnDef>()
                .ToList()
            : Columns.Where(c => c.DefaultVisible).ToList();

    private void ShowHover(string? coverUrl, MouseEventArgs e)
    {
        if (string.IsNullOrEmpty(coverUrl)) return;
        _hoverCover = coverUrl;
        _hoverX = e.ClientX + 20;
        _hoverY = e.ClientY - 100;
    }

    private void HideHover()
    {
        _hoverCover = null;
    }

    private bool IsAllSelected(List<LibraryItemViewModel> items) =>
        items.Count > 0 && items.All(i => SelectedItems.Contains(i.EntityId));

    private async Task ToggleSelectAll(List<LibraryItemViewModel> items)
    {
        var allSelected = IsAllSelected(items);
        var updated = new HashSet<Guid>(SelectedItems);
        if (allSelected)
            foreach (var item in items) updated.Remove(item.EntityId);
        else
            foreach (var item in items) updated.Add(item.EntityId);
        SelectedItems = new HashSet<Guid>(updated);
        await SelectedItemsChanged.InvokeAsync(new HashSet<Guid>(SelectedItems));
    }

    private async Task ToggleItem(LibraryItemViewModel item, List<LibraryItemViewModel> contextList, MouseEventArgs e)
    {
        var updated = new HashSet<Guid>(SelectedItems);
        var currentIndex = contextList.IndexOf(item);

        if (e.ShiftKey && _lastClickedIndex >= 0 && currentIndex >= 0)
        {
            var start = Math.Min(_lastClickedIndex, currentIndex);
            var end = Math.Max(_lastClickedIndex, currentIndex);
            for (var i = start; i <= end; i++)
                updated.Add(contextList[i].EntityId);
        }
        else
        {
            if (updated.Contains(item.EntityId))
                updated.Remove(item.EntityId);
            else
                updated.Add(item.EntityId);
            _lastClickedIndex = currentIndex;
        }

        SelectedItems = new HashSet<Guid>(updated);
        await SelectedItemsChanged.InvokeAsync(new HashSet<Guid>(SelectedItems));
    }

    private async Task ToggleGroupSelection(List<LibraryItemViewModel> groupItems)
    {
        var allSelected = groupItems.Count > 0 && groupItems.All(i => SelectedItems.Contains(i.EntityId));
        var updated = new HashSet<Guid>(SelectedItems);
        if (allSelected)
            foreach (var item in groupItems) updated.Remove(item.EntityId);
        else
            foreach (var item in groupItems) updated.Add(item.EntityId);
        SelectedItems = new HashSet<Guid>(updated);
        await SelectedItemsChanged.InvokeAsync(new HashSet<Guid>(SelectedItems));
    }

    private async Task RequestSort(string sortKey)
    {
        var ascending = ActiveSortKey == sortKey ? !SortAscending : true;
        await OnSortRequested.InvokeAsync((sortKey, ascending));
    }

    private async Task HandleRowClickAsync(LibraryItemViewModel item, List<LibraryItemViewModel> contextList, MouseEventArgs e)
    {
        if (SelectOnRowClick)
        {
            await SelectRowAsync(item, contextList, e);
            return;
        }

        if (OnRowClicked.HasDelegate)
            await OnRowClicked.InvokeAsync(item.EntityId);
    }

    private async Task HandleRowDoubleClickAsync(LibraryItemViewModel item)
    {
        if (OnRowDoubleClicked.HasDelegate)
            await OnRowDoubleClicked.InvokeAsync(item.EntityId);
    }

    private async Task HandleRowContextMenuAsync(LibraryItemViewModel item, MouseEventArgs e)
    {
        if (!EnableRowContextMenu && !OnRowContextRequested.HasDelegate)
            return;

        await OnRowContextRequested.InvokeAsync(new LibraryRowContextMenuRequest(item.EntityId, e.ClientX, e.ClientY));
    }

    private async Task HandleRowDragStartAsync(LibraryItemViewModel item)
    {
        if (!EnableRowDragging && !OnRowDragStarted.HasDelegate)
            return;

        await OnRowDragStarted.InvokeAsync(item.EntityId);
    }

    private async Task HandleRowDragEndAsync()
    {
        if (OnRowDragEnded.HasDelegate)
            await OnRowDragEnded.InvokeAsync();
    }

    private async Task HandleRowKeyDownAsync(LibraryItemViewModel item, KeyboardEventArgs e)
    {
        if (!ActivateOnEnter || !string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase))
            return;

        if (OnRowDoubleClicked.HasDelegate)
        {
            await OnRowDoubleClicked.InvokeAsync(item.EntityId);
            return;
        }

        if (OnRowClicked.HasDelegate)
            await OnRowClicked.InvokeAsync(item.EntityId);
    }

    private async Task SelectRowAsync(LibraryItemViewModel item, List<LibraryItemViewModel> contextList, MouseEventArgs e)
    {
        var updated = new HashSet<Guid>(SelectedItems);
        var currentIndex = contextList.IndexOf(item);

        if (e.ShiftKey && _lastClickedIndex >= 0 && currentIndex >= 0)
        {
            updated.Clear();
            var start = Math.Min(_lastClickedIndex, currentIndex);
            var end = Math.Max(_lastClickedIndex, currentIndex);
            for (var index = start; index <= end; index++)
                updated.Add(contextList[index].EntityId);
        }
        else if (e.CtrlKey || e.MetaKey)
        {
            if (updated.Contains(item.EntityId))
                updated.Remove(item.EntityId);
            else
                updated.Add(item.EntityId);
            _lastClickedIndex = currentIndex;
        }
        else
        {
            updated.Clear();
            updated.Add(item.EntityId);
            _lastClickedIndex = currentIndex;
        }

        SelectedItems = new HashSet<Guid>(updated);
        await SelectedItemsChanged.InvokeAsync(new HashSet<Guid>(SelectedItems));
    }

    private async Task HandleFavoriteToggleAsync(Guid entityId)
    {
        if (OnFavoriteToggled.HasDelegate)
            await OnFavoriteToggled.InvokeAsync(entityId);
    }

    private async Task ToggleSingleItemAsync(LibraryItemViewModel item)
    {
        var updated = new HashSet<Guid>(SelectedItems);

        if (updated.Contains(item.EntityId))
            updated.Remove(item.EntityId);
        else
            updated.Add(item.EntityId);

        SelectedItems = new HashSet<Guid>(updated);
        await SelectedItemsChanged.InvokeAsync(new HashSet<Guid>(SelectedItems));
    }

    private RenderFragment RenderTable(List<LibraryItemViewModel> items) => __builder =>
    {
        var cols = ActiveColumns;
        <MudSimpleTable Dense="true" Hover="true" Class="vmt-table">
            <thead>
                <tr class="vmt-thead-row">
                    @foreach (var col in cols)
                    {
                        var alignClass = col.Align switch
                        {
                            "center" => "vmt-th--center",
                            "right" => "vmt-th--right",
                            _ => ""
                        };
                        var paddingStyle = col.Key == "media" ? "padding-left: 24px;" : "";
                        var paddingRightStyle = col.Key == "status" && GroupBy == "none" ? "padding-right: 24px;" : "";
                        <th class="vmt-th @alignClass" style="width: @col.Width; @paddingStyle @paddingRightStyle">
                            @if (col.RenderType == ColumnRenderType.Checkbox)
                            {
                                <MudCheckBox T="bool"
                                             Value="@IsAllSelected(items)"
                                             ValueChanged="@(_ => ToggleSelectAll(items))"
                                             Color="Color.Primary"
                                             Dense="true"
                                             Class="vct-checkbox" />
                            }
                            else if (col.Sortable && col.SortKey is not null)
                            {
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Inherit"
                                           Class="@($"vmt-sort-header {(col.RenderType == ColumnRenderType.FavoriteToggle ? "vmt-sort-header--icon" : string.Empty)}")"
                                           OnClick="() => RequestSort(col.SortKey!)">
                                    @if (col.RenderType == ColumnRenderType.FavoriteToggle)
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Style="font-size: 14px;" />
                                    }
                                    else
                                    {
                                        @col.Label
                                    }
                                    @if (ActiveSortKey == col.SortKey)
                                    {
                                        <MudIcon Icon="@(SortAscending ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward)"
                                                 Style="font-size: 12px; margin-left: 4px; opacity: 0.7;" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.UnfoldMore"
                                                 Style="font-size: 12px; margin-left: 4px; opacity: 0.25;" />
                                    }
                                </MudButton>
                            }
                            else
                            {
                                @col.Label
                            }
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    var isQuarantined = item.LibraryDisplayStatus == LibraryStatus.Quarantined;
                    var isSelected = SelectedItems.Contains(item.EntityId);
                    var isDrillable = IsDrillable?.Invoke(item) == true;
                    var rowInteractive = SelectOnRowClick || OnRowClicked.HasDelegate || OnRowDoubleClicked.HasDelegate;
                    <tr @key="item.EntityId"
                        class="vmt-row @(isQuarantined ? "vmt-row--quarantined" : "") @(isSelected ? "vmt-row--selected" : "") vmt-row--drillable"
                        style="cursor: @(rowInteractive ? "pointer" : "default");"
                        tabindex="@(rowInteractive || ActivateOnEnter ? "0" : null)"
                        draggable="@EnableRowDragging"
                        @onclick="@(async (MouseEventArgs args) => await HandleRowClickAsync(item, items, args))"
                        @ondblclick="@(async () => await HandleRowDoubleClickAsync(item))"
                        @oncontextmenu:preventDefault="@(EnableRowContextMenu || OnRowContextRequested.HasDelegate)"
                        @oncontextmenu="@(async (MouseEventArgs args) => await HandleRowContextMenuAsync(item, args))"
                        @ondragstart="@(async () => await HandleRowDragStartAsync(item))"
                        @ondragend="HandleRowDragEndAsync"
                        @onkeydown="@(async (KeyboardEventArgs args) => await HandleRowKeyDownAsync(item, args))">
                        @foreach (var col in cols)
                        {
                            var tdAlignClass = col.Align switch
                            {
                                "center" => "vmt-td--center",
                                "right" => "vmt-td--right",
                                _ => ""
                            };
                            var tdPaddingStyle = col.Key == "media" ? "padding-left: 24px;" : "";
                            var tdPaddingRightStyle = col.Key == "status" ? "padding-right: 24px;" : "";

                            <td @key="col.Key" class="vmt-td @tdAlignClass" style="@tdPaddingStyle @tdPaddingRightStyle">
                                @switch (col.RenderType)
                                {
                                    case ColumnRenderType.Checkbox:
                                        <span @onclick:stopPropagation="true">
                                            <MudCheckBox T="bool"
                                                         Value="@isSelected"
                                                         ValueChanged="@(_ => ToggleSingleItemAsync(item))"
                                                         Color="Color.Primary"
                                                         Dense="true"
                                                         Class="vct-checkbox" />
                                        </span>
                                        break;

                                    case ColumnRenderType.MediaCell:
                                        <div class="vmt-media-cell">
                                            <div class="vmt-poster-wrap">
                                                <div class="vmt-thumb" style="width: @(PosterSize)px; min-height: @(PosterSize)px;"
                                                     @onmouseenter="(e) => ShowHover(item.CoverUrl, e)"
                                                     @onmouseleave="HideHover">
                                                    @if (!string.IsNullOrEmpty(item.CoverUrl))
                                                    {
                                                        <img src="@(item.CoverThumbUrl ?? item.CoverUrl)" alt="@item.Title" class="vmt-thumb-img" loading="lazy" />
                                                    }
                                                    else
                                                    {
                                                        <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(item.MediaType)"
                                                                 Style="font-size: 20px; opacity: 0.25;" />
                                                    }
                                                </div>
                                                <div class="vmt-type-badge" style="color: @LibraryHelpers.GetMediaTypeColor(item.MediaType);">
                                                    <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(item.MediaType)" Style="font-size: 14px;" />
                                                </div>
                                            </div>
                                            <div class="vmt-media-info">
                                                @{
                                                    var isTv = string.Equals(item.MediaType, "TV", StringComparison.OrdinalIgnoreCase);
                                                    // For TV: prefer episode title over generic title; show name moves to a badge under the title.
                                                    var displayTitle = isTv && !string.IsNullOrWhiteSpace(item.EpisodeTitle)
                                                        ? item.EpisodeTitle!
                                                        : item.Title;
                                                }
                                                <p class="vmt-title @(isQuarantined ? "vmt-title--muted" : "")">@displayTitle</p>
                                                @if (isTv && !string.IsNullOrEmpty(item.ShowName))
                                                {
                                                    <p class="vmt-show-badge">@item.ShowName</p>
                                                }
                                                @if (!string.IsNullOrEmpty(item.OriginalTitle) && item.OriginalTitle != displayTitle)
                                                {
                                                    <p class="vmt-original-title">@item.OriginalTitle</p>
                                                }
                                                @if (isTv)
                                                {
                                                    var subParts = new List<string>();
                                                    if (!string.IsNullOrEmpty(item.Network)) subParts.Add(item.Network!);
                                                    if (item.Year is not null) subParts.Add(item.Year);
                                                    <p class="vmt-subtitle">@string.Join(" - ", subParts)</p>
                                                }
                                                else
                                                {
                                                    <p class="vmt-subtitle">@LibraryHelpers.FormatMediaType(item.MediaType) @(item.Year is not null ? $"- {item.Year}" : "")</p>
                                                }
                                                @{
                                                    var creatorName = GetCreatorForMediaType(item);
                                                }
                                                @if (!string.IsNullOrEmpty(creatorName))
                                                {
                                                    var creators = creatorName.Split(new[] { " and ", " & ", ", " }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                                    @for (var ci = 0; ci < creators.Length; ci++)
                                                    {
                                                        var creator = creators[ci];
                                                        @if (ci > 0)
                                                        {
                                                            <span class="vmt-creator-sep">, </span>
                                                        }
                                                        <span @onclick:stopPropagation="true">
                                                            <MudButton Variant="Variant.Text"
                                                                       Color="Color.Inherit"
                                                                       Class="vmt-creator-link"
                                                                       OnClick="() => OnAuthorClicked.InvokeAsync(creator.Trim())">
                                                                @creator.Trim().ToUpperInvariant()
                                                            </MudButton>
                                                        </span>
                                                    }
                                                }
                                                @if (item.LibraryDisplayStatus == LibraryStatus.NeedsReview && !string.IsNullOrEmpty(item.ReviewTrigger))
                                                {
                                                    <p class="vmt-review-reason">@LibraryHelpers.GetReviewTriggerLabel(item.ReviewTrigger)</p>
                                                }
                                                @if (item.LibraryDisplayStatus == LibraryStatus.WaitingForProvider)
                                                {
                                                    <p class="vmt-provider-waiting">
                                                        @if (!string.IsNullOrEmpty(item.FailedProviderName))
                                                        {
                                                            @($"Waiting for {item.FailedProviderName} to come back online...")
                                                        }
                                                        else
                                                        {
                                                            @("Waiting for provider to come back online...")
                                                        }
                                                    </p>
                                                }
                                            </div>
                                        </div>
                                        break;

                                    case ColumnRenderType.Pipeline:
                                        <div class="vmt-pipeline">
                                            <StageGate Stage="@item.Stage1" />
                                            <StageGate Stage="@item.Stage2" />
                                            <StageGate Stage="@item.Stage3" IsLast="true" />
                                        </div>
                                        break;

                                    case ColumnRenderType.StatusPill:
                                        <div style="display: flex; justify-content: @(col.Align == "right" ? "flex-end" : col.Align == "center" ? "center" : "flex-start");">
                                            <StatusPill Status="@item.LibraryDisplayStatus" QuarantineDays="@item.QuarantineDays" />
                                        </div>
                                        break;

                                    case ColumnRenderType.UniverseLink:
                                        @if (!string.IsNullOrEmpty(item.UniverseName))
                                        {
                                            <span class="vmt-universe-linked">@item.UniverseName.ToUpperInvariant()</span>
                                        }
                                        else
                                        {
                                            <span class="vmt-universe-standalone">Standalone</span>
                                        }
                                        break;

                                    case ColumnRenderType.Date:
                                        <span class="vct-text-cell">@FormatAbsoluteDate(item.CreatedAt)</span>
                                        break;

                                    case ColumnRenderType.Duration:
                                        <span class="vct-text-cell"> - </span>
                                        break;

                                    case ColumnRenderType.FileSize:
                                        <span class="vct-text-cell">@LibraryHelpers.FormatFileSize(item.FileSizeBytes)</span>
                                        break;

                                    case ColumnRenderType.Rating:
                                        <span class="vct-text-cell"> - </span>
                                        break;

                                    case ColumnRenderType.TypeBadge:
                                        <span class="vault-type-badge" style="@GetTypeBadgeStyle(GetPropertyValue(item, col.PropertyName))">
                                            @LibraryHelpers.FormatMediaType(GetPropertyValue(item, col.PropertyName) ?? "")
                                        </span>
                                        break;

                                    case ColumnRenderType.Text:
                                        <span class="vct-text-cell">@GetDisplayTextValue(item, col.PropertyName)</span>
                                        break;

                                    case ColumnRenderType.FavoriteToggle:
                                        <span @onclick:stopPropagation="true">
                                            <MudIconButton Icon="@(item.IsFavorite ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                                           Color="Color.Inherit"
                                                           Class="@($"vmt-favorite-button {(item.IsFavorite ? "is-active" : string.Empty)}")"
                                                           aria-label="@(item.IsFavorite ? "Remove favorite" : "Add favorite")"
                                                           OnClick="() => HandleFavoriteToggleAsync(item.EntityId)" />
                                        </span>
                                        break;

                                    case ColumnRenderType.ClickableText:
                                        var clickText = GetDisplayTextValue(item, col.PropertyName);
                                        if (!string.IsNullOrEmpty(clickText))
                                        {
                                            var parts = clickText.Split(new[] { " and ", " & ", ", " }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                            for (var pi = 0; pi < parts.Length; pi++)
                                            {
                                                var part = parts[pi];
                                                if (pi > 0)
                                                {
                                                    <span class="vmt-creator-sep">, </span>
                                                }
                                                <span @onclick:stopPropagation="true">
                                                    <MudButton Variant="Variant.Text"
                                                               Color="Color.Inherit"
                                                               Class="vmt-creator-link"
                                                               OnClick="() => OnAuthorClicked.InvokeAsync(part)">
                                                        @part.ToUpperInvariant()
                                                    </MudButton>
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="vct-text-cell"> - </span>
                                        }
                                        break;

                                    case ColumnRenderType.ContainerCell:
                                        <div class="vmt-media-cell">
                                            <div class="vmt-poster-wrap">
                                                @if (!string.IsNullOrEmpty(item.ArtistPhotoUrl))
                                                {
                                                    <div class="vmt-artist-photo" style="width: @(PosterSize)px; height: @(PosterSize)px;">
                                                        <img src="@item.ArtistPhotoUrl" alt="@item.Title" class="vmt-artist-photo-img" loading="lazy" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="vmt-thumb" style="width: @(PosterSize)px; min-height: @(PosterSize)px;"
                                                         @onmouseenter="(e) => ShowHover(item.CoverUrl, e)"
                                                         @onmouseleave="HideHover">
                                                        @if (!string.IsNullOrEmpty(item.CoverUrl))
                                                        {
                                                            <img src="@(item.CoverThumbUrl ?? item.CoverUrl)" alt="@item.Title" class="vmt-thumb-img" loading="lazy" />
                                                        }
                                                        else
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Outlined.Person"
                                                                     Style="font-size: 20px; opacity: 0.25;" />
                                                        }
                                                    </div>
                                                }
                                            </div>
                                            <div class="vmt-media-info">
                                                <p class="vmt-title">@item.Title</p>
                                                @{
                                                    var subtitle = GetContainerSubtitle(item);
                                                }
                                                @if (!string.IsNullOrEmpty(subtitle))
                                                {
                                                    <p class="vmt-subtitle">@subtitle</p>
                                                }
                                            </div>
                                        </div>
                                        break;

                                    case ColumnRenderType.Count:
                                        <span class="vct-text-cell">@GetDisplayTextValue(item, col.PropertyName)</span>
                                        break;

                                    case ColumnRenderType.ManageActions:
                                        <div class="vmt-manage-actions">
                                            <span @onclick:stopPropagation="true">
                                                <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                                               Color="Color.Error"
                                                               Class="vmt-manage-btn vmt-manage-btn--delete"
                                                               aria-label="Delete"
                                                               OnClick="() => OnDeleteClicked.InvokeAsync(item.EntityId)" />
                                            </span>
                                        </div>
                                        break;

                                    case ColumnRenderType.CompactCell:
                                        <div class="vmt-compact-cell">
                                            <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(item.MediaType)"
                                                     Style="font-size: 14px; opacity: 0.3; flex-shrink: 0;" />
                                            <span class="vmt-compact-title">@item.Title</span>
                                        </div>
                                        break;

                                    case ColumnRenderType.CoverThumb:
                                        <div class="vmt-cover-thumb" style="width: 32px; height: 32px;"
                                             @onmouseenter="(e) => ShowHover(item.CoverUrl, e)"
                                             @onmouseleave="HideHover">
                                            @if (!string.IsNullOrEmpty(item.CoverUrl))
                                            {
                                                <img src="@(item.CoverThumbUrl ?? item.CoverUrl)" alt="" class="vmt-cover-thumb-img" loading="lazy" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(item.MediaType)"
                                                         Style="font-size: 16px; opacity: 0.2;" />
                                            }
                                        </div>
                                        break;

                                    case ColumnRenderType.TitleCell:
                                        <div class="vmt-title-cell">
                                            <span class="vmt-status-dot" style="background: @LibraryHelpers.GetLibraryStatusColor(item.LibraryDisplayStatus);"></span>
                                            @{
                                                var isTvTitle = string.Equals(item.MediaType, "TV", StringComparison.OrdinalIgnoreCase);
                                                var cellTitle = isTvTitle && !string.IsNullOrWhiteSpace(item.EpisodeTitle)
                                                    ? item.EpisodeTitle!
                                                    : item.Title;
                                            }
                                            <span class="vmt-title-text @(isQuarantined ? "vmt-title--muted" : "")">@cellTitle</span>
                                            @if (!string.IsNullOrEmpty(item.OriginalTitle) && item.OriginalTitle != cellTitle)
                                            {
                                                <span class="vmt-original-title-sub">@item.OriginalTitle</span>
                                            }
                                        </div>
                                        break;

                                    default:
                                        <span class="vct-text-cell"> - </span>
                                        break;
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    };

    // -- Grouping --

    private record TableGroup(string Key, string Label, List<LibraryItemViewModel> Items);

    private bool IsGroupExpanded(string key)
    {
        if (_expandedGroups.TryGetValue(key, out var val)) return val;
        return true;
    }

    private void ToggleGroup(string key) =>
        _expandedGroups[key] = !IsGroupExpanded(key);

    private List<TableGroup> GetGroups() => GetGroupsCore();

    private List<TableGroup> GetGroupsCore()
    {
        if (GroupBy == "type")
        {
            var order = new[] { "Books", "Audiobooks", "Movies", "TV", "Comics", "Music" };
            var byType = Items.GroupBy(i => i.MediaType ?? "Unknown").ToDictionary(g => g.Key, g => g.ToList());
            var result = new List<TableGroup>();
            foreach (var mt in order)
                if (byType.TryGetValue(mt, out var items) && items.Count > 0)
                    result.Add(new TableGroup(mt, mt, items));
            foreach (var kvp in byType.Where(k => !order.Contains(k.Key)))
                if (kvp.Value.Count > 0)
                    result.Add(new TableGroup(kvp.Key, kvp.Key, kvp.Value));
            return result;
        }

        if (GroupBy == "status")
        {
            var groups = new List<TableGroup>();
            var verified   = Items.Where(i => i.LibraryDisplayStatus == LibraryStatus.Verified).ToList();
            var provisional = Items.Where(i => i.LibraryDisplayStatus == LibraryStatus.Provisional).ToList();
            var review      = Items.Where(i => i.LibraryDisplayStatus == LibraryStatus.NeedsReview).ToList();
            var failed      = new List<LibraryItemViewModel>(); // Failed status removed  -  maps to NeedsReview
            var quarantined = Items.Where(i => i.LibraryDisplayStatus == LibraryStatus.Quarantined).ToList();
            var waiting     = Items.Where(i => i.LibraryDisplayStatus == LibraryStatus.WaitingForProvider).ToList();
            if (verified.Count > 0)    groups.Add(new TableGroup("verified",    "Verified",              verified));
            if (provisional.Count > 0) groups.Add(new TableGroup("provisional", "Provisional",           provisional));
            if (review.Count > 0)      groups.Add(new TableGroup("review",      "Needs Review",          review));
            if (waiting.Count > 0)     groups.Add(new TableGroup("waiting",     "Waiting for Provider",  waiting));
            if (failed.Count > 0)      groups.Add(new TableGroup("failed",      "Failed",                failed));
            if (quarantined.Count > 0) groups.Add(new TableGroup("quarantined", "Quarantined",           quarantined));
            return groups;
        }

        if (GroupBy == "letter")
        {
            var byLetter = Items
                .GroupBy(i => string.IsNullOrEmpty(i.Title) ? "#" : i.Title[0].ToString().ToUpperInvariant())
                .OrderBy(g => g.Key)
                .Select(g => new TableGroup(g.Key, g.Key, g.ToList()))
                .ToList();
            return byLetter;
        }

        if (GroupBy == "universe")
        {
            var byUniverse = Items
                .GroupBy(i => i.UniverseName ?? "Standalone")
                .OrderBy(g => g.Key == "Standalone" ? "zzz" : g.Key)
                .Select(g => new TableGroup(g.Key, g.Key, g.ToList()))
                .ToList();
            return byUniverse;
        }

        if (GroupBy == "author")
        {
            var byAuthor = Items
                .GroupBy(i => i.Author ?? i.Director ?? i.Artist ?? "Unknown")
                .OrderBy(g => g.Key == "Unknown" ? "zzz" : g.Key)
                .Select(g => new TableGroup(g.Key, g.Key, g.ToList()))
                .ToList();
            return byAuthor;
        }

        if (GroupBy == "artist")
        {
            var byArtist = Items
                .GroupBy(i => i.Artist ?? i.Author ?? "Unknown")
                .OrderBy(g => g.Key == "Unknown" ? "zzz" : g.Key)
                .Select(g => new TableGroup(g.Key, g.Key, g.ToList()))
                .ToList();
            return byArtist;
        }

        if (GroupBy == "genre")
        {
            var byGenre = Items
                .GroupBy(i => i.Genre ?? "Unknown")
                .OrderBy(g => g.Key == "Unknown" ? "zzz" : g.Key)
                .Select(g => new TableGroup(g.Key, g.Key, g.ToList()))
                .ToList();
            return byGenre;
        }

        if (GroupBy == "decade")
        {
            var byDecade = Items
                .GroupBy(i => int.TryParse(i.Year, out var y) ? $"{y / 10 * 10}s" : "Unknown")
                .OrderByDescending(g => g.Key == "Unknown" ? "0" : g.Key)
                .Select(g => new TableGroup(g.Key, g.Key, g.ToList()))
                .ToList();
            return byDecade;
        }

        return [new TableGroup("all", "All", Items)];
    }

    // -- Helpers --

    private static string? GetCreatorForMediaType(LibraryItemViewModel item) => item.MediaType switch
    {
        "Movies" => item.Director ?? item.Author,
        "TV"     => null,
        "Music"  => item.Artist ?? item.Author,
        _        => item.Author,
    };

    private static string? GetPropertyValue(LibraryItemViewModel item, string? propertyName) =>
        propertyName switch
        {
            "MediaType"      => item.MediaType,
            "ParentContext"  => item.ShowName ?? item.Series ?? item.Album,
            _               => null,
        };

    private static string GetTypeBadgeStyle(string? mediaType)
    {
        var color = LibraryHelpers.GetMediaTypeColor(mediaType ?? "");
        return $"color: {color}; background: {LibraryHelpers.HexToRgba(color, 0.12)}; border-color: {LibraryHelpers.HexToRgba(color, 0.2)};";
    }

    /// <summary>
    /// Subtitle shown under the container title in ContainerCell cells.
    /// TV shows display the top billed cast (from P161) so the row reads
    /// "Breaking Bad / Bryan Cranston, Aaron Paul, Anna Gunn" rather than
    /// repeating the director. Other media types keep the author/creator line.
    /// </summary>
    private static string? GetContainerSubtitle(LibraryItemViewModel item)
    {
        if (string.Equals(item.MediaType, "TV", StringComparison.OrdinalIgnoreCase))
            return item.TopCast;
        return item.Author;
    }

    private static string GetDisplayTextValue(LibraryItemViewModel item, string? propertyName)
    {
        const string EmptyValue = "-";

        return propertyName switch
        {
            "ParentContext" => item.ShowName ?? item.Series ?? item.Album ?? EmptyValue,
            "Author" => item.Author ?? EmptyValue,
            "Director" => item.Director ?? EmptyValue,
            "Artist" => item.Artist ?? EmptyValue,
            "AlbumArtist" => item.AlbumArtist ?? EmptyValue,
            "Composer" => item.Composer ?? EmptyValue,
            "Comments" or "Comment" => item.Comments ?? EmptyValue,
            "Favorite" => item.IsFavorite ? "Yes" : EmptyValue,
            "PlayCount" => item.PlayCount is > 0 ? item.PlayCount.Value.ToString(CultureInfo.InvariantCulture) : EmptyValue,
            "DateAdded" => item.CreatedAt == default ? EmptyValue : FormatAbsoluteDate(item.CreatedAt),
            "DateModified" => item.DateModified.HasValue ? FormatAbsoluteDate(item.DateModified.Value) : EmptyValue,
            "LastPlayed" => item.LastPlayedAt.HasValue ? FormatAbsoluteDate(item.LastPlayedAt.Value) : EmptyValue,
            "ReleaseDate" => item.ReleaseDate.HasValue ? FormatAbsoluteDate(item.ReleaseDate.Value) : EmptyValue,
            "Duration" or "Runtime" => LibraryHelpers.FormatDuration(item.DurationSeconds, item.Duration ?? item.Runtime),
            "Rating" => LibraryHelpers.FormatRating(item.Rating),
            "Album" => item.Album ?? EmptyValue,
            "Genre" => item.Genre ?? EmptyValue,
            "Kind" => item.Kind ?? EmptyValue,
            "TrackNumber" => item.TrackNumber ?? EmptyValue,
            "DiscNumber" => item.DiscNumber ?? EmptyValue,
            "Year" => FormatYear(item.Year),
            "SortTitle" => item.SortTitle ?? EmptyValue,
            "SortArtist" => item.SortArtist ?? EmptyValue,
            "SortAlbum" => item.SortAlbum ?? EmptyValue,
            "Series" => item.Series ?? item.UniverseName ?? EmptyValue,
            "SeriesPosition" => item.SeriesPosition ?? EmptyValue,
            "Narrator" => item.Narrator ?? item.Author ?? EmptyValue,
            "Season" => item.Season ?? EmptyValue,
            "Episode" => item.Episode ?? EmptyValue,
            "Network" => item.Network ?? EmptyValue,
            "EpisodeTitle" => item.EpisodeTitle ?? EmptyValue,
            "IssueNumber" => EmptyValue,
            "Name" => item.Title,
            "Type" => item.MediaType ?? EmptyValue,
            "SeriesCount" => EmptyValue,
            "PeopleCount" => EmptyValue,
            "ItemCount" => EmptyValue,
            "Featured" => EmptyValue,
            "WorkCount" => item.TrackCount ?? EmptyValue,
            "SeasonCount" => item.SeasonCount ?? EmptyValue,
            "AlbumCount" => item.AlbumCount ?? EmptyValue,
            "Creator" => item.Author ?? item.Artist ?? item.Director ?? EmptyValue,
            _ => GetTextValue(item, propertyName),
        };
    }

    private static string GetTextValue(LibraryItemViewModel item, string? propertyName) =>
        propertyName switch
        {
            "ParentContext"  => item.ShowName ?? item.Series ?? item.Album ?? " - ",
            "Author"        => item.Author ?? " - ",
            "Director"      => item.Director ?? " - ",
            "Artist"        => item.Artist ?? " - ",
            "Year"          => FormatYear(item.Year),
            "Series"         => item.Series ?? item.UniverseName ?? " - ",
            "SeriesPosition" => item.SeriesPosition ?? " - ",
            "Narrator"       => item.Narrator ?? item.Author ?? " - ",
            "Genre"          => item.Genre ?? " - ",
            "Runtime" or "Duration" => item.Runtime ?? " - ",
            "Rating"         => item.Rating ?? " - ",
            "Album"          => item.Album ?? " - ",
            "TrackNumber"    => item.TrackNumber ?? " - ",
            "Season"        => item.Season ?? " - ",
            "Episode"       => item.Episode ?? " - ",
            "Network"       => item.Network ?? " - ",
            "EpisodeTitle"  => item.EpisodeTitle ?? " - ",
            "IssueNumber"   => " - ",                   // placeholder
            "Name"          => item.Title,            // Collections tab
            "Type"          => item.MediaType ?? " - ", // Collections tab
            "SeriesCount"   => " - ",                   // Universes tab
            "PeopleCount"   => " - ",                   // Universes tab
            "ItemCount"     => " - ",                   // Collections tab
            "Featured"      => " - ",                   // Collections tab
            "WorkCount"     => item.TrackCount ?? " - ", // container: work/episode/issue count
            "SeasonCount"   => item.SeasonCount ?? " - ", // container: season count
            "AlbumCount"    => item.AlbumCount ?? " - ",  // container: album count for music artists
            "Creator"       => item.Author ?? " - ",     // container: creator
            _ => " - ",
        };

    private static string FormatYear(string? year)
    {
        if (string.IsNullOrEmpty(year)) return " - ";
        // If it looks like a date (YYYY-MM-DD or longer), extract just the year.
        if (year.Length >= 4 && char.IsDigit(year[0]) && char.IsDigit(year[1])
            && char.IsDigit(year[2]) && char.IsDigit(year[3])
            && (year.Length == 4 || year[4] == '-'))
        {
            return year[..4];
        }
        return year;
    }

    private static string FormatRelativeTime(DateTimeOffset dt)
    {
        var diff = DateTimeOffset.UtcNow - dt;
        if (diff.TotalMinutes < 60)  return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24)    return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 30)     return $"{(int)diff.TotalDays}d ago";
        if (diff.TotalDays < 365)    return $"{(int)(diff.TotalDays / 30)}mo ago";
        return $"{(int)(diff.TotalDays / 365)}y ago";
    }

    private static string FormatAbsoluteDate(DateTimeOffset dt) =>
        dt == default
            ? "-"
            : dt.LocalDateTime.ToString("M/d/yyyy, h:mm tt", CultureInfo.CurrentCulture);
}

