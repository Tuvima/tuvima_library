@using MediaEngine.Web.Models.ViewDTOs

<MudDrawer Open="@IsOpen" Anchor="Anchor.Bottom" Variant="@DrawerVariant.Temporary"
           OpenChanged="OnOpenChanged"
           Elevation="16"
           Class="vault-mobile-drawer">
    @if (Item is not null)
    {
        <div class="vmd-content">
            @* -- Header -- *@
            <div class="vmd-header">
                <div class="vmd-thumb">
                    @if (!string.IsNullOrEmpty(Item.CoverUrl))
                    {
                        <img src="@Item.CoverUrl" alt="@Item.Title" class="vmd-thumb-img" />
                    }
                    else
                    {
                        <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(Item.MediaType)"
                                 Style="font-size: 24px; opacity: 0.25;" />
                    }
                </div>
                <div class="vmd-info">
                    <h3 class="vmd-title">@Item.Title</h3>
                    <p class="vmd-subtitle">@LibraryHelpers.FormatMediaType(Item.MediaType) @(Item.Year is not null ? $"- {Item.Year}" : "")</p>
                </div>
            </div>

            @* -- Pipeline + Confidence -- *@
            <div class="vmd-pipeline-row">
                <div class="vmd-stages">
                    <StageGate Stage="@Item.Stage1" />
                    <StageGate Stage="@Item.Stage2" />
                    <StageGate Stage="@Item.Stage3" IsLast="true" />
                </div>
                <ConfidenceBar Confidence="@Item.Confidence" />
            </div>

            @* -- Status -- *@
            <div class="vmd-status-row">
                <StatusPill Status="@Item.LibraryDisplayStatus" QuarantineDays="@Item.QuarantineDays" />
            </div>

            @* -- Actions -- *@
            <div class="vmd-actions">
                @if (Item.LibraryDisplayStatus == LibraryStatus.NeedsReview)
                {
                    <button class="vmd-action-btn vmd-action-btn--primary"
                            @onclick="() => OnResolve.InvokeAsync(Item.EntityId)">
                        <MudIcon Icon="@Icons.Material.Outlined.Build" Style="font-size: 18px;" />
                        Resolve
                    </button>
                }
                <button class="vmd-action-btn vmd-action-btn--danger"
                        @onclick="() => OnDelete.InvokeAsync(Item.EntityId)">
                    <MudIcon Icon="@Icons.Material.Outlined.Delete" Style="font-size: 18px;" />
                    Delete
                </button>
            </div>
        </div>
    }
</MudDrawer>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public LibraryItemViewModel? Item { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback<Guid> OnResolve { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    private async Task OnOpenChanged(bool open)
    {
        await IsOpenChanged.InvokeAsync(open);
    }
}

<style>
    :deep(.vault-mobile-drawer) {
        border-radius: 24px 24px 0 0 !important;
        max-height: 60vh !important;
    }

    :deep(.vault-mobile-drawer .mud-drawer-content) {
        background: #14181d !important;
    }

    .vmd-content {
        padding: 24px 20px 32px;
    }

    .vmd-header {
        display: flex;
        gap: 16px;
        margin-bottom: 20px;
    }

    .vmd-thumb {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.02);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .vmd-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .vmd-info {
        overflow: hidden;
    }

    .vmd-title {
        font-size: 16px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vmd-subtitle {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.35);
        font-weight: 700;
        text-transform: uppercase;
        margin: 0;
    }

    .vmd-pipeline-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .vmd-stages {
        display: flex;
    }

    .vmd-status-row {
        display: flex;
        justify-content: center;
        padding: 16px 0;
    }

    .vmd-actions {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 8px;
    }

    .vmd-action-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 14px;
        border-radius: 12px;
        border: none;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.15s;
    }

    .vmd-action-btn--primary {
        background: rgba(96, 165, 250, 0.85);
        color: #fff;
    }

    .vmd-action-btn--primary:hover {
        background: rgba(96, 165, 250, 1);
    }

    .vmd-action-btn--danger {
        background: rgba(226, 75, 74, 0.15);
        color: rgba(226, 75, 74, 0.85);
        border: 1px solid rgba(226, 75, 74, 0.2);
    }

    .vmd-action-btn--danger:hover {
        background: rgba(226, 75, 74, 0.25);
    }
</style>
