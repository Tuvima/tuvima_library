@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Theming

@inject IEngineApiClient ApiClient

@if (_loading)
{
    <div class="vo-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Small"
                             Style="color: rgba(255,255,255,0.15);" />
    </div>
}
else if (_data is null)
{
    <div class="vo-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Dashboard" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">Unable to load overview data.</p>
    </div>
}
else
{
    @if (ReadOnly)
    {
        var topReviewCategories = _data.ReviewCategories
            .Where(c => c.Value > 0)
            .OrderByDescending(c => c.Value)
            .Take(3)
            .ToList();
        var pipelineActive = GetPipelineActiveCount(_data);
        var queuedCount = _data.PipelineStates.GetValueOrDefault("Queued");
        var noMatchCount = _data.PipelineStates.GetValueOrDefault("RetailNoMatch") + _data.PipelineStates.GetValueOrDefault("QidNoMatch");

        <div class="vo-review-grid">
            <div class="vo-card vo-card--compact @(_data.ReviewTotal > 0 ? "vo-card--alert" : "")">
                <div class="vo-card-header">
                    <MudIcon Icon="@Icons.Material.Outlined.WarningAmber" Style="font-size: 18px; opacity: 0.4;" />
                    <span class="vo-card-title">Attention</span>
                </div>
                <div class="vo-card-value" style="@(_data.ReviewTotal > 0 ? $"color: {PaletteProvider.Current.Status.NeedsReview};" : "")">
                    @_data.ReviewTotal
                </div>
                <div class="vo-card-subtitle">items waiting on a decision</div>
                <div class="vo-card-breakdown vo-card-breakdown--stacked">
                    @if (topReviewCategories.Count > 0)
                    {
                        @foreach (var cat in topReviewCategories)
                        {
                            <span class="vo-metric vo-metric--row">
                                <span class="vo-metric-value">@cat.Value</span>
                                <span class="vo-metric-label">@FormatCategory(cat.Key)</span>
                            </span>
                        }
                    }
                    else
                    {
                        <span class="vo-metric-label">Nothing currently needs review.</span>
                    }
                </div>
            </div>

            <div class="vo-card vo-card--compact">
                <div class="vo-card-header">
                    <MudIcon Icon="@Icons.Material.Outlined.Sync" Style="font-size: 18px; opacity: 0.4;" />
                    <span class="vo-card-title">Pipeline</span>
                </div>
                <div class="vo-card-value" style="color: @GetSuccessRateColor(_data.PipelineSuccessRate);">
                    @pipelineActive
                </div>
                <div class="vo-card-subtitle">items still moving through ingestion</div>
                <div class="vo-card-breakdown">
                    <span class="vo-metric">
                        <span class="vo-metric-value">@queuedCount</span>
                        <span class="vo-metric-label">queued</span>
                    </span>
                    <span class="vo-metric">
                        <span class="vo-metric-value">@noMatchCount</span>
                        <span class="vo-metric-label">no match</span>
                    </span>
                    <span class="vo-metric">
                        <span class="vo-metric-value">@((_data.PipelineSuccessRate * 100).ToString("0"))%</span>
                        <span class="vo-metric-label">success</span>
                    </span>
                </div>
            </div>

            <div class="vo-card vo-card--compact vo-card--wide">
                <div class="vo-card-header">
                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Style="font-size: 18px; opacity: 0.4;" />
                    <span class="vo-card-title">Library Snapshot</span>
                </div>
                <div class="vo-review-stats">
                    <span class="vo-review-stat">
                        <span class="vo-review-stat-value">@_data.TotalItems.ToString("N0")</span>
                        <span class="vo-review-stat-label">total</span>
                    </span>
                    <span class="vo-review-stat">
                        <span class="vo-review-stat-value">@_data.Added7d</span>
                        <span class="vo-review-stat-label">new this week</span>
                    </span>
                    <span class="vo-review-stat">
                        <span class="vo-review-stat-value">@_data.CompletedWithArt</span>
                        <span class="vo-review-stat-label">visible</span>
                    </span>
                    <span class="vo-review-stat">
                        <span class="vo-review-stat-value">@_data.WithQid</span>
                        <span class="vo-review-stat-label">with QID</span>
                    </span>
                    <span class="vo-review-stat">
                        <span class="vo-review-stat-value">@_data.UniverseAssigned</span>
                        <span class="vo-review-stat-label">in universe</span>
                    </span>
                </div>
                <div class="vo-card-breakdown vo-card-breakdown--media">
                    @foreach (var mt in _data.MediaTypeCounts.OrderByDescending(m => m.Value).Take(6))
                    {
                        <span class="vo-media-chip">
                            <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(mt.Key)" Style="font-size: 14px;" />
                            <span class="vo-media-chip-label">@mt.Key</span>
                            <span class="vo-media-chip-count">@mt.Value.ToString("N0")</span>
                        </span>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
    <div class="vo-grid @(ReadOnly ? "vo-grid--readonly" : string.Empty)">

        @* â”€â”€ Intake Summary â”€â”€ *@
        <div class="vo-card vo-card--wide" @onclick='() => HandleNavigate("new")'>
            <div class="vo-card-header">
                <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Style="font-size: 18px; opacity: 0.4;" />
                <span class="vo-card-title">Intake</span>
            </div>
            <div class="vo-card-value">@_data.TotalItems.ToString("N0")</div>
            <div class="vo-card-subtitle">total items in library</div>
            <div class="vo-card-breakdown">
                <span class="vo-metric">
                    <span class="vo-metric-value">@_data.Added24h</span>
                    <span class="vo-metric-label">24h</span>
                </span>
                <span class="vo-metric">
                    <span class="vo-metric-value">@_data.Added7d</span>
                    <span class="vo-metric-label">7d</span>
                </span>
                <span class="vo-metric">
                    <span class="vo-metric-value">@_data.Added30d</span>
                    <span class="vo-metric-label">30d</span>
                </span>
            </div>
        </div>

        @* â”€â”€ Review Backlog â”€â”€ *@
        <div class="vo-card @(_data.ReviewTotal > 0 ? "vo-card--alert" : "")"
             @onclick='() => HandleNavigate("action_center")'>
            <div class="vo-card-header">
                <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 18px; opacity: 0.4;" />
                <span class="vo-card-title">Review Backlog</span>
            </div>
            <div class="vo-card-value" style="@(_data.ReviewTotal > 0 ? $"color: {PaletteProvider.Current.Status.NeedsReview};" : "")">
                @_data.ReviewTotal
            </div>
            <div class="vo-card-subtitle">items need attention</div>
            @if (_data.ReviewCategories.Count > 0)
            {
                <div class="vo-card-breakdown vo-card-breakdown--stacked">
                    @foreach (var cat in _data.ReviewCategories.Where(c => c.Value > 0).OrderByDescending(c => c.Value))
                    {
                        <span class="vo-metric vo-metric--row">
                            <span class="vo-metric-value">@cat.Value</span>
                            <span class="vo-metric-label">@FormatCategory(cat.Key)</span>
                        </span>
                    }
                </div>
            }
        </div>

        @* â”€â”€ Pipeline Health â”€â”€ *@
        <div class="vo-card">
            <div class="vo-card-header">
                <MudIcon Icon="@Icons.Material.Outlined.Timeline" Style="font-size: 18px; opacity: 0.4;" />
                <span class="vo-card-title">Pipeline</span>
            </div>
            <div class="vo-card-value" style="color: @GetSuccessRateColor(_data.PipelineSuccessRate);">
                @((_data.PipelineSuccessRate * 100).ToString("0"))%
            </div>
            <div class="vo-card-subtitle">success rate</div>
            @if (_data.PipelineStates.Count > 0)
            {
                <div class="vo-card-breakdown vo-card-breakdown--stacked">
                    @foreach (var state in _data.PipelineStates.Where(s => s.Value > 0))
                    {
                        <span class="vo-metric vo-metric--row">
                            <span class="vo-metric-value">@state.Value</span>
                            <span class="vo-metric-label">@FormatPipelineState(state.Key)</span>
                        </span>
                    }
                </div>
            }
        </div>

        @* â”€â”€ Enrichment Progress â”€â”€ *@
        <div class="vo-card">
            <div class="vo-card-header">
                <MudIcon Icon="@Icons.Material.Outlined.Science" Style="font-size: 18px; opacity: 0.4;" />
                <span class="vo-card-title">Enrichment</span>
            </div>
            @{
                var qidTotal = _data.WithQid + _data.WithoutQid;
                var qidPct = qidTotal > 0 ? (double)_data.WithQid / qidTotal : 0;
            }
            <div class="vo-card-value">@((qidPct * 100).ToString("0"))%</div>
            <div class="vo-card-subtitle">identified (QID)</div>
            <div class="vo-progress-bar">
                <div class="vo-progress-fill" style="width: @((qidPct * 100).ToString("0"))%;"></div>
            </div>
            <div class="vo-card-breakdown">
                <span class="vo-metric">
                    <span class="vo-metric-value">@_data.WithQid</span>
                    <span class="vo-metric-label">with QID</span>
                </span>
                <span class="vo-metric">
                    <span class="vo-metric-value">@_data.WithoutQid</span>
                    <span class="vo-metric-label">without</span>
                </span>
            </div>
        </div>

        @* â”€â”€ Universe Coverage â”€â”€ *@
        <div class="vo-card" @onclick='() => HandleNavigate("new")'>
            <div class="vo-card-header">
                <MudIcon Icon="@Icons.Material.Outlined.Visibility" Style="font-size: 18px; opacity: 0.4;" />
                <span class="vo-card-title">Library Readiness</span>
            </div>
            <div class="vo-card-value">@_data.CompletedWithArt</div>
            <div class="vo-card-subtitle">visible with artwork</div>
            <div class="vo-card-breakdown vo-card-breakdown--stacked">
                <span class="vo-metric vo-metric--row">
                    <span class="vo-metric-value">@_data.HiddenByQualityGate</span>
                    <span class="vo-metric-label">hidden by gate</span>
                </span>
                <span class="vo-metric vo-metric--row">
                    <span class="vo-metric-value">@_data.ArtPending</span>
                    <span class="vo-metric-label">art pending</span>
                </span>
                <span class="vo-metric vo-metric--row">
                    <span class="vo-metric-value">@_data.RetailNeedsReview</span>
                    <span class="vo-metric-label">retail review</span>
                </span>
                <span class="vo-metric vo-metric--row">
                    <span class="vo-metric-value">@_data.QidNoMatch</span>
                    <span class="vo-metric-label">QID no match</span>
                </span>
            </div>
        </div>

        <div class="vo-card" @onclick='() => HandleNavigate("ua_pending")'>
            <div class="vo-card-header">
                <MudIcon Icon="@Icons.Material.Outlined.Collections" Style="font-size: 18px; opacity: 0.4;" />
                <span class="vo-card-title">Universes</span>
            </div>
            @{
                var uniTotal = _data.UniverseAssigned + _data.UniverseUnassigned;
                var uniPct = uniTotal > 0 ? (double)_data.UniverseAssigned / uniTotal : 0;
            }
            <div class="vo-card-value">@_data.UniverseAssigned</div>
            <div class="vo-card-subtitle">works assigned to a universe</div>
            <div class="vo-progress-bar">
                <div class="vo-progress-fill vo-progress-fill--purple" style="width: @((uniPct * 100).ToString("0"))%;"></div>
            </div>
            <div class="vo-card-breakdown">
                <span class="vo-metric">
                    <span class="vo-metric-value">@_data.UniverseUnassigned</span>
                    <span class="vo-metric-label">unassigned</span>
                </span>
            </div>
        </div>

        @* â”€â”€ Stale Items â”€â”€ *@
        <div class="vo-card @(_data.StaleItems > 20 ? "vo-card--warn" : "")">
            <div class="vo-card-header">
                <MudIcon Icon="@Icons.Material.Outlined.Update" Style="font-size: 18px; opacity: 0.4;" />
                <span class="vo-card-title">Freshness</span>
            </div>
            <div class="vo-card-value">@_data.StaleItems</div>
            <div class="vo-card-subtitle">items older than 30 days</div>
        </div>

        @* â”€â”€ Media Type Breakdown â”€â”€ *@
        <div class="vo-card vo-card--wide">
            <div class="vo-card-header">
                <MudIcon Icon="@Icons.Material.Outlined.Category" Style="font-size: 18px; opacity: 0.4;" />
                <span class="vo-card-title">Media Types</span>
            </div>
            <div class="vo-card-breakdown vo-card-breakdown--media">
                @foreach (var mt in _data.MediaTypeCounts.OrderByDescending(m => m.Value))
                {
                    <span class="vo-media-chip" @onclick='() => HandleNavigate(mt.Key.ToLowerInvariant())'
                          @onclick:stopPropagation="true">
                        <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(mt.Key)" Style="font-size: 14px;" />
                        <span class="vo-media-chip-label">@mt.Key</span>
                        <span class="vo-media-chip-count">@mt.Value.ToString("N0")</span>
                    </span>
                }
            </div>
        </div>

    </div>
    }
}

@code {
    [Parameter] public EventCallback<string> OnNavigate { get; set; }
    [Parameter] public bool ReadOnly { get; set; }

    private LibraryOverviewViewModel? _data;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _data = await ApiClient.GetLibraryOverviewAsync();
        _loading = false;
    }

    private Task HandleNavigate(string target)
        => ReadOnly ? Task.CompletedTask : OnNavigate.InvokeAsync(target);

    private static int GetPipelineActiveCount(LibraryOverviewViewModel data)
    {
        var activeStates = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "Queued",
            "RetailSearching",
            "RetailMatched",
            "RetailMatchedNeedsReview",
            "BridgeSearching",
            "QidResolved",
            "Hydrating",
            "UniverseEnriching",
        };

        return data.PipelineStates
            .Where(state => activeStates.Contains(state.Key))
            .Sum(state => state.Value);
    }

    private static string FormatCategory(string trigger) => trigger switch
    {
        "RetailMatchFailed" or "NoRetailMatch" => "Needs Identification",
        "RetailMatchAmbiguous" or "MultipleQidMatches" => "Ambiguous Match",
        "LowConfidence" => "Low Confidence",
        "MediaTypeUnknown" => "Unknown Type",
        "Quarantined" => "Quarantined",
        "WaitingForProvider" => "Waiting for Provider",
        _ => trigger.Replace("_", " "),
    };

    private static string FormatPipelineState(string state) => state switch
    {
        "Queued" => "Queued",
        "RetailSearching" => "Retail search",
        "RetailMatched" => "Retail matched",
        "RetailNoMatch" => "No retail match",
        "BridgeSearching" => "Wikidata search",
        "QidResolved" => "QID resolved",
        "QidNoMatch" => "No QID match",
        "Hydrating" => "Hydrating",
        "UniverseEnriching" => "Universe enriching",
        "Ready" => "Ready",
        "ReadyWithoutUniverse" => "Ready (no universe)",
        "Completed" => "Completed",
        "Failed" => "Failed",
        _ => state,
    };

    private static string GetSuccessRateColor(double rate)
    {
        var p = PaletteProvider.Current;
        return rate switch
        {
            >= 0.85 => p.Status.Verified,
            >= 0.60 => p.Status.Provisional,
            _ => p.Status.NeedsReview,
        };
    }
}

<style>
    .vo-loading,
    .vo-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 300px;
    }

    .vo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
        padding: 8px 0;
    }

    .vo-review-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 12px;
        padding: 4px 0 8px;
    }

    .vo-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 20px;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
    }

    .vo-grid--readonly .vo-card,
    .vo-grid--readonly .vo-media-chip {
        cursor: default;
    }

    .vo-card:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.10);
    }

    .vo-card--wide {
        grid-column: span 2;
    }

    .vo-card--compact {
        padding: 16px;
    }

    .vo-card--compact .vo-card-value {
        font-size: 1.75rem;
        margin-bottom: 6px;
    }

    .vo-review-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
        gap: 12px;
        margin-bottom: 12px;
    }

    .vo-review-stat {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 10px 12px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.04);
    }

    .vo-review-stat-value {
        font-size: 1rem;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.8);
    }

    .vo-review-stat-label {
        font-size: 0.72rem;
        color: rgba(255, 255, 255, 0.32);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .vo-card--alert {
        border-color: rgba(201, 146, 46, 0.25);
    }

    .vo-card--warn {
        border-color: rgba(201, 146, 46, 0.15);
    }

    .vo-card-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
    }

    .vo-card-title {
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(255, 255, 255, 0.35);
    }

    .vo-card-value {
        font-size: 2rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1;
        margin-bottom: 4px;
    }

    .vo-card-subtitle {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.3);
        margin-bottom: 12px;
    }

    .vo-card-breakdown {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .vo-card-breakdown--stacked {
        flex-direction: column;
        gap: 4px;
    }

    .vo-card-breakdown--media {
        gap: 8px;
    }

    .vo-metric {
        display: flex;
        align-items: baseline;
        gap: 4px;
    }

    .vo-metric--row {
        flex-direction: row;
        gap: 8px;
    }

    .vo-metric-value {
        font-size: 0.9rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.7);
    }

    .vo-metric-label {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.3);
    }

    .vo-progress-bar {
        height: 4px;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 2px;
        margin-bottom: 12px;
        overflow: hidden;
    }

    .vo-progress-fill {
        height: 100%;
        background: rgba(76, 175, 80, 0.6);
        border-radius: 2px;
        transition: width 0.4s ease;
    }

    .vo-progress-fill--purple {
        background: rgba(156, 39, 176, 0.6);
    }

    .vo-media-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s;
    }

    .vo-media-chip:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    .vo-media-chip-label {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.5);
    }

    .vo-media-chip-count {
        font-size: 0.85rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.7);
    }

    @@media (max-width: 768px) {
        .vo-card--wide {
            grid-column: span 1;
        }
    }
</style>
