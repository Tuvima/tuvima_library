@namespace MediaEngine.Web.Components.Library
@inject IStringLocalizer<SharedStrings> L
@inject IEngineApiClient ApiClient

@* â”€â”€ Backdrop â”€â”€ *@
<div class="vamd-backdrop" @onclick="OnClose"></div>

@* â”€â”€ Drawer Panel â”€â”€ *@
<div class="vamd-drawer" @onclick:stopPropagation="true">
    <div class="vamd-header">
        <MudIconButton Icon="@Icons.Material.Outlined.Close"
                       Size="Size.Small"
                       Style="position:absolute;top:24px;right:24px;color:rgba(255,255,255,0.5);"
                       OnClick="OnClose" />
        <div style="display:flex;align-items:center;gap:12px;">
            <MudIcon Icon="@Icons.Material.Outlined.CreateNewFolder" Style="font-size: 24px; color: var(--tl-status-info);" />
            <h2 class="vamd-title">@L["VaultAddMedia_Title"]</h2>
        </div>
        <p class="vamd-hint">@L["VaultAddMedia_Hint"]</p>
    </div>

    <div class="vamd-body">
        @if (_selectedFile is null)
        {
            @* â”€â”€ Drop Zone â”€â”€ *@
            <div class="vamd-drop-zone @(_isDragging ? "vamd-drop-zone--active" : "")"
                 @ondragenter="OnDragEnter"
                 @ondragover="OnDragOver"
                 @ondragover:preventDefault="true"
                 @ondragleave="OnDragLeave"
                 @ondrop="OnDrop"
                 @ondrop:preventDefault="true">
                <MudIcon Icon="@(_isDragging ? Icons.Material.Outlined.CloudUpload : Icons.Material.Outlined.UploadFile)"
                         Style="@($"font-size: 48px; color: {(_isDragging ? "var(--tl-status-info)" : "rgba(255,255,255,0.1)")}; transition: color 0.2s;")" />
                <p class="vamd-drop-text">
                    @if (_isDragging)
                    {
                        <span style="color: var(--tl-status-info); font-weight: 800;">@L["VaultAddMedia_DropToImport"]</span>
                    }
                    else
                    {
                        <span>@L["VaultAddMedia_DragFilesHere"]</span>
                    }
                </p>
                <span class="vamd-drop-or">@L["VaultAddMedia_Or"]</span>
                <label class="vamd-browse-btn">
                    <MudIcon Icon="@Icons.Material.Outlined.FolderOpen" Style="font-size: 16px;" />
                    @L["VaultAddMedia_BrowseFiles"]
                    <InputFile OnChange="OnFileSelected" style="display:none;" />
                </label>
            </div>

            <div class="vamd-supported">
                <span class="vamd-supported-label">@L["VaultAddMedia_Supported"]</span>
                <div class="vamd-supported-types">
                    <span>EPUB</span><span>M4B</span><span>MKV</span><span>MP4</span>
                    <span>CBZ</span><span>CBR</span><span>MP3</span><span>FLAC</span>
                    <span>PDF</span>
                </div>
            </div>
        }
        else
        {
            @* â”€â”€ Type Confirmation â”€â”€ *@
            <div class="vamd-confirm-section">
                <div class="vamd-file-info">
                    <MudIcon Icon="@Icons.Material.Outlined.InsertDriveFile" Style="font-size: 24px; color: rgba(255,255,255,0.4);" />
                    <div>
                        <p class="vamd-file-name">@_selectedFile.Name</p>
                        <p class="vamd-file-size">@FormatSize(_selectedFile.Size)</p>
                    </div>
                </div>

                <div class="vamd-type-picker">
                    <p class="vamd-type-label">Confirm media type:</p>
                    <MudToggleGroup T="string"
                                    Value="_selectedMediaType"
                                    ValueChanged="OnSelectedMediaTypeChanged"
                                    SelectionMode="SelectionMode.SingleSelection"
                                    Delimiters="true"
                                    CheckMark="false"
                                    Color="Color.Primary"
                                    Class="vamd-type-grid">
                        @foreach (var mt in _mediaTypes)
                        {
                            <MudToggleItem T="string" Value="@mt" Class="vamd-type-btn">
                                <MudIcon Icon="@GetIcon(mt)" Style="font-size: 18px;" />
                                <span>@mt</span>
                            </MudToggleItem>
                        }
                    </MudToggleGroup>
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="vamd-error">
                        <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Style="font-size: 16px;" />
                        <span>@_errorMessage</span>
                    </div>
                }

                <div class="vamd-actions">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="vamd-upload-btn"
                               OnClick="UploadFile"
                               Disabled="@(string.IsNullOrEmpty(_selectedMediaType) || _uploading)">
                        @if (_uploading)
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: white;" />
                            <span>Uploadingâ€¦</span>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Upload" Style="font-size: 16px;" />
                            <span>Add to Library</span>
                        }
                    </MudButton>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Inherit"
                               Class="vamd-cancel-btn"
                               OnClick="ClearSelection">
                        Cancel
                    </MudButton>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    private bool   _isDragging;
    private bool   _uploading;
    private string _selectedMediaType = "";
    private string _errorMessage      = "";
    private IBrowserFile? _selectedFile;

    private static readonly string[] _mediaTypes =
        ["Books", "Audiobooks", "Movies", "TV", "Music", "Comics"];

    // Extensions that are unambiguous â€” auto-select media type.
    private static readonly Dictionary<string, string> _autoDetect =
        new(StringComparer.OrdinalIgnoreCase)
        {
            [".epub"] = "Books",
            [".cbz"]  = "Comics",
            [".cbr"]  = "Comics",
            [".m4b"]  = "Audiobooks",
            [".pdf"]  = "Books",
        };

    private void OnDragEnter() => _isDragging = true;
    private void OnDragOver()  => _isDragging = true;
    private void OnDragLeave() => _isDragging = false;

    private void OnDrop()
    {
        // Blazor server cannot access drag-drop file data from here â€” the InputFile
        // component inside the zone handles browser file selection via the label.
        _isDragging = false;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile    = e.File;
        _errorMessage    = "";
        _isDragging      = false;

        var ext = Path.GetExtension(_selectedFile.Name);
        _selectedMediaType = _autoDetect.TryGetValue(ext, out var detected) ? detected : "";
    }

    private async Task UploadFile()
    {
        if (_selectedFile is null || string.IsNullOrEmpty(_selectedMediaType)) return;

        _uploading     = true;
        _errorMessage  = "";
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            // 10 GB max â€” media files can be large video files.
            using var stream  = _selectedFile.OpenReadStream(maxAllowedSize: 10L * 1024 * 1024 * 1024);
            content.Add(new StreamContent(stream), "file", _selectedFile.Name);
            content.Add(new StringContent(_selectedMediaType), "mediaType");

            var success = await ApiClient.UploadMediaAsync(content);
            if (success)
            {
                ClearSelection();
                await OnClose.InvokeAsync();
            }
            else
            {
                _errorMessage = "Upload failed. Check that the watch folder is configured and accessible.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred during upload.";
        }
        finally
        {
            _uploading = false;
        }
    }

    private void ClearSelection()
    {
        _selectedFile      = null;
        _selectedMediaType = "";
        _errorMessage      = "";
    }

    private Task OnSelectedMediaTypeChanged(string value)
    {
        _selectedMediaType = value;
        return Task.CompletedTask;
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1_024              => $"{bytes} B",
        < 1_048_576          => $"{bytes / 1_024.0:F1} KB",
        < 1_073_741_824      => $"{bytes / 1_048_576.0:F1} MB",
        _                    => $"{bytes / 1_073_741_824.0:F2} GB",
    };

    private static string GetIcon(string mediaType) => mediaType switch
    {
        "Books"      => Icons.Material.Outlined.MenuBook,
        "Audiobooks" => Icons.Material.Outlined.Headphones,
        "Movies"     => Icons.Material.Outlined.VideoLibrary,
        "TV"         => Icons.Material.Outlined.LiveTv,
        "Music"      => Icons.Material.Outlined.MusicNote,
        "Comics"     => Icons.Material.Outlined.AutoStories,
        _            => Icons.Material.Outlined.InsertDriveFile,
    };
}

<style>
    .vamd-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        z-index: 10000;
        animation: vamd-fade-in 0.2s ease;
    }

    @@keyframes vamd-fade-in {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .vamd-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: 36rem;
        height: 100%;
        background: #0d0f12;
        border-left: 1px solid rgba(255, 255, 255, 0.06);
        z-index: 10001;
        display: flex;
        flex-direction: column;
        box-shadow: 0 0 80px rgba(0, 0, 0, 0.9);
        animation: vamd-slide-in 0.4s ease;
    }

    @@keyframes vamd-slide-in {
        from { transform: translateX(100%); }
        to { transform: translateX(0); }
    }

    .vamd-header {
        padding: 32px 24px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        position: relative;
        flex-shrink: 0;
    }

    .vamd-title {
        font-size: 20px;
        font-weight: 900;
        color: white;
        margin: 0;
    }

    .vamd-hint {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.35);
        margin: 8px 0 0;
    }

    .vamd-body {
        flex: 1;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 24px;
        overflow-y: auto;
    }

    .vamd-drop-zone {
        flex: 1;
        min-height: 240px;
        border: 2px dashed rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.01);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        transition: all 0.2s ease;
        cursor: pointer;
        position: relative;
    }

    .vamd-drop-zone:hover {
        border-color: rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.02);
    }

    .vamd-drop-zone--active {
        border-color: var(--tl-status-info);
        background: var(--tl-status-info-soft);
        transform: scale(1.02);
    }

    .vamd-drop-text {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.35);
        margin: 0;
    }

    .vamd-drop-or {
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.15);
    }

    .vamd-browse-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 12px;
        border: 1px solid var(--tl-status-info-border);
        background: var(--tl-status-info-soft);
        color: var(--tl-status-info);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vamd-browse-btn:hover {
        background: var(--tl-status-info-border);
    }

    .vamd-supported {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .vamd-supported-label {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.2);
    }

    .vamd-supported-types {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .vamd-supported-types span {
        font-size: 9px;
        font-weight: 800;
        padding: 3px 8px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.35);
    }

    /* â”€â”€ Confirm section â”€â”€ */
    .vamd-confirm-section {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .vamd-file-info {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
    }

    .vamd-file-name {
        font-size: 13px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.85);
        margin: 0;
        word-break: break-all;
    }

    .vamd-file-size {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.3);
        margin: 2px 0 0;
    }

    .vamd-type-picker {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .vamd-type-label {
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.3);
        margin: 0;
    }

    .vamd-type-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
    }

    .vamd-type-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
        border-radius: 10px;
        color: rgba(255, 255, 255, 0.4);
        font-size: 10px;
        font-weight: 700;
        min-height: 72px;
        transition: all 0.15s;
    }

    ::deep .vamd-type-btn:hover,
    ::deep .vamd-type-btn:focus-visible {
        border-color: var(--tl-status-info-border);
        background: var(--tl-status-info-soft);
        color: rgba(255, 255, 255, 0.7);
    }

    ::deep .vamd-type-btn.mud-selected {
        border-color: var(--tl-status-info);
        background: var(--tl-status-info-border);
        color: var(--tl-status-info);
    }

    .vamd-error {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: 8px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #FCA5A5;
        font-size: 11px;
    }

    .vamd-actions {
        display: flex;
        gap: 10px;
    }

    .vamd-upload-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border-radius: 12px;
        background: var(--tl-status-info);
        color: white;
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.15s;
    }

    .vamd-upload-btn:hover:not(:disabled) {
        background: #3B82F6;
    }

    .vamd-upload-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .vamd-cancel-btn {
        border-radius: 12px;
        background: transparent;
        color: rgba(255, 255, 255, 0.4);
        font-size: 12px;
        font-weight: 700;
        text-transform: none;
        transition: all 0.15s;
    }

    .vamd-cancel-btn:hover {
        border-color: rgba(255, 255, 255, 0.15);
        color: rgba(255, 255, 255, 0.7);
    }

    @@media (max-width: 768px) {
        .vamd-drawer {
            width: 100%;
        }

        .vamd-type-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
</style>

