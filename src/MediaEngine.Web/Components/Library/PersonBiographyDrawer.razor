        margin-bottom: 0;
    }

    .pbd-role-label {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.3);
    }

    .pbd-works-list {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    /* ГўвЂќв‚¬ГўвЂќв‚¬ Work row ГўвЂќв‚¬ГўвЂќв‚¬ */
    .pbd-work-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 8px;
        border-radius: 8px;
        background: transparent;
        border: none;
        cursor: pointer;
        width: 100%;
        text-align: left;
        transition: background 0.15s;
        color: inherit;
    }

    .pbd-work-row:hover {
        background: rgba(255, 255, 255, 0.04);
    }

    .pbd-work-thumb {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
