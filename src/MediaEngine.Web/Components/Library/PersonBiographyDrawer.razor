@using MediaEngine.Web.Models.ViewDTOs
@namespace MediaEngine.Web.Components.Library
@inject IStringLocalizer<SharedStrings> L

@* ГўвЂќв‚¬ГўвЂќв‚¬ Person Biography Drawer ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
   Renders the full biography layout for a person inside a detail drawer.
   Can be used from LibraryDetailDrawer, future Work detail pages, or any
   context where a person is clicked.
   ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ *@

@* ГўвЂќв‚¬ГўвЂќв‚¬ Biography section ГўвЂќв‚¬ГўвЂќв‚¬ *@
<DrawerSection Title="Biography" Icon="@Icons.Material.Outlined.AutoStories" DefaultOpen="true">
    @if (!string.IsNullOrEmpty(Person.Biography))
    {
        <p class="pbd-biography">@Person.Biography</p>
    }
    else
    {
        <p class="pbd-empty-hint">No biography available yet. This person will be enriched during the next refresh cycle.</p>
    }
</DrawerSection>

@* ГўвЂќв‚¬ГўвЂќв‚¬ Social Links ГўвЂќв‚¬ГўвЂќв‚¬ *@
@{
    bool hasSocialLinks = !string.IsNullOrEmpty(Person.Biography); // fallback check via Occupation
    // Compute social link presence from the PersonListItemDto fields
    // PersonListItemDto doesn't have social fields Гўв‚¬вЂќ those live in PersonDetailViewModel
    // So we just render nothing if Person doesn't have them (will be enhanced in future)
}

@* ГўвЂќв‚¬ГўвЂќв‚¬ In Your Library ГўвЂќв‚¬ГўвЂќв‚¬ *@
<DrawerSection Title="In Your Library" Icon="@Icons.Material.Outlined.LibraryBooks" DefaultOpen="true">
    @if (_roleGroups.Count > 0)
    {
        @foreach (var (roleLabel, works) in _roleGroups)
        {
            <div class="pbd-role-group">
                <span class="pbd-role-label">@roleLabel</span>
                <div class="pbd-works-list">
                    @{
                        var visibleWorks = _showAllWorks ? works : works.Take(InitialWorksToShow).ToList();
                        var remaining    = works.Count - InitialWorksToShow;
                    }
                    @foreach (var work in visibleWorks)
                    {
                        <button class="pbd-work-row" @onclick="() => OnWorkClicked.InvokeAsync(work.Id)">
                            <div class="pbd-work-thumb">
                                @if (!string.IsNullOrEmpty(work.CoverUrl))
                                {
                                    <img src="@work.CoverUrl" alt="" loading="lazy" class="pbd-work-thumb-img" />
                                }
                                else
                                {
                                    <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(work.PrimaryMediaType ?? "")" Style="font-size: 16px; color: rgba(255,255,255,0.2);" />
                                }
                            </div>
                            <div class="pbd-work-info">
                                <span class="pbd-work-title">@work.DisplayName</span>
                                @if (!string.IsNullOrEmpty(work.PrimaryMediaType))
                                {
                                    <span class="pbd-work-type" style="color: @LibraryHelpers.GetMediaTypeColor(work.PrimaryMediaType);">
                                        @LibraryHelpers.FormatMediaType(work.PrimaryMediaType)
                                    </span>
                                }
                            </div>
                            <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Style="font-size: 16px; color: rgba(255,255,255,0.15); flex-shrink: 0;" />
                        </button>
                    }
                    @if (!_showAllWorks && remaining > 0)
                    {
                        <button class="pbd-show-more-btn" @onclick="() => _showAllWorks = true">
                            Show @remaining more
                        </button>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p class="pbd-empty-hint">No works found in your library for this person.</p>
    }
</DrawerSection>

@* ГўвЂќв‚¬ГўвЂќв‚¬ Linked Identities ГўвЂќв‚¬ГўвЂќв‚¬ *@
<DrawerSection Title="@L["VaultDetail_SectionLinkedIdentities"]" Icon="@Icons.Material.Outlined.Fingerprint" DefaultOpen="false">
    <div class="pbd-identities">
        <span class="vdd-field-label">@(Person.IsPseudonym ? L["VaultDetail_FieldRealPeople"] : L["VaultDetail_FieldPenNames"])</span>
        @if (Aliases is not null && Aliases.Aliases.Count > 0)
        {
            <div class="pbd-identity-items">
                @foreach (var alias in Aliases.Aliases.OrderByDescending(a => !string.IsNullOrEmpty(a.WikidataQid)))
                {
                    <button class="vdd-identity-link" @onclick="() => OnPersonAliasClicked.InvokeAsync(alias.Id)">
                        <div class="vdd-alias-avatar">
                            @if (!string.IsNullOrEmpty(alias.HeadshotUrl))
                            {
                                <img src="@alias.HeadshotUrl" alt="@alias.Name" class="vdd-alias-avatar-img" loading="lazy" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 14px; color: rgba(255,255,255,0.2);" />
                            }
                        </div>
                        <div class="vdd-alias-info">
                            <span class="vdd-alias-name">@alias.Name</span>
                            <span class="vdd-alias-relationship">@(alias.Relationship == "real_person" ? "Real person" : "Pen name")</span>
                        </div>
                    </button>
                }
            </div>
        }
        else
        {
            <p class="pbd-empty-hint">@L["VaultDetail_HintPenNames"]</p>
        }
    </div>
</DrawerSection>

@* ГўвЂќв‚¬ГўвЂќв‚¬ Members (for groups/bands) ГўвЂќв‚¬ГўвЂќв‚¬ *@
@if (Person.IsGroup && GroupMembers?.Count > 0)
{
    <DrawerSection Title="Members" Icon="@Icons.Material.Outlined.Groups" DefaultOpen="true">
        <div class="pbd-members-list">
            @foreach (var member in GroupMembers)
            {
                <button class="pbd-work-row" @onclick="() => OnMemberClicked.InvokeAsync(member.Id)">
                    <div class="pbd-work-thumb" style="border-radius: 50%;">
                        <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 16px; color: rgba(255,255,255,0.2);" />
                    </div>
                    <div class="pbd-work-info">
                        <span class="pbd-work-title">@member.Name</span>
                        @if (!string.IsNullOrEmpty(member.DateRange))
                        {
                            <span class="pbd-work-type" style="color: rgba(255,255,255,0.35);">@member.DateRange</span>
                        }
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Style="font-size: 16px; color: rgba(255,255,255,0.15); flex-shrink: 0;" />
                </button>
            }
        </div>
    </DrawerSection>
}

@* ГўвЂќв‚¬ГўвЂќв‚¬ Member of (for individuals who belong to groups) ГўвЂќв‚¬ГўвЂќв‚¬ *@
@if (!Person.IsGroup && MemberOfGroups?.Count > 0)
{
    <DrawerSection Title="Member of" Icon="@Icons.Material.Outlined.Groups" DefaultOpen="true">
        <div class="pbd-members-list">
            @foreach (var group in MemberOfGroups)
            {
                <button class="pbd-work-row" @onclick="() => OnMemberClicked.InvokeAsync(group.Id)">
                    <div class="pbd-work-thumb" style="border-radius: 6px;">
                        <MudIcon Icon="@Icons.Material.Outlined.Groups" Style="font-size: 16px; color: rgba(255,255,255,0.2);" />
                    </div>
                    <div class="pbd-work-info">
                        <span class="pbd-work-title">@group.Name</span>
                        @if (!string.IsNullOrEmpty(group.DateRange))
                        {
                            <span class="pbd-work-type" style="color: rgba(255,255,255,0.35);">@group.DateRange</span>
                        }
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Style="font-size: 16px; color: rgba(255,255,255,0.15); flex-shrink: 0;" />
                </button>
            }
        </div>
    </DrawerSection>
}

@* ГўвЂќв‚¬ГўвЂќв‚¬ Character Roles ГўвЂќв‚¬ГўвЂќв‚¬ *@
@if (PersonCharacterRoles.Count > 0)
{
    <DrawerSection Title="@L["VaultDetail_SectionCharacterRoles"]" Icon="@Icons.Material.Outlined.TheaterComedy" DefaultOpen="false">
        @{
            var rolesByUniverse = PersonCharacterRoles
                .GroupBy(r => r.UniverseLabel ?? "Unknown Universe")
                .OrderBy(g => g.Key)
                .ToList();
        }
        @foreach (var univGroup in rolesByUniverse)
        {
            <div class="vdd-role-universe-group">
                <span class="vdd-role-universe-label">@univGroup.Key</span>
                <div class="vdd-roles-row">
                    @foreach (var role in univGroup)
                    {
                        <div class="vdd-role-item">
                            <div class="vdd-character-avatar vdd-character-avatar--sm">
                                @if (!string.IsNullOrEmpty(role.PortraitUrl))
                                {
                                    <img src="@role.PortraitUrl" alt="@role.CharacterName" loading="lazy" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                }
                            </div>
                            <span class="vdd-character-name" style="font-size: 11px;">@role.CharacterName</span>
                        </div>
                    }
                </div>
            </div>
        }
    </DrawerSection>
}

@* ГўвЂќв‚¬ГўвЂќв‚¬ History Timeline ГўвЂќв‚¬ГўвЂќв‚¬ *@
<DrawerSection Title="History" Icon="@Icons.Material.Outlined.History" DefaultOpen="false">
    <LibraryTimeline EntityId="@Person.Id" />
</DrawerSection>

@* ГўвЂќв‚¬ГўвЂќв‚¬ Assets ГўвЂќв‚¬ГўвЂќв‚¬ *@
<DrawerSection Title="@L["VaultDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
    <div class="vdd-assets">
        @* Headshot *@
        <div class="vdd-asset-row">
            <span class="vdd-asset-label">@L["VaultDetail_AssetHeadshot"]</span>
            <div class="vdd-asset-items">
                @if (!string.IsNullOrEmpty(Person.HeadshotUrl))
                {
                    <div class="vdd-asset-filled">
                        <img src="@Person.HeadshotUrl" alt="Headshot" class="vdd-asset-img" />
                        <span class="vdd-asset-source">@L["VaultDetail_AssetSourceProvider"]</span>
                    </div>
                }
                <div class="vdd-asset-slot">
                    <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                    <span class="vdd-asset-upload">@L["VaultDetail_AssetCustom"]</span>
                </div>
            </div>
        </div>
        @* Remaining types as upload-only *@
        @foreach (var assetType in new[] { "Banner", "Logo", "Backdrop" })
        {
            <div class="vdd-asset-row">
                <span class="vdd-asset-label">@assetType</span>
                <div class="vdd-asset-items">
                    <div class="vdd-asset-slot">
                        <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                        <span class="vdd-asset-upload">@L["VaultDetail_AssetUpload"]</span>
                    </div>
                </div>
            </div>
        }
    </div>
</DrawerSection>

@code {
    [Parameter, EditorRequired] public PersonListItemDto Person { get; set; } = null!;
    [Parameter] public PersonAliasesResponseDto? Aliases { get; set; }
    [Parameter] public List<CollectionViewModel>? PersonWorks { get; set; }
    [Parameter] public IReadOnlyList<CharacterRoleDto> PersonCharacterRoles { get; set; } = [];
    [Parameter] public List<GroupMemberView>? GroupMembers { get; set; }
    [Parameter] public List<GroupMemberView>? MemberOfGroups { get; set; }
    [Parameter] public EventCallback<Guid> OnPersonAliasClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnWorkClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnMemberClicked { get; set; }

    // Works grouped by the person's role for the "In Your Library" section.
    // PersonWorks from GetWorksByPersonAsync returns CollectionViewModel items which carry
    // the person's role via the CollectionType or DisplayName context.
    // For now we show all works under a single "Works" group; role-specific grouping
    // requires an API extension to return role per work.
    private List<(string RoleLabel, List<CollectionViewModel> Works)> _roleGroups = [];

    private bool _showAllWorks;
    private const int InitialWorksToShow = 5;

    protected override void OnParametersSet()
    {
        _showAllWorks = false;
        _roleGroups = BuildRoleGroups();
    }

    private List<(string RoleLabel, List<CollectionViewModel> Works)> BuildRoleGroups()
    {
        if (PersonWorks is null || PersonWorks.Count == 0)
            return [];

        // Group by media type to provide role-aware labelling where possible.
        // When the API is extended to return role-per-work, replace this with proper grouping.
        var groups = new List<(string, List<CollectionViewModel>)>();

        // Use the person's known roles to create meaningful headings
        var knownRoles = Person.Roles.Count > 0 ? Person.Roles : ["works"];
        var primaryRole = knownRoles[0].ToLowerInvariant();

        // Map role to a readable heading
        var roleHeading = primaryRole switch
        {
            "author"      => "Author of:",
            "narrator"    => "Narrator of:",
            "director"    => "Director of:",
            "illustrator" => "Illustrator of:",
            "composer"    => "Composer of:",
            _             => "In your library:",
        };

        groups.Add((roleHeading, PersonWorks));
        return groups;
    }
}

<style>
    /* ГўвЂќв‚¬ГўвЂќв‚¬ Biography text ГўвЂќв‚¬ГўвЂќв‚¬ */
    .pbd-biography {
        font-size: 13px;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.65);
        margin: 0;
    }

    /* ГўвЂќв‚¬ГўвЂќв‚¬ Occupation subtitle in header ГўвЂќв‚¬ГўвЂќв‚¬ */
    .pbd-occupation {
        font-size: 11px;
        font-style: italic;
        color: rgba(255, 255, 255, 0.4);
        margin-top: 2px;
    }

    /* ГўвЂќв‚¬ГўвЂќв‚¬ Last enriched tiny date ГўвЂќв‚¬ГўвЂќв‚¬ */
    .pbd-last-enriched {
        font-size: 10px;
        color: rgba(255, 255, 255, 0.2);
        margin-top: 4px;
    }

    /* ГўвЂќв‚¬ГўвЂќв‚¬ Social link buttons ГўвЂќв‚¬ГўвЂќв‚¬ */
    .pbd-social-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 4px 0;
    }

    .pbd-social-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.15s;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.5);
    }

    .pbd-social-btn:hover {
        background: rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.9);
    }

    /* ГўвЂќв‚¬ГўвЂќв‚¬ Role groups ГўвЂќв‚¬ГўвЂќв‚¬ */
