        font-size: 12px;
        font-style: italic;
        color: rgba(255, 255, 255, 0.25);
        margin: 0;
        padding: 4px 0;
    }

    /* ГўвЂќв‚¬ГўвЂќв‚¬ Show more button ГўвЂќв‚¬ГўвЂќв‚¬ */
