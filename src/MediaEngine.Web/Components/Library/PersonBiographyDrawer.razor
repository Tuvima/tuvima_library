@using MediaEngine.Web.Models.ViewDTOs
@namespace MediaEngine.Web.Components.Library
@inject IStringLocalizer<SharedStrings> L

@* -- Person Biography Drawer -------------------------------------------------
   Renders the full biography layout for a person inside a detail drawer.
   Can be used from LibraryDetailDrawer, future Work detail pages, or any
   context where a person is clicked.
   ---------------------------------------------------------------------------- *@

@* -- Biography section -- *@
<DrawerSection Title="Biography" Icon="@Icons.Material.Outlined.AutoStories" DefaultOpen="true">
    @if (!string.IsNullOrEmpty(Person.Biography))
    {
        <p class="pbd-biography">@Person.Biography</p>
    }
    else
    {
        <p class="pbd-empty-hint">No biography available yet. This person will be enriched during the next refresh cycle.</p>
    }
</DrawerSection>

@* -- Social Links -- *@
@{
    bool hasSocialLinks = !string.IsNullOrEmpty(Person.Biography); // fallback check via Occupation
}

@* -- In Your Library -- *@
<DrawerSection Title="In Your Library" Icon="@Icons.Material.Outlined.LibraryBooks" DefaultOpen="true">
    @if (_roleGroups.Count > 0)
    {
        @foreach (var (roleLabel, credits) in _roleGroups)
        {
            <div class="pbd-role-group">
                <span class="pbd-role-label">@roleLabel</span>
                <div class="pbd-works-list">
                    @{
                        var visibleCredits = _showAllWorks ? credits : credits.Take(InitialWorksToShow).ToList();
                        var remaining      = credits.Count - InitialWorksToShow;
                    }
                    @foreach (var credit in visibleCredits)
                    {
                        <AppNativeButton Class="pbd-work-row" OnClick="() => OnWorkClicked.InvokeAsync(credit.WorkId)">
                            <div class="pbd-work-thumb">
                                @if (!string.IsNullOrEmpty(credit.CoverUrl))
                                {
                                    <img src="@credit.CoverUrl" alt="" loading="lazy" class="pbd-work-thumb-img" />
                                }
                                else
                                {
                                    <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(credit.MediaType ?? "")" Class="tl-u-font-size-16px tl-u-color-tl-text-faint" />
                                }
                            </div>
                            <div class="pbd-work-info">
                                <span class="pbd-work-title">@credit.Title</span>
                                @if (!string.IsNullOrEmpty(BuildCreditMeta(credit)))
                                {
                                    <AppCssElement Tag="span" Class="pbd-work-type" Css="@($"color: {LibraryHelpers.GetMediaTypeColor(credit.MediaType ?? "")};")">
                                        @BuildCreditMeta(credit)
                                    </AppCssElement>
                                }
                                @if (!string.IsNullOrEmpty(BuildCreditSubtitle(credit)))
                                {
                                    <span class="pbd-work-type">@BuildCreditSubtitle(credit)</span>
                                }
                            </div>
                            <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Class="tl-u-font-size-16px tl-u-color-tl-border-strong tl-u-flex-shrink-0" />
                        </AppNativeButton>
                    }
                    @if (!_showAllWorks && remaining > 0)
                    {
                        <AppNativeButton Class="pbd-show-more-btn" OnClick="() => _showAllWorks = true">
                            Show @remaining more
                        </AppNativeButton>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p class="pbd-empty-hint">No works found in your library for this person.</p>
    }
</DrawerSection>

@* -- Linked Identities -- *@
<DrawerSection Title="@L["LibraryDetail_SectionLinkedIdentities"]" Icon="@Icons.Material.Outlined.Fingerprint" DefaultOpen="false">
    <div class="pbd-identities">
        <span class="vdd-field-label">@(Person.IsPseudonym ? L["LibraryDetail_FieldRealPeople"] : L["LibraryDetail_FieldPenNames"])</span>
        @if (Aliases is not null && Aliases.Aliases.Count > 0)
        {
            <div class="pbd-identity-items">
                @foreach (var alias in Aliases.Aliases.OrderByDescending(a => !string.IsNullOrEmpty(a.WikidataQid)))
                {
                    <AppNativeButton Class="vdd-identity-link" OnClick="() => OnPersonAliasClicked.InvokeAsync(alias.Id)">
                        <div class="vdd-alias-avatar">
                            @if (!string.IsNullOrEmpty(alias.HeadshotUrl))
                            {
                                <img src="@alias.HeadshotUrl" alt="@alias.Name" class="vdd-alias-avatar-img" loading="lazy" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.Person" Class="tl-u-font-size-14px tl-u-color-tl-text-faint" />
                            }
                        </div>
                        <div class="vdd-alias-info">
                            <span class="vdd-alias-name">@alias.Name</span>
                            <span class="vdd-alias-relationship">@(alias.Relationship == "real_person" ? "Real person" : "Pen name")</span>
                        </div>
                    </AppNativeButton>
                }
            </div>
        }
        else
        {
            <p class="pbd-empty-hint">@L["LibraryDetail_HintPenNames"]</p>
        }
    </div>
</DrawerSection>

@* -- Members (for groups/bands) -- *@
@if (Person.IsGroup && GroupMembers?.Count > 0)
{
    <DrawerSection Title="Members" Icon="@Icons.Material.Outlined.Groups" DefaultOpen="true">
        <div class="pbd-members-list">
            @foreach (var member in GroupMembers)
            {
                <AppNativeButton Class="pbd-work-row" OnClick="() => OnMemberClicked.InvokeAsync(member.Id)">
                    <div class="pbd-work-thumb tl-u-border-radius-50pct" >
                        <MudIcon Icon="@Icons.Material.Outlined.Person" Class="tl-u-font-size-16px tl-u-color-tl-text-faint" />
                    </div>
                    <div class="pbd-work-info">
                        <span class="pbd-work-title">@member.Name</span>
                        @if (!string.IsNullOrEmpty(member.DateRange))
                        {
                            <span class="pbd-work-type tl-u-color-tl-text-muted" >@member.DateRange</span>
                        }
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Class="tl-u-font-size-16px tl-u-color-tl-border-strong tl-u-flex-shrink-0" />
                </AppNativeButton>
            }
        </div>
    </DrawerSection>
}

@* -- Member of (for individuals who belong to groups) -- *@
@if (!Person.IsGroup && MemberOfGroups?.Count > 0)
{
    <DrawerSection Title="Member of" Icon="@Icons.Material.Outlined.Groups" DefaultOpen="true">
        <div class="pbd-members-list">
            @foreach (var group in MemberOfGroups)
            {
                <AppNativeButton Class="pbd-work-row" OnClick="() => OnMemberClicked.InvokeAsync(group.Id)">
                    <div class="pbd-work-thumb tl-u-border-radius-6px" >
                        <MudIcon Icon="@Icons.Material.Outlined.Groups" Class="tl-u-font-size-16px tl-u-color-tl-text-faint" />
                    </div>
                    <div class="pbd-work-info">
                        <span class="pbd-work-title">@group.Name</span>
                        @if (!string.IsNullOrEmpty(group.DateRange))
                        {
                            <span class="pbd-work-type tl-u-color-tl-text-muted" >@group.DateRange</span>
                        }
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Class="tl-u-font-size-16px tl-u-color-tl-border-strong tl-u-flex-shrink-0" />
                </AppNativeButton>
            }
        </div>
    </DrawerSection>
}

@* -- Character Roles -- *@
@if (PersonCharacterRoles.Count > 0)
{
    <DrawerSection Title="@L["LibraryDetail_SectionCharacterRoles"]" Icon="@Icons.Material.Outlined.TheaterComedy" DefaultOpen="false">
        @{
            var rolesByUniverse = PersonCharacterRoles
                .GroupBy(r => r.UniverseLabel ?? "Unknown Universe")
                .OrderBy(g => g.Key)
                .ToList();
        }
        @foreach (var univGroup in rolesByUniverse)
        {
            <div class="vdd-role-universe-group">
                <span class="vdd-role-universe-label">@univGroup.Key</span>
                <div class="vdd-roles-row">
                    @foreach (var role in univGroup)
                    {
                        <div class="vdd-role-item">
                            <div class="vdd-character-avatar vdd-character-avatar--sm">
                                @if (!string.IsNullOrEmpty(role.PortraitUrl))
                                {
                                    <img src="@role.PortraitUrl" alt="@role.CharacterName" loading="lazy" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.Person" Class="tl-u-font-size-16px tl-u-color-tl-border-strong" />
                                }
                            </div>
                            <span class="vdd-character-name tl-u-font-size-11px" >@role.CharacterName</span>
                        </div>
                    }
                </div>
            </div>
        }
    </DrawerSection>
}

@* -- History Timeline -- *@
<DrawerSection Title="History" Icon="@Icons.Material.Outlined.History" DefaultOpen="false">
    <LibraryTimeline EntityId="@Person.Id" />
</DrawerSection>

@* -- Assets -- *@
<DrawerSection Title="@L["LibraryDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
    <div class="vdd-assets">
        @* Headshot *@
        <div class="vdd-asset-row">
            <span class="vdd-asset-label">@L["LibraryDetail_AssetHeadshot"]</span>
            <div class="vdd-asset-items">
                @if (!string.IsNullOrEmpty(Person.HeadshotUrl))
                {
                    <div class="vdd-asset-filled">
                        <img src="@Person.HeadshotUrl" alt="Headshot" class="vdd-asset-img" />
                        <span class="vdd-asset-source">@L["LibraryDetail_AssetSourceProvider"]</span>
                    </div>
                }
                <div class="vdd-asset-slot">
                    <MudIcon Icon="@Icons.Material.Outlined.Add" Class="tl-u-font-size-16px tl-u-color-tl-border-strong" />
                    <span class="vdd-asset-upload">@L["LibraryDetail_AssetCustom"]</span>
                </div>
            </div>
        </div>
        @* Remaining types as upload-only *@
        @foreach (var assetType in new[] { "Banner", "Logo", "Background" })
        {
            <div class="vdd-asset-row">
                <span class="vdd-asset-label">@assetType</span>
                <div class="vdd-asset-items">
                    <div class="vdd-asset-slot">
                        <MudIcon Icon="@Icons.Material.Outlined.Add" Class="tl-u-font-size-16px tl-u-color-tl-border-strong" />
                        <span class="vdd-asset-upload">@L["LibraryDetail_AssetUpload"]</span>
                    </div>
                </div>
            </div>
        }
    </div>
</DrawerSection>

@code {
    [Parameter, EditorRequired] public PersonListItemDto Person { get; set; } = null!;
    [Parameter] public PersonAliasesResponseDto? Aliases { get; set; }
    [Parameter] public List<PersonLibraryCreditViewModel>? PersonCredits { get; set; }
    [Parameter] public IReadOnlyList<CharacterRoleDto> PersonCharacterRoles { get; set; } = [];
    [Parameter] public List<GroupMemberView>? GroupMembers { get; set; }
    [Parameter] public List<GroupMemberView>? MemberOfGroups { get; set; }
    [Parameter] public EventCallback<Guid> OnPersonAliasClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnWorkClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnMemberClicked { get; set; }

    private List<(string RoleLabel, List<PersonLibraryCreditViewModel> Credits)> _roleGroups = [];

    private bool _showAllWorks;
    private const int InitialWorksToShow = 5;

    protected override void OnParametersSet()
    {
        _showAllWorks = false;
        _roleGroups = BuildRoleGroups();
    }

    private List<(string RoleLabel, List<PersonLibraryCreditViewModel> Credits)> BuildRoleGroups()
    {
        if (PersonCredits is null || PersonCredits.Count == 0)
            return [];

        return PersonCredits
            .GroupBy(credit => $"{FormatRole(credit.Role)}  -  {FormatMediaType(credit.MediaType)}")
            .OrderBy(group => group.Key, StringComparer.OrdinalIgnoreCase)
            .Select(group => (group.Key, group.ToList()))
            .ToList();
    }

    private static string FormatRole(string? role) => role?.ToLowerInvariant() switch
    {
        "actor" => "Actor",
        "voice actor" => "Voice Actor",
        "director" => "Director",
        "artist" => "Artist",
        "performer" => "Performer",
        "author" => "Author",
        "narrator" => "Narrator",
        "illustrator" => "Illustrator",
        "composer" => "Composer",
        _ => role ?? "Credit",
    };

    private static string FormatMediaType(string? mediaType) => mediaType?.ToLowerInvariant() switch
    {
        "movies" => "Movies",
        "tv" => "TV",
        "music" => "Music",
        "books" => "Books",
        "audiobooks" => "Audiobooks",
        "comics" => "Comics",
        _ => mediaType ?? "Library",
    };

    private static string BuildCreditMeta(PersonLibraryCreditViewModel credit)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(credit.Year))
            parts.Add(credit.Year!);
        if (!string.IsNullOrWhiteSpace(credit.MediaType))
            parts.Add(FormatMediaType(credit.MediaType));
        return string.Join("  -  ", parts);
    }

    private static string? BuildCreditSubtitle(PersonLibraryCreditViewModel credit)
    {
        var characterNames = credit.Characters
            .Select(character => character.CharacterName)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Cast<string>()
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        return characterNames.Count > 0
            ? $"as {string.Join(", ", characterNames)}"
            : null;
    }
}
