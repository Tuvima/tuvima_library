        font-weight: 700;
        color: rgba(255, 255, 255, 0.8);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .pbd-work-type {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    /* ГўвЂќв‚¬ГўвЂќв‚¬ Identity items ГўвЂќв‚¬ГўвЂќв‚¬ */
    .pbd-identity-items {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-top: 6px;
    }

    /* ГўвЂќв‚¬ГўвЂќв‚¬ Identities container ГўвЂќв‚¬ГўвЂќв‚¬ */
