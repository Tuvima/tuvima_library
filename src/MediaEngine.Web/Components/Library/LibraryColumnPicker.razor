@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@inject IJSRuntime JS

@if (_initialized)
{
    <div class="vcp-overlay" @onclick="OnClose">
        <div class="vcp-panel" @onclick:stopPropagation="true">

            <div class="vcp-header">
                <span>Columns</span>
                <MudIconButton Icon="@Icons.Material.Outlined.Close"
                               Size="Size.Small"
                               Class="vcp-close-btn"
                               Color="Color.Inherit"
                               OnClick="OnClose"
                               aria-label="Close" />
            </div>

            <div class="vcp-list">
                @for (var i = 0; i < _orderedKeys.Count; i++)
                {
                    var index = i;
                    var key = _orderedKeys[index];
                    var col = _columnMap.GetValueOrDefault(key);
                    if (col is null)
                    {
                        continue;
                    }

                    var isVisible = _visibleSet.Contains(key);
                    var isDragging = _dragIndex == index;
                    var isDragOver = _dragOverIndex == index;

                    <div class="vcp-row @(isDragging ? "vcp-row--dragging" : "") @(isDragOver ? "vcp-row--dragover" : "")"
                         draggable="true"
                         @ondragstart="() => OnDragStart(index)"
                         @ondragend="OnDragEnd"
                         @ondragover:preventDefault="true"
                         @ondragover="() => OnDragOver(index)"
                         @ondrop:preventDefault="true"
                         @ondrop="() => OnDrop(index)">
                        <span class="vcp-drag-handle" title="Drag to reorder">
                            <MudIcon Icon="@Icons.Material.Outlined.DragIndicator" Style="font-size: 16px;" />
                        </span>

                        <span class="vcp-label">@col.Label</span>

                        <MudCheckBox T="bool"
                                     Value="@isVisible"
                                     ValueChanged="@(_ => ToggleColumn(key))"
                                     Class="vcp-toggle"
                                     Dense="true"
                                     Color="Color.Primary" />
                    </div>
                }
            </div>

            <div class="vcp-footer">
                <MudButton Variant="Variant.Text"
                           Color="Color.Inherit"
                           Class="vcp-reset-btn"
                           OnClick="ResetDefaults">
                    Reset to Defaults
                </MudButton>
            </div>

        </div>
    </div>
}

@code {
    [Parameter] public List<LibraryColumnDef> AllColumns { get; set; } = [];
    [Parameter] public List<string> VisibleKeys { get; set; } = [];
    [Parameter] public EventCallback<List<string>> VisibleKeysChanged { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string ViewKey { get; set; } = "all";

    private List<string> _orderedKeys = [];
    private HashSet<string> _visibleSet = [];
    private Dictionary<string, LibraryColumnDef> _columnMap = [];
    private bool _initialized;

    private int? _dragIndex;
    private int? _dragOverIndex;

    public override async Task SetParametersAsync(ParameterView parameters)
    {
        await base.SetParametersAsync(parameters);

        if (!_initialized && AllColumns.Count > 0)
        {
            _columnMap = AllColumns
                .Where(c => c.Key != "checkbox")
                .ToDictionary(c => c.Key, c => c);

            _orderedKeys = _columnMap.Keys.ToList();

            _visibleSet = VisibleKeys
                .Where(k => k != "checkbox" && _columnMap.ContainsKey(k))
                .ToHashSet();

            if (_visibleSet.Count == 0)
            {
                _visibleSet = _columnMap.Values
                    .Where(c => c.DefaultVisible)
                    .Select(c => c.Key)
                    .ToHashSet();
            }

            _initialized = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", $"media-columns-{ViewKey}");
            if (!string.IsNullOrEmpty(stored))
            {
                try
                {
                    var keys = System.Text.Json.JsonSerializer.Deserialize<List<string>>(stored);
                    if (keys is { Count: > 0 })
                    {
                        var knownKeys = new HashSet<string>(_columnMap.Keys);
                        var restoredOrder = keys
                            .Where(k => k != "checkbox" && knownKeys.Contains(k))
                            .ToList();

                        foreach (var key in _columnMap.Keys)
                        {
                            if (!restoredOrder.Contains(key))
                            {
                                restoredOrder.Add(key);
                            }
                        }

                        _orderedKeys = restoredOrder;

                        _visibleSet = keys
                            .Where(k => k != "checkbox" && knownKeys.Contains(k))
                            .ToHashSet();

                        await VisibleKeysChanged.InvokeAsync(GetVisibleKeys());
                        StateHasChanged();
                    }
                }
                catch
                {
                }
            }
        }
    }

    private async Task SaveToLocalStorage()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(GetVisibleKeys());
        await JS.InvokeVoidAsync("localStorage.setItem", $"media-columns-{ViewKey}", json);
    }

    private void OnDragStart(int index)
    {
        _dragIndex = index;
        _dragOverIndex = null;
    }

    private void OnDragOver(int index)
    {
        _dragOverIndex = index;
    }

    private void OnDragEnd()
    {
        _dragIndex = null;
        _dragOverIndex = null;
    }

    private async Task OnDrop(int index)
    {
        if (_dragIndex is null || _dragIndex == index)
        {
            _dragIndex = null;
            _dragOverIndex = null;
            return;
        }

        var item = _orderedKeys[_dragIndex.Value];
        _orderedKeys.RemoveAt(_dragIndex.Value);
        _orderedKeys.Insert(index, item);

        _dragIndex = null;
        _dragOverIndex = null;

        await SaveToLocalStorage();
        await VisibleKeysChanged.InvokeAsync(GetVisibleKeys());
    }

    private async Task ToggleColumn(string key)
    {
        if (_visibleSet.Contains(key))
        {
            _visibleSet.Remove(key);
        }
        else
        {
            _visibleSet.Add(key);
        }

        await SaveToLocalStorage();
        await VisibleKeysChanged.InvokeAsync(GetVisibleKeys());
    }

    private async Task ResetDefaults()
    {
        _orderedKeys = _columnMap.Keys.ToList();
        _visibleSet = _columnMap.Values
            .Where(c => c.DefaultVisible)
            .Select(c => c.Key)
            .ToHashSet();

        await JS.InvokeVoidAsync("localStorage.removeItem", $"media-columns-{ViewKey}");
        await VisibleKeysChanged.InvokeAsync(GetVisibleKeys());
    }

    private List<string> GetVisibleKeys()
    {
        var result = new List<string> { "checkbox" };
        result.AddRange(_orderedKeys.Where(k => _visibleSet.Contains(k)));
        return result;
    }
}

<style>
    .vcp-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        z-index: 1300;
    }

    .vcp-panel {
        position: absolute;
        right: 0;
        top: 64px;
        bottom: 0;
        width: min(280px, 85vw);
        background: #14181d;
        border-left: 1px solid var(--tl-border-subtle);
        display: flex;
        flex-direction: column;
        animation: vcp-slide-in 0.2s ease;
        overflow: hidden;
    }

    @@keyframes vcp-slide-in {
        from {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    .vcp-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px;
        border-bottom: 1px solid var(--tl-border-subtle);
        font-size: 14px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.9);
        flex-shrink: 0;
    }

    .vcp-close-btn {
        color: var(--tl-text-muted);
        padding: 4px 6px;
        border-radius: 4px;
        line-height: 1;
        transition: color 0.15s, background 0.15s;
    }

    .vcp-close-btn:hover {
        color: rgba(255, 255, 255, 0.8);
        background: var(--tl-border-subtle);
    }

    .vcp-list {
        flex: 1;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: var(--tl-border-subtle) transparent;
    }

    .vcp-list::-webkit-scrollbar {
        width: 4px;
    }

    .vcp-list::-webkit-scrollbar-track {
        background: transparent;
    }

    .vcp-list::-webkit-scrollbar-thumb {
        background: var(--tl-border-subtle);
        border-radius: 2px;
    }

    .vcp-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        border-bottom: 1px solid var(--tl-divider);
        user-select: none;
        transition: background 0.1s;
    }

    .vcp-row:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    .vcp-row--dragging {
        background: var(--tl-status-info-soft);
        border: 1px solid var(--tl-status-info-border);
        opacity: 0.7;
    }

    .vcp-row--dragover {
        background: var(--tl-status-info-soft);
        border-bottom: 1px solid var(--tl-status-info-border);
    }

    .vcp-drag-handle {
        display: flex;
        align-items: center;
        color: var(--tl-text-faint);
        cursor: grab;
        flex-shrink: 0;
        transition: color 0.15s;
    }

    .vcp-row:hover .vcp-drag-handle {
        color: rgba(255, 255, 255, 0.45);
    }

    .vcp-drag-handle:active {
        cursor: grabbing;
    }

    .vcp-label {
        flex: 1;
        font-size: 12px;
        font-weight: 600;
        color: var(--tl-text-secondary);
        letter-spacing: 0.01em;
    }

    .vcp-toggle {
        flex-shrink: 0;
        margin-right: -6px;
    }

    .vcp-footer {
        padding: 16px;
        border-top: 1px solid var(--tl-border-subtle);
        flex-shrink: 0;
    }

    .vcp-reset-btn {
        color: var(--tl-text-muted);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 6px 0;
        transition: color 0.15s;
    }

    .vcp-reset-btn:hover {
        color: rgba(255, 255, 255, 0.9);
    }

    @@media (max-width: 768px) {
        .vcp-panel {
            top: 0;
            width: 100%;
            max-width: 320px;
        }

        .vcp-row {
            padding: 10px 12px;
        }
    }
</style>

