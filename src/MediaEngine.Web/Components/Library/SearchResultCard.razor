@using MediaEngine.Domain.Constants
@namespace MediaEngine.Web.Components.Library

<div class="src-card @(IsSelected ? "src-card--selected" : "")" @onclick="OnClick">
    <div class="src-card-thumb">
        @if (Mode == SearchMode.Retail && !string.IsNullOrEmpty(CoverUrl))
        {
            <img src="@CoverUrl" alt="" loading="lazy" />
        }
        else if (Mode == SearchMode.Wikidata)
        {
            <div class="src-card-wikidata-icon">W</div>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Outlined.Image" Class="tl-u-font-size-20px tl-u-color-tl-border-strong" />
        }
    </div>
    <div class="src-card-body">
        <div class="src-card-headline">
            @if (Mode == SearchMode.Wikidata && !string.IsNullOrEmpty(Qid))
            {
                <span class="src-card-qid">@Qid</span>
                <span>  -  </span>
            }
            @GetFieldValue(DisplayConfig.Headline)
        </div>
        <div class="src-card-subline">
            @GetFieldValue(DisplayConfig.Subline)
            @{
                var tertiaryVal = GetFieldValue(DisplayConfig.Tertiary);
            }
            @if (!string.IsNullOrEmpty(tertiaryVal))
            {
                <span>  -  @tertiaryVal</span>
            }
        </div>
        @if (DisplayConfig.DetailFields.Count > 0)
        {
            <div class="src-card-details">
                @foreach (var field in DisplayConfig.DetailFields)
                {
                    var val = GetFieldValue(field);
                    if (!string.IsNullOrEmpty(val))
                    {
                        <span class="src-card-detail-item">@FormatFieldLabel(field): @val</span>
                    }
                }
            </div>
        }
        <div class="src-card-bridge">
            @foreach (var bridgeKey in DisplayConfig.BridgeLabels)
            {
                var bridgeVal = GetFieldValue(bridgeKey);
                if (!string.IsNullOrEmpty(bridgeVal))
                {
                    <span class="src-card-bridge-chip src-card-bridge-chip--present">@FormatFieldLabel(bridgeKey) OK</span>
                }
            }
            @if (!string.IsNullOrEmpty(ProviderName))
            {
                <span class="src-card-source">@ProviderName</span>
            }
        </div>
    </div>
    <div class="src-card-action">
        <AppNativeButton Class="src-card-select-btn" OnClick="OnSelect" StopPropagation="true">
            Select
        </AppNativeButton>
    </div>
</div>

@code {
    public enum SearchMode { Retail, Wikidata }

    [Parameter, EditorRequired] public SearchDisplayConfig DisplayConfig { get; set; } = default!;
    [Parameter] public SearchMode Mode { get; set; } = SearchMode.Retail;
    [Parameter] public Dictionary<string, string> Fields { get; set; } = [];
    [Parameter] public string? CoverUrl { get; set; }
    [Parameter] public string? Qid { get; set; }
    [Parameter] public string? ProviderName { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback OnSelect { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    private string? GetFieldValue(string fieldKey)
    {
        if (Fields.TryGetValue(fieldKey, out var val) && !string.IsNullOrWhiteSpace(val))
            return val.Length > 120 ? val[..117] + "..." : val;
        return null;
    }

    private static string FormatFieldLabel(string key) => key switch
    {
        "title" => "Title",
        "author" => "Author",
        "artist" => "Artist",
        "director" => "Director",
        "narrator" => "Narrator",
        "year" => "Year",
        "description" => "Description",
        "series" => "Series",
        "series_position" => "#",
        "publisher" => "Publisher",
        "page_count" => "Pages",
        "language" => "Language",
        "runtime" => "Runtime",
        "duration" => "Duration",
        "rating" => "Rating",
        "genre" => "Genre",
        "album" => "Album",
        "track_number" => "Track",
        "show_name" => "Show",
        "episode_title" => "Episode",
        "season_number" => "Season",
        "episode_number" => "Episode",
        "isbn" => "ISBN",
        "asin" => "ASIN",
        "tmdb_id" => "TMDB",
        "imdb_id" => "IMDb",
        "musicbrainz_id" => "MusicBrainz",
        "apple_books_id" => "Apple",
        "open_library_id" => "Open Library",
        "comic_vine_id" => "Comic Vine",
        "spotify_id" => "Spotify",
        "wikidata_qid" => "QID",
        "label" => "Name",
        "instance_of" => "Type",
        _ => key.Replace("_", " "),
    };
}