@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs

@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar

@if (_loading)
{
    <div class="vuu-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.15);" />
    </div>
}
else if (_unlinked.Count == 0)
{
    <div class="vuu-empty">
        <MudIcon Icon="@Icons.Material.Outlined.LinkOff" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">All identified works have universe properties.</p>
    </div>
}
else
{
    <div class="vuu-header">
        <span class="vuu-count">@_unlinked.Count works without universe data in Wikidata</span>
    </div>

    <table class="vuu-table">
        <thead>
            <tr class="vuu-thead-row">
                <th class="vuu-th" style="width: auto;">Title</th>
                <th class="vuu-th" style="width: 100px;">Type</th>
                <th class="vuu-th" style="width: 120px;">QID</th>
                <th class="vuu-th" style="width: 200px;">Why Unlinked</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _unlinked)
            {
                <tr class="vuu-row">
                    <td class="vuu-td">
                        <span class="vuu-title">@item.Title</span>
                    </td>
                    <td class="vuu-td">
                        <span class="vuu-type" style="color: @LibraryHelpers.GetMediaTypeColor(item.MediaType);">
                            @LibraryHelpers.FormatMediaType(item.MediaType)
                        </span>
                    </td>
                    <td class="vuu-td">
                        <a href="https://www.wikidata.org/wiki/@item.WikidataQid" target="_blank" rel="noopener"
                           class="vuu-qid">@item.WikidataQid</a>
                    </td>
                    <td class="vuu-td">
                        <span class="vuu-reason">No P179/P8345/P1434</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<UnlinkedWorkViewModel> _unlinked = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _unlinked = await ApiClient.GetUniverseUnlinkedAsync();
        _loading = false;
    }
}

<style>
    .vuu-loading, .vuu-empty {
        display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px;
    }
    .vuu-header { margin-bottom: 12px; }
    .vuu-count { font-size: 0.8rem; color: rgba(255,255,255,0.3); }
    .vuu-table { width: 100%; border-collapse: collapse; }
    .vuu-thead-row { border-bottom: 1px solid rgba(255,255,255,0.06); }
    .vuu-th {
        padding: 8px 12px; font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.05em; color: rgba(255,255,255,0.3); text-align: left;
    }
    .vuu-row {
        border-bottom: 1px solid rgba(255,255,255,0.03); transition: background 0.15s;
    }
    .vuu-row:hover { background: rgba(255,255,255,0.03); }
    .vuu-td { padding: 10px 12px; font-size: 0.85rem; }
    .vuu-title { color: rgba(255,255,255,0.8); }
    .vuu-type { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
    .vuu-qid {
        font-size: 0.75rem; color: rgba(92,159,202,0.7); text-decoration: none; font-family: monospace;
    }
    .vuu-qid:hover { color: rgba(92,159,202,1); }
    .vuu-reason { font-size: 0.75rem; color: rgba(255,255,255,0.25); }
</style>

