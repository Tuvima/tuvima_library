@using MediaEngine.Web.Models.ViewDTOs

@if (Items.Count == 0 && !Loading)
{
    <div class="vmg-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Inbox" Class="tl-u-font-size-3rem tl-u-opacity-0-15 tl-u-margin-bottom-12px" />
        <p class="tl-u-color-tl-text-faint tl-u-font-size-0-85rem">No items match your filters.</p>
    </div>
}
else
{
    <div class="vmg-grid">
        @foreach (var item in Items)
        {
            <LibraryMediaCard Item="@item"
                            @key="item.EntityId"
                            OnCardClicked="OnCardClicked"
                            OnDeleteClicked="OnDeleteClicked" />
        }
    </div>

    @if (Loading)
    {
        <div class="vmg-loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                 Class="tl-u-color-tl-border-strong" />
        </div>
    }
}

@code {
    [Parameter] public List<LibraryItemViewModel> Items { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<Guid> OnCardClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteClicked { get; set; }
}