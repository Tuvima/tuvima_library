<AppProgressBar Value="@(Confidence * 100)"
                AccentColor="@_fillColor"
                ShowValue="@ShowLabel"
                Title="@Confidence.ToString("F2")"
                Class="confidence-bar" />

@code {
    [Parameter] public double Confidence { get; set; }
    [Parameter] public bool ShowLabel { get; set; } = true;

    private string _fillColor => Confidence switch
    {
        >= 0.80 => "#5DCAA5",
        >= 0.60 => "#EF9F27",
        _ => "#A05050",
    };
}

