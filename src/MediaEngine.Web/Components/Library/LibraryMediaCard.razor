@using MediaEngine.Web.Models.ViewDTOs

<div class="vmc-card @(IsQuarantined ? "vmc-card--quarantined" : "")"
     @onclick="() => OnCardClicked.InvokeAsync(Item.EntityId)">

    @* -- Delete button (hover, top-right) -- *@
    @if (!NeedsAction)
    {
        <button class="vmc-delete-btn"
                @onclick="() => OnDeleteClicked.InvokeAsync(Item.EntityId)"
                @onclick:stopPropagation="true">
            <MudIcon Icon="@Icons.Material.Outlined.Delete" Style="font-size: 14px;" />
        </button>
    }

    @* -- Header: thumbnail + status -- *@
    <div class="vmc-header">
        <div class="vmc-thumb">
            @if (!string.IsNullOrEmpty(Item.CoverUrl))
            {
                <img src="@Item.CoverUrl" alt="@Item.Title" class="vmc-thumb-img" loading="lazy" />
            }
            else
            {
                <MudIcon Icon="@LibraryHelpers.GetMediaTypeIcon(Item.MediaType)"
                         Style="font-size: 24px; opacity: 0.2;" />
            }
        </div>
        <StatusPill Status="@Item.LibraryDisplayStatus" QuarantineDays="@Item.QuarantineDays" />
    </div>

    @* -- Title -- *@
    <h3 class="vmc-title @(Item.LibraryDisplayStatus == LibraryStatus.Quarantined ? "vmc-title--muted" : "")">@Item.Title</h3>

    @* -- Footer: pipeline + confidence -- *@
    <div class="vmc-footer">
        <div class="vmc-pipeline">
            <StageGate Stage="@Item.Stage1" />
            <StageGate Stage="@Item.Stage2" />
            <StageGate Stage="@Item.Stage3" IsLast="true" />
        </div>
        <ConfidenceBar Confidence="@Item.Confidence" />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public LibraryItemViewModel Item { get; set; } = default!;
    [Parameter] public EventCallback<Guid> OnCardClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteClicked { get; set; }

    private bool IsQuarantined => Item.LibraryDisplayStatus == LibraryStatus.Quarantined;
    private bool NeedsAction => Item.LibraryDisplayStatus == LibraryStatus.NeedsReview;
}

<style>
    .vmc-card {
        background: rgba(255, 255, 255, 0.015);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        overflow: hidden;
        padding: 20px;
        position: relative;
        transition: border-color 0.15s, box-shadow 0.15s;
        cursor: pointer;
    }

    .vmc-card:hover {
        border-color: rgba(255, 255, 255, 0.1);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    }

    .vmc-card--quarantined {
        opacity: 0.5;
    }

    /* -- Delete button -- */
    .vmc-delete-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        padding: 6px;
        border-radius: 8px;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.2);
        cursor: pointer;
        opacity: 0;
        transition: all 0.15s;
        z-index: 2;
    }

    .vmc-card:hover .vmc-delete-btn {
        opacity: 1;
    }

    .vmc-delete-btn:hover {
        color: #A05050;
        background: rgba(160, 80, 80, 0.1);
    }

    /* -- Header -- */
    .vmc-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
    }

    .vmc-thumb {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.02);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .vmc-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.6;
    }

    /* -- Title -- */
    .vmc-title {
        font-size: 14px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.85);
        margin: 0 0 4px 0;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .vmc-title--muted {
        color: rgba(255, 255, 255, 0.4);
    }

    /* -- Footer -- */
    .vmc-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
    }

    .vmc-pipeline {
        display: flex;
        transform: scale(0.9);
        transform-origin: left center;
    }
</style>
