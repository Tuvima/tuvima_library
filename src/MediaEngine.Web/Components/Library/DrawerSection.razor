@namespace MediaEngine.Web.Components.Library

<div class="drawer-section @(_hasProblem ? "drawer-section--problem" : "")">
    <AppButton Variant="Variant.Text"
               Color="Color.Inherit"
               Class="drawer-section-header"
               FullWidth="true"
               OnClick="Toggle">
        <div class="drawer-section-header-left">
            <MudIcon Icon="@Icon" Style="@($"font-size: 16px; color: {(_hasProblem ? "var(--tl-status-warning)" : "var(--tl-text-muted)")};")" />
            <span class="drawer-section-title @(_hasProblem ? "drawer-section-title--problem" : "")">@Title</span>
        </div>
        <MudIcon Icon="@(_isOpen ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                 Style="font-size: 16px; color: var(--tl-text-faint);" />
    </AppButton>
    @if (_isOpen)
    {
        <div class="drawer-section-body">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string Icon { get; set; } = Icons.Material.Outlined.Info;
    [Parameter] public bool DefaultOpen { get; set; } = true;
    [Parameter] public bool HasProblem { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _isOpen;
    private bool _hasProblem => HasProblem;

    protected override void OnInitialized()
    {
        _isOpen = DefaultOpen;
    }

    private void Toggle() => _isOpen = !_isOpen;
}