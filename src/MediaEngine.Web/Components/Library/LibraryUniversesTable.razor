@using MediaEngine.Web.Models.ViewDTOs

@inject IStringLocalizer<SharedStrings> L

@if (Universes.Count == 0 && !Loading)
{
    <div class="vut-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">@L["VaultUniverses_NoUniversesFound"]</p>
    </div>
}
else
{
    <div class="vut-table-wrap">
        <table class="vut-table">
            <thead>
                <tr class="vut-thead-row">
                    <th class="vut-th" style="width: 4%;"></th>
                    <th class="vut-th" style="width: 42%;">@L["VaultUniverses_ColUniverse"]</th>
                    <th class="vut-th vut-th--center vut-col-series" style="width: 13%;">@L["VaultUniverses_ColSeries"]</th>
                    <th class="vut-th" style="width: 25%;">@L["VaultUniverses_ColMediaAssets"]</th>
                    <th class="vut-th vut-th--center vut-col-people" style="width: 12%;">@L["VaultUniverses_ColPeople"]</th>
                    <th class="vut-th" style="width: 8%;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Universes)
                {
                    <tr class="vut-row" @onclick="() => OnRowClicked.InvokeAsync(u.Id)">
                        <td class="vut-td" style="width: 4%;"></td>
                        <td class="vut-td">
                            <div class="vut-name-cell">
                                <div class="vut-icon-box">
                                    <MudIcon Icon="@Icons.Material.Outlined.Public"
                                             Style="font-size: 16px; color: rgba(167,139,250,0.7);" />
                                </div>
                                <div style="min-width: 0; flex: 1;">
                                    <span class="vut-name">@u.DisplayName</span>
                                    @if (!string.IsNullOrWhiteSpace(u.Description))
                                    {
                                        <span class="vut-description">@u.Description</span>
                                    }
                                </div>
                            </div>
                        </td>
                        <td class="vut-td vut-td--center vut-col-series">
                            <span class="vut-count">@(u.IsParentCollection ? u.ChildCollectionCount : u.WorkCount)</span>
                        </td>
                        <td class="vut-td">
                            @if (!string.IsNullOrWhiteSpace(u.MediaTypes))
                            {
                                <span class="vut-media-text">@u.MediaTypes</span>
                            }
                            else
                            {
                                <span class="vut-media-text vut-media-text--empty">—</span>
                            }
                        </td>
                        <td class="vut-td vut-td--center vut-col-people">
                            @if (PeopleCount is not null && PeopleCount.TryGetValue(u.Id, out var pc) && pc > 0)
                            {
                                <span class="vut-count">@pc</span>
                            }
                            else
                            {
                                <span class="vut-count vut-count--muted">—</span>
                            }
                        </td>
                        <td class="vut-td vut-td--right">
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Loading)
    {
        <div class="vut-loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                 Style="color: rgba(255,255,255,0.15);" />
        </div>
    }
}

@code {
    [Parameter] public List<CollectionViewModel> Universes { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<Guid> OnRowClicked { get; set; }
    /// <summary>Optional map of Collection ID → people count. When null, the People column shows "—".</summary>
    [Parameter] public Dictionary<Guid, int>? PeopleCount { get; set; }
}

<style>
    /* ── Container ── */
    .vut-table-wrap {
        background: rgba(17, 20, 25, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        overflow: hidden;
        backdrop-filter: blur(8px);
    }

    .vut-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        table-layout: fixed;
    }

    /* ── Header ── */
    .vut-thead-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        background: rgba(15, 23, 42, 0.5);
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .vut-th {
        padding: 10px 12px;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(255, 255, 255, 0.3);
    }

    .vut-th--center { text-align: center; }

    /* ── Body rows ── */
    .vut-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        transition: background 0.15s ease;
        cursor: pointer;
    }

    .vut-row:last-child { border-bottom: none; }

    .vut-row:hover { background: rgba(255, 255, 255, 0.02); }

    .vut-td {
        padding: 10px 12px;
        vertical-align: middle;
        overflow: hidden;
    }

    .vut-td--center { text-align: center; }
    .vut-td--right  { text-align: right; }

    /* ── Name cell ── */
    .vut-name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* ── Icon box ── */
    .vut-icon-box {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: rgba(167, 139, 250, 0.08);
        border: 1px solid rgba(167, 139, 250, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    /* ── Text ── */
    .vut-name {
        font-size: 12px;
        font-weight: 700;
        color: white;
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: color 0.15s;
    }

    .vut-row:hover .vut-name { color: #A78BFA; }

    .vut-description {
        font-size: 10px;
        font-style: italic;
        color: rgba(255, 255, 255, 0.35);
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vut-count {
        font-size: 12px;
        font-weight: 900;
        color: rgba(255, 255, 255, 0.85);
    }

    .vut-count--muted {
        color: rgba(255, 255, 255, 0.25);
        font-weight: 700;
    }

    .vut-media-text {
        font-size: 10px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.45);
        font-style: italic;
    }

    .vut-media-text--empty {
        color: rgba(255, 255, 255, 0.2);
    }

    /* ── Loading / empty ── */
    .vut-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 0;
    }

    .vut-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    @@media (max-width: 768px) {
        .vut-col-series,
        .vut-col-people { display: none; }

        .vut-td {
            padding: 6px 12px;
        }
    }
</style>
