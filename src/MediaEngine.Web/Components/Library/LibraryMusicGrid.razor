@namespace MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@using Microsoft.Extensions.Localization
@using MediaEngine.Web.Resources
@inject IStringLocalizer<SharedStrings> L

@if (Loading)
{
    <div class="vmug-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Small"
                             Class="tl-u-color-tl-border-strong" />
    </div>
}
else if (_albums.Count == 0)
{
    <div class="vmug-empty">
        <MudIcon Icon="@Icons.Material.Outlined.MusicNote"
                 Class="tl-u-font-size-3rem tl-u-opacity-0-15 tl-u-margin-bottom-12px" />
        <p class="tl-u-color-tl-text-faint tl-u-font-size-0-85rem">No albums found.</p>
    </div>
}
else
{
    <AppCssElement Tag="div" Class="vmug-grid" Css="@($"--card-size: {CardSize}px;")">
        @foreach (var album in _albums)
        {
            var firstItem = album.Value[0];
            var trackCount = album.Value.Count;
            var artistName = firstItem.Artist ?? firstItem.Author ?? "";

            <div class="vmug-card" @onclick="() => HandleClick(album.Key, firstItem.EntityId)">
                <div class="vmug-cover">
                    @if (!string.IsNullOrEmpty(firstItem.CoverUrl))
                    {
                        <img src="@firstItem.CoverUrl" alt="@album.Key" loading="lazy" />
                    }
                    else
                    {
                        <div class="vmug-cover-placeholder">
                            <MudIcon Icon="@Icons.Material.Outlined.Album"
                                     Class="tl-u-font-size-2-5rem tl-u-opacity-0-15" />
                        </div>
                    }
                </div>
                <p class="vmug-album-name" title="@album.Key">@album.Key</p>
                @if (!string.IsNullOrEmpty(artistName))
                {
                    <p class="vmug-artist" title="@artistName">@artistName</p>
                }
                <p class="vmug-track-count">@trackCount @(trackCount == 1 ? "track" : "tracks")</p>
            </div>
        }
    </AppCssElement>
}

@code {
    [Parameter] public List<LibraryItemViewModel> Items { get; set; } = [];
    [Parameter] public int CardSize { get; set; } = 180;
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<Guid> OnCardClicked { get; set; }
    [Parameter] public EventCallback<string> OnAlbumNameClicked { get; set; }

    private Dictionary<string, List<LibraryItemViewModel>> _albums = new();

    protected override void OnParametersSet()
    {
        _albums = Items
            .GroupBy(i => string.IsNullOrWhiteSpace(i.Album)
                ? "Unknown Album"
                : i.Album!)
            .OrderBy(g => g.Key == "Unknown Album" ? 1 : 0)
            .ThenBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private async Task HandleClick(string albumName, Guid firstItemId)
    {
        if (OnAlbumNameClicked.HasDelegate && !string.IsNullOrWhiteSpace(albumName) && albumName != "Unknown Album")
            await OnAlbumNameClicked.InvokeAsync(albumName);
        else if (OnCardClicked.HasDelegate)
            await OnCardClicked.InvokeAsync(firstItemId);
    }
}