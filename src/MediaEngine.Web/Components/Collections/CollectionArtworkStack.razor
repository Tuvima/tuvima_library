@namespace MediaEngine.Web.Components.Collections
@using MediaEngine.Web.Models.ViewDTOs

<div class="@RootClass">
    @if (ShowPinnedArtwork)
    {
        <img class="collection-artwork-stack__pinned" src="@Collection.SquareArtworkUrl" alt="" />
    }
    else if (ArtworkItems.Count > 0)
    {
        @foreach (var item in ArtworkItems)
        {
            <div class="collection-artwork-stack__tile collection-artwork-stack__tile--@NormalizeShape(item.ArtworkShape)" title="@item.Title">
                @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                {
                    <img src="@item.CoverUrl" alt="" />
                }
                else
                {
                    <MudIcon Icon="@IconForMediaType(item.MediaType)" />
                }
            </div>
        }
    }
    else
    {
        <div class="collection-artwork-stack__fallback">
            <MudIcon Icon="@FallbackIcon" />
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public CollectionManagementCatalogViewModel Collection { get; set; } = default!;
    [Parameter] public string? Mode { get; set; }
    [Parameter] public bool Large { get; set; }
    [Parameter] public bool PreferPinnedArtwork { get; set; } = true;

    private bool ShowPinnedArtwork => PreferPinnedArtwork && !string.IsNullOrWhiteSpace(Collection.SquareArtworkUrl);
    private IReadOnlyList<CollectionArtworkItemViewModel> ArtworkItems => Collection.ArtworkItems.Take(4).ToList();
    private string EffectiveMode => Mode ?? ModeForCollection(Collection);
    private string RootClass => string.Join(" ", new[]
    {
        "collection-artwork-stack",
        $"collection-artwork-stack--{EffectiveMode}",
        Large ? "collection-artwork-stack--large" : null,
        ShowPinnedArtwork ? "collection-artwork-stack--pinned" : null,
    }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private string FallbackIcon => EffectiveMode switch
    {
        "read-stack" => Icons.Material.Outlined.MenuBook,
        "listen-grid" => Icons.Material.Outlined.Album,
        "watch-strip" => Icons.Material.Outlined.Movie,
        _ => Icons.Material.Outlined.CollectionsBookmark,
    };

    public static string ModeForCollection(CollectionManagementCatalogViewModel collection) => collection.PrimaryLane switch
    {
        "Read" => "read-stack",
        "Listen" => "listen-grid",
        "Watch" => "watch-strip",
        _ => "cross-media-collage",
    };

    private static string NormalizeShape(string? shape) => shape switch
    {
        "portrait" => "portrait",
        "landscape" => "landscape",
        _ => "square",
    };

    private static string IconForMediaType(string? mediaType)
    {
        if (string.Equals(mediaType, "Music", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Audio", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Audiobooks", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Audiobook", StringComparison.OrdinalIgnoreCase))
            return Icons.Material.Outlined.Album;

        if (string.Equals(mediaType, "Books", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Book", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Comics", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Comic", StringComparison.OrdinalIgnoreCase))
            return Icons.Material.Outlined.MenuBook;

        if (string.Equals(mediaType, "Movies", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Movie", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "TV", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Video", StringComparison.OrdinalIgnoreCase))
            return Icons.Material.Outlined.Movie;

        return Icons.Material.Outlined.CollectionsBookmark;
    }
}
