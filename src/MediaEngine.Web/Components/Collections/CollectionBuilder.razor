@namespace MediaEngine.Web.Components.Collections
@using MediaEngine.Web.Models.ViewDTOs

@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar

<div class="collection-builder-overlay" @onclick="OnCancel">
    <div class="collection-builder" @onclick:stopPropagation>
        <h2 class="collection-builder-title">@(EditingCollection is not null ? "Edit Collection" : "New Collection")</h2>

        <MudTextField @bind-Value="_name"
                      Placeholder="Collection name..."
                      Variant="Variant.Outlined"
                      Immediate="true"
                      Class="collection-builder-field" />

        <MudTextField @bind-Value="_description"
                      Placeholder="Description (optional)"
                      Variant="Variant.Outlined"
                      Immediate="true"
                      Lines="3"
                      Class="collection-builder-field" />

        <div class="collection-builder-grid">
            <MudSelect T="string"
                       Value="_collectionType"
                       ValueChanged="OnCollectionTypeChanged"
                       Label="Collection type"
                       Variant="Variant.Outlined"
                       Disabled="@(EditingCollection is not null)"
                       Class="collection-builder-field">
                <MudSelectItem T="string" Value="@("Custom")">Collection</MudSelectItem>
                <MudSelectItem T="string" Value="@("Playlist")">Playlist</MudSelectItem>
            </MudSelect>

            <MudTextField @bind-Value="_iconName"
                          Placeholder="Icon name (optional)"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Class="collection-builder-field" />
        </div>

        <div class="collection-builder-helper collection-builder-helper--tight">
            @if (string.Equals(_collectionType, "Playlist", StringComparison.OrdinalIgnoreCase))
            {
                <span>Playlists are intended for manual membership. Rules are disabled for this collection type.</span>
            }
            else
            {
                <span>Collections can stay manual or use live rules to populate themselves.</span>
            }
        </div>

        <div class="collection-builder-section">
            <div class="collection-builder-section-title">Visibility</div>
            <MudRadioGroup T="string" @bind-Value="_visibility">
                <MudRadio T="string" Value="@("private")" Color="Color.Primary" Dense="true">
                    Private
                </MudRadio>
                @if (CanManageSharedCollections)
                {
                    <MudRadio T="string" Value="@("shared")" Color="Color.Primary" Dense="true">
                        Shared with all users
                    </MudRadio>
                }
            </MudRadioGroup>
            <div class="collection-builder-helper">
                @if (_visibility == "shared")
                {
                    <span>Shared collections are visible to every profile and editable by administrators or curators.</span>
                }
                else
                {
                    <span>Private collections belong to the active profile only.</span>
                }
            </div>
        </div>

        <div class="collection-builder-section">
            <MudCheckBox @bind-Value="_rulesEnabled" Color="Color.Error" Dense="true"
                         Disabled="@string.Equals(_collectionType, "Playlist", StringComparison.OrdinalIgnoreCase)"
                         Label="Build this collection from matching rules" />
        </div>

        @if (_rulesEnabled)
        {
            <div class="collection-builder-rules">
                @for (var i = 0; i < _rules.Count; i++)
                {
                    var idx = i;
                    var rule = _rules[idx];

                    <div class="collection-builder-rule-row">
                        <MudSelect T="string"
                                   Value="rule.Field"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Style="min-width: 140px;"
                                   ValueChanged="(string value) => { rule.Field = value; _ = OnRuleChanged(); }">
                            <MudSelectItem T="string" Value="@("media_type")">Media Type</MudSelectItem>
                            <MudSelectItem T="string" Value="@("genre")">Genre</MudSelectItem>
                            <MudSelectItem T="string" Value="@("author")">Author</MudSelectItem>
                            <MudSelectItem T="string" Value="@("director")">Director</MudSelectItem>
                            <MudSelectItem T="string" Value="@("artist")">Artist</MudSelectItem>
                            <MudSelectItem T="string" Value="@("narrator")">Narrator</MudSelectItem>
                            <MudSelectItem T="string" Value="@("album")">Album</MudSelectItem>
                            <MudSelectItem T="string" Value="@("series")">Series</MudSelectItem>
                            <MudSelectItem T="string" Value="@("show_name")">Show</MudSelectItem>
                            <MudSelectItem T="string" Value="@("year")">Year</MudSelectItem>
                            <MudSelectItem T="string" Value="@("decade")">Decade</MudSelectItem>
                            <MudSelectItem T="string" Value="@("vibe")">Vibe</MudSelectItem>
                            <MudSelectItem T="string" Value="@("publisher")">Publisher</MudSelectItem>
                            <MudSelectItem T="string" Value="@("language")">Language</MudSelectItem>
                            <MudSelectItem T="string" Value="@("added_within_days")">Added Within</MudSelectItem>
                            <MudSelectItem T="string" Value="@("provider_rating")">Rating</MudSelectItem>
                        </MudSelect>

                        <MudSelect T="string"
                                   @bind-Value="rule.Op"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Style="min-width: 120px;">
                            @foreach (var op in GetOperatorsForField(rule.Field))
                            {
                                <MudSelectItem T="string" Value="@op.Key">@op.Label</MudSelectItem>
                            }
                        </MudSelect>

                        <MudTextField @bind-Value="rule.Value"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Style="flex: 1; min-width: 120px;"
                                      Placeholder="Value..."
                                      Immediate="true"
                                      DebounceInterval="500"
                                      OnDebounceIntervalElapsed="_ => RunPreview()" />

                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                       OnClick="() => AddRule(idx)" aria-label="Add rule" />
                        <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                       Disabled="@(_rules.Count == 1)"
                                       OnClick="() => RemoveRule(idx)" aria-label="Remove rule" />
                    </div>
                }
            </div>

            <div class="collection-builder-section">
                <span class="collection-builder-inline-label">Match:</span>
                <MudRadioGroup T="string" @bind-Value="_matchMode">
                    <MudRadio T="string" Value="@("all")" Color="Color.Primary" Dense="true">ALL rules</MudRadio>
                    <MudRadio T="string" Value="@("any")" Color="Color.Primary" Dense="true">ANY rule</MudRadio>
                </MudRadioGroup>
            </div>
        }

        <div class="collection-builder-section">
            <MudCheckBox @bind-Value="_liveUpdating" Color="Color.Error" Dense="true"
                         Label="Live updating" />
        </div>

        @if (_previewResult is not null)
        {
            <div class="collection-builder-preview">
                <div class="collection-builder-preview-header">
                    <span>@_previewResult.Count items match</span>
                </div>
                @foreach (var item in _previewResult.Items.Take(10))
                {
                    <div class="collection-builder-preview-item">
                        <span class="collection-builder-preview-type">@item.MediaType[..Math.Min(2, item.MediaType.Length)]</span>
                        <span class="collection-builder-preview-title">@item.Title</span>
                        @if (!string.IsNullOrWhiteSpace(item.Year))
                        {
                            <span class="collection-builder-preview-year">(@item.Year)</span>
                        }
                    </div>
                }
            </div>
        }

        <div class="collection-builder-actions">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       OnClick="SaveCollection"
                       Disabled="_saving"
                       Style="flex: 1;">
                @(EditingCollection is not null ? "Save" : "Create Collection")
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       OnClick="OnCancel"
                       Style="flex: 1;">
                Cancel
            </MudButton>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public CollectionListItemViewModel? EditingCollection { get; set; }
    [Parameter] public Guid? ActiveProfileId { get; set; }
    [Parameter] public bool CanManageSharedCollections { get; set; }

    private string _name = string.Empty;
    private string? _description;
    private string? _iconName;
    private string _collectionType = "Custom";
    private string _visibility = "private";
    private bool _rulesEnabled = true;
    private List<CollectionRulePredicateViewModel> _rules = [new()];
    private string _matchMode = "all";
    private bool _liveUpdating = true;
    private bool _saving;
    private CollectionPreviewResult? _previewResult;

    protected override void OnInitialized()
    {
        if (EditingCollection is null)
            return;

        _name = EditingCollection.Name;
        _description = EditingCollection.Description;
        _iconName = EditingCollection.IconName;
        _collectionType = EditingCollection.CollectionType;
        _visibility = EditingCollection.Visibility;
        _matchMode = EditingCollection.MatchMode;
        _liveUpdating = EditingCollection.LiveUpdating;
        _rulesEnabled = !string.Equals(_collectionType, "Playlist", StringComparison.OrdinalIgnoreCase);

        if (string.IsNullOrWhiteSpace(EditingCollection.RuleJson))
            return;

        try
        {
            var parsed = System.Text.Json.JsonSerializer.Deserialize<List<CollectionRulePredicateViewModel>>(
                EditingCollection.RuleJson,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (parsed is { Count: > 0 })
            {
                _rules = parsed;
                if (!string.Equals(_collectionType, "Playlist", StringComparison.OrdinalIgnoreCase))
                    _rulesEnabled = true;
            }
        }
        catch
        {
            // Keep defaults when an older rule payload cannot be parsed.
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _rules.Any(rule => !string.IsNullOrWhiteSpace(rule.Value)))
            await RunPreview();
    }

    private void AddRule(int afterIndex) =>
        _rules.Insert(afterIndex + 1, new CollectionRulePredicateViewModel());

    private void RemoveRule(int index)
    {
        if (_rules.Count > 1)
            _rules.RemoveAt(index);
    }

    private async Task OnRuleChanged() => await RunPreview();

    private Task OnCollectionTypeChanged(string value)
    {
        _collectionType = value;
        if (string.Equals(_collectionType, "Playlist", StringComparison.OrdinalIgnoreCase))
        {
            _rulesEnabled = false;
            _previewResult = null;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task RunPreview()
    {
        if (!_rulesEnabled)
        {
            _previewResult = null;
            return;
        }

        var validRules = _rules
            .Where(rule => !string.IsNullOrWhiteSpace(rule.Value))
            .ToList();

        if (validRules.Count == 0)
        {
            _previewResult = null;
            return;
        }

        _previewResult = await ApiClient.PreviewCollectionRulesAsync(validRules, _matchMode, 20);
        StateHasChanged();
    }

    private async Task SaveCollection()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            Snackbar.Add("Please enter a name for the collection.", Severity.Warning);
            return;
        }

        if (!CanManageSharedCollections)
            _visibility = "private";

        if (!string.Equals(_visibility, "shared", StringComparison.OrdinalIgnoreCase) && !ActiveProfileId.HasValue)
        {
            Snackbar.Add("An active profile is required to save a private collection.", Severity.Warning);
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            var rules = _rulesEnabled
                ? _rules.Where(rule => !string.IsNullOrWhiteSpace(rule.Value)).ToList()
                : [];

            var ok = EditingCollection is not null
                ? await ApiClient.UpdateCollectionAsync(
                    EditingCollection.Id,
                    _name,
                    _description,
                    _iconName,
                    rules,
                    _matchMode,
                    _visibility,
                    _liveUpdating,
                    null,
                    null,
                    ActiveProfileId)
                : await ApiClient.CreateCollectionAsync(
                    _name,
                    _description,
                    _iconName,
                    _collectionType,
                    rules,
                    _matchMode,
                    null,
                    "desc",
                    _liveUpdating,
                    _visibility,
                    ActiveProfileId);

            if (!ok)
            {
                Snackbar.Add("Failed to save collection.", Severity.Error);
                return;
            }

            Snackbar.Add(
                EditingCollection is not null
                    ? $"Collection \"{_name}\" updated."
                    : $"Collection \"{_name}\" created.",
                Severity.Success);

            await OnSave.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save collection: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private sealed record OpDef(string Key, string Label);

    private static List<OpDef> GetOperatorsForField(string field) => field switch
    {
        "media_type" => [new("eq", "is"), new("neq", "is not")],
        "year" or "provider_rating" or "added_within_days" =>
            [new("eq", "is"), new("gt", "greater than"), new("lt", "less than"), new("between", "between"), new("gte", "at least"), new("lte", "at most")],
        "decade" => [new("eq", "is")],
        _ => [new("eq", "is"), new("neq", "is not"), new("contains", "contains")],
    };
}

<style>
    .collection-builder-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1500;
        backdrop-filter: blur(4px);
    }

    .collection-builder {
        background: #161b29;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 18px;
        padding: 24px;
        width: min(760px, 96vw);
        max-height: 88vh;
        overflow-y: auto;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
    }

    .collection-builder-title {
        margin: 0 0 18px;
        color: rgba(248, 248, 248, 0.95);
        font-family: 'Montserrat', sans-serif;
        font-size: 1.2rem;
        font-weight: 700;
    }

    .collection-builder-field {
        margin-bottom: 14px;
    }

    .collection-builder-section {
        margin-bottom: 16px;
    }

    .collection-builder-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .collection-builder-section-title {
        margin-bottom: 8px;
        color: rgba(248, 248, 248, 0.78);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.86rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .collection-builder-helper,
    .collection-builder-inline-label {
        color: rgba(248, 248, 248, 0.55);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.82rem;
    }

    .collection-builder-helper--tight {
        margin-top: -6px;
        margin-bottom: 14px;
    }

    .collection-builder-rules {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 14px;
    }

    .collection-builder-rule-row {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .collection-builder-preview {
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 14px;
        padding: 14px;
        background: rgba(255, 255, 255, 0.02);
        margin-bottom: 16px;
    }

    .collection-builder-preview-header {
        margin-bottom: 10px;
        color: rgba(248, 248, 248, 0.76);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.86rem;
        font-weight: 700;
    }

    .collection-builder-preview-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
        color: rgba(248, 248, 248, 0.78);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.84rem;
    }

    .collection-builder-preview-type {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        font-size: 0.72rem;
        font-weight: 700;
    }

    .collection-builder-preview-title {
        flex: 1;
        min-width: 0;
    }

    .collection-builder-preview-year {
        color: rgba(248, 248, 248, 0.45);
    }

    .collection-builder-actions {
        display: flex;
        gap: 12px;
        margin-top: 18px;
    }

    @@media (max-width: 900px) {
        .collection-builder-grid {
            grid-template-columns: 1fr;
        }

        .collection-builder-rule-row {
            flex-direction: column;
            align-items: stretch;
        }

        .collection-builder-actions {
            flex-direction: column;
        }
    }
</style>
