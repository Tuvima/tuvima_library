@namespace MediaEngine.Web.Components.Collections
@using MediaEngine.Web.Models.ViewDTOs

<button type="button" class="@RootClass" @onclick="Select">
    <div class="collection-hub-card__art">
        <CollectionArtworkStack Collection="Collection" Mode="@ArtworkMode" PreferPinnedArtwork="@PreferPinnedArtwork" />
    </div>

    <div class="collection-hub-card__body">
        <div class="collection-hub-card__title-row">
            <h3>@Collection.Name</h3>
            <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Size="Size.Small" />
        </div>
        @if (!string.IsNullOrWhiteSpace(Collection.Description))
        {
            <p>@Collection.Description</p>
        }
        @if (UseListPreview && Collection.ArtworkItems.Count > 0)
        {
            <div class="collection-hub-card__preview-list">
                @foreach (var item in Collection.ArtworkItems.Take(3))
                {
                    <div class="collection-hub-card__preview-row">
                        @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                        {
                            <img src="@item.CoverUrl" alt="" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Album" Size="Size.Small" />
                        }
                        <span>@item.Title</span>
                    </div>
                }
            </div>
        }
        <CollectionHubStats Collection="Collection" />
        <div class="collection-hub-card__meta">
            <span>@Collection.FamilyLabel</span>
            <span>@UpdatedLabel</span>
        </div>
    </div>
</button>

@code {
    [Parameter, EditorRequired] public CollectionManagementCatalogViewModel Collection { get; set; } = default!;
    [Parameter] public bool Selected { get; set; }
    [Parameter] public EventCallback<CollectionManagementCatalogViewModel> OnSelect { get; set; }

    private string RootClass => string.Join(" ", new[]
    {
        "collection-hub-card",
        "tl-card",
        Selected ? "collection-hub-card--selected" : null,
        $"collection-hub-card--{DisplayStyle}",
    }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private string Icon => Collection.CollectionType switch
    {
        "System" => Icons.Material.Outlined.BookmarkAdded,
        "Playlist" => Icons.Material.Outlined.QueueMusic,
        "Smart" => Icons.Material.Outlined.AutoAwesome,
        "Mix" => Icons.Material.Outlined.GraphicEq,
        _ => Icons.Material.Outlined.CollectionsBookmark,
    };

    private string DisplayStyle => Collection.PrimaryLane switch
    {
        "Listen" => "list",
        "Watch" => "watch",
        "Read" => "read",
        _ => "mixed",
    };

    private bool UseListPreview => Collection.CollectionType == "Playlist" || Collection.PrimaryLane == "Listen";
    private bool PreferPinnedArtwork => !UseListPreview;
    private string ArtworkMode => Collection.PrimaryLane switch
    {
        "Listen" => "listen-grid",
        "Read" => "read-stack",
        "Watch" => "watch-strip",
        _ => "cross-media-collage",
    };

    private string UpdatedLabel
    {
        get
        {
            var timestamp = Collection.ModifiedAt ?? Collection.CreatedAt;
            var age = DateTimeOffset.Now - timestamp;
            if (age.TotalDays < 1)
                return "Updated today";

            var days = Math.Max(1, (int)Math.Round(age.TotalDays));
            return $"Updated {days} day{(days == 1 ? string.Empty : "s")} ago";
        }
    }

    private Task Select() => OnSelect.InvokeAsync(Collection);
}
