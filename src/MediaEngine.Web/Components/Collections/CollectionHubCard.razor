@namespace MediaEngine.Web.Components.Collections
@using MediaEngine.Web.Models.ViewDTOs

<button type="button" class="@RootClass" style="@RootStyle" @onclick="Select">
    <div class="collection-hub-card__art">
        <CollectionArtworkStack Collection="Collection" Mode="@ArtworkMode" PreferPinnedArtwork="@PreferPinnedArtwork" />
        <div class="collection-hub-card__overlay">
            <h3>@Collection.Name</h3>
            <span>
                <MudIcon Icon="@CountIcon" Size="Size.Small" />
                @Collection.ItemCount item@(Collection.ItemCount == 1 ? string.Empty : "s")
            </span>
        </div>
    </div>
</button>

@code {
    [Parameter, EditorRequired] public CollectionManagementCatalogViewModel Collection { get; set; } = default!;
    [Parameter] public bool Selected { get; set; }
    [Parameter] public EventCallback<CollectionManagementCatalogViewModel> OnSelect { get; set; }

    private string RootClass => string.Join(" ", new[]
    {
        "collection-hub-card",
        "tl-card",
        Selected ? "collection-hub-card--selected" : null,
        $"collection-hub-card--{DisplayStyle}",
    }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private string RootStyle => $"--collection-card-accent: {AccentColor}; --collection-card-accent-2: {SecondaryAccentColor};";

    private string DisplayStyle => Collection.PrimaryLane switch
    {
        "Listen" => "listen",
        "Watch" => "watch",
        "Read" => "read",
        _ => "mixed",
    };

    private bool PreferPinnedArtwork => false;
    private string ArtworkMode => "landscape-cascade";
    private string AccentColor => Collection.PrimaryLane switch
    {
        "Listen" => "var(--tl-media-audio)",
        "Read" => "var(--tl-media-book)",
        "Watch" => "var(--tl-media-video)",
        _ => "var(--tl-accent-primary)",
    };

    private string SecondaryAccentColor => Collection.PrimaryLane switch
    {
        "Listen" => "var(--tl-media-book)",
        "Read" => "var(--tl-media-comic)",
        "Watch" => "var(--tl-media-comic)",
        _ => "var(--tl-media-audio)",
    };

    private string CountIcon => Collection.PrimaryLane switch
    {
        "Listen" => Icons.Material.Outlined.MusicNote,
        "Read" => Icons.Material.Outlined.MenuBook,
        "Watch" => Icons.Material.Outlined.LocalMovies,
        _ => Icons.Material.Outlined.CollectionsBookmark,
    };

    private Task Select() => OnSelect.InvokeAsync(Collection);
}
