@namespace MediaEngine.Web.Components.Collections
@using MediaEngine.Web.Models.ViewDTOs

<section class="collection-hub-section">
    <div class="collection-hub-section__header">
        <div>
            <h2>@Title</h2>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p>@Description</p>
            }
        </div>
        <span class="tl-chip-muted">@Collections.Count item(s)</span>
    </div>

    @if (Collections.Count == 0)
    {
        <div class="collection-hub-section__empty tl-panel">
            <MudIcon Icon="@Icons.Material.Outlined.CollectionsBookmark" />
            <span>@EmptyText</span>
        </div>
    }
    else if (ViewMode == "list")
    {
        <div class="collection-hub-section__list">
            @foreach (var collection in Collections)
            {
                <button type="button"
                        class="collection-hub-row tl-card @(SelectedId == collection.Id ? "collection-hub-row--selected" : "")"
                        @onclick="() => OnSelect.InvokeAsync(collection)">
                    <div class="collection-hub-row__icon">
                        <MudIcon Icon="@GetIcon(collection)" />
                    </div>
                    <div class="collection-hub-row__copy">
                        <strong>@collection.Name</strong>
                        <span>@collection.TypeLabel · @collection.FamilyLabel · @collection.ItemCount item(s)</span>
                    </div>
                    <CollectionHubStats Collection="collection" />
                </button>
            }
        </div>
    }
    else
    {
        <div class="collection-hub-section__grid">
            @foreach (var collection in Collections)
            {
                <CollectionHubCard Collection="collection"
                                   Selected="@(SelectedId == collection.Id)"
                                   OnSelect="OnSelect" />
            }
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string EmptyText { get; set; } = "No collections match this section.";
    [Parameter, EditorRequired] public IReadOnlyList<CollectionManagementCatalogViewModel> Collections { get; set; } = [];
    [Parameter] public Guid? SelectedId { get; set; }
    [Parameter] public string ViewMode { get; set; } = "grid";
    [Parameter] public EventCallback<CollectionManagementCatalogViewModel> OnSelect { get; set; }

    private static string GetIcon(CollectionManagementCatalogViewModel collection) => collection.CollectionType switch
    {
        "System" => Icons.Material.Outlined.BookmarkAdded,
        "Playlist" => Icons.Material.Outlined.QueueMusic,
        "Smart" => Icons.Material.Outlined.AutoAwesome,
        "Mix" => Icons.Material.Outlined.GraphicEq,
        _ => Icons.Material.Outlined.CollectionsBookmark,
    };
}
