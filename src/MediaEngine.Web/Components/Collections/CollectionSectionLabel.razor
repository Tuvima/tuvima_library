@namespace MediaEngine.Web.Components.Collections

<div class="collection-section-label @Class">
    <span class="collection-section-label__left">
        <MudIcon Icon="@Icon" Size="Size.Small" />
        <span>@Label</span>
    </span>
    @if (!string.IsNullOrWhiteSpace(Status))
    {
        <small>@Status</small>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = Icons.Material.Outlined.CollectionsBookmark;
    [Parameter] public string? Status { get; set; }
    [Parameter] public string? Class { get; set; }
}
