@namespace MediaEngine.Web.Components.Collections
@using MediaEngine.Web.Models.ViewDTOs

<div class="collection-hub-stats" aria-label="Collection item counts">
    <span title="Watch">
        <MudIcon Icon="@Icons.Material.Outlined.LocalMovies" Size="Size.Small" />
        @FormatCount(Collection.WatchCount)
    </span>
    <span title="Listen">
        <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Size="Size.Small" />
        @FormatCount(Collection.ListenCount)
    </span>
    <span title="Read">
        <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Size="Size.Small" />
        @FormatCount(Collection.ReadCount)
    </span>
    <span title="Other">
        <MudIcon Icon="@Icons.Material.Outlined.Category" Size="Size.Small" />
        @FormatCount(Collection.OtherCount)
    </span>
</div>

@code {
    [Parameter, EditorRequired] public CollectionManagementCatalogViewModel Collection { get; set; } = default!;

    private static string FormatCount(int count) => count == 0 ? "-" : count.ToString(System.Globalization.CultureInfo.InvariantCulture);
}
