@namespace MediaEngine.Web.Components.Collections
@using MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Components.Discovery
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Editing

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject CollectionEditorLauncherService CollectionEditorLauncher
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<BrowseShellStyles />

<div class="browse-shell collections-browse">
    @if (CollectionHeroes.Count > 0)
    {
        <CinematicHeroCarousel Items="@CollectionHeroes"
                              SectionTitle="Collections"
                              SectionSubtitle="Broader rollups, curated lists, and playlists"
                              AriaLabel="Featured collections" />
    }

    <div class="browse-shell__toolbar-anchor">
        <div class="browse-shell__toolbar-panel">
            <div class="browse-shell__tab-row">
                <div class="browse-shell__title-block">
                    <div class="browse-shell__title-eyebrow">Tuvima Library</div>
                    <div class="browse-shell__title-text">Collections</div>
                </div>

                <AppButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenCollectionBuilder"
                           Class="browse-shell__back">
                    New Collection
                </AppButton>
            </div>

            <SurfaceTabBar Items="@CollectionFilters"
                           ActiveKey="@_activeFilter"
                           ActiveKeyChanged="SetCollectionFilterAsync"
                           AriaLabel="Filter Collections"
                           Class="collections-filter-bar"
                           ItemClass="collections-filter-tab" />

            <div class="browse-shell__toolbar">
                <AppTextField T="string"
                              Value="_searchText"
                              ValueChanged="OnSearchChanged"
                              Placeholder="Search collections"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              DebounceInterval="250"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Search"
                              Class="browse-shell__search" />

                <div class="browse-shell__controls">
                    <AppSelect T="string"
                               Value="_sortBy"
                               ValueChanged="OnSortChanged"
                               Label="Sort"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Class="browse-shell__sort">
                        <MudSelectItem T="string" Value="@("recent")">Recently Updated</MudSelectItem>
                        <MudSelectItem T="string" Value="@("name")">Name</MudSelectItem>
                        <MudSelectItem T="string" Value="@("items")">Item Count</MudSelectItem>
                        <MudSelectItem T="string" Value="@("type")">Type</MudSelectItem>
                    </AppSelect>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="browse-shell__loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Class="tl-u-color-tl-text-faint" />
        </div>
    }
    else if (FilteredCollections.Count == 0)
    {
        <div class="browse-shell__empty">
            <MudIcon Icon="@Icons.Material.Outlined.CollectionsBookmark" Class="tl-u-font-size-52px tl-u-opacity-0-16" />
            <h3>No collections found</h3>
            <p>Collections appear when the Engine finds Wikidata-backed universes or when you create one.</p>
        </div>
    }
    else if (CollectionCards.Count > 0)
    {
        <MediaTileGrid Items="@CollectionCards"
                       HoverMode="@MediaTileHoverMode.Expanded"
                       Class="browse-shell__grid" />
    }
</div>

@code {
    private readonly List<CollectionManagementCatalogViewModel> _collections = [];
    private ProfileViewModel? _activeProfile;
    private string _searchText = string.Empty;
    private string _sortBy = "recent";
    private string _activeFilter = "all";
    private bool _loading;

    private static readonly IReadOnlyList<SurfaceTabItem> CollectionFilters =
    [
        new("all", "All"),
        new("broader", "Broader rollups"),
        new("mine", "My collections"),
        new("playlists", "Playlists"),
    ];

    private bool CanManageSharedCollections => _activeProfile?.Role is "Administrator" or "Curator";

    private IReadOnlyList<CollectionManagementCatalogViewModel> FilteredCollections =>
        Sort(FilterBySearch(FilterByCollectionType(_collections)));

    private IReadOnlyList<DiscoveryHeroViewModel> CollectionHeroes =>
        FilteredCollections
            .OrderByDescending(collection => collection.ModifiedAt ?? collection.CreatedAt)
            .Take(5)
            .Select(ToCollectionHero)
            .ToList();

    private IReadOnlyList<MediaTileViewModel> CollectionCards =>
        FilteredCollections
            .Select(ToMediaTile)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        _activeProfile = await Orchestrator.GetActiveProfileAsync();
        await LoadCollectionsAsync();
    }

    private async Task LoadCollectionsAsync()
    {
        _loading = true;
        try
        {
            _collections.Clear();
            _collections.AddRange(await ApiClient.GetCollectionCatalogAsync(_activeProfile?.Id));
        }
        finally
        {
            _loading = false;
        }
    }

    private IEnumerable<CollectionManagementCatalogViewModel> FilterBySearch(IEnumerable<CollectionManagementCatalogViewModel> collections)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
            return collections;

        return collections.Where(collection =>
            collection.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || (collection.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || collection.TypeLabel.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || collection.CollectionType.Contains(_searchText, StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<CollectionManagementCatalogViewModel> FilterByCollectionType(
        IEnumerable<CollectionManagementCatalogViewModel> collections) => _activeFilter switch
    {
        "broader" => collections.Where(collection =>
            collection.IsGlobal
            || collection.IsSystem
            || collection.CollectionType is "Universe" or "Series" or "ContentGroup"),
        "mine" => collections.Where(collection =>
            !collection.IsGlobal
            && !collection.IsSystem
            && !string.Equals(collection.CollectionType, "Playlist", StringComparison.OrdinalIgnoreCase)),
        "playlists" => collections.Where(collection =>
            string.Equals(collection.CollectionType, "Playlist", StringComparison.OrdinalIgnoreCase)),
        _ => collections,
    };

    private IReadOnlyList<CollectionManagementCatalogViewModel> Sort(IEnumerable<CollectionManagementCatalogViewModel> collections) =>
        (_sortBy switch
        {
            "name" => collections.OrderBy(collection => collection.Name, StringComparer.OrdinalIgnoreCase),
            "items" => collections.OrderByDescending(collection => collection.ItemCount).ThenBy(collection => collection.Name),
            "type" => collections.OrderBy(collection => collection.TypeLabel).ThenBy(collection => collection.Name),
            _ => collections.OrderByDescending(collection => collection.ModifiedAt ?? collection.CreatedAt),
        }).ToList();

    private Task OnSearchChanged(string value)
    {
        _searchText = value;
        return Task.CompletedTask;
    }

    private Task OnSortChanged(string value)
    {
        _sortBy = value;
        return Task.CompletedTask;
    }

    private Task SetCollectionFilterAsync(string filter)
    {
        _activeFilter = filter;
        return Task.CompletedTask;
    }

    private static DiscoveryHeroViewModel ToCollectionHero(CollectionManagementCatalogViewModel collection)
    {
        var previewItems = collection.ArtworkItems
            .Select(ToArtworkStackItem)
            .Where(item => !string.IsNullOrWhiteSpace(item.ImageUrl))
            .ToList();
        var paletteArtwork = PaletteArtwork(collection);

        return new DiscoveryHeroViewModel
        {
            Eyebrow = collection.TypeLabel,
            Title = collection.Name,
            Subtitle = CollectionSubtitle(collection),
            Description = collection.Description,
            BackgroundImageUrl = HeroBackground(collection),
            HeroBackgroundImageUrl = HeroBackground(collection),
            PreviewImageUrl = PrimaryArtwork(collection),
            PreviewSurfaceKind = MediaTileSurfaceKind.BannerLandscape,
            SurfaceKind = MediaTileSurfaceKind.BannerLandscape,
            AccentColor = FirstNonBlank(paletteArtwork?.AccentColor, paletteArtwork?.PrimaryColor, "var(--tl-accent-primary)")!,
            MetaPills = [collection.TypeLabel, .. BuildMediaCountLabels(collection)],
            RepresentativeEntityId = collection.Id,
            CollectionId = collection.Id,
            MediaKind = "Collection",
            Presentation = "default",
            PreviewItems = previewItems,
            PreviewTotalCount = collection.ItemCount,
            PrimaryActionLabel = "Open collection",
            PrimaryNavigationUrl = $"/collection/{collection.Id:D}",
        };
    }

    private Task OpenCollection(CollectionManagementCatalogViewModel collection)
    {
        Nav.NavigateTo($"/collection/{collection.Id:D}");
        return Task.CompletedTask;
    }

    private async Task OpenCollectionBuilder()
    {
        if (_activeProfile is null)
        {
            Snackbar.Add("Choose an active profile before creating a collection.", Severity.Warning);
            return;
        }

        var changed = await CollectionEditorLauncher.OpenAsync(new CollectionEditorLaunchRequest
        {
            ActiveProfileId = _activeProfile.Id,
            CanManageSharedCollections = CanManageSharedCollections,
            InitialCollectionType = "Custom",
            InitialRulesEnabled = true,
            Mode = "Collection",
        });

        if (changed)
            await LoadCollectionsAsync();
    }

    private static MediaTileViewModel ToMediaTile(CollectionManagementCatalogViewModel collection)
    {
        var previewImages = collection.ArtworkItems
            .Select(item => MediaTileArtworkUrl.Sized(item.CoverUrl, "s"))
            .Where(url => !string.IsNullOrWhiteSpace(url))
            .Cast<string>()
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(5)
            .ToList();
        var artworkStackItems = collection.ArtworkItems
            .Select(ToArtworkStackItem)
            .Where(item => !string.IsNullOrWhiteSpace(item.ImageUrl))
            .ToList();
        var primaryArtwork = PrimaryArtwork(collection);
        var primarySmall = MediaTileArtworkUrl.Sized(primaryArtwork, "s");
        var primaryMedium = MediaTileArtworkUrl.Sized(primaryArtwork, "m");
        var heroArtwork = HeroBackground(collection);
        var heroSmall = MediaTileArtworkUrl.Sized(heroArtwork, "s");
        var heroMedium = MediaTileArtworkUrl.Sized(heroArtwork, "m");
        var paletteArtwork = PaletteArtwork(collection);
        var accentColor = FirstNonBlank(paletteArtwork?.PrimaryColor, paletteArtwork?.AccentColor, "var(--tl-accent-primary)")!;
        var secondaryAccentColor = FirstNonBlank(paletteArtwork?.SecondaryColor, paletteArtwork?.AccentColor, paletteArtwork?.PrimaryColor, "#111827")!;

        return new MediaTileViewModel
        {
            Id = collection.Id,
            CollectionId = collection.Id,
            Title = collection.Name,
            Subtitle = CollectionSubtitle(collection),
            Description = collection.Description,
            CoverUrl = primaryArtwork,
            BackgroundUrl = HeroBackground(collection),
            PreviewImages = previewImages,
            ArtworkStackItems = artworkStackItems,
            StatusText = collection.StatusLabel,
            MetaText = null,
            MediaCounts = BuildMediaCounts(collection),
            ContextLines = BuildContextLines(collection),
            HoverFacts = BuildHoverFacts(collection),
            MediaKind = "Collection",
            AccentColor = accentColor,
            SecondaryAccentColor = secondaryAccentColor,
            ArtworkPalette = collection.ArtworkPalette,
            Shape = MediaTileShape.Landscape,
            Presentation = MediaTilePresentation.Default,
            SurfaceKind = MediaTileSurfaceKind.BannerLandscape,
            HoverLayout = MediaTileHoverLayout.ArtOnlyPopover,
            TileTextMode = MediaTileTextMode.CoverOnly,
            TileImageUrl = primarySmall,
            TileImageSrcSet = MediaTileArtworkUrl.SrcSet(primarySmall, primaryMedium),
            HoverImageUrl = primaryMedium,
            HoverImageSrcSet = BuildMediumSrcSet(primaryMedium),
            HeroBackgroundImageUrl = heroMedium,
            NavigationUrl = $"/collection/{collection.Id:D}",
            PrimaryNavigationUrl = $"/collection/{collection.Id:D}",
            DetailsNavigationUrl = $"/collection/{collection.Id:D}",
            PrimaryActionLabel = "Open",
            Creator = null,
            CollectionKey = collection.CollectionType,
            PreviewTotalCount = collection.ItemCount,
            SortTimestamp = collection.ModifiedAt ?? collection.CreatedAt,
            IsCollection = true,
            UseLandscapeGroupTile = true,
        };
    }

    private static IReadOnlyList<string> BuildContextLines(CollectionManagementCatalogViewModel collection)
    {
        var lines = new List<string>();
        if (collection.ArtworkItems.Count > 0)
        {
            lines.Add(string.Join(" / ", collection.ArtworkItems.Take(3).Select(item => item.Title)));
        }

        if (!string.IsNullOrWhiteSpace(collection.Description))
        {
            lines.Add(collection.Description);
        }

        return lines;
    }

    private static IReadOnlyList<string> BuildHoverFacts(CollectionManagementCatalogViewModel collection) =>
    [
        .. BuildMediaCountLabels(collection),
        collection.IsGlobal ? "Shared" : "Personal",
    ];

    private static IReadOnlyList<MediaTileMediaCountViewModel> BuildMediaCounts(CollectionManagementCatalogViewModel collection)
    {
        var artworkCounts = collection.ArtworkItems
            .GroupBy(item => NormalizeMediaType(item.MediaType), StringComparer.OrdinalIgnoreCase)
            .Where(group => !string.IsNullOrWhiteSpace(group.Key))
            .Select(group => ToMediaCount(group.Key, group.Count()))
            .Where(count => count.Count > 0)
            .ToList();

        if (artworkCounts.Count > 0)
        {
            return artworkCounts
                .OrderBy(count => MediaCountSort(count.Label))
                .ToList();
        }

        var counts = new List<MediaTileMediaCountViewModel>();
        if (collection.WatchCount > 0)
        {
            counts.Add(new MediaTileMediaCountViewModel(Icons.Material.Filled.PlayArrow, "Video", collection.WatchCount));
        }

        if (collection.ListenCount > 0)
        {
            counts.Add(new MediaTileMediaCountViewModel(Icons.Material.Filled.Headphones, "Audio", collection.ListenCount));
        }

        if (collection.ReadCount > 0)
        {
            counts.Add(new MediaTileMediaCountViewModel(Icons.Material.Filled.MenuBook, "Books", collection.ReadCount));
        }

        if (collection.OtherCount > 0)
        {
            counts.Add(new MediaTileMediaCountViewModel(Icons.Material.Filled.MoreHoriz, "Other", collection.OtherCount));
        }

        return counts;
    }

    private static IReadOnlyList<string> BuildMediaCountLabels(CollectionManagementCatalogViewModel collection) =>
        BuildMediaCounts(collection)
            .Select(count => $"{count.Count} {count.Label}")
            .ToList();

    private static MediaTileMediaCountViewModel ToMediaCount(string mediaType, int count) => mediaType switch
    {
        "Movies" => new MediaTileMediaCountViewModel(Icons.Material.Filled.Movie, "Movies", count),
        "TV" => new MediaTileMediaCountViewModel(Icons.Material.Filled.LiveTv, "TV", count),
        "Music" => new MediaTileMediaCountViewModel(Icons.Material.Filled.MusicNote, "Music", count),
        "Audiobooks" => new MediaTileMediaCountViewModel(Icons.Material.Filled.Headphones, "Audiobooks", count),
        "Comics" => new MediaTileMediaCountViewModel(Icons.Material.Filled.AutoStories, "Comics", count),
        "Books" => new MediaTileMediaCountViewModel(Icons.Material.Filled.MenuBook, "Books", count),
        _ => new MediaTileMediaCountViewModel(Icons.Material.Filled.Theaters, "Media", count),
    };

    private static string NormalizeMediaType(string? mediaType)
    {
        var value = mediaType ?? string.Empty;
        if (value.Contains("tv", StringComparison.OrdinalIgnoreCase) || value.Contains("show", StringComparison.OrdinalIgnoreCase))
            return "TV";
        if (value.Contains("movie", StringComparison.OrdinalIgnoreCase) || value.Contains("film", StringComparison.OrdinalIgnoreCase))
            return "Movies";
        if (value.Contains("audio", StringComparison.OrdinalIgnoreCase))
            return "Audiobooks";
        if (value.Contains("music", StringComparison.OrdinalIgnoreCase) || value.Contains("song", StringComparison.OrdinalIgnoreCase) || value.Contains("album", StringComparison.OrdinalIgnoreCase))
            return "Music";
        if (value.Contains("comic", StringComparison.OrdinalIgnoreCase))
            return "Comics";
        if (value.Contains("book", StringComparison.OrdinalIgnoreCase) || value.Contains("epub", StringComparison.OrdinalIgnoreCase))
            return "Books";

        return string.Empty;
    }

    private static int MediaCountSort(string label) => label switch
    {
        "Movies" => 0,
        "TV" => 1,
        "Video" => 2,
        "Books" => 3,
        "Audiobooks" => 4,
        "Audio" => 5,
        "Music" => 6,
        "Comics" => 7,
        _ => 8,
    };

    private static string CollectionSubtitle(CollectionManagementCatalogViewModel collection) =>
        string.Join(" / ", BuildMediaCountLabels(collection));

    private static string? PrimaryArtwork(CollectionManagementCatalogViewModel collection) =>
        FirstNonBlank(collection.SquareArtworkUrl, collection.ArtworkItems.FirstOrDefault()?.CoverUrl);

    private static string? HeroBackground(CollectionManagementCatalogViewModel collection) =>
        FirstNonBlank(collection.ArtworkItems.Skip(1).FirstOrDefault()?.CoverUrl, PrimaryArtwork(collection));

    private static string? BuildMediumSrcSet(string? url) =>
        string.IsNullOrWhiteSpace(url) ? null : $"{url} 960w";

    private static ArtworkStackItem ToArtworkStackItem(CollectionArtworkItemViewModel item) => new()
    {
        Id = item.WorkId.ToString("D"),
        WorkId = item.WorkId,
        Title = item.Title,
        ImageUrl = MediaTileArtworkUrl.Sized(item.CoverUrl, "s") ?? string.Empty,
        MediaType = item.MediaType,
        NavigationUrl = CollectionItemRoute(item),
        Shape = ToArtworkShape(item.ArtworkShape, item.MediaType),
        Description = item.Description,
        Facts = item.Facts,
    };

    private static string CollectionItemRoute(CollectionArtworkItemViewModel item)
    {
        var mediaType = item.MediaType.Trim().ToLowerInvariant();
        return mediaType.Contains("tv")
            ? $"/watch/tv/show/{item.WorkId:D}"
            : MediaNavigation.ForMedia(item.MediaType, item.WorkId);
    }

    private static ArtworkShape ToArtworkShape(string? shape, string? mediaType)
    {
        if (string.Equals(shape, "square", StringComparison.OrdinalIgnoreCase))
            return ArtworkShape.Square;

        if (string.Equals(shape, "wide", StringComparison.OrdinalIgnoreCase)
            || string.Equals(shape, "landscape", StringComparison.OrdinalIgnoreCase))
            return ArtworkShape.Wide;

        if (string.Equals(shape, "portrait", StringComparison.OrdinalIgnoreCase))
            return ArtworkShape.Portrait;

        var normalized = NormalizeMediaType(mediaType);
        return normalized is "Audiobooks" or "Music"
            ? ArtworkShape.Square
            : ArtworkShape.Portrait;
    }

    private static CollectionArtworkItemViewModel? PaletteArtwork(CollectionManagementCatalogViewModel collection)
    {
        var candidates = collection.ArtworkItems
            .Where(item => !string.IsNullOrWhiteSpace(item.PrimaryColor)
                || !string.IsNullOrWhiteSpace(item.SecondaryColor)
                || !string.IsNullOrWhiteSpace(item.AccentColor))
            .OrderBy(item => StableHash(collection.Id, item.WorkId))
            .ToList();

        if (candidates.Count == 0)
        {
            return null;
        }

        var index = (StableHash(collection.Id, collection.Id) & int.MaxValue) % candidates.Count;
        return candidates[index];
    }

    private static int StableHash(Guid collectionId, Guid valueId)
    {
        var bytes = collectionId.ToByteArray().Concat(valueId.ToByteArray()).ToArray();
        unchecked
        {
            var hash = 17;
            foreach (var value in bytes)
                hash = (hash * 31) + value;
            return hash;
        }
    }

    private static string? FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));
}
