@namespace MediaEngine.Web.Components.Collections
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Editing

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject CollectionEditorLauncherService CollectionEditorLauncher
@inject ISnackbar Snackbar

<div class="collections-layout">
    <div class="collections-header">
        <h1 class="collections-title">Collections</h1>
        <p class="collections-subtitle">Manage saved collections, playlists, and shared sets. Browse-specific groups are generated dynamically on the Home and library views.</p>
    </div>

    <div class="collections-tab-row">
        <div class="collections-tab-bar">
            @foreach (var tab in _tabs)
            {
                <button class="collections-tab @(_activeTab == tab.Id ? "collections-tab--active" : null)"
                        @onclick="() => SwitchTab(tab.Id)">
                    <MudIcon Icon="@tab.Icon" Style="font-size: 16px;" />
                    <span>@tab.Label</span>
                    @if (tab.Count > 0)
                    {
                        <span class="collections-tab-badge">@tab.Count</span>
                    }
                </button>
            }
        </div>
        <button class="collections-add-btn" @onclick="OpenBuilder">
            <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size: 16px;" />
            <span>New Collection</span>
        </button>
    </div>

    <div class="collections-toolbar">
        <MudTextField @bind-Value="_searchText"
                      Placeholder="Search saved collections..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      DebounceInterval="300"
                      OnDebounceIntervalElapsed="OnSearchChanged"
                      Class="collections-search"
                      Style="max-width: 320px;" />

        <MudSelect T="string" Value="_sortBy"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Style="max-width: 180px;"
                   ValueChanged="OnSortChanged">
            <MudSelectItem T="string" Value="@("name")">Name</MudSelectItem>
            <MudSelectItem T="string" Value="@("items")">Item Count</MudSelectItem>
            <MudSelectItem T="string" Value="@("newest")">Newest</MudSelectItem>
            <MudSelectItem T="string" Value="@("type")">Type</MudSelectItem>
        </MudSelect>
    </div>

    <div class="collections-table-wrap">
        @if (_loading)
        {
            <div class="collections-loading">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (_filteredCollections.Count == 0)
        {
            <div class="collections-empty">
                <MudIcon Icon="@Icons.Material.Outlined.Collections" Style="font-size: 48px; opacity: 0.3;" />
                <p>No saved collections found for this profile.</p>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="OpenBuilder">
                    Create Collection
                </MudButton>
            </div>
        }
        else
        {
            <table class="collections-table">
                <thead>
                    <tr>
                        <th style="width: 44px;"></th>
                        <th style="width: 42%; text-align: left;">Name</th>
                        <th style="width: 14%; text-align: left;">Type</th>
                        <th style="width: 12%; text-align: center;">Access</th>
                        <th style="width: 10%; text-align: center;">Items</th>
                        <th style="width: 12%; text-align: center;">Status</th>
                        <th style="width: 80px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var collection in _filteredCollections)
                    {
                        <tr class="collections-row @(collection.CanEdit ? null : "collections-row--readonly")"
                            @onclick="() => OnCollectionClicked(collection)">
                            <td style="text-align: center;">
                                <MudIcon Icon="@GetTypeIcon(collection.CollectionType)"
                                         Size="Size.Small"
                                         Style="@($"color: {GetTypeColor(collection.CollectionType)}; opacity: 0.85;")" />
                            </td>
                            <td>
                                <div class="collections-name-cell">
                                    @if (!string.IsNullOrWhiteSpace(collection.CoverUrl))
                                    {
                                        <img src="@collection.CoverUrl" class="collections-thumb" alt="" />
                                    }
                                    else
                                    {
                                        <div class="collections-thumb-placeholder">
                                            <MudIcon Icon="@GetTypeIcon(collection.CollectionType)" Size="Size.Small" />
                                        </div>
                                    }
                                    <div class="collections-name-text">
                                        <span class="collections-name">@collection.Name</span>
                                        @if (!string.IsNullOrWhiteSpace(collection.Description))
                                        {
                                            <span class="collections-desc">@collection.Description</span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="collections-type-chip" style="@($"background: {GetTypeColor(collection.CollectionType)}22; color: {GetTypeColor(collection.CollectionType)};")">
                                    @GetTypeLabel(collection.CollectionType)
                                </span>
                            </td>
                            <td style="text-align: center;">
                                <span class="collections-type-chip" style="@($"background: {GetVisibilityColor(collection)}22; color: {GetVisibilityColor(collection)};")">
                                    @GetVisibilityLabel(collection)
                                </span>
                            </td>
                            <td style="text-align: center;">
                                <span class="collections-muted">@collection.ItemCount</span>
                            </td>
                            <td style="text-align: center;">
                                <span class="collections-status-pill collections-status-@collection.Status.ToLowerInvariant()">@collection.Status</span>
                            </td>
                            <td style="text-align: center;">
                                <MudIconButton Icon="@(collection.CanEdit ? Icons.Material.Outlined.Edit : Icons.Material.Outlined.Visibility)"
                                               Size="Size.Small"
                                               Disabled="@(!collection.CanEdit)"
                                               OnClick="@(() => OnEditCollection(collection))"
                                               aria-label="Edit collection" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

</div>

@code {
    private IReadOnlyList<CollectionManagementTab> _tabs = [];
    private string _activeTab = "all";
    private string _searchText = string.Empty;
    private string _sortBy = "name";
    private bool _loading;
    private ProfileViewModel? _activeProfile;
    private List<CollectionListItemViewModel> _allCollections = [];
    private List<CollectionListItemViewModel> _filteredCollections = [];

    private bool CanManageSharedCollections =>
        _activeProfile?.Role is "Administrator" or "Curator";

    protected override async Task OnInitializedAsync()
    {
        _activeProfile = await Orchestrator.GetActiveProfileAsync();
        await LoadCollections();
    }

    private async Task LoadCollections()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var managedCollections = await ApiClient.GetManagedCollectionsAsync(_activeProfile?.Id);
            _allCollections = managedCollections
                .Select(collection => new CollectionListItemViewModel
                {
                    Id = collection.Id,
                    Name = collection.Name,
                    Description = collection.Description,
                    IconName = collection.IconName,
                    CollectionType = collection.CollectionType,
                    Resolution = collection.Resolution,
                    Scope = collection.Scope,
                    ProfileId = collection.ProfileId,
                    Visibility = collection.Visibility,
                    IsEnabled = collection.IsEnabled,
                    IsFeatured = collection.IsFeatured,
                    ItemCount = collection.ItemCount,
                    RuleJson = collection.RuleJson,
                    MatchMode = collection.MatchMode,
                    SortField = collection.SortField,
                    SortDirection = collection.SortDirection,
                    LiveUpdating = collection.LiveUpdating,
                    CreatedAt = collection.CreatedAt,
                    CanEdit = collection.CanEdit,
                    CanShare = collection.CanShare,
                })
                .ToList();

            UpdateTabs();
            ApplyFilters();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void UpdateTabs()
    {
        _tabs = CollectionManagementTabs.Build(_allCollections, _activeProfile?.Id);
    }

    private void SwitchTab(string tabId)
    {
        _activeTab = tabId;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        var query = CollectionManagementTabs.Filter(_allCollections, _activeTab, _activeProfile?.Id);

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            query = query.Where(collection =>
                collection.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                || (collection.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        _filteredCollections = (_sortBy switch
        {
            "items" => query.OrderByDescending(collection => collection.ItemCount),
            "newest" => query.OrderByDescending(collection => collection.CreatedAt),
            "type" => query.OrderBy(collection => collection.CollectionType).ThenBy(collection => collection.Name),
            _ => query.OrderBy(collection => collection.Name),
        }).ToList();

        StateHasChanged();
    }

    private Task OnSearchChanged(string text)
    {
        _searchText = text;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private void OnSortChanged(string value)
    {
        _sortBy = value;
        ApplyFilters();
    }

    private async Task OpenBuilder()
    {
        if (_activeProfile is null)
        {
            Snackbar.Add("Choose an active profile before creating a collection.", Severity.Warning);
            return;
        }

        var changed = await CollectionEditorLauncher.OpenAsync(new CollectionEditorLaunchRequest
        {
            ActiveProfileId = _activeProfile.Id,
            CanManageSharedCollections = CanManageSharedCollections,
        });

        if (changed)
            await LoadCollections();
    }

    private async Task OnEditCollection(CollectionListItemViewModel collection)
    {
        if (!collection.CanEdit)
        {
            Snackbar.Add("This collection is read-only for the active profile.", Severity.Info);
            return;
        }

        var changed = await CollectionEditorLauncher.OpenAsync(new CollectionEditorLaunchRequest
        {
            EditingCollection = collection,
            ActiveProfileId = _activeProfile?.Id,
            CanManageSharedCollections = CanManageSharedCollections,
        });

        if (changed)
            await LoadCollections();
    }

    private async Task OnCollectionClicked(CollectionListItemViewModel collection)
    {
        if (collection.CanEdit)
            await OnEditCollection(collection);
    }

    private static string GetTypeIcon(string collectionType) => collectionType switch
    {
        "Smart" => Icons.Material.Outlined.AutoAwesome,
        "System" => Icons.Material.Outlined.Bookmark,
        "Mix" => Icons.Material.Outlined.Tune,
        "Playlist" => Icons.Material.Outlined.QueueMusic,
        "Custom" => Icons.Material.Outlined.FilterAlt,
        _ => Icons.Material.Outlined.Collections,
    };

    private static string GetTypeColor(string collectionType) => collectionType switch
    {
        "Smart" => "#81C784",
        "System" => "#4DB6AC",
        "Mix" => "#CE93D8",
        "Playlist" => "#FFB74D",
        "Custom" => "#EAB308",
        _ => "#90A4AE",
    };

    private static string GetTypeLabel(string collectionType) => collectionType switch
    {
        "Smart" => "Smart",
        "System" => "System",
        "Mix" => "Mix",
        "Playlist" => "Playlist",
        "Custom" => "Custom",
        _ => collectionType,
    };

    private static string GetVisibilityLabel(CollectionListItemViewModel collection) =>
        collection.IsShared ? "Shared" : "Private";

    private static string GetVisibilityColor(CollectionListItemViewModel collection) =>
        collection.IsShared ? "#60A5FA" : "#A78BFA";
}

<style>
    .collections-layout {
        max-width: 1400px;
        margin: 0 auto;
    }

    .collections-header {
        margin-bottom: 24px;
    }

    .collections-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: rgba(248, 248, 248, 0.95);
        margin: 0;
    }

    .collections-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
        color: rgba(248, 248, 248, 0.5);
        margin: 6px 0 0;
        max-width: 780px;
    }

    .collections-tab-row,
    .collections-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 16px;
    }

    .collections-tab-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        padding-bottom: 12px;
    }

    .collections-tab-bar {
        display: flex;
        gap: 6px;
        overflow-x: auto;
        scrollbar-width: none;
    }

    .collections-tab {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.02);
        color: rgba(248, 248, 248, 0.7);
        padding: 10px 14px;
        border-radius: 999px;
        cursor: pointer;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .collections-tab--active {
        background: rgba(96, 165, 250, 0.16);
        border-color: rgba(96, 165, 250, 0.45);
        color: rgba(248, 248, 248, 0.95);
    }

    .collections-tab-badge {
        background: rgba(255, 255, 255, 0.12);
        border-radius: 999px;
        padding: 2px 8px;
        font-size: 0.72rem;
    }

    .collections-add-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid rgba(234, 179, 8, 0.45);
        background: rgba(234, 179, 8, 0.12);
        color: rgba(248, 248, 248, 0.95);
        padding: 10px 14px;
        border-radius: 999px;
        cursor: pointer;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
    }

    .collections-table-wrap {
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 18px;
        overflow: hidden;
        background: rgba(7, 11, 19, 0.88);
    }

    .collections-loading,
    .collections-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 48px 24px;
        color: rgba(248, 248, 248, 0.6);
        font-family: 'Montserrat', sans-serif;
    }

    .collections-table {
        width: 100%;
        border-collapse: collapse;
    }

    .collections-table th {
        background: rgba(255, 255, 255, 0.03);
        color: rgba(248, 248, 248, 0.55);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 14px 12px;
    }

    .collections-row {
        cursor: pointer;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .collections-row:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    .collections-row--readonly {
        cursor: default;
    }

    .collections-row td {
        padding: 14px 12px;
        color: rgba(248, 248, 248, 0.86);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
    }

    .collections-name-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .collections-thumb,
    .collections-thumb-placeholder {
        width: 42px;
        height: 58px;
        border-radius: 10px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .collections-thumb-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.04);
        color: rgba(248, 248, 248, 0.45);
    }

    .collections-name-text {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
    }

    .collections-name {
        font-weight: 700;
        color: rgba(248, 248, 248, 0.96);
    }

    .collections-desc {
        color: rgba(248, 248, 248, 0.5);
        font-size: 0.82rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .collections-type-chip,
    .collections-status-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .collections-status-active {
        background: rgba(93, 202, 165, 0.18);
        color: #5DCAA5;
    }

    .collections-status-disabled {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(248, 248, 248, 0.55);
    }

    .collections-status-empty {
        background: rgba(239, 159, 39, 0.14);
        color: #EF9F27;
    }

    .collections-muted {
        color: rgba(248, 248, 248, 0.66);
    }

    @@media (max-width: 960px) {
        .collections-tab-row,
        .collections-toolbar {
            flex-direction: column;
            align-items: stretch;
        }

        .collections-table-wrap {
            overflow-x: auto;
        }

        .collections-table {
            min-width: 860px;
        }
    }
</style>
