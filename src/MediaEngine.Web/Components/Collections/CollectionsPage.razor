@namespace MediaEngine.Web.Components.Collections
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Editing

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject CollectionEditorLauncherService CollectionEditorLauncher
@inject ISnackbar Snackbar

<div class="collections-hub tl-page">
    <header class="tl-page-header collections-hub__header">
        <div>
            <h1 class="tl-page-title">Collections</h1>
            <p class="tl-page-subtitle">Organize and explore playlists across read, watch, and listen.</p>
        </div>
        <div class="tl-action-bar">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Inherit"
                       StartIcon="@Icons.Material.Outlined.QueueMusic"
                       OnClick="OpenPlaylistBuilder">
                New Playlist
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCollectionBuilder">
                New Collection
            </MudButton>
        </div>
    </header>

    <div class="tl-filter-bar collections-hub__filters">
        <div class="collections-hub__tabs" role="tablist" aria-label="Collection filters">
            @foreach (var tab in Tabs)
            {
                <button type="button"
                        role="tab"
                        aria-selected="@(tab.Id == _activeTab)"
                        class="collections-hub-tab @(tab.Id == _activeTab ? "is-active" : "")"
                        @onclick="() => SetActiveTab(tab.Id)">
                    <MudIcon Icon="@tab.Icon" Size="Size.Small" />
                    <span>@tab.Label</span>
                </button>
            }
        </div>

        <MudTextField T="string"
                      Value="_searchText"
                      ValueChanged="OnSearchChanged"
                      Placeholder="Search collections..."
                      Variant="Variant.Outlined"
                      Immediate="true"
                      DebounceInterval="250"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.Search"
                      Class="tl-field collections-hub__search" />

        <MudSelect T="string" Value="_sortBy" ValueChanged="OnSortChanged" Variant="Variant.Outlined" Dense="true" Class="tl-field collections-hub__sort">
            <MudSelectItem T="string" Value="@("recent")">Recently Updated</MudSelectItem>
            <MudSelectItem T="string" Value="@("name")">Name</MudSelectItem>
            <MudSelectItem T="string" Value="@("items")">Item Count</MudSelectItem>
            <MudSelectItem T="string" Value="@("type")">Type</MudSelectItem>
        </MudSelect>
    </div>

    @if (_loading)
    {
        <div class="collections-hub__state tl-panel">
            <MudProgressCircular Indeterminate="true" />
            <span>Loading collections...</span>
        </div>
    }
    else
    {
        <div class="collections-hub__layout">
            <main class="collections-hub__main">
                @if (_activeTab is "all" or "cross")
                {
                    <CollectionHubSection Title="CROSS-MEDIA COLLECTIONS"
                                      Description="Premium collections spanning read, watch, and listen."
                                      Collections="CrossMediaCollections"
                                      SelectedId="SelectedCollection?.Id"
                                      ViewMode="list"
                                      Icon="@Icons.Material.Outlined.AllInclusive"
                                      OnSelect="SelectCollection" />
                }

                @if (_activeTab is "all" or "watch")
                {
                    <CollectionHubSection Title="WATCH COLLECTIONS"
                                          Description="Watchlists and visual-media collections managed from Collections."
                                          Collections="WatchCollections"
                                          SelectedId="SelectedCollection?.Id"
                                          ViewMode="list"
                                          Icon="@Icons.Material.Outlined.Movie"
                                          OnSelect="SelectCollection" />
                }
                @if (_activeTab is "all" or "listen")
                {
                    <CollectionHubSection Title="LISTEN COLLECTIONS"
                                          Description="Listening queues, music playlists, and audio-forward collections."
                                          Collections="ListenCollections"
                                          SelectedId="SelectedCollection?.Id"
                                          ViewMode="list"
                                          Icon="@Icons.Material.Outlined.Album"
                                          OnSelect="SelectCollection" />
                }
                @if (_activeTab is "all" or "read")
                {
                    <CollectionHubSection Title="READ COLLECTIONS"
                                          Description="Reading lists and book or comic collections."
                                          Collections="ReadCollections"
                                          SelectedId="SelectedCollection?.Id"
                                          ViewMode="list"
                                          Icon="@Icons.Material.Outlined.MenuBook"
                                          OnSelect="SelectCollection" />
                }
                @if (_activeTab is "all" or "global")
                {
                    <CollectionHubSection Title="GLOBAL COLLECTIONS"
                                          Description="Shared collections visible across profiles."
                                          Collections="GlobalCollections"
                                          SelectedId="SelectedCollection?.Id"
                                          ViewMode="list"
                                          Icon="@Icons.Material.Outlined.Public"
                                          OnSelect="SelectCollection" />
                }
                @if (_activeTab is "system")
                {
                    <CollectionHubSection Title="SYSTEM COLLECTIONS"
                                          Description="Built-in lists grouped by their media lane."
                                          Collections="SystemCollections"
                                          SelectedId="SelectedCollection?.Id"
                                          ViewMode="list"
                                          Icon="@Icons.Material.Outlined.BookmarkAdded"
                                          OnSelect="SelectCollection" />
                }
                @if (_activeTab is "user")
                {
                    <CollectionHubSection Title="CREATED BY YOU"
                                          Description="Private collections and playlists created by the active profile."
                                          Collections="UserCollections"
                                          SelectedId="SelectedCollection?.Id"
                                          ViewMode="list"
                                          Icon="@Icons.Material.Outlined.Person"
                                          OnSelect="SelectCollection" />
                }

                @if (_activeTab is "all")
                {
                    <CollectionHubSection Title="RECENTLY USED"
                                      Description="Collections with the most recent activity or updates."
                                      Collections="RecentlyUsedCollections"
                                      SelectedId="SelectedCollection?.Id"
                                      ViewMode="list"
                                      Icon="@Icons.Material.Outlined.History"
                                      OnSelect="SelectCollection" />
                }
            </main>

            <CollectionInlineInspector Collection="SelectedCollection"
                                       ActiveProfileId="_activeProfile?.Id"
                                       OnChanged="ReloadAfterEdit"
                                       OnClose="ClearSelection" />
        </div>
    }
</div>

@code {
    private sealed record CollectionTab(string Id, string Label, string Icon);

    private static readonly CollectionTab[] Tabs =
    [
        new("all", "All", Icons.Material.Outlined.CollectionsBookmark),
        new("watch", "Watch", Icons.Material.Outlined.Movie),
        new("listen", "Listen", Icons.Material.Outlined.Album),
        new("read", "Read", Icons.Material.Outlined.MenuBook),
        new("cross", "Cross-Media", Icons.Material.Outlined.AllInclusive),
        new("global", "Global", Icons.Material.Outlined.Public),
        new("user", "Created by You", Icons.Material.Outlined.Person),
        new("system", "System", Icons.Material.Outlined.BookmarkAdded),
    ];

    private readonly List<CollectionManagementCatalogViewModel> _collections = [];
    private ProfileViewModel? _activeProfile;
    private CollectionManagementCatalogViewModel? SelectedCollection { get; set; }
    private string _searchText = string.Empty;
    private string _sortBy = "recent";
    private string _activeTab = "all";
    private bool _loading;

    private bool CanManageSharedCollections => _activeProfile?.Role is "Administrator" or "Curator";

    private IReadOnlyList<CollectionManagementCatalogViewModel> FilteredCollections =>
        Sort(FilterBySearch(_collections));

    private IReadOnlyList<CollectionManagementCatalogViewModel> WatchCollections =>
        FilteredCollections.Where(collection => collection.PrimaryLane == "Watch").Take(8).ToList();

    private IReadOnlyList<CollectionManagementCatalogViewModel> ListenCollections =>
        FilteredCollections.Where(collection => collection.PrimaryLane == "Listen").Take(8).ToList();

    private IReadOnlyList<CollectionManagementCatalogViewModel> ReadCollections =>
        FilteredCollections.Where(collection => collection.PrimaryLane == "Read").Take(8).ToList();

    private IReadOnlyList<CollectionManagementCatalogViewModel> CrossMediaCollections =>
        FilteredCollections.Where(collection => collection.PrimaryLane == "CrossMedia").Take(8).ToList();

    private IReadOnlyList<CollectionManagementCatalogViewModel> GlobalCollections =>
        FilteredCollections.Where(collection => collection.Family == "Global").Take(8).ToList();

    private IReadOnlyList<CollectionManagementCatalogViewModel> RecentlyUsedCollections =>
        FilteredCollections
            .OrderByDescending(collection => collection.ModifiedAt ?? collection.CreatedAt)
            .Take(8)
            .ToList();

    private IReadOnlyList<CollectionManagementCatalogViewModel> SystemCollections =>
        FilteredCollections.Where(collection => collection.Family == "System").ToList();

    private IReadOnlyList<CollectionManagementCatalogViewModel> UserCollections =>
        FilteredCollections.Where(collection => collection.Family == "User").ToList();

    protected override async Task OnInitializedAsync()
    {
        _activeProfile = await Orchestrator.GetActiveProfileAsync();
        await LoadCollectionsAsync();
    }

    private async Task LoadCollectionsAsync()
    {
        _loading = true;
        try
        {
            var selectedId = SelectedCollection?.Id;
            _collections.Clear();
            _collections.AddRange(await ApiClient.GetCollectionManagementCatalogAsync(_activeProfile?.Id));
            SelectedCollection = selectedId.HasValue
                ? _collections.FirstOrDefault(collection => collection.Id == selectedId.Value)
                : _collections.FirstOrDefault();
        }
        finally
        {
            _loading = false;
        }
    }

    private IEnumerable<CollectionManagementCatalogViewModel> FilterBySearch(IEnumerable<CollectionManagementCatalogViewModel> collections)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
            return collections;

        return collections.Where(collection =>
            collection.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || (collection.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || collection.TypeLabel.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || collection.FamilyLabel.Contains(_searchText, StringComparison.OrdinalIgnoreCase));
    }

    private IReadOnlyList<CollectionManagementCatalogViewModel> Sort(IEnumerable<CollectionManagementCatalogViewModel> collections) =>
        (_sortBy switch
        {
            "name" => collections.OrderBy(collection => collection.Name, StringComparer.OrdinalIgnoreCase),
            "items" => collections.OrderByDescending(collection => collection.ItemCount),
            "type" => collections.OrderBy(collection => collection.CollectionType).ThenBy(collection => collection.Name),
            _ => collections.OrderByDescending(collection => collection.ModifiedAt ?? collection.CreatedAt),
        }).ToList();

    private Task OnSearchChanged(string value)
    {
        _searchText = value;
        return Task.CompletedTask;
    }

    private Task OnSortChanged(string value)
    {
        _sortBy = value;
        return Task.CompletedTask;
    }

    private void SetActiveTab(string id)
    {
        _activeTab = id;
    }

    private Task SelectCollection(CollectionManagementCatalogViewModel collection)
    {
        SelectedCollection = collection;
        return Task.CompletedTask;
    }

    private async Task ReloadAfterEdit() => await LoadCollectionsAsync();

    private void ClearSelection() => SelectedCollection = null;

    private Task OpenCollectionBuilder() => OpenBuilder("Custom", true);

    private Task OpenPlaylistBuilder() => OpenBuilder("Playlist", false);

    private async Task OpenBuilder(string type, bool rulesEnabled)
    {
        if (_activeProfile is null)
        {
            Snackbar.Add("Choose an active profile before creating a collection.", Severity.Warning);
            return;
        }

        var changed = await CollectionEditorLauncher.OpenAsync(new CollectionEditorLaunchRequest
        {
            ActiveProfileId = _activeProfile.Id,
            CanManageSharedCollections = CanManageSharedCollections,
            InitialCollectionType = type,
            InitialRulesEnabled = rulesEnabled,
            Mode = type == "Playlist" ? "Playlist" : "Collection",
        });

        if (changed)
            await LoadCollectionsAsync();
    }
}
