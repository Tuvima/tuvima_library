@namespace MediaEngine.Web.Components.Universe

<div class="global-bg" aria-hidden="true">
    <div class="global-bg-gradient"
         style="background: radial-gradient(circle at top center, @(Color ?? "#080B14")22 0%, #080B14 80%);">
    </div>
    @if (!string.IsNullOrEmpty(ImageUrl))
    {
        <img src="@ImageUrl" class="global-bg-image" alt="" />
    }
    <div class="global-bg-grain"></div>
</div>

@code {
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string? Color { get; set; }
}