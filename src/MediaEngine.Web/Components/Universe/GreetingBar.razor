@namespace MediaEngine.Web.Components.Universe
<AppCssElement Tag="div" Class="greeting-bar" Css="@(string.IsNullOrEmpty(AccentColor) ? "" : $"--greeting-accent: {AccentColor};")">
    <div class="greeting-text">
        <span class="greeting-main">@GreetingText</span>
        @if (!string.IsNullOrEmpty(DateText))
        {
            <span class="greeting-date">@DateText</span>
        }
    </div>
    @if (!string.IsNullOrEmpty(StatLabel))
    {
        <span class="greeting-stat">@StatLabel</span>
    }
</AppCssElement>

@code {
    [Parameter] public string? UserName { get; set; }
    [Parameter] public string? GreetingOverride { get; set; }
    [Parameter] public string? StatLabel { get; set; }
    [Parameter] public string? AccentColor { get; set; }

    private string GreetingText
    {
        get
        {
            if (!string.IsNullOrEmpty(GreetingOverride))
                return GreetingOverride;

            var hour = DateTime.Now.Hour;
            var timeGreeting = hour switch
            {
                < 12 => "Good morning",
                < 17 => "Good afternoon",
                _ => "Good evening",
            };

            return string.IsNullOrEmpty(UserName)
                ? timeGreeting
                : $"{timeGreeting}, {UserName}";
        }
    }

    private string DateText => DateTime.Now.ToString("dddd, d MMMM");
}