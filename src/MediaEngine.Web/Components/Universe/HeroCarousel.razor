@namespace MediaEngine.Web.Components.Universe
@using MediaEngine.Web.Models.ViewDTOs

@if (CurrentItem is not null)
{
    <div class="hero-carousel">
        <div class="hero-layout">
<div class="hero-cover">
                @if (!string.IsNullOrEmpty(CurrentItem.CoverUrl))
                {
                    <img src="@CurrentItem.CoverUrl" alt="@CurrentItem.Title"
                         class="hero-cover-img" />
                }
                <div class="hero-cover-ring"></div>
            </div>
<div class="hero-info">
                @* Now Playing pill *@
                <div class="hero-context-pill">
                    <AppMaterialIcon Icon="@TypeIcon" Size="Size.Small" Css="@($"font-size: 12px; color: {TypeColor};")"  />
                    <span class="hero-context-text">@NowContext</span>
                </div>
<h2 class="hero-title">
                    @{
                        var parts = CurrentItem.Title.Split(':');
                        for (var i = 0; i < parts.Length; i++)
                        {
                            <span class="hero-title-line">@(parts[i].Trim())@(i == 0 && parts.Length > 1 ? ":" : "")</span>
                        }
                    }
                </h2>

                @* Metadata chips *@
                <div class="hero-meta">
                    @if (!string.IsNullOrEmpty(CurrentItem.Genre))
                    {
                        <span>@CurrentItem.Genre</span>
                    }
                    @if (!string.IsNullOrEmpty(CurrentItem.Year))
                    {
                        <span class="hero-meta-dot"></span>
                        <span>@CurrentItem.Year</span>
                    }
                    @if (!string.IsNullOrEmpty(CurrentItem.Rating))
                    {
                        <span class="hero-meta-dot"></span>
                        <span class="hero-meta-rating">@CurrentItem.Rating</span>
                    }
                </div>

                @* Action buttons *@
                <div class="hero-actions">
                    <AppNativeButton Class="hero-cta" OnClick="HandleCta">
                        <MudIcon Icon="@MudBlazor.Icons.Material.Filled.PlayArrow"
                                 Size="Size.Small" Class="tl-u-font-size-18px" />
                        @ActionLabel
                    </AppNativeButton>
                    <AppNativeButton Class="hero-action-btn" OnClick="HandleClick">
                        <MudIcon Icon="@MudBlazor.Icons.Material.Outlined.BookmarkBorder"
                                 Size="Size.Small" Class="tl-u-font-size-20px" />
                    </AppNativeButton>
                    <AppNativeButton Class="hero-action-btn" OnClick="HandleClick">
                        <MudIcon Icon="@MudBlazor.Icons.Material.Outlined.Info"
                                 Size="Size.Small" Class="tl-u-font-size-20px" />
                    </AppNativeButton>
                </div>

                @* Progress bar *@
                @if (CurrentItem.ProgressPct is > 0)
                {
                    <div class="hero-progress">
                        <div class="hero-progress-track">
                            <AppCssElement Tag="div" Class="hero-progress-fill"
                                 Css="@($"width: {CurrentItem.ProgressPct.Value}%;")"></AppCssElement>
                        </div>
                    </div>
                }

                @* Dot navigation *@
                @if (Items.Count > 1)
                {
                    <div class="hero-dots">
                        @for (var i = 0; i < Items.Count; i++)
                        {
                            var idx = i;
                            <AppNativeButton Class='@($"hero-dot {(i == _currentIndex ? " hero-dot-active" : "")}")' OnClick="() => SetIndex(idx)"></AppNativeButton>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<HeroData> Items { get; set; } = [];
    [Parameter] public EventCallback<HeroData> OnItemSelected { get; set; }
    [Parameter] public EventCallback<HeroData> OnCtaClicked { get; set; }
    [Parameter] public EventCallback<HeroData> OnActiveItemChanged { get; set; }

    private int _currentIndex;
    private HeroData? CurrentItem => Items.Count > 0 ? Items[_currentIndex] : null;

    private async Task SetIndex(int index)
    {
        if (index >= 0 && index < Items.Count)
        {
            _currentIndex = index;
            if (CurrentItem is not null)
                await OnActiveItemChanged.InvokeAsync(CurrentItem);
        }
    }

    private string ActionLabel => CurrentItem?.MediaTypeLabel?.ToLowerInvariant() switch
    {
        var t when t != null && t.Contains("book")    => "CONTINUE READING",
        var t when t != null && t.Contains("music")   => "LISTEN NOW",
        var t when t != null && t.Contains("audio")   => "CONTINUE LISTENING",
        _                                              => "CONTINUE WATCHING",
    };

    private string NowContext => CurrentItem?.MediaTypeLabel?.ToLowerInvariant() switch
    {
        var t when t != null && t.Contains("book")  => "Now Reading",
        var t when t != null && t.Contains("music") => "Now Listening",
        var t when t != null && t.Contains("audio") => "Now Listening",
        _                                            => "Now Playing",
    };

    private string TypeIcon => CurrentItem?.MediaTypeLabel?.ToLowerInvariant() switch
    {
        var t when t != null && t.Contains("book")  => MudBlazor.Icons.Material.Filled.MenuBook,
        var t when t != null && t.Contains("music") => MudBlazor.Icons.Material.Filled.MusicNote,
        _                                            => MudBlazor.Icons.Material.Filled.PlayArrow,
    };

    private string TypeColor
    {
        get
        {
            var t = (CurrentItem?.MediaTypeLabel ?? "").ToLowerInvariant();
            if (t.Contains("book") || t.Contains("epub"))   return "var(--tl-status-success)";
            if (t.Contains("audio") || t.Contains("m4b"))   return "#A78BFA";
            if (t.Contains("movie") || t.Contains("video")) return "var(--tl-status-info)";
            if (t.Contains("tv"))                            return "var(--tl-media-video)";
            if (t.Contains("music"))                         return "#22D3EE";
            if (t.Contains("comic"))                         return "#7C4DFF";
            return "var(--tl-accent-primary)";
        }
    }

    private async Task HandleClick()
    {
        if (CurrentItem is not null)
            await OnItemSelected.InvokeAsync(CurrentItem);
    }

    private async Task HandleCta()
    {
        if (CurrentItem is not null)
            await OnCtaClicked.InvokeAsync(CurrentItem);
    }
}