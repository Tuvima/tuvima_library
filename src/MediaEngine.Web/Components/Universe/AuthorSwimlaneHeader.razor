@namespace MediaEngine.Web.Components.Universe

@* AuthorSwimlaneHeader — Inline header for author-grouped swimlanes.
   Shows 40px circular headshot (or initials fallback), author name, book count, and See All link. *@

<div class="author-swimlane-header">
    <div class="author-header-left">
        @if (!string.IsNullOrEmpty(HeadshotUrl))
        {
            <img src="@HeadshotUrl" alt="@AuthorName"
                 class="author-header-headshot" loading="lazy" />
        }
        else
        {
            <div class="author-header-avatar">@Initials</div>
        }
        <div class="author-header-info">
            <span class="author-header-name">@AuthorName</span>
            <span class="author-header-count">(@BookCount @(BookCount == 1 ? "book" : "books"))</span>
        </div>
    </div>
    @if (SeeAllHref is not null)
    {
        <a class="swimlane-see-all" href="@SeeAllHref">See All &#x203A;</a>
    }
</div>

@code {
    [Parameter, EditorRequired] public string AuthorName { get; set; } = string.Empty;
    [Parameter] public string? HeadshotUrl { get; set; }
    [Parameter] public int BookCount { get; set; }
    [Parameter] public string? SeeAllHref { get; set; }

    private string Initials
    {
        get
        {
            var parts = AuthorName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            return parts.Length switch
            {
                0 => "?",
                1 => parts[0][..1].ToUpperInvariant(),
                _ => $"{parts[0][..1]}{parts[^1][..1]}".ToUpperInvariant(),
            };
        }
    }
}

<style>
    .author-swimlane-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
    }

    .author-header-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .author-header-headshot {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .author-header-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(201, 146, 46, 0.25);
        color: #C9922E;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        flex-shrink: 0;
    }

    .author-header-info {
        display: flex;
        align-items: baseline;
        gap: 8px;
    }

    .author-header-name {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.15rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.90);
        line-height: 1.3;
    }

    .author-header-count {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.40);
    }

    @@media (max-width: 768px) {
        .author-header-headshot,
        .author-header-avatar {
            width: 32px;
            height: 32px;
        }

        .author-header-name {
            font-size: 1rem;
        }

        .author-header-count {
            font-size: 0.75rem;
        }
    }
</style>
