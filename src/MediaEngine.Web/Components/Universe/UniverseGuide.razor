@namespace MediaEngine.Web.Components.Universe

@* Mobile card-based searchable universe guide *@

<div class="universe-guide">
    @* Search + filter bar *@
    <AppTextField T="string" @bind-Value="_search" Placeholder="Search entities..."
                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" />

    <MudStack Row="true" Spacing="1" Class="mb-4 tl-u-flex-wrap-wrap" >
        <AppChip T="string"
                 Color="@(_filter == "All" ? Color.Warning : Color.Default)"
                 Variant="@(_filter == "All" ? Variant.Filled : Variant.Outlined)"
                 OnClick="@(() => _filter = "All")" Size="Size.Small">
            All
        </AppChip>
        <AppChip T="string"
                 Color="@(_filter == "Character" ? Color.Primary : Color.Default)"
                 Variant="@(_filter == "Character" ? Variant.Filled : Variant.Outlined)"
                 OnClick="@(() => _filter = "Character")" Size="Size.Small">
            Characters
        </AppChip>
        <AppChip T="string"
                 Color="@(_filter == "Location" ? Color.Success : Color.Default)"
                 Variant="@(_filter == "Location" ? Variant.Filled : Variant.Outlined)"
                 OnClick="@(() => _filter = "Location")" Size="Size.Small">
            Locations
        </AppChip>
        <AppChip T="string"
                 Color="@(_filter == "Organization" ? Color.Warning : Color.Default)"
                 Variant="@(_filter == "Organization" ? Variant.Filled : Variant.Outlined)"
                 OnClick="@(() => _filter = "Organization")" Size="Size.Small">
            Organizations
        </AppChip>
    </MudStack>

    @* Entity cards *@
    <div class="tl-u-overflow-y-auto tl-u-max-height-560px">
        @if (!FilteredEntities.Any())
        {
            <MudText Typo="Typo.body2" Class="tl-u-color-hex-555 tl-u-text-align-center tl-u-padding-32px-0">
                No entities match your search.
            </MudText>
        }
        else
        {
            @foreach (var entity in FilteredEntities)
            {
                <div class="guide-card @(_expandedQid == entity.Id ? "guide-card-expanded" : "")"
                     @onclick="@(() => ToggleExpand(entity.Id))">
                    @* Collapsed header *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        @if (!string.IsNullOrWhiteSpace(entity.Image))
                        {
                            <MudAvatar Size="Size.Medium"><img src="@entity.Image" alt="@entity.Label" class="tl-u-width-100pct tl-u-height-100pct tl-u-object-fit-cover" /></MudAvatar>
                        }
                        else
                        {
                            <MudAvatar Color="@GetAvatarColor(entity.Type)" Size="Size.Medium">
                                @(entity.Label.Length > 0 ? entity.Label[0].ToString() : "?")
                            </MudAvatar>
                        }
                        <div class="tl-u-flex-1 tl-u-overflow-hidden">
                            <MudText Typo="Typo.subtitle2" Class="tl-u-font-weight-600 tl-u-white-space-nowrap tl-u-overflow-hidden tl-u-text-overflow-ellipsis">
                                @entity.Label
                            </MudText>
                            @if (!string.IsNullOrWhiteSpace(entity.Description))
                            {
                                <MudText Typo="Typo.caption" Class="tl-u-color-hex-888 tl-u-white-space-nowrap tl-u-overflow-hidden tl-u-text-overflow-ellipsis">
                                    @entity.Description
                                </MudText>
                            }
                        </div>
                        <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Color="@GetChipColor(entity.Type)"
                                 Class="tl-u-font-size-10px tl-u-height-20px">
                            @entity.Type
                        </AppChip>
                        <MudIcon Icon="@(_expandedQid == entity.Id ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                 Class="tl-u-color-hex-555" Size="Size.Small" />
                    </MudStack>

                    @* Expanded detail *@
                    @if (_expandedQid == entity.Id)
                    {
                        <div class="guide-detail">
                            @if (!string.IsNullOrWhiteSpace(entity.Description))
                            {
                                <MudText Typo="Typo.body2" Class="mb-3 tl-u-color-hex-ccc" >
                                    @entity.Description
                                </MudText>
                            }

                            @if (entity.Works?.Count > 0)
                            {
                                <MudText Typo="Typo.caption" Class="tl-u-color-tl-accent-primary tl-u-font-weight-600 tl-u-margin-bottom-6px tl-u-display-block">
                                    APPEARS IN
                                </MudText>
                                <MudStack Row="true"  Class="mb-2 tl-u-flex-wrap-wrap tl-u-gap-4px">
                                    @foreach (var work in entity.Works)
                                    {
                                        <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                            @work.Label
                                        </AppChip>
                                    }
                                </MudStack>
                            }

                            @{
                                var rels = GetRelationshipsFor(entity.Id);
                            }
                            @if (rels.Count > 0)
                            {
                                <MudText Typo="Typo.caption" Class="tl-u-color-tl-accent-primary tl-u-font-weight-600 tl-u-margin-bottom-6px tl-u-display-block">
                                    RELATIONSHIPS
                                </MudText>
                                <MudStack Row="true" Class="tl-u-flex-wrap-wrap tl-u-gap-4px">
                                    @foreach (var rel in rels.Take(8))
                                    {
                                        <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Class="tl-u-font-size-11px">
                                            @rel.Label @GetNodeLabelForQid(rel.Source == entity.Id ? rel.Target : rel.Source)
                                        </AppChip>
                                    }
                                </MudStack>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>
@code {
    [Parameter] public string UniverseQid { get; set; } = string.Empty;
    [Parameter] public UniverseGraphResponse? Graph { get; set; }

    private string _search = string.Empty;
    private string _filter = "All";
    private string? _expandedQid;

    private IEnumerable<GraphNodeDto> FilteredEntities
    {
        get
        {
            IEnumerable<GraphNodeDto> source = Graph?.Nodes ?? [];
            if (_filter != "All")
                source = source.Where(n => string.Equals(n.Type, _filter, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(_search))
                source = source.Where(n => n.Label.Contains(_search, StringComparison.OrdinalIgnoreCase));
            return source.OrderBy(n => n.Label);
        }
    }

    private void ToggleExpand(string qid)
    {
        _expandedQid = _expandedQid == qid ? null : qid;
    }

    private List<GraphEdgeDto> GetRelationshipsFor(string qid) =>
        Graph?.Edges.Where(e => e.Source == qid || e.Target == qid).ToList() ?? [];

    private string GetNodeLabelForQid(string qid) =>
        Graph?.Nodes.FirstOrDefault(n => n.Id == qid)?.Label ?? qid;

    private static Color GetAvatarColor(string type) => type switch
    {
        "Character"    => Color.Primary,
        "Location"     => Color.Success,
        "Organization" => Color.Warning,
        _              => Color.Default,
    };

    private static Color GetChipColor(string type) => type switch
    {
        "Character"    => Color.Primary,
        "Location"     => Color.Success,
        "Organization" => Color.Warning,
        _              => Color.Default,
    };
}