@namespace MediaEngine.Web.Components.Universe

@* Reusable progress card for the Last Journey hero tile.
   Displays: icon, primary value, progress bar, label. *@

<div class="progress-card">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
        <MudIcon Icon="@Icon" Size="Size.Small"
                 Class="tl-u-color-app-icon-muted tl-u-font-size-20px" />
        <MudText Typo="Typo.body1" Class="tl-u-font-weight-600">
            @Value
        </MudText>
    </MudStack>

    <MudProgressLinear Value="@Percent" Color="Color.Warning" Rounded="false"
                       Size="Size.Small" Class="mb-1 tl-u-height-4px"
                        />

    <MudText Typo="Typo.caption" Class="tl-u-color-app-text-faint">
        @Label
    </MudText>
</div>

@code {
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.HelpOutline;
    [Parameter] public string Value { get; set; } = "-";
    [Parameter] public double Percent { get; set; }
    [Parameter] public string Label { get; set; } = "";
}