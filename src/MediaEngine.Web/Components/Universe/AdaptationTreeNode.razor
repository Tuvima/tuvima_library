@namespace MediaEngine.Web.Components.Universe

@* Recursive tree node for AdaptationTree *@

<div class="adaptation-node" style="margin-left: @(Depth * 24)px;">
    <div class="adaptation-card">
        @* Cover thumbnail *@
        @if (!string.IsNullOrWhiteSpace(Node.CoverImage))
        {
            <img src="@Node.CoverImage" alt="@Node.Label" class="adapt-thumb" />
        }
        else
        {
            <div class="adapt-thumb-placeholder">
                <MudIcon Icon="@GetMediaTypeIcon(Node.MediaType)" Style="color: #555;" />
            </div>
        }

        @* Work info *@
        <div class="adapt-info">
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@Node.Label</MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                @if (Node.Year.HasValue)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Style="font-size: 10px; height: 20px;">
                        @Node.Year
                    </MudChip>
                }
                @if (!string.IsNullOrWhiteSpace(Node.MediaType))
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@GetMediaTypeColor(Node.MediaType)"
                             Style="font-size: 10px; height: 20px;">
                        @Node.MediaType
                    </MudChip>
                }
                @if (!string.IsNullOrWhiteSpace(Node.RelationshipToParent))
                {
                    <MudText Typo="Typo.caption" Style="color: #888; font-size: 10px;">
                        (@Node.RelationshipToParent)
                    </MudText>
                }
            </MudStack>
        </div>
    </div>
@if (Node.Children.Count > 0)
    {
        <div class="adaptation-children">
            @foreach (var child in Node.Children)
            {
                <AdaptationTreeNode Node="@child" Depth="@(Depth + 1)" />
            }
        </div>
    }
</div>

<style>
    .adaptation-node {
        position: relative;
    }
    .adaptation-card {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        margin-bottom: 4px;
        background: #111;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
        transition: border-color 0.15s;
    }
    .adaptation-card:hover {
        border-color: #444;
    }
    .adapt-thumb {
        width: 40px;
        height: 56px;
        border-radius: 4px;
        object-fit: cover;
        flex-shrink: 0;
    }
    .adapt-thumb-placeholder {
        width: 40px;
        height: 56px;
        border-radius: 4px;
        background: #1a1a1a;
        border: 1px solid #333;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .adapt-info {
        flex: 1;
        overflow: hidden;
    }
    .adaptation-children {
        border-left: 2px solid #2a2a2a;
        margin-left: 12px;
        padding-left: 0;
    }
</style>

@code {
    [Parameter] public AdaptationNodeDto Node { get; set; } = new();
    [Parameter] public int Depth { get; set; }

    private static string GetMediaTypeIcon(string? mediaType) => mediaType?.ToLowerInvariant() switch
    {
        "book" or "epub"      => Icons.Material.Filled.MenuBook,
        "movie" or "film"     => Icons.Material.Filled.Movie,
        "tv" or "television"  => Icons.Material.Filled.Tv,
        "comic"               => Icons.Material.Filled.AutoStories,
        "audiobook"           => Icons.Material.Filled.Headphones,
        "music"               => Icons.Material.Filled.MusicNote,
        _                     => Icons.Material.Filled.Category,
    };

    private static Color GetMediaTypeColor(string? mediaType) => mediaType?.ToLowerInvariant() switch
    {
        "book" or "epub"      => Color.Primary,
        "movie" or "film"     => Color.Error,
        "tv" or "television"  => Color.Secondary,
        "comic"               => Color.Warning,
        "audiobook"           => Color.Success,
        _                     => Color.Default,
    };
}
