<div class="collection-shell">
    @if (ShowToolbar && ToolbarContent is not null)
    {
        <div class="collection-shell-toolbar">
            @ToolbarContent
        </div>
    }

    <div class="collection-shell-body @(SidebarContent is not null ? "collection-shell-body--with-sidebar" : "")"
         style="@(SidebarContent is not null ? $"--collection-sidebar-width: {SidebarWidth}px;" : "")">

        @if (SidebarContent is not null)
        {
            <aside class="collection-shell-sidebar">
                @SidebarContent
            </aside>
        }

        <main class="collection-shell-content">
            @ChildContent
        </main>
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ToolbarContent { get; set; }
    [Parameter] public RenderFragment? SidebarContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public int SidebarWidth { get; set; } = 260;
    [Parameter] public bool ShowToolbar { get; set; } = true;
}