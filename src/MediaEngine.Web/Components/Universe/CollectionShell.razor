@* CollectionShell — universal layout frame for all Collection views.
   Provides three slots: toolbar (optional), sidebar (optional), and content (required).
   Knows nothing about the data or view type inside it. *@

<div class="collection-shell">
    @if (ShowToolbar && ToolbarContent is not null)
    {
        <div class="collection-shell-toolbar">
            @ToolbarContent
        </div>
    }

    <div class="collection-shell-body @(SidebarContent is not null ? "collection-shell-body--with-sidebar" : "")"
         style="@(SidebarContent is not null ? $"--collection-sidebar-width: {SidebarWidth}px;" : "")">

        @if (SidebarContent is not null)
        {
            <aside class="collection-shell-sidebar">
                @SidebarContent
            </aside>
        }

        <main class="collection-shell-content">
            @ChildContent
        </main>
    </div>
</div>

@code {
    /// <summary>Optional toolbar area above the main content (media type toggles, filters).</summary>
    [Parameter] public RenderFragment? ToolbarContent { get; set; }

    /// <summary>Optional left sidebar (item list, navigation).</summary>
    [Parameter] public RenderFragment? SidebarContent { get; set; }

    /// <summary>Main content area (BookDetail, PosterGrid, etc.). Required.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Sidebar width in pixels. Only used when SidebarContent is provided.</summary>
    [Parameter] public int SidebarWidth { get; set; } = 260;

    /// <summary>Whether to show the toolbar area.</summary>
    [Parameter] public bool ShowToolbar { get; set; } = true;
}

<style>
    .collection-shell {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 56px); /* below TopBar */
        overflow: hidden;
        margin-left: 0;
    }

    .collection-shell-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 16px;
        background: rgba(8, 13, 30, 0.7);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        flex-shrink: 0;
        flex-wrap: wrap;
    }

    .collection-shell-body {
        flex: 1;
        min-height: 0;
        display: flex;
        overflow: hidden;
    }

    .collection-shell-body--with-sidebar {
        display: grid;
        grid-template-columns: var(--collection-sidebar-width, 260px) 1fr;
    }

    .collection-shell-sidebar {
        display: flex;
        flex-direction: column;
        background: rgba(8, 13, 30, 0.5);
        border-right: 1px solid rgba(255, 255, 255, 0.06);
        overflow: hidden;
    }

    .collection-shell-content {
        flex: 1;
        min-width: 0;
        min-height: 0;
        overflow: hidden;
        position: relative;
    }
</style>
