@namespace MediaEngine.Web.Components.Universe
@inject DeviceContextService DeviceContext
@implements IDisposable

@* "Your Universes" Bento grid — clean minimalist design.
   All tiles are 1x1. Each tile shows: title and metadata line.
   Column count and tile style driven by device context via parent parameters. *@

@if (VisibleHubs is { Count: > 0 })
{
    <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">
        Your Universes
    </MudText>

    <BentoGrid Class="@Class" Columns="@Columns" TileStyle="@TileStyle">
        @foreach (var hub in VisibleHubs)
        {
            var extraClass = IsLargeTile ? "large-tile" : string.Empty;

            <BentoItem ColSpan="1" RowSpan="1"
                       GlowColor="@hub.DominantHexColor"
                       Class="@extraClass">

                @* ── The Reveal tile ── *@
                <div class="bento-hub-tile" @onclick="() => OnHubSelected.InvokeAsync(hub)">

                    @* Color-fill background derived from hub's dominant color *@
                    <div class="bento-hub-bg" style="@HubBgStyle(hub.DominantHexColor)"></div>

                    @* Metadata panel — hidden by default, slides up on hover *@
                    <div class="bento-hub-reveal">
                        <span class="hub-reveal-title">@hub.DisplayName</span>
                        <span class="hub-reveal-meta">
                            @hub.WorkCount @(hub.WorkCount == 1 ? "work" : "works") · @hub.MediaTypes
                        </span>
                        <div class="hub-reveal-icons">
                            @foreach (var icon in GetDistinctMediaIcons(hub))
                            {
                                <MudIcon Icon="@icon"
                                         Size="@(IsLargeTile ? Size.Medium : Size.Small)"
                                         Style="color: rgba(248,248,248,0.75); font-size: 18px;" />
                            }
                        </div>
                    </div>

                </div>
            </BentoItem>
        }
    </BentoGrid>
}
else if (VisibleHubs is { Count: 0 } && Hubs is { Count: > 0 })
{
    <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="0"
              Style="background: var(--app-glass-inner-bg); border-radius: 20px; border: 1px solid var(--app-glass-inner-border);">
        <MudIcon Icon="@Icons.Material.Filled.FilterAlt"
                 Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
        <MudText Typo="Typo.h6" Class="mb-2">No matching Hubs</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--app-text-muted);">
            Try a different filter from the dock.
        </MudText>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="0"
              Style="background: var(--app-glass-inner-bg); border-radius: 20px; border: 1px solid var(--app-glass-inner-border);">
        <MudIcon Icon="@Icons.Material.Filled.LibraryAdd"
                 Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
        <MudText Typo="Typo.h6" Class="mb-2">Your library is empty</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--app-text-muted);">
            Configure a watch directory and drop files in to get started.
        </MudText>
    </MudPaper>
}

@code {
    [Parameter] public List<HubViewModel>?         Hubs          { get; set; }
    [Parameter] public string?                     Class         { get; set; }
    [Parameter] public EventCallback<HubViewModel> OnHubSelected { get; set; }
    [Parameter] public int Columns { get; set; }
    [Parameter] public string TileStyle { get; set; } = "normal";

    private bool IsLargeTile =>
        string.Equals(TileStyle, "large", StringComparison.OrdinalIgnoreCase);

    private List<HubViewModel> VisibleHubs =>
        Hubs is null
            ? []
            : string.Equals(TileStyle, "audio-only", StringComparison.OrdinalIgnoreCase)
                ? Hubs.Where(h => h.Works.Any(w => UniverseMapper.IsAudio(w.MediaType))).ToList()
                : Hubs;

    protected override void OnInitialized() =>
        DeviceContext.OnChanged += OnDeviceChanged;

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() =>
        DeviceContext.OnChanged -= OnDeviceChanged;

    // ── Reveal helpers ────────────────────────────────────────────────────────

    private static string HubBgStyle(string? hex)
    {
        if (string.IsNullOrWhiteSpace(hex))
            return "background: linear-gradient(135deg, #2A2020 0%, #111111 100%);";
        var dark = DimHex(hex);
        return $"background: linear-gradient(135deg, {hex} 0%, {dark} 100%);";
    }

    private static string DimHex(string hex)
    {
        try
        {
            hex = hex.TrimStart('#');
            if (hex.Length == 3) hex = $"{hex[0]}{hex[0]}{hex[1]}{hex[1]}{hex[2]}{hex[2]}";
            if (hex.Length != 6) return "#1A1A1A";
            var r = Math.Clamp((int)(Convert.ToInt32(hex[..2],  16) * 0.45), 0, 255);
            var g = Math.Clamp((int)(Convert.ToInt32(hex[2..4], 16) * 0.45), 0, 255);
            var b = Math.Clamp((int)(Convert.ToInt32(hex[4..6], 16) * 0.45), 0, 255);
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch { return "#1A1A1A"; }
    }

    private static List<string> GetDistinctMediaIcons(HubViewModel hub)
    {
        var icons = new List<string>();
        var types = hub.Works.Select(w => w.MediaType.ToLowerInvariant()).Distinct().ToList();

        if (types.Any(t => t.Contains("video") || t.Contains("movie")))
            icons.Add(Icons.Material.Filled.PlayCircle);
        if (types.Any(t => t.Contains("epub") || t.Contains("book")))
            icons.Add(Icons.Material.Filled.MenuBook);
        if (types.Any(t => t.Contains("audio")))
            icons.Add(Icons.Material.Filled.Headphones);
        if (types.Any(t => t.Contains("comic") || t.Contains("cbz") || t.Contains("cbr")))
            icons.Add(Icons.Material.Filled.AutoStories);

        if (icons.Count == 0)
            icons.Add(Icons.Material.Filled.Folder);

        return icons;
    }
}

<style>
    /* ── The Reveal tile ─────────────────────────────────────────── */
    .bento-hub-tile {
        position:   relative;
        height:     100%;
        min-height: inherit;
        cursor:     pointer;
        user-select: none;
        overflow:   hidden; /* clips the reveal panel */
    }

    /* Color-fill background — fills the full tile */
    .bento-hub-bg {
        position:   absolute;
        inset:      0;
        transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Subtle zoom on the bg when the tile is hovered */
    .bento-hub-tile:hover .bento-hub-bg {
        transform: scale(1.06);
    }

    /* Metadata panel — hidden below the tile, slides up on hover */
    .bento-hub-reveal {
        position:        absolute;
        bottom:          0;
        left:            0;
        right:           0;
        padding:         1rem 1.25rem 1.1rem;
        background:      rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        display:         flex;
        flex-direction:  column;
        gap:             3px;
        transform:       translateY(100%);
        transition:      transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .bento-hub-tile:hover .bento-hub-reveal {
        transform: translateY(0);
    }

    /* Title — SemiBold (600) per Media Titles spec */
    .hub-reveal-title {
        font-family:     'Montserrat', sans-serif;
        font-size:       0.95rem;
        font-weight:     600;
        color:           #F8F8F8;
        letter-spacing:  0;
        line-height:     1.3;
        white-space:     nowrap;
        overflow:        hidden;
        text-overflow:   ellipsis;
        display:         block;
    }

    /* Metadata line — Medium (500), wide tracking, 70% opacity */
    .hub-reveal-meta {
        font-family:    'Montserrat', sans-serif;
        font-size:      0.75rem;
        font-weight:    500;
        letter-spacing: 0.05em;
        opacity:        0.70;
        color:          #F8F8F8;
        display:        block;
    }

    .hub-reveal-icons {
        display:     flex;
        gap:         6px;
        align-items: center;
        margin-top:  5px;
    }
</style>
