@namespace MediaEngine.Web.Components.Universe
<AppCssElement Tag="div" Class="ambient-bg" aria-hidden="true"
     Css="@($"--ambient-color: {Color ?? "#080B14"}; --ambient-opacity: {OpacityStr};")">
</AppCssElement>

@code {
    [Parameter] public string? Color { get; set; }
    [Parameter] public double Opacity { get; set; } = 0.25;

    private string OpacityStr => Opacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
}