@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Models.ViewDTOs

@if (Data is not null)
{
    <div class="category-hero" @onclick="HandleClick">
        @* Blurred backdrop *@
        <div class="category-hero-backdrop" aria-hidden="true">
            @if (!string.IsNullOrEmpty(Data.HeroUrl ?? Data.CoverUrl))
            {
                <img src="@(Data.HeroUrl ?? Data.CoverUrl)" alt=""
                     class="category-hero-backdrop-img" />
            }
            <div class="category-hero-vignette"></div>
        </div>

        @* Content *@
        <div class="category-hero-content">
            @if (!string.IsNullOrEmpty(Data.CoverUrl))
            {
                <div class="category-hero-cover @(Data.IsPortraitMedia ? "portrait" : "landscape")">
                    <img src="@Data.CoverUrl" alt="@Data.Title"
                         class="category-hero-cover-img" />
                </div>
            }
            <div class="category-hero-info">
                <div class="category-hero-count" style="color: @AccentColor;">
                    @ItemCount @(ItemCount == 1 ? "Title" : "Titles") in Collection
                </div>
                <span class="category-hero-title">@Data.Title</span>
                <div class="category-hero-meta">
                    @if (!string.IsNullOrEmpty(Data.Author))
                    {
                        <span>@Data.Author</span>
                    }
                    @if (!string.IsNullOrEmpty(Data.Year))
                    {
                        <span>@Data.Year</span>
                    }
                    @if (!string.IsNullOrEmpty(Data.MediaTypeLabel))
                    {
                        <span>@Data.MediaTypeLabel</span>
                    }
                </div>
                @if (Data.ProgressPct is > 0)
                {
                    <div class="category-hero-progress">
                        <div class="category-hero-progress-track">
                            <div class="category-hero-progress-fill"
                                 style="width: @(Data.ProgressPct.Value)%; background: @AccentColor;"></div>
                        </div>
                        <span class="category-hero-progress-text">@($"{Data.ProgressPct.Value:F0}%")</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Data.ActionLabel))
                {
                    <div class="category-hero-actions">
                        <button class="category-hero-cta"
                                style="background: @AccentColor;"
                                @onclick="HandleCta" @onclick:stopPropagation="true">
                            @if (!string.IsNullOrEmpty(Data.ActionIcon))
                            {
                                <MudIcon Icon="@Data.ActionIcon" Size="Size.Small"
                                         Style="font-size: 16px;" />
                            }
                            @Data.ActionLabel
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public HeroData? Data { get; set; }
    [Parameter] public string CategoryLabel { get; set; } = "";
    [Parameter] public string AccentColor { get; set; } = "#C9922E";
    [Parameter] public int ItemCount { get; set; }
    [Parameter] public EventCallback OnClicked { get; set; }
    [Parameter] public EventCallback OnCtaClicked { get; set; }

    private async Task HandleClick() => await OnClicked.InvokeAsync();
    private async Task HandleCta() => await OnCtaClicked.InvokeAsync();
}

<style>
    .category-hero {
        position: relative;
        width: 100%;
        border-radius: 16px;
        overflow: hidden;
        cursor: pointer;
        margin-bottom: 2rem;
        display: grid;
        grid-template: 1fr / 1fr;
    }

    .category-hero > * {
        grid-area: 1 / 1;
    }

    .category-hero-backdrop {
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .category-hero-backdrop-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: blur(40px) brightness(0.45);
        transform: scale(1.2);
    }

    .category-hero-vignette {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to right,
            rgba(8, 11, 20, 0.90) 0%,
            rgba(8, 11, 20, 0.50) 50%,
            rgba(8, 11, 20, 0.80) 100%
        );
    }

    .category-hero-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 24px;
        padding: 24px 32px;
    }

    .category-hero-cover {
        flex-shrink: 0;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.50);
    }

    .category-hero-cover.portrait {
        width: 100px;
        height: 150px;
    }

    .category-hero-cover.landscape {
        width: 160px;
        height: auto;
        aspect-ratio: 16 / 9;
    }

    .category-hero-cover-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .category-hero-info {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .category-hero-count {
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.4em;
        margin-bottom: 4px;
    }

    .category-hero-title {
        font-family: 'Montserrat', sans-serif;
        font-size: clamp(1.3rem, 2.5vw, 1.8rem);
        font-weight: 700;
        color: rgba(248, 248, 248, 0.95);
        line-height: 1.2;
        letter-spacing: -0.02em;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .category-hero-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        font-weight: 400;
        color: rgba(248, 248, 248, 0.50);
    }

    .category-hero-meta > span:not(:last-child)::after {
        content: '\00B7';
        margin-left: 8px;
        color: rgba(248, 248, 248, 0.25);
    }

    .category-hero-progress {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 4px;
    }

    .category-hero-progress-track {
        flex: 1;
        max-width: 200px;
        height: 3px;
        background: rgba(255, 255, 255, 0.10);
        border-radius: 2px;
        overflow: hidden;
    }

    .category-hero-progress-fill {
        height: 100%;
        border-radius: 2px;
        transition: width 0.3s ease;
    }

    .category-hero-progress-text {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.45);
    }

    .category-hero-actions {
        margin-top: 8px;
    }

    .category-hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        color: #000;
        border: none;
        border-radius: 8px;
        padding: 8px 18px;
        cursor: pointer;
        transition: opacity 0.2s ease, transform 0.15s ease;
    }

    .category-hero-cta:hover {
        opacity: 0.85;
        transform: translateY(-1px);
    }

    /* Mobile */
    @@media (max-width: 768px) {
        .category-hero-content {
            gap: 14px;
            padding: 16px 18px;
        }

        .category-hero-cover.portrait {
            width: 72px;
            height: 108px;
        }

        .category-hero-cover.landscape {
            width: 110px;
        }

        .category-hero-title {
            font-size: 1.1rem;
            -webkit-line-clamp: 1;
        }

        .category-hero-meta > span:nth-child(n+3) {
            display: none;
        }
    }
</style>
