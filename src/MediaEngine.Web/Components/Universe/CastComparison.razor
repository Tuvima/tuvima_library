@namespace MediaEngine.Web.Components.Universe
@inject IEngineApiClient ApiClient
@inject IJSRuntime JS
<div class="cast-panel">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudText Typo="Typo.subtitle1" Class="tl-u-color-tl-accent-primary tl-u-font-weight-600 tl-u-flex-1">
            Cast Comparison
        </MudText>
        <AppSwitchRow T="bool" @bind-Value="_multiActorOnly" Label="Multi-actor only"
                   Color="Color.Warning" />
        <AppTextField T="string" @bind-Value="_search" Placeholder="Search characters..."
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="tl-u-max-width-200px"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" />
    </MudStack>

    @if (_loading)
    {
        <div class="d-flex justify-center pa-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Warning" />
        </div>
    }
    else if (_castData?.Characters.Count > 0)
    {
        <div class="cast-grid">
            @foreach (var character in FilteredCharacters)
            {
                <div class="cast-card">
                    @* Character portrait *@
                    <div class="character-portrait">
                        @if (!string.IsNullOrWhiteSpace(character.Image))
                        {
                            <img src="@character.Image" alt="@character.Label" class="char-img" />
                        }
                        else
                        {
                            <div class="char-img-placeholder">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Class="tl-u-font-size-32px tl-u-color-hex-555" />
                            </div>
                        }
                    </div>

                    @* Character name *@
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1 tl-u-font-weight-600 tl-u-white-space-nowrap tl-u-overflow-hidden tl-u-text-overflow-ellipsis tl-u-max-width-160px"
                             >
                        @character.Label
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(character.Description))
                    {
                        <MudText Typo="Typo.caption" Class="tl-u-color-hex-888 tl-u-font-size-11px tl-u-overflow-hidden tl-u-display-webkit-box tl-u-webkit-line-clamp-2 tl-u-webkit-box-orient-vertical tl-u-max-width-160px">
                            @character.Description
                        </MudText>
                    }

                    @* Performer chips *@
                    @if (character.Performers.Count > 0)
                    {
                        <MudText Typo="Typo.caption" Class="tl-u-color-tl-accent-primary tl-u-margin-top-8px tl-u-margin-bottom-4px tl-u-font-size-11px tl-u-font-weight-600">
                            PERFORMERS (@character.Performers.Count)
                        </MudText>
                        <div class="performer-row">
                            @foreach (var performer in character.Performers)
                            {
                                <div class="performer-chip">
                                    @if (!string.IsNullOrWhiteSpace(performer.HeadshotUrl))
                                    {
                                        <MudAvatar Size="Size.Small"><img src="@performer.HeadshotUrl" alt="@performer.Name" class="tl-u-width-100pct tl-u-height-100pct tl-u-object-fit-cover" /></MudAvatar>
                                    }
                                    else
                                    {
                                        <MudAvatar Size="Size.Small" Color="Color.Secondary">
                                            @(performer.Name.Length > 0 ? performer.Name[0].ToString() : "?")
                                        </MudAvatar>
                                    }
                                    <MudText Typo="Typo.caption" Class="tl-u-font-size-11px tl-u-white-space-nowrap tl-u-overflow-hidden tl-u-text-overflow-ellipsis tl-u-max-width-80px">
                                        @performer.Name
                                    </MudText>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Class="tl-u-color-hex-444 tl-u-margin-top-8px tl-u-font-size-11px">
                            No performers linked
                        </MudText>
                    }
                </div>
            }
        </div>

        @if (!FilteredCharacters.Any())
        {
            <MudText Typo="Typo.body2" Class="tl-u-color-hex-555 tl-u-text-align-center tl-u-padding-32px-0">
                No characters match the current filters.
            </MudText>
        }
    }
    else if (!_loading)
    {
        <AppAlert Severity="Severity.Info">No cast data found for this universe.</AppAlert>
    }
</div>
@code {
    [Parameter] public string UniverseQid { get; set; } = string.Empty;

    private bool _multiActorOnly;
    private string _search = string.Empty;
    private bool _loading;
    private UniverseCastResponse? _castData;

    private IEnumerable<CastCharacterDto> FilteredCharacters
    {
        get
        {
            var source = _castData?.Characters ?? [];
            if (_multiActorOnly)
                source = source.Where(c => c.Performers.Count > 1).ToList();
            if (!string.IsNullOrWhiteSpace(_search))
                source = source.Where(c => c.Label.Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();
            return source;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(UniverseQid) && _castData is null)
            await LoadCast();
    }

    private async Task LoadCast()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _castData = await ApiClient.GetUniverseCastAsync(UniverseQid);
        }
        finally
        {
            _loading = false;
        }
    }
}