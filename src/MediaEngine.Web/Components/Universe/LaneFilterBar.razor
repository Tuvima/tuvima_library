@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Models.ViewDTOs

@* LaneFilterBar -- Unified filter controls for all lane pages (desktop only).
   Driven by LaneFilterConfig to show media-type-appropriate controls. *@

<div class="lane-filter-bar">
    @if (Config.FormatOptions.Length > 1)
    {
        <div class="filter-format-toggle">
            <MudChipSet T="string" SelectedValue="@FilterState.Format"
                        SelectedValueChanged="OnFormatChanged"
                        Class="filter-chip-set">
                @foreach (var fmt in Config.FormatOptions)
                {
                    <MudChip T="string" Value="@fmt" Variant="Variant.Text"
                             Style="@ChipStyle(fmt)">@fmt</MudChip>
                }
            </MudChipSet>
        </div>
    }

    <div class="filter-controls">
        <MudSelect T="string" Label="Genre" MultiSelection="true"
                   SelectedValues="@FilterState.SelectedGenres"
                   SelectedValuesChanged="OnGenresChanged"
                   Dense="true" Variant="Variant.Outlined"
                   AdornmentIcon="@Icons.Material.Filled.FilterList"
                   AnchorOrigin="Origin.BottomCenter"
                   Class="filter-select" Style="min-width: 160px;">
            @foreach (var genre in AvailableGenres)
            {
                <MudSelectItem T="string" Value="@genre">@genre</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="string" Label="Sort" Value="@FilterState.SortBy"
                   ValueChanged="OnSortChanged"
                   Dense="true" Variant="Variant.Outlined"
                   Class="filter-select" Style="min-width: 150px;">
            <MudSelectItem T="string" Value="@("recent")">Recently Added</MudSelectItem>
            <MudSelectItem T="string" Value="@("title-az")">Title A-Z</MudSelectItem>
            <MudSelectItem T="string" Value="@("title-za")">Title Z-A</MudSelectItem>
            <MudSelectItem T="string" Value="@("person-az")">@Config.PersonLabel A-Z</MudSelectItem>
            <MudSelectItem T="string" Value="@("year-new")">Year (Newest)</MudSelectItem>
            <MudSelectItem T="string" Value="@("year-old")">Year (Oldest)</MudSelectItem>
        </MudSelect>

        <MudAutocomplete T="string" Label="@Config.PersonLabel" Value="@FilterState.PersonSearch"
                         ValueChanged="OnPersonChanged" SearchFunc="SearchPersons"
                         Dense="true" Variant="Variant.Outlined" Clearable="true"
                         Class="filter-select" Style="min-width: 160px;"
                         ResetValueOnEmptyText="true" />

        @if (Config.SeriesLabel is not null)
        {
            <MudSelect T="string" Label="@Config.SeriesLabel" Value="@FilterState.SeriesFilter"
                       ValueChanged="OnSeriesChanged"
                       Dense="true" Variant="Variant.Outlined" Clearable="true"
                       Class="filter-select" Style="min-width: 150px;">
                <MudSelectItem T="string" Value="@("")">All @Config.SeriesLabel</MudSelectItem>
                @foreach (var series in AvailableSeries)
                {
                    <MudSelectItem T="string" Value="@series">@series</MudSelectItem>
                }
            </MudSelect>
        }

        @if (Config.ShowYearRange)
        {
            <div class="filter-year-range">
                <MudTextField T="string" Label="From" Value="@FilterState.YearFrom"
                              ValueChanged="OnYearFromChanged" Margin="Margin.Dense"
                              Variant="Variant.Outlined" InputType="InputType.Number"
                              Style="width: 80px;" />
                <span class="filter-year-dash">-</span>
                <MudTextField T="string" Label="To" Value="@FilterState.YearTo"
                              ValueChanged="OnYearToChanged" Margin="Margin.Dense"
                              Variant="Variant.Outlined" InputType="InputType.Number"
                              Style="width: 80px;" />
            </div>
        }

        @if (FilterState.HasActiveFilters)
        {
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearAll"
                       Style="color: rgba(248,248,248,0.50); text-transform: none;">
                Clear
            </MudButton>
        }
    </div>
</div>

@code {
    [Parameter] public LaneFilterState FilterState { get; set; } = new();
    [Parameter] public EventCallback<LaneFilterState> FilterStateChanged { get; set; }
    [Parameter] public LaneFilterConfig Config { get; set; } = LaneFilterConfig.ForLane("books");
    [Parameter] public IReadOnlyList<string> AvailableGenres { get; set; } = [];
    [Parameter] public IReadOnlyList<string> AvailableSeries { get; set; } = [];
    [Parameter] public IReadOnlyList<string> AvailablePersons { get; set; } = [];

    private async Task NotifyChanged() => await FilterStateChanged.InvokeAsync(FilterState);

    private async Task OnFormatChanged(string value)
    { FilterState = FilterState with { Format = value ?? "All" }; await NotifyChanged(); }

    private async Task OnGenresChanged(IEnumerable<string> values)
    { FilterState = FilterState with { SelectedGenres = values.ToHashSet() }; await NotifyChanged(); }

    private async Task OnSortChanged(string value)
    { FilterState = FilterState with { SortBy = value ?? "recent" }; await NotifyChanged(); }

    private async Task OnPersonChanged(string value)
    { FilterState = FilterState with { PersonSearch = value }; await NotifyChanged(); }

    private async Task OnSeriesChanged(string value)
    { FilterState = FilterState with { SeriesFilter = value }; await NotifyChanged(); }

    private async Task OnYearFromChanged(string value)
    { FilterState = FilterState with { YearFrom = value }; await NotifyChanged(); }

    private async Task OnYearToChanged(string value)
    { FilterState = FilterState with { YearTo = value }; await NotifyChanged(); }

    private async Task ClearAll()
    { FilterState = new LaneFilterState(); await NotifyChanged(); }

    private Task<IEnumerable<string>> SearchPersons(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(AvailablePersons.AsEnumerable());
        return Task.FromResult(AvailablePersons
            .Where(p => p.Contains(value, StringComparison.OrdinalIgnoreCase)).Take(10));
    }

    private string ChipStyle(string v) => FilterState.Format == v
        ? "color: #C9922E; font-weight: 600; font-family: Montserrat, sans-serif;"
        : "color: rgba(248,248,248,0.60); font-family: Montserrat, sans-serif;";
}

<style>
    .lane-filter-bar { padding: 0 0 1rem 88px; }
    .filter-format-toggle { margin-bottom: 12px; }
    .filter-chip-set { gap: 4px; }
    .filter-controls { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .filter-select { font-family: Montserrat, sans-serif; font-size: 0.85rem; }
    .filter-year-range { display: flex; align-items: center; gap: 4px; }
    .filter-year-dash { color: rgba(248,248,248,0.40); font-size: 0.9rem; padding-top: 12px; }

    @@media (max-width: 768px) {
        .lane-filter-bar { display: none; }
    }
</style>
