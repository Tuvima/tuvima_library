@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Models.ViewDTOs
@if (Visible && Data is not null)
{
    <div class="hero-banner @(Data.IsPortraitMedia ? "hero-portrait" : "hero-landscape")"
         style="@AmbientStyle">
<div class="hero-banner-bg">
            <div class="hero-bleed">
                <div class="hero-backdrop">
                    @if (!string.IsNullOrEmpty(Data.HeroUrl))
                    {
                        <img src="@Data.HeroUrl" alt="" class="hero-bg-prerendered" />
                    }
                    else if (!string.IsNullOrEmpty(Data.CoverUrl))
                    {
                        <img src="@Data.CoverUrl" alt="" class="hero-bg-blurred" />
                    }
<div class="hero-vignette" />

                    @* Gradient fallback when no art at all *@
                    @if (string.IsNullOrEmpty(Data.HeroUrl) && string.IsNullOrEmpty(Data.CoverUrl))
                    {
                        <div class="hero-gradient"
                             style="--hero-accent: @(Data.DominantColor ?? "var(--tl-accent-primary)");" />
                    }
                </div>
            </div>
        </div>
@if (Data.IsPortraitMedia && !string.IsNullOrEmpty(Data.CoverUrl))
        {
            <div class="hero-mobile-cover-wrapper" @onclick="HandleClick">
                <img src="@Data.CoverUrl"
                     alt="@Data.Title"
                     class="hero-mobile-cover" />
@if (!string.IsNullOrEmpty(Data.MediaTypeLabel))
                {
                    <div class="hero-mobile-type-icon"
                         style="background: @(HeroData.FormatBadgeColor(Data.MediaTypeLabel))">
                        <MudIcon Icon="@(HeroData.IconForMediaType(Data.MediaTypeLabel))"
                                 Style="font-size: 0.85rem; color: white;" />
                    </div>
                }
            </div>
        }
<div class="hero-content">
            @if (Data.IsPortraitMedia)
            {
                @* Portrait layout: cover + text side by side on desktop *@
                <div class="hero-content-row">
                    @if (!string.IsNullOrEmpty(Data.CoverUrl))
                    {
                        <img src="@Data.CoverUrl"
                             alt="@Data.Title"
                             class="hero-poster"
                             @onclick="HandleClick" />
                    }
                    <div class="hero-text">
                        <CollectionHeroText Data="@Data" OnCtaClicked="@OnCtaClicked" OnClicked="@OnClicked" />
                    </div>
                </div>
            }
            else
            {
                @* Landscape layout: text only *@
                <div class="hero-text">
                    <CollectionHeroText Data="@Data" OnCtaClicked="@OnCtaClicked" OnClicked="@OnClicked" />
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public HeroData? Data { get; set; }
    [Parameter] public bool Visible { get; set; } = true;
    [Parameter] public EventCallback OnClicked { get; set; }
    [Parameter] public EventCallback OnCtaClicked { get; set; }

    private string? AmbientStyle => Data?.DominantColor is not null
        ? $"--hero-dominant: {Data.DominantColor};"
        : null;

    private async Task HandleClick()
    {
        if (OnClicked.HasDelegate)
            await OnClicked.InvokeAsync();
    }
}