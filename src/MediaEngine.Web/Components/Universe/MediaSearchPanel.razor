@inject UIOrchestratorService Orchestrator

<div class="search-panel">
@if (_comparisonCandidate != null)
    {
        <div class="sp-comparison-view">
            @* Back link *@
            <AppNativeButton Class="sp-back-link" OnClick="ClearComparison">
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Style="margin-right: 4px;" />
                Back to results
            </AppNativeButton>

            <div class="sp-comparison-title">Compare &amp; Apply Match</div>

            @* Side-by-side summary *@
            <div class="sp-comparison-summary">
                @* Your File *@
                <div class="sp-comparison-side sp-comparison-current">
                    <div class="sp-comparison-side-label">Your File</div>
                    <div class="sp-comparison-cover-wrap">
                        @if (!string.IsNullOrEmpty(CurrentCoverUrl))
                        {
                            <img src="@CurrentCoverUrl" alt="current cover" class="sp-comparison-cover" />
                        }
                        else
                        {
                            <div class="sp-comparison-cover-placeholder">
                                <MudIcon Icon="@Icons.Material.Outlined.InsertDriveFile" Size="Size.Large" Style="opacity: 0.3;" />
                            </div>
                        }
                    </div>
                    <div class="sp-comparison-side-title">@(CurrentTitle ?? "(no title)")</div>
                    @if (!string.IsNullOrEmpty(CurrentAuthor))
                    {
                        <div class="sp-comparison-side-meta">@CurrentAuthor</div>
                    }
                    @if (!string.IsNullOrEmpty(CurrentYear))
                    {
                        <div class="sp-comparison-side-meta">@CurrentYear</div>
                    }
                </div>

                <div class="sp-comparison-arrow">
                    <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Size="Size.Large" Style="color: var(--tl-accent-primary); opacity: 0.6;" />
                </div>

                @* Candidate *@
                <div class="sp-comparison-side sp-comparison-candidate">
                    <div class="sp-comparison-side-label">
                        @GetCandidateSourceLabel()
                    </div>
                    <div class="sp-comparison-cover-wrap">
                        @{
                            var candCover = GetCandidateCoverUrl();
                        }
                        @if (!string.IsNullOrEmpty(candCover))
                        {
                            <img src="@candCover" alt="candidate cover" class="sp-comparison-cover" />
                        }
                        else
                        {
                            <div class="sp-comparison-cover-placeholder">
                                <MudIcon Icon="@Icons.Material.Outlined.Image" Size="Size.Large" Style="opacity: 0.3;" />
                            </div>
                        }
                    </div>
                    <div class="sp-comparison-side-title">@GetCandidateTitle()</div>
                    @{
                        var candAuthor = GetCandidateAuthor();
                        var candYear   = GetCandidateYear();
                    }
                    @if (!string.IsNullOrEmpty(candAuthor))
                    {
                        <div class="sp-comparison-side-meta">@candAuthor</div>
                    }
                    @if (!string.IsNullOrEmpty(candYear))
                    {
                        <div class="sp-comparison-side-meta">@candYear</div>
                    }
                </div>
            </div>

            @* Source attribution *@
            <div class="sp-source-attribution">
                @if (_comparisonCandidate is UniverseCandidateDto uc)
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Public" Size="Size.Small" Style="margin-right: 4px; color: var(--tl-accent-primary);" />
                    <span>Source: <strong>Wikidata</strong>  -  <span class="sp-qid-pill">@uc.Qid</span></span>
                }
                else if (_comparisonCandidate is RetailCandidateDto rc)
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Store" Size="Size.Small" Style="margin-right: 4px; color: #888;" />
                    <span>Source: <strong>@rc.ProviderName</strong></span>
                }
            </div>

            @if (_comparisonCandidate is UniverseCandidateDto)
            {
<div class="sp-wikidata-notice">
                    <MudIcon Icon="@Icons.Material.Outlined.Lock" Size="Size.Small" Style="color: var(--tl-accent-primary);" />
                    <span>Linking to Wikidata applies <strong>all</strong> available data. Only fields Wikidata does not have can be edited afterward.</span>
                </div>

                @* Read-only field preview (no checkboxes) *@
                <div class="sp-diff-table">
                    <div class="sp-diff-header">
                        <span class="sp-diff-col-field">Field</span>
                        <span class="sp-diff-col-current">Current</span>
                        <span class="sp-diff-col-candidate">Wikidata</span>
                    </div>
                    @foreach (var row in BuildDiffRows())
                    {
                        <div class="sp-diff-row @(row.IsDifferent ? "sp-diff-row-changed" : "")">
                            <span class="sp-diff-col-field sp-diff-field-name">@row.FieldName</span>
                            <span class="sp-diff-col-current sp-diff-value @(string.IsNullOrEmpty(row.CurrentValue) ? "sp-diff-empty" : "")">
                                @(string.IsNullOrEmpty(row.CurrentValue) ? "-" : row.CurrentValue)
                            </span>
                            <span class="sp-diff-col-candidate sp-diff-value @(string.IsNullOrEmpty(row.CandidateValue) ? "sp-diff-empty" : "")">
                                @(string.IsNullOrEmpty(row.CandidateValue) ? "-" : row.CandidateValue)
                            </span>
                        </div>
                    }
                </div>
            }
            else
            {
var hasBothCovers = !string.IsNullOrEmpty(CurrentCoverUrl) && !string.IsNullOrEmpty(GetCandidateCoverUrl());
                if (hasBothCovers)
                {
                    <div class="sp-cover-chooser">
                        <div class="sp-cover-chooser-label">Cover Art</div>
                        <div class="sp-cover-chooser-options">
                            <label class="sp-cover-option @(_useCandidateCover == false ? "sp-cover-option-selected" : "")">
                                <AppNativeInput Type="radio" Name="@($"coverChoice_{EntityId}")" Value="@("current")" Checked="@(_useCandidateCover == false)" OnChange="@(() => _useCandidateCover = false)" />
                                <img src="@CurrentCoverUrl" alt="current" class="sp-cover-thumb" />
                                <span>Keep current</span>
                            </label>
                            <label class="sp-cover-option @(_useCandidateCover == true ? "sp-cover-option-selected" : "")">
                                <AppNativeInput Type="radio" Name="@($"coverChoice_{EntityId}")" Value="@("candidate")" Checked="@(_useCandidateCover == true)" OnChange="@(() => _useCandidateCover = true)" />
                                <img src="@GetCandidateCoverUrl()" alt="candidate" class="sp-cover-thumb" />
                                <span>Use candidate</span>
                            </label>
                        </div>
                    </div>
                }
            }
        </div>
<div class="sp-sticky-bar">
            @if (_comparisonCandidate is UniverseCandidateDto)
            {
                <AppButton Variant="Variant.Filled"
                           OnClick="@(() => ApplyFromComparison("Universe"))"
                           Disabled="@_applying"
                           Size="Size.Small"
                           Style="background: var(--tl-accent-primary); color: #000; font-weight: 700; min-width: 160px;">
                    @(_applying ? "Linking..." : "Link to Wikidata")
                </AppButton>
            }
            else
            {
                <AppButton Variant="Variant.Filled"
                           OnClick="@(() => ApplyFromComparison("image"))"
                           Disabled="@_applying"
                           Size="Size.Small"
                           Style="background: var(--tl-accent-primary); color: #000; font-weight: 700; min-width: 140px;">
                    @(_applying ? "Applying..." : "Use This Cover")
                </AppButton>
            }
            <AppButton Variant="Variant.Outlined"
                       OnClick="@(() => { ClearComparison(); _hasSearched = false; })"
                       Size="Size.Small"
                       Style="border-color: rgba(239,83,80,0.4); color: var(--tl-status-danger);">
                New Search
            </AppButton>
        </div>
    }
    else
    {
@* Search Controls *@
        <div class="search-panel-controls">
            <AppTextField @bind-Value="_query"
                          Placeholder="Search title, author, ISBN, QID..."
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="false"
                          Class="search-panel-input"
                          Style="flex: 1;"
                          OnKeyDown="@OnSearchKeyDown" />

            <AppSelect T="string" @bind-Value="_mediaType"
                       Label="Type" Variant="Variant.Outlined"
                       Dense="true" Style="min-width: 130px;"
                       AnchorOrigin="Origin.BottomCenter">
                <MudSelectItem T="string" Value="@("Books")">Book</MudSelectItem>
                <MudSelectItem T="string" Value="@("Audiobooks")">Audiobook</MudSelectItem>
                <MudSelectItem T="string" Value="@("Movies")">Movie</MudSelectItem>
                <MudSelectItem T="string" Value="@("TV")">TV Show</MudSelectItem>
                <MudSelectItem T="string" Value="@("Music")">Music</MudSelectItem>
                <MudSelectItem T="string" Value="@("Comic")">Comic</MudSelectItem>
            </AppSelect>

            <AppButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="RunSearch"
                       Disabled="@(_searching || string.IsNullOrWhiteSpace(_query))"
                       StartIcon="@Icons.Material.Filled.Search"
                       Size="Size.Medium">
                Search
            </AppButton>
        </div>

        @* Smart search hint *@
        <p class="search-panel-hint sp-search-tip">
            <MudIcon Icon="@Icons.Material.Outlined.Lightbulb" Size="Size.Small"
                     Style="font-size: 0.75rem; vertical-align: middle; margin-right: 3px; opacity: 0.5;" />
            Tip: Paste an ISBN, ASIN, TMDB ID, or QID directly
            @if (!string.IsNullOrEmpty(_detectedIdType))
            {
                <AppChip T="string" Size="Size.Small" Variant="Variant.Filled"
                         Style="font-size: 0.65rem; height: 16px; padding: 0 6px; background: var(--tl-accent-primary-border); color: var(--tl-accent-primary); margin-left: 6px;">
                    @_detectedIdType detected
                </AppChip>
            }
        </p>

        @* Search progress *@
        @if (_searching)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary"
                               Class="mt-2 mb-2" Style="border-radius: 4px;" />
            <p class="search-panel-hint">Searching Wikidata...</p>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <AppAlert Severity="Severity.Warning" Dense="true" Class="mt-2">@_errorMessage</AppAlert>
        }
@if (_universeCandidates.Count > 0)
        {
            <div class="sp-results-section">
@{
                    var best = _universeCandidates[0];
                    var bestConfColor = GetTrafficLightColor(best.Confidence);
                }
                <div class="sp-best-match-card" style="border-left-color: @bestConfColor;"
                     @onclick="@(() => OpenComparison(best))">
                    <div class="sp-best-match-badge">BEST MATCH</div>
                    <div class="sp-result-inner">
                        <div class="search-result-cover">
                            @if (!string.IsNullOrEmpty(best.CoverUrl))
                            {
                                <img src="@best.CoverUrl" alt="" class="search-result-img" loading="lazy" />
                            }
                            else
                            {
                                <div class="search-result-img-placeholder">
                                    <MudIcon Icon="@Icons.Material.Outlined.Public" Size="Size.Medium" Style="opacity: 0.3;" />
                                </div>
                            }
                        </div>
                        <div class="search-result-details">
                            <div class="search-result-title">@best.Label</div>
                            @RenderUniverseMeta(best)
                            @RenderDescription(best.WikipediaExtract ?? best.Description)
                            <div class="search-result-footer">
                                @RenderBridgeChip(best)
                                @RenderInstanceOfChip(best)
                                @RenderConfidenceChip(best.Confidence)
                            </div>
                            @RenderMatchSignals(best.MatchScores, best)
                        </div>
                    </div>
                    <div @onclick:stopPropagation="true" style="align-self: flex-end; margin-top: 8px;">
                        <AppButton Variant="Variant.Filled"
                                   Size="Size.Small"
                                   OnClick="@(() => OpenComparison(best))"
                                   Style="@($"background: {bestConfColor}; color: #000; font-weight: 700;")">
                            Match &amp; Confirm
                        </AppButton>
                    </div>
                </div>

                @* Other candidates (collapsible) *@
                @if (_universeCandidates.Count > 1)
                {
                    <AppNativeButton Class="sp-other-toggle" OnClick="@(() => _showOtherUniverseCandidates = !_showOtherUniverseCandidates)">
                        <MudIcon Icon="@(_showOtherUniverseCandidates ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                 Size="Size.Small" Style="margin-right: 4px;" />
                        @(_showOtherUniverseCandidates ? "Hide" : "Show") @(_universeCandidates.Count - 1) other candidate@(_universeCandidates.Count - 1 == 1 ? "" : "s")
                    </AppNativeButton>

                    @if (_showOtherUniverseCandidates)
                    {
                        <div class="search-results-grid">
                            @foreach (var c in _universeCandidates.Skip(1))
                            {
                                var localC = c;
                                <div class="search-result-card" @onclick="@(() => OpenComparison(localC))">
                                    <div class="search-result-cover">
                                        @if (!string.IsNullOrEmpty(localC.CoverUrl))
                                        {
                                            <img src="@localC.CoverUrl" alt="" class="search-result-img" loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="search-result-img-placeholder">
                                                <MudIcon Icon="@Icons.Material.Outlined.Public" Size="Size.Medium" Style="opacity: 0.3;" />
                                            </div>
                                        }
                                    </div>
                                    <div class="search-result-details">
                                        <div class="search-result-title">@localC.Label</div>
                                        @RenderUniverseMeta(localC)
                                        @RenderDescription(localC.WikipediaExtract ?? localC.Description)
                                        <div class="search-result-footer">
                                            @RenderBridgeChip(localC)
                                            @RenderInstanceOfChip(localC)
                                            @RenderConfidenceChip(localC.Confidence)
                                        </div>
                                        @RenderMatchSignals(localC.MatchScores, localC)
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        }



        @* No results / Did you mean *@
        @if (_hasSearched && !_searching && HasNoResults())
        {
            <div class="search-no-results">
                <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Size="Size.Large" Style="opacity: 0.3;" />
                <p>No matches found.</p>
                @{
                    var cleaned = GetCleanedQuery();
                }
                @if (!string.IsNullOrEmpty(cleaned) && cleaned != _query.Trim())
                {
                    <p class="search-panel-hint">
                        Did you mean: <AppNativeButton Class="sp-did-you-mean" OnClick="@(() => { _query = cleaned; })">@cleaned</AppNativeButton>?
                    </p>
                }
                <p class="search-panel-hint">Try a different query, or create a manual entry.</p>
            </div>
        }

        @* Legacy action buttons (shown when searched but no comparison active) *@
        @if (_hasSearched || _showManualForm)
        {
            <div class="search-panel-actions">
                <AppButton Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Outlined.Edit"
                           OnClick="@(() => _showManualForm = !_showManualForm)"
                           Size="Size.Small">
                    @(_showManualForm ? "Cancel Manual Entry" : "Create Manually")
                </AppButton>
            </div>
        }
    }
@if (_showManualForm)
    {
        <ManualEntryForm EntityId="EntityId"
                         DefaultTitle="@InitialQuery"
                         DefaultMediaType="@InitialMediaType"
                         OnEntryCreated="OnManualEntryCreated" />
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <AppAlert Severity="Severity.Success" Dense="true" Class="mt-2">@_successMessage</AppAlert>
    }

</div>
@code {
    private RenderFragment RenderUniverseMeta(UniverseCandidateDto c) =>
        @<text>
            @if (!string.IsNullOrEmpty(c.Year) || !string.IsNullOrEmpty(c.Author) || !string.IsNullOrEmpty(c.Director))
            {
                <div class="search-result-meta">
                    @if (!string.IsNullOrEmpty(c.Year)) { @c.Year }
                    @if (!string.IsNullOrEmpty(c.Author)) { <text>  -  @c.Author</text> }
                    @if (!string.IsNullOrEmpty(c.Director)) { <text>  -  dir. @c.Director</text> }
                </div>
            }
        </text>;

    private RenderFragment RenderRetailMeta(RetailCandidateDto c) =>
        @<text>
            <div class="search-result-meta">
                @if (!string.IsNullOrEmpty(c.Year)) { @c.Year }
                @if (!string.IsNullOrEmpty(c.Author)) { <text>  -  @c.Author</text> }
                @if (!string.IsNullOrEmpty(c.Director)) { <text>  -  dir. @c.Director</text> }
            </div>
        </text>;

    private RenderFragment RenderDescription(string? text) =>
        @<text>
            @if (!string.IsNullOrEmpty(text))
            {
                <div class="search-result-description">@TruncateText(text, 120)</div>
            }
        </text>;

    private RenderFragment RenderBridgeChip(UniverseCandidateDto c) =>
        @<text>
            @{
                var bridgeLabel = GetBridgeLabel(c);
            }
            @if (!string.IsNullOrEmpty(bridgeLabel))
            {
                <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Style="font-size: 0.65rem; height: 18px; padding: 0 6px; color: var(--tl-accent-primary); border-color: var(--tl-accent-primary-border);">
                    @bridgeLabel
                </AppChip>
            }
            else
            {
                <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Style="font-size: 0.65rem; height: 18px; padding: 0 6px; color: rgba(255,255,255,0.4); border-color: var(--tl-border-strong);">
                    @c.Qid
                </AppChip>
            }
        </text>;

    private RenderFragment RenderInstanceOfChip(UniverseCandidateDto c) =>
        @<text>
            @if (!string.IsNullOrEmpty(c.InstanceOf))
            {
                <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Style="font-size: 0.65rem; height: 18px; padding: 0 6px; color: #888; border-color: var(--tl-border-default);">
                    @TruncateText(c.InstanceOf, 30)
                </AppChip>
            }
        </text>;

    private RenderFragment RenderConfidenceChip(double conf) =>
        @<text>
            <AppChip T="string" Size="Size.Small" Variant="Variant.Filled"
                     Style="@GetConfidenceChipStyle(conf)">
                @((int)(conf * 100))%
            </AppChip>
        </text>;

    private RenderFragment RenderMatchSignals(FieldMatchScoresDto? scores, UniverseCandidateDto? uc) =>
        @<text>
            @{
                var signals = BuildMatchSignals(scores, uc);
            }
            @if (signals.Count > 0)
            {
                <div class="sp-match-signals">
                    @foreach (var sig in signals)
                    {
                        <span class="sp-signal sp-signal-@sig.Level">@sig.Label</span>
                    }
                </div>
            }
        </text>;
}
@code {
    [Parameter] public Guid EntityId { get; set; }
    [Parameter] public string? InitialQuery { get; set; }
    [Parameter] public string? InitialMediaType { get; set; }
    [Parameter] public string? CurrentTitle { get; set; }
    [Parameter] public string? CurrentAuthor { get; set; }
    [Parameter] public string? CurrentYear { get; set; }
    [Parameter] public string? CurrentNarrator { get; set; }
    [Parameter] public string? CurrentCoverUrl { get; set; }
    [Parameter] public string? CurrentMediaType { get; set; }
    [Parameter] public EventCallback<ApplyMatchResponseDto> OnMatchApplied { get; set; }

    private string _query     = "";
    private string _mediaType = "Epub";

    private bool _searching;
    private bool _applying;
    private bool _hasSearched;
    private bool _showManualForm;
    private bool _showOtherUniverseCandidates;
    private object? _comparisonCandidate;
    private bool    _useCandidateCover = true;
    private List<DiffRow> _diffRows = [];

    private List<UniverseCandidateDto> _universeCandidates = [];

    private string? _errorMessage;
    private string? _successMessage;
    private string? _detectedIdType;
    private readonly Dictionary<string, List<UniverseCandidateDto>> _universeCache = new();

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(InitialQuery) && string.IsNullOrWhiteSpace(_query))
            _query = InitialQuery;

        if (!string.IsNullOrWhiteSpace(InitialMediaType) && _mediaType == "Epub")
            _mediaType = InitialMediaType;
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await RunSearch();
    }

    private void DetectIdType()
    {
        var q = _query.Trim();
        if (System.Text.RegularExpressions.Regex.IsMatch(q, @"^Q\d+$"))
            _detectedIdType = "Wikidata QID";
        else if (System.Text.RegularExpressions.Regex.IsMatch(q, @"^(97[89])?\d{9}[\dXx]$"))
            _detectedIdType = "ISBN";
        else if (System.Text.RegularExpressions.Regex.IsMatch(q, @"^B0[A-Z0-9]{8}$"))
            _detectedIdType = "ASIN";
        else if (System.Text.RegularExpressions.Regex.IsMatch(q, @"^tt\d{7,}$"))
            _detectedIdType = "IMDb ID";
        else
            _detectedIdType = null;
    }

    private async Task RunSearch()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;

        DetectIdType();
        ClearComparison();

        _searching    = true;
        _hasSearched  = false;
        _errorMessage = null;
        _successMessage = null;
        _universeCandidates = [];
        _showOtherUniverseCandidates = false;

        var queryKey = _query.Trim().ToLowerInvariant();

        try
        {
            var cacheKey = $"data|{queryKey}|{_mediaType}";
            if (_universeCache.TryGetValue(cacheKey, out var cached))
            {
                _universeCandidates = cached;
            }
            else
            {
                var result = await Orchestrator.SearchUniverseAsync(_query, _mediaType, maxCandidates: 5);
                _universeCandidates = result;
                _universeCache[cacheKey] = result;
            }

            _hasSearched = true;
        }
        catch (Exception)
        {
            _errorMessage = "Search failed. Please check the Engine connection.";
        }
        finally
        {
            _searching = false;
        }
    }
    private void SwitchSearchMode(string mode) { }

    private void OpenComparison(object candidate)
    {
        _comparisonCandidate = candidate;
        _useCandidateCover   = !string.IsNullOrEmpty(GetCandidateCoverUrl());
        _diffRows            = BuildDiffRows();
    }

    private void ClearComparison()
    {
        _comparisonCandidate = null;
        _diffRows = [];
    }

    private string GetCandidateTitle() => _comparisonCandidate switch
    {
        UniverseCandidateDto uc => uc.Label,
        RetailCandidateDto   rc => rc.Title,
        _                       => ""
    };

    private string? GetCandidateAuthor() => _comparisonCandidate switch
    {
        UniverseCandidateDto uc => uc.Author ?? uc.Director,
        RetailCandidateDto   rc => rc.Author ?? rc.Director,
        _                       => null
    };

    private string? GetCandidateYear() => _comparisonCandidate switch
    {
        UniverseCandidateDto uc => uc.Year,
        RetailCandidateDto   rc => rc.Year,
        _                       => null
    };

    private string? GetCandidateCoverUrl() => _comparisonCandidate switch
    {
        UniverseCandidateDto uc => uc.CoverUrl,
        RetailCandidateDto   rc => rc.CoverUrl,
        _                       => null
    };

    private string? GetCandidateDescription() => _comparisonCandidate switch
    {
        UniverseCandidateDto uc => uc.WikipediaExtract ?? uc.Description,
        RetailCandidateDto   rc => rc.Description,
        _                       => null
    };

    private string? GetCandidateDirector() => _comparisonCandidate switch
    {
        UniverseCandidateDto uc => uc.Director,
        RetailCandidateDto   rc => rc.Director,
        _                       => null
    };

    private string GetCandidateSourceLabel() => _comparisonCandidate switch
    {
        UniverseCandidateDto uc => $"Wikidata  -  {uc.Qid}",
        RetailCandidateDto   rc => rc.ProviderName,
        _                       => "Candidate"
    };

    private List<DiffRow> BuildDiffRows()
    {
        var isAudiobook = string.Equals(_mediaType, "Audiobook", StringComparison.OrdinalIgnoreCase)
                       || string.Equals(CurrentMediaType, "Audiobook", StringComparison.OrdinalIgnoreCase);
        var isMovie     = string.Equals(_mediaType, "Movies", StringComparison.OrdinalIgnoreCase)
                       || string.Equals(CurrentMediaType, "Movies", StringComparison.OrdinalIgnoreCase);
        var isTV        = string.Equals(_mediaType, "TV", StringComparison.OrdinalIgnoreCase)
                       || string.Equals(CurrentMediaType, "TV", StringComparison.OrdinalIgnoreCase);

        var authorLabel = (isMovie || isTV) ? "Director" : "Author";
        var candAuthorValue = (isMovie || isTV) ? GetCandidateDirector() : GetCandidateAuthor();
        var curAuthorValue  = (isMovie || isTV) ? null : CurrentAuthor; // CurrentAuthor covers both

        var rows = new List<DiffRow>
        {
            MakeDiffRow("Title",       CurrentTitle,   GetCandidateTitle()),
            MakeDiffRow(authorLabel,   curAuthorValue, candAuthorValue),
            MakeDiffRow("Year",        CurrentYear,    GetCandidateYear()),
        };

        if (isAudiobook)
            rows.Add(MakeDiffRow("Narrator", CurrentNarrator, null ));

        rows.Add(MakeDiffRow("Description", null, GetCandidateDescription()));

        return rows;
    }

    private static DiffRow MakeDiffRow(string fieldName, string? current, string? candidate)
    {
        var cur = TruncateText(current, 80);
        var can = TruncateText(candidate, 80);
        return new DiffRow
        {
            FieldName      = fieldName,
            CurrentValue   = cur,
            CandidateValue = can,
            IsDifferent    = !string.IsNullOrEmpty(can) && !string.Equals(cur, can, StringComparison.OrdinalIgnoreCase),
            IsChecked      = !string.IsNullOrEmpty(can) && !string.Equals(cur, can, StringComparison.OrdinalIgnoreCase),
        };
    }

    private async Task ApplyFromComparison(string intent)
    {
        if (_comparisonCandidate is null) return;

        _applying     = true;
        _errorMessage = null;

        try
        {
            ApplyMatchRequestDto request;

            if (_comparisonCandidate is UniverseCandidateDto uc)
            {
                request = new ApplyMatchRequestDto
                {
                    Qid         = intent != "image" ? uc.Qid : null,
                    Title       = intent != "image" ? uc.Label : null,
                    Year        = intent != "image" ? uc.Year  : null,
                    Author      = intent != "image" ? uc.Author : null,
                    Director    = intent != "image" ? uc.Director : null,
                    Description = intent != "image" ? (uc.WikipediaExtract ?? uc.Description) : null,
                    CoverUrl    = (intent != "metadata" && _useCandidateCover) ? uc.CoverUrl : null,
                };
            }
            else if (_comparisonCandidate is RetailCandidateDto rc)
            {
                request = new ApplyMatchRequestDto
                {
                    Title       = intent != "image" ? rc.Title  : null,
                    Year        = intent != "image" ? rc.Year   : null,
                    Author      = intent != "image" ? rc.Author : null,
                    Director    = intent != "image" ? rc.Director : null,
                    Description = intent != "image" ? rc.Description : null,
                    CoverUrl    = (intent != "metadata" && _useCandidateCover) ? rc.CoverUrl : null,
                };
            }
            else return;

            var result = await Orchestrator.ApplyLibraryItemMatchAsync(EntityId, request);
            if (result is not null)
            {
                _successMessage = result.Message ?? "Match applied successfully.";
                ClearComparison();
                await OnMatchApplied.InvokeAsync(result);
            }
            else
            {
                _errorMessage = "Failed to apply match.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "Error applying match.";
        }
        finally
        {
            _applying = false;
        }
    }

    private async Task OnManualEntryCreated(CreateManualResponseDto response)
    {
        _showManualForm = false;
        _successMessage = response.Message ?? "Manual entry created.";
        await OnMatchApplied.InvokeAsync(new ApplyMatchResponseDto
        {
            EntityId       = response.EntityId,
            WikidataStatus = response.WikidataStatus,
            ClaimsWritten  = response.ClaimsWritten,
            Message        = response.Message,
        });
    }

    private bool HasNoResults() => _universeCandidates.Count == 0;

    private string GetCleanedQuery()
    {
        var q = _query.Trim();
        q = System.Text.RegularExpressions.Regex.Replace(q, @"^\d+\s+", "");
        q = System.Text.RegularExpressions.Regex.Replace(q, @"\.(epub|mp3|m4b|mp4|mkv|cbz|cbr)$", "",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        q = System.Text.RegularExpressions.Regex.Replace(q, @"\[.*?\]|\(.*?\)", "").Trim();
        return q;
    }

    private static string? GetBridgeLabel(UniverseCandidateDto c)
    {
        if (c.BridgeIds is null || c.BridgeIds.Count == 0) return null;
        if (c.BridgeIds.TryGetValue("isbn",          out var isbn)) return $"ISBN: {isbn}";
        if (c.BridgeIds.TryGetValue("asin",          out var asin)) return $"ASIN: {asin}";
        if (c.BridgeIds.TryGetValue("tmdb_id",       out var tmdb)) return $"TMDB: {tmdb}";
        if (c.BridgeIds.TryGetValue("imdb_id",       out var imdb)) return $"IMDb: {imdb}";
        if (c.BridgeIds.TryGetValue("musicbrainz_id",out var mb))   return $"MB: {mb}";
        if (c.BridgeIds.TryGetValue("comic_vine_id", out var cv))   return $"CV: {cv}";
        if (c.BridgeIds.TryGetValue("apple_books_id",out var ab))   return $"Apple: {ab}";
        return null;
    }
    private static string GetTrafficLightColor(double conf) => conf switch
    {
        >= 0.85 => "#4CAF50",
        >= 0.60 => "var(--tl-status-warning)",
        _       => "var(--tl-status-danger)",
    };

    private static string GetConfidenceChipStyle(double conf) => conf switch
    {
        >= 0.85 => "background: rgba(76,175,80,0.2); color: #4CAF50; font-size: 0.65rem; height: 18px; padding: 0 6px;",
        >= 0.60 => "background: var(--tl-status-warning-soft); color: var(--tl-status-warning); font-size: 0.65rem; height: 18px; padding: 0 6px;",
        _       => "background: rgba(239,83,80,0.2); color: var(--tl-status-danger); font-size: 0.65rem; height: 18px; padding: 0 6px;",
    };

    private static string TruncateText(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "";
        return text.Length <= maxLength ? text : text[..maxLength] + "...";
    }
    private List<MatchSignal> BuildMatchSignals(FieldMatchScoresDto? scores, UniverseCandidateDto? uc)
    {
        var signals = new List<MatchSignal>();

        if (scores is not null)
        {
            if (scores.TitleScore  >= 0.7)  signals.Add(new("OK Title match",  "good"));
            if (scores.AuthorScore >= 0.7)  signals.Add(new("OK Author match", "good"));
            if (scores.YearScore   >= 0.7)  signals.Add(new("OK Year match",   "good"));
            if (scores.FormatScore is >= 0.4 and < 0.7) signals.Add(new("Warning Format: Medium", "warn"));
            if (scores.AuthorScore < 0.3)   signals.Add(new("X Author missing", "missing"));
        }
        else if (uc is not null)
        {
            if (!string.IsNullOrEmpty(uc.Author))   signals.Add(new("OK Has author",   "good"));
            if (!string.IsNullOrEmpty(uc.Year))     signals.Add(new("OK Has year",     "good"));
            if (!string.IsNullOrEmpty(uc.CoverUrl)) signals.Add(new("OK Has cover art","good"));
            if (uc.BridgeIds.Count > 0)             signals.Add(new("OK Bridge ID",    "good"));
        }

        return signals;
    }

    private sealed class DiffRow
    {
        public string FieldName      { get; set; } = "";
        public string CurrentValue   { get; set; } = "";
        public string CandidateValue { get; set; } = "";
        public bool   IsDifferent    { get; set; }
        public bool   IsChecked      { get; set; }
    }

    private sealed record MatchSignal(string Label, string Level);
