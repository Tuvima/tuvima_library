@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Models.ViewDTOs

@* JourneyHero — "Continue your Journey" featured banner.
   Two-panel layout: crisp cover poster (left) + metadata/progress (right)
   over a blurred cover art backdrop. Falls back to gradient when no cover. *@

@if (Item is not null)
{
    <div class="journey-hero" @onclick="OnClick">

        @* ── Full-bleed backdrop: bleeds to 100vw via absolute positioning.
               Kept separate from content so content aligns with the page container. ── *@
        <div class="journey-hero-backdrop">
            @if (!string.IsNullOrEmpty(Item.CoverUrl))
            {
                <img src="@Item.CoverUrl"
                     alt=""
                     class="journey-hero-bg" />
            }
            <div class="journey-hero-vignette" />
            @if (string.IsNullOrEmpty(Item.CoverUrl))
            {
                <div class="journey-hero-gradient" />
            }
        </div>

        @* ── Two-panel content — aligned with swimlanes via standard 88px dock clearance ── *@
        <div class="journey-hero-content">

            @* Left: crisp cover poster *@
            <div class="journey-hero-poster">
                @if (!string.IsNullOrEmpty(Item.CoverUrl))
                {
                    <img src="@Item.CoverUrl"
                         alt="@Item.Title"
                         class="journey-hero-cover" />
                }
                else
                {
                    <div class="journey-hero-cover-placeholder">
                        <MudIcon Icon="@GetMediaIcon()"
                                 Style="font-size: 48px; color: rgba(255,255,255,0.25);" />
                    </div>
                }
            </div>

            @* Right: metadata + progress *@
            <div class="journey-hero-info">

                @* Hub name subtitle *@
                @if (!string.IsNullOrEmpty(Item.HubDisplayName))
                {
                    <span class="journey-hero-hub">@Item.HubDisplayName</span>
                }

                <h2 class="journey-hero-title">@Item.Title</h2>

                @* Author / narrator *@
                @if (!string.IsNullOrEmpty(Item.Author))
                {
                    <span class="journey-hero-author">@Item.Author</span>
                }
                @if (!string.IsNullOrEmpty(Item.Narrator) && Item.Narrator != Item.Author)
                {
                    <span class="journey-hero-narrator">Narrated by @Item.Narrator</span>
                }

                @* Badges *@
                <div class="journey-hero-badges">
                    <span class="journey-badge">@Item.FormatMediaType</span>
                    @if (!string.IsNullOrEmpty(Item.Series))
                    {
                        <span class="journey-badge">@Item.Series@(
                            !string.IsNullOrEmpty(Item.SeriesPosition) ? $" #{Item.SeriesPosition}" : ""
                        )</span>
                    }
                </div>

                @* Action button with built-in progress stripe — matches HubDetail CTA *@
                <button class="hub-primary-cta" style="align-self: flex-start; margin-bottom: 12px;"
                        @onclick:stopPropagation="true"
                        @onclick="OnClick">
                    <div class="hub-primary-cta-inner">
                        <MudIcon Icon="@GetActionIcon()"
                                 Style="font-size: 1.2rem; color: #1a1208; flex-shrink:0;" />
                        <span class="hub-primary-cta-label">@Item.ActionLabel</span>
                    </div>
                    @if (Item.ProgressPct is > 0 and < 99.5)
                    {
                        <div class="hub-primary-cta-progress"
                             style="width: @(Item.ProgressPct.ToString("F0"))%"></div>
                    }
                </button>

                @* Description excerpt *@
                @if (!string.IsNullOrEmpty(Item.Description))
                {
                    <p class="journey-hero-desc">@Truncate(Item.Description, 180)</p>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public JourneyItemViewModel? Item { get; set; }
    [Parameter] public EventCallback<JourneyItemViewModel> OnResumeClicked { get; set; }

    private async Task OnClick()
    {
        if (Item is not null)
            await OnResumeClicked.InvokeAsync(Item);
    }

    private string GetMediaIcon()
    {
        var t = (Item?.MediaType ?? "").ToLowerInvariant();
        if (t.Contains("epub") || t.Contains("book"))   return MudBlazor.Icons.Material.Filled.MenuBook;
        if (t.Contains("audio"))                          return MudBlazor.Icons.Material.Filled.Headphones;
        if (t.Contains("video") || t.Contains("movie"))  return MudBlazor.Icons.Material.Filled.PlayCircle;
        if (t.Contains("comic") || t.Contains("cbz"))    return MudBlazor.Icons.Material.Filled.AutoStories;
        return MudBlazor.Icons.Material.Filled.Folder;
    }

    private string GetActionIcon()
    {
        var t = (Item?.MediaType ?? "").ToLowerInvariant();
        if (t.Contains("audio"))                          return MudBlazor.Icons.Material.Filled.Headphones;
        if (t.Contains("video") || t.Contains("movie"))  return MudBlazor.Icons.Material.Filled.PlayArrow;
        return MudBlazor.Icons.Material.Filled.MenuBook;
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength].TrimEnd() + "\u2026";
}

<style>
    /* ── Journey hero container ─────────────────────────────────────── */
    .journey-hero {
        position: relative;
        /* overflow: visible — backdrop bleeds to 100vw via absolute positioning */
        cursor: pointer;
        min-height: 440px;
        background: #0A0A0A;
    }

    /* ── Full-bleed backdrop: stretches to 100vw while hero stays container-width ── */
    .journey-hero-backdrop {
        position: absolute;
        top: 0;
        left: calc(50% - 50vw);   /* pull to viewport left edge */
        width: 100vw;
        height: 100%;
        overflow: hidden;          /* clips the blurred image overhang */
        pointer-events: none;
        z-index: 0;
    }

    /* ── Blurred cover background ────────────────────────────────────── */
    .journey-hero-bg {
        position: absolute;
        inset: -30px;
        width: calc(100% + 60px);
        height: calc(100% + 60px);
        object-fit: cover;
        filter: blur(24px) brightness(0.45);
        transform: scale(1.1);
        pointer-events: none;
    }

    /* ── Vignette overlay ────────────────────────────────────────────── */
    .journey-hero-vignette {
        position: absolute;
        inset: 0;
        background:
            linear-gradient(to right,  rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.40) 55%, rgba(0,0,0,0.20) 100%),
            linear-gradient(to top,    rgba(0,0,0,0.80) 0%, transparent 40%),
            linear-gradient(to bottom, rgba(0,0,0,0.60) 0%, transparent 30%);
        pointer-events: none;
    }

    /* ── Gradient fallback ───────────────────────────────────────────── */
    .journey-hero-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, #C9922E33, #0A0A0A);
        pointer-events: none;
    }

    /* ── Two-panel content ───────────────────────────────────────────── */
    .journey-hero-content {
        position: relative;
        z-index: 2;
        display: flex;
        gap: 2.5rem;
        /* padding-left: 88px = page standard dock clearance — aligns with swimlane titles and cards */
        padding: 104px 3rem 3rem 88px;
        width: 100%;
        align-items: flex-end;
        box-sizing: border-box;
    }

    /* ── Left: cover poster ──────────────────────────────────────────── */
    .journey-hero-poster {
        flex-shrink: 0;
    }

    .journey-hero-cover {
        width: 200px;
        aspect-ratio: 2 / 3;
        object-fit: cover;
        border-radius: 8px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.60);
    }

    .journey-hero-cover-placeholder {
        width: 200px;
        aspect-ratio: 2 / 3;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.06);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* ── Right: metadata + progress ──────────────────────────────────── */
    .journey-hero-info {
        display: flex;
        flex-direction: column;
        min-width: 0;
        flex: 1;
        max-width: 680px;
    }

    .journey-hero-hub {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.78rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.45);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 4px;
    }

    .journey-hero-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        color: #ffffff;
        margin: 0 0 8px 0;
        line-height: 1.15;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.50);
    }

    .journey-hero-author {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.95rem;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.70);
        margin-bottom: 4px;
    }

    .journey-hero-narrator {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 300;
        font-style: italic;
        color: rgba(255, 255, 255, 0.50);
        margin-bottom: 8px;
    }

    /* ── Badges ──────────────────────────────────────────────────────── */
    .journey-hero-badges {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 16px;
    }

    .journey-badge {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 4px 10px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.10);
        text-transform: uppercase;
    }

    /* ── Description ─────────────────────────────────────────────────── */
    .journey-hero-desc {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.82rem;
        font-weight: 300;
        line-height: 1.5;
        color: rgba(255, 255, 255, 0.45);
        margin: 0;
    }

    /* ── Responsive ──────────────────────────────────────────────────── */
    @@media (max-width: 768px) {
        .journey-hero {
            min-height: 320px;
        }

        .journey-hero-content {
            flex-direction: column;
            align-items: flex-start;
            padding: 80px 1.5rem 2rem 1.5rem; /* no LeftDock on mobile */
            gap: 1rem;
        }

        .journey-hero-cover,
        .journey-hero-cover-placeholder {
            width: 120px;
        }

        .journey-hero-title {
            font-size: 1.4rem;
        }
    }
</style>
