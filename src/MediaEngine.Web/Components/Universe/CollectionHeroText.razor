@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Models.ViewDTOs
@if (!string.IsNullOrEmpty(Data?.Subtitle))
{
    <p class="hero-subtitle-label">@Data.Subtitle</p>
}

<h2 class="hero-title" @onclick="HandleClick" style="cursor: pointer;">@Data?.Title</h2>

<div class="hero-badges">
    @if (!string.IsNullOrEmpty(Data?.Year))
    {
        <span class="hero-badge">@Data.Year</span>
    }
    @if (!string.IsNullOrEmpty(Data?.MediaTypeLabel))
    {
        <span class="hero-badge">@Data.MediaTypeLabel</span>
    }
    @if (Data?.Genres.Count > 0)
    {
        <MetadataChips Labels="@Data.Genres" Qids="@Data.GenreQids" />
    }
    else if (!string.IsNullOrEmpty(Data?.Genre))
    {
        @foreach (var genre in Data.Genre.Split(['|', ',', ';'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Where(g => g != "|").Take(2))
        {
            <span class="hero-badge">@genre</span>
        }
    }
    @if (!string.IsNullOrEmpty(Data?.Rating))
    {
        <span class="hero-badge">@Data.Rating</span>
    }
    @if (!string.IsNullOrEmpty(Data?.Series))
    {
        <span class="hero-badge">@Data.Series@(!string.IsNullOrEmpty(Data.SeriesPosition) ? $" #{Data.SeriesPosition}" : "")</span>
    }
</div>

@if (!string.IsNullOrEmpty(Data?.Author))
{
    <p class="hero-author">@Data.Author</p>
}
@if (!string.IsNullOrEmpty(Data?.Narrator))
{
    <p class="hero-narrator">Narrated by @Data.Narrator</p>
}
@if (!string.IsNullOrEmpty(Data?.Description))
{
    <p class="hero-description">@Data.Description</p>
}

@if (!string.IsNullOrEmpty(Data?.ActionLabel))
{
    <AppNativeButton Class="collection-primary-cta" OnClick="HandleCtaClick" StopPropagation="true" InlineStyle="margin-top: 16px;">
        <div class="collection-primary-cta-inner">
            <MudIcon Icon="@(Data.ActionIcon ?? Icons.Material.Filled.MenuBook)"
                     Style="font-size: 1.2rem; color: #1a1208; flex-shrink:0;" />
            <span class="collection-primary-cta-label">@Data.ActionLabel</span>
        </div>
        @if (Data.ProgressPct is > 0 and < 99.5)
        {
            <div class="collection-primary-cta-progress"
                 style="width: @(Data.ProgressPct.Value.ToString("F0"))%"></div>
        }
    </AppNativeButton>
}

@code {
    [Parameter] public HeroData? Data { get; set; }
    [Parameter] public EventCallback OnCtaClicked { get; set; }
    [Parameter] public EventCallback OnClicked { get; set; }

    private async Task HandleClick()
    {
        if (OnClicked.HasDelegate)
            await OnClicked.InvokeAsync();
    }

    private async Task HandleCtaClick()
    {
        if (OnCtaClicked.HasDelegate)
            await OnCtaClicked.InvokeAsync();
    }
}