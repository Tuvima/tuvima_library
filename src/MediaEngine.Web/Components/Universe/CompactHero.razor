@namespace MediaEngine.Web.Components.Universe
@if (Data is not null)
{
    <div class="spotlight spotlight-@(ModeClass)"
         style="--accent: @AccentColor;"
         @onclick="HandleClick">
<div class="spotlight-backdrop" aria-hidden="true">
            @if (!string.IsNullOrEmpty(Data.HeroUrl ?? Data.CoverUrl))
            {
                <img src="@(Data.HeroUrl ?? Data.CoverUrl)" alt="" class="spotlight-backdrop-img" />
            }
            <div class="spotlight-vignette"></div>
        </div>
<div class="spotlight-content">
            @if (!string.IsNullOrEmpty(Data.CoverUrl))
            {
                <div class="spotlight-cover">
                    <img src="@Data.CoverUrl" alt="@Data.Title" class="spotlight-cover-img" />
                </div>
            }
            <div class="spotlight-info">
                @if (!string.IsNullOrEmpty(Eyebrow))
                {
                    <span class="spotlight-eyebrow">@Eyebrow</span>
                }
                <span class="spotlight-title">@Data.Title</span>
                <div class="spotlight-meta">
                    @if (!string.IsNullOrEmpty(Data.Author))
                    {
                        <span>@Data.Author</span>
                    }
                    @if (!string.IsNullOrEmpty(Data.Year))
                    {
                        <span>@Data.Year</span>
                    }
                    @if (!string.IsNullOrEmpty(Data.MediaTypeLabel))
                    {
                        <span>@Data.MediaTypeLabel</span>
                    }
                </div>
                @if (Data.ProgressPct is > 0)
                {
                    <div class="spotlight-progress">
                        <div class="spotlight-progress-track">
                            <div class="spotlight-progress-fill"
                                 style="width: @(Data.ProgressPct.Value)%;"></div>
                        </div>
                        <span class="spotlight-progress-text">@($"{Data.ProgressPct.Value:F0}% complete")</span>
                    </div>
                }
                <div class="spotlight-actions">
                    <button class="spotlight-cta" @onclick="HandleCta" @onclick:stopPropagation="true">
                        @if (!string.IsNullOrEmpty(Data.ActionIcon))
                        {
                            <MudIcon Icon="@Data.ActionIcon" Size="Size.Small" Style="font-size: 18px;" />
                        }
                        else
                        {
                            <MudIcon Icon="@FallbackIcon" Size="Size.Small" Style="font-size: 18px;" />
                        }
                        @(Data.ActionLabel ?? FallbackLabel)
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    public enum SpotlightMode { Auto, Portrait, Landscape, Square }

    [Parameter] public HeroData? Data { get; set; }
    [Parameter] public SpotlightMode Mode { get; set; } = SpotlightMode.Auto;
    [Parameter] public string AccentColor { get; set; } = "var(--tl-accent-primary)";
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public string FallbackLabel { get; set; } = "Details";
    [Parameter] public string FallbackIcon { get; set; } = MudBlazor.Icons.Material.Filled.Info;
    [Parameter] public EventCallback OnClicked { get; set; }
    [Parameter] public EventCallback OnCtaClicked { get; set; }

    private string ModeClass => Mode switch
    {
        SpotlightMode.Portrait  => "portrait",
        SpotlightMode.Landscape => "landscape",
        SpotlightMode.Square    => "square",
        _                       => Data?.IsPortraitMedia == true ? "portrait" : "landscape",
    };

    private async Task HandleClick() => await OnClicked.InvokeAsync();
    private async Task HandleCta() => await OnCtaClicked.InvokeAsync();
}

<style>
    .spotlight {
        position: relative;
        width: 100%;
        max-height: 280px;
        border-radius: 14px;
        overflow: hidden;
        cursor: pointer;
        margin-bottom: 2rem;
        display: grid;
        grid-template: 1fr / 1fr;
    }

    .spotlight > * {
        grid-area: 1 / 1;
    }


    .spotlight-backdrop {
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .spotlight-backdrop-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: blur(36px) brightness(0.48);
        transform: scale(1.18);
    }

    .spotlight-vignette {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to right,
            rgba(8, 11, 20, 0.88) 0%,
            rgba(8, 11, 20, 0.55) 45%,
            rgba(8, 11, 20, 0.78) 100%
        );
    }


    .spotlight-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 28px;
        padding: 18px 28px;
    }

    .spotlight-cover {
        flex-shrink: 0;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.55);
    }


    .spotlight-portrait .spotlight-cover {
        width: 160px;
        height: 240px;
    }


    .spotlight-landscape .spotlight-cover {
        width: 320px;
        height: 180px;
    }


    .spotlight-square .spotlight-cover {
        width: 220px;
        height: 220px;
    }

    .spotlight-cover-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .spotlight-info {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .spotlight-eyebrow {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.32em;
        color: var(--accent, var(--tl-accent-primary));
    }

    .spotlight-title {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: clamp(1.4rem, 2.4vw, 2rem);
        font-weight: 700;
        color: rgba(248, 248, 248, 0.97);
        line-height: 1.15;
        letter-spacing: -0.02em;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .spotlight-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.82rem;
        font-weight: 400;
        color: rgba(248, 248, 248, 0.55);
    }

    .spotlight-meta > span:not(:last-child)::after {
        content: '\00B7';
        margin-left: 8px;
        color: rgba(248, 248, 248, 0.25);
    }

    .spotlight-progress {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 2px;
    }

    .spotlight-progress-track {
        flex: 1;
        max-width: 220px;
        height: 4px;
        background: var(--tl-border-default);
        border-radius: 2px;
        overflow: hidden;
    }

    .spotlight-progress-fill {
        height: 100%;
        background: var(--accent, var(--tl-accent-primary));
        border-radius: 2px;
        transition: width 0.3s ease;
    }

    .spotlight-progress-text {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.72rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.48);
    }

    .spotlight-actions {
        display: flex;
        gap: 10px;
        margin-top: 6px;
    }

    .spotlight-cta {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.84rem;
        font-weight: 700;
        color: #000;
        background: var(--accent, var(--tl-accent-primary));
        border: none;
        border-radius: 999px;
        padding: 10px 22px;
        cursor: pointer;
        transition: opacity 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
        text-transform: none;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.35);
    }

    .spotlight-cta:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.45);
    }


    @@media (max-width: 768px) {
        .spotlight {
            border-radius: 12px;
            max-height: none;
        }

        .spotlight-content {
            gap: 14px;
            padding: 14px 16px;
        }

        .spotlight-portrait .spotlight-cover {
            width: 92px;
            height: 138px;
        }

        .spotlight-landscape .spotlight-cover {
            width: 168px;
            height: 95px;
        }

        .spotlight-square .spotlight-cover {
            width: 120px;
            height: 120px;
        }

        .spotlight-title {
            font-size: 1.15rem;
            -webkit-line-clamp: 2;
        }

        .spotlight-meta > span:nth-child(n+3) {
            display: none;
        }

        .spotlight-progress-track {
            max-width: 140px;
        }

        .spotlight-cta {
            font-size: 0.76rem;
            padding: 8px 16px;
        }
    }
</style>
