@namespace MediaEngine.Web.Components.Universe

@* CompactHero — Compact hero banner for browse pages. Shows actionable context
   (progress, time remaining) with a blurred cover backdrop. Max 280px height. *@

@if (Data is not null)
{
    <div class="compact-hero @(Data.IsPortraitMedia ? "portrait" : "landscape")"
         @onclick="HandleClick">
        @* ── Blurred backdrop ── *@
        <div class="compact-hero-backdrop" aria-hidden="true">
            @if (!string.IsNullOrEmpty(Data.HeroUrl ?? Data.CoverUrl))
            {
                <img src="@(Data.HeroUrl ?? Data.CoverUrl)" alt="" class="compact-hero-backdrop-img" />
            }
            <div class="compact-hero-vignette"></div>
        </div>

        @* ── Content ── *@
        <div class="compact-hero-content">
            @if (!string.IsNullOrEmpty(Data.CoverUrl))
            {
                <div class="compact-hero-cover">
                    <img src="@Data.CoverUrl" alt="@Data.Title" class="compact-hero-cover-img" />
                </div>
            }
            <div class="compact-hero-info">
                <span class="compact-hero-title">@Data.Title</span>
                <div class="compact-hero-meta">
                    @if (!string.IsNullOrEmpty(Data.Author))
                    {
                        <span>@Data.Author</span>
                    }
                    @if (!string.IsNullOrEmpty(Data.Year))
                    {
                        <span>@Data.Year</span>
                    }
                    @if (!string.IsNullOrEmpty(Data.MediaTypeLabel))
                    {
                        <span>@Data.MediaTypeLabel</span>
                    }
                </div>
                @if (Data.ProgressPct is > 0)
                {
                    <div class="compact-hero-progress">
                        <div class="compact-hero-progress-track">
                            <div class="compact-hero-progress-fill"
                                 style="width: @(Data.ProgressPct.Value)%;"></div>
                        </div>
                        <span class="compact-hero-progress-text">@($"{Data.ProgressPct.Value:F0}% complete")</span>
                    </div>
                }
                <div class="compact-hero-actions">
                    @if (!string.IsNullOrEmpty(Data.ActionLabel))
                    {
                        <button class="compact-hero-cta" @onclick="HandleCta" @onclick:stopPropagation="true">
                            @if (!string.IsNullOrEmpty(Data.ActionIcon))
                            {
                                <MudIcon Icon="@Data.ActionIcon" Size="Size.Small"
                                         Style="font-size: 18px;" />
                            }
                            @Data.ActionLabel
                        </button>
                    }
                    else
                    {
                        <button class="compact-hero-cta" @onclick="HandleCta" @onclick:stopPropagation="true">
                            <MudIcon Icon="@MudBlazor.Icons.Material.Filled.Info" Size="Size.Small"
                                     Style="font-size: 18px;" />
                            Details
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public HeroData? Data { get; set; }
    [Parameter] public EventCallback OnClicked { get; set; }
    [Parameter] public EventCallback OnCtaClicked { get; set; }

    private async Task HandleClick() => await OnClicked.InvokeAsync();
    private async Task HandleCta() => await OnCtaClicked.InvokeAsync();
}

<style>
    .compact-hero {
        position: relative;
        width: 100%;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        margin-bottom: 1.5rem;
        display: grid;
        grid-template: 1fr / 1fr;
    }

    .compact-hero > * {
        grid-area: 1 / 1;
    }

    /* ── Backdrop ── */
    .compact-hero-backdrop {
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .compact-hero-backdrop-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: blur(32px) brightness(0.5);
        transform: scale(1.15);
    }

    .compact-hero-vignette {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to right,
            rgba(8, 11, 20, 0.85) 0%,
            rgba(8, 11, 20, 0.55) 50%,
            rgba(8, 11, 20, 0.75) 100%
        );
    }

    /* ── Content ── */
    .compact-hero-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 20px 28px;
    }

    .compact-hero-cover {
        flex-shrink: 0;
        width: 120px;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.50);
    }

    .portrait .compact-hero-cover {
        height: 170px;
    }

    .landscape .compact-hero-cover {
        width: 180px;
        height: auto;
        aspect-ratio: 16 / 9;
    }

    .compact-hero-cover-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .compact-hero-info {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .compact-hero-title {
        font-family: 'Montserrat', sans-serif;
        font-size: clamp(1.2rem, 2vw, 1.6rem);
        font-weight: 700;
        color: rgba(248, 248, 248, 0.95);
        line-height: 1.2;
        letter-spacing: -0.02em;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .compact-hero-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        font-weight: 400;
        color: rgba(248, 248, 248, 0.50);
    }

    .compact-hero-meta > span:not(:last-child)::after {
        content: '\00B7';
        margin-left: 8px;
        color: rgba(248, 248, 248, 0.25);
    }

    .compact-hero-progress {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 4px;
    }

    .compact-hero-progress-track {
        flex: 1;
        max-width: 200px;
        height: 4px;
        background: rgba(255, 255, 255, 0.10);
        border-radius: 2px;
        overflow: hidden;
    }

    .compact-hero-progress-fill {
        height: 100%;
        background: #C9922E;
        border-radius: 2px;
        transition: width 0.3s ease;
    }

    .compact-hero-progress-text {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.45);
    }

    .compact-hero-actions {
        display: flex;
        gap: 10px;
        margin-top: 8px;
    }

    .compact-hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.82rem;
        font-weight: 600;
        color: #fff;
        background: rgba(201, 146, 46, 0.85);
        border: none;
        border-radius: 8px;
        padding: 8px 18px;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.15s ease;
        text-transform: none;
    }

    .compact-hero-cta:hover {
        background: rgba(201, 146, 46, 1);
        transform: translateY(-1px);
    }

    /* ── Mobile ── */
    @@media (max-width: 768px) {
        .compact-hero {
            border-radius: 10px;
        }

        .compact-hero-content {
            gap: 12px;
            padding: 14px 16px;
        }

        .compact-hero-cover {
            width: 80px;
        }

        .portrait .compact-hero-cover {
            height: 110px;
        }

        .landscape .compact-hero-cover {
            width: 120px;
        }

        .compact-hero-title {
            font-size: 1rem;
            -webkit-line-clamp: 1;
        }

        .compact-hero-meta > span:nth-child(n+3) {
            display: none;
        }

        .compact-hero-progress-track {
            max-width: 140px;
        }

        .compact-hero-cta {
            font-size: 0.75rem;
            padding: 6px 14px;
        }
    }
</style>
