@namespace MediaEngine.Web.Components.Universe

<AppMediaCard Title="@Item.Title"
              Subtitle="@Subtitle"
              ImageUrl="@Item.CoverUrl"
              FallbackText="@Item.Title"
              FallbackIcon="@AppMediaPresentation.IconFor(Item.FormatBadge)"
              AccentColor="@AppMediaPresentation.AccentFor(Item.FormatBadge)"
              Progress="@EffectiveProgressPct"
              Width="@CardWidth"
              Variant="@Variant"
              OnSelected="OnClick">
    <Badge>
        @if (Item.IsNew)
        {
            <AppStatusBadge Text="NEW" Tone="AppStatusTone.Warning" />
        }
        @if (!string.IsNullOrEmpty(TypeLabel))
        {
            <AppStatusBadge Text="@TypeLabel" Tone="AppStatusTone.Primary" />
        }
    </Badge>
</AppMediaCard>

@code {
    [Parameter, EditorRequired] public PosterItemViewModel Item { get; set; } = default!;
    [Parameter] public EventCallback<PosterItemViewModel> OnItemSelected { get; set; }
    [Parameter] public int CardHeight { get; set; } = 270;
    [Parameter] public double? ProgressPct { get; set; }

    private double? EffectiveProgressPct => ProgressPct ?? Item.Progress;
    private AppMediaCardVariant Variant => AppMediaPresentation.VariantFor(Item.FormatBadge);
    private int CardWidth => Variant == AppMediaCardVariant.Square ? CardHeight : (int)Math.Round(CardHeight / 1.5);
    private string TypeLabel => AppMediaPresentation.LabelFor(Item.FormatBadge);
    private string Subtitle => !string.IsNullOrEmpty(Item.Subtitle) ? Item.Subtitle : TypeLabel;

    private Task OnClick() => OnItemSelected.InvokeAsync(Item);
}
