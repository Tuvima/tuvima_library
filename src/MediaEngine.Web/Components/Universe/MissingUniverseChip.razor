@* Amber chip shown on libraryItem items that have no Wikidata QID (status 'missing' or 'manual'). *@

@if (Show)
{
    <MudTooltip Text="@TooltipText" Arrow="true" Placement="Placement.Top">
        <MudChip T="string"
                 Size="Size.Small"
                 Variant="Variant.Filled"
                 Style="background: var(--tl-status-warning-soft); color: var(--tl-status-warning); font-size: 0.68rem; height: 20px; padding: 0 8px;">
            <MudIcon Icon="@Icons.Material.Outlined.Public" Size="Size.Small"
                     Style="font-size: 0.7rem; margin-right: 3px;" />
            @Label
        </MudChip>
    </MudTooltip>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public string Label { get; set; } = "Missing Universe";
    [Parameter] public string TooltipText { get; set; } =
        "This item has no Wikidata identity. Use 'Find Match' to link it to the universe.";
}
