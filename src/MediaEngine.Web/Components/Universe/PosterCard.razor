@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Services.Integration

@* PosterCard — Individual poster art tile with cover image, title, and metadata badges.
   Used inside PosterSwimlane for horizontal scrolling rows. *@

<div class="poster-card" style="width: @(Width)px;" @onclick="OnClick">
    <div class="poster-card-artwork" style="aspect-ratio: @ArtworkAspectRatio; @ArtworkStyle">
        @if (!string.IsNullOrEmpty(Hub.CoverUrl))
        {
            <img src="@Hub.CoverUrl"
                 alt="@Hub.DisplayName"
                 class="poster-card-img"
                 loading="lazy" />
        }
        else
        {
            @* Book fallback — spine-style gradient with title *@
            <div class="poster-card-book-spine">
                <MudIcon Icon="@MudBlazor.Icons.Material.Filled.MenuBook"
                         Style="font-size: 36px; color: rgba(255,255,255,0.18); margin-bottom: 8px;" />
                <span class="poster-card-spine-title">@Hub.DisplayName</span>
            </div>
        }

        @if (IsNew)
        {
            <span class="poster-new-badge">NEW</span>
        }

        @* Format badge — book formats only *@
        @if (!string.IsNullOrEmpty(Hub.PrimaryMediaType))
        {
            <span class="poster-format-badge"
                  style="background: @FormatBadgeColour;">@FormatBadgeText</span>
        }
    </div>
    <div class="poster-card-info">
        <span class="poster-card-title">@Hub.DisplayName</span>
        @* Author — primary subtitle for books *@
        @if (!string.IsNullOrEmpty(Hub.Author))
        {
            <span class="poster-card-author">@Hub.Author</span>
        }
        @* Series — shown if author is available, or as fallback *@
        @if (!string.IsNullOrEmpty(Hub.Series) && string.IsNullOrEmpty(Hub.Author))
        {
            <span class="poster-card-subtitle">@Hub.Series</span>
        }
        <div class="poster-card-meta">
            @if (!string.IsNullOrEmpty(Hub.Year))
            {
                <span class="poster-meta-badge">@Hub.Year</span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public HubViewModel Hub { get; set; } = default!;
    [Parameter] public EventCallback<HubViewModel> OnHubSelected { get; set; }
    [Parameter] public int Width { get; set; } = 180;

    private bool IsNew => DateTimeOffset.UtcNow - Hub.CreatedAt < TimeSpan.FromDays(7);

    private string ArtworkStyle =>
        string.IsNullOrEmpty(Hub.CoverUrl)
            ? $"background: linear-gradient(160deg, {Hub.DominantHexColor ?? "#1A2040"}44 0%, #0D1230 100%);"
            : string.Empty;

    private string ArtworkAspectRatio
    {
        get
        {
            var t = (Hub.PrimaryMediaType ?? "").ToLowerInvariant();
            if (t.Contains("m4b") || t.Contains("audiobook") || t.Contains("audio"))
                return "1 / 1";
            return "2 / 3";
        }
    }

    private async Task OnClick() => await OnHubSelected.InvokeAsync(Hub);

    private string FormatBadgeText =>
        FormatBadgeLabel(Hub.PrimaryMediaType ?? string.Empty);

    private string FormatBadgeColour
    {
        get
        {
            var t = (Hub.PrimaryMediaType ?? string.Empty).ToLowerInvariant();
            if (t.Contains("audio") || t.Contains("m4b")) return "rgba(139, 92, 246, 0.85)"; // purple for audiobooks
            if (t.Contains("comic") || t.Contains("cbz")) return "rgba(20, 160, 100, 0.85)"; // teal for comics
            return "rgba(37, 99, 235, 0.85)"; // blue for books (default)
        }
    }

    private static string FormatBadgeLabel(string mediaType)
    {
        var t = mediaType.ToLowerInvariant();
        if (t.Contains("epub"))                                          return "EPUB";
        if (t.Contains("m4b") || t.Contains("audiobook"))               return "AUDIOBOOK";
        if (t.Contains("audio"))                                         return "AUDIO";
        if (t.Contains("book"))                                          return "BOOK";
        if (t.Contains("cbz") || t.Contains("cbr") || t.Contains("comic")) return "COMIC";
        return "BOOK";
    }
}

<style>
    .poster-card {
        flex-shrink: 0;
        cursor: pointer;
        scroll-snap-align: start;
        transition: transform 0.2s ease;
    }

    .poster-card:hover {
        transform: translateY(-4px);
    }

    .poster-card:hover .poster-card-artwork {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.40);
    }

    .poster-card-artwork {
        position: relative;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0D1230;
        margin-bottom: 8px;
        transition: box-shadow 0.2s ease;
    }

    /* ── Book spine fallback — shown when no cover art ── */
    .poster-card-book-spine {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 16px 10px;
        width: 100%;
        height: 100%;
    }

    .poster-card-spine-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.30);
        text-align: center;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .poster-new-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        padding: 3px 8px;
        border-radius: 4px;
        background: #C9922E;
        color: #ffffff;
        z-index: 1;
    }

    .poster-format-badge {
        position: absolute;
        bottom: 8px;
        right: 8px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.55rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 2px 6px;
        border-radius: 4px;
        color: #ffffff;
        z-index: 1;
        text-transform: uppercase;
    }

    .poster-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .poster-card-info {
        display: flex;
        flex-direction: column;
        padding: 0 2px;
    }

    .poster-card-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1.3;
        color: rgba(248, 248, 248, 0.90);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 2px;
    }

    /* Author — bold subtitle below title */
    .poster-card-author {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        line-height: 1.3;
        color: rgba(248, 248, 248, 0.55);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 4px;
    }

    .poster-card-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 400;
        line-height: 1.3;
        color: rgba(248, 248, 248, 0.38);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 4px;
    }

    .poster-card-meta {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .poster-meta-badge {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        color: var(--app-text-muted);
        text-transform: uppercase;
    }
</style>
