@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Services.Integration

@* PosterCard — Individual poster art tile with cover image, title, and metadata badges.
   Used inside PosterSwimlane for horizontal scrolling rows. *@

<div class="poster-card" style="width: @(Width)px; --card-width: @(Width)px;" @onclick="OnClick">
    <div class="poster-card-artwork @(IsAudiobook ? "audiobook-tile" : "") @(string.IsNullOrEmpty(Item.CoverUrl) ? "no-cover" : "")"
         style="@ArtworkStyle">
        @if (!string.IsNullOrEmpty(Item.CoverUrl))
        {
            <img src="@Item.CoverUrl"
                 alt="@Item.Title"
                 class="poster-card-img"
                 loading="lazy" />
        }
        else
        {
            @* Book fallback — spine-style gradient with title *@
            <div class="poster-card-book-spine">
                <MudIcon Icon="@MudBlazor.Icons.Material.Filled.MenuBook"
                         Style="font-size: 36px; color: rgba(255,255,255,0.18); margin-bottom: 8px;" />
                <span class="poster-card-spine-title">@Item.Title</span>
            </div>
        }

        @if (Item.IsNew)
        {
            <span class="poster-new-badge">NEW</span>
        }

        @* Format badge — book formats only *@
        @if (!string.IsNullOrEmpty(Item.FormatBadge))
        {
            <span class="poster-format-badge"
                  style="background: @FormatBadgeColour;">@FormatBadgeText</span>
        }

        @if (EffectiveProgressPct.HasValue && EffectiveProgressPct.Value > 0)
        {
            <div class="poster-progress-bar">
                <div class="poster-progress-fill" style="width: @(EffectiveProgressPct.Value)%;"></div>
            </div>
        }
    </div>
    <div class="poster-card-info">
        <span class="poster-card-title">@Item.Title</span>
        @* Author — primary subtitle for books *@
        @if (!string.IsNullOrEmpty(Item.Subtitle))
        {
            <span class="poster-card-author">@Item.Subtitle</span>
        }
        <div class="poster-card-meta">
            @if (!string.IsNullOrEmpty(Item.Year))
            {
                <span class="poster-meta-badge">@Item.Year</span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PosterItemViewModel Item { get; set; } = default!;
    [Parameter] public EventCallback<PosterItemViewModel> OnItemSelected { get; set; }
    [Parameter] public int Width { get; set; } = 180;
    [Parameter] public double? ProgressPct { get; set; }

    // ProgressPct parameter takes precedence; fall back to Item.Progress so
    // swimlanes that don't explicitly pass ProgressPct still show the bar.
    private double? EffectiveProgressPct => ProgressPct ?? Item.Progress;

    private bool IsAudiobook =>
        (Item.FormatBadge ?? string.Empty).Contains("audio", StringComparison.OrdinalIgnoreCase)
        || (Item.FormatBadge ?? string.Empty).Contains("m4b", StringComparison.OrdinalIgnoreCase);

    private string ArtworkStyle =>
        // Audiobooks: transparent — CSS handles subtle fallback when no cover art
        IsAudiobook || !string.IsNullOrEmpty(Item.CoverUrl)
            ? string.Empty
            : $"background: linear-gradient(160deg, {Item.DominantHexColor}44 0%, #0D1230 100%);";


    private async Task OnClick() => await OnItemSelected.InvokeAsync(Item);

    private string FormatBadgeText =>
        FormatBadgeLabel(Item.FormatBadge ?? string.Empty);

    private string FormatBadgeColour
    {
        get
        {
            var t = (Item.FormatBadge ?? string.Empty).ToLowerInvariant();
            if (t.Contains("audio") || t.Contains("m4b")) return "rgba(139, 92, 246, 0.85)"; // purple for audiobooks
            if (t.Contains("comic") || t.Contains("cbz")) return "rgba(20, 160, 100, 0.85)"; // teal for comics
            return "rgba(37, 99, 235, 0.85)"; // blue for books (default)
        }
    }

    private static string FormatBadgeLabel(string mediaType)
    {
        var t = mediaType.ToLowerInvariant();
        if (t.Contains("m4b") || t.Contains("audiobook")) return "Audiobook";
        if (t.Contains("audio"))                           return "Audio";
        if (t.Contains("epub") || t.Contains("book"))      return "Book";
        if (t.Contains("cbz") || t.Contains("cbr") || t.Contains("comic")) return "Comic";
        return "Book";
    }
}

<style>
    .poster-card {
        flex-shrink: 0;
        cursor: pointer;
        scroll-snap-align: start;
        transition: transform 0.2s ease;
    }

    .poster-card:hover {
        transform: translateY(-4px);
    }

    .poster-card:hover .poster-card-artwork {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.40);
    }

    .poster-card-artwork {
        position: relative;
        width: 100%;
        height: calc(var(--card-width) * 1.5);
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0D1230;
        margin-bottom: 8px;
        transition: box-shadow 0.2s ease;
    }

    /* ── Audiobook tile: square aspect ratio (1:1) + transparent background ── */
    .poster-card-artwork.audiobook-tile {
        height: var(--card-width);
        background: transparent;
    }

    /* Subtle shape when no cover art exists for audiobook */
    .poster-card-artwork.audiobook-tile.no-cover {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    /* ── Book spine fallback — shown when no cover art ── */
    .poster-card-book-spine {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 16px 10px;
        width: 100%;
        height: 100%;
    }

    .poster-card-spine-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.30);
        text-align: center;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .poster-new-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        padding: 3px 8px;
        border-radius: 4px;
        background: #C9922E;
        color: #ffffff;
        z-index: 1;
    }

    .poster-format-badge {
        position: absolute;
        bottom: 8px;
        right: 8px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.55rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 2px 6px;
        border-radius: 4px;
        color: #ffffff;
        z-index: 1;
    }

    .poster-card-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    .poster-card-info {
        display: flex;
        flex-direction: column;
        padding: 0 2px;
    }

    .poster-card-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1.3;
        color: rgba(248, 248, 248, 0.90);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 2px;
    }

    /* Author — bold subtitle below title */
    .poster-card-author {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        line-height: 1.3;
        color: rgba(248, 248, 248, 0.55);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 4px;
    }

    .poster-card-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 400;
        line-height: 1.3;
        color: rgba(248, 248, 248, 0.38);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 4px;
    }

    .poster-card-meta {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .poster-meta-badge {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        color: var(--app-text-muted);
        text-transform: uppercase;
    }

    .poster-progress-bar {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: rgba(0, 0, 0, 0.40);
        z-index: 2;
    }

    .poster-progress-fill {
        height: 100%;
        background: #C9922E;
        border-radius: 0 2px 2px 0;
        transition: width 0.3s ease;
    }

    /* ── Mobile: shrink cards so exactly 3.5 fit before swiping ── */
    /* Formula: (100vw - 2×16px page padding - 3×16px card gaps) / 3.5 ≈ (100vw - 80px) / 3.5 */
    @@media (max-width: 768px) {
        .poster-card {
            --card-width: calc((100vw - 80px) / 3.5) !important;
            width: calc((100vw - 80px) / 3.5) !important;
        }
    }
</style>
