@namespace MediaEngine.Web.Components.Universe
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer State
@inject NavigationManager Nav
@implements IDisposable
@if (_files.Count > 0 && DisplayMode != "hidden")
{
    @if (string.Equals(DisplayMode, "badge", StringComparison.OrdinalIgnoreCase))
    {
        @* Badge mode (mobile): compact inline chip *@
        <AppChip T="string" Size="Size.Medium"
                 Color="Color.Warning"
                 Icon="@Icons.Material.Filled.FolderOpen"
                 Class="@Class">
            @_files.Count @(_files.Count == 1 ? "file" : "files") to review
        </AppChip>
    }
    else
    {
        @* Expandable mode (default web): full alert with file list *@
        <AppPanel Elevation="0" Class="@PanelClass">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.FolderOpen"
                         Color="Color.Warning" Class="mr-2" />
                <MudText Typo="Typo.body1" Class="tl-u-flex-1">
                    <strong>@_files.Count</strong> @(_files.Count == 1 ? "file" : "files")
                    in the review queue
                </MudText>

                <AppButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.RateReview"
                           OnClick="@(() => Nav.NavigateTo("/settings/review"))">
                    Review Now
                </AppButton>

                <AppIconButton Icon="@(_expanded
                                        ? Icons.Material.Filled.ExpandLess
                                        : Icons.Material.Filled.ExpandMore)"
                               Size="Size.Small"
                               Color="Color.Default"
                               title="@(_expanded ? "Collapse file list" : "Show file list")"
                               OnClick="@(() => _expanded = !_expanded)" />
            </MudStack>

            @if (_expanded)
            {
                <MudSimpleTable Dense="true" Hover="true"
                                Class="tl-u-background-transparent tl-u-margin-top-8px">
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Size</th>
                            <th>Modified</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in _files)
                        {
                            <tr>
                                <td>
                                    <MudTooltip Text="@f.RelativePath">
                                        <code class="tl-u-font-family-monospace tl-u-font-size-0-85rem">
                                            @f.FileName
                                        </code>
                                    </MudTooltip>
                                </td>
                                <td>@f.FormattedSize</td>
                                <td>@f.LastModified.LocalDateTime.ToString("g")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </AppPanel>
    }
}

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public string DisplayMode { get; set; } = "expandable";

    private List<MediaEngine.Web.Models.ViewDTOs.WatchFolderFileViewModel> _files = [];
    private bool _expanded;

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await LoadFilesAsync();
    }

    private async Task LoadFilesAsync()
    {
        _files = await Orchestrator.GetWatchFolderAsync();
    }
    private void OnStateChanged()
    {
        InvokeAsync(async () =>
        {
            await LoadFilesAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }

    private string PanelClass =>
        string.Join(" ", new[] { "pending-files-alert-panel", Class }
            .Where(value => !string.IsNullOrWhiteSpace(value)));
}
