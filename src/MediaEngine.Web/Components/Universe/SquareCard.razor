@namespace MediaEngine.Web.Components.Universe

<AppMediaCard Title="@Item.Title"
              Subtitle="@Item.Subtitle"
              ImageUrl="@Item.CoverUrl"
              FallbackIcon="@Icons.Material.Filled.MusicNote"
              AccentColor="@AppMediaPresentation.AccentFor(Item.FormatBadge)"
              Progress="@Item.Progress"
              Width="@Width"
              Variant="AppMediaCardVariant.Square"
              OnSelected="OnClick">
    <Badge>
        @if (Item.IsNew)
        {
            <AppStatusBadge Text="NEW" Tone="AppStatusTone.Warning" />
        }
    </Badge>
</AppMediaCard>

@code {
    [Parameter, EditorRequired] public PosterItemViewModel Item { get; set; } = default!;
    [Parameter] public EventCallback<PosterItemViewModel> OnItemSelected { get; set; }
    [Parameter] public int Width { get; set; } = 180;

    private Task OnClick() => OnItemSelected.InvokeAsync(Item);
}
