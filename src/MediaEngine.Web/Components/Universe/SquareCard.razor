@namespace MediaEngine.Web.Components.Universe

@* SquareCard — 1:1 aspect ratio card for music albums.
   Features play overlay on hover and optional track count. *@

<div class="square-card" style="width: @(Width)px; --card-width: @(Width)px;" @onclick="OnClick">
    <div class="square-card-artwork">
        @if (!string.IsNullOrEmpty(Item.CoverUrl))
        {
            <img src="@Item.CoverUrl" alt="@Item.Title" class="square-card-img" loading="lazy" />
        }
        else
        {
            <div class="square-card-no-cover">
                <MudIcon Icon="@MudBlazor.Icons.Material.Filled.MusicNote"
                         Style="font-size: 40px; color: rgba(255,255,255,0.12);" />
            </div>
        }
        <div class="square-card-play-overlay">
            <div class="square-card-play-button">
                <MudIcon Icon="@MudBlazor.Icons.Material.Filled.PlayArrow"
                         Style="font-size: 28px; color: #fff;" />
            </div>
        </div>

        @if (Item.IsNew)
        {
            <span class="square-new-badge">NEW</span>
        }

        @if (Item.Progress is > 0)
        {
            <div class="square-progress-bar">
                <div class="square-progress-fill" style="width: @(Item.Progress.Value)%;"></div>
            </div>
        }
    </div>
    <div class="square-card-info">
        <span class="square-card-title">@Item.Title</span>
        @if (!string.IsNullOrEmpty(Item.Subtitle))
        {
            <span class="square-card-artist">@Item.Subtitle</span>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PosterItemViewModel Item { get; set; } = default!;
    [Parameter] public EventCallback<PosterItemViewModel> OnItemSelected { get; set; }
    [Parameter] public int Width { get; set; } = 180;

    private async Task OnClick() => await OnItemSelected.InvokeAsync(Item);
}

<style>
    .square-card {
        flex-shrink: 0;
        cursor: pointer;
        scroll-snap-align: start;
        transition: transform 0.2s ease;
    }

    .square-card:hover {
        transform: translateY(-4px);
    }

    .square-card:hover .square-card-artwork {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.40);
    }

    .square-card-artwork {
        position: relative;
        width: 100%;
        height: var(--card-width);
        border-radius: 8px;
        overflow: hidden;
        background: #0D1230;
        margin-bottom: 8px;
        transition: box-shadow 0.2s ease;
    }

    .square-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .square-card-no-cover {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 8px;
    }

    .square-card-play-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.35);
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .square-card:hover .square-card-play-overlay {
        opacity: 1;
    }

    .square-card-play-button {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(201, 146, 46, 0.85);
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        transition: transform 0.15s ease;
    }

    .square-card:hover .square-card-play-button {
        transform: scale(1.05);
    }

    .square-new-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        padding: 3px 8px;
        border-radius: 4px;
        background: #C9922E;
        color: #ffffff;
        z-index: 1;
    }

    .square-progress-bar {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: rgba(0, 0, 0, 0.40);
        z-index: 2;
    }

    .square-progress-fill {
        height: 100%;
        background: #C9922E;
        border-radius: 0 2px 2px 0;
        transition: width 0.3s ease;
    }

    .square-card-info {
        display: flex;
        flex-direction: column;
        padding: 0 2px;
    }

    .square-card-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1.3;
        color: rgba(248, 248, 248, 0.90);
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 2px;
    }

    .square-card-artist {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.50);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    @@media (max-width: 768px) {
        .square-card {
            --card-width: calc((100vw - 64px) / 2.5) !important;
            width: calc((100vw - 64px) / 2.5) !important;
        }
    }
</style>
