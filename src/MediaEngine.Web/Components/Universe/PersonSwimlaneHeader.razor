@namespace MediaEngine.Web.Components.Universe

@* PersonSwimlaneHeader — Inline header for person-grouped swimlanes.
   Shows 40px circular headshot (or initials fallback), person name, item count, and See All link.
   Works for any role: Author, Director, Artist, Host, etc. *@

<div class="person-swimlane-header">
    <div class="person-header-left">
        @if (!string.IsNullOrEmpty(HeadshotUrl))
        {
            <img src="@HeadshotUrl" alt="@PersonName"
                 class="person-header-headshot" loading="lazy" />
        }
        else
        {
            <div class="person-header-avatar">@Initials</div>
        }
        <div class="person-header-info">
            <span class="person-header-name">@PersonName</span>
            <span class="person-header-count">(@ItemCount @(ItemCount == 1 ? ItemNoun : ItemNoun + "s"))</span>
        </div>
    </div>
    @if (SeeAllHref is not null)
    {
        <a class="swimlane-see-all" href="@SeeAllHref">See All &#x203A;</a>
    }
</div>

@code {
    [Parameter, EditorRequired] public string PersonName { get; set; } = string.Empty;
    [Parameter] public string? HeadshotUrl { get; set; }
    [Parameter] public int ItemCount { get; set; }
    [Parameter] public string ItemNoun { get; set; } = "item";
    [Parameter] public string? SeeAllHref { get; set; }

    private string Initials
    {
        get
        {
            var parts = PersonName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            return parts.Length switch
            {
                0 => "?",
                1 => parts[0][..1].ToUpperInvariant(),
                _ => $"{parts[0][..1]}{parts[^1][..1]}".ToUpperInvariant(),
            };
        }
    }
}

<style>
    .person-swimlane-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
    }

    .person-header-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .person-header-headshot {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .person-header-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(201, 146, 46, 0.25);
        color: #C9922E;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.8rem;
        font-weight: 600;
        flex-shrink: 0;
    }

    .person-header-info {
        display: flex;
        align-items: baseline;
        gap: 8px;
    }

    .person-header-name {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 1.15rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.90);
        line-height: 1.3;
    }

    .person-header-count {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.40);
    }

    @@media (max-width: 768px) {
        .person-header-headshot,
        .person-header-avatar {
            width: 32px;
            height: 32px;
        }

        .person-header-name {
            font-size: 1rem;
        }

        .person-header-count {
            font-size: 0.75rem;
        }
    }
</style>
