@namespace MediaEngine.Web.Components.Universe
@inject IEngineApiClient ApiClient
<div class="adaptation-panel">
    <MudText Typo="Typo.subtitle1" Class="mb-1 tl-u-color-tl-accent-primary tl-u-font-weight-600" >
        Adaptation Tree
    </MudText>
    <MudText Typo="Typo.body2" Class="mb-4 tl-u-color-hex-888" >
        Works connected by based-on, derivative, and inspired-by relationships.
    </MudText>

    @if (_loading)
    {
        <div class="d-flex justify-center pa-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Warning" />
        </div>
    }
    else if (_adaptations?.Works.Count > 0)
    {
        <div class="adaptation-tree tl-u-overflow-y-auto tl-u-max-height-500px" >
            @foreach (var root in _adaptations.Works)
            {
                <AdaptationTreeNode Node="@root" Depth="0" />
            }
        </div>
    }
    else if (!_loading)
    {
        <AppAlert Severity="Severity.Info">
            No adaptation relationships found. Works appear here when they are linked by
            "based on", "derivative work", or "inspired by" connections.
        </AppAlert>
    }
</div>
@code {
    [Parameter] public string UniverseQid { get; set; } = string.Empty;

    private bool _loading;
    private UniverseAdaptationsResponse? _adaptations;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(UniverseQid) && _adaptations is null)
            await LoadAdaptations();
    }

    private async Task LoadAdaptations()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _adaptations = await ApiClient.GetUniverseAdaptationsAsync(UniverseQid);
        }
        finally
        {
            _loading = false;
        }
    }
}