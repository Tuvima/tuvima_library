@namespace MediaEngine.Web.Components.Universe

@inject IJSRuntime JS

@* PosterSwimlane -- Horizontal scrolling row of PosterCards.
   Features: section title with item count, "See All" link, hidden scrollbar,
   scroll-snap, touch-friendly, left/right scroll arrow buttons. *@

@if (Items is { Count: > 0 })
{
    <div class="swimlane-section @Class">
        <div class="swimlane-header">
            @if (HeaderContent is not null)
            {
                @HeaderContent
            }
            else
            {
                <div class="swimlane-header-left">
                    <h3 class="swimlane-title">@Title</h3>
                    @if (TotalCount.HasValue)
                    {
                        <span class="swimlane-count">(@TotalCount)</span>
                    }
                </div>
                @if (SeeAllRoute is not null)
                {
                    <a class="swimlane-see-all" href="@SeeAllRoute">See All &#x203A;</a>
                }
            }
        </div>

        <div class="swimlane-scroll-wrapper">
            @* Left arrow  only when there are multiple items and we can scroll left *@
            @if (Items.Count > 1 && !_atStart)
            {
                <AppNativeButton Class="swimlane-arrow swimlane-arrow-left" OnClick="ScrollLeft" AriaLabel="Scroll left">
                    <MudIcon Icon="@MudBlazor.Icons.Material.Filled.ChevronLeft" Size="Size.Medium" />
                </AppNativeButton>
            }

            <div class="swimlane-scroll" @ref="_scrollRef">
                @foreach (var item in Items)
                {
                    <LibraryCard Item="@item"
                               @key="item.Id"
                               OnItemSelected="OnItemSelected" />
                }
            </div>

            @* Right arrow  only when there are multiple items and we can scroll right *@
            @if (Items.Count > 1 && !_atEnd)
            {
                <AppNativeButton Class="swimlane-arrow swimlane-arrow-right" OnClick="ScrollRight" AriaLabel="Scroll right">
                    <MudIcon Icon="@MudBlazor.Icons.Material.Filled.ChevronRight" Size="Size.Medium" />
                </AppNativeButton>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<PosterItemViewModel> Items { get; set; } = [];
    [Parameter] public EventCallback<PosterItemViewModel> OnItemSelected { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public int? TotalCount { get; set; }
    [Parameter] public string? SeeAllRoute { get; set; }
    [Parameter] public RenderFragment? HeaderContent { get; set; }

    private ElementReference _scrollRef;
    private bool _atStart = true;
    private bool _atEnd   = false;
    private bool _refreshBoundaries;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if ((firstRender || _refreshBoundaries) && Items.Count > 1)
        {
            _refreshBoundaries = false;
            var state = await JS.InvokeAsync<ScrollBoundary>("getSwimlaneScrollState", _scrollRef);
            _atStart = state.AtStart;
            _atEnd   = state.AtEnd;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override void OnParametersSet()
    {
        _atStart = true;
        _atEnd   = false;
        _refreshBoundaries = true;
    }

    private async Task ScrollLeft()
    {
        var state = await JS.InvokeAsync<ScrollBoundary>("scrollSwimlaneEx", _scrollRef, "left");
        _atStart = state.AtStart;
        _atEnd   = state.AtEnd;
    }

    private async Task ScrollRight()
    {
        var state = await JS.InvokeAsync<ScrollBoundary>("scrollSwimlaneEx", _scrollRef, "right");
        _atStart = state.AtStart;
        _atEnd   = state.AtEnd;
    }

    private sealed class ScrollBoundary
    {
        public bool AtStart { get; set; }
        public bool AtEnd   { get; set; }
    }
}