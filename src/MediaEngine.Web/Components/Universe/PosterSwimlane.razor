@namespace MediaEngine.Web.Components.Universe

@inject IJSRuntime JS

@* PosterSwimlane -- Horizontal scrolling row of PosterCards.
   Features: section title with item count, "See All" link, hidden scrollbar,
   scroll-snap, touch-friendly, left/right scroll arrow buttons. *@

@if (Hubs is { Count: > 0 })
{
    <div class="swimlane-section @Class">
        <div class="swimlane-header">
            <div class="swimlane-header-left">
                <h3 class="swimlane-title">@Title</h3>
                @if (TotalCount.HasValue)
                {
                    <span class="swimlane-count">(@TotalCount)</span>
                }
            </div>
            @if (SeeAllRoute is not null)
            {
                <a class="swimlane-see-all" href="@SeeAllRoute">See All &#x203A;</a>
            }
        </div>

        <div class="swimlane-scroll-wrapper">
            <button class="swimlane-arrow swimlane-arrow-left" @onclick="ScrollLeft"
                    aria-label="Scroll left">
                <MudIcon Icon="@MudBlazor.Icons.Material.Filled.ChevronLeft" Size="Size.Medium" />
            </button>

            <div class="swimlane-scroll" @ref="_scrollRef">
                @foreach (var hub in Hubs)
                {
                    <PosterCard Hub="@hub"
                                OnHubSelected="OnHubSelected"
                                Width="@CardWidth" />
                }
            </div>

            <button class="swimlane-arrow swimlane-arrow-right" @onclick="ScrollRight"
                    aria-label="Scroll right">
                <MudIcon Icon="@MudBlazor.Icons.Material.Filled.ChevronRight" Size="Size.Medium" />
            </button>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<HubViewModel> Hubs { get; set; } = [];
    [Parameter] public EventCallback<HubViewModel> OnHubSelected { get; set; }
    [Parameter] public int CardWidth { get; set; } = 180;
    [Parameter] public string? Class { get; set; }
    [Parameter] public int? TotalCount { get; set; }
    [Parameter] public string? SeeAllRoute { get; set; }

    private ElementReference _scrollRef;

    private async Task ScrollLeft()
    {
        await JS.InvokeVoidAsync("scrollSwimlane", _scrollRef, "left");
    }

    private async Task ScrollRight()
    {
        await JS.InvokeVoidAsync("scrollSwimlane", _scrollRef, "right");
    }
}

<style>
    .swimlane-section {
        margin-bottom: 2rem;
        /* Left padding keeps title and first card clear of the floating dock */
        padding-left: 88px;
    }

    /* Mobile: dock is hidden -- reduce swimlane indent to match container padding */
    @@media (max-width: 768px) {
        .swimlane-section {
            padding-left: 0;
        }
    }

    .swimlane-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
        padding: 0 2px;
    }

    .swimlane-header-left {
        display: flex;
        align-items: baseline;
        gap: 8px;
    }

    .swimlane-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.90);
        margin: 0;
        line-height: 1.3;
    }

    .swimlane-count {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.40);
    }

    .swimlane-see-all {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.45);
        text-decoration: none;
        transition: color 0.2s ease;
        white-space: nowrap;
    }

    .swimlane-see-all:hover {
        color: rgba(248, 248, 248, 0.75);
    }

    /* -- Scroll wrapper with arrow buttons -- */
    .swimlane-scroll-wrapper {
        position: relative;
    }

    .swimlane-arrow {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 40px;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        color: rgba(248, 248, 248, 0.80);
        opacity: 0;
        transition: opacity 0.2s ease;
        padding: 0;
    }

    .swimlane-arrow-left {
        left: 0;
        background: linear-gradient(to right, rgba(6, 10, 22, 0.95) 40%, transparent);
        border-radius: 6px 0 0 6px;
    }

    .swimlane-arrow-right {
        right: 0;
        background: linear-gradient(to left, rgba(6, 10, 22, 0.95) 40%, transparent);
        border-radius: 0 6px 6px 0;
    }

    .swimlane-scroll-wrapper:hover .swimlane-arrow {
        opacity: 1;
    }

    .swimlane-arrow:hover {
        color: rgba(248, 248, 248, 1);
    }

    /* Hide arrows on touch devices -- they scroll natively */
    @@media (hover: none) {
        .swimlane-arrow {
            display: none;
        }
    }

    .swimlane-scroll {
        display: flex;
        gap: 16px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        padding-bottom: 8px;

        /* Hide scrollbar across browsers */
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .swimlane-scroll::-webkit-scrollbar {
        display: none;
    }
</style>