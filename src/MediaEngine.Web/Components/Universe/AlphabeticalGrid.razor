@namespace MediaEngine.Web.Components.Universe

@inject IJSRuntime JS

@* AlphabeticalGrid -- Groups collections by first letter with sticky headers and
   a right-edge alphabet strip for quick-jump navigation. *@

<div class="az-container">
    <div class="az-content">
        @foreach (var group in _letterGroups)
        {
            <div class="az-letter-section" id="az-@group.Letter" @key="group.Letter">
                <div class="az-letter-header">
                    <span class="az-letter">@group.Letter</span>
                    <span class="az-letter-count">@group.Items.Count</span>
                </div>
                <div class="az-grid">
                    @foreach (var item in group.Items)
                    {
                        <LibraryCard Item="@item"
                                     @key="@GetItemKey(item)"
                                     OnItemSelected="OnItemSelected" />
                    }
                </div>
            </div>
        }
    </div>

    <div class="az-strip">
        @foreach (var letter in _allLetters)
        {
            var hasItems = _activeLetters.Contains(letter);
            <AppNativeButton Class='@($"az-strip-letter {(hasItems ? " " : "az-strip-inactive")}")' @key="letter" Disabled="@(!hasItems)" OnClick="@(() => ScrollToLetter(letter))">
                @letter
            </AppNativeButton>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<PosterItemViewModel> Items { get; set; } = [];
    [Parameter] public EventCallback<PosterItemViewModel> OnItemSelected { get; set; }

    private static readonly string[] _allLetters =
        Enumerable.Range('A', 26).Select(c => ((char)c).ToString()).Append("#").ToArray();

    private List<LetterGroup> _letterGroups = [];
    private HashSet<string> _activeLetters = [];
    private IReadOnlyList<PosterItemViewModel>? _lastItemsReference;

    private sealed record LetterGroup(string Letter, IReadOnlyList<PosterItemViewModel> Items);

    protected override void OnParametersSet()
    {
        BuildGroups();
    }

    private void BuildGroups()
    {
        if (ReferenceEquals(Items, _lastItemsReference))
        {
            return;
        }

        _lastItemsReference = Items;
        _letterGroups = Items
            .GroupBy(i => GetLetterKey(i.Title))
            .OrderBy(g => g.Key == "#" ? "ZZZ" : g.Key)
            .Select(g => new LetterGroup(g.Key, g.OrderBy(i => i.Title).ToList()))
            .ToList();

        _activeLetters = _letterGroups.Select(g => g.Letter).ToHashSet();
    }

    private static string GetItemKey(PosterItemViewModel item)
        => item.Id != Guid.Empty ? item.Id.ToString("N") : item.NavigationUrl;

    private static string GetLetterKey(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "#";
        var first = char.ToUpperInvariant(name[0]);
        return char.IsLetter(first) ? first.ToString() : "#";
    }

    private async Task ScrollToLetter(string letter)
    {
        await JS.InvokeVoidAsync("scrollToLetter", $"az-{letter}");
    }
}