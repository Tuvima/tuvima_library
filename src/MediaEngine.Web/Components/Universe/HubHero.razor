@namespace MediaEngine.Web.Components.Universe

@* Hero Banner Row — Plex-inspired wide banner cards at the top of the Home page.
   Primary banner: "Continue Watching" with the first Hub.
   Secondary banner: "Next Up" with the second Hub.
   Uses mock progress data until UserState API exists.

   Layout variants:
     "two-column"           → Default web: two banners side by side
     "stacked"              → Mobile: single banner, stacked
     "two-column-oversized" → Television: larger banners
     "hidden"               → Not rendered *@

@if (Layout != "hidden")
{
    <div class="hero-banner-row @LayoutClass">
        @* ── Primary Banner ── *@
        @if (Hub is not null)
        {
            <div class="hero-banner hero-banner-primary" style="@BannerBgStyle(Hub)">
                <div class="hero-banner-overlay" />
                <div class="hero-banner-content">
                    <span class="hero-banner-tag">CONTINUE WATCHING</span>
                    <h2 class="hero-banner-title">@Hub.DisplayName</h2>
                    <p class="hero-banner-subtitle">@HubMeta(Hub)</p>
                </div>
            </div>
        }

        @* ── Secondary Banner ── *@
        @if (SecondaryHub is not null && !IsStacked)
        {
            <div class="hero-banner hero-banner-secondary" style="@BannerBgStyle(SecondaryHub)">
                <div class="hero-banner-overlay" />
                <div class="hero-banner-content">
                    <span class="hero-banner-tag">NEXT UP IN THE COLLECTION</span>
                    <h2 class="hero-banner-title">@SecondaryHub.DisplayName</h2>
                    <p class="hero-banner-subtitle">@HubMeta(SecondaryHub)</p>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public HubViewModel? Hub { get; set; }
    [Parameter] public HubViewModel? SecondaryHub { get; set; }

    /// <summary>
    /// Layout variant driven by DeviceContext.
    /// Accepted values: "two-column" (default), "stacked", "two-column-oversized", "hidden".
    /// </summary>
    [Parameter] public string Layout { get; set; } = "two-column";

    private bool IsStacked =>
        string.Equals(Layout, "stacked", StringComparison.OrdinalIgnoreCase);

    private string LayoutClass => Layout switch
    {
        "stacked"              => "hero-banner-row-stacked",
        "two-column-oversized" => "hero-banner-row-oversized",
        _                      => string.Empty,
    };

    private string BannerBgStyle(HubViewModel hub)
    {
        var hex = hub.DominantHexColor ?? "#C9922E";
        return $"--banner-accent: {hex};";
    }

    private string HubMeta(HubViewModel hub) =>
        $"{hub.MediaTypes} — {hub.WorkCount} {(hub.WorkCount == 1 ? "work" : "works")}";
}

<style>
    /* ── Banner row container ────────────────────────────────────────── */
    .hero-banner-row {
        display: flex;
        gap: 20px;
        margin-bottom: 2rem;
    }

    .hero-banner-row-stacked {
        flex-direction: column;
    }

    /* ── Individual banner card ──────────────────────────────────────── */
    .hero-banner {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        min-height: 260px;
        display: flex;
        align-items: flex-end;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        background: #111111;
    }

    .hero-banner:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
    }

    .hero-banner-primary {
        flex: 2;
        min-height: 300px;
    }

    .hero-banner-secondary {
        flex: 1;
        min-height: 260px;
    }

    /* ── Dark gradient overlay for text readability ──────────────────── */
    .hero-banner-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.80) 0%,
            rgba(0, 0, 0, 0.30) 40%,
            transparent 70%
        );
        pointer-events: none;
    }

    /* ── Banner text content ─────────────────────────────────────────── */
    .hero-banner-content {
        position: relative;
        z-index: 1;
        padding: 1.5rem 2rem;
        width: 100%;
    }

    .hero-banner-tag {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.65);
        text-transform: uppercase;
        display: block;
        margin-bottom: 6px;
    }

    .hero-banner-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: #ffffff;
        margin: 0 0 4px 0;
        line-height: 1.2;
    }

    .hero-banner-primary .hero-banner-title {
        font-size: 2rem;
    }

    .hero-banner-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.70);
        margin: 0;
    }

    /* ── Oversized layout (television) ──────────────────────────────── */
    .hero-banner-row-oversized .hero-banner {
        min-height: 380px;
    }

    .hero-banner-row-oversized .hero-banner-title {
        font-size: 2.4rem;
    }

    .hero-banner-row-oversized .hero-banner-content {
        padding: 2.5rem 3rem;
    }

    /* ── Stacked layout (mobile) ────────────────────────────────────── */
    .hero-banner-row-stacked .hero-banner-primary {
        min-height: 220px;
    }

    /* ── Responsive fallback ────────────────────────────────────────── */
    @@media (max-width: 768px) {
        .hero-banner-row {
            flex-direction: column;
        }

        .hero-banner-primary {
            min-height: 220px;
        }

        .hero-banner-secondary {
            display: none;
        }

        .hero-banner-title {
            font-size: 1.4rem !important;
        }
    }
</style>
