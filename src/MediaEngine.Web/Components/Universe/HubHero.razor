@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Models.ViewDTOs

@* Unified Hero Banner — Renders a cinematic hero for any media type.
   Portrait media (Books/Comics/Audiobooks): foreground cover + text on desktop, Netflix-style on mobile.
   Landscape media (Movies/TV): full-bleed cinematic backdrop on both desktop and mobile. *@

@if (Visible && Data is not null)
{
    <div class="hero-banner @(Data.IsPortraitMedia ? "hero-portrait" : "hero-landscape")"
         @onclick="HandleClick"
         style="@AmbientStyle">

        @* ── Background layer — full-bleed cinematic backdrop ── *@
        <div class="hero-banner-bg">
            <div class="hero-bleed">
                <div class="hero-backdrop">
                    @if (!string.IsNullOrEmpty(Data.HeroUrl))
                    {
                        <img src="@Data.HeroUrl" alt="" class="hero-bg-prerendered" />
                    }
                    else if (!string.IsNullOrEmpty(Data.CoverUrl))
                    {
                        <img src="@Data.CoverUrl" alt="" class="hero-bg-blurred" />
                    }

                    @* Vignette — always rendered for text readability *@
                    <div class="hero-vignette" />

                    @* Gradient fallback when no art at all *@
                    @if (string.IsNullOrEmpty(Data.HeroUrl) && string.IsNullOrEmpty(Data.CoverUrl))
                    {
                        <div class="hero-gradient"
                             style="--hero-accent: @(Data.DominantColor ?? "#C9922E");" />
                    }
                </div>
            </div>
        </div>

        @* ── Mobile cover — large prominent cover for portrait media on mobile ── *@
        @if (Data.IsPortraitMedia && !string.IsNullOrEmpty(Data.CoverUrl))
        {
            <div class="hero-mobile-cover-wrapper">
                <img src="@Data.CoverUrl"
                     alt="@Data.Title"
                     class="hero-mobile-cover" />

                @* Subtle media type icon — visible on mobile only *@
                @if (!string.IsNullOrEmpty(Data.MediaTypeLabel))
                {
                    <div class="hero-mobile-type-icon"
                         style="background: @(HeroData.FormatBadgeColor(Data.MediaTypeLabel))">
                        <MudIcon Icon="@(HeroData.IconForMediaType(Data.MediaTypeLabel))"
                                 Style="font-size: 0.85rem; color: white;" />
                    </div>
                }
            </div>
        }

        @* ── Content layer — text, badges, CTA ── *@
        <div class="hero-content">
            @if (Data.IsPortraitMedia)
            {
                @* Portrait layout: cover + text side by side on desktop *@
                <div class="hero-content-row">
                    @if (!string.IsNullOrEmpty(Data.CoverUrl))
                    {
                        <img src="@Data.CoverUrl"
                             alt="@Data.Title"
                             class="hero-poster" />
                    }
                    <div class="hero-text">
                        <HubHeroText Data="@Data" OnCtaClicked="@OnCtaClicked" />
                    </div>
                </div>
            }
            else
            {
                @* Landscape layout: text only *@
                <div class="hero-text">
                    <HubHeroText Data="@Data" OnCtaClicked="@OnCtaClicked" />
                </div>
            }
        </div>
    </div>
}

@code {
    /// <summary>Unified hero data (use HeroData.FromHub / FromJourney factory methods).</summary>
    [Parameter] public HeroData? Data { get; set; }

    /// <summary>Controls visibility. Driven by device-context hero settings.</summary>
    [Parameter] public bool Visible { get; set; } = true;

    /// <summary>Callback when the hero banner area is clicked.</summary>
    [Parameter] public EventCallback OnClicked { get; set; }

    /// <summary>Callback when the CTA button is clicked.</summary>
    [Parameter] public EventCallback OnCtaClicked { get; set; }

    private string? AmbientStyle => Data?.DominantColor is not null
        ? $"--hero-dominant: {Data.DominantColor};"
        : null;

    private async Task HandleClick()
    {
        if (OnClicked.HasDelegate)
            await OnClicked.InvokeAsync();
    }
}

<style>
    /* ══════════════════════════════════════════════════════════════════════
       UNIFIED HERO BANNER
       ══════════════════════════════════════════════════════════════════════ */

    /* ── Outer container — grid overlay so bg + content share the same cell ── */
    .hero-banner {
        display: grid;
        grid-template-areas: "hero";
        margin-top: -88px;           /* Negate TopBar (64px) + container padding (24px) */
        margin-bottom: 2.5rem;
        cursor: pointer;
        position: relative;
    }

    .hero-banner-bg   { grid-area: hero; }
    .hero-content     { grid-area: hero; }

    /* Mobile cover occupies the same grid cell */
    .hero-mobile-cover-wrapper { grid-area: hero; display: none; position: relative; }

    /* Media type icon — hidden on desktop, shown on mobile */
    .hero-mobile-type-icon { display: none; }

    /* ── Content layer ──────────────────────────────────────────────────── */
    .hero-content {
        align-self: stretch;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        align-items: flex-start;
        padding: 0 2.5rem 2.5rem 88px;   /* 88px = left dock clearance */
        position: relative;
        z-index: 3;
    }

    /* ── Full-bleed wrapper — escapes MudContainer to reach viewport edges ── */
    .hero-bleed {
        width: 100vw;
        position: relative;
        margin-left: calc(50% - 50vw);
    }

    /* ── Backdrop container ─────────────────────────────────────────────── */
    .hero-backdrop {
        position: relative;
        overflow: hidden;
        width: 100%;
        display: flex;
        align-items: flex-end;
        background: #060A16;
        /* Aspect-ratio driven sizing — scales with viewport, prevents clipping */
        aspect-ratio: 21 / 9;
        max-height: 580px;
        min-height: 360px;
    }

    /* ── Pre-rendered hero.jpg ──────────────────────────────────────────── */
    .hero-bg-prerendered {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 30%;
        pointer-events: none;
        z-index: 0;
    }

    /* ── CSS-blurred cover art fallback ─────────────────────────────────── */
    .hero-bg-blurred {
        position: absolute;
        inset: -30px;
        width: calc(100% + 60px);
        height: calc(100% + 60px);
        object-fit: cover;
        filter: blur(24px) brightness(0.5);
        transform: scale(1.1);
        pointer-events: none;
        z-index: 0;
    }

    /* ── Vignette overlay — always rendered for text readability ────────── */
    .hero-vignette {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(6, 10, 22, 0.95) 0%,
            rgba(6, 10, 22, 0.55) 35%,
            rgba(6, 10, 22, 0.20) 65%,
            rgba(6, 10, 22, 0.10) 100%
        );
        pointer-events: none;
        z-index: 1;
    }

    /* ── Gradient fallback (no cover art at all) ───────────────────────── */
    .hero-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            var(--hero-accent) 0%,
            rgba(0, 0, 0, 0.80) 60%,
            #0A0A0A 100%
        );
        opacity: 0.4;
        pointer-events: none;
        z-index: 0;
    }

    /* ══════════════════════════════════════════════════════════════════════
       PORTRAIT MODE — Books, Comics, Audiobooks (desktop)
       ══════════════════════════════════════════════════════════════════════ */

    .hero-content-row {
        display: flex;
        align-items: flex-end;
        gap: 28px;
        max-width: 900px;
        width: 100%;
    }

    .hero-poster {
        align-self: stretch;
        width: auto;
        max-width: 220px;
        object-fit: contain;
        object-position: bottom center;
        border-radius: 10px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
        flex-shrink: 0;
        pointer-events: none;
    }

    .hero-text {
        flex: 1;
        min-width: 0;
    }

    /* ══════════════════════════════════════════════════════════════════════
       MOBILE — Netflix-style hero
       ══════════════════════════════════════════════════════════════════════ */

    @@media (max-width: 768px) {

        .hero-banner {
            min-height: unset;
        }

        .hero-content {
            padding: 0 1.25rem 1.5rem 1.25rem;
        }

        /* ── Portrait mobile: Framed card — cover + text in separate rows ── */

        .hero-portrait {
            grid-template-rows: auto auto;
            grid-template-areas:
                "hero-visual"
                "hero-info";
        }

        .hero-portrait .hero-banner-bg {
            grid-row: 1 / -1;
            grid-column: 1;
        }

        .hero-portrait .hero-mobile-cover-wrapper {
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 72px 0 16px 0;
            z-index: 2;
            grid-area: hero-visual;
            position: relative;
        }

        .hero-portrait .hero-mobile-type-icon {
            display: flex;
            position: absolute;
            bottom: 24px;
            right: calc(50% - 170px + 12px); /* align to cover right edge */
            width: 28px;
            height: 28px;
            border-radius: 50%;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
            z-index: 3;
        }

        .hero-portrait .hero-content {
            grid-area: hero-info;
            background: none;
            padding-top: 0;
            padding-bottom: 1.5rem;
        }

        .hero-mobile-cover {
            width: 90%;
            max-width: 340px;
            aspect-ratio: 2 / 3;
            object-fit: cover;
            border-radius: 10px;
            box-shadow: 0 16px 48px rgba(0, 0, 0, 0.7);
        }

        /* Backdrop extends behind both cover and text rows — forms the coloured "frame". */
        .hero-portrait .hero-backdrop {
            aspect-ratio: unset;
            min-height: unset;
            max-height: unset;
            height: 100%;
        }

        .hero-portrait .hero-bg-prerendered,
        .hero-portrait .hero-bg-blurred {
            opacity: 0.35;
            filter: blur(40px) brightness(0.4) saturate(1.4);
        }

        /* Vignette — softer edges for the framed card look */
        .hero-portrait .hero-vignette {
            background: linear-gradient(
                to top,
                rgba(6, 10, 22, 0.95) 0%,
                rgba(6, 10, 22, 0.60) 35%,
                rgba(6, 10, 22, 0.30) 60%,
                rgba(6, 10, 22, 0.20) 100%
            );
        }

        /* Center-align text on mobile portrait, flex column for reordering */
        .hero-portrait .hero-text {
            text-align: center;
            display: flex;
            flex-direction: column;
        }

        /* Reorder: CTA → Phrase → Title (badges, author, description hidden) */
        .hero-portrait .hub-primary-cta {
            order: 1;
            margin-top: 0 !important;
            margin-bottom: 12px;
        }

        .hero-portrait .hero-subtitle-label {
            order: 2;
            font-size: 0.72rem;
            color: rgba(255, 255, 255, 0.60);
            margin-bottom: 4px;
        }

        .hero-portrait .hero-title {
            order: 3;
        }

        /* Hide these on mobile portrait to keep it compact */
        .hero-portrait .hero-badges,
        .hero-portrait .hero-author,
        .hero-portrait .hero-narrator,
        .hero-portrait .hero-description {
            display: none;
        }

        /* Hide the desktop poster in portrait mode on mobile
           (the mobile cover wrapper shows the large cover instead) */
        .hero-portrait .hero-poster {
            display: none;
        }

        .hero-portrait .hero-content-row {
            gap: 0;
            justify-content: center;
        }

        /* ── Landscape mobile: backdrop-based, similar to desktop but shorter ── */

        .hero-landscape .hero-backdrop {
            aspect-ratio: 16 / 9;
            max-height: 320px;
            min-height: 220px;
        }

        .hero-landscape .hero-content {
            background: linear-gradient(
                to top,
                rgba(0, 0, 0, 0.95) 0%,
                rgba(0, 0, 0, 0.70) 40%,
                transparent 100%
            );
            padding-top: 2rem;
        }

        .hero-content-row {
            gap: 16px;
        }
    }
</style>
