@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Services.Integration

@* Cinematic Hero Banner — Single full-width banner with blurred cover art backdrop.
   Displays the primary Hub with dark vignette overlay and metadata badges.
   Gracefully falls back to a gradient when no cover art is available. *@

@if (Visible && Hub is not null)
{
    <div class="hero-cinema @SizeClass @(BackgroundOnly ? "hero-bg-only" : "")" @onclick="OnClick">

        @* ── Blurred cover art background ── *@
        @if (!string.IsNullOrEmpty(Hub.CoverUrl))
        {
            <img src="@Hub.CoverUrl"
                 alt=""
                 class="hero-cinema-bg" />
        }

        @* ── Dark vignette overlay ── *@
        <div class="hero-cinema-vignette" />

        @* ── Accent colour fallback gradient (when no cover art) ── *@
        @if (string.IsNullOrEmpty(Hub.CoverUrl))
        {
            <div class="hero-cinema-gradient" style="--hero-accent: @(Hub.DominantHexColor ?? "#C9922E");" />
        }

        @* ── Content at bottom-left (skipped when used as background-only layer) ── *@
        @if (!BackgroundOnly)
        {
            <div class="hero-cinema-content">
                <h2 class="hero-cinema-title">@Hub.DisplayName</h2>

                @* Metadata badges *@
                <div class="hero-cinema-badges">
                    @if (!string.IsNullOrEmpty(Hub.Year))
                    {
                        <span class="hero-badge">@Hub.Year</span>
                    }
                    @if (!string.IsNullOrEmpty(Hub.PrimaryMediaType))
                    {
                        <span class="hero-badge">@FormatMediaType(Hub.PrimaryMediaType)</span>
                    }
                    @if (!string.IsNullOrEmpty(Hub.Genre))
                    {
                        @foreach (var genre in Hub.Genre.Split(',', ';').Take(2).Select(g => g.Trim()).Where(g => g.Length > 0))
                        {
                            <span class="hero-badge">@genre</span>
                        }
                    }
                    @if (!string.IsNullOrEmpty(Hub.Rating))
                    {
                        <span class="hero-badge">@Hub.Rating</span>
                    }
                    @if (Hub.WorkCount > 1)
                    {
                        <span class="hero-badge">@Hub.WorkCount works</span>
                    }
                </div>

                @* Series info *@
                @if (!string.IsNullOrEmpty(Hub.Series))
                {
                    <p class="hero-cinema-series">@Hub.Series</p>
                }

                @* Author/creator *@
                @if (!string.IsNullOrEmpty(Hub.Author))
                {
                    <p class="hero-cinema-subtitle">@Hub.Author</p>
                }

                @* Description *@
                @if (!string.IsNullOrEmpty(Hub.Description))
                {
                    <p class="hero-cinema-description">@Truncate(Hub.Description, 200)</p>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public HubViewModel? Hub { get; set; }

    /// <summary>Controls visibility. Driven by device-context hero settings.</summary>
    [Parameter] public bool Visible { get; set; } = true;

    /// <summary>Callback when the hero banner is clicked.</summary>
    [Parameter] public EventCallback<HubViewModel> OnHubClicked { get; set; }

    /// <summary>
    /// When true, renders only the visual background layers (image, vignette, gradient).
    /// Text content is omitted so the caller can place it in normal document flow for alignment.
    /// </summary>
    [Parameter] public bool BackgroundOnly { get; set; } = false;

    private string SizeClass => "hero-cinema-desktop";

    private async Task OnClick()
    {
        if (!BackgroundOnly && Hub is not null)
            await OnHubClicked.InvokeAsync(Hub);
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength].TrimEnd() + "…";

    private static string FormatMediaType(string mediaType)
    {
        var t = mediaType.ToLowerInvariant();
        if (t.Contains("epub") || t.Contains("book"))  return "Book";
        if (t.Contains("video") || t.Contains("movie")) return "Movie";
        if (t.Contains("audio") || t.Contains("m4b"))   return "Audiobook";
        if (t.Contains("comic") || t.Contains("cbz"))   return "Comic";
        if (t.Contains("mkv") || t.Contains("mp4"))     return "Video";
        return mediaType;
    }
}

<style>
    /* ── Cinematic hero container — full-bleed, no rounded corners ─────── */
    .hero-cinema {
        position: relative;
        border-radius: 0;
        overflow: hidden;
        cursor: pointer;
        margin-bottom: 0;
        display: flex;
        align-items: flex-end;
        background: #060A16;
        transition: box-shadow 0.25s ease;
        width: 100%; /* Fill the 100vw bleed wrapper */
    }

    /* Background-only mode: no click affordance (click handled by outer wrapper) */
    .hero-bg-only {
        cursor: inherit;
        pointer-events: none;
    }

    .hero-cinema-desktop {
        min-height: 520px;
    }

    /* ── Blurred cover art background image ────────────────────────────── */
    .hero-cinema-bg {
        position: absolute;
        inset: -30px;
        width: calc(100% + 60px);
        height: calc(100% + 60px);
        object-fit: cover;
        filter: blur(24px) brightness(0.5);
        transform: scale(1.1);
        pointer-events: none;
        z-index: 0;
    }

    /* ── Dark vignette overlay for text readability ─────────────────────── */
    .hero-cinema-vignette {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(6, 10, 22, 0.95) 0%,
            rgba(6, 10, 22, 0.55) 35%,
            rgba(6, 10, 22, 0.20) 65%,
            rgba(6, 10, 22, 0.10) 100%
        );
        pointer-events: none;
        z-index: 1;
    }

    /* ── Gradient fallback (no cover art) ──────────────────────────────── */
    .hero-cinema-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            var(--hero-accent) 0%,
            rgba(0, 0, 0, 0.80) 60%,
            #0A0A0A 100%
        );
        opacity: 0.4;
        pointer-events: none;
        z-index: 0;
    }

    /* ── Content overlay (bottom-left) ─────────────────────────────────── */
    /* Padding is intentionally minimal here — when used in the grid overlay layout
       (BackgroundOnly=false, standalone use), the text renders over the background.
       In the primary Home layout, text lives in .hero-stack-text (Home.razor) and
       this div is not rendered (BackgroundOnly=true). */
    .hero-cinema-content {
        position: relative;
        z-index: 2;
        padding: 2rem 2.5rem 2.5rem 2rem;
        width: 100%;
        max-width: 900px;
    }

    .hero-cinema-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 2.4rem;
        font-weight: 700;
        color: #ffffff;
        margin: 0 0 10px 0;
        line-height: 1.15;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.50);
    }

    /* ── Metadata badges ───────────────────────────────────────────────── */
    .hero-cinema-badges {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 10px;
    }

    .hero-badge {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 4px 10px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.10);
        text-transform: uppercase;
    }

    .hero-cinema-series {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.55);
        margin: 0 0 4px 0;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        text-shadow: 0 1px 6px rgba(0, 0, 0, 0.40);
    }

    .hero-cinema-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 1rem;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.70);
        margin: 0 0 8px 0;
        text-shadow: 0 1px 6px rgba(0, 0, 0, 0.40);
    }

    .hero-cinema-description {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.88rem;
        font-weight: 300;
        line-height: 1.5;
        color: rgba(255, 255, 255, 0.50);
        margin: 0;
        text-shadow: 0 1px 4px rgba(0, 0, 0, 0.30);
    }

    /* ── Responsive ────────────────────────────────────────────────────── */
    @@media (max-width: 768px) {
        .hero-cinema-desktop {
            min-height: 240px;
        }

        .hero-cinema-content {
            padding: 1.25rem 1.5rem;
        }

        .hero-cinema-title {
            font-size: 1.5rem;
        }

        .hero-cinema-subtitle {
            font-size: 0.85rem;
        }

        .hero-badge {
            font-size: 0.65rem;
            padding: 3px 8px;
        }
    }
</style>
