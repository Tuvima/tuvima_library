@namespace MediaEngine.Web.Components.Universe
@inject IEngineApiClient ApiClient
<div class="family-tree-panel">
    <MudText Typo="Typo.subtitle1" Class="mb-3" Style="color: var(--tl-accent-primary); font-weight: 600;">
        Family Tree
    </MudText>

    @* Character selector *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <AppSelect T="string" Value="@_selectedCharQid" ValueChanged="OnCharacterSelected"
                   Label="Character" Variant="Variant.Outlined" Margin="Margin.Dense"
                   Style="flex: 1; min-width: 200px;"
                   Placeholder="Select a character...">
            @foreach (var node in Characters)
            {
                <MudSelectItem T="string" Value="@node.Id">@node.Label</MudSelectItem>
            }
        </AppSelect>
        <AppNumericField T="int" @bind-Value="_generations" Label="Generations"
                         Min="1" Max="5" Style="max-width: 100px;" Margin="Margin.Dense"
                         Variant="Variant.Outlined" />
        <AppButton Variant="Variant.Filled" Color="Color.Warning"
                   OnClick="LoadTree" Disabled="@(string.IsNullOrEmpty(_selectedCharQid) || _loading)"
                   StartIcon="@Icons.Material.Filled.AccountTree">
            @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" /> }
            else { <span>Show Tree</span> }
        </AppButton>
    </MudStack>

    @* Tree display *@
    @if (_tree is not null && _tree.Generations.Count > 0)
    {
        <div class="family-tree-container">
            @foreach (var gen in _tree.Generations.OrderBy(g => int.TryParse(g.Key, out var n) ? n : 0))
            {
                var genNum = gen.Key;
                var genLabel = genNum switch
                {
                    "0" => "Selected Character",
                    "-1" => "Parents",
                    "-2" => "Grandparents",
                    "1"  => "Children",
                    "2"  => "Grandchildren",
                    _    => $"Generation {genNum}",
                };

                <div class="gen-row">
                    <MudText Typo="Typo.caption" Class="gen-label">@genLabel</MudText>
                    <div class="gen-members">
                        @foreach (var member in gen.Value)
                        {
                            <div class="family-node @(member.Qid == _selectedCharQid ? "family-node-center" : "")">
                                @if (!string.IsNullOrWhiteSpace(member.Image))
                                {
                                    <MudAvatar Size="Size.Medium"><img src="@member.Image" alt="@member.Label" style="width:100%;height:100%;object-fit:cover;" /></MudAvatar>
                                }
                                else
                                {
                                    <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                        @(member.Label.Length > 0 ? member.Label[0].ToString() : "?")
                                    </MudAvatar>
                                }
                                <MudText Typo="Typo.caption" Class="mt-1" Style="text-align: center; max-width: 80px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @member.Label
                                </MudText>
                                @if (!string.IsNullOrWhiteSpace(member.Relationship))
                                {
                                    <MudText Typo="Typo.caption" Style="color: #888; font-size: 10px; text-align: center;">
                                        @member.Relationship
                                    </MudText>
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="gen-divider"></div>
            }
        </div>
    }
    else if (_noResults)
    {
        <AppAlert Severity="Severity.Info">No family relationships found for this character.</AppAlert>
    }
</div>
@code {
    [Parameter] public string UniverseQid { get; set; } = string.Empty;
    [Parameter] public UniverseGraphResponse? Graph { get; set; }

    private string? _selectedCharQid;
    private int _generations = 2;
    private bool _loading;
    private bool _noResults;
    private FamilyTreeResponse? _tree;

    private IEnumerable<GraphNodeDto> Characters =>
        Graph?.Nodes.Where(n =>
            string.Equals(n.Type, "Character", StringComparison.OrdinalIgnoreCase)) ?? [];

    private async Task OnCharacterSelected(string qid)
    {
        _selectedCharQid = qid;
        _tree            = null;
        _noResults       = false;
    }

    private async Task LoadTree()
    {
        if (string.IsNullOrEmpty(_selectedCharQid)) return;
        _loading   = true;
        _tree      = null;
        _noResults = false;
        StateHasChanged();

        try
        {
            _tree = await ApiClient.GetFamilyTreeAsync(
                UniverseQid, _selectedCharQid, _generations);
            _noResults = _tree is null || _tree.Generations.Count == 0;
        }
        finally
        {
            _loading = false;
        }
    }
}