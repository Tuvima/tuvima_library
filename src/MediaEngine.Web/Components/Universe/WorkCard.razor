@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Models.ViewDTOs

<AppMediaCard Title="@Work.Title"
              Subtitle="@Subtitle"
              ImageUrl="@Work.CoverUrl"
              FallbackIcon="@AppMediaPresentation.IconFor(Work.MediaType)"
              AccentColor="@AppMediaPresentation.AccentFor(Work.MediaType)"
              Width="@Width"
              Variant="@AppMediaPresentation.VariantFor(Work.MediaType)"
              OnSelected="OnClick">
    <Badge>
        <AppStatusBadge Text="@AppMediaPresentation.LabelFor(Work.MediaType)" Tone="AppStatusTone.Primary" />
    </Badge>
    <Meta>
        @if (!string.IsNullOrEmpty(Work.Year))
        {
            <AppStatusBadge Text="@Work.Year" />
        }
        @if (!string.IsNullOrEmpty(Work.SeriesPosition))
        {
            <AppStatusBadge Text="@($"Part {Work.SeriesPosition}")" />
        }
    </Meta>
</AppMediaCard>

@code {
    [Parameter, EditorRequired] public WorkViewModel Work { get; set; } = default!;
    [Parameter] public EventCallback<WorkViewModel> OnWorkSelected { get; set; }
    [Parameter] public int Width { get; set; } = 180;

    private string? Subtitle => Work.Author ?? Work.Narrator;

    private Task OnClick() => OnWorkSelected.InvokeAsync(Work);
}
