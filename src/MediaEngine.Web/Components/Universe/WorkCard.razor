@namespace MediaEngine.Web.Components.Universe

@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration

@* WorkCard — Individual Work-level poster card.
   Same visual pattern as PosterCard but for WorkViewModel.
   Cover art with media-type colour badge, title, author, series chip. *@

<div class="work-card" style="width: @(Width)px;" @onclick="OnClick">
    <div class="work-card-artwork" style="@ArtworkStyle">
        @if (!string.IsNullOrEmpty(Work.CoverUrl))
        {
            <img src="@Work.CoverUrl"
                 alt="@Work.Title"
                 class="work-card-img"
                 loading="lazy" />
        }
        else
        {
            <MudIcon Icon="@GetWorkIcon()"
                     Style="font-size: 48px; color: rgba(255,255,255,0.25);" />
        }

        @* Media type colour badge (top-right) *@
        <span class="work-card-type-badge"
              style="background: @MediaTypeColor;">
            @FormatMediaType(Work.MediaType)
        </span>
    </div>

    <div class="work-card-info">
        <span class="work-card-title">@Work.Title</span>

        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <span class="work-card-subtitle">@Subtitle</span>
        }

        <div class="work-card-meta">
            @if (!string.IsNullOrEmpty(Work.Year))
            {
                <span class="work-card-meta-badge">@Work.Year</span>
            }
            @if (!string.IsNullOrEmpty(Work.SeriesPosition))
            {
                <span class="work-card-meta-badge">Part @Work.SeriesPosition</span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public WorkViewModel Work { get; set; } = default!;
    [Parameter] public EventCallback<WorkViewModel> OnWorkSelected { get; set; }
    [Parameter] public int Width { get; set; } = 180;

    private string? Subtitle => Work.Author ?? Work.Narrator;

    private string MediaTypeColor =>
        UniverseMapper.ColourFor(UniverseMapper.ClassifyBucketPublic(Work.MediaType));

    private string ArtworkStyle =>
        string.IsNullOrEmpty(Work.CoverUrl)
            ? $"background: linear-gradient(135deg, {MediaTypeColor}33, #1A1A1A);"
            : string.Empty;

    private async Task OnClick() => await OnWorkSelected.InvokeAsync(Work);

    private string GetWorkIcon()
    {
        var t = Work.MediaType.ToLowerInvariant();
        if (t.Contains("video") || t.Contains("movie"))  return MudBlazor.Icons.Material.Filled.PlayCircle;
        if (t.Contains("epub") || t.Contains("book"))    return MudBlazor.Icons.Material.Filled.MenuBook;
        if (t.Contains("audio"))                           return MudBlazor.Icons.Material.Filled.Headphones;
        if (t.Contains("comic") || t.Contains("cbz") || t.Contains("cbr"))
            return MudBlazor.Icons.Material.Filled.AutoStories;
        return MudBlazor.Icons.Material.Filled.Folder;
    }

    private static string FormatMediaType(string mediaType)
    {
        var t = mediaType.ToLowerInvariant();
        if (t.Contains("epub") || t.Contains("book"))  return "Book";
        if (t.Contains("video") || t.Contains("movie")) return "Movie";
        if (t.Contains("audio") || t.Contains("m4b"))   return "Audiobook";
        if (t.Contains("comic") || t.Contains("cbz"))   return "Comic";
        if (t.Contains("mkv") || t.Contains("mp4"))     return "Video";
        return mediaType;
    }
}

<style>
    .work-card {
        flex-shrink: 0;
        cursor: pointer;
        scroll-snap-align: start;
        transition: transform 0.2s ease;
    }

    .work-card:hover {
        transform: translateY(-4px);
    }

    .work-card:hover .work-card-artwork {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.40);
    }

    .work-card-artwork {
        position: relative;
        width: 100%;
        aspect-ratio: 2 / 3;
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #1A1A1A;
        margin-bottom: 8px;
        transition: box-shadow 0.2s ease;
    }

    .work-card-type-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.58rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        padding: 3px 8px;
        border-radius: 4px;
        color: #ffffff;
        text-transform: uppercase;
        z-index: 1;
    }

    .work-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .work-card-info {
        display: flex;
        flex-direction: column;
        padding: 0 2px;
    }

    .work-card-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1.3;
        color: rgba(248, 248, 248, 0.90);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 2px;
    }

    .work-card-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 400;
        line-height: 1.3;
        color: rgba(248, 248, 248, 0.45);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 4px;
    }

    .work-card-meta {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .work-card-meta-badge {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        color: var(--app-text-muted);
        text-transform: uppercase;
    }
</style>
