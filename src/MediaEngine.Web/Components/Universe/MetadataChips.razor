@namespace MediaEngine.Web.Components.Universe
@if (Labels is not null && Labels.Count > 0)
{
    <div class="metadata-chips">
        @for (var i = 0; i < Labels.Count; i++)
        {
            var label = Labels[i];
            var qid = Qids is not null && i < Qids.Count ? Qids[i] : null;
            var hasQid = !string.IsNullOrEmpty(qid);

            <MudChip T="string"
                     Size="Size.Small"
                     Variant="Variant.Outlined"
                     Color="Color.Default"
                     Class="@($"metadata-chip {(hasQid ? "has-qid" : "")}")"
                     Text="@label" />
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<string> Labels { get; set; } = [];
    [Parameter] public IReadOnlyList<string>? Qids { get; set; }
}

<style>
    .metadata-chips {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        align-items: center;
    }

    .metadata-chip {
        font-family: var(--app-font-sans, 'Nunito', sans-serif) !important;
        font-size: 0.72rem !important;
        font-weight: 500 !important;
        letter-spacing: 0.02em;
        border-color: rgba(248, 248, 248, 0.15) !important;
        color: rgba(248, 248, 248, 0.70) !important;
    }

    .metadata-chip.has-qid {
        border-color: rgba(201, 146, 46, 0.35) !important;
        color: rgba(248, 248, 248, 0.85) !important;
        cursor: pointer;
    }

    .metadata-chip.has-qid:hover {
        border-color: var(--tl-status-warning) !important;
        background: rgba(201, 146, 46, 0.08) !important;
    }
</style>
