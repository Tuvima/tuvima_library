@namespace MediaEngine.Web.Components.Universe

@* LandscapeCard — Wide card for in-progress items with progress context.
   Used in "Continue" swimlanes showing reading/watching/listening progress. *@

<div class="landscape-card" @onclick="OnClick">
    <div class="landscape-card-cover">
        @if (!string.IsNullOrEmpty(Item.CoverUrl))
        {
            <img src="@Item.CoverUrl" alt="@Item.Title" class="landscape-card-img" loading="lazy" />
        }
        else
        {
            <div class="landscape-card-no-cover">
                <MudIcon Icon="@MudBlazor.Icons.Material.Filled.MenuBook"
                         Style="font-size: 28px; color: rgba(255,255,255,0.15);" />
            </div>
        }
        <div class="landscape-card-play-overlay">
            <MudIcon Icon="@MudBlazor.Icons.Material.Filled.PlayArrow"
                     Style="font-size: 32px; color: rgba(255,255,255,0.90);" />
        </div>
    </div>
    <div class="landscape-card-body">
        <span class="landscape-card-title">@Item.Title</span>
        @if (!string.IsNullOrEmpty(ContextLine))
        {
            <span class="landscape-card-context">@ContextLine</span>
        }
        @if (Item.Progress is > 0)
        {
            <div class="landscape-card-progress">
                <div class="landscape-card-progress-track">
                    <div class="landscape-card-progress-fill" style="width: @(Item.Progress.Value)%; --accent: @AccentColor;"></div>
                </div>
                <span class="landscape-card-progress-label">@($"{Item.Progress.Value:F0}%")</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PosterItemViewModel Item { get; set; } = default!;
    [Parameter] public EventCallback<PosterItemViewModel> OnItemSelected { get; set; }
    [Parameter] public string? Context { get; set; }

    private string AccentColor => MediaTypeAccent(Item.FormatBadge);

    private string ContextLine =>
        Context ?? Item.Subtitle ?? string.Empty;

    private async Task OnClick() => await OnItemSelected.InvokeAsync(Item);

    private static string MediaTypeAccent(string? mediaType)
    {
        if (string.IsNullOrEmpty(mediaType)) return "#C9922E";
        var t = mediaType.ToLowerInvariant();
        if (t.Contains("book") || t.Contains("epub")) return "#5DCAA5";
        if (t.Contains("audio") || t.Contains("m4b")) return "#A78BFA";
        if (t.Contains("movie") || t.Contains("video")) return "#60A5FA";
        if (t.Contains("tv")) return "#FBBF24";
        if (t.Contains("music")) return "#22D3EE";
        if (t.Contains("comic")) return "#7C4DFF";
        return "#C9922E";
    }
}

<style>
    .landscape-card {
        display: flex;
        gap: 12px;
        min-width: 320px;
        max-width: 400px;
        flex-shrink: 0;
        cursor: pointer;
        scroll-snap-align: start;
        padding: 10px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    }

    .landscape-card:hover {
        transform: translateY(-4px);
        background: rgba(255, 255, 255, 0.05);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    }

    .landscape-card-cover {
        position: relative;
        width: 110px;
        min-width: 110px;
        height: 110px;
        border-radius: 8px;
        overflow: hidden;
        background: #0D1230;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .landscape-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .landscape-card-no-cover {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.04);
    }

    .landscape-card-play-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.45);
        opacity: 0;
        transition: opacity 0.15s ease;
        border-radius: 8px;
    }

    .landscape-card:hover .landscape-card-play-overlay {
        opacity: 1;
    }

    .landscape-card-body {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 4px;
    }

    .landscape-card-title {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.88rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.90);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.3;
    }

    .landscape-card-context {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.75rem;
        font-weight: 400;
        color: rgba(248, 248, 248, 0.45);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .landscape-card-progress {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 4px;
    }

    .landscape-card-progress-track {
        flex: 1;
        height: 4px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 2px;
        overflow: hidden;
    }

    .landscape-card-progress-fill {
        height: 100%;
        background: var(--accent, #C9922E);
        border-radius: 2px;
        transition: width 0.3s ease;
    }

    .landscape-card-progress-label {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.7rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.55);
        min-width: 30px;
        text-align: right;
    }

    @@media (max-width: 768px) {
        .landscape-card {
            min-width: 280px;
            max-width: 320px;
        }

        .landscape-card-cover {
            width: 80px;
            min-width: 80px;
            height: 80px;
        }
    }
</style>
