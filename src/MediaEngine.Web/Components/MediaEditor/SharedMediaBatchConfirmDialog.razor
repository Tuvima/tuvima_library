@namespace MediaEngine.Web.Components.MediaEditor

<MudDialog Class="smb-dialog">
    <DialogContent>
        <div class="smb-shell">
            <div class="smb-title">Are you sure you want to edit information for multiple items?</div>
            <MudCheckBox T="bool"
                         @bind-Value="_dontAskAgain"
                         Label="Don't ask again"
                         Color="Color.Primary"
                         Class="smb-check" />
            <div class="smb-actions">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Class="smb-btn smb-btn--primary"
                           OnClick="Confirm">
                    Edit Items
                </MudButton>
                <MudButton Variant="Variant.Text"
                           Color="Color.Inherit"
                           Class="smb-btn smb-btn--secondary"
                           OnClick="Cancel">
                    Cancel
                </MudButton>
            </div>
        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    private bool _dontAskAgain;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}

<style>
    .smb-shell {
        background: #1b1b1d;
        color: #f4f4f4;
        min-width: min(560px, 100%);
        padding: 28px 24px 20px;
        border-radius: 14px;
        border: 1px solid var(--tl-border-subtle);
        display: flex;
        flex-direction: column;
        gap: 22px;
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
    }

    .smb-title {
        font-size: 1.65rem;
        font-weight: 650;
        line-height: 1.2;
        letter-spacing: -0.02em;
        max-width: 460px;
    }

    ::deep .smb-check .mud-checkbox-label {
        color: rgba(255,255,255,0.86);
        font-size: 0.95rem;
    }

    .smb-actions {
        display: flex;
        gap: 12px;
        border-top: 1px solid var(--tl-border-subtle);
        padding-top: 18px;
    }

    .smb-btn {
        border-radius: 8px;
        height: 40px;
        min-width: 0;
        flex: 1;
        font-size: 0.95rem;
        font-weight: 700;
        text-transform: none;
        transition: transform 0.12s ease, opacity 0.12s ease;
    }

    .smb-btn:hover {
        transform: translateY(-1px);
    }

    .smb-btn--primary {
        background: #ff445d;
        color: white;
    }

    .smb-btn--secondary {
        background: var(--tl-border-subtle);
        color: rgba(255,255,255,0.9);
    }

    @@media (max-width: 680px) {
        .smb-shell {
            min-width: 0;
            padding: 24px 18px 18px;
        }

        .smb-title {
            font-size: 1.35rem;
        }
    }
</style>
