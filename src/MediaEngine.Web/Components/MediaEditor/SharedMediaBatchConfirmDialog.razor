@namespace MediaEngine.Web.Components.MediaEditor

<AppDialog Class="smb-dialog">
    <DialogContent>
        <div class="smb-shell">
            <div class="smb-title">Are you sure you want to edit information for multiple items?</div>
            <MudCheckBox T="bool"
                         @bind-Value="_dontAskAgain"
                         Label="Don't ask again"
                         Color="Color.Primary"
                         Class="smb-check" />
            <div class="smb-actions">
                <AppButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Class="smb-btn smb-btn--primary"
                           OnClick="Confirm">
                    Edit Items
                </AppButton>
                <AppButton Variant="Variant.Text"
                           Color="Color.Inherit"
                           Class="smb-btn smb-btn--secondary"
                           OnClick="Cancel">
                    Cancel
                </AppButton>
            </div>
        </div>
    </DialogContent>
</AppDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    private bool _dontAskAgain;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}