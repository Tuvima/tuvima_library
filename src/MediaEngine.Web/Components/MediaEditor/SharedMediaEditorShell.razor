@namespace MediaEngine.Web.Components.MediaEditor
@using System.Globalization
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Forms
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Editing
@using MediaEngine.Web.Components.Shared

<NavigationLock ConfirmExternalNavigation="@IsDirty"
                OnBeforeInternalNavigation="ConfirmNavigationWithUnsavedChanges" />

<AppDialog Class="sme-dialog">
    <DialogContent>
        <div class="sme-shell">
            <div class="sme-header">
                <div class="sme-cover-cluster @(IsSingleItem ? "sme-cover-cluster--single" : "sme-cover-cluster--batch")">
                    @if (IsBatchMode)
                    {
                        <div class="sme-batch-cover-grid">
                            @foreach (var preview in Request.PreviewItems.Take(4))
                            {
                                <div class="sme-batch-cover-cell">
                                    @if (!string.IsNullOrWhiteSpace(preview.CoverUrl))
                                    {
                                        <img src="@preview.CoverUrl" alt="" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.Collections" Class="tl-u-font-size-20px tl-u-opacity-0-22" />
                                    }
                                </div>
                            }
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(CurrentCoverUrl))
                    {
                        <img src="@CurrentCoverUrl" alt="" class="sme-cover-image" />
                    }
                    else
                    {
                        <div class="sme-cover-fallback">
                            <MudIcon Icon="@Icons.Material.Outlined.Image" Class="tl-u-font-size-36px tl-u-opacity-0-2" />
                        </div>
                    }
                </div>

                <div class="sme-header-copy">
                    <div class="sme-kicker">@HeaderKicker</div>
                    @if (!string.IsNullOrWhiteSpace(BreadcrumbText))
                    {
                        <div class="sme-breadcrumb">@BreadcrumbText</div>
                    }
                    <h2 class="sme-title">@HeaderTitle</h2>
                    @if (!string.IsNullOrWhiteSpace(HeaderSubtitle))
                    {
                        <div class="sme-subtitle">@HeaderSubtitle</div>
                    }
                    @if (IsSingleItem && !string.IsNullOrWhiteSpace(_detail?.WikidataQid))
                    {
                        <a class="sme-qid-link" href="https://www.wikidata.org/wiki/@_detail!.WikidataQid" target="_blank" rel="noopener">
                            @_detail.WikidataQid
                        </a>
                    }
                </div>

                @if (CanReclassifyMediaType)
                {
                    <div class="sme-header-actions">
                        <AppMediaTypeSelect Value="@_selectedMediaType"
                                            ValueChanged="OnSelectedMediaTypeChanged" />
                        <AppButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="sme-header-type-action"
                                   Disabled="@_reclassifying"
                                   OnClick="ReclassifyMediaTypeAsync">
                            @(_reclassifying ? "Updating..." : "Change Type")
                        </AppButton>
                    </div>
                }

                <AppIconButton Icon="@Icons.Material.Outlined.Close"
                               Size="Size.Small"
                               Color="Color.Inherit"
                               Class="sme-close"
                               aria-label="Close media editor"
                               OnClick="HandleClose" />
            </div>

            @if (Request.Mode == SharedMediaEditorMode.Review)
            {
                <div class="sme-review-banner">
                    <div class="sme-review-icon" aria-hidden="true">
                        <MudIcon Icon="@Icons.Material.Outlined.PriorityHigh" Class="tl-u-font-size-22px" />
                    </div>
                    <div class="sme-review-copy">
                        <div class="sme-review-title">Needs review <span class="sme-review-text">- @_reviewSummary</span></div>
                    </div>
                </div>
            }

            @if (IsSingleItem && ScopeOptions.Count(scope => scope.ScopeId != "file") > 1)
            {
                <nav class="sme-scope-switcher" aria-label="Edit level">
                    <div class="sme-scope-switcher-copy">
                        <span class="sme-scope-picker-kicker">Editing level</span>
                        <span class="sme-scope-switcher-hint">Choose the owner before changing details, identity, or artwork.</span>
                    </div>
                    <div class="sme-scope-switcher-items">
                        @foreach (var scope in ScopeOptions.Where(scope => scope.ScopeId != "file"))
                        {
                            var isActiveScope = string.Equals(scope.ScopeId, ActiveScope?.ScopeId, StringComparison.OrdinalIgnoreCase);
                            <AppButton Variant="Variant.Text"
                                       Color="Color.Inherit"
                                       Class="@(isActiveScope ? "sme-scope-chip sme-scope-chip--active" : "sme-scope-chip")"
                                       title="@scope.ScopeSummary"
                                       OnClick="@(() => SelectScopeAsync(scope.ScopeId))">
                                <span>@scope.Label</span>
                                @if (!string.IsNullOrWhiteSpace(GetScopePickerTitle(scope)))
                                {
                                    <small>@GetScopePickerTitle(scope)</small>
                                }
                            </AppButton>
                        }
                    </div>
                </nav>
            }

            <div class="sme-workspace">
                <div class="sme-main-pane">
                    <div class="settings-admin-panel">
                        <AppTabs ActivePanelIndex="@ActiveTabIndex"
                                 ActivePanelIndexChanged="OnTabChanged"
                                 Rounded="true"
                                 Border="false"
                                 Color="Color.Primary"
                                 Elevation="0"
                                 Class="settings-tab-strip sme-tabs">
                            @foreach (var tab in Tabs)
                            {
                                <MudTabPanel Text="@tab.Label" Icon="@tab.Icon" Disabled="@IsTabDisabled(tab.Id)" />
                            }
                        </AppTabs>
                    </div>

                    @if (HasContainerReturnState)
                    {
                        <div class="sme-container-return">
                            <AppButton Variant="Variant.Text"
                                       Color="Color.Inherit"
                                       StartIcon="@Icons.Material.Outlined.ArrowBack"
                                       Class="sme-container-return-button"
                                       OnClick="ReturnToContainerEditorAsync">
                                @ContainerReturnLabel
                            </AppButton>
                            @if (!string.IsNullOrWhiteSpace(ContainerReturnContext))
                            {
                                <span>@ContainerReturnContext</span>
                            }
                        </div>
                    }

                    <div class="sme-body">
                @if (_loading)
                {
                    <div class="sme-loading">
                        <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_loadError))
                {
                    <div class="sme-empty-panel">
                        <MudIcon Icon="@Icons.Material.Outlined.CloudOff" Class="tl-u-font-size-24px tl-u-opacity-0-18" />
                        <span>@_loadError</span>
                    </div>
                }
                else if (_activeTab == "details")
                {
                    <div class="sme-details sme-details--with-summary">
                        <div class="sme-fields-pane sme-details-main">
                            <MediaEditorPanel Title="Metadata" Description="Canonical metadata and library-specific fields live together here. Override a canonical field to use a local value.">
                                <div class="sme-metadata-legend" aria-label="Metadata editing legend">
                                    <span><MudIcon Icon="@Icons.Material.Outlined.Lock" Size="Size.Small" /> Locked uses canonical data</span>
                                    <span><MudIcon Icon="@Icons.Material.Outlined.LockOpen" Size="Size.Small" Color="Color.Warning" Class="sme-metadata-legend-icon--unlock" /> Unlock edits a local value</span>
                                    <span><MudIcon Icon="@Icons.Material.Outlined.Restore" Size="Size.Small" /> Revert removes an override</span>
                                </div>

                                @foreach (var field in GetDetailsMetadataFields())
                                {
                                    <AppFormFieldRow Label="@field.Label"
                                                     Value="@GetEditableValue(field.Key)"
                                                     ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                     Placeholder="@GetPlaceholder(field)"
                                                      InputKind="@field.InputKind"
                                                      Lines="@GetFieldLineCount(field)"
                                                      Locked="@IsInlineFieldReadOnly(field.Key)"
                                                      Unlocked="@IsInlineOverrideEnabled(field.Key)"
                                                      OverrideActive="@HasActiveDisplayOverride(field.Key)"
                                                      HelpText="@GetInlineFieldHelpText(field)"
                                                      AutoFocus="@IsInlineFieldAutoFocus(field.Key)"
                                                      ActionIcon="@GetInlineFieldActionIcon(field.Key)"
                                                      ActionLabel="@GetInlineFieldActionLabel(field.Key, field.Label)"
                                                      ActionColor="@GetInlineFieldActionColor(field.Key)"
                                                      OnAction="@(() => HandleInlineFieldActionAsync(field.Key, field.Label))"
                                                      ConfirmingAction="@IsInlineFieldConfirmingRevert(field.Key)"
                                                      ConfirmLabel="@($"Remove local override for {field.Label}")"
                                                      CancelLabel="Keep override"
                                                      OnConfirmAction="@(() => ConfirmInlineFieldRevertAsync(field.Key))"
                                                      OnCancelAction="@(() => CancelInlineFieldRevert(field.Key))" />
                                }
                            </MediaEditorPanel>
                        </div>

                        <aside class="sme-details-sidebar">
                            <MediaEditorPanel Class="sme-match-info-panel">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="sme-match-info-heading">
                                    <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Color="Color.Secondary" />
                                    <div class="sme-match-info-heading-copy">
                                        <MudText Typo="Typo.subtitle1" Class="sme-match-info-title">Match Information</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Identity Summary</MudText>
                                    </div>
                                </MudStack>

                                <div class="sme-match-info-list">
                                    @foreach (var row in GetMatchInformationRows())
                                    {
                                        <div class="sme-match-info-row">
                                            <span>@row.Label</span>
                                            <strong>@row.Value</strong>
                                        </div>
                                    }
                                </div>

                                @if (GetActiveOverrideLabels().Count > 0)
                                {
                                    <div class="sme-match-override-summary">
                                        <div class="sme-match-override-kicker">Local overrides</div>
                                        <div class="sme-match-override-count">@GetActiveOverrideLabels().Count</div>
                                        <div class="sme-match-override-caption">fields overridden</div>
                                        <div class="sme-match-override-list">
                                            @foreach (var label in GetActiveOverrideLabels())
                                            {
                                                <span>@label</span>
                                            }
                                        </div>
                                    </div>
                                }

                                <MudDivider Class="sme-match-info-divider" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="sme-match-info-note">
                                    @GetMatchInformationNote()
                                </MudText>
                            </MediaEditorPanel>
                        </aside>
                    </div>
                }
                else if (_activeTab == "episodes" || _activeTab == "tracks")
                {
                    <div class="sme-content-tab">
                        @if (NavigatorRootNode is null)
                        {
                            <div class="sme-empty-panel">
                                <MudIcon Icon="@Icons.Material.Outlined.ListAlt" Class="tl-u-font-size-24px tl-u-opacity-0-18" />
                                <span>@GetContentEmptyStateText()</span>
                            </div>
                        }
                        else
                        {
                            <section class="sme-group">
                                <div class="sme-content-completion">
                                    <div>
                                        <div class="sme-group-title">@ContentTabLabel</div>
                                        <div class="sme-content-completion-title">
                                            Owned <strong>@EditorContentOwnedCount</strong> of @EditorContentTotalCount @EditorContentItemPlural
                                        </div>
                                        @if (EditorContentGroupCount > 0)
                                        {
                                            <div class="sme-content-completion-meta">@EditorContentGroupCount @EditorContentGroupPlural</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(EditorContentIncompleteHint))
                                        {
                                            <div class="sme-content-completion-hint">@EditorContentIncompleteHint</div>
                                        }
                                    </div>
                                    <div class="sme-content-completion-meter" aria-label="@($"{EditorContentOwnedCount} of {EditorContentTotalCount} {EditorContentItemPlural} owned")">
                                        <div class="sme-content-completion-bar">
                                            <AppCssElement Tag="span" Css="@($"width: {$"{EditorContentCompletionPercent:F0}%"}")"></AppCssElement>
                                        </div>
                                        <strong>@EditorContentOwnedCount / @EditorContentTotalCount</strong>
                                    </div>
                                </div>

                                @foreach (var group in EditorContentGroups)
                                {
                                    var collapsed = IsContentGroupCollapsed(group);
                                    <div class="sme-content-group @(collapsed ? "is-collapsed" : string.Empty)">
                                        <AppButton Variant="Variant.Text"
                                                   Color="Color.Inherit"
                                                   FullWidth="true"
                                                   Class="sme-content-group-header"
                                                   UserAttributes="@GetContentGroupHeaderAttributes(collapsed)"
                                                   OnClick="@(() => ToggleContentGroup(group))">
                                            <span class="sme-content-group-icon">
                                                <MudIcon Icon="@(string.Equals(_activeTab, "tracks", StringComparison.OrdinalIgnoreCase) ? Icons.Material.Outlined.Album : Icons.Material.Outlined.CalendarMonth)" Size="Size.Small" />
                                            </span>
                                            <span class="sme-content-group-copy">
                                                <span class="sme-content-group-title">@group.Title</span>
                                            </span>
                                            <span class="sme-content-group-meter">
                                                <span class="sme-content-group-progress" aria-hidden="true">
                                                    <AppCssElement Tag="span" Css="@($"width: {$"{group.CompletionPercent:F0}%"}")"></AppCssElement>
                                                </span>
                                                <strong>@group.OwnedCount / @group.TotalCount</strong>
                                            </span>
                                            <MudIcon Icon="@(collapsed ? Icons.Material.Outlined.KeyboardArrowDown : Icons.Material.Outlined.KeyboardArrowUp)" Size="Size.Small" />
                                        </AppButton>

                                        @if (!collapsed)
                                        {
                                            <div class="sme-content-list">
                                                @foreach (var entry in group.Items.Select((node, index) => (node, index)))
                                                {
                                                    var item = entry.node;
                                                    var ordinal = GetContentOrdinalLabel(item, entry.index);
                                                    var meta = GetContentRowMeta(item);
                                                    <AppButton Variant="Variant.Text"
                                                               Color="Color.Inherit"
                                                               FullWidth="true"
                                                               Disabled="@(!item.IsClickable)"
                                                               Class='@($"sme-content-item {(IsContentNodeSelected(item) ? "is-active" : string.Empty)} {(item.IsOwned ? "is-owned" : "is-missing")} {(item.IsClickable ? "is-clickable" : "is-disabled")}")'
                                                               OnClick="@(() => SelectContentItemAsync(group, item))">
                                                        <span class="sme-content-item-badge">@ordinal</span>
                                                        <span class="sme-content-item-copy">
                                                            <span class="sme-content-item-title">@item.Title</span>
                                                            @if (!string.IsNullOrWhiteSpace(meta))
                                                            {
                                                                <span class="sme-content-item-subtitle">@meta</span>
                                                            }
                                                        </span>
                                                        @if (item.TechnicalBadges.Count > 0)
                                                        {
                                                            <span class="sme-content-tech-badges">
                                                                @foreach (var badge in item.TechnicalBadges)
                                                                {
                                                                    <span>@badge</span>
                                                                }
                                                            </span>
                                                        }
                                                        @if (item.IsOwned)
                                                        {
                                                            <span class="sme-content-owned" title="Owned" aria-label="Owned">
                                                                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small" />
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="sme-content-missing">No file in library</span>
                                                        }
                                                    </AppButton>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </section>
                        }
                    </div>
                }
                else if (_activeTab == "links")
                {
                    <div class="sme-match-tab">
                        <section class="sme-match-status-strip" aria-label="Match and identity status">
                            @foreach (var row in GetMatchStatusStripRows())
                            {
                                <div class="sme-match-status-item">
                                    <span>@row.Label</span>
                                    <strong>@row.Value</strong>
                                </div>
                            }
                        </section>

                        @if (!string.IsNullOrWhiteSpace(_matchActionStatus))
                        {
                            <div class="sme-match-progress @(_matchActionPending ? "sme-match-progress--active" : string.Empty)" role="status">
                                <MudIcon Icon="@(_matchActionPending ? Icons.Material.Outlined.Sync : Icons.Material.Outlined.CheckCircle)" Class="tl-u-font-size-18px" />
                                <div>
                                    <strong>@(_matchActionPending ? "Updating identity" : "Identity update accepted")</strong>
                                    <span>@_matchActionStatus</span>
                                    @if (_matchIdentityJobId.HasValue)
                                    {
                                        <small>Pipeline job @_matchIdentityJobId</small>
                                    }
                                </div>
                            </div>
                        }

                        @if (IsSingleItem)
                        {
                            <div class="sme-match-workflow">
                                <section class="sme-match-current-panel">
                                    @{
                                        var currentRetail = BuildCurrentRetailMatchCard();
                                        var currentQid = BuildCurrentWikidataMatchCard();
                                    }
                                    <div class="sme-match-panel-heading">
                                        <div>
                                            <div class="sme-group-title">Current Identity</div>
                                            <p>Current retail and Wikidata identity state for this item.</p>
                                        </div>
                                    </div>
                                    <div class="sme-current-match-stack">
                                        <div class="sme-current-match-card">
                                            <div class="sme-current-match-art">
                                                @if (!string.IsNullOrWhiteSpace(currentRetail.CoverUrl))
                                                {
                                                    <img src="@currentRetail.CoverUrl" alt="" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Outlined.Image" Class="tl-u-font-size-28px tl-u-opacity-0-24" />
                                                }
                                            </div>
                                            <div class="sme-current-match-copy">
                                                <span class="sme-match-chip">@currentRetail.Badge</span>
                                                <h3>@currentRetail.Title</h3>
                                                @if (!string.IsNullOrWhiteSpace(currentRetail.Creator))
                                                {
                                                    <p>@currentRetail.Creator</p>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(currentRetail.Year))
                                                {
                                                    <p>@currentRetail.Year</p>
                                                }
                                                @if (currentRetail.Links.Count > 0)
                                                {
                                                    <div class="sme-current-identity-links">
                                                        @foreach (var link in currentRetail.Links)
                                                        {
                                                            <a href="@link.Url" target="_blank" rel="noopener">@link.Label</a>
                                                        }
                                                    </div>
                                                }
                                                @if (currentRetail.Chips.Count > 0)
                                                {
                                                    <div class="sme-match-chip-row">
                                                        @foreach (var chip in currentRetail.Chips)
                                                        {
                                                            <span>@chip</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <div class="sme-current-match-card sme-current-match-card--qid">
                                            <div class="sme-current-match-art sme-current-match-art--qid">
                                                <span>Q</span>
                                            </div>
                                            <div class="sme-current-match-copy">
                                                <span class="sme-match-chip sme-match-chip--qid">@currentQid.Badge</span>
                                                <h3>@currentQid.Title</h3>
                                                @if (!string.IsNullOrWhiteSpace(currentQid.Creator))
                                                {
                                                    <p>@currentQid.Creator</p>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(currentQid.Year))
                                                {
                                                    <p>@currentQid.Year</p>
                                                }
                                                @if (currentQid.Links.Count > 0)
                                                {
                                                    <div class="sme-current-identity-links">
                                                        @foreach (var link in currentQid.Links)
                                                        {
                                                            <a href="@link.Url" target="_blank" rel="noopener">@link.Label</a>
                                                        }
                                                    </div>
                                                }
                                                @if (currentQid.Chips.Count > 0)
                                                {
                                                    <div class="sme-match-chip-row">
                                                        @foreach (var chip in currentQid.Chips)
                                                        {
                                                            <span>@chip</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </section>

                                <section class="sme-match-search-panel">
                                    @if (SupportsCanonicalSearch)
                                    {
                                        <div class="sme-match-panel-heading sme-match-panel-heading--row">
                                        <div>
                                            <div class="sme-group-title">Correct Match</div>
                                            <p>@GetCanonicalSearchSubtitle()</p>
                                        </div>
                                    </div>

                                    @if (QuickSearchTargets.Count > 1)
                                    {
                                        <div class="sme-identity-targets" aria-label="Identity target">
                                            <span>Change identity for</span>
                                            @foreach (var target in QuickSearchTargets)
                                            {
                                                var isActiveTarget = string.Equals(target.Key, _canonicalTargetGroup, StringComparison.OrdinalIgnoreCase);
                                                <AppButton Variant="Variant.Text"
                                                           Color="Color.Inherit"
                                                           Class="@(isActiveTarget ? "sme-identity-target sme-identity-target--active" : "sme-identity-target")"
                                                           OnClick="@(() => SelectCanonicalTargetGroup(target.Key))">
                                                    @target.Label
                                                </AppButton>
                                            }
                                        </div>
                                    }

                                    <div class="sme-identity-impact">
                                        <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Class="tl-u-font-size-17px" />
                                        <span>@GetIdentityTargetImpactText()</span>
                                    </div>

                                        <div class="settings-admin-panel">
                                            <AppTabs ActivePanelIndex="@MatchSearchModeIndex"
                                                     ActivePanelIndexChanged="OnMatchSearchModeChanged"
                                                     Rounded="true"
                                                     Border="false"
                                                     Color="Color.Primary"
                                                     Elevation="0"
                                                     Class="settings-tab-strip sme-match-search-tabs">
                                                <MudTabPanel Text="Retail" Icon="@Icons.Material.Outlined.TravelExplore" />
                                                <MudTabPanel Text="Wikidata" Icon="@Icons.Material.Outlined.Hub" />
                                            </AppTabs>
                                        </div>

                                        <div class="sme-search-row">
                                            <AppTextField T="string"
                                                          Value="@_canonicalSearchQuery"
                                                          ValueChanged="@((string? value) => _canonicalSearchQuery = value ?? string.Empty)"
                                                          Placeholder="@($"Find {GetCanonicalTargetLabel(_canonicalTargetGroup).ToLowerInvariant()}")"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Immediate="true"
                                                          Class="sme-text-input" />
                                            <AppButton Variant="Variant.Filled"
                                                       Color="Color.Primary"
                                                       Class="sme-inline-btn sme-inline-btn--primary"
                                                       Disabled="@_searchingCanonical"
                                                       StartIcon="@Icons.Material.Outlined.Search"
                                                       OnClick="SearchCanonicalAsync">
                                                @(_searchingCanonical ? "Searching..." : IsWikidataSearchMode ? "Search Wikidata" : "Search Retail")
                                            </AppButton>
                                        </div>

                                        <div class="sme-match-results">
                                            @if (_canonicalSearchResponse is null)
                                            {
                                                <div class="sme-empty-panel">
                                                    <MudIcon Icon="@Icons.Material.Outlined.TravelExplore" Class="tl-u-font-size-24px tl-u-opacity-0-18" />
                                                    <span>@(IsWikidataSearchMode ? "Search Wikidata for a canonical identity." : "Search retail providers for a provider match.")</span>
                                                </div>
                                            }
                                            else if (_canonicalSearchResponse.LinkedCandidates.Count == 0 && _canonicalSearchResponse.RetailCandidates.Count == 0)
                                            {
                                                <div class="sme-empty-panel">
                                                    <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Class="tl-u-font-size-24px tl-u-opacity-0-18" />
                                                    <span>@(_canonicalSearchResponse.NoResultMessage ?? "No safe canonical results were found.")</span>
                                                </div>
                                            }
                                            else if (IsWikidataSearchMode)
                                            {
                                                @foreach (var candidate in _canonicalSearchResponse.LinkedCandidates)
                                                {
                                                    var candidateId = GetCandidateId(candidate);
                                                    <div class="sme-match-result-card @(IsCandidateSelected(candidateId) ? "sme-match-result-card--selected" : "")">
                                                        <AppButton Variant="Variant.Text"
                                                                   Color="Color.Inherit"
                                                                   FullWidth="true"
                                                                   Class="sme-match-result-summary"
                                                                   OnClick="@(() => SelectCandidate(candidate))">
                                                            <div class="sme-match-result-art sme-match-result-art--qid">
                                                                <span>Q</span>
                                                            </div>
                                                            <div class="sme-match-result-copy">
                                                                <div class="sme-match-result-kicker">@candidate.Qid</div>
                                                                <div class="sme-match-result-title">@candidate.Label</div>
                                                                <div class="sme-match-result-meta">@BuildWikidataCandidateSubtitle(candidate)</div>
                                                                <div class="sme-match-result-score">@FormatCandidateScore(candidate.Confidence) | @candidate.LinkStatusLabel</div>
                                                                @if (BuildCandidateChips(candidate).Count > 0)
                                                                {
                                                                    <div class="sme-match-chip-row">
                                                                        @foreach (var chip in BuildCandidateChips(candidate))
                                                                        {
                                                                            <span>@chip</span>
                                                                        }
                                                                    </div>
                                                                }
                                                            </div>
                                                            <span class="sme-candidate-badge">@(candidate.IsApplicable ? "QID" : "Suggestion")</span>
                                                        </AppButton>
                                                        @if (IsCandidateSelected(candidateId))
                                                        {
                                                            @RenderSuggestedFields(candidateId, candidate.SuggestedFields)
                                                            <AppButton Variant="Variant.Filled"
                                                                       Color="Color.Primary"
                                                                       Class="sme-inline-btn sme-inline-btn--primary"
                                                                       Disabled="@(!candidate.IsApplicable || _matchActionPending)"
                                                                       OnClick="@(() => ApplyLinkedCandidateAsync(candidate))">
                                                                @(_matchActionPending ? "Applying..." : "Use This QID")
                                                            </AppButton>
                                                        }
                                                    </div>
                                                }
                                                <div class="sme-file-actions">
                                                    <AppButton Variant="Variant.Outlined"
                                                               Color="Color.Inherit"
                                                               Class="sme-inline-btn"
                                                               Disabled="@_matchActionPending"
                                                               OnClick="MarkWikidataMissingAsync">
                                                        Mark Wikidata Missing
                                                    </AppButton>
                                                    <AppButton Variant="Variant.Outlined"
                                                               Color="Color.Inherit"
                                                               Class="sme-inline-btn"
                                                               Disabled="@_matchActionPending"
                                                               OnClick="ClearWikidataMatchAsync">
                                                        Clear QID
                                                    </AppButton>
                                                </div>
                                            }
                                            else
                                            {
                                                @foreach (var candidate in _canonicalSearchResponse.RetailCandidates)
                                                {
                                                    var candidateId = GetCandidateId(candidate);
                                                    <div class="sme-match-result-card @(IsCandidateSelected(candidateId) ? "sme-match-result-card--selected" : "")">
                                                        <AppButton Variant="Variant.Text"
                                                                   Color="Color.Inherit"
                                                                   FullWidth="true"
                                                                   Class="sme-match-result-summary"
                                                                   OnClick="@(() => SelectCandidate(candidate))">
                                                            <div class="sme-match-result-art">
                                                                @if (!string.IsNullOrWhiteSpace(candidate.CoverUrl))
                                                                {
                                                                    <img src="@candidate.CoverUrl" alt="" />
                                                                }
                                                                else
                                                                {
                                                                    <MudIcon Icon="@Icons.Material.Outlined.Image" Class="tl-u-font-size-24px tl-u-opacity-0-24" />
                                                                }
                                                            </div>
                                                            <div class="sme-match-result-copy">
                                                                <div class="sme-match-result-kicker">@candidate.ProviderName</div>
                                                                <div class="sme-match-result-title">@candidate.Title</div>
                                                                <div class="sme-match-result-meta">@BuildRetailCandidateSubtitle(candidate)</div>
                                                                <div class="sme-match-result-score">@FormatCandidateScore(GetRetailCandidateScore(candidate)) | @candidate.LinkStatusLabel</div>
                                                                @if (BuildCandidateChips(candidate).Count > 0)
                                                                {
                                                                    <div class="sme-match-chip-row">
                                                                        @foreach (var chip in BuildCandidateChips(candidate))
                                                                        {
                                                                            <span>@chip</span>
                                                                        }
                                                                    </div>
                                                                }
                                                            </div>
                                                            <span class="sme-candidate-badge">@(candidate.IsApplicable ? candidate.ProviderName : "Suggestion")</span>
                                                        </AppButton>
                                                        @if (IsCandidateSelected(candidateId))
                                                        {
                                                            @RenderSuggestedFields(candidateId, candidate.SuggestedFields)
                                                            <AppButton Variant="Variant.Filled"
                                                                       Color="Color.Primary"
                                                                       Class="sme-inline-btn sme-inline-btn--primary"
                                                                       Disabled="@(!candidate.IsApplicable || _matchActionPending)"
                                                                       OnClick="@(() => ApplyRetailCandidateAsync(candidate))">
                                                                @(_matchActionPending ? "Applying..." : "Use This Match")
                                                            </AppButton>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(CanonicalSearchUnavailableReason))
                                    {
                                        <div class="sme-search-inline-hint">@CanonicalSearchUnavailableReason</div>
                                    }
                                </section>
                            </div>
                        }
                        else
                        {
                            <div class="sme-search-inline-hint">Match and identity correction is available for one item at a time.</div>
                        }

                        @foreach (var group in GetGroupsForTab("links"))
                        {
                            <section class="sme-group">
                                <div class="sme-group-title">@group.Label</div>
                                @foreach (var field in group.Fields)
                                {
                                    <div class="sme-field-row">
                                        <label class="sme-field-label">
                                            <span>@field.Label</span>
                                            @if (field.IdentityField)
                                            {
                                                <MudTooltip Text="Used to identify the right title, edition, show, or person during matching.">
                                                    <span class="sme-field-info" aria-label="Matching help">
                                                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="tl-u-font-size-14px" />
                                                    </span>
                                                </MudTooltip>
                                            }
                                        </label>
                                        <div class="sme-field-control">
                                            @if (field.InputKind == "textarea")
                                            {
                                                <AppTextField T="string"
                                                              Value="@GetEditableValue(field.Key)"
                                                              ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                              Placeholder="@GetPlaceholder(field)"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Immediate="true"
                                                              Lines="4"
                                                              Class="sme-textarea" />
                                            }
                                            else
                                            {
                                                <AppTextField T="string"
                                                              Value="@GetEditableValue(field.Key)"
                                                              ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                              Placeholder="@GetPlaceholder(field)"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Immediate="true"
                                                              Class="sme-text-input" />
                                            }
                                        </div>
                                    </div>
                                }
                            </section>
                        }

                    </div>
                }
                else if (_activeTab == "artwork")
                {
                    <div class="sme-artwork">
                        @if (IsSingleItem)
                        {
                            <div class="sme-artwork-context">
                                <div>
                                    <strong>@(ArtworkScope?.Label ?? "Artwork") artwork</strong>
                                    <span>@GetArtworkTabExplanation()</span>
                                </div>
                                @if (ArtworkSlots.Count > 0 && GetRelatedArtworkScopeTargets().Count > 0)
                                {
                                    <div class="sme-artwork-context-actions">
                                        @foreach (var scope in GetRelatedArtworkScopeTargets())
                                        {
                                            <AppButton Variant="Variant.Outlined"
                                                       Color="Color.Inherit"
                                                       Class="sme-inline-btn"
                                                       OnClick="@(() => SelectArtworkScopeAsync(scope.ScopeId))">
                                                Open @scope.Label Artwork
                                            </AppButton>
                                        }
                                    </div>
                                }
                            </div>
                            <section class="sme-artwork-workspace">
                                <div class="sme-artwork-sidebar">
                                    <div class="sme-artwork-sidebar-title">Artwork Types</div>
                                    <div class="sme-artwork-rail" role="tablist" aria-label="Artwork types">
                                        @foreach (var slotItem in ArtworkSlots)
                                        {
                                            var isSelectedSlot = string.Equals(slotItem.AssetType, SelectedArtworkSlot?.AssetType, StringComparison.OrdinalIgnoreCase);
                                            <AppButton Variant="Variant.Text"
                                                       Color="Color.Inherit"
                                                       Class='@($"sme-artwork-rail-item {(isSelectedSlot ? "sme-artwork-rail-item--active" : string.Empty)}")'
                                                       OnClick="@(() => SelectArtworkSlot(slotItem.AssetType))">
                                                <span class="sme-artwork-rail-icon">
                                                    <MudIcon Icon="@slotItem.Icon" Class="tl-u-font-size-18px" />
                                                </span>
                                                <span class="sme-artwork-rail-copy">
                                                    <span class="sme-artwork-rail-label">@slotItem.Label</span>
                                                </span>
                                                <span class="sme-artwork-rail-badge">
                                                    <span class="sme-artwork-rail-count">@GetArtworkSlotCount(slotItem)</span>
                                                </span>
                                            </AppButton>
                                        }
                                    </div>

                                    @if (SelectedArtworkSlot is not null)
                                    {
                                        <AppButton Variant="Variant.Outlined"
                                                   Color="Color.Inherit"
                                                   Class="sme-artwork-upload-card"
                                                   title="@SelectedArtworkSlot.UploadHelp">
                                            <MudIcon Icon="@Icons.Material.Outlined.CloudUpload" Class="tl-u-font-size-30px" />
                                            <span>
                                                <strong>Upload Artwork</strong>
                                            </span>
                                            <span class="sme-art-slot-input-shell">
                                                <InputFile class="sme-art-slot-file-input"
                                                           OnChange="@((InputFileChangeEventArgs args) => HandleArtworkSelectedAsync(SelectedArtworkSlot.AssetType, args))"
                                                           accept="@GetArtworkAcceptedTypes(SelectedArtworkSlot.AssetType)" />
                                            </span>
                                        </AppButton>
                                    }
                                </div>

                                <div class="sme-artwork-main">
                                    @if (ArtworkSlots.Count == 0)
                                    {
                                        <div class="sme-artwork-readonly">
                                            <div class="sme-artwork-readonly-title">@GetArtworkReadOnlyTitle()</div>
                                            <div class="sme-artwork-readonly-text">@GetArtworkReadOnlyText()</div>
                                            @if (GetArtworkReadOnlySwitchTargets().Count > 0)
                                            {
                                                <div class="sme-artwork-readonly-actions">
                                                    @foreach (var scope in GetArtworkReadOnlySwitchTargets())
                                                    {
                                                        <AppButton Variant="Variant.Outlined"
                                                                   Color="Color.Inherit"
                                                                   Class="sme-inline-btn"
                                                                   OnClick="@(() => SelectArtworkScopeAsync(scope.ScopeId))">
                                                            Open @scope.Label
                                                        </AppButton>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (SelectedArtworkSlot is not null)
                                    {
                                        var slot = SelectedArtworkSlot;
                                        var focusedItem = LeadArtworkVariant;
                                        var rowItems = GetArtworkRowItems(slot.AssetType);

                                        <section class="sme-artwork-gallery-panel @(IsArtworkDragTarget(slot.AssetType) ? "sme-artwork-gallery-panel--drag" : "")"
                                                 @ondragenter="@(() => SetArtworkDragTarget(slot.AssetType))"
                                                 @ondragleave="@(() => ClearArtworkDragTarget(slot.AssetType))"
                                                 @ondragover:preventDefault="true"
                                                 @ondrop="@(() => ClearArtworkDragTarget(slot.AssetType))">
                                            <div class="sme-artwork-gallery-heading">
                                                <div class="sme-artwork-gallery-heading-row">
                                                    <h3>@GetArtworkGalleryTitle(slot)</h3>
                                                    @if (CanRefreshProviderArtwork(ArtworkScope))
                                                    {
                                                        <AppButton Variant="Variant.Outlined"
                                                                   Color="Color.Inherit"
                                                                   Class="sme-inline-btn sme-provider-art-refresh"
                                                                   Disabled="@IsArtworkBusy"
                                                                   OnClick="RefreshProviderArtworkAsync">
                                                            <MudIcon Icon="@Icons.Material.Outlined.Sync" Class="tl-u-font-size-18px" />
                                                            <span>@(_providerArtworkRefreshing ? "Refreshing" : "Refresh Provider Art")</span>
                                                        </AppButton>
                                                    }
                                                </div>
                                            </div>

                                            <div class="sme-artwork-gallery sme-artwork-gallery--@slot.PreviewClass">
                                                @foreach (var item in rowItems)
                                                {
                                                    var isConfirmingDelete = IsArtworkDeleteConfirming(item);

                                                    <div class="@($"sme-artwork-gallery-card sme-artwork-gallery-card--{slot.PreviewClass} {(item.IsPreferred ? "sme-artwork-gallery-card--preferred" : string.Empty)} {(item.IsPending ? "sme-artwork-gallery-card--pending" : string.Empty)} {(IsFocusedArtworkVariant(item.Key) ? "sme-artwork-gallery-card--focused" : string.Empty)}")">
                                                        <div class="sme-artwork-gallery-tile"
                                                             role="button"
                                                             tabindex="0"
                                                             aria-label="@BuildArtworkVariantHoverLabel(slot, item)"
                                                             @onclick="@(() => HandleArtworkVariantClickAsync(slot, item))">
                                                            <div class="sme-art-row-stage sme-art-row-stage--@slot.PreviewClass">
                                                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                                                {
                                                                    <img src="@item.ImageUrl" alt="@slot.Label" class="sme-art-slot-image sme-art-slot-image--@slot.ImageClass" />
                                                                }
                                                                else
                                                                {
                                                                    <div class="sme-cover-fallback sme-art-slot-placeholder"><MudIcon Icon="@slot.Icon" Class="tl-u-font-size-28px tl-u-opacity-0-18" /></div>
                                                                }
                                                                @if (item.IsPreferred)
                                                                {
                                                                    <span class="sme-artwork-gallery-check" aria-label="Primary image">
                                                                        <MudIcon Icon="@Icons.Material.Filled.Check" Class="tl-u-font-size-18px" />
                                                                    </span>
                                                                }
                                                                else if (item.IsPending)
                                                                {
                                                                    <span class="sme-artwork-gallery-check sme-artwork-gallery-check--pending" aria-label="Pending upload">
                                                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="tl-u-font-size-16px" />
                                                                    </span>
                                                                }
                                                            </div>
                                                        </div>

                                                        @if (isConfirmingDelete)
                                                        {
                                                            <div class="sme-artwork-delete-confirm" @onclick:stopPropagation="true">
                                                                <span>Delete?</span>
                                                                <AppButton Variant="Variant.Text"
                                                                           Color="Color.Inherit"
                                                                           Class="sme-artwork-confirm-button"
                                                                           OnClick="@(() => CancelArtworkDelete(item))">Cancel</AppButton>
                                                                <AppButton Variant="Variant.Filled"
                                                                           Color="Color.Error"
                                                                           Class="sme-artwork-confirm-button sme-artwork-confirm-button--danger"
                                                                           OnClick="@(() => ConfirmArtworkDeleteAsync(item))">Delete</AppButton>
                                                            </div>
                                                        }

                                                        <div class="sme-artwork-card-copy">
                                                            <div class="sme-artwork-card-meta">
                                                                <div class="sme-artwork-card-source">@GetArtworkCardSource(item)</div>
                                                                @if (!item.IsPending)
                                                                {
                                                                    <div class="sme-artwork-card-dimensions">@GetArtworkCardDimensions(slot)</div>
                                                                }
                                                            </div>
                                                            <div class="sme-artwork-card-actions" @onclick:stopPropagation="true">
                                                                <AppIconButton Icon="@Icons.Material.Outlined.ZoomIn"
                                                                               Size="Size.Small"
                                                                               Class="sme-artwork-card-action"
                                                                               Disabled="@string.IsNullOrWhiteSpace(item.ImageUrl)"
                                                                               aria-label="Preview artwork"
                                                                               OnClick="@(() => OpenArtworkZoom(slot, item))" />
                                                                @if (item.VariantId != Guid.Empty)
                                                                {
                                                                    <AppIconButton Icon="@Icons.Material.Outlined.Delete"
                                                                                   Size="Size.Small"
                                                                                   Class='@($"sme-artwork-card-action sme-artwork-card-action--danger {(isConfirmingDelete ? "sme-artwork-card-action--confirm" : string.Empty)}")'
                                                                                   aria-label="Delete artwork"
                                                                                   OnClick="@(() => DeleteArtworkVariantWithConfirmationAsync(item))" />
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>

                                            @if (_showArtworkUrlInput && string.Equals(slot.AssetType, SelectedArtworkSlot?.AssetType, StringComparison.OrdinalIgnoreCase))
                                            {
                                                <div class="sme-artwork-import-url-row">
                                                    <AppTextField T="string"
                                                                  Value="@_artworkUrlInput"
                                                                  ValueChanged="@((string? value) => _artworkUrlInput = value ?? string.Empty)"
                                                                  Placeholder="Paste an image URL"
                                                                  InputType="InputType.Url"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true"
                                                                  Class="sme-text-input" />
                                                    <div class="sme-artwork-import-url-actions">
                                                        <AppButton Variant="Variant.Outlined" Color="Color.Inherit" Class="sme-inline-btn" OnClick="ToggleArtworkUrlInput">Cancel</AppButton>
                                                        <AppButton Variant="Variant.Filled" Color="Color.Primary" Class="sme-inline-btn sme-inline-btn--primary" Disabled="@(_artworkUrlSubmitting || string.IsNullOrWhiteSpace(_artworkUrlInput))" OnClick="ApplyArtworkUrlAsync">Add</AppButton>
                                                    </div>
                                                </div>
                                            }

                                            @if (HasPendingArtwork(slot.AssetType))
                                            {
                                                <div class="sme-artwork-import-status">
                                                    <span>@GetPendingArtworkFileName(slot.AssetType)</span>
                                                    <AppButton Variant="Variant.Outlined" Color="Color.Inherit" Class="sme-inline-btn" OnClick="@(() => ClearArtworkSelection(slot.AssetType))">Clear</AppButton>
                                                    @if (HasArtworkUploadError(slot.AssetType))
                                                    {
                                                        <AppButton Variant="Variant.Outlined" Color="Color.Inherit" Class="sme-inline-btn" OnClick="@(() => RetryArtworkUploadAsync(slot.AssetType))">Retry Upload</AppButton>
                                                    }
                                                </div>
                                            }

                                            @if (HasArtworkUploadError(slot.AssetType))
                                            {
                                                <div class="sme-artwork-import-error">@GetArtworkUploadError(slot.AssetType)</div>
                                            }

                                            @if (focusedItem?.IsPending == true)
                                            {
                                                <div class="sme-artwork-selection-actions">
                                                    <AppButton Variant="Variant.Outlined" Color="Color.Inherit" Class="sme-inline-btn" OnClick="@(() => ClearArtworkSelection(slot.AssetType))">Cancel Pending</AppButton>
                                                </div>
                                            }

                                            <div class="sme-artwork-disclaimer">
                                                <MudIcon Icon="@Icons.Material.Outlined.Info" Class="tl-u-font-size-22px" />
                                                <div class="sme-artwork-disclaimer-title">About Artwork Types</div>
                                                <div class="sme-artwork-disclaimer-copy">
                                                    Different artwork types serve different purposes. Poster/Cover is the primary display image.
                                                    <a href="https://tuvima.github.io/tuvima_library/reference/artwork-types/"
                                                       target="_blank"
                                                       rel="noopener">
                                                        Learn more about artwork types
                                                        <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Class="tl-u-font-size-14px" />
                                                    </a>
                                                </div>
                                            </div>
                                        </section>

                                    }
                                </div>
                            </section>

                            <MediaEditorArtworkLightbox IsOpen="@IsArtworkZoomOpen"
                                                        ImageUrl="@ZoomArtworkVariant?.ImageUrl"
                                                        Label="@ZoomArtworkSlot?.Label"
                                                        Summary="@(ZoomArtworkSlot is not null && ZoomArtworkVariant is not null ? BuildArtworkVariantSummary(ZoomArtworkSlot, ZoomArtworkVariant) : null)"
                                                        PreviewClass="@ZoomArtworkSlot?.PreviewClass"
                                                        ImageClass="@ZoomArtworkSlot?.ImageClass"
                                                        OnClose="CloseArtworkZoom" />
                        }
                        else
                        {
                            <div class="sme-empty-panel">
                                <MudIcon Icon="@Icons.Material.Outlined.Collections" Class="tl-u-font-size-24px tl-u-opacity-0-18" />
                                <span>Artwork changes are single-item only in this pass.</span>
                            </div>
                        }
                    </div>
                }
                else if (_activeTab == "options")
                {
                    var groups = GetAdditionalOptionsGroups().ToList();
                    <div class="sme-fields-pane sme-fields-pane--single">
                        <MediaEditorLocalOptions GenreValue="@GetEditableValue("genre")"
                                                 GenreValueChanged="@((string? value) => OnFieldInput("genre", value))"
                                                 TagValue="@GetEditableValue("custom_tags")"
                                                 TagValueChanged="@((string? value) => OnFieldInput("custom_tags", value))"
                                                 RatingValue="@GetEditableValue("rating")"
                                                 RatingValueChanged="@((string? value) => OnFieldInput("rating", value))"
                                                 CommentValue="@GetEditableValue("comment")"
                                                 CommentValueChanged="@((string? value) => OnFieldInput("comment", value))" />

                        @if (groups.Count == 0)
                        {
                            <div class="sme-options-note">Additional item options will appear here when available.</div>
                        }
                        else
                        {
                            @foreach (var group in groups)
                            {
                                <section class="sme-group">
                                    <div class="sme-group-title">@group.Label</div>
                                    @foreach (var field in group.Fields)
                                    {
                                        <div class="sme-field-row">
                                            <label class="sme-field-label">@field.Label</label>
                                            <div class="sme-field-control">
                                                @if (field.InputKind == "textarea")
                                                {
                                                    <AppTextField T="string"
                                                                  Value="@GetEditableValue(field.Key)"
                                                                  ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                                  Placeholder="@GetPlaceholder(field)"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true"
                                                                  Lines="4"
                                                                  Class="sme-textarea" />
                                                }
                                                else
                                                {
                                                    <AppTextField T="string"
                                                                  Value="@GetEditableValue(field.Key)"
                                                                  ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                                  Placeholder="@GetPlaceholder(field)"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true"
                                                                  Class="sme-text-input" />
                                                }
                                            </div>
                                        </div>
                                    }
                                </section>
                            }
                        }
                    </div>
                }
                else if (_activeTab == "file")
                {
                    <div class="sme-file-tab">
                        @if (!IsSingleItem || _detail is null)
                        {
                            <div class="sme-empty-panel">
                                <MudIcon Icon="@Icons.Material.Outlined.InsertDriveFile" Class="tl-u-font-size-24px tl-u-opacity-0-18" />
                                <span>File inspection is available for a single item.</span>
                            </div>
                        }
                        else
                        {
                            <section class="sme-group">
                                <div class="sme-group-title">File</div>
                                <div class="sme-readonly-row"><span>Name</span><strong>@(_detail.FileName ?? "Unknown")</strong></div>
                                <div class="sme-readonly-row"><span>Path</span><strong>@(_detail.FilePath ?? "Unknown")</strong></div>
                                <div class="sme-readonly-row"><span>Status</span><strong>@_detail.Status</strong></div>
                                <div class="sme-readonly-row"><span>Pipeline</span><strong>@_detail.PipelineStep</strong></div>
                                @if (!string.IsNullOrWhiteSpace(_detail.ReviewTrigger))
                                {
                                    <div class="sme-readonly-row"><span>Review trigger</span><strong>@_detail.ReviewTrigger</strong></div>
                                }
                            </section>

                        }
                    </div>
                }
                else if (_activeTab == "history")
                {
                    <div class="sme-file-tab sme-history-tab">
                        <MediaEditorPanel Title="Change History"
                                          Description="A timeline of identity, metadata, artwork, and system changes for this item.">
                            @if (_history.Count == 0)
                            {
                                <div class="sme-empty-panel">
                                    <MudIcon Icon="@Icons.Material.Outlined.History" Class="tl-u-font-size-24px tl-u-opacity-0-18" />
                                    <span>No recent history is available.</span>
                                </div>
                            }
                            else
                            {
                                <div class="sme-history-list">
                                    @foreach (var entry in _history)
                                    {
                                        <div class="sme-history-row sme-history-row--timeline">
                                            <div class="sme-history-title">@entry.Label</div>
                                            @if (!string.IsNullOrWhiteSpace(entry.Detail))
                                            {
                                                <div class="sme-history-detail">@entry.Detail</div>
                                            }
                                            <div class="sme-history-time">@entry.OccurredAt.LocalDateTime.ToString("g", CultureInfo.CurrentCulture)</div>
                                        </div>
                                    }
                                </div>
                            }
                        </MediaEditorPanel>
                    </div>
                }
                    </div>
                </div>
            </div>

            @if (ShouldShowEditorFooter)
            {
            <div class="sme-footer">
                @if (_confirmDiscard)
                {
                    <div class="sme-discard-warning">Discard unsaved changes?</div>
                    <AppButton Variant="Variant.Text"
                               Color="Color.Inherit"
                               Class="sme-footer-btn sme-footer-btn--ghost"
                               OnClick="@(() => _confirmDiscard = false)">
                        Keep Editing
                    </AppButton>
                    <AppButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Class="sme-footer-btn sme-footer-btn--danger"
                               OnClick="DiscardAndClose">
                        Discard
                    </AppButton>
                }
                else
                {
                    <div class="sme-footer-spacer"></div>
                    @if (_pendingMembershipPreview is not null)
                    {
                        <div class="sme-footer-note">@_pendingMembershipPreview.Message</div>
                        <AppButton Variant="Variant.Text"
                                   Color="Color.Inherit"
                                   Class="sme-footer-btn sme-footer-btn--ghost"
                                   OnClick="@(() => _pendingMembershipPreview = null)">
                            Keep Editing
                        </AppButton>
                        <AppButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="sme-footer-btn sme-footer-btn--primary"
                                   OnClick="ConfirmMembershipMoveAsync"
                                   Disabled="@_saving">
                            Save and Move
                        </AppButton>
                    }
                    else if (IsDirty)
                    {
                        <AppButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="sme-footer-btn sme-footer-btn--primary"
                                   OnClick="SaveAsync"
                                   Disabled="@_saving">
                            @if (_saving)
                            {
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="tl-u-color-inherit tl-u-width-14px tl-u-height-14px" />
                            }
                            @GetDirtySaveLabel()
                        </AppButton>
                    }
                    else if (Request.Mode == SharedMediaEditorMode.Review)
                    {
                        <AppButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="sme-footer-btn sme-footer-btn--primary"
                                   OnClick="ResolveReviewWithoutChangesAsync"
                                   Disabled="@_saving">
                            @(_saving ? "Resolving..." : GetResolveReviewLabel())
                        </AppButton>
                    }
                }
            </div>
            }
        </div>
    </DialogContent>
</AppDialog>

@code {
    private RenderFragment RenderSuggestedFields(string candidateId, Dictionary<string, string> fields) => @<div>
        @if (fields.Count > 0)
        {
            <div class="sme-suggested-title">Optional fields</div>
            @foreach (var field in fields.OrderBy(x => x.Key, StringComparer.OrdinalIgnoreCase))
            {
                <MudCheckBox T="bool"
                             Value="@IsSuggestedFieldSelected(candidateId, field.Key)"
                             ValueChanged="@((bool value) => ToggleSuggestedField(candidateId, field.Key, value))"
                             Color="Color.Primary"
                             Dense="true"
                             Class="sme-suggested-field">
                    @field.Key: @field.Value
                </MudCheckBox>
            }
        }
    </div>;
}
