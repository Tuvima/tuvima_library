@namespace MediaEngine.Web.Components.MediaEditor
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Editing

<MudDialog Class="sme-dialog">
    <DialogContent>
        <div class="sme-shell">
            <div class="sme-header">
                <div class="sme-cover-cluster @(IsSingleItem ? "sme-cover-cluster--single" : "sme-cover-cluster--batch")">
                    @if (IsBatchMode)
                    {
                        <div class="sme-batch-cover-grid">
                            @foreach (var preview in Request.PreviewItems.Take(4))
                            {
                                <div class="sme-batch-cover-cell">
                                    @if (!string.IsNullOrWhiteSpace(preview.CoverUrl))
                                    {
                                        <img src="@preview.CoverUrl" alt="" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.Collections" Style="font-size: 20px; opacity: 0.22;" />
                                    }
                                </div>
                            }
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(CurrentCoverUrl))
                    {
                        <img src="@CurrentCoverUrl" alt="" class="sme-cover-image" />
                    }
                    else
                    {
                        <div class="sme-cover-fallback">
                            <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 36px; opacity: 0.2;" />
                        </div>
                    }
                </div>

                <div class="sme-header-copy">
                    <div class="sme-kicker">@HeaderKicker</div>
                    @if (!string.IsNullOrWhiteSpace(BreadcrumbText))
                    {
                        <div class="sme-breadcrumb">@BreadcrumbText</div>
                    }
                    <h2 class="sme-title">@HeaderTitle</h2>
                    @if (!string.IsNullOrWhiteSpace(HeaderSubtitle))
                    {
                        <div class="sme-subtitle">@HeaderSubtitle</div>
                    }
                    @if (IsSingleItem && !string.IsNullOrWhiteSpace(_detail?.WikidataQid))
                    {
                        <a class="sme-qid-link" href="https://www.wikidata.org/wiki/@_detail!.WikidataQid" target="_blank" rel="noopener">
                            @_detail.WikidataQid
                        </a>
                    }
                </div>

                <MudIconButton Icon="@Icons.Material.Outlined.Close"
                               Size="Size.Small"
                               Color="Color.Inherit"
                               Class="sme-close"
                               OnClick="HandleClose" />
            </div>

            @if (Request.Mode == SharedMediaEditorMode.Review)
            {
                <div class="sme-review-banner">
                    <div class="sme-review-copy">
                        <div class="sme-review-title">Needs review</div>
                        <div class="sme-review-text">@_reviewSummary</div>
                    </div>
                    @if (CanReclassifyMediaType)
                    {
                        <div class="sme-review-reclassify">
                            <MudSelect T="string"
                                       Value="_selectedMediaType"
                                       ValueChanged="OnSelectedMediaTypeChanged"
                                       Variant="Variant.Outlined"
                                       Dense="true"
                                       Class="sme-review-select">
                                @foreach (var mediaType in ReclassifyMediaTypes)
                                {
                                    <MudSelectItem T="string" Value="@mediaType">@mediaType</MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Class="sme-review-action"
                                       Disabled="@_reclassifying"
                                       OnClick="ReclassifyMediaTypeAsync">
                                @(_reclassifying ? "Updating..." : "Change type")
                            </MudButton>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_canonicalTargetGroup))
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="sme-review-action"
                                   OnClick="@(() => _activeTab = "links")">
                            Find @GetCanonicalTargetLabel(_canonicalTargetGroup)
                        </MudButton>
                    }
                </div>
            }

            <div class="sme-workspace">
                <div class="sme-main-pane">
                    <MudTabs ActivePanelIndex="@ActiveTabIndex"
                             ActivePanelIndexChanged="OnTabChanged"
                         Rounded="false"
                             Border="false"
                             Elevation="0"
                             Class="sme-tabs">
                        @foreach (var tab in Tabs)
                        {
                            <MudTabPanel Text="@tab.Label" Disabled="@IsTabDisabled(tab.Id)" />
                        }
                    </MudTabs>

                    @if (IsSingleItem)
                    {
                        <div class="sme-selection-bar">
                            <div class="sme-selection-copy">
                                <div class="sme-selection-kicker">@CurrentTargetLabel</div>
                                <div class="sme-selection-title">@CurrentTargetTitle</div>
                                @if (!string.IsNullOrWhiteSpace(CurrentTargetSubtitle))
                                {
                                    <div class="sme-selection-subtitle">@CurrentTargetSubtitle</div>
                                }
                            </div>
                            @if (SupportsDeleteAction)
                            {
                                <div class="sme-selection-actions">
                                    @if (_showQuarantineConfirm)
                                    {
                                        <div class="sme-delete-confirm">
                                            <div class="sme-delete-confirm-text">@GetDeleteConfirmationText()</div>
                                            <div class="sme-delete-confirm-actions">
                                                <MudButton Variant="Variant.Filled"
                                                           Color="Color.Error"
                                                           Class="sme-inline-btn sme-inline-btn--danger"
                                                           Disabled="@_quarantining"
                                                           OnClick="QuarantineCurrentSelectionAsync">
                                                    @(_quarantining ? "Quarantining..." : "Quarantine")
                                                </MudButton>
                                                <MudButton Variant="Variant.Text"
                                                           Color="Color.Inherit"
                                                           Class="sme-inline-btn"
                                                           OnClick="ToggleQuarantineConfirmAsync">
                                                    Cancel
                                                </MudButton>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Error"
                                                   Class="sme-inline-btn sme-inline-btn--danger"
                                                   OnClick="ToggleQuarantineConfirmAsync">
                                            Delete
                                        </MudButton>
                                    }
                                </div>
                            }
                        </div>
                    }

                    <div class="sme-body">
                @if (_loading)
                {
                    <div class="sme-loading">
                        <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                    </div>
                }
                else if (_activeTab == "details")
                {
                    <div class="sme-details sme-details--single">
                        <div class="sme-fields-pane sme-fields-pane--single">

                            @foreach (var group in GetGroupsForTab("details"))
                            {
                                <section class="sme-group">
                                    <div class="sme-group-title">@group.Label</div>
                                    @foreach (var field in group.Fields)
                                    {
                                        var isDisplayOverride = IsDisplayOverrideKey(field.Key);
                                        var isLocked = IsFieldLocked(field.Key) && !isDisplayOverride;
                                        <div class="sme-field-row @(isLocked ? "sme-field-row--locked" : string.Empty)">
                                            <label class="sme-field-label">
                                                <span>@field.Label</span>
                                                @if (isLocked)
                                                {
                                                    <MudTooltip Text="Linked identity field. Edit it here or use Links to search provider matches.">
                                                        <span class="sme-field-info sme-field-info--locked" aria-label="Locked field">
                                                            <MudIcon Icon="@Icons.Material.Outlined.Lock" Style="font-size: 14px;" />
                                                        </span>
                                                    </MudTooltip>
                                                }
                                                else if (field.IdentityField)
                                                {
                                                    <MudTooltip Text="Used to identify the right title, edition, show, or person during matching.">
                                                        <span class="sme-field-info" aria-label="Matching help">
                                                            <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size: 14px;" />
                                                        </span>
                                                    </MudTooltip>
                                                }
                                            </label>
                                            <div class="sme-field-control">
                                                @if (field.InputKind == "textarea")
                                                {
                                                    <MudTextField T="string"
                                                                  Value="@GetEditableValue(field.Key)"
                                                                  ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                                  Placeholder="@GetPlaceholder(field)"
                                                                  Disabled="@isLocked"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true"
                                                                  Lines="4"
                                                                  Class="@($"sme-textarea {(isLocked ? "sme-textarea--locked" : string.Empty)}")" />
                                                }
                                                else
                                                {
                                                    <MudTextField T="string"
                                                                  Value="@GetEditableValue(field.Key)"
                                                                  ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                                  Placeholder="@GetPlaceholder(field)"
                                                                  Disabled="@isLocked"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true"
                                                                  Class="@($"sme-text-input {(isLocked ? "sme-text-input--locked" : string.Empty)}")" />
                                                }
                                                @if (isLocked)
                                                {
                                                    <div class="sme-field-hint">Edit here directly, or use Links to search and relink the canonical match.</div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </section>
                            }

                            @if (GetDisplayDetailOverrideKeys().Count > 0)
                            {
                                <section class="sme-group">
                                    <div class="sme-group-title">Display Overrides</div>
                                    @foreach (var key in GetDisplayDetailOverrideKeys())
                                    {
                                        <div class="sme-field-row">
                                            <label class="sme-field-label">
                                                <span>@GetDisplayOverrideLabel(key)</span>
                                                <span class="sme-field-chip">Alias</span>
                                            </label>
                                            <div class="sme-field-control">
                                                <MudTextField T="string"
                                                              Value="@GetEditableValue(key)"
                                                              ValueChanged="@((string? value) => OnFieldInput(key, value))"
                                                              Placeholder="@GetDisplayOverrideHint(key)"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Immediate="true"
                                                              Class="sme-text-input" />
                                                <div class="sme-field-hint">@GetDisplayOverrideHint(key)</div>
                                            </div>
                                        </div>
                                    }
                                </section>
                            }

                            @if (IsSingleItem && GetPlacementFieldKeysForActiveScope().Count > 0)
                            {
                                <section class="sme-group">
                                    <div class="sme-group-title">Placement & Identity</div>
                                    @foreach (var key in GetPlacementFieldKeysForActiveScope())
                                    {
                                        var field = _schema.Groups
                                            .SelectMany(candidateGroup => candidateGroup.Fields)
                                            .FirstOrDefault(candidate => string.Equals(candidate.Key, key, StringComparison.OrdinalIgnoreCase));
                                        if (field is null)
                                        {
                                            continue;
                                        }

                                        <div class="sme-field-row">
                                            <label class="sme-field-label">
                                                <span>@field.Label</span>
                                                <MudTooltip Text="Type to update this field. Existing library matches appear first, with provider search available inline when needed.">
                                                    <span class="sme-field-info" aria-label="Placement help">
                                                        <MudIcon Icon="@Icons.Material.Outlined.ManageSearch" Style="font-size: 14px;" />
                                                    </span>
                                                </MudTooltip>
                                            </label>
                                            <div class="sme-field-control">
                                                <div class="sme-membership-input-row">
                                                    <MudTextField T="string"
                                                                  Value="@GetEditableValue(field.Key)"
                                                                  ValueChanged="@(async (string? value) => await OnMembershipFieldInputAsync(field.Key, value))"
                                                                  Placeholder="@GetPlaceholder(field)"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true"
                                                                  Class="sme-text-input" />
                                                    @if (CanSearchRetailMembership(field.Key))
                                                    {
                                                        <MudButton Variant="Variant.Outlined"
                                                                   Color="Color.Inherit"
                                                                   Class="sme-inline-btn"
                                                                   OnClick="@(() => SearchRetailMembershipAsync(field.Key))">
                                                            Search
                                                        </MudButton>
                                                    }
                                                </div>

                                                @if (GetMembershipSuggestions(field.Key).Count > 0)
                                                {
                                                    <div class="sme-membership-suggestions">
                                                        @foreach (var suggestion in GetMembershipSuggestions(field.Key))
                                                        {
                                                            <MudButton Variant="Variant.Outlined"
                                                                       Color="Color.Inherit"
                                                                       FullWidth="true"
                                                                       Class="sme-membership-suggestion"
                                                                       OnClick="@(() => ApplyMembershipSuggestionAsync(field.Key, suggestion))">
                                                                <span class="sme-membership-suggestion-label">@suggestion.Label</span>
                                                                @if (!string.IsNullOrWhiteSpace(suggestion.Subtitle))
                                                                {
                                                                    <span class="sme-membership-suggestion-subtitle">@suggestion.Subtitle</span>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(GetMembershipSuggestionMeta(suggestion)))
                                                                {
                                                                    <span class="sme-membership-suggestion-subtitle">@GetMembershipSuggestionMeta(suggestion)</span>
                                                                }
                                                            </MudButton>
                                                        }
                                                    </div>
                                                }

                                                <div class="sme-field-hint">If the right album or artist is already in your library, select it here. If not, use Search to look up provider results without leaving Details.</div>
                                            </div>
                                        </div>
                                    }
                                </section>
                            }
                        </div>

                    </div>
                }
                else if (_activeTab == "episodes" || _activeTab == "tracks")
                {
                    <div class="sme-content-tab">
                        @if (NavigatorRootNode is null)
                        {
                            <div class="sme-empty-panel">
                                <MudIcon Icon="@Icons.Material.Outlined.ListAlt" Style="font-size: 24px; opacity: 0.18;" />
                                <span>@GetContentEmptyStateText()</span>
                            </div>
                        }
                        else
                        {
                            <section class="sme-group">
                                <div class="sme-group-title">@ContentTabLabel</div>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Inherit"
                                           FullWidth="true"
                                           Class="@($"sme-content-root {(IsContentNodeSelected(NavigatorRootNode) ? "is-active" : string.Empty)}")"
                                           OnClick="@(() => SelectNavigatorNodeAsync(NavigatorRootNode.EntityId))">
                                    <span class="sme-content-root-label">@NavigatorRootNode.Label</span>
                                    <span class="sme-content-root-title">@NavigatorRootNode.Title</span>
                                    @if (!string.IsNullOrWhiteSpace(NavigatorRootNode.Subtitle))
                                    {
                                        <span class="sme-content-root-subtitle">@NavigatorRootNode.Subtitle</span>
                                    }
                                </MudButton>

                                @if (string.Equals(_activeTab, "episodes", StringComparison.OrdinalIgnoreCase))
                                {
                                    foreach (var season in ContentRootChildren)
                                    {
                                        var episodes = GetNavigatorChildren(season.NodeId);
                                        <div class="sme-content-group">
                                            <div class="sme-content-group-header">
                                                <div class="sme-content-group-title">@season.Title</div>
                                                @if (!string.IsNullOrWhiteSpace(season.Subtitle))
                                                {
                                                    <div class="sme-content-group-subtitle">@season.Subtitle</div>
                                                }
                                            </div>
                                            <div class="sme-content-list">
                                                @foreach (var episode in episodes)
                                                {
                                                    <MudButton Variant="Variant.Outlined"
                                                               Color="Color.Inherit"
                                                               FullWidth="true"
                                                               Class="@($"sme-content-item {(IsContentNodeSelected(episode) ? "is-active" : string.Empty)}")"
                                                               OnClick="@(() => SelectNavigatorNodeAsync(episode.EntityId))">
                                                        <span class="sme-content-item-copy">
                                                            <span class="sme-content-item-title">@episode.Title</span>
                                                            @if (!string.IsNullOrWhiteSpace(episode.Subtitle))
                                                            {
                                                                <span class="sme-content-item-subtitle">@episode.Subtitle</span>
                                                            }
                                                        </span>
                                                        @if (!string.IsNullOrWhiteSpace(episode.OrdinalLabel))
                                                        {
                                                            <span class="sme-content-item-badge">@episode.OrdinalLabel</span>
                                                        }
                                                    </MudButton>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="sme-content-list">
                                        @foreach (var track in ContentRootChildren)
                                        {
                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Inherit"
                                                       FullWidth="true"
                                                       Class="@($"sme-content-item {(IsContentNodeSelected(track) ? "is-active" : string.Empty)}")"
                                                       OnClick="@(() => SelectNavigatorNodeAsync(track.EntityId))">
                                                <span class="sme-content-item-copy">
                                                    <span class="sme-content-item-title">@track.Title</span>
                                                    @if (!string.IsNullOrWhiteSpace(track.Subtitle))
                                                    {
                                                        <span class="sme-content-item-subtitle">@track.Subtitle</span>
                                                    }
                                                </span>
                                                @if (!string.IsNullOrWhiteSpace(track.OrdinalLabel))
                                                {
                                                    <span class="sme-content-item-badge">@track.OrdinalLabel</span>
                                                }
                                            </MudButton>
                                        }
                                    </div>
                                }
                            </section>
                        }
                    </div>
                }
                else if (_activeTab == "links")
                {
                    <div class="sme-file-tab">
                        @if (_editorContext?.IdentitySummary is not null)
                        {
                            var identity = _editorContext.IdentitySummary;
                            <section class="sme-group">
                                <div class="sme-group-title">Current Links</div>
                                <div class="sme-readonly-row"><span>Retail Match</span><strong>@(identity.ProviderName ?? identity.MatchSource ?? "Not linked")</strong></div>
                                <div class="sme-readonly-row"><span>Provider ID</span><strong>@(identity.ProviderItemId ?? "Not linked")</strong></div>
                                <div class="sme-readonly-row"><span>Canonical QID</span><strong>@(identity.WikidataQid ?? "Pending")</strong></div>
                                <div class="sme-readonly-row"><span>Match Status</span><strong>@(identity.MatchLevel ?? identity.WikidataStatus ?? "Unresolved")</strong></div>
                                <div class="sme-readonly-row"><span>Universe / Series</span><strong>@(identity.UniverseName ?? "None")</strong></div>
                                @if (!string.IsNullOrWhiteSpace(GetUniverseExploreUrl()))
                                {
                                    <div class="sme-file-actions">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Inherit"
                                                   Class="sme-inline-btn"
                                                   Href="@GetUniverseExploreUrl()">
                                            Open graph
                                        </MudButton>
                                    </div>
                                }
                            </section>
                        }

                        @if (IsSingleItem)
                        {
                            @if (SupportsCanonicalSearch)
                            {
                                <section class="sme-group">
                                    <div class="sme-group-title">Canonical Search</div>
                                    <MudTabs ActivePanelIndex="@CanonicalTargetIndex"
                                             ActivePanelIndexChanged="OnCanonicalTargetChanged"
                             Rounded="false"
                                             Border="false"
                                             Elevation="0"
                                             Class="sme-search-targets">
                                        @foreach (var target in QuickSearchTargets)
                                        {
                                            <MudTabPanel Text="@target.Label" />
                                        }
                                    </MudTabs>

                                    <div class="sme-search-row">
                                        <MudTextField T="string"
                                                      Value="@_canonicalSearchQuery"
                                                      ValueChanged="@((string? value) => _canonicalSearchQuery = value ?? string.Empty)"
                                                      Placeholder="@($"Find {GetCanonicalTargetLabel(_canonicalTargetGroup).ToLowerInvariant()}")"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true"
                                                      Class="sme-text-input" />
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Class="sme-inline-btn sme-inline-btn--primary"
                                                   Disabled="@_searchingCanonical"
                                                   OnClick="SearchCanonicalAsync">
                                            @(_searchingCanonical ? "Searching..." : "Quick Search")
                                        </MudButton>
                                    </div>
                                </section>

                                <section class="sme-group">
                                    <div class="sme-group-title">Search Results</div>
                                    @if (_canonicalSearchResponse is null)
                                    {
                                        <div class="sme-empty-panel">
                                            <MudIcon Icon="@Icons.Material.Outlined.TravelExplore" Style="font-size: 24px; opacity: 0.18;" />
                                            <span>Search for a canonical @GetCanonicalTargetLabel(_canonicalTargetGroup).ToLowerInvariant().</span>
                                        </div>
                                    }
                                    else if (_canonicalSearchResponse.LinkedCandidates.Count == 0 && _canonicalSearchResponse.RetailCandidates.Count == 0)
                                    {
                                        <div class="sme-empty-panel">
                                            <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Style="font-size: 24px; opacity: 0.18;" />
                                            <span>@(_canonicalSearchResponse.NoResultMessage ?? "No safe canonical results were found.")</span>
                                        </div>
                                    }
                                    else
                                    {
                                        @if (_canonicalSearchResponse.LinkedCandidates.Count > 0)
                                        {
                                            <div class="sme-result-section-label">Linked results</div>
                                                @foreach (var candidate in _canonicalSearchResponse.LinkedCandidates)
                                                {
                                                    <div class="sme-candidate @(IsCandidateSelected(GetCandidateId(candidate)) ? "sme-candidate--selected" : "")">
                                                    <MudButton Variant="Variant.Outlined"
                                                               Color="Color.Inherit"
                                                               FullWidth="true"
                                                               Class="sme-candidate-summary"
                                                               OnClick="@(() => SelectCandidate(candidate))">
                                                        <div class="sme-candidate-copy">
                                                            <div class="sme-candidate-title">@candidate.Label</div>
                                                            @if (!string.IsNullOrWhiteSpace(candidate.Description))
                                                            {
                                                                <div class="sme-candidate-description">@candidate.Description</div>
                                                            }
                                                            <div class="sme-candidate-meta">@candidate.LinkStatusLabel</div>
                                                        </div>
                                                        <span class="sme-candidate-badge">@(candidate.IsApplicable ? candidate.LinkState : "Suggestion")</span>
                                                    </MudButton>
                                                    @if (IsCandidateSelected(GetCandidateId(candidate)))
                                                    {
                                                        @RenderSuggestedFields(GetCandidateId(candidate), candidate.SuggestedFields)
                                                        <MudButton Variant="Variant.Filled"
                                                                   Color="Color.Primary"
                                                                   Class="sme-inline-btn sme-inline-btn--primary"
                                                                   Disabled="@(!candidate.IsApplicable)"
                                                                   OnClick="@(() => ApplyLinkedCandidateAsync(candidate))">
                                                            Apply linked candidate
                                                        </MudButton>
                                                    }
                                                </div>
                                            }
                                        }

                                        @if (_canonicalSearchResponse.RetailCandidates.Count > 0)
                                        {
                                            <div class="sme-result-section-label">Provider results</div>
                                                @foreach (var candidate in _canonicalSearchResponse.RetailCandidates)
                                                {
                                                    <div class="sme-candidate @(IsCandidateSelected(GetCandidateId(candidate)) ? "sme-candidate--selected" : "")">
                                                    <MudButton Variant="Variant.Outlined"
                                                               Color="Color.Inherit"
                                                               FullWidth="true"
                                                               Class="sme-candidate-summary"
                                                               OnClick="@(() => SelectCandidate(candidate))">
                                                        <div class="sme-candidate-copy">
                                                            <div class="sme-candidate-title">@candidate.Title</div>
                                                            <div class="sme-candidate-description">@BuildRetailCandidateSubtitle(candidate)</div>
                                                            <div class="sme-candidate-meta">@candidate.LinkStatusLabel</div>
                                                        </div>
                                                        <span class="sme-candidate-badge">@(candidate.IsApplicable ? candidate.ProviderName : "Suggestion")</span>
                                                    </MudButton>
                                                    @if (IsCandidateSelected(GetCandidateId(candidate)))
                                                    {
                                                        @RenderSuggestedFields(GetCandidateId(candidate), candidate.SuggestedFields)
                                                        <MudButton Variant="Variant.Filled"
                                                                   Color="Color.Primary"
                                                                   Class="sme-inline-btn sme-inline-btn--primary"
                                                                   Disabled="@(!candidate.IsApplicable)"
                                                                   OnClick="@(() => ApplyRetailCandidateAsync(candidate))">
                                                            Apply provider candidate
                                                        </MudButton>
                                                    }
                                                </div>
                                            }
                                        }
                                    }
                                </section>
                            }
                            else if (!string.IsNullOrWhiteSpace(CanonicalSearchUnavailableReason))
                            {
                                <div class="sme-search-inline-hint">@CanonicalSearchUnavailableReason</div>
                            }
                        }

                        @foreach (var group in GetGroupsForTab("links"))
                        {
                            <section class="sme-group">
                                <div class="sme-group-title">@group.Label</div>
                                @foreach (var field in group.Fields)
                                {
                                    <div class="sme-field-row">
                                        <label class="sme-field-label">
                                            <span>@field.Label</span>
                                            @if (field.IdentityField)
                                            {
                                                <MudTooltip Text="Used to identify the right title, edition, show, or person during matching.">
                                                    <span class="sme-field-info" aria-label="Matching help">
                                                        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size: 14px;" />
                                                    </span>
                                                </MudTooltip>
                                            }
                                        </label>
                                        <div class="sme-field-control">
                                            @if (field.InputKind == "textarea")
                                            {
                                                <MudTextField T="string"
                                                              Value="@GetEditableValue(field.Key)"
                                                              ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                              Placeholder="@GetPlaceholder(field)"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Immediate="true"
                                                              Lines="4"
                                                              Class="sme-textarea" />
                                            }
                                            else
                                            {
                                                <MudTextField T="string"
                                                              Value="@GetEditableValue(field.Key)"
                                                              ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                              Placeholder="@GetPlaceholder(field)"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Immediate="true"
                                                              Class="sme-text-input" />
                                            }
                                        </div>
                                    </div>
                                }
                            </section>
                        }

                    </div>
                }
                else if (_activeTab == "artwork")
                {
                    <div class="sme-artwork">
                        @if (IsSingleItem)
                        {
                            <section class="sme-artwork-workspace">
                                <div class="sme-artwork-rail" role="tablist" aria-label="Artwork types">
                                    @foreach (var slotItem in ArtworkSlots)
                                    {
                                        var isSelectedSlot = string.Equals(slotItem.AssetType, SelectedArtworkSlot?.AssetType, StringComparison.OrdinalIgnoreCase);
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Inherit"
                                                   Class="@($"sme-artwork-rail-item {(isSelectedSlot ? "sme-artwork-rail-item--active" : string.Empty)}")"
                                                   OnClick="@(() => SelectArtworkSlot(slotItem.AssetType))">
                                            <span class="sme-artwork-rail-icon">
                                                <MudIcon Icon="@slotItem.Icon" Style="font-size: 18px;" />
                                            </span>
                                            <span class="sme-artwork-rail-copy">
                                                <span class="sme-artwork-rail-label">@slotItem.Label</span>
                                                <span class="sme-artwork-rail-meta">@slotItem.Description</span>
                                            </span>
                                            <span class="sme-artwork-rail-badge">
                                                <span class="sme-artwork-rail-count">@GetArtworkSlotCount(slotItem)</span>
                                            </span>
                                        </MudButton>
                                    }
                                </div>

                                <div class="sme-artwork-main">
                                    @if (ArtworkSlots.Count == 0)
                                    {
                                        <div class="sme-artwork-readonly">
                                            <div class="sme-artwork-readonly-title">@GetArtworkReadOnlyTitle()</div>
                                            <div class="sme-artwork-readonly-text">@GetArtworkReadOnlyText()</div>
                                            @if (GetArtworkReadOnlySwitchTargets().Count > 0)
                                            {
                                                <div class="sme-artwork-readonly-actions">
                                                    @foreach (var scope in GetArtworkReadOnlySwitchTargets())
                                                    {
                                                        <MudButton Variant="Variant.Outlined"
                                                                   Color="Color.Inherit"
                                                                   Class="sme-inline-btn"
                                                                   OnClick="@(() => SelectArtworkScopeAsync(scope.ScopeId))">
                                                            Open @scope.Label
                                                        </MudButton>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (SelectedArtworkSlot is not null)
                                    {
                                        var slot = SelectedArtworkSlot;
                                        var focusedItem = LeadArtworkVariant;
                                        var rowItems = GetArtworkRowItems(slot.AssetType);

                                        <section class="sme-artwork-gallery-panel @(IsArtworkDragTarget(slot.AssetType) ? "sme-artwork-gallery-panel--drag" : "")"
                                                 @ondragenter="@(() => SetArtworkDragTarget(slot.AssetType))"
                                                 @ondragleave="@(() => ClearArtworkDragTarget(slot.AssetType))"
                                                 @ondragover:preventDefault="true"
                                                 @ondrop="@(() => ClearArtworkDragTarget(slot.AssetType))">
                                            <div class="sme-artwork-gallery sme-artwork-gallery--@slot.PreviewClass">
                                                <div class="sme-artwork-add-entry">
                                                    <MudButton Variant="Variant.Outlined"
                                                               Color="Color.Inherit"
                                                               Class="@($"sme-artwork-gallery-add {(IsArtworkAddMenuOpen(slot.AssetType) ? "sme-artwork-gallery-add--open" : string.Empty)}")"
                                                               aria-label="@slot.UploadHelp"
                                                               OnClick="@(() => ToggleArtworkAddMenu(slot.AssetType))">
                                                        <div class="sme-art-row-stage sme-art-row-stage--@slot.PreviewClass">
                                                            <div class="sme-cover-fallback sme-art-slot-placeholder sme-artwork-add-stage-copy">
                                                                <span class="sme-art-add-symbol">+</span>
                                                                <span class="sme-artwork-add-copy">Add @slot.Label</span>
                                                            </div>
                                                        </div>
                                                    </MudButton>

                                                    @if (IsArtworkAddMenuOpen(slot.AssetType))
                                                    {
                                                        <div class="sme-artwork-add-menu">
                                                            <label class="sme-art-slot-action sme-art-slot-action--primary" title="@slot.UploadHelp">
                                                                <span>Upload file</span>
                                                                <span class="sme-art-slot-input-shell">
                                                                    <InputFile class="sme-art-slot-file-input"
                                                                               OnChange="@((InputFileChangeEventArgs args) => HandleArtworkSelectedAsync(slot.AssetType, args))"
                                                                               accept="@GetArtworkAcceptedTypes(slot.AssetType)" />
                                                                </span>
                                                            </label>
                                                            <MudButton Variant="Variant.Outlined"
                                                                       Color="Color.Inherit"
                                                                       Class="sme-art-slot-action sme-art-slot-action--ghost"
                                                                       Disabled="@_artworkUrlSubmitting"
                                                                       OnClick="@(() => OpenArtworkUrlInput(slot.AssetType))">
                                                                Enter URL
                                                            </MudButton>
                                                        </div>
                                                    }
                                                </div>

                                                @foreach (var item in rowItems)
                                                {
                                                    <div class="sme-artwork-gallery-card">
                                                        <MudButton Variant="Variant.Outlined"
                                                                   Color="Color.Inherit"
                                                                   Class="@($"sme-artwork-gallery-tile {(item.IsPreferred ? "sme-artwork-gallery-tile--preferred" : string.Empty)} {(item.IsPending ? "sme-artwork-gallery-tile--pending" : string.Empty)} {(IsFocusedArtworkVariant(item.Key) ? "sme-artwork-gallery-tile--focused" : string.Empty)}")"
                                                                   aria-label="@BuildArtworkVariantHoverLabel(slot, item)"
                                                                   OnClick="@(() => HandleArtworkVariantClickAsync(slot, item))">
                                                            <div class="sme-art-row-stage sme-art-row-stage--@slot.PreviewClass">
                                                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                                                {
                                                                    <img src="@item.ImageUrl" alt="@slot.Label" class="sme-art-slot-image sme-art-slot-image--@slot.ImageClass" />
                                                                }
                                                                else
                                                                {
                                                                    <div class="sme-cover-fallback sme-art-slot-placeholder"><MudIcon Icon="@slot.Icon" Style="font-size: 28px; opacity: 0.18;" /></div>
                                                                }
                                                                @if (item.IsPreferred)
                                                                {
                                                                    <span class="sme-artwork-gallery-check" aria-label="Primary image">
                                                                        <MudIcon Icon="@Icons.Material.Filled.Check" Style="font-size: 18px;" />
                                                                    </span>
                                                                }
                                                                else if (item.IsPending)
                                                                {
                                                                    <span class="sme-artwork-gallery-check sme-artwork-gallery-check--pending" aria-label="Pending upload">
                                                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Style="font-size: 16px;" />
                                                                    </span>
                                                                }
                                                            </div>
                                                        </MudButton>

                                                        <div class="sme-artwork-gallery-popout">
                                                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                                            {
                                                                <MudIconButton Icon="@Icons.Material.Outlined.ZoomIn"
                                                                               Size="Size.Small"
                                                                               Class="sme-artwork-gallery-icon-button"
                                                                               aria-label="View full size"
                                                                               OnClick="@(() => OpenArtworkZoom(slot, item))" />
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>

                                            @if (_showArtworkUrlInput && string.Equals(slot.AssetType, SelectedArtworkSlot?.AssetType, StringComparison.OrdinalIgnoreCase))
                                            {
                                                <div class="sme-artwork-import-url-row">
                                                    <MudTextField T="string"
                                                                  Value="@_artworkUrlInput"
                                                                  ValueChanged="@((string? value) => _artworkUrlInput = value ?? string.Empty)"
                                                                  Placeholder="Paste an image URL"
                                                                  InputType="InputType.Url"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true"
                                                                  Class="sme-text-input" />
                                                    <div class="sme-artwork-import-url-actions">
                                                        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Class="sme-inline-btn" OnClick="ToggleArtworkUrlInput">Cancel</MudButton>
                                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="sme-inline-btn sme-inline-btn--primary" Disabled="@(_artworkUrlSubmitting || string.IsNullOrWhiteSpace(_artworkUrlInput))" OnClick="ApplyArtworkUrlAsync">Add</MudButton>
                                                    </div>
                                                </div>
                                            }

                                            @if (HasPendingArtwork(slot.AssetType))
                                            {
                                                <div class="sme-artwork-import-status">
                                                    <span>@GetPendingArtworkFileName(slot.AssetType)</span>
                                                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Class="sme-inline-btn" OnClick="@(() => ClearArtworkSelection(slot.AssetType))">Clear</MudButton>
                                                    @if (HasArtworkUploadError(slot.AssetType))
                                                    {
                                                        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Class="sme-inline-btn" OnClick="@(() => RetryArtworkUploadAsync(slot.AssetType))">Retry Upload</MudButton>
                                                    }
                                                </div>
                                            }

                                            @if (HasArtworkUploadError(slot.AssetType))
                                            {
                                                <div class="sme-artwork-import-error">@GetArtworkUploadError(slot.AssetType)</div>
                                            }

                                            @if (focusedItem is not null)
                                            {
                                                <div class="sme-artwork-selection-actions">
                                                    @if (focusedItem.IsPending)
                                                    {
                                                        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Class="sme-inline-btn" OnClick="@(() => ClearArtworkSelection(slot.AssetType))">Cancel Pending</MudButton>
                                                    }
                                                    else if (focusedItem.CanDelete && focusedItem.VariantId != Guid.Empty)
                                                    {
                                                        <MudButton Variant="Variant.Filled" Color="Color.Error" Class="sme-inline-btn sme-inline-btn--danger" OnClick="@(() => DeleteArtworkVariantAsync(focusedItem.VariantId))">Delete</MudButton>
                                                    }
                                                </div>
                                            }
                                        </section>

                                    }
                                </div>
                            </section>

                            @if (IsArtworkZoomOpen && ZoomArtworkSlot is not null && ZoomArtworkVariant is not null)
                            {
                                <div class="sme-art-lightbox" @onclick="CloseArtworkZoom">
                                    <div class="sme-art-lightbox-panel" @onclick:stopPropagation="true">
                                        <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                                       Size="Size.Small"
                                                       Class="sme-art-lightbox-close"
                                                       Color="Color.Inherit"
                                                       OnClick="CloseArtworkZoom" />
                                        <div class="sme-art-lightbox-copy">
                                            <div class="sme-art-lightbox-title">@ZoomArtworkSlot.Label</div>
                                            <div class="sme-art-lightbox-text">@BuildArtworkVariantSummary(ZoomArtworkSlot, ZoomArtworkVariant)</div>
                                        </div>
                                        <div class="sme-art-lightbox-frame sme-art-lightbox-frame--@ZoomArtworkSlot.PreviewClass">
                                            @if (!string.IsNullOrWhiteSpace(ZoomArtworkVariant.ImageUrl))
                                            {
                                                <img src="@ZoomArtworkVariant.ImageUrl" alt="@ZoomArtworkSlot.Label" class="sme-art-lightbox-image sme-art-lightbox-image--@ZoomArtworkSlot.ImageClass" />
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="sme-empty-panel">
                                <MudIcon Icon="@Icons.Material.Outlined.Collections" Style="font-size: 24px; opacity: 0.18;" />
                                <span>Artwork changes are single-item only in this pass.</span>
                            </div>
                        }
                    </div>
                }
                else if (_activeTab == "options")
                {
                    var groups = GetGroupsForTab("options").ToList();
                    <div class="sme-fields-pane sme-fields-pane--single">
                        @if (groups.Count == 0)
                        {
                            <div class="sme-empty-panel">
                                <MudIcon Icon="@Icons.Material.Outlined.Tune" Style="font-size: 24px; opacity: 0.18;" />
                                <span>No options are available for this selection.</span>
                            </div>
                        }
                        else
                        {
                            @foreach (var group in groups)
                            {
                                <section class="sme-group">
                                    <div class="sme-group-title">@group.Label</div>
                                    @foreach (var field in group.Fields)
                                    {
                                        <div class="sme-field-row">
                                            <label class="sme-field-label">@field.Label</label>
                                            <div class="sme-field-control">
                                                @if (field.InputKind == "textarea")
                                                {
                                                    <MudTextField T="string"
                                                                  Value="@GetEditableValue(field.Key)"
                                                                  ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                                  Placeholder="@GetPlaceholder(field)"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true"
                                                                  Lines="4"
                                                                  Class="sme-textarea" />
                                                }
                                                else
                                                {
                                                    <MudTextField T="string"
                                                                  Value="@GetEditableValue(field.Key)"
                                                                  ValueChanged="@((string? value) => OnFieldInput(field.Key, value))"
                                                                  Placeholder="@GetPlaceholder(field)"
                                                                  Variant="Variant.Outlined"
                                                                  Margin="Margin.Dense"
                                                                  Immediate="true"
                                                                  Class="sme-text-input" />
                                                }
                                            </div>
                                        </div>
                                    }
                                </section>
                            }
                        }
                    </div>
                }
                else if (_activeTab == "file")
                {
                    <div class="sme-file-tab">
                        @if (!IsSingleItem || _detail is null)
                        {
                            <div class="sme-empty-panel">
                                <MudIcon Icon="@Icons.Material.Outlined.InsertDriveFile" Style="font-size: 24px; opacity: 0.18;" />
                                <span>File inspection is available for a single item.</span>
                            </div>
                        }
                        else
                        {
                            <section class="sme-group">
                                <div class="sme-group-title">File</div>
                                <div class="sme-readonly-row"><span>Name</span><strong>@(_detail.FileName ?? "Unknown")</strong></div>
                                <div class="sme-readonly-row"><span>Path</span><strong>@(_detail.FilePath ?? "Unknown")</strong></div>
                                <div class="sme-readonly-row"><span>Status</span><strong>@_detail.Status</strong></div>
                                <div class="sme-readonly-row"><span>Pipeline</span><strong>@_detail.PipelineStep</strong></div>
                                @if (!string.IsNullOrWhiteSpace(_detail.ReviewTrigger))
                                {
                                    <div class="sme-readonly-row"><span>Review trigger</span><strong>@_detail.ReviewTrigger</strong></div>
                                }
                            </section>

                            <section class="sme-group">
                                <div class="sme-group-title">Canonical Snapshot</div>
                                @foreach (var field in _canonicalValues.OrderBy(x => x.Key, StringComparer.OrdinalIgnoreCase).Take(18))
                                {
                                    <div class="sme-readonly-row">
                                        <span>@field.Key</span>
                                        <strong>@field.Value</strong>
                                    </div>
                                }
                            </section>

                            <section class="sme-group">
                                <div class="sme-group-title">Recent History</div>
                                @if (_history.Count == 0)
                                {
                                    <div class="sme-field-hint">No recent history is available.</div>
                                }
                                else
                                {
                                    @foreach (var entry in _history.Take(10))
                                    {
                                        <div class="sme-history-row">
                                            <div class="sme-history-title">@entry.Label</div>
                                            @if (!string.IsNullOrWhiteSpace(entry.Detail))
                                            {
                                                <div class="sme-history-detail">@entry.Detail</div>
                                            }
                                            <div class="sme-history-time">@entry.OccurredAt.LocalDateTime.ToString("g", CultureInfo.CurrentCulture)</div>
                                        </div>
                                    }
                                }
                            </section>
                        }
                    </div>
                }
                    </div>
                </div>
            </div>

            <div class="sme-footer">
                @if (_confirmDiscard)
                {
                    <div class="sme-discard-warning">Discard unsaved changes?</div>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Inherit"
                               Class="sme-footer-btn sme-footer-btn--ghost"
                               OnClick="@(() => _confirmDiscard = false)">
                        Keep Editing
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Class="sme-footer-btn sme-footer-btn--danger"
                               OnClick="DiscardAndClose">
                        Discard
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Text"
                               Color="Color.Inherit"
                               Class="sme-footer-btn sme-footer-btn--ghost"
                               OnClick="HandleClose">
                        @(IsDirty ? "Cancel" : "Close")
                    </MudButton>
                    <div class="sme-footer-spacer"></div>
                    @if (_pendingMembershipPreview is not null)
                    {
                        <div class="sme-footer-note">@_pendingMembershipPreview.Message</div>
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Inherit"
                                   Class="sme-footer-btn sme-footer-btn--ghost"
                                   OnClick="@(() => _pendingMembershipPreview = null)">
                            Keep Editing
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="sme-footer-btn sme-footer-btn--primary"
                                   OnClick="ConfirmMembershipMoveAsync"
                                   Disabled="@_saving">
                            Save and Move
                        </MudButton>
                    }
                    else if (IsDirty)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="sme-footer-btn sme-footer-btn--primary"
                                   OnClick="SaveAsync"
                                   Disabled="@_saving">
                            @if (_saving)
                            {
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: inherit; width: 14px; height: 14px;" />
                            }
                            @(IsBatchMode ? $"Apply ({Request.EntityIds.Count})" : "Save")
                        </MudButton>
                    }
                }
            </div>
        </div>
    </DialogContent>
</MudDialog>

@code {
    private RenderFragment RenderSuggestedFields(string candidateId, Dictionary<string, string> fields) => @<div>
        @if (fields.Count > 0)
        {
            <div class="sme-suggested-title">Optional fields</div>
            @foreach (var field in fields.OrderBy(x => x.Key, StringComparer.OrdinalIgnoreCase))
            {
                <MudCheckBox T="bool"
                             Value="@IsSuggestedFieldSelected(candidateId, field.Key)"
                             ValueChanged="@((bool value) => ToggleSuggestedField(candidateId, field.Key, value))"
                             Color="Color.Primary"
                             Dense="true"
                             Class="sme-suggested-field">
                    @field.Key: @field.Value
                </MudCheckBox>
            }
        }
    </div>;
}
