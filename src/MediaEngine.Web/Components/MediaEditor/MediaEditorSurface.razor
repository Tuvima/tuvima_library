@namespace MediaEngine.Web.Components.MediaEditor

@if (Inline)
{
    <section class="sme-inline-surface @(HeroConstrained ? "sme-inline-surface--hero" : string.Empty)" aria-label="Media editor">
        @ChildContent
    </section>
}
else
{
    <AppDialog Class="sme-dialog">
        <DialogContent>
            @ChildContent
        </DialogContent>
    </AppDialog>
}

@code {
    [Parameter] public bool Inline { get; set; }
    [Parameter] public bool HeroConstrained { get; set; }
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }
}
