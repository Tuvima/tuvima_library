@namespace MediaEngine.Web.Components.Watch
@using MediaEngine.Web.Models.ViewDTOs

@if (VisibleSpecs.Count > 0)
{
    <div class="watch-specs">
        @foreach (var spec in VisibleSpecs)
        {
            <div class="watch-specs__chip">
                <div class="watch-specs__label">@spec.Label</div>
                <div class="watch-specs__value">@spec.Value</div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public PlaybackTechnicalSummaryViewModel? Summary { get; set; }

    private List<(string Label, string Value)> VisibleSpecs
    {
        get
        {
            var specs = new List<(string Label, string Value)>();
            var video = PlaybackTechnicalSummaryDisplay.VideoChip(Summary);
            var audio = PlaybackTechnicalSummaryDisplay.AudioChip(Summary);
            var subtitles = PlaybackTechnicalSummaryDisplay.SubtitleChip(Summary);

            if (!string.IsNullOrWhiteSpace(video))
                specs.Add(("Video", video));
            if (!string.IsNullOrWhiteSpace(audio))
                specs.Add(("Audio", audio));
            if (!string.IsNullOrWhiteSpace(subtitles))
                specs.Add(("Subtitles", subtitles));

            return specs;
        }
    }
}