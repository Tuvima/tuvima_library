@using MediaEngine.Web.Models.ViewDTOs

<div class="vro-backdrop" @onclick="OnClose">
    <div class="vro-modal" @onclick:stopPropagation="true">

        @* ── Header ── *@
        <div class="vro-header">
            <div>
                <h2 class="vro-header-title">
                    <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 20px; color: #EF9F27;" />
                    Resolve Signal Conflict
                </h2>
                <p class="vro-header-sub">
                    Manual Resolution Required for: <span class="vro-header-item">@Item.Title</span>
                </p>
            </div>
            <button class="vro-close-btn" @onclick="OnClose">
                <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 24px;" />
            </button>
        </div>

        @* ── Content split ── *@
        <div class="vro-content">

            @* Left panel: File Discovery *@
            <div class="vro-left">
                <section class="vro-section">
                    <h3 class="vro-section-title">File Discovery</h3>
                    <div class="vro-discovery-card">
                        <div class="vro-field">
                            <span class="vro-field-label">RAW FILE HINT</span>
                            <p class="vro-field-value vro-field-mono">@(Item.FileName ?? "Unknown")</p>
                        </div>
                    </div>
                </section>

                <section class="vro-section">
                    <h3 class="vro-section-title">Conflict Detail</h3>
                    <div class="vro-conflict-card">
                        <p class="vro-conflict-text">@GetConflictMessage()</p>
                    </div>
                </section>
            </div>

            @* Right panel: Lookup Tools *@
            <div class="vro-right">
                <div class="vro-lookup-placeholder">
                    <MudIcon Icon="@Icons.Material.Outlined.Search"
                             Style="font-size: 64px; color: rgba(255,255,255,0.08); margin-bottom: 16px;" />
                    <p class="vro-lookup-label">Manual Lookup Tools</p>
                    <div class="vro-provider-buttons">
                        @foreach (var provider in VaultHelpers.GetProviderButtons(Item.MediaType))
                        {
                            <div class="vro-provider-chip">@provider</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* ── Bottom bar ── *@
        <div class="vro-footer">
            <button class="vro-reject-btn" @onclick="HandleReject">
                <MudIcon Icon="@Icons.Material.Outlined.Cancel" Style="font-size: 16px;" />
                Reject &amp; Quarantine
            </button>
            <div class="vro-footer-right">
                <button class="vro-cancel-btn" @onclick="OnClose">Cancel</button>
                <button class="vro-apply-btn" @onclick="HandleApply">Apply Resolution</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public VaultItemViewModel Item { get; set; } = default!;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Guid> OnReject { get; set; }
    [Parameter] public EventCallback<Guid> OnApply { get; set; }

    private string GetConflictMessage()
    {
        if (Item.Stage1.State == VaultStageState.Failed)
            return "Stage 1 failed: No consistent metadata or extraction signal found.";
        if (Item.Stage2.State is VaultStageState.Failed or VaultStageState.Warning)
            return "Stage 2 failed: Wikidata bridge is blocked by low-confidence person signals.";
        return "Pipeline could not automatically resolve this item. Manual intervention required.";
    }

    private async Task HandleReject() => await OnReject.InvokeAsync(Item.EntityId);
    private async Task HandleApply() => await OnApply.InvokeAsync(Item.EntityId);
}

<style>
    .vro-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1300;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .vro-modal {
        background: #14181d;
        width: 100%;
        max-width: 1024px;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        max-height: 85vh;
        animation: vro-zoom-in 0.2s ease;
    }

    @@keyframes vro-zoom-in {
        from { transform: scale(0.95); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }

    /* ── Header ── */
    .vro-header {
        padding: 24px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(255, 255, 255, 0.015);
    }

    .vro-header-title {
        font-size: 20px;
        font-weight: 900;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0;
    }

    .vro-header-sub {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.35);
        margin: 4px 0 0;
    }

    .vro-header-item {
        color: rgba(255, 255, 255, 0.7);
        font-weight: 700;
    }

    .vro-close-btn {
        padding: 8px;
        border-radius: 50%;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.35);
        cursor: pointer;
        transition: all 0.15s;
    }

    .vro-close-btn:hover {
        background: rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.7);
    }

    /* ── Content ── */
    .vro-content {
        flex: 1;
        display: flex;
        overflow: hidden;
    }

    .vro-left {
        width: 35%;
        border-right: 1px solid rgba(255, 255, 255, 0.06);
        padding: 32px;
        overflow-y: auto;
        background: rgba(0, 0, 0, 0.15);
    }

    .vro-right {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.08);
    }

    /* ── Sections ── */
    .vro-section {
        margin-bottom: 32px;
    }

    .vro-section-title {
        font-size: 10px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.35);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin: 0 0 16px;
    }

    .vro-discovery-card {
        background: #0d0f12;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        padding: 16px;
    }

    .vro-field {
        margin-bottom: 0;
    }

    .vro-field-label {
        font-size: 9px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.25);
        text-transform: uppercase;
        display: block;
        margin-bottom: 4px;
    }

    .vro-field-value {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.7);
        margin: 0;
        line-height: 1.5;
        word-break: break-all;
    }

    .vro-field-mono {
        font-family: monospace;
        color: rgba(96, 165, 250, 0.8);
    }

    .vro-conflict-card {
        background: rgba(239, 159, 39, 0.05);
        border: 1px solid rgba(239, 159, 39, 0.2);
        border-radius: 16px;
        padding: 16px;
    }

    .vro-conflict-text {
        font-size: 12px;
        color: rgba(239, 159, 39, 0.7);
        font-style: italic;
        line-height: 1.5;
        margin: 0;
    }

    /* ── Lookup placeholder ── */
    .vro-lookup-placeholder {
        text-align: center;
        opacity: 0.3;
    }

    .vro-lookup-label {
        font-size: 14px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.5);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin: 0 0 24px;
    }

    .vro-provider-buttons {
        display: flex;
        gap: 16px;
        justify-content: center;
    }

    .vro-provider-chip {
        padding: 8px 16px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        font-size: 10px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
    }

    /* ── Footer ── */
    .vro-footer {
        padding: 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        background: #0d0f12;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }

    .vro-reject-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        background: transparent;
        border: none;
        color: rgba(226, 75, 74, 0.8);
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        cursor: pointer;
        padding: 8px 16px;
        border-radius: 8px;
        transition: all 0.15s;
    }

    .vro-reject-btn:hover {
        color: #E24B4A;
        background: rgba(226, 75, 74, 0.1);
    }

    .vro-footer-right {
        display: flex;
        gap: 12px;
    }

    .vro-cancel-btn {
        padding: 10px 24px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: transparent;
        color: rgba(255, 255, 255, 0.35);
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vro-cancel-btn:hover {
        background: rgba(255, 255, 255, 0.04);
    }

    .vro-apply-btn {
        padding: 10px 32px;
        border-radius: 12px;
        border: none;
        background: rgba(93, 202, 165, 0.85);
        color: #fff;
        font-size: 12px;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.15s;
        box-shadow: 0 4px 12px rgba(93, 202, 165, 0.1);
    }

    .vro-apply-btn:hover {
        background: rgba(93, 202, 165, 1);
    }

    /* ── Mobile ── */
    @@media (max-width: 768px) {
        .vro-backdrop {
            padding: 0;
            align-items: flex-end;
        }

        .vro-modal {
            max-width: 100%;
            max-height: 95vh;
            border-radius: 24px 24px 0 0;
        }

        .vro-content {
            flex-direction: column;
        }

        .vro-left {
            width: 100%;
            border-right: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            padding: 20px;
        }

        .vro-right {
            padding: 20px;
        }

        .vro-footer {
            flex-direction: column;
            gap: 12px;
        }

        .vro-footer-right {
            width: 100%;
        }

        .vro-cancel-btn, .vro-apply-btn {
            flex: 1;
        }
    }
</style>
