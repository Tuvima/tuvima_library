@using MediaEngine.Web.Models.ViewDTOs
@inject IStringLocalizer<SharedStrings> L

<div class="vault-status-pill">
    <div class="vault-status-badge" style="color: @_color; background: @_bgColor; border-color: @_borderColor;">
        <MudIcon Icon="@_icon" Style="font-size: 12px;" />
        <span>@_label</span>
    </div>
    @if (Status == VaultStatus.Quarantined && QuarantineDays.HasValue)
    {
        <span class="vault-quarantine-timer">@L["StatusPill_DeletesIn", QuarantineDays]</span>
    }
</div>

@code {
    [Parameter, EditorRequired] public VaultStatus Status { get; set; }
    [Parameter] public int? QuarantineDays { get; set; }

    private string _color => Status switch
    {
        VaultStatus.Verified => "#5DCAA5",
        VaultStatus.Provisional => "#3B82F6",
        VaultStatus.NeedsReview => "#EF9F27",
        VaultStatus.Quarantined => "rgba(255,255,255,0.5)",
        VaultStatus.WaitingForProvider => "#38BDF8",
        _ => "rgba(255,255,255,0.3)",
    };

    private string _bgColor => Status switch
    {
        VaultStatus.Verified => "rgba(93,202,165,0.05)",
        VaultStatus.Provisional => "rgba(59,130,246,0.05)",
        VaultStatus.NeedsReview => "rgba(239,159,39,0.05)",
        VaultStatus.Quarantined => "rgba(255,255,255,0.03)",
        VaultStatus.WaitingForProvider => "rgba(56,189,248,0.05)",
        _ => "rgba(255,255,255,0.02)",
    };

    private string _borderColor => Status switch
    {
        VaultStatus.Verified => "rgba(93,202,165,0.2)",
        VaultStatus.Provisional => "rgba(59,130,246,0.2)",
        VaultStatus.NeedsReview => "rgba(239,159,39,0.2)",
        VaultStatus.Quarantined => "rgba(255,255,255,0.1)",
        VaultStatus.WaitingForProvider => "rgba(56,189,248,0.2)",
        _ => "rgba(255,255,255,0.05)",
    };

    private string _icon => Status switch
    {
        VaultStatus.Verified => Icons.Material.Filled.Check,
        VaultStatus.Provisional => Icons.Material.Filled.Info,
        VaultStatus.NeedsReview => Icons.Material.Filled.Warning,
        VaultStatus.Quarantined => Icons.Material.Filled.Close,
        VaultStatus.WaitingForProvider => Icons.Material.Filled.Schedule,
        _ => Icons.Material.Filled.HelpOutline,
    };

    private string _label => Status switch
    {
        VaultStatus.Verified => L["StatusPill_Verified"],
        VaultStatus.Provisional => L["StatusPill_Provisional"],
        VaultStatus.NeedsReview => L["StatusPill_NeedsReview"],
        VaultStatus.Quarantined => L["StatusPill_Quarantined"],
        VaultStatus.WaitingForProvider => L["StatusPill_WaitingForProvider"],
        _ => L["StatusPill_Unknown"],
    };
}

<style>
    .vault-status-pill {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .vault-status-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 10px;
        font-weight: 800;
        padding: 4px 8px;
        border-radius: 6px;
        border: 1px solid;
        white-space: nowrap;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .vault-quarantine-timer {
        font-size: 9px;
        font-weight: 700;
        color: rgba(226, 75, 74, 0.7);
    }
</style>
