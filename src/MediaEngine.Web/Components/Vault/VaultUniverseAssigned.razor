@namespace MediaEngine.Web.Components.Vault
@using MediaEngine.Web.Models.ViewDTOs

@inject IEngineApiClient ApiClient

@if (_loading)
{
    <div class="vua-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.15);" />
    </div>
}
else if (_universes.Count == 0)
{
    <div class="vua-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">No universes assigned yet.</p>
    </div>
}
else
{
    <div class="vua-count">@_universes.Count universes</div>
    <div class="vua-list">
        @foreach (var universe in _universes)
        {
            <div class="vua-row" @onclick="() => OnRowClicked.InvokeAsync(universe.Id)">
                <div class="vua-row-icon">
                    <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 20px; opacity: 0.3;" />
                </div>
                <div class="vua-row-info">
                    <p class="vua-row-name">@universe.DisplayName</p>
                    @if (!string.IsNullOrEmpty(universe.Description))
                    {
                        <p class="vua-row-desc">@universe.Description</p>
                    }
                </div>
                <div class="vua-row-meta">
                    @{
                        var count = universe.IsParentHub ? universe.ChildHubCount : universe.WorkCount;
                        var label = universe.IsParentHub ? "series" : "works";
                    }
                    <span class="vua-row-count">@count @label</span>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public EventCallback<Guid> OnRowClicked { get; set; }

    private List<HubViewModel> _universes = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _universes = await ApiClient.GetParentHubsAsync() ?? [];
        _loading = false;
    }
}

<style>
    .vua-loading, .vua-empty {
        display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px;
    }
    .vua-count {
        font-size: 0.8rem; color: rgba(255,255,255,0.3); margin-bottom: 12px;
    }
    .vua-list { display: flex; flex-direction: column; gap: 2px; }
    .vua-row {
        display: flex; align-items: center; gap: 12px; padding: 12px 16px;
        background: rgba(255,255,255,0.02); border-radius: 8px; cursor: pointer;
        transition: background 0.15s;
    }
    .vua-row:hover { background: rgba(255,255,255,0.05); }
    .vua-row-icon { flex-shrink: 0; }
    .vua-row-info { flex: 1; min-width: 0; }
    .vua-row-name {
        font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.85);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .vua-row-desc {
        font-size: 0.75rem; color: rgba(255,255,255,0.3); margin-top: 2px;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .vua-row-meta { flex-shrink: 0; }
    .vua-row-count {
        font-size: 0.8rem; color: rgba(255,255,255,0.4);
    }
</style>
