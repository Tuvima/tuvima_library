@using MediaEngine.Web.Models.ViewDTOs

@inject IStringLocalizer<SharedStrings> L

@if (Universes.Count == 0 && !Loading)
{
    <div class="vut-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">@L["VaultUniverses_NoUniversesFound"]</p>
    </div>
}
else
{
    <div class="vut-table-wrap">
        <table class="vut-table">
            <thead>
                <tr class="vut-thead-row">
                    <th class="vut-th" style="width: 40%;">@L["VaultUniverses_ColUniverse"]</th>
                    <th class="vut-th vut-th--center vut-col-series" style="width: 15%;">@L["VaultUniverses_ColSeries"]</th>
                    <th class="vut-th vut-th--center" style="width: 25%;">@L["VaultUniverses_ColMediaAssets"]</th>
                    <th class="vut-th vut-th--center vut-col-people" style="width: 15%;">@L["VaultUniverses_ColPeople"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Universes)
                {
                    <tr class="vut-row" @onclick="() => OnRowClicked.InvokeAsync(u.Id)">
                        <td class="vut-td">
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <div class="vut-icon-box">
                                    <MudIcon Icon="@Icons.Material.Outlined.Public"
                                             Style="font-size: 18px; color: rgba(167,139,250,0.7);" />
                                </div>
                                <div style="min-width: 0;">
                                    <span class="vut-name">@u.DisplayName</span>
                                    @if (!string.IsNullOrWhiteSpace(u.Description))
                                    {
                                        <span class="vut-description">@u.Description</span>
                                    }
                                </div>
                            </div>
                        </td>
                        <td class="vut-td vut-td--center vut-col-series">
                            <span class="vut-count">@(u.IsParentHub ? u.ChildHubCount : u.WorkCount)</span>
                        </td>
                        <td class="vut-td vut-td--center">
                            @if (!string.IsNullOrWhiteSpace(u.MediaTypes))
                            {
                                <span class="vut-media-text">@u.MediaTypes</span>
                            }
                            else
                            {
                                <span class="vut-media-text">—</span>
                            }
                        </td>
                        <td class="vut-td vut-td--center vut-col-people">
                            @if (PeopleCount is not null && PeopleCount.TryGetValue(u.Id, out var pc) && pc > 0)
                            {
                                <span class="vut-count">@pc</span>
                            }
                            else
                            {
                                <span class="vut-count" style="color: rgba(255,255,255,0.4);">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Loading)
    {
        <div class="vut-loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                 Style="color: rgba(255,255,255,0.15);" />
        </div>
    }
}

@code {
    [Parameter] public List<HubViewModel> Universes { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<Guid> OnRowClicked { get; set; }
    /// <summary>Optional map of Hub ID → people count. When null, the People column shows "—".</summary>
    [Parameter] public Dictionary<Guid, int>? PeopleCount { get; set; }
}

<style>
    .vut-table-wrap {
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        overflow: hidden;
    }

    .vut-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    .vut-thead-row {
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .vut-th {
        padding: 12px 16px;
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.25);
    }

    .vut-th--center { text-align: center; }

    .vut-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        transition: background 0.15s ease;
        cursor: pointer;
    }

    .vut-row:last-child { border-bottom: none; }

    .vut-row:hover { background: rgba(167, 139, 250, 0.04); }

    .vut-td {
        padding: 12px 16px;
        vertical-align: middle;
    }

    .vut-td--center { text-align: center; }

    .vut-icon-box {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: rgba(167, 139, 250, 0.08);
        border: 1px solid rgba(167, 139, 250, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .vut-name {
        font-size: 14px;
        font-weight: 700;
        color: white;
        display: block;
    }

    .vut-row:hover .vut-name { color: #A78BFA; }

    .vut-description {
        font-size: 11px;
        font-style: italic;
        color: rgba(255, 255, 255, 0.4);
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 300px;
    }

    .vut-count {
        font-size: 14px;
        font-weight: 800;
        color: white;
    }

    .vut-media-text {
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.5);
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .vut-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 0;
    }

    .vut-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    @@media (max-width: 768px) {
        .vut-col-series,
        .vut-col-people { display: none; }

        .vut-td {
            padding: 10px 12px;
        }

        .vut-description {
            max-width: 180px;
        }
    }
</style>
