@using MediaEngine.Web.Models.ViewDTOs

@if (Items.Count == 0 && !Loading)
{
    <div class="vmt-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Inbox" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">No items match your filters.</p>
    </div>
}
else
{
    <div class="vmt-container">
        @if (GroupBy != "none")
        {
            @foreach (var group in GetGroups())
            {
                <div class="vmt-group">
                    <div class="vmt-group-header" @onclick="() => ToggleGroup(group.Key)">
                        <MudIcon Icon="@(IsGroupExpanded(group.Key) ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                 Style="font-size: 14px; opacity: 0.4;" />
                        <span class="vmt-group-label">@group.Label</span>
                        <div class="vmt-group-line"></div>
                        <span class="vmt-group-count">@group.Items.Count items</span>
                    </div>
                    @if (IsGroupExpanded(group.Key))
                    {
                        <div class="vmt-table-wrap">
                            @RenderTable(group.Items)
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="vmt-table-wrap">
                @RenderTable(Items)
            </div>
        }

        @if (Loading)
        {
            <div class="vmt-loading">
                <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                     Style="color: rgba(255,255,255,0.15);" />
            </div>
        }
    </div>
}

@code {
    [Parameter] public List<VaultItemViewModel> Items { get; set; } = [];
    [Parameter] public string GroupBy { get; set; } = "none";
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<Guid> OnResolveClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnMoreClicked { get; set; }

    private readonly Dictionary<string, bool> _expandedGroups = new();

    private RenderFragment RenderTable(List<VaultItemViewModel> items) => __builder =>
    {
        <table class="vmt-table">
            <thead>
                <tr class="vmt-thead-row">
                    <th class="vmt-th" style="width: 30%; padding-left: 24px;">Media Item</th>
                    <th class="vmt-th vmt-th--center" style="width: 12%;">Pipeline</th>
                    <th class="vmt-th" style="width: 15%;">Universe</th>
                    <th class="vmt-th vmt-th--center" style="width: 12%;">Confidence</th>
                    <th class="vmt-th vmt-th--center" style="width: 15%;">Status</th>
                    <th class="vmt-th vmt-th--right" style="width: 13%; padding-right: 24px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    var isQuarantined = item.VaultDisplayStatus == VaultStatus.Quarantined;
                    var needsAction = item.VaultDisplayStatus is VaultStatus.NeedsReview or VaultStatus.Failed;
                    <tr class="vmt-row @(isQuarantined ? "vmt-row--quarantined" : "")">
                        @* ── Media Item ── *@
                        <td class="vmt-td" style="padding-left: 24px;">
                            <div class="vmt-media-cell">
                                <div class="vmt-thumb">
                                    @if (!string.IsNullOrEmpty(item.CoverUrl))
                                    {
                                        <img src="@item.CoverUrl" alt="@item.Title" class="vmt-thumb-img" loading="lazy" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@VaultHelpers.GetMediaTypeIcon(item.MediaType)"
                                                 Style="font-size: 20px; opacity: 0.25;" />
                                    }
                                </div>
                                <div class="vmt-media-info">
                                    <p class="vmt-title @(isQuarantined || item.VaultDisplayStatus == VaultStatus.Failed ? "vmt-title--muted" : "")">@item.Title</p>
                                    <p class="vmt-subtitle">@VaultHelpers.FormatMediaType(item.MediaType) @(item.Year is not null ? $"• {item.Year}" : "")</p>
                                </div>
                            </div>
                        </td>

                        @* ── Pipeline ── *@
                        <td class="vmt-td">
                            <div class="vmt-pipeline">
                                <StageGate Stage="@item.Stage1" />
                                <StageGate Stage="@item.Stage2" />
                                <StageGate Stage="@item.Stage3" IsLast="true" />
                            </div>
                        </td>

                        @* ── Universe ── *@
                        <td class="vmt-td">
                            @if (!string.IsNullOrEmpty(item.UniverseName))
                            {
                                <div class="vmt-universe">
                                    <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 12px; color: rgba(96,165,250,0.7);" />
                                    <span>@item.UniverseName</span>
                                </div>
                            }
                            else
                            {
                                <span class="vmt-standalone">STANDALONE</span>
                            }
                        </td>

                        @* ── Confidence ── *@
                        <td class="vmt-td">
                            <div class="vmt-center">
                                <ConfidenceBar Confidence="@item.Confidence" />
                            </div>
                        </td>

                        @* ── Status ── *@
                        <td class="vmt-td">
                            <div class="vmt-center">
                                <StatusPill Status="@item.VaultDisplayStatus" QuarantineDays="@item.QuarantineDays" />
                            </div>
                        </td>

                        @* ── Actions ── *@
                        <td class="vmt-td vmt-td--actions" style="padding-right: 24px;">
                            @if (needsAction)
                            {
                                <button class="vmt-resolve-btn" @onclick="() => OnResolveClicked.InvokeAsync(item.EntityId)">
                                    Resolve
                                </button>
                            }
                            else
                            {
                                <div class="vmt-hover-actions">
                                    <button class="vmt-icon-btn vmt-icon-btn--delete"
                                            @onclick="() => OnDeleteClicked.InvokeAsync(item.EntityId)">
                                        <MudIcon Icon="@Icons.Material.Outlined.Delete" Style="font-size: 16px;" />
                                    </button>
                                    <button class="vmt-icon-btn"
                                            @onclick="() => OnMoreClicked.InvokeAsync(item.EntityId)">
                                        <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Style="font-size: 16px;" />
                                    </button>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    };

    // ── Grouping ──

    private record TableGroup(string Key, string Label, List<VaultItemViewModel> Items);

    private bool IsGroupExpanded(string key)
    {
        if (_expandedGroups.TryGetValue(key, out var val)) return val;
        return true; // default expanded
    }

    private void ToggleGroup(string key) =>
        _expandedGroups[key] = !IsGroupExpanded(key);

    private List<TableGroup> GetGroups()
    {
        if (GroupBy == "type")
        {
            var order = new[] { "Books", "Audiobooks", "Movies", "TV", "Comics", "Music", "Podcasts" };
            var byType = Items.GroupBy(i => i.MediaType ?? "Unknown").ToDictionary(g => g.Key, g => g.ToList());
            var result = new List<TableGroup>();
            foreach (var mt in order)
                if (byType.TryGetValue(mt, out var items) && items.Count > 0)
                    result.Add(new TableGroup(mt, mt, items));
            foreach (var kvp in byType.Where(k => !order.Contains(k.Key)))
                if (kvp.Value.Count > 0)
                    result.Add(new TableGroup(kvp.Key, kvp.Key, kvp.Value));
            return result;
        }

        if (GroupBy == "status")
        {
            var groups = new List<TableGroup>();
            var verified = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Verified).ToList();
            var review = Items.Where(i => i.VaultDisplayStatus == VaultStatus.NeedsReview).ToList();
            var failed = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Failed).ToList();
            var quarantined = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Quarantined).ToList();
            if (verified.Count > 0) groups.Add(new TableGroup("verified", "Verified", verified));
            if (review.Count > 0) groups.Add(new TableGroup("review", "Needs Review", review));
            if (failed.Count > 0) groups.Add(new TableGroup("failed", "Failed", failed));
            if (quarantined.Count > 0) groups.Add(new TableGroup("quarantined", "Quarantined", quarantined));
            return groups;
        }

        return [new TableGroup("all", "All Items", Items)];
    }
}

<style>
    .vmt-container {
        /* outer wrapper */
    }

    .vmt-table-wrap {
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        overflow: hidden;
    }

    .vmt-table {
        width: 100%;
        text-align: left;
        border-collapse: collapse;
        table-layout: fixed;
    }

    /* ── Header ── */
    .vmt-thead-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        background: rgba(255, 255, 255, 0.015);
    }

    .vmt-th {
        padding: 16px;
        font-size: 10px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.25);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .vmt-th--center { text-align: center; }
    .vmt-th--right { text-align: right; }

    /* ── Rows ── */
    .vmt-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.025);
        transition: background 0.15s;
    }

    .vmt-row:last-child {
        border-bottom: none;
    }

    .vmt-row:hover {
        background: rgba(96, 165, 250, 0.02);
    }

    .vmt-row--quarantined {
        opacity: 0.5;
    }

    .vmt-td {
        padding: 16px;
        vertical-align: middle;
    }

    .vmt-td--actions {
        text-align: right;
    }

    /* ── Media cell ── */
    .vmt-media-cell {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .vmt-thumb {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.02);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .vmt-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.6;
        transition: opacity 0.15s;
    }

    .vmt-row:hover .vmt-thumb-img {
        opacity: 1;
    }

    .vmt-media-info {
        overflow: hidden;
    }

    .vmt-title {
        font-size: 14px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin: 0 0 4px 0;
    }

    .vmt-title--muted {
        color: rgba(255, 255, 255, 0.4);
    }

    .vmt-subtitle {
        font-size: 10px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.02em;
        margin: 0;
    }

    /* ── Pipeline ── */
    .vmt-pipeline {
        display: flex;
        justify-content: center;
    }

    /* ── Universe ── */
    .vmt-universe {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.5);
    }

    .vmt-standalone {
        font-size: 11px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.1);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    /* ── Center helpers ── */
    .vmt-center {
        display: flex;
        justify-content: center;
    }

    /* ── Actions ── */
    .vmt-resolve-btn {
        background: rgba(96, 165, 250, 0.85);
        color: #fff;
        font-size: 10px;
        font-weight: 800;
        padding: 6px 12px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        transition: background 0.15s;
    }

    .vmt-resolve-btn:hover {
        background: rgba(96, 165, 250, 1);
    }

    .vmt-hover-actions {
        display: flex;
        align-items: center;
        gap: 4px;
        justify-content: flex-end;
        opacity: 0;
        transition: opacity 0.15s;
    }

    .vmt-row:hover .vmt-hover-actions {
        opacity: 1;
    }

    .vmt-icon-btn {
        padding: 8px;
        border-radius: 8px;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.2);
        cursor: pointer;
        display: flex;
        align-items: center;
        transition: all 0.12s;
    }

    .vmt-icon-btn:hover {
        color: rgba(255, 255, 255, 0.7);
    }

    .vmt-icon-btn--delete:hover {
        color: #A05050;
        background: rgba(160, 80, 80, 0.1);
    }

    /* ── Group headers ── */
    .vmt-group {
        margin-bottom: 32px;
    }

    .vmt-group-header {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 0 8px;
        margin-bottom: 12px;
        cursor: pointer;
        user-select: none;
    }

    .vmt-group-label {
        font-size: 10px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.35);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        white-space: nowrap;
    }

    .vmt-group-line {
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.04);
    }

    .vmt-group-count {
        font-size: 10px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.2);
        white-space: nowrap;
    }

    /* ── Empty / Loading ── */
    .vmt-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        text-align: center;
    }

    .vmt-loading {
        display: flex;
        justify-content: center;
        padding: 24px;
    }

    /* ── Mobile ── */
    @@media (max-width: 768px) {
        .vmt-table-wrap {
            border-radius: 12px;
        }

        .vmt-thead-row {
            display: none;
        }

        .vmt-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            padding: 12px 16px;
            gap: 8px;
        }

        .vmt-td {
            padding: 0;
        }

        .vmt-td:nth-child(1) {
            flex: 1;
            min-width: 0;
        }

        /* Hide pipeline, universe columns on mobile */
        .vmt-td:nth-child(2),
        .vmt-td:nth-child(3),
        .vmt-td:nth-child(4) {
            display: none;
        }

        /* Status pill inline */
        .vmt-td:nth-child(5) {
            flex-shrink: 0;
        }

        /* Actions */
        .vmt-td:nth-child(6) {
            flex-shrink: 0;
        }

        .vmt-hover-actions {
            opacity: 1;
        }

        .vmt-thumb {
            width: 40px;
            height: 40px;
        }
    }
</style>
