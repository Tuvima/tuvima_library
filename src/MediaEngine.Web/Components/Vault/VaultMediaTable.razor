@using MediaEngine.Web.Models.ViewDTOs

@inject IStringLocalizer<SharedStrings> L

@if (Items.Count == 0 && !Loading)
{
    <div class="vmt-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Inbox" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">@L["VaultMedia_NoItemsMatch"]</p>
    </div>
}
else
{
    <div class="vmt-container">
        @if (GroupBy != "none")
        {
            @foreach (var group in GetGroups())
            {
                <div class="vmt-group">
                    <div class="vmt-group-header" @onclick="() => ToggleGroup(group.Key)">
                        <MudIcon Icon="@(IsGroupExpanded(group.Key) ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                 Style="font-size: 14px; opacity: 0.4;" />
                        <span class="vmt-group-label">@group.Label</span>
                        <div class="vmt-group-line"></div>
                        <span class="vmt-group-count">@group.Items.Count @L["VaultMedia_ItemsCount"]</span>
                    </div>
                    @if (IsGroupExpanded(group.Key))
                    {
                        <div class="vmt-table-wrap">
                            @RenderTable(group.Items)
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="vmt-table-wrap">
                @RenderTable(Items)
            </div>
        }

        @if (Loading)
        {
            <div class="vmt-loading">
                <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                     Style="color: rgba(255,255,255,0.15);" />
            </div>
        }
    </div>
}

@code {
    [Parameter] public List<VaultItemViewModel> Items { get; set; } = [];
    [Parameter] public string GroupBy { get; set; } = "none";
    [Parameter] public bool Loading { get; set; }
    [Parameter] public int PosterSize { get; set; } = 48;
    [Parameter] public EventCallback<Guid> OnRowClicked { get; set; }
    [Parameter] public EventCallback<string> OnAuthorClicked { get; set; }

    private readonly Dictionary<string, bool> _expandedGroups = new();

    private RenderFragment RenderTable(List<VaultItemViewModel> items) => __builder =>
    {
        <table class="vmt-table">
            <thead>
                <tr class="vmt-thead-row">
                    <th class="vmt-th" style="width: 45%; padding-left: 24px;"></th>
                    <th class="vmt-th vmt-th--center" style="width: 12%;">@L["VaultMedia_ColPipelineStatus"]</th>
                    <th class="vmt-th vmt-th--center" style="width: 18%;">@L["VaultMedia_ColLinkedUniverse"]</th>
                    <th class="vmt-th vmt-th--right" style="width: 20%; padding-right: 24px;">@L["VaultMedia_ColVerification"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    var isQuarantined = item.VaultDisplayStatus == VaultStatus.Quarantined;
                    <tr class="vmt-row @(isQuarantined ? "vmt-row--quarantined" : "")"
                        style="cursor: pointer;"
                        @onclick="() => OnRowClicked.InvokeAsync(item.EntityId)">
                        @* ── Media Item ── *@
                        <td class="vmt-td" style="padding-left: 24px;">
                            <div class="vmt-media-cell">
                                <div class="vmt-poster-wrap">
                                    <div class="vmt-thumb" style="width: @(PosterSize)px; min-height: @(PosterSize)px;">
                                        @if (!string.IsNullOrEmpty(item.CoverUrl))
                                        {
                                            <img src="@item.CoverUrl" alt="@item.Title" class="vmt-thumb-img" loading="lazy" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@VaultHelpers.GetMediaTypeIcon(item.MediaType)"
                                                     Style="font-size: 20px; opacity: 0.25;" />
                                        }
                                    </div>
                                    <div class="vmt-type-badge" style="color: @VaultHelpers.GetMediaTypeColor(item.MediaType);">
                                        <MudIcon Icon="@VaultHelpers.GetMediaTypeIcon(item.MediaType)" Style="font-size: 14px;" />
                                    </div>
                                </div>
                                <div class="vmt-media-info">
                                    <p class="vmt-title @(isQuarantined || item.VaultDisplayStatus == VaultStatus.Failed ? "vmt-title--muted" : "")">@item.Title</p>
                                    @if (!string.IsNullOrEmpty(item.OriginalTitle) && item.OriginalTitle != item.Title)
                                    {
                                        <p class="vmt-original-title">@item.OriginalTitle</p>
                                    }
                                    <p class="vmt-subtitle">@VaultHelpers.FormatMediaType(item.MediaType) @(item.Year is not null ? $"• {item.Year}" : "")</p>
                                    @if (!string.IsNullOrEmpty(item.Author))
                                    {
                                        <button class="vmt-creator-link" @onclick:stopPropagation="true"
                                                @onclick="() => OnAuthorClicked.InvokeAsync(item.Author)">
                                            @item.Author.ToUpperInvariant()
                                        </button>
                                    }
                                    else
                                    {
                                        <p class="vmt-creator">@L["VaultMedia_UnknownCreator"].Value</p>
                                    }
                                    @if (item.VaultDisplayStatus is VaultStatus.NeedsReview or VaultStatus.Failed && !string.IsNullOrEmpty(item.ReviewTrigger))
                                    {
                                        <p class="vmt-review-reason">@VaultHelpers.GetReviewTriggerLabel(item.ReviewTrigger)</p>
                                    }
                                    @if (item.VaultDisplayStatus == VaultStatus.WaitingForProvider)
                                    {
                                        <p class="vmt-provider-waiting">
                                            @if (!string.IsNullOrEmpty(item.FailedProviderName))
                                            {
                                                @L["VaultMedia_WaitingForProviderNamed", item.FailedProviderName]
                                            }
                                            else
                                            {
                                                @L["VaultMedia_WaitingForProvider"]
                                            }
                                        </p>
                                    }
                                </div>
                            </div>
                        </td>

                        @* ── Pipeline ── *@
                        <td class="vmt-td vmt-td--center">
                            <div class="vmt-pipeline">
                                <StageGate Stage="@item.Stage1" />
                                <StageGate Stage="@item.Stage2" />
                                <StageGate Stage="@item.Stage3" IsLast="true" />
                            </div>
                        </td>

                        @* ── Universe ── *@
                        <td class="vmt-td vmt-td--center">
                            @if (!string.IsNullOrEmpty(item.UniverseName))
                            {
                                <span class="vmt-universe-linked">@item.UniverseName.ToUpperInvariant()</span>
                            }
                            else
                            {
                                <span class="vmt-universe-standalone">@L["VaultMedia_Standalone"]</span>
                            }
                        </td>

                        @* ── Verification ── *@
                        <td class="vmt-td vmt-td--right" style="padding-right: 24px;">
                            <div style="display: flex; justify-content: flex-end;">
                                <StatusPill Status="@item.VaultDisplayStatus" QuarantineDays="@item.QuarantineDays" />
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    };

    // ── Grouping ──

    private record TableGroup(string Key, string Label, List<VaultItemViewModel> Items);

    private bool IsGroupExpanded(string key)
    {
        if (_expandedGroups.TryGetValue(key, out var val)) return val;
        return true; // default expanded
    }

    private void ToggleGroup(string key) =>
        _expandedGroups[key] = !IsGroupExpanded(key);

    private List<TableGroup> GetGroups()
    {
        if (GroupBy == "type")
        {
            var order = new[] { "Books", "Audiobooks", "Movies", "TV", "Comics", "Music", "Podcasts" };
            var byType = Items.GroupBy(i => i.MediaType ?? "Unknown").ToDictionary(g => g.Key, g => g.ToList());
            var result = new List<TableGroup>();
            foreach (var mt in order)
                if (byType.TryGetValue(mt, out var items) && items.Count > 0)
                    result.Add(new TableGroup(mt, mt, items));
            foreach (var kvp in byType.Where(k => !order.Contains(k.Key)))
                if (kvp.Value.Count > 0)
                    result.Add(new TableGroup(kvp.Key, kvp.Key, kvp.Value));
            return result;
        }

        if (GroupBy == "status")
        {
            var groups = new List<TableGroup>();
            var verified = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Verified).ToList();
            var provisional = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Provisional).ToList();
            var review = Items.Where(i => i.VaultDisplayStatus == VaultStatus.NeedsReview).ToList();
            var failed = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Failed).ToList();
            var quarantined = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Quarantined).ToList();
            var waiting = Items.Where(i => i.VaultDisplayStatus == VaultStatus.WaitingForProvider).ToList();
            if (verified.Count > 0) groups.Add(new TableGroup("verified", L["VaultMedia_GroupVerified"].Value, verified));
            if (provisional.Count > 0) groups.Add(new TableGroup("provisional", L["VaultMedia_GroupProvisional"].Value, provisional));
            if (review.Count > 0) groups.Add(new TableGroup("review", L["VaultMedia_GroupNeedsReview"].Value, review));
            if (waiting.Count > 0) groups.Add(new TableGroup("waiting", L["VaultMedia_GroupWaitingForProvider"].Value, waiting));
            if (failed.Count > 0) groups.Add(new TableGroup("failed", L["VaultMedia_GroupFailed"].Value, failed));
            if (quarantined.Count > 0) groups.Add(new TableGroup("quarantined", L["VaultMedia_GroupQuarantined"].Value, quarantined));
            return groups;
        }

        if (GroupBy == "letter")
        {
            var byLetter = Items
                .GroupBy(i => string.IsNullOrEmpty(i.Title) ? "#" : i.Title[0].ToString().ToUpperInvariant())
                .OrderBy(g => g.Key)
                .Select(g => new TableGroup(g.Key, g.Key, g.ToList()))
                .ToList();
            return byLetter;
        }

        return [new TableGroup("all", L["VaultMedia_GroupAll"].Value, Items)];
    }
}

<style>
    .vmt-container {
        /* outer wrapper */
    }

    .vmt-table-wrap {
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        overflow: visible;
    }

    .vmt-table {
        width: 100%;
        text-align: left;
        border-collapse: collapse;
        table-layout: fixed;
    }

    /* ── Header ── */
    .vmt-thead-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        background: rgba(255, 255, 255, 0.015);
    }

    .vmt-th {
        padding: 16px;
        font-size: 10px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.25);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .vmt-th--center { text-align: center; }
    .vmt-th--right { text-align: right; }

    /* ── Rows ── */
    .vmt-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.025);
        transition: background 0.15s;
    }

    .vmt-row:last-child {
        border-bottom: none;
    }

    .vmt-row:hover {
        background: rgba(96, 165, 250, 0.02);
    }

    .vmt-row--quarantined {
        opacity: 0.5;
    }

    .vmt-td {
        padding: 16px;
        vertical-align: middle;
        overflow: visible;
    }

    .vmt-td--center { text-align: center; }
    .vmt-td--right { text-align: right; }

    /* ── Media cell ── */
    .vmt-media-cell {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    /* ── Poster wrap (thumb + type badge) ── */
    .vmt-poster-wrap {
        position: relative;
        flex-shrink: 0;
    }

    .vmt-thumb {
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.02);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        z-index: 1;
    }

    .vmt-thumb:hover {
        transform: scale(2.8);
        z-index: 50;
        box-shadow: 0 8px 32px rgba(0,0,0,0.8);
        border-radius: 8px;
    }

    .vmt-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.6;
        transition: opacity 0.15s;
    }

    .vmt-thumb:hover .vmt-thumb-img {
        opacity: 1;
    }

    /* ── Media type icon badge ── */
    .vmt-type-badge {
        position: absolute;
        bottom: -4px;
        right: -6px;
        width: 22px;
        height: 22px;
        border-radius: 6px;
        background: #14181d;
        border: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.6);
        z-index: 2;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
    }

    .vmt-media-info {
        overflow: hidden;
    }

    .vmt-title {
        font-size: 14px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin: 0 0 4px 0;
    }

    .vmt-title--muted {
        color: rgba(255, 255, 255, 0.4);
    }

    .vmt-original-title {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
        margin: 2px 0 4px 0;
        opacity: 0.7;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vmt-subtitle {
        font-size: 10px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.02em;
        margin: 0;
    }

    .vmt-creator {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.3);
        margin-top: 2px;
    }

    .vmt-creator-link {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.3);
        margin-top: 2px;
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        text-align: left;
        transition: color 0.15s;
    }

    .vmt-creator-link:hover {
        color: #60A5FA;
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .vmt-review-reason {
        font-size: 10px;
        font-weight: 600;
        color: #EF9F27;
        margin-top: 4px;
        font-style: italic;
    }

    .vmt-provider-waiting {
        font-size: 10px;
        font-weight: 600;
        color: #38BDF8;
        margin-top: 4px;
        font-style: italic;
    }

    /* ── Pipeline ── */
    .vmt-pipeline {
        display: flex;
        justify-content: center;
    }

    /* ── Universe ── */
    .vmt-universe-linked {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #A78BFA;
    }

    .vmt-universe-standalone {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.2);
    }

    /* ── Group headers ── */
    .vmt-group {
        margin-bottom: 32px;
    }

    .vmt-group-header {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 0 8px;
        margin-bottom: 12px;
        cursor: pointer;
        user-select: none;
    }

    .vmt-group-label {
        font-size: 10px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.35);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        white-space: nowrap;
    }

    .vmt-group-line {
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.04);
    }

    .vmt-group-count {
        font-size: 10px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.2);
        white-space: nowrap;
    }

    /* ── Empty / Loading ── */
    .vmt-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        text-align: center;
    }

    .vmt-loading {
        display: flex;
        justify-content: center;
        padding: 24px;
    }

    /* ── Mobile ── */
    @@media (max-width: 768px) {
        .vmt-table-wrap {
            border-radius: 12px;
        }

        .vmt-thead-row {
            display: none;
        }

        .vmt-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            padding: 12px 16px;
            gap: 8px;
        }

        .vmt-td {
            padding: 0;
        }

        .vmt-td:nth-child(1) {
            flex: 1;
            min-width: 0;
        }

        /* Hide pipeline and universe columns on mobile */
        .vmt-td:nth-child(2),
        .vmt-td:nth-child(3) {
            display: none;
        }

        /* Verification pill inline */
        .vmt-td:nth-child(4) {
            flex-shrink: 0;
        }

        .vmt-thumb {
            width: 40px;
            min-height: 40px;
        }
    }
</style>
