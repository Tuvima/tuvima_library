@using MediaEngine.Web.Models.ViewDTOs

<div class="stage-gate">
    <div class="stage-dot"
         style="background: @DotColor; box-shadow: @DotShadow;"
         title="@Stage.Label"></div>
    @if (!IsLast)
    {
        <div class="stage-line" style="background: @LineColor;"></div>
    }
</div>

@code {
    [Parameter, EditorRequired] public VaultPipelineStage Stage { get; set; } = default!;
    [Parameter] public bool IsLast { get; set; }

    private string DotColor => Stage.State switch
    {
        VaultStageState.Completed => "#5DCAA5",
        VaultStageState.Warning => "#EF9F27",
        VaultStageState.Failed => "#A05050",
        _ => "rgba(255,255,255,0.12)",
    };

    private string DotShadow => Stage.State switch
    {
        VaultStageState.Completed => "0 0 8px rgba(93,202,165,0.3)",
        VaultStageState.Warning => "0 0 8px rgba(239,159,39,0.3)",
        VaultStageState.Failed => "0 0 8px rgba(160,80,80,0.3)",
        _ => "none",
    };

    private string LineColor => Stage.State == VaultStageState.Completed
        ? "rgba(93,202,165,0.3)"
        : "rgba(255,255,255,0.08)";
}

<style>
    .stage-gate {
        display: flex;
        align-items: center;
    }

    .stage-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        z-index: 1;
        border: 2px solid #0d0f12;
        flex-shrink: 0;
    }

    .stage-line {
        height: 2px;
        width: 20px;
        margin: 0 -2px;
        flex-shrink: 0;
    }
</style>
