@namespace MediaEngine.Web.Components.Vault
@inject IStringLocalizer<SharedStrings> L

@* ── Backdrop ── *@
<div class="vamd-backdrop" @onclick="OnClose"></div>

@* ── Drawer Panel ── *@
<div class="vamd-drawer" @onclick:stopPropagation="true">
    <div class="vamd-header">
        <MudIconButton Icon="@Icons.Material.Outlined.Close"
                       Size="Size.Small"
                       Style="position:absolute;top:24px;right:24px;color:rgba(255,255,255,0.5);"
                       OnClick="OnClose" />
        <div style="display:flex;align-items:center;gap:12px;">
            <MudIcon Icon="@Icons.Material.Outlined.CreateNewFolder" Style="font-size: 24px; color: #60A5FA;" />
            <h2 class="vamd-title">@L["VaultAddMedia_Title"]</h2>
        </div>
        <p class="vamd-hint">@L["VaultAddMedia_Hint"]</p>
    </div>

    <div class="vamd-body">
        <div class="vamd-drop-zone @(_isDragging ? "vamd-drop-zone--active" : "")"
             @ondragenter="OnDragEnter"
             @ondragover="OnDragOver"
             @ondragover:preventDefault="true"
             @ondragleave="OnDragLeave"
             @ondrop="OnDrop"
             @ondrop:preventDefault="true">
            <MudIcon Icon="@(_isDragging ? Icons.Material.Outlined.CloudUpload : Icons.Material.Outlined.UploadFile)"
                     Style="@($"font-size: 48px; color: {(_isDragging ? "#60A5FA" : "rgba(255,255,255,0.1)")}; transition: color 0.2s;")" />
            <p class="vamd-drop-text">
                @if (_isDragging)
                {
                    <span style="color: #60A5FA; font-weight: 800;">@L["VaultAddMedia_DropToImport"]</span>
                }
                else
                {
                    <span>@L["VaultAddMedia_DragFilesHere"]</span>
                }
            </p>
            <span class="vamd-drop-or">@L["VaultAddMedia_Or"]</span>
            <button class="vamd-browse-btn">
                <MudIcon Icon="@Icons.Material.Outlined.FolderOpen" Style="font-size: 16px;" />
                @L["VaultAddMedia_BrowseFiles"]
            </button>
        </div>

        <div class="vamd-supported">
            <span class="vamd-supported-label">@L["VaultAddMedia_Supported"]</span>
            <div class="vamd-supported-types">
                <span>EPUB</span><span>M4B</span><span>MKV</span><span>MP4</span>
                <span>CBZ</span><span>CBR</span><span>MP3</span><span>FLAC</span>
                <span>PDF</span>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _isDragging;

    private void OnDragEnter() => _isDragging = true;
    private void OnDragOver() => _isDragging = true;
    private void OnDragLeave() => _isDragging = false;

    private void OnDrop()
    {
        _isDragging = false;
        // Placeholder: actual file ingestion would be wired here
    }
}

<style>
    .vamd-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        z-index: 10000;
        animation: vamd-fade-in 0.2s ease;
    }

    @@keyframes vamd-fade-in {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .vamd-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: 36rem;
        height: 100%;
        background: #0d0f12;
        border-left: 1px solid rgba(255, 255, 255, 0.06);
        z-index: 10001;
        display: flex;
        flex-direction: column;
        box-shadow: 0 0 80px rgba(0, 0, 0, 0.9);
        animation: vamd-slide-in 0.4s ease;
    }

    @@keyframes vamd-slide-in {
        from { transform: translateX(100%); }
        to { transform: translateX(0); }
    }

    .vamd-header {
        padding: 32px 24px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        position: relative;
        flex-shrink: 0;
    }

    .vamd-title {
        font-size: 20px;
        font-weight: 900;
        color: white;
        margin: 0;
    }

    .vamd-hint {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.35);
        margin: 8px 0 0;
    }

    .vamd-body {
        flex: 1;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .vamd-drop-zone {
        flex: 1;
        min-height: 240px;
        border: 2px dashed rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.01);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .vamd-drop-zone:hover {
        border-color: rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.02);
    }

    .vamd-drop-zone--active {
        border-color: #60A5FA;
        background: rgba(96, 165, 250, 0.05);
        transform: scale(1.02);
    }

    .vamd-drop-text {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.35);
        margin: 0;
    }

    .vamd-drop-or {
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.15);
    }

    .vamd-browse-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 12px;
        border: 1px solid rgba(96, 165, 250, 0.3);
        background: rgba(96, 165, 250, 0.1);
        color: #60A5FA;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vamd-browse-btn:hover {
        background: rgba(96, 165, 250, 0.2);
    }

    .vamd-supported {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .vamd-supported-label {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.2);
    }

    .vamd-supported-types {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .vamd-supported-types span {
        font-size: 9px;
        font-weight: 800;
        padding: 3px 8px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.35);
    }

    @@media (max-width: 768px) {
        .vamd-drawer {
            width: 100%;
        }
    }
</style>
