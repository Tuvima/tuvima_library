@using MediaEngine.Web.Models.ViewDTOs

@inject IStringLocalizer<SharedStrings> L

@if (People.Count == 0 && !Loading)
{
    <div class="vpt-empty">
        <MudIcon Icon="@Icons.Material.Outlined.People" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">@L["VaultPeople_NoPeopleFound"]</p>
    </div>
}
else
{
    <div class="vpt-table-wrap">
        <table class="vpt-table">
            <thead>
                <tr class="vpt-thead-row">
                    <th class="vpt-th" style="width: 4%;"></th>
                    <th class="vpt-th" style="width: 40%;">
                        <button class="vpt-sort-header" @onclick="SortByName">
                            @L["VaultPeople_ColName"]
                            <MudIcon Icon="@(_activeSortKey == "name" ? (_sortAscending ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward) : Icons.Material.Filled.UnfoldMore)"
                                     Style="@($"font-size: 11px; margin-left: 4px; opacity: {(_activeSortKey == "name" ? "0.7" : "0.25")};")" />
                        </button>
                    </th>
                    <th class="vpt-th" style="width: 16%;">
                        <button class="vpt-sort-header" @onclick="SortByRole">
                            Role
                            <MudIcon Icon="@(_activeSortKey == "role" ? (_sortAscending ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward) : Icons.Material.Filled.UnfoldMore)"
                                     Style="@($"font-size: 11px; margin-left: 4px; opacity: {(_activeSortKey == "role" ? "0.7" : "0.25")};")" />
                        </button>
                    </th>
                    <th class="vpt-th vpt-th--center" style="width: 10%;">
                        <button class="vpt-sort-header vpt-sort-header--center" @onclick="SortByPresence">
                            Works
                            <MudIcon Icon="@(_activeSortKey == "presence" ? (_sortAscending ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward) : Icons.Material.Filled.UnfoldMore)"
                                     Style="@($"font-size: 11px; margin-left: 4px; opacity: {(_activeSortKey == "presence" ? "0.7" : "0.25")};")" />
                        </button>
                    </th>
                    <th class="vpt-th" style="width: 34%;">Types</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var person in SortedPeople)
                {
                    var pid = person.Id.ToString();
                    var hasCounts = Presence.TryGetValue(pid, out var counts) && counts.Count > 0;
                    var total = hasCounts ? counts!.Values.Sum() : 0;
                    var displayRoles = person.Roles.Where(r => !r.Equals("Composer", StringComparison.OrdinalIgnoreCase)).ToList();
                    var primaryRole = displayRoles.FirstOrDefault() ?? string.Empty;
                    <tr class="vpt-row" @onclick="() => OnRowClicked.InvokeAsync(person.Id)" style="cursor: pointer;">
                        <td class="vpt-td" style="width: 4%;"></td>
                        <td class="vpt-td vpt-td--person">
                            <div class="vpt-avatar">
                                @if (!string.IsNullOrEmpty(person.HeadshotUrl))
                                {
                                    <img src="@person.HeadshotUrl" alt="@person.Name" loading="lazy" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.Person"
                                             Style="font-size: 16px; color: rgba(255,255,255,0.25);" />
                                }
                            </div>
                            <div class="vpt-person-info">
                                <span class="vpt-name">
                                    @if (person.IsGroup)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Groups"
                                                 Style="font-size: 12px; color: rgba(255,255,255,0.35); margin-right: 4px; vertical-align: middle;" />
                                    }
                                    @person.Name
                                </span>
                                @if (!string.IsNullOrWhiteSpace(person.Biography))
                                {
                                    <span class="vpt-description">@person.Biography</span>
                                }
                            </div>
                        </td>
                        <td class="vpt-td">
                            @if (!string.IsNullOrWhiteSpace(primaryRole))
                            {
                                <span class="vpt-role-chip vpt-role-chip--@primaryRole.ToLowerInvariant()">@primaryRole</span>
                            }
                            @if (displayRoles.Count > 1)
                            {
                                <span class="vpt-role-more">+@(displayRoles.Count - 1)</span>
                            }
                        </td>
                        <td class="vpt-td vpt-td--center">
                            @if (hasCounts)
                            {
                                <span class="vpt-count">@total</span>
                            }
                            else
                            {
                                <span class="vpt-count vpt-count--muted">—</span>
                            }
                        </td>
                        <td class="vpt-td">
                            @if (hasCounts)
                            {
                                <div class="vpt-presence-pills">
                                    @foreach (var kvp in counts!.OrderByDescending(c => c.Value))
                                    {
                                        <span class="vpt-presence-pill" style="color: @VaultHelpers.GetMediaTypeColor(kvp.Key);"
                                              title="@kvp.Key">
                                            <MudIcon Icon="@GetMediaTypeIcon(kvp.Key)" Style="font-size: 11px;" />
                                            <span>@kvp.Value</span>
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="vpt-muted">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Loading)
    {
        <div class="vpt-loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                 Style="color: rgba(255,255,255,0.15);" />
        </div>
    }
}

@code {
    [Parameter] public List<PersonListItemDto> People { get; set; } = [];
    [Parameter] public Dictionary<string, Dictionary<string, int>> Presence { get; set; } = new();
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<Guid> OnRowClicked { get; set; }

    private string _activeSortKey = "role";
    private bool _sortAscending = true;

    private IEnumerable<PersonListItemDto> SortedPeople => (_activeSortKey, _sortAscending) switch
    {
        ("name", true)     => People.OrderBy(p => p.Name),
        ("name", false)    => People.OrderByDescending(p => p.Name),
        ("role", true)     => People.OrderBy(p => p.Roles.FirstOrDefault() ?? "").ThenBy(p => p.Name),
        ("role", false)    => People.OrderByDescending(p => p.Roles.FirstOrDefault() ?? "").ThenBy(p => p.Name),
        ("presence", true) => People.OrderBy(p =>
        {
            Presence.TryGetValue(p.Id.ToString(), out var c);
            return c?.Values.Sum() ?? 0;
        }),
        ("presence", false) => People.OrderByDescending(p =>
        {
            Presence.TryGetValue(p.Id.ToString(), out var c);
            return c?.Values.Sum() ?? 0;
        }),
        _ => People.OrderBy(p => p.Roles.FirstOrDefault() ?? "").ThenBy(p => p.Name),
    };

    private void RequestSort(string key)
    {
        if (_activeSortKey == key)
            _sortAscending = !_sortAscending;
        else
        {
            _activeSortKey = key;
            _sortAscending = true;
        }
    }

    private void SortByName() => RequestSort("name");
    private void SortByRole() => RequestSort("role");
    private void SortByPresence() => RequestSort("presence");

    private static string GetMediaTypeIcon(string mediaType) => mediaType switch
    {
        "Movies"     => Icons.Material.Outlined.VideoLibrary,
        "Books"      => Icons.Material.Outlined.MenuBook,
        "Audiobooks" => Icons.Material.Outlined.Headphones,
        "TV"         => Icons.Material.Outlined.LiveTv,
        "Music"      => Icons.Material.Outlined.MusicNote,
        "Podcasts"   => Icons.Material.Outlined.Mic,
        "Comics"     => Icons.Material.Outlined.AutoStories,
        _            => Icons.Material.Outlined.Inventory2,
    };
}

<style>
    /* ── Container ── */
    .vpt-table-wrap {
        background: rgba(17, 20, 25, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        overflow: hidden;
        backdrop-filter: blur(8px);
    }

    .vpt-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        table-layout: fixed;
    }

    /* ── Header ── */
    .vpt-thead-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        background: rgba(15, 23, 42, 0.5);
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .vpt-th {
        padding: 10px 12px;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(255, 255, 255, 0.3);
    }

    .vpt-th--right  { text-align: right; }
    .vpt-th--center { text-align: center; }

    .vpt-sort-header {
        display: inline-flex;
        align-items: center;
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.3);
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        cursor: pointer;
        padding: 0;
        transition: color 0.15s;
    }

    .vpt-sort-header:hover {
        color: rgba(255, 255, 255, 0.8);
    }

    .vpt-sort-header--center {
        display: flex;
        justify-content: center;
        width: 100%;
    }

    /* ── Body rows ── */
    .vpt-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        transition: background 0.15s ease;
    }

    .vpt-row:last-child { border-bottom: none; }

    .vpt-row:hover { background: rgba(255, 255, 255, 0.02); }

    .vpt-td {
        padding: 10px 12px;
        vertical-align: middle;
        overflow: hidden;
    }

    .vpt-td--person {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .vpt-td--center { text-align: center; }
    .vpt-td--right  { text-align: right; }

    /* ── Avatar ── */
    .vpt-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
    }

    .vpt-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.75;
        transition: opacity 0.15s;
    }

    .vpt-row:hover .vpt-avatar img {
        opacity: 1;
    }

    /* ── Person info ── */
    .vpt-person-info {
        flex: 1;
        min-width: 0;
    }

    .vpt-name {
        font-size: 12px;
        font-weight: 700;
        color: white;
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: color 0.15s;
    }

    .vpt-row:hover .vpt-name { color: #60A5FA; }

    .vpt-description {
        font-size: 10px;
        font-style: italic;
        color: rgba(255, 255, 255, 0.35);
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* ── Role chip ── */
    .vpt-role-chip {
        display: inline-flex;
        align-items: center;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 2px 7px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.45);
        white-space: nowrap;
    }

    .vpt-role-chip--author    { color: #60A5FA; border-color: #60A5FA33; background: #60A5FA0D; }
    .vpt-role-chip--director  { color: #F472B6; border-color: #F472B633; background: #F472B60D; }
    .vpt-role-chip--narrator  { color: #34D399; border-color: #34D39933; background: #34D3990D; }
    .vpt-role-chip--performer { color: #A78BFA; border-color: #A78BFA33; background: #A78BFA0D; }
    .vpt-role-chip--artist    { color: #A78BFA; border-color: #A78BFA33; background: #A78BFA0D; }
    .vpt-role-chip--cast      { color: #FB923C; border-color: #FB923C33; background: #FB923C0D; }

    .vpt-role-more {
        font-size: 9px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.25);
        margin-left: 4px;
    }

    /* ── Count ── */
    .vpt-count {
        font-size: 12px;
        font-weight: 900;
        color: rgba(255, 255, 255, 0.85);
    }

    .vpt-count--muted {
        color: rgba(255, 255, 255, 0.25);
        font-weight: 700;
    }

    /* ── Presence pills ── */
    .vpt-presence-pills {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .vpt-presence-pill {
        display: flex;
        align-items: center;
        gap: 3px;
        font-size: 10px;
        font-weight: 700;
        opacity: 0.7;
        transition: opacity 0.15s;
    }

    .vpt-presence-pill:hover { opacity: 1; }

    .vpt-muted {
        font-size: 10px;
        color: rgba(255, 255, 255, 0.25);
        font-style: italic;
    }

    /* ── Manage actions ── */
    .vpt-manage-actions {
        display: flex;
        align-items: center;
        gap: 4px;
        justify-content: flex-end;
        opacity: 0;
        transition: opacity 0.15s;
    }

    .vpt-row:hover .vpt-manage-actions {
        opacity: 1;
    }

    .vpt-manage-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.03);
        color: rgba(255, 255, 255, 0.4);
        cursor: pointer;
        transition: all 0.15s;
    }

    .vpt-manage-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.8);
    }

    .vpt-manage-btn--delete:hover {
        background: rgba(239, 68, 68, 0.15);
        color: #EF4444;
        border-color: rgba(239, 68, 68, 0.3);
    }

    /* ── Loading / empty ── */
    .vpt-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 0;
    }

    .vpt-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    @@media (max-width: 768px) {
        .vpt-td {
            padding: 6px 12px;
        }

        .vpt-description {
            max-width: 160px;
        }
    }
</style>
