@using MediaEngine.Web.Models.ViewDTOs

@inject IStringLocalizer<SharedStrings> L

@if (People.Count == 0 && !Loading)
{
    <div class="vpt-empty">
        <MudIcon Icon="@Icons.Material.Outlined.People" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">@L["VaultPeople_NoPeopleFound"]</p>
    </div>
}
else
{
    <div class="vpt-table-wrap">
        <table class="vpt-table">
            <thead>
                <tr class="vpt-thead-row">
                    <th class="vpt-th" style="width: 60px;"></th>
                    <th class="vpt-th" style="width: 55%;">@L["VaultPeople_ColIndividual"]</th>
                    <th class="vpt-th vpt-th--right" style="width: 30%;">@L["VaultPeople_ColPresence"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var person in People)
                {
                    <tr class="vpt-row" @onclick="() => OnRowClicked.InvokeAsync(person.Id)">
                        <td class="vpt-td" style="width: 60px;">
                            <div class="vpt-avatar">
                                @if (!string.IsNullOrEmpty(person.HeadshotUrl))
                                {
                                    <img src="@person.HeadshotUrl" alt="@person.Name" loading="lazy" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.Person"
                                             Style="font-size: 18px; color: rgba(255,255,255,0.25);" />
                                }
                            </div>
                        </td>
                        <td class="vpt-td" style="width: 55%;">
                            <span class="vpt-name">@person.Name</span>
                            @if (!string.IsNullOrWhiteSpace(person.Biography))
                            {
                                <span class="vpt-description">@person.Biography</span>
                            }
                            @if (person.Roles.Count > 0)
                            {
                                <div class="vpt-roles">
                                    @foreach (var role in person.Roles)
                                    {
                                        <span class="vpt-role-chip">@role</span>
                                    }
                                </div>
                            }
                        </td>
                        <td class="vpt-td vpt-td--right">
                            @{
                                var pid = person.Id.ToString();
                                var hasCounts = Presence.TryGetValue(pid, out var counts) && counts.Count > 0;
                                var total = hasCounts ? counts!.Values.Sum() : 0;
                            }
                            @if (hasCounts)
                            {
                                <div class="vpt-presence">
                                    <span class="vpt-presence-total">@total</span>
                                    <div class="vpt-presence-pills">
                                        @foreach (var kvp in counts!.OrderByDescending(c => c.Value))
                                        {
                                            <span class="vpt-presence-pill" style="color: @VaultHelpers.GetMediaTypeColor(kvp.Key);"
                                                  title="@kvp.Key">
                                                <MudIcon Icon="@GetMediaTypeIcon(kvp.Key)" Style="font-size: 12px;" />
                                                <span>@kvp.Value</span>
                                            </span>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <span class="vpt-presence-text">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Loading)
    {
        <div class="vpt-loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                 Style="color: rgba(255,255,255,0.15);" />
        </div>
    }
}

@code {
    [Parameter] public List<PersonListItemDto> People { get; set; } = [];
    [Parameter] public Dictionary<string, Dictionary<string, int>> Presence { get; set; } = new();
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<Guid> OnRowClicked { get; set; }

    private static string GetMediaTypeIcon(string mediaType) => mediaType switch
    {
        "Movies" => Icons.Material.Outlined.VideoLibrary,
        "Books" => Icons.Material.Outlined.MenuBook,
        "Audiobooks" => Icons.Material.Outlined.Headphones,
        "TV" => Icons.Material.Outlined.LiveTv,
        "Music" => Icons.Material.Outlined.MusicNote,
        "Podcasts" => Icons.Material.Outlined.Mic,
        "Comics" => Icons.Material.Outlined.AutoStories,
        _ => Icons.Material.Outlined.Inventory2,
    };
}

<style>
    .vpt-table-wrap {
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        overflow: visible;
    }

    .vpt-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    .vpt-thead-row {
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .vpt-th {
        padding: 12px 16px;
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.25);
    }

    .vpt-th--right { text-align: right; }

    .vpt-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        transition: background 0.15s ease;
        cursor: pointer;
    }

    .vpt-row:last-child { border-bottom: none; }

    .vpt-row:hover { background: rgba(59, 130, 246, 0.04); }

    .vpt-td {
        padding: 12px 16px;
        vertical-align: middle;
        overflow: visible;
    }

    .vpt-td:first-child {
        padding-right: 0;
    }

    .vpt-td:nth-child(2) {
        padding-left: 8px;
    }

    .vpt-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        z-index: 1;
        position: relative;
    }

    .vpt-avatar:hover {
        transform: scale(2.8);
        z-index: 50;
        box-shadow: 0 8px 32px rgba(0,0,0,0.8);
    }

    .vpt-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.6;
        transition: opacity 0.15s;
    }

    .vpt-avatar:hover img {
        opacity: 1;
    }

    .vpt-name {
        font-size: 14px;
        font-weight: 700;
        color: white;
        display: block;
    }

    .vpt-row:hover .vpt-name { color: #60A5FA; }

    .vpt-description {
        font-size: 11px;
        font-style: italic;
        color: rgba(255, 255, 255, 0.4);
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 300px;
    }

    .vpt-roles {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-top: 5px;
    }

    .vpt-role-chip {
        font-size: 8px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 2px 8px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.5);
        white-space: nowrap;
    }

    .vpt-td--right {
        text-align: right;
        vertical-align: middle;
    }

    .vpt-presence-text {
        font-size: 10px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.5);
        text-align: right;
    }

    .vpt-presence {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
    }

    .vpt-presence-total {
        font-size: 16px;
        font-weight: 900;
        color: rgba(255, 255, 255, 0.7);
        min-width: 24px;
        text-align: right;
    }

    .vpt-presence-pills {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .vpt-presence-pill {
        display: flex;
        align-items: center;
        gap: 3px;
        font-size: 10px;
        font-weight: 700;
        opacity: 0.7;
    }

    .vpt-presence-pill:hover {
        opacity: 1;
    }

    .vpt-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 0;
    }

    .vpt-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    @@media (max-width: 768px) {
        .vpt-td {
            padding: 10px 12px;
        }

        .vpt-description {
            max-width: 180px;
        }

        .vpt-presence-text {
            font-size: 9px;
        }
    }
</style>
