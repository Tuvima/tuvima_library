@namespace MediaEngine.Web.Components.Vault

<div class="vault-stats-bar">
    @foreach (var card in Cards)
    {
        <button class="vault-stat-card @(card.IsActive ? "vault-stat-card--active" : "") @(card.IsActive ? "" : "vault-stat-card--dimmed")"
                style="--stat-color: @card.Color;"
                @onclick="() => OnCardToggled.InvokeAsync(card.Id)">
            <div class="vault-stat-icon" style="color: @card.Color;">
                <MudIcon Icon="@card.Icon" Style="font-size: 18px;" />
            </div>
            <div class="vault-stat-info">
                <span class="vault-stat-count">@FormatCount(card.Count)</span>
                <span class="vault-stat-label">@card.Label</span>
            </div>
        </button>
    }
</div>

@code {
    [Parameter] public List<StatCardModel> Cards { get; set; } = [];
    [Parameter] public EventCallback<string> OnCardToggled { get; set; }

    private static string FormatCount(int n) => n >= 1000 ? $"{n / 1000.0:0.#}k" : n.ToString();
}

<style>
    .vault-stats-bar {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 8px;
        padding: 0 24px;
    }

    .vault-stat-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(17, 20, 25, 0.5);
        cursor: pointer;
        transition: all 0.15s ease;
        text-align: left;
    }

    .vault-stat-card:hover {
        border-color: rgba(255, 255, 255, 0.1);
        background: rgba(17, 20, 25, 0.8);
    }

    .vault-stat-card--active {
        background: rgba(17, 20, 25, 1);
        border-color: var(--stat-color);
        box-shadow: 0 0 16px color-mix(in srgb, var(--stat-color) 20%, transparent);
    }

    .vault-stat-card--dimmed {
        background: transparent;
        border-color: rgba(255, 255, 255, 0.06);
    }

    .vault-stat-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 6px;
        border-radius: 8px;
        background: rgba(15, 23, 42, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.04);
    }

    .vault-stat-info {
        display: flex;
        flex-direction: column;
    }

    .vault-stat-count {
        font-size: 18px;
        font-weight: 900;
        color: white;
        line-height: 1;
    }

    .vault-stat-label {
        font-size: 7px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(255, 255, 255, 0.25);
        margin-top: 2px;
    }

    @@media (max-width: 768px) {
        .vault-stats-bar {
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
            padding: 0 16px;
        }
        .vault-stat-card {
            padding: 8px 10px;
            gap: 8px;
        }
        .vault-stat-count {
            font-size: 14px;
        }
    }
</style>
