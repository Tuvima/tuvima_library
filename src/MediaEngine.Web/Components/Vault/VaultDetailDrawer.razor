@using MediaEngine.Web.Models.ViewDTOs
@namespace MediaEngine.Web.Components.Vault
@inject IStringLocalizer<SharedStrings> L
@inject IEngineApiClient ApiClient

@* ── Backdrop ── *@
<div class="vdd-backdrop" @onclick="OnClose"></div>

@* ── Drawer Panel ── *@
<div class="vdd-drawer" @onclick:stopPropagation="true">

    @* ── 1. Pinned Header ── *@
    <div class="vdd-header">
        <MudIconButton Icon="@Icons.Material.Outlined.Close"
                       Size="Size.Small"
                       Style="position:absolute;top:24px;right:24px;color:rgba(255,255,255,0.5);"
                       OnClick="OnClose" />

        @if (MediaItem is not null)
        {
            @* ── Media Header ── *@
            <div class="vdd-header-content">
                <div class="vdd-thumb-wrap">
                    @if (!string.IsNullOrEmpty(MediaItem.CoverUrl))
                    {
                        <img src="@MediaItem.CoverUrl" alt="" class="vdd-thumb-img" loading="lazy" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 48px; color: rgba(255,255,255,0.1);" />
                    }
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        <StatusPill Status="@MediaItem.VaultDisplayStatus" QuarantineDays="@MediaItem.QuarantineDays" />
                        @if (!string.IsNullOrEmpty(MediaItem.WikidataQid))
                        {
                            <a href="https://www.wikidata.org/wiki/@MediaItem.WikidataQid" target="_blank" rel="noopener" class="vdd-qid-badge">
                                <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 11px;" />
                                @MediaItem.WikidataQid
                            </a>
                        }
                    </div>
                    <h2 class="vdd-title">@MediaItem.Title</h2>
                    <p class="vdd-subtitle">@(MediaItem.Author?.ToUpperInvariant() ?? L["VaultDetail_Unknown"].ToString().ToUpperInvariant())</p>
                    <div class="vdd-meta">
                        <span class="vdd-meta-item">
                            <MudIcon Icon="@VaultHelpers.GetMediaTypeIcon(MediaItem.MediaType)" Style="font-size: 14px; opacity: 0.5;" />
                            @VaultHelpers.FormatMediaType(MediaItem.MediaType)
                        </span>
                        @if (!string.IsNullOrEmpty(MediaItem.Year))
                        {
                            <span class="vdd-meta-item">@MediaItem.Year</span>
                        }
                    </div>
                </div>
            </div>
        }
        else if (Person is not null)
        {
            @* ── Person Header ── *@
            <div class="vdd-header-content">
                <div class="vdd-avatar-round">
                    @if (!string.IsNullOrEmpty(Person.HeadshotUrl))
                    {
                        <img src="@Person.HeadshotUrl" alt="" class="vdd-avatar-img" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 48px; color: rgba(255,255,255,0.1);" />
                    }
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        @foreach (var role in Person.Roles)
                        {
                            <span class="vdd-role-chip">@role.ToUpperInvariant()</span>
                        }
                        @if (!string.IsNullOrEmpty(Person.WikidataQid))
                        {
                            <a href="https://www.wikidata.org/wiki/@Person.WikidataQid" target="_blank" rel="noopener" class="vdd-qid-badge">
                                <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="font-size: 11px;" />
                                @Person.WikidataQid
                            </a>
                        }
                    </div>
                    <h2 class="vdd-title">@Person.Name</h2>
                    <p class="vdd-subtitle-italic">@Person.Biography</p>
                </div>
            </div>
        }
        else if (Universe is not null)
        {
            @* ── Universe Header ── *@
            <div class="vdd-header-content">
                <div class="vdd-universe-icon">
                    <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 48px; color: #A78BFA;" />
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        <StatusPill Status="VaultStatus.Verified" />
                    </div>
                    <h2 class="vdd-title">@Universe.DisplayName</h2>
                    <p class="vdd-subtitle-italic">@Universe.Description</p>
                </div>
            </div>
        }
    </div>

    @* ── 2. Scrollable Body ── *@
    <div class="vdd-body">
        @if (MediaItem is not null)
        {
            @* ── Media Sections ── *@
            <DrawerSection Title="@L["VaultDetail_SectionSourceDetails"]" Icon="@Icons.Material.Outlined.Storage">
                <div class="vdd-source">
                    <span class="vdd-location-badge @(IsInLibrary ? "vdd-location--library" : "vdd-location--staging")">
                        @(IsInLibrary ? L["VaultDetail_LocationLibrary"] : L["VaultDetail_LocationStaging"])
                    </span>
                    <div class="vdd-file-block">
                        <span class="vdd-field-label">@L["VaultDetail_FieldFileIdentity"]</span>
                        <p class="vdd-file-name">@(MediaItem.FileName ?? L["VaultDetail_Unknown"])</p>
                    </div>
                    @if (MediaItem.FileSizeBytes.HasValue)
                    {
                        <div class="vdd-field-row">
                            <span class="vdd-field-label">@L["VaultDetail_FieldSize"]</span>
                            <span class="vdd-field-value">@VaultHelpers.FormatFileSize(MediaItem.FileSizeBytes)</span>
                        </div>
                    }
                </div>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionPipeline"]" Icon="@Icons.Material.Outlined.AccountTree"
                           HasProblem="@(MediaItem.VaultDisplayStatus is VaultStatus.NeedsReview or VaultStatus.Failed)"
                           DefaultOpen="@(MediaItem.VaultDisplayStatus != VaultStatus.Verified)">
                <div class="vdd-pipeline">
                    @if (MediaItem.VaultDisplayStatus is VaultStatus.NeedsReview or VaultStatus.Failed && !string.IsNullOrEmpty(MediaItem.ReviewTrigger))
                    {
                        <div class="vdd-review-banner">
                            <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Style="font-size: 16px;" />
                            <span>@VaultHelpers.GetReviewTriggerLabel(MediaItem.ReviewTrigger)</span>
                        </div>
                    }
                    @* Retail Stage *@
                    <div class="vdd-stage-block">
                        <div class="vdd-stage-header">
                            <span class="vdd-stage-label">@L["VaultDetail_StageRetail"]</span>
                            <div class="vdd-stage-actions">
                                <span class="vdd-stage-status" style="color: @VaultHelpers.GetStageColor(MediaItem.Stage1.State); border-color: @(VaultHelpers.HexToRgba(VaultHelpers.GetStageColor(MediaItem.Stage1.State), 0.2));">
                                    @MediaItem.Stage1.Label
                                </span>
                            </div>
                        </div>
                        @if (MediaItem.RetailMatch is not "none" and not "" && MediaItem.RetailMatch is not null)
                        {
                            <div class="vdd-match-card">
                                <div class="vdd-match-info">
                                    <span class="vdd-field-label">@L["VaultDetail_FieldRetailMatch"]</span>
                                    <span class="vdd-match-value">@MediaItem.RetailMatch</span>
                                </div>
                                <span class="vdd-match-tag vdd-match-tag--provider">@L["VaultDetail_TagProvider"]</span>
                            </div>
                            @if (MediaItem.Confidence > 0)
                            {
                                <div class="vdd-match-card">
                                    <div class="vdd-match-info">
                                        <span class="vdd-field-label">@L["VaultDetail_FieldConfidenceScore"]</span>
                                        <span class="vdd-match-value">@((MediaItem.Confidence * 100).ToString("F0"))%</span>
                                    </div>
                                    <span class="vdd-match-tag" style="color: @VaultHelpers.GetConfidenceColor(MediaItem.Confidence);">@L["VaultDetail_TagAi"]</span>
                                </div>
                            }
                            <div class="vdd-rematch-block">
                                <button class="vdd-rematch-btn" @onclick="() => _showRematch = !_showRematch">
                                    <MudIcon Icon="@Icons.Material.Outlined.FindReplace" Style="font-size: 12px;" />
                                    @(_showRematch ? "Cancel" : "Find different match")
                                </button>
                            </div>
                            @if (_showRematch)
                            {
                                <div class="vdd-search-block">
                                    <input type="text" class="vdd-search-input" placeholder="Search for a match..."
                                           @bind="_manualSearchQuery" @bind:event="oninput" />
                                    <button class="vdd-search-btn" @onclick="RunManualSearch"
                                            disabled="@(string.IsNullOrWhiteSpace(_manualSearchQuery))">
                                        <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 14px;" />
                                        Search
                                    </button>
                                </div>
                                @if (_searching)
                                {
                                    <div style="padding: 8px 0; text-align: center;">
                                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.2);" />
                                    </div>
                                }
                                else if (_searchResults.Count > 0)
                                {
                                    <div class="vdd-search-results">
                                        @foreach (var result in _searchResults)
                                        {
                                            <div class="vdd-search-result-item" @onclick="() => SelectSearchResult(result)">
                                                <div class="vdd-search-result-thumb">
                                                    @if (!string.IsNullOrEmpty(result.CoverUrl))
                                                    {
                                                        <img src="@result.CoverUrl" alt="" loading="lazy" />
                                                    }
                                                    else
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                                    }
                                                </div>
                                                <div class="vdd-search-result-info">
                                                    <span class="vdd-search-result-title">@result.Title</span>
                                                    <span class="vdd-search-result-meta">@result.Author • @result.Year</span>
                                                </div>
                                                @if (_pendingMatch?.EntityId == result.EntityId)
                                                {
                                                    <button class="vdd-confirm-match-btn" @onclick:stopPropagation="true"
                                                            @onclick="() => ConfirmMatch(result.EntityId)">
                                                        Confirm
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                else if (_manualSearchQuery is { Length: > 0 })
                                {
                                    <p class="vdd-stage-hint">No results found for "@_manualSearchQuery"</p>
                                }
                            }
                        }
                        else
                        {
                            <p class="vdd-stage-hint">@L["VaultDetail_HintAwaitingRetail"]</p>
                            <div class="vdd-search-block">
                                <input type="text" class="vdd-search-input" placeholder="Search for a match..."
                                       @bind="_manualSearchQuery" @bind:event="oninput" />
                                <button class="vdd-search-btn" @onclick="RunManualSearch"
                                        disabled="@(string.IsNullOrWhiteSpace(_manualSearchQuery))">
                                    <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 14px;" />
                                    Search
                                </button>
                            </div>
                            @if (_searching)
                            {
                                <div style="padding: 8px 0; text-align: center;">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.2);" />
                                </div>
                            }
                            else if (_searchResults.Count > 0)
                            {
                                <div class="vdd-search-results">
                                    @foreach (var result in _searchResults)
                                    {
                                        <div class="vdd-search-result-item" @onclick="() => SelectSearchResult(result)">
                                            <div class="vdd-search-result-thumb">
                                                @if (!string.IsNullOrEmpty(result.CoverUrl))
                                                {
                                                    <img src="@result.CoverUrl" alt="" loading="lazy" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                                }
                                            </div>
                                            <div class="vdd-search-result-info">
                                                <span class="vdd-search-result-title">@result.Title</span>
                                                <span class="vdd-search-result-meta">@result.Author • @result.Year</span>
                                            </div>
                                            @if (_pendingMatch?.EntityId == result.EntityId)
                                            {
                                                <button class="vdd-confirm-match-btn" @onclick:stopPropagation="true"
                                                        @onclick="() => ConfirmMatch(result.EntityId)">
                                                    Confirm
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else if (_manualSearchQuery is { Length: > 0 })
                            {
                                <p class="vdd-stage-hint">No results found for "@_manualSearchQuery"</p>
                            }
                            <div class="vdd-provider-chips">
                                @foreach (var provider in VaultHelpers.GetProviderButtons(MediaItem.MediaType))
                                {
                                    <button class="vdd-provider-chip">@provider</button>
                                }
                            </div>
                        }
                    </div>

                    @* Wikidata Stage *@
                    <div class="vdd-stage-block">
                        <div class="vdd-stage-header">
                            <span class="vdd-stage-label">@L["VaultDetail_StageWikidata"]</span>
                            <div class="vdd-stage-actions">
                                <span class="vdd-stage-status" style="color: @VaultHelpers.GetStageColor(MediaItem.Stage2.State); border-color: @(VaultHelpers.HexToRgba(VaultHelpers.GetStageColor(MediaItem.Stage2.State), 0.2));">
                                    @MediaItem.Stage2.Label
                                </span>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(MediaItem.WikidataQid))
                        {
                            <div class="vdd-qid-result">
                                <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 14px; color: #A78BFA;" />
                                <span>@L["VaultDetail_Linked"] @MediaItem.WikidataQid</span>
                            </div>
                            @if (MediaItem.WikidataMatch is not "none" and not "" && MediaItem.WikidataMatch is not null)
                            {
                                <div class="vdd-match-card">
                                    <div class="vdd-match-info">
                                        <span class="vdd-field-label">@L["VaultDetail_FieldWikidataMatch"]</span>
                                        <span class="vdd-match-value">@MediaItem.WikidataMatch</span>
                                    </div>
                                    <span class="vdd-match-tag vdd-match-tag--authority">@L["VaultDetail_TagAuthority"]</span>
                                </div>
                            }
                        }
                        else if (MediaItem.RetailMatch is not "none" and not "" && MediaItem.RetailMatch is not null)
                        {
                            <p class="vdd-stage-hint">@L["VaultDetail_HintRetailMatchedSearchWikidata"]</p>
                        }
                        else
                        {
                            <p class="vdd-stage-hint">@L["VaultDetail_HintCompleteStage1First"]</p>
                        }
                    </div>

                    <p class="vdd-cascade-note">@L["VaultDetail_CascadeNote"]</p>
                </div>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
                <div class="vdd-assets">
                    @* Cover Art *@
                    <div class="vdd-asset-row">
                        <span class="vdd-asset-label">@L["VaultDetail_AssetCoverArt"]</span>
                        <div class="vdd-asset-items">
                            @if (!string.IsNullOrEmpty(MediaItem.CoverUrl))
                            {
                                <div class="vdd-asset-filled">
                                    <img src="@MediaItem.CoverUrl" alt="Cover" class="vdd-asset-img" />
                                    <span class="vdd-asset-source">@L["VaultDetail_AssetSourceProvider"]</span>
                                </div>
                            }
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetCustom"]</span>
                            </div>
                        </div>
                    </div>
                    @* Hero Banner *@
                    <div class="vdd-asset-row">
                        <span class="vdd-asset-label">@L["VaultDetail_AssetHeroBanner"]</span>
                        <div class="vdd-asset-items">
                            @if (!string.IsNullOrEmpty(MediaItem.HeroUrl))
                            {
                                <div class="vdd-asset-filled vdd-asset-filled--wide">
                                    <img src="@MediaItem.HeroUrl" alt="Hero" class="vdd-asset-img" />
                                    <span class="vdd-asset-source">@L["VaultDetail_AssetSourceGenerated"]</span>
                                </div>
                            }
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetCustom"]</span>
                            </div>
                        </div>
                    </div>
                    @* Remaining types as upload-only *@
                    @foreach (var assetType in new[] { "Logo", "Backdrop" })
                    {
                        <div class="vdd-asset-row">
                            <span class="vdd-asset-label">@assetType</span>
                            <div class="vdd-asset-items">
                                <div class="vdd-asset-slot">
                                    <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                    <span class="vdd-asset-upload">@L["VaultDetail_AssetUpload"]</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionLifecycle"]" Icon="@Icons.Material.Outlined.Sync">
                <div class="vdd-lifecycle">
                    <div class="vdd-lifecycle-card">
                        <span class="vdd-field-label">@L["VaultDetail_FieldState"]</span>
                        <div class="vdd-lifecycle-value" style="color: #5DCAA5;">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="font-size: 14px;" />
                            @L["VaultDetail_StateSynced"]
                        </div>
                    </div>
                    <div class="vdd-lifecycle-card">
                        <span class="vdd-field-label">@L["VaultDetail_FieldAdded"]</span>
                        <span class="vdd-lifecycle-value vdd-mono">@MediaItem.CreatedAt.ToString("MMM dd, HH:mm")</span>
                    </div>
                </div>
            </DrawerSection>
        }
        else if (Person is not null)
        {
            @* ── Person Sections ── *@
            <DrawerSection Title="@L["VaultDetail_SectionLibraryPresence"]" Icon="@Icons.Material.Outlined.LibraryBooks">
                <p class="vdd-empty-hint">@L["VaultDetail_HintPersonPresence"]</p>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionLinkedIdentities"]" Icon="@Icons.Material.Outlined.Fingerprint">
                <div class="vdd-identities">
                    <div class="vdd-identity-group">
                        <span class="vdd-field-label">@L["VaultDetail_FieldKnownAs"]</span>
                        <div class="vdd-identity-items">
                            <div class="vdd-identity-item">
                                <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 14px; color: rgba(255,255,255,0.3);" />
                                <span>@Person.Name</span>
                            </div>
                        </div>
                    </div>
                    <div class="vdd-identity-group" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.04);">
                        <span class="vdd-field-label">@(Person.IsPseudonym ? L["VaultDetail_FieldRealPeople"] : L["VaultDetail_FieldPenNames"])</span>
                        @if (_aliases is not null && _aliases.Aliases.Count > 0)
                        {
                            <div class="vdd-identity-items">
                                @foreach (var alias in _aliases.Aliases.OrderByDescending(a => !string.IsNullOrEmpty(a.WikidataQid)))
                                {
                                    @if (!string.IsNullOrEmpty(alias.WikidataQid))
                                    {
                                        <button class="vdd-identity-link" @onclick="() => OnPersonAliasClicked.InvokeAsync(alias.Id)">
                                            <MudIcon Icon="@Icons.Material.Outlined.Link" Style="font-size: 14px; color: #60A5FA;" />
                                            <span>@alias.Name</span>
                                            <span class="vdd-alias-relationship">@(alias.Relationship == "real_person" ? "Real person" : "Pen name")</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="vdd-identity-item">
                                            <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 14px; color: rgba(255,255,255,0.3);" />
                                            <span>@alias.Name</span>
                                            <span class="vdd-alias-relationship">@(alias.Relationship == "real_person" ? "Real person" : "Pen name")</span>
                                        </div>
                                    }
                                }
                            </div>
                        }
                        else
                        {
                            <p class="vdd-empty-hint">@L["VaultDetail_HintPenNames"]</p>
                        }
                    </div>
                </div>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
                <div class="vdd-assets">
                    @* Headshot *@
                    <div class="vdd-asset-row">
                        <span class="vdd-asset-label">@L["VaultDetail_AssetHeadshot"]</span>
                        <div class="vdd-asset-items">
                            @if (!string.IsNullOrEmpty(Person.HeadshotUrl))
                            {
                                <div class="vdd-asset-filled">
                                    <img src="@Person.HeadshotUrl" alt="Headshot" class="vdd-asset-img" />
                                    <span class="vdd-asset-source">@L["VaultDetail_AssetSourceProvider"]</span>
                                </div>
                            }
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetCustom"]</span>
                            </div>
                        </div>
                    </div>
                    @* Remaining types as upload-only *@
                    @foreach (var assetType in new[] { "Banner", "Logo", "Backdrop" })
                    {
                        <div class="vdd-asset-row">
                            <span class="vdd-asset-label">@assetType</span>
                            <div class="vdd-asset-items">
                                <div class="vdd-asset-slot">
                                    <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                    <span class="vdd-asset-upload">@L["VaultDetail_AssetUpload"]</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionLifecycle"]" Icon="@Icons.Material.Outlined.CalendarToday">
                <div class="vdd-lifecycle">
                    <div class="vdd-lifecycle-card" style="flex: 1;">
                        <span class="vdd-field-label">@L["VaultDetail_FieldLastSync"]</span>
                        <span class="vdd-lifecycle-value vdd-mono">@L["VaultDetail_ValueAutoManaged"]</span>
                    </div>
                </div>
            </DrawerSection>
        }
        else if (Universe is not null)
        {
            @* ── Universe Sections ── *@
            <DrawerSection Title="@L["VaultDetail_SectionUniverseContent"]" Icon="@Icons.Material.Outlined.Layers">
                <div class="vdd-universe-content">
                    @if (Universe.WorkCount > 0)
                    {
                        <p class="vdd-field-value">@Universe.WorkCount @L["VaultDetail_WorksAcross"] @(Universe.MediaTypes ?? L["VaultDetail_VariousMediaTypes"])</p>
                    }
                    else
                    {
                        <p class="vdd-empty-hint">@L["VaultDetail_HintNoSeriesLinked"]</p>
                    }
                </div>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionNotablePeople"]" Icon="@Icons.Material.Outlined.People">
                <p class="vdd-empty-hint">@L["VaultDetail_HintPeopleAssociated"]</p>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
                <div class="vdd-assets">
                    @foreach (var assetType in _assetTypes)
                    {
                        <div class="vdd-asset-row">
                            <span class="vdd-asset-label">@assetType</span>
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 20px; color: rgba(255,255,255,0.08);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetUpload"]</span>
                            </div>
                        </div>
                    }
                </div>
            </DrawerSection>
        }
    </div>

    @* ── 3. Pinned Footer (Media only) ── *@
    @if (MediaItem is not null)
    {
        <div class="vdd-footer">
            <button class="vdd-purge-btn @(_confirmPurge ? "vdd-purge-btn--confirm" : "")"
                    @onclick="HandlePurge">
                @if (_confirmPurge)
                {
                    <span>@L["VaultDetail_ConfirmPurge"]</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.DeleteForever" Style="font-size: 16px;" />
                    <span>@L["VaultDetail_ActionPurgeRecord"]</span>
                }
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public VaultItemViewModel? MediaItem { get; set; }
    [Parameter] public PersonListItemDto? Person { get; set; }
    [Parameter] public HubViewModel? Universe { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Guid> OnPurge { get; set; }
    [Parameter] public EventCallback<Guid> OnUnmatchRetail { get; set; }
    [Parameter] public EventCallback<Guid> OnUnmatchWikidata { get; set; }
    [Parameter] public EventCallback<Guid> OnApplyMatch { get; set; }
    [Parameter] public EventCallback<Guid> OnPersonAliasClicked { get; set; }

    private bool _confirmPurge;
    private static readonly string[] _assetTypes = ["Cover Art", "Headshot", "Banner", "Logo", "Backdrop"];
    private string _manualSearchQuery = "";
    private bool _showRematch;
    private bool _searching;
    private List<RegistryItemViewModel> _searchResults = [];
    private PersonAliasesResponseDto? _aliases;
    private RegistryItemViewModel? _pendingMatch;

    private bool IsInLibrary => MediaItem?.Status?.Equals("Confirmed", StringComparison.OrdinalIgnoreCase) == true
                             || MediaItem?.VaultDisplayStatus == VaultStatus.Verified;

    private async Task HandleUnmatchRetail()
    {
        if (MediaItem is not null)
            await OnUnmatchRetail.InvokeAsync(MediaItem.EntityId);
    }

    private async Task HandleUnmatchWikidata()
    {
        if (MediaItem is not null)
            await OnUnmatchWikidata.InvokeAsync(MediaItem.EntityId);
    }

    protected override async Task OnParametersSetAsync()
    {
        _confirmPurge = false;
        _manualSearchQuery = "";
        _showRematch = false;
        _searchResults = [];
        _aliases = null;
        _pendingMatch = null;
        _searching = false;

        if (Person is not null)
        {
            _aliases = await ApiClient.GetPersonAliasesAsync(Person.Id);
        }
    }

    private async Task RunManualSearch()
    {
        if (string.IsNullOrWhiteSpace(_manualSearchQuery)) return;
        _searching = true;
        StateHasChanged();

        var response = await ApiClient.GetRegistryItemsAsync(
            offset: 0, limit: 10,
            search: _manualSearchQuery);
        _searchResults = response?.Items?.ToList() ?? [];
        _searching = false;
    }

    private void SelectSearchResult(RegistryItemViewModel result)
    {
        // Toggle: clicking same item deselects, clicking different item selects
        _pendingMatch = _pendingMatch?.EntityId == result.EntityId ? null : result;
    }

    private async Task ConfirmMatch(Guid entityId)
    {
        _pendingMatch = null;
        _searchResults = [];
        _manualSearchQuery = "";
        _showRematch = false;
        await OnApplyMatch.InvokeAsync(entityId);
    }

    private async Task HandlePurge()
    {
        if (_confirmPurge && MediaItem is not null)
        {
            await OnPurge.InvokeAsync(MediaItem.EntityId);
            _confirmPurge = false;
        }
        else
        {
            _confirmPurge = true;
        }
    }
}

