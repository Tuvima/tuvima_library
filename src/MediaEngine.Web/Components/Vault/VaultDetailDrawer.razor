    .vdd-detail-fields {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .vdd-detail-field {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .vdd-confirm-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .vdd-confirm-prompt {
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.6);
    }

    .vdd-cancel-match-btn {
        padding: 4px 12px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.5);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-cancel-match-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.8);
    }

    .vdd-or-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 4px 0;
    }

    .vdd-or-divider::before,
    .vdd-or-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.06);
    }

    .vdd-or-divider span {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: rgba(255, 255, 255, 0.25);
    }

    .vdd-purge-confirm-row {
        display: flex;
        align-items: center;
        gap: 8px;
        justify-content: center;
    }

    .vdd-purge-confirm-text {
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 80, 80, 0.8);
    }

    .vdd-purge-cancel-btn {
        padding: 6px 14px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.5);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-purge-cancel-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.8);
    }

    .vdd-search-result-thumb {
        width: 36px;
        height: 52px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        position: relative;
        z-index: 1;
    }

    .vdd-search-result-thumb:hover {
        transform: scale(3);
        z-index: 50;
        box-shadow: 0 8px 32px rgba(0,0,0,0.8);
    }

    .vdd-search-result-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .vdd-search-result-info {
        flex: 1;
        min-width: 0;
    }

    .vdd-search-result-title {
        display: block;
        font-size: 12px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.85);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vdd-search-result-meta {
        display: block;
        font-size: 10px;
        color: rgba(255, 255, 255, 0.35);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vdd-search-result-desc {
        display: block;
        font-size: 10px;
        color: rgba(255, 255, 255, 0.25);
        margin-top: 2px;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .vdd-search-results-header {
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.25);
        padding: 6px 0 2px;
    }

    .vdd-confirm-match-btn {
        padding: 4px 12px;
        border-radius: 6px;
        background: rgba(93, 202, 165, 0.15);
        border: 1px solid rgba(93, 202, 165, 0.3);
        color: #5DCAA5;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.15s;
        flex-shrink: 0;
        animation: vdd-pulse 0.3s ease-out;
    }

    .vdd-confirm-match-btn:hover {
        background: rgba(93, 202, 165, 0.25);
        border-color: rgba(93, 202, 165, 0.5);
    }

    @@keyframes vdd-pulse {
        from { transform: scale(0.9); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }

    .vdd-rematch-block {
        margin-top: 8px;
    }

    .vdd-rematch-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 6px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.4);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-rematch-btn:hover {
        background: rgba(96, 165, 250, 0.08);
        border-color: rgba(96, 165, 250, 0.2);
        color: #60A5FA;
    }

    /* ── Pen name linking ── */
    .vdd-identity-link {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #60A5FA;
        font-weight: 600;
        background: none;
        border: none;
        padding: 4px 0;
        cursor: pointer;
        transition: color 0.15s;
        text-align: left;
        width: 100%;
    }

    .vdd-identity-link:hover {
        color: #93C5FD;
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .vdd-alias-relationship {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: rgba(255, 255, 255, 0.25);
        margin-left: auto;
        flex-shrink: 0;
    }

    /* ── Footer ── */
    .vdd-footer {
        padding: 20px 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
        flex-shrink: 0;
    }

    .vdd-purge-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 8px;
        background: transparent;
        border: 1px solid rgba(255, 80, 80, 0.2);
        color: rgba(255, 80, 80, 0.5);
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-purge-btn:hover {
        background: rgba(255, 80, 80, 0.08);
        border-color: rgba(255, 80, 80, 0.4);
        color: rgba(255, 80, 80, 0.8);
    }

    .vdd-purge-btn--confirm {
        background: rgba(255, 80, 80, 0.12);
        border-color: rgba(255, 80, 80, 0.5);
        color: rgba(255, 80, 80, 1);
    }

    /* ── Universe Health Ring ── */
    .vdd-health-ring-wrap {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 24px;
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .vdd-health-ring {
        position: relative;
        width: 64px;
        height: 64px;
        flex-shrink: 0;
    }

    .vdd-health-pct {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 900;
    }

    .vdd-health-label-block {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .vdd-health-title {
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.4);
    }

    .vdd-health-sub {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.6);
    }

    /* ── Entity Counts ── */
    .vdd-entity-counts {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .vdd-entity-count-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    }

    .vdd-entity-count-item:last-child { border-bottom: none; }

    .vdd-entity-count-label {
        flex: 1;
        font-size: 12px;
        color: rgba(255, 255, 255, 0.55);
    }

    .vdd-entity-count-val {
        font-size: 13px;
        font-weight: 800;
        color: white;
    }

    /* ── Character Grid ── */
    .vdd-characters-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .vdd-character-item {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .vdd-character-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(167, 139, 250, 0.08);
        border: 1px solid rgba(167, 139, 250, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        overflow: hidden;
    }

    .vdd-character-avatar--sm {
        width: 34px;
        height: 34px;
    }

    .vdd-character-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .vdd-character-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .vdd-character-name {
        font-size: 13px;
        font-weight: 700;
        color: white;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vdd-character-actor {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.45);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vdd-actor-count-badge {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #C9922E;
        background: rgba(201, 146, 46, 0.1);
        border: 1px solid rgba(201, 146, 46, 0.2);
        border-radius: 4px;
        padding: 2px 5px;
        align-self: flex-start;
    }

    /* ── Character Roles (Person view) ── */
    .vdd-role-universe-group {
        margin-bottom: 14px;
    }

    .vdd-role-universe-label {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.25);
        display: block;
        margin-bottom: 8px;
    }

    .vdd-roles-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .vdd-role-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        width: 60px;
    }

    /* ── Universe Action Buttons ── */
    .vdd-universe-actions {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 16px 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
    }

    .vdd-action-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 8px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.55);
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-action-btn:hover {
        background: rgba(255, 255, 255, 0.04);
        color: rgba(255, 255, 255, 0.85);
        border-color: rgba(255, 255, 255, 0.2);
    }

    .vdd-action-btn--primary {
        border-color: rgba(167, 139, 250, 0.3);
        color: #A78BFA;
    }

    .vdd-action-btn--primary:hover {
        background: rgba(167, 139, 250, 0.08);
        border-color: rgba(167, 139, 250, 0.5);
        color: #C4B5FD;
    }

    .vdd-type-selector {
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .vdd-type-dropdown {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 4px;
        color: rgba(255,255,255,0.7);
        font-size: 11px;
        letter-spacing: 0.05em;
        padding: 2px 6px;
        cursor: pointer;
        outline: none;
        font-family: inherit;
        text-transform: uppercase;
    }

    .vdd-type-dropdown:hover {
        border-color: rgba(201,146,46,0.4);
        color: rgba(255,255,255,0.9);
    }

    .vdd-type-dropdown:focus {
        border-color: #C9922E;
        box-shadow: 0 0 0 1px rgba(201,146,46,0.2);
    }

    .vdd-type-dropdown option {
        background: #1a1a2e;
        color: rgba(255,255,255,0.9);
    }

    /* ── Pipeline matched lines ── */
    .vdd-pipeline-matched {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .vdd-pipeline-line {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
    }

    .vdd-pipeline-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .vdd-pipeline-dot--ok {
        background: #5DCAA5;
        box-shadow: 0 0 6px rgba(93,202,165,0.4);
    }

    .vdd-pipeline-dot--fail {
        background: #A05050;
        box-shadow: 0 0 6px rgba(160,80,80,0.3);
    }

    .vdd-pipeline-dot--warn {
        background: #C9922E;
        box-shadow: 0 0 6px rgba(201,146,46,0.4);
    }

    .vdd-pipeline-qid-link {
        font-size: 13px;
        font-weight: 700;
        color: #A78BFA;
        text-decoration: none;
    }

    .vdd-pipeline-qid-link:hover {
        text-decoration: underline;
    }

    /* ── Unified search ── */
    .vdd-unified-search {
        margin-top: 8px;
    }

    .vdd-search-row {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .vdd-search-row .vdd-search-input {
        flex: 1;
    }

    .vdd-search-row .vdd-type-dropdown {
        width: auto;
        min-width: 100px;
    }

    /* ── Filter-based search UI ── */
    .vdd-search-bar-wrap { display: flex; flex-direction: column; gap: 8px; margin-top: 12px; }
    .vdd-search-type-row { display: flex; align-items: center; gap: 8px; }
    .vdd-search-type-label { font-size: 11px; color: rgba(255,255,255,0.4); }
    .vdd-search-main-row { display: flex; gap: 8px; align-items: stretch; }
    .vdd-search-input-group {
        flex: 1; display: flex; align-items: center; gap: 8px;
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px; padding: 8px 12px;
    }
    .vdd-search-primary-input {
        flex: 1; background: transparent; border: none; outline: none;
        color: rgba(255,255,255,0.9); font-size: 13px; font-family: inherit;
    }
    .vdd-search-primary-input::placeholder { color: rgba(255,255,255,0.25); }
    .vdd-primary-field-btn {
        display: flex; align-items: center; gap: 2px;
        font-size: 11px; color: rgba(255,255,255,0.6);
        background: rgba(255,255,255,0.06); border: none;
        padding: 3px 8px; border-radius: 6px; cursor: pointer; white-space: nowrap; font-family: inherit;
    }
    .vdd-primary-field-btn:hover { background: rgba(255,255,255,0.1); }
    .vdd-add-filter-btn {
        display: flex; align-items: center; gap: 4px;
        font-size: 11px; color: rgba(255,255,255,0.5);
        background: none; border: 1px solid rgba(255,255,255,0.08);
        padding: 3px 10px; border-radius: 8px; cursor: pointer; white-space: nowrap; font-family: inherit;
    }
    .vdd-add-filter-btn:hover { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.7); }
    .vdd-search-execute-btn {
        padding: 8px 20px; font-size: 13px; border-radius: 12px;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.7); cursor: pointer; white-space: nowrap; font-family: inherit;
    }
    .vdd-search-execute-btn:hover { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.9); }
    .vdd-search-execute-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .vdd-dropdown-wrap { position: relative; }
    .vdd-dropdown-btn {
        display: flex; align-items: center; gap: 4px;
        font-size: 13px; color: rgba(255,255,255,0.8);
        background: none; border: 1px solid rgba(255,255,255,0.1);
        padding: 4px 12px; border-radius: 10px; cursor: pointer; font-family: inherit;
    }
    .vdd-dropdown-btn:hover { background: rgba(255,255,255,0.06); }
    .vdd-dropdown-menu {
        position: absolute; left: 0; top: calc(100% + 4px); z-index: 10;
        min-width: 160px; background: #121826; border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,0.5); overflow: hidden;
    }
    .vdd-dropdown-item {
        padding: 8px 14px; font-size: 13px; color: rgba(255,255,255,0.7);
        cursor: pointer;
    }
    .vdd-dropdown-item:hover { background: rgba(255,255,255,0.06); }
    .vdd-filter-pills { display: flex; flex-wrap: wrap; gap: 8px; }
    .vdd-filter-pill {
        display: flex; align-items: center; gap: 6px;
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px; padding: 6px 10px;
    }
    .vdd-filter-pill-label { font-size: 11px; color: rgba(255,255,255,0.4); white-space: nowrap; }
    .vdd-filter-pill-input {
        background: transparent; border: none; outline: none;
        color: rgba(255,255,255,0.8); font-size: 12px; width: 100px; font-family: inherit;
    }
    .vdd-filter-pill-input::placeholder { color: rgba(255,255,255,0.2); }
    .vdd-filter-pill-remove {
        background: none; border: none; color: rgba(255,255,255,0.3);
        cursor: pointer; padding: 0; display: flex;
    }
    .vdd-filter-pill-remove:hover { color: rgba(255,255,255,0.6); }

    /* ── Result detail below (not beside) ── */
    .vdd-search-result-detail-below {
        padding: 10px 12px 12px;
        border-top: 1px solid rgba(255,255,255,0.04);
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .vdd-detail-description {
        font-size: 12px;
        color: rgba(255,255,255,0.5);
        line-height: 1.5;
        margin: 0;
    }

    .vdd-detail-fields-compact {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .vdd-detail-field-inline {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* ── Bridge ID chips ── */
    .vdd-bridge-chips {
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
        margin: 6px 0;
    }

    .vdd-bridge-chip {
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 3px;
        background: rgba(93,202,165,0.12);
        color: rgba(93,202,165,0.7);
    }

    /* ── Status section ── */
    .vdd-status {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .vdd-status-row {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    /* ── Metadata section ── */
    .vdd-metadata {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .vdd-metadata-tabs {
        display: flex;
        gap: 4px;
        background: rgba(255,255,255,0.02);
        border-radius: 8px;
        padding: 3px;
    }

    .vdd-meta-tab {
        flex: 1;
        padding: 6px 12px;
        border: none;
        background: transparent;
        color: rgba(255,255,255,0.4);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-meta-tab:hover {
        color: rgba(255,255,255,0.6);
    }

    .vdd-meta-tab--active {
        background: rgba(96,165,250,0.1);
        color: #60A5FA;
    }

    .vdd-metadata-list {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    /* ── Claims rows (FIX A6) ── */
    .vdd-claim-row {
        display: flex;
        align-items: baseline;
        gap: 8px;
        padding: 4px 0;
        border-bottom: 1px solid rgba(255,255,255,0.03);
    }

    .vdd-claim-row .vdd-field-label {
        min-width: 80px;
        flex-shrink: 0;
    }

    .vdd-claim-row .vdd-field-value {
        flex: 1;
        word-break: break-word;
    }

    .vdd-claim-confidence {
        font-size: 11px;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        flex-shrink: 0;
    }

    /* ── Provider URL link (FIX A7) ── */
    .vdd-provider-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
