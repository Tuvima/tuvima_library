@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Domain.Constants
@using MediaEngine.Domain.Enums
@namespace MediaEngine.Web.Components.Vault
@inject IStringLocalizer<SharedStrings> L
@inject IEngineApiClient ApiClient
@inject NavigationManager Nav

@* ── Backdrop ── *@
<div class="vdd-backdrop" @onclick="OnClose"></div>

@* ── Drawer Panel ── *@
<div class="vdd-drawer" @onclick:stopPropagation="true">

    @* ── 1. Pinned Header ── *@
    <div class="vdd-header">
        <MudIconButton Icon="@Icons.Material.Outlined.Close"
                       Size="Size.Small"
                       Style="position:absolute;top:24px;right:24px;color:rgba(255,255,255,0.5);"
                       OnClick="OnClose" />

        @if (MediaItem is not null)
        {
            @* ── Media Header ── *@
            <div class="vdd-header-content">
                <div class="vdd-thumb-wrap">
                    @if (!string.IsNullOrEmpty(MediaItem.CoverUrl))
                    {
                        <img src="@MediaItem.CoverUrl" alt="" class="vdd-thumb-img" loading="lazy" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 48px; color: rgba(255,255,255,0.1);" />
                    }
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        @if (!IsInLibrary)
                        {
                            <span class="vdd-location-chip vdd-location-chip--staging">
                                Staging
                            </span>
                        }
                        <StatusPill Status="@MediaItem.VaultDisplayStatus" QuarantineDays="@MediaItem.QuarantineDays" />
                        @if (!string.IsNullOrEmpty(MediaItem.WikidataQid))
                        {
                            <a href="https://www.wikidata.org/wiki/@MediaItem.WikidataQid" target="_blank" rel="noopener" class="vdd-qid-badge">
                                <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 11px;" />
                                @MediaItem.WikidataQid
                            </a>
                            <a href="https://www.wikidata.org/wiki/Special:GoToLinkedPage/@(MediaItem.WikidataQid)/enwiki" target="_blank" rel="noopener" class="vdd-wiki-badge" title="Open Wikipedia article">
                                <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 11px;" />
                                Wikipedia
                            </a>
                        }
                    </div>
                    <h2 class="vdd-title">@MediaItem.Title</h2>
                    @{
                        var drawerCreator = MediaItem.MediaType switch
                        {
                            "Movies" => MediaItem.Director ?? MediaItem.Author,
                            "TV" => MediaItem.Director,
                            "Music" => MediaItem.Artist ?? MediaItem.Author,
                            _ => MediaItem.Author,
                        };
                    }
                    @if (!string.IsNullOrEmpty(drawerCreator))
                    {
                        <p class="vdd-subtitle vdd-subtitle--clickable" @onclick="() => NavigateToCreatorPerson(drawerCreator)">
                            @drawerCreator.ToUpperInvariant()
                        </p>
                    }
                    <div class="vdd-meta">
                        <span class="vdd-meta-item" style="color: @VaultHelpers.GetMediaTypeColor(MediaItem.MediaType);">
                            <MudIcon Icon="@VaultHelpers.GetMediaTypeIcon(MediaItem.MediaType)" Style="font-size: 14px;" />
                            @VaultHelpers.FormatMediaType(MediaItem.MediaType)
                        </span>
                        @if (!string.IsNullOrEmpty(MediaItem.Year))
                        {
                            <span class="vdd-meta-item">@MediaItem.Year</span>
                        }
                    </div>
                    <p class="vdd-added-date">Added @MediaItem.CreatedAt.ToString("MMM dd, yyyy")</p>
                </div>
            </div>
        }
        else if (Person is not null)
        {
            @* ── Person Header ── *@
            <div class="vdd-header-content">
                <div class="vdd-avatar-round">
                    @if (!string.IsNullOrEmpty(Person.HeadshotUrl))
                    {
                        <img src="@Person.HeadshotUrl" alt="" class="vdd-avatar-img" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 48px; color: rgba(255,255,255,0.1);" />
                    }
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        @foreach (var role in Person.Roles)
                        {
                            <span class="vdd-role-chip">@role.ToUpperInvariant()</span>
                        }
                        @if (!string.IsNullOrEmpty(Person.WikidataQid))
                        {
                            <a href="https://www.wikidata.org/wiki/@Person.WikidataQid" target="_blank" rel="noopener" class="vdd-qid-badge">
                                <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="font-size: 11px;" />
                                @Person.WikidataQid
                            </a>
                        }
                    </div>
                    <h2 class="vdd-title">@Person.Name</h2>
                    @if (!string.IsNullOrEmpty(Person.Occupation))
                    {
                        <p class="vdd-subtitle-italic">@Person.Occupation</p>
                    }
                </div>
            </div>
        }
        else if (Universe is not null)
        {
            @* ── Universe Header ── *@
            <div class="vdd-header-content">
                <div class="vdd-universe-icon">
                    <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 48px; color: #A78BFA;" />
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        <StatusPill Status="VaultStatus.Verified" />
                    </div>
                    <h2 class="vdd-title">@Universe.DisplayName</h2>
                    <p class="vdd-subtitle-italic">@Universe.Description</p>
                </div>
            </div>
        }
    </div>

    @* ── 2. Scrollable Body ── *@
    <div class="vdd-body">
        @if (MediaItem is not null)
        {
            @* ── NeedsReview problem banner ── *@
            @if (MediaItem.VaultDisplayStatus == VaultStatus.NeedsReview && !string.IsNullOrEmpty(MediaItem.ReviewTrigger))
            {
                <div class="vdd-problem-banner">
                    <div class="vdd-problem-banner-top">
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 18px; color: #EF9F27; flex-shrink: 0;" />
                        <span class="vdd-problem-banner-msg">@VaultHelpers.GetReviewTriggerLabel(MediaItem.ReviewTrigger)</span>
                    </div>
                    <p class="vdd-problem-banner-hint">You can search for a match in the Pipeline section below, or check the File Info for clues.</p>
                </div>
            }

            @if (MediaItem.VaultDisplayStatus == VaultStatus.WaitingForProvider)
            {
                <div class="vdd-waiting-banner">
                    <MudIcon Icon="@Icons.Material.Outlined.Schedule" Style="font-size: 18px;" />
                    <span>
                        @if (!string.IsNullOrEmpty(MediaItem.FailedProviderName))
                        {
                            @L["VaultDetail_WaitingForProviderNamed", MediaItem.FailedProviderName]
                        }
                        else
                        {
                            @L["VaultDetail_WaitingForProvider"]
                        }
                    </span>
                </div>
            }

            @* ── Pipeline (circles + File/Retail/Wikidata tabs) ── *@
            <DrawerSection Title="Pipeline" Icon="@Icons.Material.Outlined.AccountTree"
                           HasProblem="@(!IsRealRetailMatch(MediaItem.RetailMatch) || !IsWikidataMatched(MediaItem.WikidataQid))"
                           DefaultOpen="true">

                @* Pipeline stage circles *@
                <div class="vdd-pipeline-circles-wrap">
                    <VaultPipelineCircles
                        Stage0="@(new VaultPipelineStage { State = VaultStageState.Completed, Label = "File scanned" })"
                        Stage1="@MediaItem.Stage1"
                        Stage2="@MediaItem.Stage2"
                        Stage3="@MediaItem.Stage3"
                        @bind-SelectedStage="_selectedStage" />
                </div>

                @* Tab bar *@
                <div class="vdd-stage-tabs">
                    <button class="vdd-stage-tab @(ActiveTab == 0 ? "vdd-stage-tab--active" : "")" @onclick="() => SetActiveTab(0)">
                        <MudIcon Icon="@Icons.Material.Outlined.InsertDriveFile" Style="font-size: 14px;" />
                        File
                    </button>
                    <button class="vdd-stage-tab @(ActiveTab == 1 ? "vdd-stage-tab--active" : "")" @onclick="() => SetActiveTab(1)">
                        <MudIcon Icon="@Icons.Material.Outlined.Store" Style="font-size: 14px;" />
                        Retail
                    </button>
                    <button class="vdd-stage-tab @(ActiveTab == 2 ? "vdd-stage-tab--active" : "")" @onclick="() => SetActiveTab(2)">
                        <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 14px;" />
                        Wikidata
                    </button>
                </div>

                @* ── Tab content ── *@
                @{
                    var hasRetail = IsRealRetailMatch(MediaItem.RetailMatch);
                    var hasWikidata = IsWikidataMatched(MediaItem.WikidataQid);
                    var hasRetailForWiki = hasRetail;
                    var retailClaims = _claims.Where(c =>
                        !VaultHelpers.IsFileSource(c.ProviderId) &&
                        !VaultHelpers.IsUserSource(c.ProviderId) &&
                        !c.ProviderId.ToString().Contains("b3000003")).ToList();
                    var wikiClaims = _claims.Where(c =>
                        c.ProviderId.ToString().Contains("b3000003")).ToList();
                }
                @switch (ActiveTab)
                {
                    case 0:
                        @* ── FILE TAB ── *@
                        <div class="vdd-tab-content">
                            <h4 class="vdd-tab-heading">Current Metadata</h4>
                            <div class="vdd-metadata-list">
                                @foreach (var (label, val) in GetCurrentMetadataRows())
                                {
                                    <div class="vdd-claim-row">
                                        <span class="vdd-field-label">@label</span>
                                        <span class="vdd-field-value">@val</span>
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(MediaItem.CoverUrl))
                            {
                                <div class="vdd-file-cover">
                                    <span class="vdd-field-label">Cover Art</span>
                                    <img src="@MediaItem.CoverUrl" alt="Cover" class="vdd-file-cover-img" loading="lazy" />
                                </div>
                            }

                            @* Collapsed original metadata *@
                            <details class="vdd-original-meta">
                                <summary class="vdd-original-meta-summary">Original File Metadata</summary>
                                <div class="vdd-metadata-list" style="margin-top: 8px;">
                                    @if (_claimsLoading)
                                    {
                                        <div style="padding: 8px 0; text-align: center;">
                                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.2);" />
                                        </div>
                                    }
                                    else
                                    {
                                        var fileClaims = _claims.Where(c => VaultHelpers.IsFileSource(c.ProviderId) || VaultHelpers.IsUserSource(c.ProviderId)).ToList();
                                        @if (fileClaims.Count == 0)
                                        {
                                            <p class="vdd-stage-hint">No file metadata extracted yet.</p>
                                        }
                                        else
                                        {
                                            @foreach (var group in fileClaims.GroupBy(c => c.ClaimKey).OrderBy(g => g.Key))
                                            {
                                                var bestClaim = group.OrderByDescending(c => c.Confidence).First();
                                                <div class="vdd-claim-row">
                                                    <span class="vdd-field-label">@FormatClaimKey(group.Key)</span>
                                                    <span class="vdd-field-value">@(bestClaim.ClaimValue.Length > 80 ? bestClaim.ClaimValue[..80] + "\u2026" : bestClaim.ClaimValue)</span>
                                                </div>
                                            }
                                        }
                                    }
                                </div>
                            </details>
                        </div>
                        break;

                    case 1:
                        @* ── RETAIL TAB ── *@
                        <div class="vdd-tab-content">
                            @if (hasRetail)
                            {
                                var retailDisplayName = GetRetailProviderDisplayName();
                                var isManualMatch = MediaItem.RetailMatch?.Equals("user_manual", StringComparison.OrdinalIgnoreCase) == true;
                                <div class="vdd-match-status vdd-match-status--ok">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--ok"></span>
                                    <span>@(isManualMatch ? "Matched manually" : $"Matched via {retailDisplayName}")</span>
                                </div>
                                @if (GetRetailProviderUrl() is { } retailUrl)
                                {
                                    <a href="@retailUrl.Url" target="_blank" rel="noopener" class="vdd-provider-link">
                                        <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="font-size: 11px;" />
                                        @retailUrl.Label
                                    </a>
                                }

                                @* Show retail provider claims *@
                                @if (retailClaims.Count > 0)
                                {
                                    <div class="vdd-metadata-list" style="margin-top: 8px;">
                                        @foreach (var group in retailClaims.GroupBy(c => c.ClaimKey).OrderBy(g => g.Key))
                                        {
                                            var bestClaim = group.OrderByDescending(c => c.Confidence).First();
                                            <div class="vdd-claim-row">
                                                <span class="vdd-field-label">@FormatClaimKey(group.Key)</span>
                                                <span class="vdd-field-value">@(bestClaim.ClaimValue.Length > 80 ? bestClaim.ClaimValue[..80] + "\u2026" : bestClaim.ClaimValue)</span>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="vdd-match-status vdd-match-status--warn">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--fail"></span>
                                    <span>Unmatched — no retail provider confirmed this item</span>
                                </div>
                            }

                            @* Always-visible multi-field search *@
                            <div class="vdd-tab-search">
                                <div class="vdd-search-header">
                                    <select class="vdd-type-dropdown" value="@_searchMediaType" @onchange="OnSearchTypeChanged">
                                        <option value="Books">Books</option>
                                        <option value="Audiobooks">Audiobooks</option>
                                        <option value="Movies">Movies</option>
                                        <option value="TV">TV</option>
                                        <option value="Music">Music</option>
                                        <option value="Comics">Comics</option>
                                        <option value="Podcasts">Podcasts</option>
                                    </select>
                                    <button class="vdd-search-btn" @onclick="RunRetailSearch"
                                            disabled="@(!HasAnySearchFieldValue())">
                                        <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 14px;" />
                                    </button>
                                </div>
                                <div class="vdd-field-chips">
                                    @{
                                        var searchableFields = GetSearchableFieldsForCurrentType();
                                    }
                                    @foreach (var field in searchableFields)
                                    {
                                        var f = field;
                                        <button class="vdd-field-chip @(_activeSearchFields.Contains(f.FieldKey) ? "vdd-field-chip--active" : "")"
                                                @onclick="() => ToggleSearchField(f.FieldKey)">
                                            @f.DisplayLabel
                                        </button>
                                    }
                                </div>
                                @foreach (var field in searchableFields)
                                {
                                    if (!_activeSearchFields.Contains(field.FieldKey)) continue;
                                    var f = field;
                                    <div class="vdd-field-row">
                                        <label class="vdd-field-label">@f.DisplayLabel</label>
                                        <input type="text" class="vdd-search-input vdd-field-input"
                                               placeholder="@f.DisplayLabel..."
                                               value="@GetSearchFieldValue(f.FieldKey)"
                                               @oninput="(e) => SetSearchFieldValue(f.FieldKey, e.Value?.ToString())"
                                               @onkeydown="OnRetailSearchKeyDown" />
                                        <button class="vdd-field-remove" @onclick="() => ToggleSearchField(f.FieldKey)">
                                            <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 12px;" />
                                        </button>
                                    </div>
                                }
                                @if (hasRetail && HasAnySearchFieldValue())
                                {
                                    <p class="vdd-rematch-warning">
                                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: #EF9F27;" />
                                        Searching will let you replace the current retail match.
                                    </p>
                                }
                            </div>

                            @if (_searching)
                            {
                                <div style="padding: 8px 0; text-align: center;">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.2);" />
                                </div>
                            }
                            else if (_hasSearched && _retailSearchResults.Count == 0)
                            {
                                <p class="vdd-stage-hint">No retail results found</p>
                            }
                            else if (_retailSearchResults.Count > 0)
                            {
                                <div class="vdd-search-results">
                                    @foreach (var result in _retailSearchResults)
                                    {
                                        var isExpanded = _pendingRetailMatch == result;
                                        var displayFields = GetRetailResultFields(result);
                                        <div class="vdd-search-result-item @(isExpanded ? "vdd-search-result-item--expanded" : "")"
                                             @onclick="() => SelectRetailResult(result)">
                                            <div class="vdd-search-result-row">
                                                <div class="vdd-search-result-thumb">
                                                    @if (!string.IsNullOrEmpty(result.CoverUrl))
                                                    {
                                                        <img src="@result.CoverUrl" alt="" loading="lazy" />
                                                    }
                                                    else
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                                    }
                                                </div>
                                                <div class="vdd-search-result-info">
                                                    <span class="vdd-search-result-title">@result.Title</span>
                                                    <span class="vdd-search-result-meta">
                                                        @displayFields.Subline
                                                        @if (!string.IsNullOrEmpty(displayFields.Tertiary))
                                                        {
                                                            <span> · @displayFields.Tertiary</span>
                                                        }
                                                    </span>
                                                </div>
                                            </div>
                                            @if (isExpanded)
                                            {
                                                <div class="vdd-search-result-detail-below">
                                                    @if (!string.IsNullOrEmpty(result.Description))
                                                    {
                                                        <p class="vdd-detail-description">@(result.Description.Length > 300 ? result.Description[..300] + "\u2026" : result.Description)</p>
                                                    }

                                                    @if (displayFields.Details.Count > 0)
                                                    {
                                                        <div class="vdd-detail-fields-compact">
                                                            @foreach (var (label, value) in displayFields.Details)
                                                            {
                                                                <div class="vdd-detail-field-inline">
                                                                    <span class="vdd-field-label">@label</span>
                                                                    <span class="vdd-field-value">@value</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    }

                                                    @if (displayFields.BridgeIds.Count > 0)
                                                    {
                                                        <div class="vdd-bridge-chips">
                                                            @foreach (var (label, _) in displayFields.BridgeIds)
                                                            {
                                                                <span class="vdd-bridge-chip">@label ✓</span>
                                                            }
                                                        </div>
                                                    }

                                                    @if (!_confirmingRetailMatch)
                                                    {
                                                        <button class="vdd-confirm-match-btn" @onclick:stopPropagation="true"
                                                                @onclick="() => _confirmingRetailMatch = true">
                                                            Confirm Match
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <div class="vdd-confirm-row" @onclick:stopPropagation="true">
                                                            @if (IsRealRetailMatch(MediaItem?.RetailMatch))
                                                            {
                                                                <span class="vdd-overwrite-warning">
                                                                    <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: #EF9F27;" />
                                                                    This will replace the current retail match.
                                                                </span>
                                                            }
                                                            <span class="vdd-confirm-prompt">Are you sure?</span>
                                                            <button class="vdd-confirm-match-btn" @onclick="() => ConfirmRetailMatch(result)">
                                                                Yes
                                                            </button>
                                                            <button class="vdd-cancel-match-btn" @onclick="() => _confirmingRetailMatch = false">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        break;

                    case 2:
                        @* ── WIKIDATA TAB ── *@
                        <div class="vdd-tab-content">
                            @if (hasWikidata)
                            {
                                <div class="vdd-match-status vdd-match-status--ok">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--ok"></span>
                                    <a href="https://www.wikidata.org/wiki/@MediaItem.WikidataQid" target="_blank" rel="noopener" class="vdd-pipeline-qid-link">@MediaItem.WikidataQid</a>
                                </div>
                                <p class="vdd-match-explanation">@GetWikidataExplanation()</p>

                                @* Wikidata claims *@
                                @if (wikiClaims.Count > 0)
                                {
                                    <div class="vdd-metadata-list" style="margin-top: 8px;">
                                        @foreach (var group in wikiClaims.GroupBy(c => c.ClaimKey).OrderBy(g => g.Key))
                                        {
                                            var bestClaim = group.OrderByDescending(c => c.Confidence).First();
                                            <div class="vdd-claim-row">
                                                <span class="vdd-field-label">@FormatClaimKey(group.Key)</span>
                                                <span class="vdd-field-value">@(bestClaim.ClaimValue.Length > 80 ? bestClaim.ClaimValue[..80] + "\u2026" : bestClaim.ClaimValue)</span>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="vdd-match-status @(hasRetailForWiki ? "vdd-match-status--warn" : "vdd-match-status--fail")">
                                    <span class="vdd-pipeline-dot @(hasRetailForWiki ? "vdd-pipeline-dot--warn" : "vdd-pipeline-dot--fail")"></span>
                                    <span>@(hasRetailForWiki ? "Awaiting Wikidata lookup" : "No identity confirmed")</span>
                                </div>
                                @if (!hasRetailForWiki)
                                {
                                    <p class="vdd-stage-hint">A retail match is needed first so the Engine has a bridge ID (like an ISBN or TMDB ID) to look up on Wikidata.</p>
                                }
                                else
                                {
                                    <p class="vdd-stage-hint">A retail match was found but the Wikidata lookup hasn't completed yet, or no matching entry was found.</p>
                                }
                            }

                            @* Always-visible Wikidata search *@
                            <div class="vdd-tab-search">
                                <div class="vdd-search-row">
                                    <input type="text" class="vdd-search-input"
                                           placeholder="@(hasWikidata ? "Search to relink..." : "Search Wikidata by title or QID...")"
                                           @bind="_wikidataSearchQuery" @bind:event="oninput" @onkeydown="OnWikidataSearchKeyDown" />
                                    <select class="vdd-type-dropdown" value="@_searchMediaType" @onchange="OnSearchTypeChanged">
                                        <option value="Books">Books</option>
                                        <option value="Audiobooks">Audiobooks</option>
                                        <option value="Movies">Movies</option>
                                        <option value="TV">TV</option>
                                        <option value="Music">Music</option>
                                        <option value="Comics">Comics</option>
                                        <option value="Podcasts">Podcasts</option>
                                    </select>
                                    <button class="vdd-search-btn" @onclick="RunWikidataSearch"
                                            disabled="@(string.IsNullOrWhiteSpace(_wikidataSearchQuery))">
                                        <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 14px;" />
                                    </button>
                                </div>
                                @if (hasWikidata && !string.IsNullOrWhiteSpace(_wikidataSearchQuery))
                                {
                                    <p class="vdd-rematch-warning">
                                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: #EF9F27;" />
                                        Searching will let you replace the current Wikidata link.
                                    </p>
                                }
                            </div>

                            @if (_searchingWikidata)
                            {
                                <div style="padding: 8px 0; text-align: center;">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.2);" />
                                </div>
                            }
                            else if (_hasSearchedWikidata && _wikidataSearchResults.Count == 0)
                            {
                                <p class="vdd-stage-hint">No Wikidata results for "@_wikidataSearchQuery"</p>
                            }
                            else if (_wikidataSearchResults.Count > 0)
                            {
                                <div class="vdd-search-results">
                                    @foreach (var result in _wikidataSearchResults)
                                    {
                                        var isExpanded = _pendingWikidataMatch == result;
                                        <div class="vdd-search-result-item @(isExpanded ? "vdd-search-result-item--expanded" : "")"
                                             @onclick="() => SelectWikidataResult(result)">
                                            <div class="vdd-search-result-row">
                                                <div class="vdd-search-result-thumb" style="background: rgba(167,139,250,0.1);">
                                                    <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 16px; color: #A78BFA;" />
                                                </div>
                                                <div class="vdd-search-result-info">
                                                    <span class="vdd-search-result-title">@result.Label</span>
                                                    <span class="vdd-search-result-meta">@result.Qid</span>
                                                    @if (!string.IsNullOrEmpty(result.Description))
                                                    {
                                                        <span class="vdd-search-result-desc">@(result.Description.Length > 100 ? result.Description[..100] + "\u2026" : result.Description)</span>
                                                    }
                                                </div>
                                            </div>
                                            @if (isExpanded)
                                            {
                                                <div class="vdd-search-result-detail-below">
                                                    @if (!string.IsNullOrEmpty(result.Description))
                                                    {
                                                        <p class="vdd-detail-description">@result.Description</p>
                                                    }
                                                    @if (!_confirmingWikidataMatch)
                                                    {
                                                        <button class="vdd-confirm-match-btn" @onclick:stopPropagation="true"
                                                                @onclick="() => _confirmingWikidataMatch = true">
                                                            Link to @result.Qid
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <div class="vdd-confirm-row" @onclick:stopPropagation="true">
                                                            @if (IsWikidataMatched(MediaItem?.WikidataQid))
                                                            {
                                                                <span class="vdd-overwrite-warning">
                                                                    <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: #EF9F27;" />
                                                                    This will replace the current Wikidata link (@MediaItem?.WikidataQid).
                                                                </span>
                                                            }
                                                            <span class="vdd-confirm-prompt">Are you sure?</span>
                                                            <button class="vdd-confirm-match-btn" @onclick="() => ConfirmWikidataMatch(result.Qid)">
                                                                Yes
                                                            </button>
                                                            <button class="vdd-cancel-match-btn" @onclick="() => _confirmingWikidataMatch = false">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        break;
                }
            </DrawerSection>

            <DrawerSection Title="History" Icon="@Icons.Material.Outlined.History" DefaultOpen="false">
                <VaultTimeline EntityId="@MediaItem.EntityId" />
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
                <div class="vdd-assets">
                    @* Cover Art *@
                    <div class="vdd-asset-row">
                        <span class="vdd-asset-label">@L["VaultDetail_AssetCoverArt"]</span>
                        <div class="vdd-asset-items">
                            @if (!string.IsNullOrEmpty(MediaItem.CoverUrl))
                            {
                                <div class="vdd-asset-filled">
                                    <img src="@MediaItem.CoverUrl" alt="Cover" class="vdd-asset-img" />
                                    <span class="vdd-asset-source">@L["VaultDetail_AssetSourceProvider"]</span>
                                </div>
                            }
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetCustom"]</span>
                            </div>
                        </div>
                    </div>
                    @* Hero Banner *@
                    <div class="vdd-asset-row">
                        <span class="vdd-asset-label">@L["VaultDetail_AssetHeroBanner"]</span>
                        <div class="vdd-asset-items">
                            @if (!string.IsNullOrEmpty(MediaItem.HeroUrl))
                            {
                                <div class="vdd-asset-filled vdd-asset-filled--wide">
                                    <img src="@MediaItem.HeroUrl" alt="Hero" class="vdd-asset-img" />
                                    <span class="vdd-asset-source">@L["VaultDetail_AssetSourceGenerated"]</span>
                                </div>
                            }
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetCustom"]</span>
                            </div>
                        </div>
                    </div>
                    @* Remaining types as upload-only *@
                    @foreach (var assetType in new[] { "Logo", "Backdrop" })
                    {
                        <div class="vdd-asset-row">
                            <span class="vdd-asset-label">@assetType</span>
                            <div class="vdd-asset-items">
                                <div class="vdd-asset-slot">
                                    <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                    <span class="vdd-asset-upload">@L["VaultDetail_AssetUpload"]</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </DrawerSection>

        }
        else if (Person is not null)
        {
            @* ── Person: delegate to PersonBiographyDrawer ── *@
            <PersonBiographyDrawer Person="@Person"
                                   Aliases="@_aliases"
                                   PersonWorks="@_personWorks"
                                   PersonCharacterRoles="@_personCharacterRoles"
                                   OnPersonAliasClicked="@OnPersonAliasClicked" />

            @* Old person sections removed — all person content is now in PersonBiographyDrawer *@
        }
        else if (Universe is not null)
        {
            @* ── Universe Sections ── *@

            @* Health Score Ring *@
            @if (_universeHealth is not null)
            {
                <div class="vdd-health-ring-wrap">
                    @{
                        var hp = _universeHealth.HealthPercent;
                        var ringColor = hp >= 80 ? "#5DCAA5" : hp >= 50 ? "#C9922E" : "#EF4444";
                        var circumference = 2 * Math.PI * 22;
                        var dashOffset = circumference * (1 - hp / 100.0);
                    }
                    <div class="vdd-health-ring">
                        <svg width="64" height="64" viewBox="0 0 64 64">
                            <circle cx="32" cy="32" r="22" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="6" />
                            <circle cx="32" cy="32" r="22" fill="none"
                                    stroke="@ringColor" stroke-width="6"
                                    stroke-dasharray="@circumference.ToString("F1")"
                                    stroke-dashoffset="@dashOffset.ToString("F1")"
                                    stroke-linecap="round"
                                    transform="rotate(-90 32 32)" />
                        </svg>
                        <span class="vdd-health-pct" style="color: @ringColor;">@((int)hp)%</span>
                    </div>
                    <div class="vdd-health-label-block">
                        <span class="vdd-health-title">@L["VaultDetail_HealthScore"]</span>
                        <span class="vdd-health-sub">@_universeHealth.EntitiesEnriched / @_universeHealth.EntitiesTotal @L["VaultDetail_EntityCounts"]</span>
                    </div>
                </div>
            }

            @* Entity Counts *@
            @if (_universeHealth is not null && _universeHealth.EntitiesTotal > 0)
            {
                <DrawerSection Title="@L["VaultDetail_EntityCounts"]" Icon="@Icons.Material.Outlined.Category">
                    <div class="vdd-entity-counts">
                        <div class="vdd-entity-count-item">
                            <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 16px; color: #A78BFA;" />
                            <span class="vdd-entity-count-label">Characters</span>
                            <span class="vdd-entity-count-val">@_universeCharacters.Count</span>
                        </div>
                        <div class="vdd-entity-count-item">
                            <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Style="font-size: 16px; color: #60A5FA;" />
                            <span class="vdd-entity-count-label">Locations</span>
                            <span class="vdd-entity-count-val">@(_universeHealth.EntitiesTotal - _universeCharacters.Count)</span>
                        </div>
                        <div class="vdd-entity-count-item">
                            <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Style="font-size: 16px; color: #C9922E;" />
                            <span class="vdd-entity-count-label">Relationships</span>
                            <span class="vdd-entity-count-val">@_universeHealth.RelationshipsTotal</span>
                        </div>
                    </div>
                </DrawerSection>
            }

            @* Characters *@
            <DrawerSection Title="@L["VaultDetail_SectionCharacters"]" Icon="@Icons.Material.Outlined.TheaterComedy">
                @if (_loadingUniverseData)
                {
                    <div style="padding: 12px 0; text-align: center;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.2);" />
                    </div>
                }
                else if (_universeCharacters.Count == 0)
                {
                    <p class="vdd-empty-hint">@L["VaultDetail_HintNoCharacters"]</p>
                }
                else
                {
                    <div class="vdd-characters-grid">
                        @foreach (var ch in _universeCharacters.Take(12))
                        {
                            <div class="vdd-character-item">
                                <div class="vdd-character-avatar">
                                    @if (!string.IsNullOrEmpty(ch.PortraitUrl))
                                    {
                                        <img src="@ch.PortraitUrl" alt="@ch.CharacterName" loading="lazy" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 20px; color: rgba(255,255,255,0.15);" />
                                    }
                                </div>
                                <div class="vdd-character-info">
                                    <span class="vdd-character-name">@ch.CharacterName</span>
                                    @if (!string.IsNullOrEmpty(ch.DefaultActorName))
                                    {
                                        <span class="vdd-character-actor">@ch.DefaultActorName</span>
                                    }
                                    @if (ch.ActorCount > 1)
                                    {
                                        <span class="vdd-actor-count-badge">@string.Format(L["VaultDetail_ActorsCount"].ToString(), ch.ActorCount)</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    @if (_universeCharacters.Count > 12)
                    {
                        <p class="vdd-stage-hint" style="margin-top: 8px;">+@(_universeCharacters.Count - 12) more — open Universe Explorer to see all</p>
                    }
                }
            </DrawerSection>

            @* Universe Content *@
            <DrawerSection Title="@L["VaultDetail_SectionUniverseContent"]" Icon="@Icons.Material.Outlined.Layers">
                <div class="vdd-universe-content">
                    @if (Universe.WorkCount > 0)
                    {
                        <p class="vdd-field-value">@Universe.WorkCount @L["VaultDetail_WorksAcross"] @(Universe.MediaTypes ?? L["VaultDetail_VariousMediaTypes"])</p>
                    }
                    else
                    {
                        <p class="vdd-empty-hint">@L["VaultDetail_HintNoSeriesLinked"]</p>
                    }
                </div>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionNotablePeople"]" Icon="@Icons.Material.Outlined.People">
                <p class="vdd-empty-hint">@L["VaultDetail_HintPeopleAssociated"]</p>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
                <div class="vdd-assets">
                    @foreach (var assetType in _assetTypes)
                    {
                        <div class="vdd-asset-row">
                            <span class="vdd-asset-label">@assetType</span>
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 20px; color: rgba(255,255,255,0.08);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetUpload"]</span>
                            </div>
                        </div>
                    }
                </div>
            </DrawerSection>

            @* ── History Timeline ── *@
            <DrawerSection Title="History" Icon="@Icons.Material.Outlined.History" DefaultOpen="false">
                <VaultTimeline EntityId="@Universe.Id" />
            </DrawerSection>

            @* Trigger enrichment + open explorer actions *@
            <div class="vdd-universe-actions">
                <button class="vdd-action-btn vdd-action-btn--primary" @onclick="OpenUniverseExplorer">
                    <MudIcon Icon="@Icons.Material.Outlined.Hub" Style="font-size: 15px;" />
                    @L["VaultDetail_OpenExplorer"]
                </button>
                <button class="vdd-action-btn" @onclick="TriggerEnrichment">
                    <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Style="font-size: 15px;" />
                    @L["VaultDetail_TriggerEnrichment"]
                </button>
            </div>
        }
    </div>

    @* ── 3. Pinned Footer (Media only) ── *@
    @if (MediaItem is not null)
    {
        <div class="vdd-footer">
            @if (_confirmPurge)
            {
                <div class="vdd-purge-confirm-row">
                    <span class="vdd-purge-confirm-text">@L["VaultDetail_ConfirmPurge"]</span>
                    <button class="vdd-purge-btn vdd-purge-btn--confirm" @onclick="HandlePurge">
                        <span>Yes, Purge</span>
                    </button>
                    <button class="vdd-purge-cancel-btn" @onclick="() => _confirmPurge = false">
                        <span>Cancel</span>
                    </button>
                </div>
            }
            else
            {
                <button class="vdd-purge-btn" @onclick="HandlePurge">
                    <MudIcon Icon="@Icons.Material.Outlined.DeleteForever" Style="font-size: 16px;" />
                    <span>@L["VaultDetail_ActionPurgeRecord"]</span>
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public VaultItemViewModel? MediaItem { get; set; }
    [Parameter] public PersonListItemDto? Person { get; set; }
    [Parameter] public HubViewModel? Universe { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Guid> OnPurge { get; set; }
    [Parameter] public EventCallback<Guid> OnApplyMatch { get; set; }
    [Parameter] public EventCallback<Guid> OnPersonAliasClicked { get; set; }

    private bool _confirmPurge;
    private int _selectedStage = 0;
    private static readonly string[] _assetTypes = ["Cover Art", "Headshot", "Banner", "Logo", "Backdrop"];
    // _manualSearchQuery removed — replaced by _searchFieldValues multi-field system
    private bool _searching;
    private bool _hasSearched;
    private List<RegistryItemViewModel> _searchResults = [];
    private PersonAliasesResponseDto? _aliases;
    private List<HubViewModel>? _personWorks;
    private RegistryItemViewModel? _pendingMatch;
    private string _selectedMediaType = "";
    private string _searchMediaType = "";
    private HashSet<string> _activeSearchFields = new(StringComparer.OrdinalIgnoreCase) { "title" };
    private Dictionary<string, string> _searchFieldValues = new(StringComparer.OrdinalIgnoreCase);
    private List<RetailCandidateDto> _retailSearchResults = [];
    private RetailCandidateDto? _pendingRetailMatch;
    private bool _confirmingRetailMatch;
    private bool _searchingWikidata;
    private List<UniverseCandidateDto> _wikidataSearchResults = [];
    private UniverseCandidateDto? _pendingWikidataMatch;
    private bool _confirmingWikidataMatch;
    private string _wikidataSearchQuery = "";
    private bool _hasSearchedWikidata;
    // _metadataTab removed — Metadata section split into File Info + Provider Claims
    private List<ClaimHistoryDto> _claims = [];
    private bool _claimsLoading;

    private void OnSearchTypeChanged(ChangeEventArgs e)
    {
        _searchMediaType = e.Value?.ToString() ?? "";
        _retailSearchResults = [];
        _pendingRetailMatch = null;
        _activeSearchFields = new(StringComparer.OrdinalIgnoreCase) { "title" };
        _searchFieldValues.Clear();
    }

    // Universe data
    private UniverseHealthDto? _universeHealth;
    private IReadOnlyList<UniverseCharacterDto> _universeCharacters = [];
    private bool _loadingUniverseData;

    // Person character roles
    private IReadOnlyList<CharacterRoleDto> _personCharacterRoles = [];

    private bool IsInLibrary => MediaItem?.Status?.Equals("Confirmed", StringComparison.OrdinalIgnoreCase) == true
                             || MediaItem?.VaultDisplayStatus == VaultStatus.Verified;

    /// <summary>Returns true if the retail match is from an actual retail provider (not local_processor or library_scanner).</summary>
    private static bool IsRealRetailMatch(string? retailMatch) =>
        retailMatch is not "none" and not "" and not null
        && !retailMatch.Equals("local_processor", StringComparison.OrdinalIgnoreCase)
        && !retailMatch.Equals("library_scanner", StringComparison.OrdinalIgnoreCase);

    /// <summary>Returns true if a valid Wikidata QID is present (not null, empty, or NF-prefixed).</summary>
    private static bool IsWikidataMatched(string? qid) =>
        !string.IsNullOrEmpty(qid) && !qid.StartsWith("NF", StringComparison.OrdinalIgnoreCase);

    private int ActiveTab => Math.Min(_selectedStage, 2);
    private void SetActiveTab(int tab) { _selectedStage = tab; }

    private void NavigateToCreatorPerson(string creatorName)
    {
        // TODO: Look up person by name and open person drawer
        // For now, this is a placeholder that will be wired to the person detail drawer
    }

    protected override async Task OnParametersSetAsync()
    {
        _confirmPurge = false;
        _selectedStage = 0;
        _searchFieldValues.Clear();
        _searchResults = [];
        _aliases = null;
        _personWorks = null;
        _pendingMatch = null;
        _pendingRetailMatch = null;
        _searching = false;
        _hasSearched = false;
        _confirmingRetailMatch = false;
        _selectedMediaType = MediaItem?.MediaType ?? "";
        _searchMediaType = MediaItem?.MediaType ?? "";
        _activeSearchFields = new(StringComparer.OrdinalIgnoreCase) { "title" };
        _searchFieldValues.Clear();
        _retailSearchResults = [];
        _searchingWikidata = false;
        _wikidataSearchResults = [];
        _pendingWikidataMatch = null;
        _confirmingWikidataMatch = false;
        _wikidataSearchQuery = "";
        _hasSearchedWikidata = false;
        _claims = [];
        _claimsLoading = false;
        _universeHealth = null;
        _universeCharacters = [];
        _personCharacterRoles = [];

        if (MediaItem is not null)
        {
            _claimsLoading = true;
            StateHasChanged();
            _claims = await ApiClient.GetClaimHistoryAsync(MediaItem.EntityId);
            _claimsLoading = false;
        }
        else if (Person is not null)
        {
            var aliasTask = ApiClient.GetPersonAliasesAsync(Person.Id);
            var rolesTask = ApiClient.GetPersonCharacterRolesAsync(Person.Id);
            var worksTask = ApiClient.GetWorksByPersonAsync(Person.Id);
            await Task.WhenAll(aliasTask, rolesTask, worksTask);
            _aliases = await aliasTask;
            _personCharacterRoles = await rolesTask;
            _personWorks = await worksTask;
        }
        else if (Universe is not null && !string.IsNullOrWhiteSpace(Universe.FictionalUniverseQid))
        {
            _loadingUniverseData = true;
            StateHasChanged();

            var healthTask     = ApiClient.GetUniverseHealthAsync(Universe.FictionalUniverseQid);
            var charactersTask = ApiClient.GetUniverseCharactersAsync(Universe.FictionalUniverseQid);
            await Task.WhenAll(healthTask, charactersTask);
            _universeHealth     = await healthTask;
            _universeCharacters = await charactersTask;
            _loadingUniverseData = false;
        }
    }

    private void OpenUniverseExplorer()
    {
        if (Universe?.FictionalUniverseQid is { } qid)
            Nav.NavigateTo($"/universe/{qid}/explore");
    }

    private async Task TriggerEnrichment()
    {
        await ApiClient.TriggerUniverseEnrichmentAsync();
    }

    private async Task RunRetailSearch()
    {
        if (!HasAnySearchFieldValue() || string.IsNullOrWhiteSpace(_searchMediaType)) return;
        _searching = true;
        _retailSearchResults = [];
        _pendingRetailMatch = null;
        _confirmingRetailMatch = false;
        StateHasChanged();

        // Build structured search fields from active field inputs
        var searchFields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var key in _activeSearchFields)
        {
            if (_searchFieldValues.TryGetValue(key, out var val) && !string.IsNullOrWhiteSpace(val))
                searchFields[key] = val.Trim();
        }

        // Build a combined query string for providers that need it
        var queryParts = searchFields.Values.ToList();
        var combinedQuery = string.Join(" ", queryParts);

        var response = await ApiClient.SearchRetailAsync(
            combinedQuery, _searchMediaType, 10,
            searchFields: searchFields);
        if (response?.Candidates is not null)
            _retailSearchResults = response.Candidates.ToList();

        _searching = false;
        _hasSearched = true;
    }

    private async Task RunWikidataSearch()
    {
        if (string.IsNullOrWhiteSpace(_wikidataSearchQuery)) return;

        // Direct QID entry — show as a result for confirmation, don't auto-confirm
        var trimmed = _wikidataSearchQuery.Trim();
        if (trimmed.StartsWith("Q", StringComparison.OrdinalIgnoreCase) && trimmed.Length > 1 && trimmed[1..].All(char.IsDigit))
        {
            var directQid = trimmed.ToUpperInvariant();
            _wikidataSearchResults =
            [
                new UniverseCandidateDto
                {
                    Qid = directQid,
                    Label = directQid,
                    Description = "Direct QID entry — confirm to link this item",
                }
            ];
            _searchingWikidata = false;
            _hasSearchedWikidata = true;
            return;
        }

        _searchingWikidata = true;
        _wikidataSearchResults = [];
        _pendingWikidataMatch = null;
        _confirmingWikidataMatch = false;
        StateHasChanged();

        var response = await ApiClient.SearchUniverseAsync(_wikidataSearchQuery, _searchMediaType, 10);
        _wikidataSearchResults = response?.Candidates ?? [];

        _searchingWikidata = false;
        _hasSearchedWikidata = true;
    }

    /// <summary>Gets the current resolved metadata for the File tab.</summary>
    private List<(string Label, string Value)> GetCurrentMetadataRows()
    {
        var rows = new List<(string, string)>();
        if (MediaItem is null) return rows;

        if (!string.IsNullOrEmpty(MediaItem.Title)) rows.Add(("Title", MediaItem.Title));
        if (!string.IsNullOrEmpty(MediaItem.OriginalTitle) && MediaItem.OriginalTitle != MediaItem.Title)
            rows.Add(("Original Title", MediaItem.OriginalTitle));
        if (!string.IsNullOrEmpty(MediaItem.Author)) rows.Add(("Author", MediaItem.Author));
        if (!string.IsNullOrEmpty(MediaItem.Director)) rows.Add(("Director", MediaItem.Director));
        if (!string.IsNullOrEmpty(MediaItem.Artist)) rows.Add(("Artist", MediaItem.Artist));
        if (!string.IsNullOrEmpty(MediaItem.Narrator)) rows.Add(("Narrator", MediaItem.Narrator));
        if (!string.IsNullOrEmpty(MediaItem.Year)) rows.Add(("Year", MediaItem.Year));
        rows.Add(("Media Type", MediaItem.MediaType));
        if (!string.IsNullOrEmpty(MediaItem.Genre)) rows.Add(("Genre", MediaItem.Genre));
        if (!string.IsNullOrEmpty(MediaItem.Series))
            rows.Add(("Series", MediaItem.Series + (!string.IsNullOrEmpty(MediaItem.SeriesPosition) ? $" #{MediaItem.SeriesPosition}" : "")));
        if (!string.IsNullOrEmpty(MediaItem.UniverseName)) rows.Add(("Universe", MediaItem.UniverseName));
        if (!string.IsNullOrEmpty(MediaItem.FileName)) rows.Add(("File", MediaItem.FileName));
        if (MediaItem.FileSizeBytes.HasValue && MediaItem.FileSizeBytes.Value > 0)
            rows.Add(("Size", VaultHelpers.FormatFileSize(MediaItem.FileSizeBytes)));

        return rows;
    }

    /// <summary>Returns a display name for the retail provider that matched this item.</summary>
    private string GetRetailProviderDisplayName()
    {
        if (MediaItem is null) return "a retail provider";
        var match = !string.IsNullOrEmpty(MediaItem.RetailMatchDetail) ? MediaItem.RetailMatchDetail : MediaItem.RetailMatch;
        return VaultHelpers.FormatSourceName(match ?? "");
    }

    /// <summary>Returns a short explanation of the Wikidata match for the Wikidata tab.</summary>
    private string GetWikidataExplanation()
    {
        if (MediaItem is null) return "";
        var qid = MediaItem.WikidataQid;
        if (string.IsNullOrEmpty(qid)) return "";
        return $"Matched to {qid} on Wikidata. Canonical data (title, author, year, genre) is sourced from Wikidata.";
    }

    /// <summary>Result display data extracted from a retail candidate using the media type registry.</summary>
    private sealed record RetailResultDisplay(
        string? Subline,
        string? Tertiary,
        List<(string Label, string Value)> Details,
        List<(string Label, string Value)> BridgeIds);

    /// <summary>
    /// Builds media-type-aware display data for a retail search result.
    /// Uses MediaTypeFieldRegistry to determine which fields to show per media type.
    /// </summary>
    private RetailResultDisplay GetRetailResultFields(RetailCandidateDto result)
    {
        // Parse the media type enum
        if (!Enum.TryParse<MediaType>(_searchMediaType, true, out var mediaType))
            mediaType = MediaType.Books;

        var config = MediaTypeFieldRegistry.GetSearchDisplay(mediaType);

        // Build a lookup from all available fields on the result
        var allFields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrEmpty(result.Title)) allFields["title"] = result.Title;
        if (!string.IsNullOrEmpty(result.Author))
        {
            allFields["author"] = result.Author;
            // Music display uses "artist" while providers use "author" — expose under both keys.
            allFields.TryAdd("artist", result.Author);
        }
        if (!string.IsNullOrEmpty(result.Director)) allFields["director"] = result.Director;
        if (!string.IsNullOrEmpty(result.Year)) allFields["year"] = result.Year;
        if (!string.IsNullOrEmpty(result.Description)) allFields["description"] = result.Description;
        if (!string.IsNullOrEmpty(result.ProviderItemId)) allFields["provider_item_id"] = result.ProviderItemId;

        // Merge extra fields from the provider
        foreach (var (k, v) in result.ExtraFields)
        {
            if (!string.IsNullOrWhiteSpace(v))
                allFields.TryAdd(k, v);
        }

        // Extract display values using the config
        string? subline = allFields.GetValueOrDefault(config.Subline);
        string? tertiary = allFields.GetValueOrDefault(config.Tertiary);

        // Detail fields (excluding any already shown in subline/tertiary)
        var details = new List<(string, string)>();
        foreach (var fieldKey in config.DetailFields)
        {
            if (fieldKey == config.Subline || fieldKey == config.Tertiary) continue;
            if (allFields.TryGetValue(fieldKey, out var val) && !string.IsNullOrWhiteSpace(val))
                details.Add((FormatClaimKey(fieldKey), val.Length > 80 ? val[..77] + "\u2026" : val));
        }

        // Bridge IDs
        var bridges = new List<(string, string)>();
        foreach (var bridgeKey in config.BridgeLabels)
        {
            if (allFields.TryGetValue(bridgeKey, out var val) && !string.IsNullOrWhiteSpace(val))
                bridges.Add((FormatClaimKey(bridgeKey), val));
        }

        return new RetailResultDisplay(subline, tertiary, details, bridges);
    }

    private IReadOnlyList<SearchableField> GetSearchableFieldsForCurrentType()
    {
        if (Enum.TryParse<MediaEngine.Domain.Enums.MediaType>(_searchMediaType, true, out var mt))
            return MediaTypeFieldRegistry.GetSearchableFields(mt);
        return MediaTypeFieldRegistry.GetSearchableFields(MediaEngine.Domain.Enums.MediaType.Books);
    }

    private void ToggleSearchField(string fieldKey)
    {
        if (_activeSearchFields.Contains(fieldKey))
        {
            _activeSearchFields.Remove(fieldKey);
            _searchFieldValues.Remove(fieldKey);
        }
        else
        {
            _activeSearchFields.Add(fieldKey);
        }
    }

    private string GetSearchFieldValue(string fieldKey) =>
        _searchFieldValues.TryGetValue(fieldKey, out var val) ? val : "";

    private void SetSearchFieldValue(string fieldKey, string? value) =>
        _searchFieldValues[fieldKey] = value ?? "";

    private bool HasAnySearchFieldValue() =>
        _searchFieldValues.Any(kv => _activeSearchFields.Contains(kv.Key) && !string.IsNullOrWhiteSpace(kv.Value));

    private void SelectRetailResult(RetailCandidateDto result)
    {
        _pendingRetailMatch = _pendingRetailMatch == result ? null : result;
        _confirmingRetailMatch = false;
    }

    private async Task ConfirmRetailMatch(RetailCandidateDto candidate)
    {
        if (MediaItem is null) return;

        var request = new ApplyMatchRequestDto
        {
            Title = candidate.Title,
            Year = candidate.Year,
            Author = candidate.Author,
            Director = candidate.Director,
            Description = candidate.Description,
            CoverUrl = candidate.CoverUrl,
            RetailProviderName = candidate.ProviderName,
            RetailProviderItemId = candidate.ProviderItemId,
        };

        await ApiClient.ApplyRegistryMatchAsync(MediaItem.EntityId, request);

        _pendingRetailMatch = null;
        _retailSearchResults = [];
        _searchFieldValues.Clear();
        _confirmingRetailMatch = false;
        _hasSearched = false;

        // Reload claims to reflect the new match
        _claims = await ApiClient.GetClaimHistoryAsync(MediaItem.EntityId);

        // Switch to Wikidata tab — Wikidata lookup kicks off automatically after retail match
        _selectedStage = 2;

        await OnApplyMatch.InvokeAsync(MediaItem.EntityId);
    }

    private async Task OnRetailSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await RunRetailSearch();
    }

    private async Task OnWikidataSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await RunWikidataSearch();
    }


    private void SelectWikidataResult(UniverseCandidateDto result)
    {
        _pendingWikidataMatch = _pendingWikidataMatch == result ? null : result;
        _confirmingWikidataMatch = false;
    }

    private async Task ConfirmWikidataMatch(string qid)
    {
        if (MediaItem is null || string.IsNullOrWhiteSpace(qid)) return;

        var request = new ApplyMatchRequestDto { Qid = qid };
        await ApiClient.ApplyRegistryMatchAsync(MediaItem.EntityId, request);

        _pendingWikidataMatch = null;
        _wikidataSearchResults = [];
        _confirmingWikidataMatch = false;
        _wikidataSearchQuery = "";
        _hasSearchedWikidata = false;

        // Reload claims to reflect the new Wikidata link
        _claims = await ApiClient.GetClaimHistoryAsync(MediaItem.EntityId);

        await OnApplyMatch.InvokeAsync(MediaItem.EntityId);
    }

    private void SelectSearchResult(RegistryItemViewModel result)
    {
        // Toggle: clicking same item deselects, clicking different item selects
        _pendingMatch = _pendingMatch?.EntityId == result.EntityId ? null : result;
    }

    private async Task ConfirmMatch(Guid entityId)
    {
        _pendingMatch = null;
        _searchResults = [];
        _searchFieldValues.Clear();
        await OnApplyMatch.InvokeAsync(entityId);
    }

    private async Task HandlePurge()
    {
        if (_confirmPurge && MediaItem is not null)
        {
            await OnPurge.InvokeAsync(MediaItem.EntityId);
            _confirmPurge = false;
        }
        else
        {
            _confirmPurge = true;
        }
    }

    /// <summary>Formats a claim key — delegates to shared VaultHelpers.</summary>
    private static string FormatClaimKey(string key) => VaultHelpers.FormatClaimKey(key);

    /// <summary>
    /// Builds the best available external URL for the current item's retail provider match,
    /// using bridge IDs found in loaded claims data.
    /// </summary>
    private (string Label, string Url)? GetRetailProviderUrl()
    {
        if (MediaItem is null || _claims.Count == 0) return null;

        // Bridge ID keys in priority order per media type
        string[] bridgeKeys = (MediaItem.MediaType ?? "").ToLowerInvariant() switch
        {
            var t when t.Contains("movie") || t.Contains("video") => ["tmdb_id", "imdb_id"],
            "tv" => ["tmdb_id", "imdb_id"],
            var t when t.Contains("book") || t.Contains("epub") => ["open_library_id", "apple_books_id"],
            var t when t.Contains("audiobook") => ["apple_books_id", "open_library_id"],
            var t when t.Contains("music") => ["musicbrainz_id"],
            _ => ["tmdb_id", "open_library_id", "musicbrainz_id"],
        };

        foreach (var key in bridgeKeys)
        {
            var claim = _claims.FirstOrDefault(c =>
                c.ClaimKey.Equals(key, StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(c.ClaimValue));
            if (claim is not null)
            {
                var result = VaultHelpers.BuildProviderUrl(key, claim.ClaimValue, MediaItem.MediaType);
                if (result is not null) return result;
            }
        }

        return null;
    }
}

