    /// <summary>Formats a claim key — delegates to shared VaultHelpers.</summary>
    private static string FormatClaimKey(string key) => VaultHelpers.FormatClaimKey(key);

    private static string FormatDuration(string? duration)
    {
        if (string.IsNullOrEmpty(duration)) return "";
        // Try to parse as milliseconds (common from providers)
        if (long.TryParse(duration, out var ms))
        {
            var ts = TimeSpan.FromMilliseconds(ms);
            return ts.TotalHours >= 1
                ? $"{(int)ts.TotalHours}h {ts.Minutes:D2}m"
                : $"{ts.Minutes}m {ts.Seconds:D2}s";
        }
        return duration; // Return as-is if not numeric
    }

    // ── Field comparison helpers ──

    private record FieldComparison(string FieldLabel, string? YourValue, string? ProviderValue, double? Score);

    private List<FieldComparison> GetRetailFieldComparisons(RetailCandidateDto result)
    {
        var comparisons = new List<FieldComparison>();

        // Title
        comparisons.Add(new("Title", MediaItem?.Title, result.Title,
            ComputeFieldScore(MediaItem?.Title, result.Title)));

        // Author/Director/Artist based on media type
        var (creatorLabel, yourCreator, theirCreator) = _searchMediaType switch
        {
            "Movies" or "TV" => ("Director", MediaItem?.Director, result.Director),
            "Music" => ("Artist", MediaItem?.Artist, result.Author),
            _ => ("Author", MediaItem?.Author, result.Author),
        };
        if (!string.IsNullOrEmpty(yourCreator) || !string.IsNullOrEmpty(theirCreator))
            comparisons.Add(new(creatorLabel, yourCreator, theirCreator,
                ComputeFieldScore(yourCreator, theirCreator)));

        // Year
        if (!string.IsNullOrEmpty(MediaItem?.Year) || !string.IsNullOrEmpty(result.Year))
            comparisons.Add(new("Year", MediaItem?.Year, result.Year,
                ComputeFieldScore(MediaItem?.Year, result.Year)));

        // Media type
        comparisons.Add(new("Type", MediaItem?.MediaType, _searchMediaType,
            string.Equals(MediaItem?.MediaType, _searchMediaType, StringComparison.OrdinalIgnoreCase) ? 1.0 : 0.0));

        // Series (if applicable)
        var theirSeries = result.ExtraFields?.GetValueOrDefault("series");
        if (!string.IsNullOrEmpty(MediaItem?.Series) || !string.IsNullOrEmpty(theirSeries))
            comparisons.Add(new("Series", MediaItem?.Series, theirSeries,
                ComputeFieldScore(MediaItem?.Series, theirSeries)));

        return comparisons;
    }

    private List<FieldComparison> GetWikidataFieldComparisons(UniverseCandidateDto result)
    {
        var comparisons = new List<FieldComparison>();

        comparisons.Add(new("Title", MediaItem?.Title, result.Label,
            ComputeFieldScore(MediaItem?.Title, result.Label)));

        var (creatorLabel, yourCreator, theirCreator) = _searchMediaType switch
        {
            "Movies" or "TV" => ("Director", MediaItem?.Director, result.Director),
            _ => ("Author", MediaItem?.Author, result.Author),
        };
        if (!string.IsNullOrEmpty(yourCreator) || !string.IsNullOrEmpty(theirCreator))
            comparisons.Add(new(creatorLabel, yourCreator, theirCreator,
                ComputeFieldScore(yourCreator, theirCreator)));

        if (!string.IsNullOrEmpty(MediaItem?.Year) || !string.IsNullOrEmpty(result.Year))
            comparisons.Add(new("Year", MediaItem?.Year, result.Year,
                ComputeFieldScore(MediaItem?.Year, result.Year)));

        // Instance type
        if (!string.IsNullOrEmpty(result.InstanceOf))
            comparisons.Add(new("Type", MediaItem?.MediaType, result.InstanceOf, null));

        return comparisons;
    }

    private static double? ComputeFieldScore(string? a, string? b)
    {
        if (string.IsNullOrWhiteSpace(a) || string.IsNullOrWhiteSpace(b)) return null;
        if (string.Equals(a.Trim(), b.Trim(), StringComparison.OrdinalIgnoreCase)) return 1.0;

        var aLower = a.Trim().ToLowerInvariant();
        var bLower = b.Trim().ToLowerInvariant();

        if (aLower.Contains(bLower) || bLower.Contains(aLower))
            return 0.85;

        var maxLen = Math.Max(aLower.Length, bLower.Length);
        if (maxLen == 0) return 1.0;
        var distance = LevenshteinDistance(aLower, bLower);
        return Math.Max(0, 1.0 - (double)distance / maxLen);
    }

    private static int LevenshteinDistance(string s, string t)
    {
        var n = s.Length;
        var m = t.Length;
        var d = new int[n + 1, m + 1];
        for (int i = 0; i <= n; i++) d[i, 0] = i;
        for (int j = 0; j <= m; j++) d[0, j] = j;
        for (int i = 1; i <= n; i++)
            for (int j = 1; j <= m; j++)
                d[i, j] = Math.Min(Math.Min(d[i - 1, j] + 1, d[i, j - 1] + 1),
                    d[i - 1, j - 1] + (s[i - 1] == t[j - 1] ? 0 : 1));
        return d[n, m];
    }

    private static string GetScoreColor(double score) =>
        score >= 0.85 ? "#5DCAA5" : score >= 0.60 ? "#EF9F27" : "#A05050";

    /// <summary>
    /// Builds the best available external URL for the current item's retail provider match,
    /// using bridge IDs found in loaded claims data.
    /// </summary>
    private (string Label, string Url)? GetRetailProviderUrl()
    {
        if (MediaItem is null || _claims.Count == 0) return null;

        // Bridge ID keys in priority order per media type
        string[] bridgeKeys = (MediaItem.MediaType ?? "").ToLowerInvariant() switch
        {
            var t when t.Contains("movie") || t.Contains("video") => ["tmdb_id", "imdb_id"],
            "tv" => ["tmdb_id", "imdb_id"],
            var t when t.Contains("book") || t.Contains("epub") => ["open_library_id", "apple_books_id"],
            var t when t.Contains("audiobook") => ["apple_books_id", "open_library_id"],
            var t when t.Contains("music") => ["musicbrainz_id"],
            _ => ["tmdb_id", "open_library_id", "musicbrainz_id"],
        };

        foreach (var key in bridgeKeys)
        {
            var claim = _claims.FirstOrDefault(c =>
                c.ClaimKey.Equals(key, StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(c.ClaimValue));
            if (claim is not null)
            {
                var result = VaultHelpers.BuildProviderUrl(key, claim.ClaimValue, MediaItem.MediaType);
                if (result is not null) return result;
            }
        }

        return null;
    }

}

