    private async Task RunRetailSearch()
    {
        var hasQuery = !string.IsNullOrWhiteSpace(_primarySearchValue)
                       || _searchFilters.Any(f => !string.IsNullOrWhiteSpace(f.Value));
        if (!hasQuery || string.IsNullOrWhiteSpace(_searchMediaType)) return;

        _searching = true;
        _retailSearchResults = [];
        _pendingRetailMatch = null;
        _confirmingRetailMatch = false;
        StateHasChanged();

        var searchFields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrWhiteSpace(_primarySearchValue))
            searchFields[_primarySearchField] = _primarySearchValue.Trim();
        foreach (var (key, val) in _searchFilters)
        {
            if (!string.IsNullOrWhiteSpace(val))
                searchFields[key] = val.Trim();
        }

        var queryParts = searchFields.Values.ToList();
        var combinedQuery = string.Join(" ", queryParts);

        var response = await ApiClient.SearchRetailAsync(
            combinedQuery, _searchMediaType, 10,
            searchFields: searchFields);
        if (response?.Candidates is not null)
            _retailSearchResults = response.Candidates.ToList();

        _searching = false;
        _hasSearched = true;
    }

    private async Task RunWikidataSearch()
    {
        if (string.IsNullOrWhiteSpace(_wikidataSearchQuery)) return;

        // Direct QID entry — show as a result for confirmation, don't auto-confirm
        var trimmed = _wikidataSearchQuery.Trim();
        if (trimmed.StartsWith("Q", StringComparison.OrdinalIgnoreCase) && trimmed.Length > 1 && trimmed[1..].All(char.IsDigit))
        {
            var directQid = trimmed.ToUpperInvariant();
            _wikidataSearchResults =
            [
                new UniverseCandidateDto
                {
                    Qid = directQid,
                    Label = directQid,
                    Description = "Direct QID entry — confirm to link this item",
                }
            ];
            _searchingWikidata = false;
            _hasSearchedWikidata = true;
            return;
        }

        _searchingWikidata = true;
        _wikidataSearchResults = [];
        _pendingWikidataMatch = null;
        _confirmingWikidataMatch = false;
        StateHasChanged();

        var response = await ApiClient.SearchUniverseAsync(_wikidataSearchQuery, _searchMediaType, 10);
        _wikidataSearchResults = response?.Candidates ?? [];

        _searchingWikidata = false;
        _hasSearchedWikidata = true;
    }

    /// <summary>Gets the current resolved metadata for the File tab.</summary>
    private List<(string Label, string Value)> GetCurrentMetadataRows()
    {
        var rows = new List<(string, string)>();
        if (MediaItem is null) return rows;

        if (!string.IsNullOrEmpty(MediaItem.Title)) rows.Add(("Title", MediaItem.Title));
        if (!string.IsNullOrEmpty(MediaItem.OriginalTitle) && MediaItem.OriginalTitle != MediaItem.Title)
            rows.Add(("Original Title", MediaItem.OriginalTitle));
        if (!string.IsNullOrEmpty(MediaItem.Author)) rows.Add(("Author", MediaItem.Author));
        if (!string.IsNullOrEmpty(MediaItem.Director)) rows.Add(("Director", MediaItem.Director));
        if (!string.IsNullOrEmpty(MediaItem.Artist)) rows.Add(("Artist", MediaItem.Artist));
        if (!string.IsNullOrEmpty(MediaItem.Narrator)) rows.Add(("Narrator", MediaItem.Narrator));
        if (!string.IsNullOrEmpty(MediaItem.Year)) rows.Add(("Year", MediaItem.Year));
        rows.Add(("Media Type", MediaItem.MediaType));
        if (!string.IsNullOrEmpty(MediaItem.Genre)) rows.Add(("Genre", MediaItem.Genre));
        if (!string.IsNullOrEmpty(MediaItem.Series))
            rows.Add(("Series", MediaItem.Series + (!string.IsNullOrEmpty(MediaItem.SeriesPosition) ? $" #{MediaItem.SeriesPosition}" : "")));
        if (!string.IsNullOrEmpty(MediaItem.UniverseName)) rows.Add(("Universe", MediaItem.UniverseName));

        // Music-specific
        if (MediaItem.MediaType == "Music")
        {
            if (!string.IsNullOrEmpty(MediaItem.Album)) rows.Add(("Album", MediaItem.Album));
            if (!string.IsNullOrEmpty(MediaItem.TrackNumber))
            {
                var trackDisplay = MediaItem.TrackNumber;
                if (!string.IsNullOrEmpty(MediaItem.TrackCount))
                    trackDisplay += $" of {MediaItem.TrackCount}";
                rows.Add(("Track", trackDisplay));
            }
            if (!string.IsNullOrEmpty(MediaItem.DiscNumber)) rows.Add(("Disc", MediaItem.DiscNumber));
            if (!string.IsNullOrEmpty(MediaItem.Duration)) rows.Add(("Duration", FormatDuration(MediaItem.Duration)));
        }

        // TV-specific
        if (MediaItem.MediaType == "TV")
        {
            if (!string.IsNullOrEmpty(MediaItem.ShowName)) rows.Add(("Show", MediaItem.ShowName));
            if (!string.IsNullOrEmpty(MediaItem.Season)) rows.Add(("Season", MediaItem.Season));
            if (!string.IsNullOrEmpty(MediaItem.Episode)) rows.Add(("Episode", MediaItem.Episode));
            if (!string.IsNullOrEmpty(MediaItem.Duration)) rows.Add(("Runtime", FormatDuration(MediaItem.Duration)));
        }

        // Audiobooks
        if (MediaItem.MediaType == "Audiobooks" && !string.IsNullOrEmpty(MediaItem.Duration))
            rows.Add(("Duration", FormatDuration(MediaItem.Duration)));

        // Podcasts
        if (MediaItem.MediaType == "Podcasts")
        {
            if (!string.IsNullOrEmpty(MediaItem.ShowName)) rows.Add(("Podcast", MediaItem.ShowName));
            if (!string.IsNullOrEmpty(MediaItem.Episode)) rows.Add(("Episode", MediaItem.Episode));
            if (!string.IsNullOrEmpty(MediaItem.Duration)) rows.Add(("Duration", FormatDuration(MediaItem.Duration)));
        }

        if (!string.IsNullOrEmpty(MediaItem.FileName)) rows.Add(("File", MediaItem.FileName));
        if (MediaItem.FileSizeBytes.HasValue && MediaItem.FileSizeBytes.Value > 0)
            rows.Add(("Size", VaultHelpers.FormatFileSize(MediaItem.FileSizeBytes)));

        return rows;
    }

    /// <summary>Returns rows for the File Information drawer section.</summary>
    private List<(string Label, string Value)> GetFileInfoRows()
    {
        var rows = new List<(string Label, string Value)>();
        if (MediaItem is null) return rows;

        if (!string.IsNullOrEmpty(MediaItem.FileName))
            rows.Add(("File Name", MediaItem.FileName));

        if (!string.IsNullOrEmpty(MediaItem.FilePath))
        {
            var folder = MediaItem.FilePath;
            // Show the folder path (strip the filename if it's at the end)
            if (!string.IsNullOrEmpty(MediaItem.FileName) && folder.EndsWith(MediaItem.FileName, StringComparison.OrdinalIgnoreCase))
                folder = folder[..^MediaItem.FileName.Length].TrimEnd('/', '\\');
            if (!string.IsNullOrEmpty(folder))
                rows.Add(("Folder", folder));
        }

        if (MediaItem.FileSizeBytes.HasValue && MediaItem.FileSizeBytes.Value > 0)
            rows.Add(("Size", VaultHelpers.FormatFileSize(MediaItem.FileSizeBytes)));

        // Format: derive from file extension
        if (!string.IsNullOrEmpty(MediaItem.FileName))
        {
            var ext = System.IO.Path.GetExtension(MediaItem.FileName)?.TrimStart('.').ToUpperInvariant();
            if (!string.IsNullOrEmpty(ext))
                rows.Add(("Format", ext));
        }

        // Movies: show quality info from resolution summary or filename patterns
        if (MediaItem.MediaType is "Movies" or "TV")
        {
            var quality = DetectVideoQuality(MediaItem.FileName, MediaItem.ResolutionSummary);
            if (!string.IsNullOrEmpty(quality))
                rows.Add(("Quality", quality));
        }

        if (!string.IsNullOrEmpty(MediaItem.Duration))
            rows.Add(("Duration", FormatDuration(MediaItem.Duration)));

        return rows;
    }

    /// <summary>Detect video quality from filename patterns (REMUX, 4K, 1080p, etc.).</summary>
    private static string? DetectVideoQuality(string? fileName, string? resolutionSummary)
    {
        if (string.IsNullOrEmpty(fileName)) return null;
        var parts = new List<string>();
        var upper = fileName.ToUpperInvariant();

        if (upper.Contains("2160P") || upper.Contains("4K") || upper.Contains("UHD"))
            parts.Add("4K");
        else if (upper.Contains("1080P"))
            parts.Add("1080p");
        else if (upper.Contains("720P"))
            parts.Add("720p");

        if (upper.Contains("REMUX"))
            parts.Add("REMUX");
        else if (upper.Contains("BLURAY") || upper.Contains("BLU-RAY"))
            parts.Add("Blu-ray");
        else if (upper.Contains("WEBDL") || upper.Contains("WEB-DL"))
            parts.Add("WEB-DL");
        else if (upper.Contains("WEBRIP") || upper.Contains("WEB-RIP"))
            parts.Add("WEBRip");

        if (upper.Contains("HDR10+"))
            parts.Add("HDR10+");
        else if (upper.Contains("HDR"))
            parts.Add("HDR");
        else if (upper.Contains("DOLBY VISION") || upper.Contains("DV"))
            parts.Add("DV");

        return parts.Count > 0 ? string.Join(" · ", parts) : null;
    }

