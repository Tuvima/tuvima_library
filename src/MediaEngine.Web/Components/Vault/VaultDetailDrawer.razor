@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Domain.Constants
@using MediaEngine.Domain.Enums
@namespace MediaEngine.Web.Components.Vault
@inject IStringLocalizer<SharedStrings> L
@inject IEngineApiClient ApiClient
@inject NavigationManager Nav

@* ── Backdrop ── *@
<div class="vdd-backdrop" @onclick="OnClose"></div>

@* ── Drawer Panel ── *@
<div class="vdd-drawer" @onclick:stopPropagation="true">

    @* ── 1. Pinned Header ── *@
    <div class="vdd-header">
        <MudIconButton Icon="@Icons.Material.Outlined.Close"
                       Size="Size.Small"
                       Style="position:absolute;top:24px;right:24px;color:rgba(255,255,255,0.5);"
                       OnClick="OnClose" />

        @if (MediaItem is not null)
        {
            @* ── Media Header ── *@
            <div class="vdd-header-content">
                <div class="vdd-thumb-wrap">
                    @if (!string.IsNullOrEmpty(MediaItem.CoverUrl))
                    {
                        <img src="@MediaItem.CoverUrl" alt="" class="vdd-thumb-img" loading="lazy" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 48px; color: rgba(255,255,255,0.1);" />
                    }
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        @if (!IsInLibrary)
                        {
                            <span class="vdd-location-chip vdd-location-chip--staging">
                                Staging
                            </span>
                        }
                        <StatusPill Status="@MediaItem.VaultDisplayStatus" QuarantineDays="@MediaItem.QuarantineDays" />
                        @if (!string.IsNullOrEmpty(MediaItem.WikidataQid))
                        {
                            <a href="https://www.wikidata.org/wiki/@MediaItem.WikidataQid" target="_blank" rel="noopener" class="vdd-qid-badge">
                                <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 11px;" />
                                @MediaItem.WikidataQid
                            </a>
                            @if (GetWikipediaUrl() is string mediaWikiUrl)
                            {
                                <a href="@mediaWikiUrl" target="_blank" rel="noopener" class="vdd-wiki-badge" title="Open Wikipedia article">
                                    <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 11px;" />
                                    Wikipedia
                                </a>
                            }
                        }
                    </div>
                    <h2 class="vdd-title">@MediaItem.Title</h2>
                    @{
                        var drawerCreator = MediaItem.MediaType switch
                        {
                            "Movies" => MediaItem.Director ?? MediaItem.Author,
                            "TV" => MediaItem.Director,
                            "Music" => MediaItem.Artist ?? MediaItem.Author,
                            _ => MediaItem.Author,
                        };
                    }
                    @if (!string.IsNullOrEmpty(drawerCreator))
                    {
                        <p class="vdd-subtitle vdd-subtitle--clickable" @onclick="() => NavigateToCreatorPerson(drawerCreator)">
                            @drawerCreator.ToUpperInvariant()
                        </p>
                    }
                    <div class="vdd-meta">
                        <span class="vdd-meta-item" style="color: @VaultHelpers.GetMediaTypeColor(MediaItem.MediaType);">
                            <MudIcon Icon="@VaultHelpers.GetMediaTypeIcon(MediaItem.MediaType)" Style="font-size: 14px;" />
                            @VaultHelpers.FormatMediaType(MediaItem.MediaType)
                        </span>
                        @if (!string.IsNullOrEmpty(MediaItem.Year))
                        {
                            <span class="vdd-meta-item">@MediaItem.Year</span>
                        }
                    </div>
                    <p class="vdd-added-date">Added @MediaItem.CreatedAt.ToString("MMM dd, yyyy")</p>
                </div>
            </div>
        }
        else if (Person is not null)
        {
            @* ── Person Header ── *@
            <div class="vdd-header-content">
                <div class="vdd-avatar-round">
                    @if (!string.IsNullOrEmpty(Person.HeadshotUrl))
                    {
                        <img src="@Person.HeadshotUrl" alt="" class="vdd-avatar-img" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 48px; color: rgba(255,255,255,0.1);" />
                    }
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        @foreach (var role in Person.Roles)
                        {
                            <span class="vdd-role-chip">@role.ToUpperInvariant()</span>
                        }
                        @if (!string.IsNullOrEmpty(Person.WikidataQid))
                        {
                            <a href="https://www.wikidata.org/wiki/@Person.WikidataQid" target="_blank" rel="noopener" class="vdd-qid-badge">
                                <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="font-size: 11px;" />
                                @Person.WikidataQid
                            </a>
                            @if (GetWikipediaUrl() is string personWikiUrl)
                            {
                                <a href="@personWikiUrl" target="_blank" rel="noopener" class="vdd-wiki-badge" title="Open Wikipedia article">
                                    <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 11px;" />
                                    Wikipedia
                                </a>
                            }
                        }
                    </div>
                    <h2 class="vdd-title">@Person.Name</h2>
                    @if (!string.IsNullOrEmpty(Person.Occupation))
                    {
                        <p class="vdd-subtitle-italic">@Person.Occupation</p>
                    }
                </div>
            </div>
        }
        else if (Universe is not null)
        {
            @* ── Universe Header ── *@
            <div class="vdd-header-content">
                <div class="vdd-universe-icon">
                    <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 48px; color: #A78BFA;" />
                </div>
                <div class="vdd-header-info">
                    <div class="vdd-badges">
                        <StatusPill Status="VaultStatus.Verified" />
                    </div>
                    <h2 class="vdd-title">@Universe.DisplayName</h2>
                    <p class="vdd-subtitle-italic">@Universe.Description</p>
                </div>
            </div>
        }
    </div>

    @* ── 2. Scrollable Body ── *@
    <div class="vdd-body">
        @if (MediaItem is not null)
        {
            @* ── NeedsReview problem banner ── *@
            @if (MediaItem.VaultDisplayStatus == VaultStatus.NeedsReview && !string.IsNullOrEmpty(MediaItem.ReviewTrigger))
            {
                <div class="vdd-problem-banner">
                    <div class="vdd-problem-banner-top">
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 18px; color: #EF9F27; flex-shrink: 0;" />
                        <span class="vdd-problem-banner-msg">@VaultHelpers.GetReviewTriggerLabel(MediaItem.ReviewTrigger)</span>
                    </div>
                    <p class="vdd-problem-banner-hint">You can search for a match in the Pipeline section below, or check the File Info for clues.</p>
                </div>
            }

            @if (MediaItem.VaultDisplayStatus == VaultStatus.WaitingForProvider)
            {
                <div class="vdd-waiting-banner">
                    <MudIcon Icon="@Icons.Material.Outlined.Schedule" Style="font-size: 18px;" />
                    <span>
                        @if (!string.IsNullOrEmpty(MediaItem.FailedProviderName))
                        {
                            @L["VaultDetail_WaitingForProviderNamed", MediaItem.FailedProviderName]
                        }
                        else
                        {
                            @L["VaultDetail_WaitingForProvider"]
                        }
                    </span>
                </div>
            }

            @* ── Pipeline (circles + File/Retail/Wikidata tabs) ── *@
            <DrawerSection @key="@($"pipeline-{MediaItem.EntityId}")" Title="Pipeline" Icon="@Icons.Material.Outlined.AccountTree"
                           HasProblem="@(!IsRealRetailMatch(MediaItem.RetailMatch) || !IsWikidataMatched(MediaItem.WikidataQid))"
                           DefaultOpen="@(!IsRealRetailMatch(MediaItem.RetailMatch) || !IsWikidataMatched(MediaItem.WikidataQid))">

                @* Pipeline stage circles *@
                <div class="vdd-pipeline-circles-wrap">
                    <VaultPipelineCircles
                        Stage0="@(new VaultPipelineStage { State = VaultStageState.Completed, Label = "File scanned" })"
                        Stage1="@MediaItem.Stage1"
                        Stage2="@MediaItem.Stage2"
                        Stage3="@MediaItem.Stage3"
                        @bind-SelectedStage="_selectedStage" />
                </div>

                @* ── Tab content (selected via pipeline circles) ── *@
                @{
                    var hasRetail = IsRealRetailMatch(MediaItem?.RetailMatch) || IsRealRetailMatch(MediaItem?.RetailMatchDetail);
                    var hasWikidata = IsWikidataMatched(MediaItem?.WikidataQid);
                    var hasRetailForWiki = hasRetail;
                    var retailClaims = _claims.Where(c =>
                        !VaultHelpers.IsFileSource(c.ProviderId) &&
                        !VaultHelpers.IsUserSource(c.ProviderId) &&
                        !c.ProviderId.ToString().Contains("b3000003")).ToList();
                    var wikiClaims = _claims.Where(c =>
                        c.ProviderId.ToString().Contains("b3000003")).ToList();
                }
                @switch (ActiveTab)
                {
                    case 0:
                        @* ── FILE TAB ── *@
                        <div class="vdd-tab-content">
                            <h4 class="vdd-tab-heading">Current Metadata</h4>
                            <div class="vdd-metadata-list">
                                @foreach (var (label, val) in GetCurrentMetadataRows())
                                {
                                    <div class="vdd-claim-row">
                                        <span class="vdd-field-label">@label</span>
                                        <span class="vdd-field-value">@val</span>
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(MediaItem?.CoverUrl))
                            {
                                <div class="vdd-file-cover">
                                    <span class="vdd-field-label">Cover Art</span>
                                    <img src="@MediaItem.CoverUrl" alt="Cover" class="vdd-file-cover-img" loading="lazy" />
                                </div>
                            }

                            @* Collapsed original metadata *@
                            <details class="vdd-original-meta">
                                <summary class="vdd-original-meta-summary">Original File Metadata</summary>
                                <div class="vdd-metadata-list" style="margin-top: 8px;">
                                    @if (_claimsLoading)
                                    {
                                        <div style="padding: 8px 0; text-align: center;">
                                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.2);" />
                                        </div>
                                    }
                                    else
                                    {
                                        var fileClaims = _claims.Where(c => VaultHelpers.IsFileSource(c.ProviderId) || VaultHelpers.IsUserSource(c.ProviderId)).ToList();
                                        @if (fileClaims.Count == 0)
                                        {
                                            <p class="vdd-stage-hint">No file metadata extracted yet.</p>
                                        }
                                        else
                                        {
                                            @foreach (var group in fileClaims.GroupBy(c => c.ClaimKey).OrderBy(g => g.Key))
                                            {
                                                var bestClaim = group.OrderByDescending(c => c.Confidence).First();
                                                <div class="vdd-claim-row">
                                                    <span class="vdd-field-label">@FormatClaimKey(group.Key)</span>
                                                    <span class="vdd-field-value">@bestClaim.ClaimValue</span>
                                                </div>
                                            }
                                        }
                                    }
                                </div>
                            </details>
                        </div>
                        break;

                    case 1:
                        @* ── RETAIL TAB ── *@
                        <div class="vdd-tab-content">
                            @* Always-visible filter-based search (at the top) *@
                            <div class="vdd-tab-search" style="margin-top: 0; padding-top: 0; border-top: none;">
                                <div class="vdd-search-bar-wrap" style="margin-top: 4px;">
                                    @* Media type row *@
                                    <div class="vdd-search-type-row">
                                        <span class="vdd-search-type-label">Type:</span>
                                        <div class="vdd-dropdown-wrap">
                                            <button class="vdd-dropdown-btn" @onclick="() => _showMediaTypeDropdown = !_showMediaTypeDropdown">
                                                @_searchMediaType <MudIcon Icon="@Icons.Material.Outlined.ExpandMore" Style="font-size: 14px;" />
                                            </button>
                                            @if (_showMediaTypeDropdown)
                                            {
                                                <div class="vdd-dropdown-menu">
                                                    @foreach (var mt in new[] { "Books", "Audiobooks", "Movies", "TV", "Music", "Comics", "Podcasts" })
                                                    {
                                                        <div class="vdd-dropdown-item" @onclick="() => SetRetailMediaType(mt)">@mt</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    @* Main search row *@
                                    <div class="vdd-search-main-row">
                                        <div class="vdd-search-input-group">
                                            <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 18px; color: rgba(255,255,255,0.35);" />

                                            @* Primary field selector *@
                                            <div class="vdd-dropdown-wrap">
                                                <button class="vdd-primary-field-btn" @onclick="() => _showPrimaryDropdown = !_showPrimaryDropdown">
                                                    @FormatClaimKey(_primarySearchField)
                                                    <MudIcon Icon="@Icons.Material.Outlined.ExpandMore" Style="font-size: 12px;" />
                                                </button>
                                                @if (_showPrimaryDropdown)
                                                {
                                                    <div class="vdd-dropdown-menu">
                                                        @foreach (var f in GetSearchableFieldsForCurrentType())
                                                        {
                                                            <div class="vdd-dropdown-item" @onclick="() => SetPrimaryField(f.FieldKey)">@f.DisplayLabel</div>
                                                        }
                                                    </div>
                                                }
                                            </div>

                                            <input type="text" class="vdd-search-primary-input"
                                                   placeholder="@($"Search {FormatClaimKey(_primarySearchField).ToLower()}...")"
                                                   @bind="_primarySearchValue" @bind:event="oninput"
                                                   @onkeydown="OnRetailSearchKeyDown" />

                                            @* Add Filter button *@
                                            <div class="vdd-dropdown-wrap">
                                                <button class="vdd-add-filter-btn" @onclick="() => _showFilterDropdown = !_showFilterDropdown">
                                                    <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 14px;" />
                                                    Add Filter
                                                </button>
                                                @if (_showFilterDropdown)
                                                {
                                                    <div class="vdd-dropdown-menu">
                                                        @foreach (var f in GetSearchableFieldsForCurrentType())
                                                        {
                                                            if (f.FieldKey == _primarySearchField) continue;
                                                            if (_searchFilters.Any(sf => sf.FieldKey == f.FieldKey)) continue;
                                                            <div class="vdd-dropdown-item" @onclick="() => AddSearchFilter(f.FieldKey)">@f.DisplayLabel</div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <button class="vdd-search-execute-btn" @onclick="RunRetailSearch"
                                                disabled="@(!HasAnySearchFieldValue())">
                                            Search
                                        </button>
                                    </div>

                                    @* Filter pills *@
                                    @if (_searchFilters.Count > 0)
                                    {
                                        <div class="vdd-filter-pills">
                                            @for (int i = 0; i < _searchFilters.Count; i++)
                                            {
                                                var idx = i;
                                                var filter = _searchFilters[idx];
                                                <div class="vdd-filter-pill">
                                                    <span class="vdd-filter-pill-label">@FormatClaimKey(filter.FieldKey):</span>
                                                    <input type="text" class="vdd-filter-pill-input"
                                                           value="@filter.Value"
                                                           placeholder="..."
                                                           @oninput="(e) => UpdateFilter(idx, e.Value?.ToString())"
                                                           @onkeydown="OnRetailSearchKeyDown" />
                                                    <button class="vdd-filter-pill-remove" @onclick="() => RemoveFilter(idx)">
                                                        <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 14px;" />
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>

                                @if (hasRetail && HasAnySearchFieldValue())
                                {
                                    <p class="vdd-rematch-warning">
                                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: #EF9F27;" />
                                        Searching will let you replace the current retail match.
                                    </p>
                                }
                            </div>

                            @* Search results with field comparison cards *@
                            @if (_searching)
                            {
                                <div style="padding: 8px 0; text-align: center;">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.2);" />
                                </div>
                            }
                            else if (_hasSearched && _retailSearchResults.Count == 0)
                            {
                                <p class="vdd-stage-hint">No retail results found</p>
                            }
                            else if (_retailSearchResults.Count > 0)
                            {
                                <div class="vdd-search-results" style="max-height: none;">
                                    @foreach (var result in _retailSearchResults)
                                    {
                                        var isExpanded = _pendingRetailMatch == result;
                                        var fieldComparisons = GetRetailFieldComparisons(result);
                                        var overallScore = result.Confidence;
                                        <div class="vdd-result-card @(isExpanded ? "vdd-result-card--expanded" : "")"
                                             @onclick="() => SelectRetailResult(result)">
                                            @* Header: cover + title + overall score *@
                                            <div class="vdd-result-header">
                                                <div class="vdd-result-cover">
                                                    @if (!string.IsNullOrEmpty(result.CoverUrl))
                                                    {
                                                        <img src="@result.CoverUrl" alt="" loading="lazy" />
                                                    }
                                                    else
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 24px; color: rgba(255,255,255,0.15);" />
                                                    }
                                                </div>
                                                <div class="vdd-result-title-block">
                                                    <span class="vdd-result-card-title">@result.Title</span>
                                                    @{
                                                        var displayFields = GetRetailResultFields(result);
                                                    }
                                                    <span class="vdd-result-card-meta">@displayFields.Subline</span>
                                                </div>
                                                <div class="vdd-result-score">
                                                    <span class="vdd-result-score-val" style="color: @GetScoreColor(overallScore);">@overallScore.ToString("F2")</span>
                                                    <div class="vdd-result-score-bar">
                                                        @for (int s = 0; s < 5; s++)
                                                        {
                                                            var filled = s < (int)Math.Round(overallScore * 5);
                                                            <div class="vdd-score-seg @(filled ? "vdd-score-seg--filled" : "")" style="@(filled ? $"background: {GetScoreColor(overallScore)};" : "")"></div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>

                                            @* Field comparison table (always visible) *@
                                            <div class="vdd-field-compare">
                                                <div class="vdd-compare-header-row">
                                                    <span class="vdd-compare-col-label">YOUR FILE</span>
                                                    <span class="vdd-compare-col-label" style="text-align: center;">↔</span>
                                                    <span class="vdd-compare-col-label">PROVIDER MATCH</span>
                                                    <span class="vdd-compare-col-label" style="text-align: right;">SCORE</span>
                                                </div>
                                                @foreach (var comp in fieldComparisons)
                                                {
                                                    <div class="vdd-compare-row">
                                                        <div class="vdd-compare-cell vdd-compare-cell--yours">
                                                            <span class="vdd-compare-field-name">@comp.FieldLabel</span>
                                                            <span class="vdd-compare-field-val">@(string.IsNullOrEmpty(comp.YourValue) ? "—" : comp.YourValue)</span>
                                                        </div>
                                                        <span class="vdd-compare-arrow">↔</span>
                                                        <div class="vdd-compare-cell vdd-compare-cell--theirs">
                                                            <span class="vdd-compare-field-val">@(string.IsNullOrEmpty(comp.ProviderValue) ? "—" : comp.ProviderValue)</span>
                                                        </div>
                                                        <div class="vdd-compare-cell vdd-compare-cell--score">
                                                            @if (comp.Score.HasValue)
                                                            {
                                                                <span style="color: @GetScoreColor(comp.Score.Value); font-weight: 700; font-size: 12px;">@comp.Score.Value.ToString("F2")</span>
                                                                <div class="vdd-score-mini-bar">
                                                                    <div class="vdd-score-mini-fill" style="width: @(comp.Score.Value * 100)%; background: @GetScoreColor(comp.Score.Value);"></div>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <span style="color: rgba(255,255,255,0.2); font-size: 11px;">—</span>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>

                                            @* Confirm button (only when expanded/selected) *@
                                            @if (isExpanded)
                                            {
                                                <div class="vdd-result-actions">
                                                    @if (!_confirmingRetailMatch)
                                                    {
                                                        <button class="vdd-confirm-match-btn" @onclick:stopPropagation="true"
                                                                @onclick="() => _confirmingRetailMatch = true">
                                                            Confirm Match
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <div class="vdd-confirm-row" @onclick:stopPropagation="true">
                                                            @if (IsRealRetailMatch(MediaItem?.RetailMatch))
                                                            {
                                                                <span class="vdd-overwrite-warning">
                                                                    <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: #EF9F27;" />
                                                                    Replaces current retail match.
                                                                </span>
                                                            }
                                                            <span class="vdd-confirm-prompt">Are you sure?</span>
                                                            <button class="vdd-confirm-match-btn" @onclick="() => ConfirmRetailMatch(result)">Yes</button>
                                                            <button class="vdd-cancel-match-btn" @onclick="() => _confirmingRetailMatch = false">Cancel</button>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @* Existing match status (below search and results) *@
                            @if (hasRetail)
                            {
                                <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.04);">
                                    @{
                                        var retailDisplayName = GetRetailProviderDisplayName();
                                        var isManualMatch = MediaItem?.RetailMatch?.Equals("user_manual", StringComparison.OrdinalIgnoreCase) == true;
                                    }
                                    <div class="vdd-match-status vdd-match-status--ok">
                                        <span class="vdd-pipeline-dot vdd-pipeline-dot--ok"></span>
                                        <span>@(isManualMatch ? "Manually matched by user" : $"Matched automatically via {retailDisplayName}")</span>
                                    </div>
                                    @if (GetRetailProviderUrl() is { } retailUrl)
                                    {
                                        <a href="@retailUrl.Url" target="_blank" rel="noopener" class="vdd-provider-link">
                                            <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="font-size: 11px;" />
                                            @retailUrl.Label
                                        </a>
                                    }

                                    @* Show retail provider claims *@
                                    @if (retailClaims.Count > 0)
                                    {
                                        <div class="vdd-metadata-list" style="margin-top: 8px;">
                                            @foreach (var group in retailClaims.GroupBy(c => c.ClaimKey).OrderBy(g => g.Key))
                                            {
                                                var bestClaim = group.OrderByDescending(c => c.Confidence).First();
                                                <div class="vdd-claim-row">
                                                    <span class="vdd-field-label">@FormatClaimKey(group.Key)</span>
                                                    <span class="vdd-field-value">@bestClaim.ClaimValue</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        break;

                    case 2:
                        @* ── WIKIDATA TAB ── *@
                        <div class="vdd-tab-content">
                            @* Always-visible Wikidata search (at the top) *@
                            <div class="vdd-tab-search" style="margin-top: 0; padding-top: 0; border-top: none;">
                                <div class="vdd-search-bar-wrap" style="margin-top: 4px;">
                                    <div class="vdd-search-type-row">
                                        <span class="vdd-search-type-label">Type:</span>
                                        <div class="vdd-dropdown-wrap">
                                            <button class="vdd-dropdown-btn" @onclick="() => _showWikiMediaTypeDropdown = !_showWikiMediaTypeDropdown">
                                                @_searchMediaType <MudIcon Icon="@Icons.Material.Outlined.ExpandMore" Style="font-size: 14px;" />
                                            </button>
                                            @if (_showWikiMediaTypeDropdown)
                                            {
                                                <div class="vdd-dropdown-menu">
                                                    @foreach (var mt in new[] { "Books", "Audiobooks", "Movies", "TV", "Music", "Comics", "Podcasts" })
                                                    {
                                                        <div class="vdd-dropdown-item" @onclick="() => SetWikiMediaType(mt)">@mt</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="vdd-search-main-row">
                                        <div class="vdd-search-input-group">
                                            <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 18px; color: rgba(255,255,255,0.35);" />
                                            <input type="text" class="vdd-search-primary-input"
                                                   placeholder="@(hasWikidata ? "Search to relink..." : "Search by title or enter QID...")"
                                                   @bind="_wikidataSearchQuery" @bind:event="oninput" @onkeydown="OnWikidataSearchKeyDown" />
                                        </div>
                                        <button class="vdd-search-execute-btn" @onclick="RunWikidataSearch"
                                                disabled="@(string.IsNullOrWhiteSpace(_wikidataSearchQuery))">
                                            Search
                                        </button>
                                    </div>
                                </div>
                                @if (hasWikidata && !string.IsNullOrWhiteSpace(_wikidataSearchQuery))
                                {
                                    <p class="vdd-rematch-warning">
                                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: #EF9F27;" />
                                        Searching will let you replace the current Wikidata link.
                                    </p>
                                }
                            </div>

                            @* Search results with field comparison cards *@
                            @if (_searchingWikidata)
                            {
                                <div style="padding: 8px 0; text-align: center;">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.2);" />
                                </div>
                            }
                            else if (_hasSearchedWikidata && _wikidataSearchResults.Count == 0)
                            {
                                <p class="vdd-stage-hint">No Wikidata results for "@_wikidataSearchQuery"</p>
                            }
                            else if (_wikidataSearchResults.Count > 0)
                            {
                                <div class="vdd-search-results" style="max-height: none;">
                                    @foreach (var result in _wikidataSearchResults)
                                    {
                                        var isExpanded = _pendingWikidataMatch == result;
                                        var wikiFieldComparisons = GetWikidataFieldComparisons(result);
                                        <div class="vdd-result-card @(isExpanded ? "vdd-result-card--expanded" : "")"
                                             @onclick="() => SelectWikidataResult(result)">
                                            @* Header: icon + label/QID *@
                                            <div class="vdd-result-header">
                                                <div class="vdd-result-cover" style="background: rgba(167,139,250,0.1); border-color: rgba(167,139,250,0.15);">
                                                    <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 24px; color: #A78BFA;" />
                                                </div>
                                                <div class="vdd-result-title-block">
                                                    <span class="vdd-result-card-title">@result.Label</span>
                                                    <span class="vdd-result-card-meta">@result.Qid</span>
                                                    @if (!string.IsNullOrEmpty(result.Description))
                                                    {
                                                        <span class="vdd-result-card-meta" style="overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; white-space: normal;">@result.Description</span>
                                                    }
                                                </div>
                                                <div class="vdd-result-score">
                                                    @{
                                                        var wikiScore = result.Confidence;
                                                    }
                                                    <span class="vdd-result-score-val" style="color: @GetScoreColor(wikiScore);">@wikiScore.ToString("F2")</span>
                                                    <div class="vdd-result-score-bar">
                                                        @for (int s = 0; s < 5; s++)
                                                        {
                                                            var filled = s < (int)Math.Round(wikiScore * 5);
                                                            <div class="vdd-score-seg @(filled ? "vdd-score-seg--filled" : "")" style="@(filled ? $"background: {GetScoreColor(wikiScore)};" : "")"></div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>

                                            @* Field comparison table *@
                                            @if (wikiFieldComparisons.Count > 0)
                                            {
                                                <div class="vdd-field-compare">
                                                    <div class="vdd-compare-header-row">
                                                        <span class="vdd-compare-col-label">YOUR FILE</span>
                                                        <span class="vdd-compare-col-label" style="text-align: center;">↔</span>
                                                        <span class="vdd-compare-col-label">WIKIDATA</span>
                                                        <span class="vdd-compare-col-label" style="text-align: right;">SCORE</span>
                                                    </div>
                                                    @foreach (var comp in wikiFieldComparisons)
                                                    {
                                                        <div class="vdd-compare-row">
                                                            <div class="vdd-compare-cell vdd-compare-cell--yours">
                                                                <span class="vdd-compare-field-name">@comp.FieldLabel</span>
                                                                <span class="vdd-compare-field-val">@(string.IsNullOrEmpty(comp.YourValue) ? "—" : comp.YourValue)</span>
                                                            </div>
                                                            <span class="vdd-compare-arrow">↔</span>
                                                            <div class="vdd-compare-cell vdd-compare-cell--theirs">
                                                                <span class="vdd-compare-field-val">@(string.IsNullOrEmpty(comp.ProviderValue) ? "—" : comp.ProviderValue)</span>
                                                            </div>
                                                            <div class="vdd-compare-cell vdd-compare-cell--score">
                                                                @if (comp.Score.HasValue)
                                                                {
                                                                    <span style="color: @GetScoreColor(comp.Score.Value); font-weight: 700; font-size: 12px;">@comp.Score.Value.ToString("F2")</span>
                                                                    <div class="vdd-score-mini-bar">
                                                                        <div class="vdd-score-mini-fill" style="width: @(comp.Score.Value * 100)%; background: @GetScoreColor(comp.Score.Value);"></div>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <span style="color: rgba(255,255,255,0.2); font-size: 11px;">—</span>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            @* Confirm button (only when expanded/selected) *@
                                            @if (isExpanded)
                                            {
                                                <div class="vdd-result-actions">
                                                    @if (!_confirmingWikidataMatch)
                                                    {
                                                        <button class="vdd-confirm-match-btn" @onclick:stopPropagation="true"
                                                                @onclick="() => _confirmingWikidataMatch = true">
                                                            Link to @result.Qid
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <div class="vdd-confirm-row" @onclick:stopPropagation="true">
                                                            @if (IsWikidataMatched(MediaItem?.WikidataQid))
                                                            {
                                                                <span class="vdd-overwrite-warning">
                                                                    <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px; color: #EF9F27;" />
                                                                    Replaces current link (@MediaItem?.WikidataQid).
                                                                </span>
                                                            }
                                                            <span class="vdd-confirm-prompt">Are you sure?</span>
                                                            <button class="vdd-confirm-match-btn" @onclick:stopPropagation="true" @onclick="() => ConfirmWikidataMatch(result.Qid)">
                                                                Yes
                                                            </button>
                                                            <button class="vdd-cancel-match-btn" @onclick="() => _confirmingWikidataMatch = false">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @* Existing QID status (below search and results) *@
                            @if (hasWikidata)
                            {
                                <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.04);">
                                    <div class="vdd-match-status vdd-match-status--ok">
                                        <span class="vdd-pipeline-dot vdd-pipeline-dot--ok"></span>
                                        <a href="https://www.wikidata.org/wiki/@MediaItem?.WikidataQid" target="_blank" rel="noopener" class="vdd-pipeline-qid-link">@MediaItem?.WikidataQid</a>
                                    </div>
                                    <p class="vdd-match-explanation">@GetWikidataExplanation()</p>

                                    @* Wikidata claims *@
                                    @if (wikiClaims.Count > 0)
                                    {
                                        <div class="vdd-metadata-list" style="margin-top: 8px;">
                                            @foreach (var group in wikiClaims.GroupBy(c => c.ClaimKey).OrderBy(g => g.Key))
                                            {
                                                var bestClaim = group.OrderByDescending(c => c.Confidence).First();
                                                <div class="vdd-claim-row">
                                                    <span class="vdd-field-label">@FormatClaimKey(group.Key)</span>
                                                    <span class="vdd-field-value">@bestClaim.ClaimValue</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="vdd-match-status vdd-match-status--fail" style="margin-top: 12px;">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--fail"></span>
                                    <span>No Wikidata identity assigned yet</span>
                                </div>
                            }
                        </div>
                        break;

                    case 3:
                        @* ── UNIVERSE TAB ── *@
                        <div class="vdd-tab-content">
                            @if (!string.IsNullOrEmpty(MediaItem?.UniverseName))
                            {
                                <div class="vdd-match-status vdd-match-status--ok">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--ok"></span>
                                    <span>Assigned to universe: @MediaItem.UniverseName</span>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(MediaItem?.WikidataQid) && !MediaItem.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="vdd-match-status vdd-match-status--warn">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--warn"></span>
                                    <span>Wikidata linked but universe assignment pending</span>
                                </div>
                                <p class="vdd-stage-hint">The Engine will automatically assign a universe once enrichment completes.</p>
                            }
                            else
                            {
                                <div class="vdd-match-status vdd-match-status--fail">
                                    <span class="vdd-pipeline-dot vdd-pipeline-dot--fail"></span>
                                    <span>No universe assigned</span>
                                </div>
                                <p class="vdd-stage-hint">A Wikidata identity is needed before the Engine can determine universe membership.</p>
                            }
                        </div>
                        break;
                }
            </DrawerSection>

            <DrawerSection @key="@($"fileinfo-{MediaItem.EntityId}")" Title="File Information" Icon="@Icons.Material.Outlined.InsertDriveFile" DefaultOpen="false">
                <div class="vdd-file-info">
                    @foreach (var row in GetFileInfoRows())
                    {
                        <div class="vdd-file-info-row">
                            <span class="vdd-file-info-label">@row.Label</span>
                            <span class="vdd-file-info-value">@row.Value</span>
                        </div>
                    }
                </div>
            </DrawerSection>

            <DrawerSection @key="@($"history-{MediaItem.EntityId}")" Title="History" Icon="@Icons.Material.Outlined.History" DefaultOpen="false">
                <VaultTimeline EntityId="@MediaItem.EntityId" />
            </DrawerSection>

            <DrawerSection @key="@($"assets-{MediaItem.EntityId}")" Title="@L["VaultDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
                <div class="vdd-assets">
                    @* Cover Art *@
                    <div class="vdd-asset-row">
                        <span class="vdd-asset-label">@L["VaultDetail_AssetCoverArt"]</span>
                        <div class="vdd-asset-items">
                            @if (!string.IsNullOrEmpty(MediaItem.CoverUrl))
                            {
                                <div class="vdd-asset-filled">
                                    <img src="@MediaItem.CoverUrl" alt="Cover" class="vdd-asset-img" />
                                    <span class="vdd-asset-source">@L["VaultDetail_AssetSourceProvider"]</span>
                                </div>
                            }
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetCustom"]</span>
                            </div>
                        </div>
                    </div>
                    @* Hero Banner *@
                    <div class="vdd-asset-row">
                        <span class="vdd-asset-label">@L["VaultDetail_AssetHeroBanner"]</span>
                        <div class="vdd-asset-items">
                            @if (!string.IsNullOrEmpty(MediaItem.HeroUrl))
                            {
                                <div class="vdd-asset-filled vdd-asset-filled--wide">
                                    <img src="@MediaItem.HeroUrl" alt="Hero" class="vdd-asset-img" />
                                    <span class="vdd-asset-source">@L["VaultDetail_AssetSourceGenerated"]</span>
                                </div>
                            }
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetCustom"]</span>
                            </div>
                        </div>
                    </div>
                    @* Remaining types as upload-only *@
                    @foreach (var assetType in new[] { "Logo", "Backdrop" })
                    {
                        <div class="vdd-asset-row">
                            <span class="vdd-asset-label">@assetType</span>
                            <div class="vdd-asset-items">
                                <div class="vdd-asset-slot">
                                    <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                                    <span class="vdd-asset-upload">@L["VaultDetail_AssetUpload"]</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </DrawerSection>

        }
        else if (Person is not null)
        {
            @* ── Person: delegate to PersonBiographyDrawer ── *@
            <PersonBiographyDrawer Person="@Person"
                                   Aliases="@_aliases"
                                   PersonWorks="@_personWorks"
                                   PersonCharacterRoles="@_personCharacterRoles"
                                   OnPersonAliasClicked="@OnPersonAliasClicked" />

            @* Old person sections removed — all person content is now in PersonBiographyDrawer *@
        }
        else if (Universe is not null)
        {
            @* ── Universe Sections ── *@

            @* Health Score Ring *@
            @if (_universeHealth is not null)
            {
                <div class="vdd-health-ring-wrap">
                    @{
                        var hp = _universeHealth.HealthPercent;
                        var ringColor = hp >= 80 ? "#5DCAA5" : hp >= 50 ? "#C9922E" : "#EF4444";
                        var circumference = 2 * Math.PI * 22;
                        var dashOffset = circumference * (1 - hp / 100.0);
                    }
                    <div class="vdd-health-ring">
                        <svg width="64" height="64" viewBox="0 0 64 64">
                            <circle cx="32" cy="32" r="22" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="6" />
                            <circle cx="32" cy="32" r="22" fill="none"
                                    stroke="@ringColor" stroke-width="6"
                                    stroke-dasharray="@circumference.ToString("F1")"
                                    stroke-dashoffset="@dashOffset.ToString("F1")"
                                    stroke-linecap="round"
                                    transform="rotate(-90 32 32)" />
                        </svg>
                        <span class="vdd-health-pct" style="color: @ringColor;">@((int)hp)%</span>
                    </div>
                    <div class="vdd-health-label-block">
                        <span class="vdd-health-title">@L["VaultDetail_HealthScore"]</span>
                        <span class="vdd-health-sub">@_universeHealth.EntitiesEnriched / @_universeHealth.EntitiesTotal @L["VaultDetail_EntityCounts"]</span>
                    </div>
                </div>
            }

            @* Entity Counts *@
            @if (_universeHealth is not null && _universeHealth.EntitiesTotal > 0)
            {
                <DrawerSection Title="@L["VaultDetail_EntityCounts"]" Icon="@Icons.Material.Outlined.Category">
                    <div class="vdd-entity-counts">
                        <div class="vdd-entity-count-item">
                            <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 16px; color: #A78BFA;" />
                            <span class="vdd-entity-count-label">Characters</span>
                            <span class="vdd-entity-count-val">@_universeCharacters.Count</span>
                        </div>
                        <div class="vdd-entity-count-item">
                            <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Style="font-size: 16px; color: #60A5FA;" />
                            <span class="vdd-entity-count-label">Locations</span>
                            <span class="vdd-entity-count-val">@(_universeHealth.EntitiesTotal - _universeCharacters.Count)</span>
                        </div>
                        <div class="vdd-entity-count-item">
                            <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Style="font-size: 16px; color: #C9922E;" />
                            <span class="vdd-entity-count-label">Relationships</span>
                            <span class="vdd-entity-count-val">@_universeHealth.RelationshipsTotal</span>
                        </div>
                    </div>
                </DrawerSection>
            }

            @* Characters *@
            <DrawerSection Title="@L["VaultDetail_SectionCharacters"]" Icon="@Icons.Material.Outlined.TheaterComedy">
                @if (_loadingUniverseData)
                {
                    <div style="padding: 12px 0; text-align: center;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.2);" />
                    </div>
                }
                else if (_universeCharacters.Count == 0)
                {
                    <p class="vdd-empty-hint">@L["VaultDetail_HintNoCharacters"]</p>
                }
                else
                {
                    <div class="vdd-characters-grid">
                        @foreach (var ch in _universeCharacters.Take(12))
                        {
                            <div class="vdd-character-item">
                                <div class="vdd-character-avatar">
                                    @if (!string.IsNullOrEmpty(ch.PortraitUrl))
                                    {
                                        <img src="@ch.PortraitUrl" alt="@ch.CharacterName" loading="lazy" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 20px; color: rgba(255,255,255,0.15);" />
                                    }
                                </div>
                                <div class="vdd-character-info">
                                    <span class="vdd-character-name">@ch.CharacterName</span>
                                    @if (!string.IsNullOrEmpty(ch.DefaultActorName))
                                    {
                                        <span class="vdd-character-actor">@ch.DefaultActorName</span>
                                    }
                                    @if (ch.ActorCount > 1)
                                    {
                                        <span class="vdd-actor-count-badge">@string.Format(L["VaultDetail_ActorsCount"].ToString(), ch.ActorCount)</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    @if (_universeCharacters.Count > 12)
                    {
                        <p class="vdd-stage-hint" style="margin-top: 8px;">+@(_universeCharacters.Count - 12) more — open Universe Explorer to see all</p>
                    }
                }
            </DrawerSection>

            @* Universe Content *@
            <DrawerSection Title="@L["VaultDetail_SectionUniverseContent"]" Icon="@Icons.Material.Outlined.Layers">
                <div class="vdd-universe-content">
                    @if (Universe.WorkCount > 0)
                    {
                        <p class="vdd-field-value">@Universe.WorkCount @L["VaultDetail_WorksAcross"] @(Universe.MediaTypes ?? L["VaultDetail_VariousMediaTypes"])</p>
                    }
                    else
                    {
                        <p class="vdd-empty-hint">@L["VaultDetail_HintNoSeriesLinked"]</p>
                    }
                </div>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionNotablePeople"]" Icon="@Icons.Material.Outlined.People">
                <p class="vdd-empty-hint">@L["VaultDetail_HintPeopleAssociated"]</p>
            </DrawerSection>

            <DrawerSection Title="@L["VaultDetail_SectionAssets"]" Icon="@Icons.Material.Outlined.Image" DefaultOpen="false">
                <div class="vdd-assets">
                    @foreach (var assetType in _assetTypes)
                    {
                        <div class="vdd-asset-row">
                            <span class="vdd-asset-label">@assetType</span>
                            <div class="vdd-asset-slot">
                                <MudIcon Icon="@Icons.Material.Outlined.Image" Style="font-size: 20px; color: rgba(255,255,255,0.08);" />
                                <span class="vdd-asset-upload">@L["VaultDetail_AssetUpload"]</span>
                            </div>
                        </div>
                    }
                </div>
            </DrawerSection>

            @* ── History Timeline ── *@
            <DrawerSection Title="History" Icon="@Icons.Material.Outlined.History" DefaultOpen="false">
                <VaultTimeline EntityId="@Universe.Id" />
            </DrawerSection>

            @* Trigger enrichment + open explorer actions *@
            <div class="vdd-universe-actions">
                <button class="vdd-action-btn vdd-action-btn--primary" @onclick="OpenUniverseExplorer">
                    <MudIcon Icon="@Icons.Material.Outlined.Hub" Style="font-size: 15px;" />
                    @L["VaultDetail_OpenExplorer"]
                </button>
                <button class="vdd-action-btn" @onclick="TriggerEnrichment">
                    <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Style="font-size: 15px;" />
                    @L["VaultDetail_TriggerEnrichment"]
                </button>
            </div>
        }
    </div>

    @* ── 3. Pinned Footer (Media only) ── *@
    @if (MediaItem is not null)
    {
        <div class="vdd-footer">
            @if (_confirmPurge)
            {
                <div class="vdd-purge-confirm-row">
                    <span class="vdd-purge-confirm-text">@L["VaultDetail_ConfirmPurge"]</span>
                    <button class="vdd-purge-btn vdd-purge-btn--confirm" @onclick="HandlePurge">
                        <span>Yes, Purge</span>
                    </button>
                    <button class="vdd-purge-cancel-btn" @onclick="() => _confirmPurge = false">
                        <span>Cancel</span>
                    </button>
                </div>
            }
            else
            {
                <button class="vdd-purge-btn" @onclick="HandlePurge">
                    <MudIcon Icon="@Icons.Material.Outlined.DeleteForever" Style="font-size: 16px;" />
                    <span>@L["VaultDetail_ActionPurgeRecord"]</span>
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public VaultItemViewModel? MediaItem { get; set; }
    [Parameter] public PersonListItemDto? Person { get; set; }
    [Parameter] public HubViewModel? Universe { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Guid> OnPurge { get; set; }
    [Parameter] public EventCallback<Guid> OnApplyMatch { get; set; }
    [Parameter] public EventCallback<Guid> OnPersonAliasClicked { get; set; }
    [Parameter] public EventCallback<string> OnCreatorClicked { get; set; }

    private bool _confirmPurge;
    private int _selectedStage = 0;
    private static readonly string[] _assetTypes = ["Cover Art", "Headshot", "Banner", "Logo", "Backdrop"];
    private bool _searching;
    private bool _hasSearched;
    private List<RegistryItemViewModel> _searchResults = [];
    private PersonAliasesResponseDto? _aliases;
    private List<HubViewModel>? _personWorks;
    private RegistryItemViewModel? _pendingMatch;
    private string _selectedMediaType = "";
    private string _searchMediaType = "";
    // New filter-based search state (replaces _activeSearchFields + _searchFieldValues)
    private string _primarySearchField = "title";
    private string _primarySearchValue = "";
    private List<(string FieldKey, string Value)> _searchFilters = [];
    private bool _showFilterDropdown;
    private bool _showPrimaryDropdown;
    private bool _showMediaTypeDropdown;
    private bool _showWikiMediaTypeDropdown;
    private List<RetailCandidateDto> _retailSearchResults = [];
    private RetailCandidateDto? _pendingRetailMatch;
    private bool _confirmingRetailMatch;
    private bool _searchingWikidata;
    private List<UniverseCandidateDto> _wikidataSearchResults = [];
    private UniverseCandidateDto? _pendingWikidataMatch;
    private bool _confirmingWikidataMatch;
    private string _wikidataSearchQuery = "";
    private bool _hasSearchedWikidata;
    private List<ClaimHistoryDto> _claims = [];
    private bool _claimsLoading;

    private void OnSearchTypeChanged(ChangeEventArgs e)
    {
        _searchMediaType = e.Value?.ToString() ?? "";
        _retailSearchResults = [];
        _pendingRetailMatch = null;
        _primarySearchField = "title";
        _primarySearchValue = "";
        _searchFilters = [];
    }

    // Universe data
    private UniverseHealthDto? _universeHealth;
    private IReadOnlyList<UniverseCharacterDto> _universeCharacters = [];
    private bool _loadingUniverseData;

    // Person character roles
    private IReadOnlyList<CharacterRoleDto> _personCharacterRoles = [];

    private bool IsInLibrary => MediaItem?.Status?.Equals("Confirmed", StringComparison.OrdinalIgnoreCase) == true
                             || MediaItem?.VaultDisplayStatus == VaultStatus.Verified;

    /// <summary>Returns true if the retail match is from an actual retail provider (not local_processor or library_scanner).</summary>
    private static bool IsRealRetailMatch(string? retailMatch) =>
        retailMatch is not "none" and not "" and not null
        && !retailMatch.Equals("local_processor", StringComparison.OrdinalIgnoreCase)
        && !retailMatch.Equals("library_scanner", StringComparison.OrdinalIgnoreCase);

    /// <summary>Returns true if a valid Wikidata QID is present (not null, empty, or NF-prefixed).</summary>
    private static bool IsWikidataMatched(string? qid) =>
        !string.IsNullOrEmpty(qid) && !qid.StartsWith("NF", StringComparison.OrdinalIgnoreCase);

    /// <summary>Looks up the Wikipedia URL from claims, falling back to GoToLinkedPage for persons without claims.</summary>
    private string? GetWikipediaUrl()
    {
        // Try claims first — stored wikipedia_url from Wikidata provider
        if (_claims is not null && _claims.Count > 0)
        {
            var wikiClaim = _claims.FirstOrDefault(c =>
                c.ClaimKey.Equals("wikipedia_url", StringComparison.OrdinalIgnoreCase)
                && !string.IsNullOrEmpty(c.ClaimValue)
                && Uri.IsWellFormedUriString(c.ClaimValue, UriKind.Absolute));
            if (wikiClaim is not null) return wikiClaim.ClaimValue;
        }

        // Fallback: construct from QID (media item or person)
        var qid = MediaItem?.WikidataQid ?? Person?.WikidataQid;
        if (!string.IsNullOrEmpty(qid) && !qid.StartsWith("NF", StringComparison.OrdinalIgnoreCase))
            return $"https://www.wikidata.org/wiki/Special:GoToLinkedPage/{qid}/enwiki";

        return null;
    }

