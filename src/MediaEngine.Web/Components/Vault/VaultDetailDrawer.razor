        border-radius: 6px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: color 0.15s, background 0.15s;
    }

    .vdd-wiki-badge:hover {
        color: rgba(255, 255, 255, 0.8);
        background: rgba(255, 255, 255, 0.08);
    }

    .vdd-role-chip {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #60A5FA;
        background: rgba(96, 165, 250, 0.1);
        border: 1px solid rgba(96, 165, 250, 0.2);
        padding: 2px 8px;
        border-radius: 6px;
    }

    .vdd-title {
        font-size: 26px;
        font-weight: 900;
        color: white;
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin: 0;
        word-wrap: break-word;
        overflow-wrap: break-word;
        padding-right: 48px;
    }

    .vdd-subtitle {
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: rgba(255, 255, 255, 0.35);
        margin-top: 4px;
    }

    .vdd-subtitle-italic {
        font-size: 12px;
        font-style: italic;
        color: rgba(255, 255, 255, 0.4);
        margin-top: 4px;
        max-width: 300px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .vdd-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 8px;
    }

    .vdd-meta-item {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(255, 255, 255, 0.4);
    }

    /* ── Body ── */
    .vdd-body {
        flex: 1;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.08) transparent;
    }

    /* ── Source section ── */
    .vdd-source {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .vdd-location-badge {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 4px 10px;
        border-radius: 4px;
        align-self: flex-start;
    }

    .vdd-location--library {
        background: rgba(93, 202, 165, 0.1);
        border: 1px solid rgba(93, 202, 165, 0.2);
        color: #5DCAA5;
    }

    .vdd-location--staging {
        background: rgba(239, 159, 39, 0.1);
        border: 1px solid rgba(239, 159, 39, 0.2);
        color: #EF9F27;
    }

    .vdd-location-chip {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 2px 8px;
        border-radius: 6px;
    }

    .vdd-location-chip--library {
        background: rgba(93, 202, 165, 0.1);
        border: 1px solid rgba(93, 202, 165, 0.2);
        color: #5DCAA5;
    }

    .vdd-location-chip--staging {
        background: rgba(239, 159, 39, 0.1);
        border: 1px solid rgba(239, 159, 39, 0.2);
        color: #EF9F27;
    }

    .vdd-file-block {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .vdd-file-name {
        font-size: 12px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.7);
        word-break: break-all;
        margin: 0;
        font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    }

    .vdd-field-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .vdd-field-label {
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.3);
        flex-shrink: 0;
    }

    .vdd-field-value {
        font-size: 13px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.7);
    }

    /* ── Pipeline section ── */
    .vdd-pipeline {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .vdd-stage-block {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 10px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .vdd-stage-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .vdd-stage-label {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.4);
    }

    .vdd-stage-actions {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .vdd-stage-status {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 2px 8px;
        border-radius: 4px;
        border: 1px solid;
    }

    .vdd-unmatch-btn {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 2px 8px;
        border-radius: 4px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.4);
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-unmatch-btn:hover {
        background: rgba(255, 80, 80, 0.1);
        border-color: rgba(255, 80, 80, 0.3);
        color: rgba(255, 80, 80, 0.8);
    }

    .vdd-match-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 6px;
        padding: 8px 10px;
    }

    .vdd-match-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .vdd-match-value {
        font-size: 13px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.8);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .vdd-match-tag {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        flex-shrink: 0;
        color: rgba(255, 255, 255, 0.3);
    }

    .vdd-match-tag--provider { color: #60A5FA; }
    .vdd-match-tag--authority { color: #A78BFA; }

    .vdd-stage-hint {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.3);
        font-style: italic;
        margin: 0;
    }

    .vdd-provider-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .vdd-provider-chip {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 4px 10px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.5);
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-provider-chip:hover {
        background: rgba(96, 165, 250, 0.1);
        border-color: rgba(96, 165, 250, 0.25);
        color: #60A5FA;
    }

    .vdd-qid-result {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        font-weight: 700;
        color: #A78BFA;
        background: rgba(167, 139, 250, 0.08);
        border-radius: 6px;
        padding: 8px 10px;
    }

    .vdd-universe-link {
        font-size: 11px;
        font-weight: 700;
        color: #A78BFA;
        cursor: pointer;
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .vdd-cascade-note {
        font-size: 9px;
        color: rgba(255, 255, 255, 0.2);
        font-style: italic;
        margin: 0;
        padding-top: 4px;
    }

    /* ── Assets section ── */
    .vdd-assets {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .vdd-asset-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .vdd-asset-label {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.35);
        flex-shrink: 0;
    }

    .vdd-asset-items {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .vdd-asset-filled {
        position: relative;
        width: 48px;
        height: 48px;
        border-radius: 6px;
        overflow: hidden;
    }

    .vdd-asset-filled--wide {
        width: 80px;
    }

    .vdd-asset-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .vdd-asset-source {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        font-size: 7px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: rgba(0, 0, 0, 0.7);
        color: rgba(255, 255, 255, 0.6);
        text-align: center;
        padding: 2px 0;
    }

    .vdd-asset-slot {
        width: 48px;
        height: 48px;
        border-radius: 6px;
        border: 1px dashed rgba(255, 255, 255, 0.08);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        cursor: pointer;
        transition: border-color 0.15s;
    }

    .vdd-asset-slot:hover {
        border-color: rgba(255, 255, 255, 0.2);
    }

    .vdd-asset-upload {
        font-size: 7px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(255, 255, 255, 0.2);
    }

    /* ── Lifecycle section ── */
    .vdd-lifecycle {
        display: flex;
        gap: 12px;
    }

    .vdd-lifecycle-card {
        flex: 1;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 10px;
        padding: 12px 14px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .vdd-lifecycle-value {
        font-size: 13px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.7);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .vdd-mono {
        font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
        font-size: 11px;
    }

    /* ── Identities section ── */
    .vdd-identities {
        display: flex;
        flex-direction: column;
    }

    .vdd-identity-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .vdd-identity-items {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .vdd-identity-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.7);
        font-weight: 600;
    }

    /* ── Universe section ── */
    .vdd-universe-content {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.6);
    }

    /* ── Empty hints ── */
    .vdd-empty-hint {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.25);
        font-style: italic;
        margin: 0;
    }

    /* ── Person Library Presence list ── */
    .vdd-presence-list {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .vdd-presence-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 12px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.04);
    }

    .vdd-presence-title {
        font-size: 13px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
    }

    .vdd-presence-type {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    /* ── Review banner ── */
    .vdd-review-banner {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        border-radius: 10px;
        background: rgba(239, 159, 39, 0.08);
        border: 1px solid rgba(239, 159, 39, 0.15);
        color: #EF9F27;
        font-size: 12px;
        font-weight: 700;
    }

    .vdd-waiting-banner {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin: 0 24px 16px 24px;
        border-radius: 10px;
        background: rgba(56, 189, 248, 0.08);
        border: 1px solid rgba(56, 189, 248, 0.15);
        color: #38BDF8;
        font-size: 12px;
        font-weight: 700;
    }

    /* ── Manual search ── */
    .vdd-search-block {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: 8px;
    }

    .vdd-search-input {
        flex: 1;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 12px;
        color: rgba(255, 255, 255, 0.85);
        outline: none;
        transition: border-color 0.15s;
    }

    .vdd-search-input:focus {
        border-color: rgba(96, 165, 250, 0.3);
    }

    .vdd-search-input::placeholder {
        color: rgba(255, 255, 255, 0.2);
    }

    .vdd-search-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        border-radius: 8px;
        background: rgba(96, 165, 250, 0.15);
        border: 1px solid rgba(96, 165, 250, 0.25);
        color: #60A5FA;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .vdd-search-btn:hover:not(:disabled) {
        background: rgba(96, 165, 250, 0.25);
    }

    .vdd-search-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .vdd-search-results {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-top: 8px;
        max-height: 200px;
        overflow-y: auto;
    }

    .vdd-search-result-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s;
        border: 1px solid transparent;
    }

    .vdd-search-result-item:hover {
        background: rgba(255, 255, 255, 0.04);
    }

    .vdd-search-result-row {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .vdd-search-result-item--expanded {
        background: rgba(96, 165, 250, 0.06);
        border-color: rgba(96, 165, 250, 0.15);
    }

    .vdd-detail-fields {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .vdd-detail-field {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .vdd-confirm-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .vdd-confirm-prompt {
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.6);
    }

    .vdd-cancel-match-btn {
        padding: 4px 12px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.5);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-cancel-match-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.8);
    }

    .vdd-or-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 4px 0;
    }

    .vdd-or-divider::before,
    .vdd-or-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.06);
    }

    .vdd-or-divider span {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: rgba(255, 255, 255, 0.25);
    }

    .vdd-purge-confirm-row {
        display: flex;
        align-items: center;
        gap: 8px;
        justify-content: center;
    }

    .vdd-purge-confirm-text {
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 80, 80, 0.8);
    }

    .vdd-purge-cancel-btn {
        padding: 6px 14px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.5);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-purge-cancel-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.8);
    }

    .vdd-search-result-thumb {
        width: 36px;
        height: 52px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        position: relative;
        z-index: 1;
    }

    .vdd-search-result-thumb:hover {
        transform: scale(3);
        z-index: 50;
        box-shadow: 0 8px 32px rgba(0,0,0,0.8);
    }

    .vdd-search-result-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .vdd-search-result-info {
        flex: 1;
        min-width: 0;
    }

    .vdd-search-result-title {
        display: block;
        font-size: 12px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.85);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vdd-search-result-meta {
        display: block;
        font-size: 10px;
        color: rgba(255, 255, 255, 0.35);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vdd-search-result-desc {
        display: block;
        font-size: 10px;
        color: rgba(255, 255, 255, 0.25);
        margin-top: 2px;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .vdd-search-results-header {
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.25);
        padding: 6px 0 2px;
    }

    .vdd-confirm-match-btn {
        padding: 4px 12px;
        border-radius: 6px;
        background: rgba(93, 202, 165, 0.15);
        border: 1px solid rgba(93, 202, 165, 0.3);
        color: #5DCAA5;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.15s;
        flex-shrink: 0;
        animation: vdd-pulse 0.3s ease-out;
    }

    .vdd-confirm-match-btn:hover {
        background: rgba(93, 202, 165, 0.25);
        border-color: rgba(93, 202, 165, 0.5);
    }

    @@keyframes vdd-pulse {
        from { transform: scale(0.9); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }

    .vdd-rematch-block {
        margin-top: 8px;
    }

    .vdd-rematch-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 6px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.4);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.15s;
    }

    .vdd-rematch-btn:hover {
        background: rgba(96, 165, 250, 0.08);
        border-color: rgba(96, 165, 250, 0.2);
        color: #60A5FA;
    }

    /* ── Pen name linking ── */
    .vdd-identity-link {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #60A5FA;
        font-weight: 600;
        background: none;
        border: none;
        padding: 4px 0;
        cursor: pointer;
        transition: color 0.15s;
        text-align: left;
        width: 100%;
    }

    .vdd-identity-link:hover {
        color: #93C5FD;
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .vdd-alias-relationship {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: rgba(255, 255, 255, 0.25);
        margin-left: auto;
        flex-shrink: 0;
    }

    /* ── Footer ── */
    .vdd-footer {
        padding: 20px 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
        flex-shrink: 0;
    }

    .vdd-purge-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 8px;
