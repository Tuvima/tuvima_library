        else if (_filterWaitingForProvider && _counts.WaitingForProvider == 0)
            _filterWaitingForProvider = false;

        await LoadMediaItems();
        _mediaTypeCounts = await ApiClient.GetRegistryTypeCountsAsync();

        // Refresh the detail drawer with updated data so Wikidata info appears
        // immediately after confirming a match — without this, the drawer shows stale data.
        if (_selectedMedia is not null)
        {
            var refreshed = _mediaItems.FirstOrDefault(m => m.EntityId == matchEntityId);
            if (refreshed is not null)
                _selectedMedia = refreshed;
        }

        UpdateUrl();
        await InvokeAsync(StateHasChanged);
