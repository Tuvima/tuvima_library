@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Vault

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer StateContainer
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<SharedStrings> L
@inject NavigationManager Nav

@implements IDisposable

<div class="vault-layout">

    @* ── 1. TITLE ROW ── *@
    <div class="vault-header">
        <div class="vault-title-row">
            <h1 class="vault-title">@L["Vault_Title"]</h1>
        </div>

        @* ── 2. TAB ROW (tabs left, alert filters right) ── *@
        <div class="vault-tab-row">
            <div class="vault-tab-bar">
                @foreach (var tab in _tabs)
                {
                    <button class="vault-tab @(_activeTab == tab.Id ? "vault-tab--active" : "")"
                            @onclick="() => SwitchTab(tab.Id)">
                        <MudIcon Icon="@tab.Icon" Style="font-size: 16px;" />
                        <span>@tab.Label</span>
                    </button>
                }
            </div>
            <div class="vault-alert-filters">
                @if (_needsReviewCount > 0)
                {
                    <button class="vault-alert vault-alert--amber @(_filterReview ? "vault-alert--on" : "")"
                            @onclick="ToggleReviewFilter">
                        <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Style="font-size: 16px;" />
                        <span>Need Review (@_needsReviewCount)</span>
                    </button>
                }
                @if (_provisionalCount > 0)
                {
                    <button class="vault-alert vault-alert--amber @(_filterProvisional ? "vault-alert--on" : "")"
                            @onclick="ToggleProvisionalFilter">
                        <MudIcon Icon="@Icons.Material.Outlined.FactCheck" Style="font-size: 16px;" />
                        <span>Provisional (@_provisionalCount)</span>
                    </button>
                }
                @if (_quarantinedCount > 0)
                {
                    <button class="vault-alert vault-alert--red @(_filterQuarantine ? "vault-alert--on" : "")"
                            @onclick="ToggleQuarantineFilter">
                        <MudIcon Icon="@Icons.Material.Outlined.Block" Style="font-size: 16px;" />
                        <span>Quarantined (@_quarantinedCount)</span>
                    </button>
                }
                @if (_waitingForProviderCount > 0)
                {
                    <button class="vault-alert vault-alert--blue @(_filterWaitingForProvider ? "vault-alert--on" : "")"
                            @onclick="ToggleWaitingForProviderFilter">
                        <MudIcon Icon="@Icons.Material.Outlined.Schedule" Style="font-size: 16px;" />
                        <span>@L["Vault_WaitingForProvider"] (@_waitingForProviderCount)</span>
                    </button>
                }
                @if (_staleUniverseCount > 0)
                {
                    <div class="vault-alert vault-alert--amber"
                         title="@L["Vault_StaleUniversesHint"]">
                        <MudIcon Icon="@Icons.Material.Outlined.Update" Style="font-size: 16px;" />
                        <span>@string.Format(L["Vault_StaleUniverses"], _staleUniverseCount)</span>
                    </div>
                }
            </div>
        </div>

        @* ── 3. STATS BAR (card-based filters) ── *@
        <VaultStatsBar Cards="@_statsCards" OnCardToggled="OnStatCardToggled" />
    </div>

    @* ── 4. TOOLBAR ROW ── *@
    <div class="vault-toolbar-row">
        <VaultToolbar ActiveTab="@_activeTab"
                      SearchText="@_searchText"
                      SortBy="@_sortBy"
                      GroupBy="@_groupBy"
                      PosterSize="@_posterSize"
                      SearchTextChanged="OnSearchChanged"
                      SortByChanged="OnSortChanged"
                      GroupByChanged="OnGroupChanged"
                      PosterSizeChanged="OnPosterSizeChanged" />
        <button class="vault-add-btn" @onclick="() => _addMediaOpen = true">
            <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size: 16px;" />
            <span>@L["Vault_AddMedia"]</span>
        </button>
    </div>

    @* ── 4. CONTENT AREA ── *@
    <div class="vault-content">
        @if (_activeTab == "media")
        {
            <VaultMediaTable Items="@_mediaItems"
                             GroupBy="@_groupBy"
                             Loading="@_loading"
                             PosterSize="@_posterSize"
                             OnRowClicked="OnMediaRowClicked"
                             OnAuthorClicked="OnAuthorLinkClicked" />
            @if (_hasMore)
            {
                <div class="vault-load-more">
                    <button class="vault-load-more-btn" @onclick="LoadMore">
                        @L["Vault_LoadMore"]
                    </button>
                </div>
            }
        }
        else if (_activeTab == "people")
        {
            <VaultPeopleTable People="@FilteredPeople"
                              Presence="@_personPresence"
                              Loading="@_loadingPeople"
                              OnRowClicked="OnPersonRowClicked" />
        }
        else if (_activeTab == "universes")
        {
            <VaultUniversesTable Universes="@_universes"
                                 Loading="@_loadingUniverses"
                                 PeopleCount="@_universePeopleCounts"
                                 OnRowClicked="OnUniverseRowClicked" />
        }
        else if (_activeTab == "hubs")
        {
            <VaultHubsTable Hubs="@_managedHubs"
                            Loading="@_loadingHubs"
                            EnabledTypes="@_enabledHubTypes"
                            OnHubClicked="OnHubClicked" />
        }
    </div>

    @* ── HUB DETAIL DRAWER ── *@
    @if (_selectedHub is not null)
    {
        <VaultHubDrawer Hub="@_selectedHub"
                        Items="@_selectedHubItems"
                        OnClose="CloseHubDrawer"
                        OnEnabledToggled="OnHubEnabledToggled"
                        OnFeaturedToggled="OnHubFeaturedToggled" />
    }

    @* ── 5. DETAIL DRAWER ── *@
    @if (_selectedMedia is not null || _selectedPerson is not null || _selectedUniverse is not null)
    {
        <VaultDetailDrawer MediaItem="@_selectedMedia"
                           Person="@_selectedPerson"
                           Universe="@_selectedUniverse"
                           OnClose="CloseDetailDrawer"
                           OnPurge="OnPurgeItem"
                           OnApplyMatch="OnApplyMatchClicked"
                           OnPersonAliasClicked="OnPersonAliasClicked" />
    }

    @* ── 6. ADD MEDIA DRAWER ── *@
    @if (_addMediaOpen)
    {
        <VaultAddMediaDrawer OnClose="() => _addMediaOpen = false" />
    }

    @* ── 7. DELETE CONFIRM ── *@
    @if (_deleteItemId.HasValue)
    {
        <VaultDeleteConfirm ItemTitle="@_deleteItemTitle"
                            OnConfirm="OnDeleteConfirmed"
                            OnCancel="() => _deleteItemId = null" />
    }
</div>

@code {
    // ── Parameters ──
    [Parameter] public string? Tab { get; set; }

    // ── State ──
    private string _activeTab = "media";
    private string _groupBy = "none";
    private string _sortBy = "newest";
    private string _searchText = "";
    private bool _loading;
    private bool _loadingPeople;
    private bool _loadingUniverses;
    private Dictionary<Guid, int>? _universePeopleCounts;

    // ── Filter state (driven by alert badges + stats bar) ──
    private bool _filterReview;
    private bool _filterQuarantine;
    private bool _filterProvisional;
    private bool _filterWaitingForProvider;

    /// <summary>Derived from _enabledMediaTypes: when all 6 are active, null (no filter).
    /// When fewer are active, pass as comma-separated types for client-side filtering.</summary>
    private string? _filterMediaType => _enabledMediaTypes.Count < 6
        ? string.Join(",", _enabledMediaTypes)
        : null;

    // ── Data ──
    private List<VaultItemViewModel> _mediaItems = [];
    private List<PersonListItemDto> _people = [];
    private List<HubViewModel> _universes = [];
    private List<ManagedHubViewModel> _managedHubs = [];
    private RegistryFourStateCountsDto _counts = new();
    private Dictionary<string, int> _mediaTypeCounts = new();
    private bool _hasMore;
    private int _loadedCount;
    private bool _loadingHubs;

    // ── Hub drawer state ──
    private ManagedHubViewModel? _selectedHub;
    private List<HubItemViewModel> _selectedHubItems = [];

    // ── Computed counts ──
    private int _needsReviewCount => _counts.InReview;
    private int _provisionalCount => _counts.Provisional;
    private int _quarantinedCount => _counts.Rejected;
    private int _waitingForProviderCount => _counts.WaitingForProvider;

    /// <summary>
    /// Count of universes that have fictional entities older than 30 days —
    /// populated by a LoreDeltaDiscovered SignalR event.
    /// Shown as an informational amber banner in the Vault header.
    /// </summary>
    private int _staleUniverseCount;

    // ── Stats bar state ──
    private HashSet<string> _enabledMediaTypes = new(["Movies", "Books", "Audiobooks", "TV", "Music", "Podcasts"]);
    private HashSet<string> _enabledHubTypes = new(["Smart", "System", "Mix", "Playlist"]);

    // ── People state ──
    private Dictionary<string, int> _allRoleCounts = new();
    private HashSet<string> _enabledRoles = new();
    private Dictionary<string, Dictionary<string, int>> _personPresence = new();

    // ── URL state ──
    private Guid? _pendingItemId;

    // ── Poster size ──
    private int _posterSize = 48;

    // ── Add media drawer ──
    private bool _addMediaOpen;

    // ── Detail drawer state ──
    private VaultItemViewModel? _selectedMedia;
    private PersonListItemDto? _selectedPerson;
    private HubViewModel? _selectedUniverse;

    // ── Delete confirm state ──
    private Guid? _deleteItemId;
    private string _deleteItemTitle = "";

    // ── Tab definitions ──
    private static readonly (string Id, string Label, string Icon)[] _tabs =
    [
        ("media", "Media", Icons.Material.Outlined.VideoLibrary),
        ("people", "People", Icons.Material.Outlined.People),
        ("universes", "Universes", Icons.Material.Outlined.Public),
        ("hubs", "Hubs", Icons.Material.Outlined.AutoAwesome),
    ];

    // ── Stats bar computation ──
    private List<StatCardModel> _statsCards => _activeTab switch
    {
        "media" => new List<StatCardModel>
        {
            new() { Id = "Total", Icon = Icons.Material.Outlined.LocalLibrary, Count = _mediaTypeCounts.Values.Sum(), Label = "LIBRARY", Color = "#C9922E", IsActive = _enabledMediaTypes.Count == _allMediaTypeIds.Length },
            new() { Id = "Movies", Icon = Icons.Material.Outlined.VideoLibrary, Count = _mediaTypeCounts.GetValueOrDefault("Movies", 0), Label = "MOVIES", Color = "#60A5FA", IsActive = _enabledMediaTypes.Contains("Movies") },
            new() { Id = "Books", Icon = Icons.Material.Outlined.MenuBook, Count = _mediaTypeCounts.GetValueOrDefault("Books", 0), Label = "BOOKS", Color = "#5DCAA5", IsActive = _enabledMediaTypes.Contains("Books") },
            new() { Id = "Audiobooks", Icon = Icons.Material.Outlined.Headphones, Count = _mediaTypeCounts.GetValueOrDefault("Audiobooks", 0), Label = "AUDIOBOOKS", Color = "#A78BFA", IsActive = _enabledMediaTypes.Contains("Audiobooks") },
            new() { Id = "TV", Icon = Icons.Material.Outlined.LiveTv, Count = _mediaTypeCounts.GetValueOrDefault("TV", 0), Label = "TV", Color = "#FBBF24", IsActive = _enabledMediaTypes.Contains("TV") },
            new() { Id = "Music", Icon = Icons.Material.Outlined.MusicNote, Count = _mediaTypeCounts.GetValueOrDefault("Music", 0), Label = "MUSIC", Color = "#22D3EE", IsActive = _enabledMediaTypes.Contains("Music") },
            new() { Id = "Podcasts", Icon = Icons.Material.Outlined.Mic, Count = _mediaTypeCounts.GetValueOrDefault("Podcasts", 0), Label = "PODCASTS", Color = "#FB923C", IsActive = _enabledMediaTypes.Contains("Podcasts") },
        },
        "people" => BuildPeopleStatsCards(),
        "universes" => new List<StatCardModel>
        {
            new() { Id = "Universes", Icon = Icons.Material.Outlined.Public, Count = _universes.Count, Label = "UNIVERSES", Color = "#A78BFA" },
            new() { Id = "Series", Icon = Icons.Material.Outlined.Layers, Count = _universes.Sum(u => u.ChildHubCount), Label = "SERIES", Color = "#60A5FA" },
        },
        "hubs" => new List<StatCardModel>
        {
            new() { Id = "Smart", Icon = Icons.Material.Outlined.AutoAwesome, Count = _hubCounts.GetValueOrDefault("Smart", 0), Label = "SMART HUBS", Color = "#60A5FA", IsActive = _enabledHubTypes.Contains("Smart") },
            new() { Id = "System", Icon = Icons.Material.Outlined.Bookmarks, Count = _hubCounts.GetValueOrDefault("System", 0), Label = "SYSTEM LISTS", Color = "#5DCAA5", IsActive = _enabledHubTypes.Contains("System") },
            new() { Id = "Mix", Icon = Icons.Material.Outlined.AutoAwesome, Count = _hubCounts.GetValueOrDefault("Mix", 0), Label = "PERSONALIZED MIXES", Color = "#A78BFA", IsActive = _enabledHubTypes.Contains("Mix") },
            new() { Id = "Playlist", Icon = Icons.Material.Outlined.QueueMusic, Count = _hubCounts.GetValueOrDefault("Playlist", 0), Label = "PLAYLISTS", Color = "#C9922E", IsActive = _enabledHubTypes.Contains("Playlist") },
        },
        _ => []
    };

    private Dictionary<string, int> _hubCounts = new();

    private static readonly string[] _allMediaTypeIds = ["Movies", "Books", "Audiobooks", "TV", "Music", "Podcasts"];

    private async Task OnStatCardToggled(string cardId)
    {
        if (_activeTab == "media")
        {
            if (cardId == "Total")
            {
                // Toggle all: if all enabled → clear all; otherwise → enable all
                if (_enabledMediaTypes.Count == _allMediaTypeIds.Length)
                    _enabledMediaTypes.Clear();
                else
                    _enabledMediaTypes = new HashSet<string>(_allMediaTypeIds);
            }
            else
            {
                if (_enabledMediaTypes.Contains(cardId))
                    _enabledMediaTypes.Remove(cardId);
                else
                    _enabledMediaTypes.Add(cardId);
            }
            await LoadMediaItems();
            UpdateUrl();
        }
        else if (_activeTab == "people")
        {
            if (cardId == "AllPeople") return; // Keep people summary as-is for now
            if (_enabledRoles.Contains(cardId))
                _enabledRoles.Remove(cardId);
            else
                _enabledRoles.Add(cardId);
            StateHasChanged();
            UpdateUrl();
        }
        else if (_activeTab == "hubs")
        {
            if (_enabledHubTypes.Contains(cardId))
                _enabledHubTypes.Remove(cardId);
            else
                _enabledHubTypes.Add(cardId);
            StateHasChanged();
        }
    }

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        Orchestrator.OnActivityChanged += OnActivityChanged;
        Orchestrator.OnLoreDeltaDiscovered += OnLoreDeltaDiscovered;
        Nav.LocationChanged += OnLocationChanged;

        ReadUrlState();

        await LoadCounts();
        _mediaTypeCounts = await ApiClient.GetRegistryTypeCountsAsync();

        // Load tab data based on URL state
        if (_activeTab == "people") await LoadPeople();
        else if (_activeTab == "universes") await LoadUniverses();
        else if (_activeTab == "hubs") await LoadManagedHubs();
        else await LoadMediaItems();

        // Open drawer if URL had ?item=
        if (_pendingItemId.HasValue)
        {
            await OpenItemFromUrl(_pendingItemId.Value);
            _pendingItemId = null;
        }
    }

    public void Dispose()
    {
        Orchestrator.OnActivityChanged -= OnActivityChanged;
        Orchestrator.OnLoreDeltaDiscovered -= OnLoreDeltaDiscovered;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private void OnLoreDeltaDiscovered(string universeQid, int changedCount)
    {
        // Each LoreDeltaDiscovered event represents one universe — accumulate the total.
        InvokeAsync(() =>
        {
            _staleUniverseCount++;
            StateHasChanged();
        });
    }

    private async void OnActivityChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadCounts();
            _mediaTypeCounts = await ApiClient.GetRegistryTypeCountsAsync();
            await LoadMediaItems();
            StateHasChanged();
        });
    }

    // ── Data loading ──

    private async Task LoadCounts()
    {
        var counts = await ApiClient.GetRegistryFourStateCountsAsync();
        if (counts is not null) _counts = counts;
    }

    private async Task LoadMediaItems(bool append = false)
    {
        if (!append) _loading = true;
        StateHasChanged();

        // If all media type filters are off, show nothing
        if (_enabledMediaTypes.Count == 0)
        {
            _mediaItems = [];
            _hasMore = false;
            _loadedCount = 0;
            _loading = false;
            return;
        }

        // Build the status filter from toggle state
        string? statusFilter = null;
        if (_filterReview)
            statusFilter = "InReview";
        else if (_filterProvisional)
            statusFilter = "Provisional";
        else if (_filterQuarantine)
            statusFilter = "Rejected";
        else if (_filterWaitingForProvider)
            statusFilter = "WaitingForProvider";

        var offset = append ? _loadedCount : 0;

        var response = await ApiClient.GetRegistryItemsAsync(
            offset: offset, limit: 50,
            search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
            type: _filterMediaType,
            status: statusFilter,
            sort: VaultHelpers.GetSortParam(_sortBy));

        var items = response?.Items?.Select(VaultItemViewModel.From).ToList() ?? [];

        if (append)
            _mediaItems.AddRange(items);
        else
            _mediaItems = items;

        _hasMore = response?.HasMore ?? false;
        _loadedCount = _mediaItems.Count;
        _loading = false;
    }

    private async Task LoadMore()
    {
        await LoadMediaItems(append: true);
    }

    private async Task LoadPeople()
    {
        _loadingPeople = true;
        StateHasChanged();

        var result = await ApiClient.GetPersonsAsync(limit: 500);
        _people = result?.ToList() ?? [];
        _allRoleCounts = await ApiClient.GetPersonRoleCountsAsync();

        // Initialize enabled roles to all if empty
        if (_enabledRoles.Count == 0)
            _enabledRoles = new HashSet<string>(_allRoleCounts.Keys);

        // Load presence data for all people
        if (_people.Count > 0)
        {
            _personPresence = await ApiClient.GetPersonPresenceAsync(_people.Select(p => p.Id));
        }

        _loadingPeople = false;
    }

    private async Task LoadUniverses()
    {
        if (_universes.Count > 0) return; // already loaded
        _loadingUniverses = true;
        StateHasChanged();

        _universes = await ApiClient.GetParentHubsAsync() ?? [];

        // Load people counts per universe (non-blocking — show "—" until loaded).
        if (_universes.Count > 0)
        {
            var counts = new Dictionary<Guid, int>();
            foreach (var u in _universes)
            {
                var people = await ApiClient.GetPersonsByHubAsync(u.Id);
                counts[u.Id] = people?.Count ?? 0;
            }
            _universePeopleCounts = counts;
        }

        _loadingUniverses = false;
    }

    private async Task LoadManagedHubs()
    {
        if (_managedHubs.Count > 0) return; // already loaded
        _loadingHubs = true;
        StateHasChanged();

        _managedHubs = await ApiClient.GetManagedHubsAsync();
        _hubCounts = await ApiClient.GetManagedHubCountsAsync();
        _loadingHubs = false;
    }

    // ── Tab switching ──

    private async Task SwitchTab(string tabId)
    {
        _activeTab = tabId;
        if (tabId == "people") await LoadPeople();
        else if (tabId == "universes") await LoadUniverses();
        else if (tabId == "hubs") await LoadManagedHubs();
        UpdateUrl();
    }

    // ── Toolbar callbacks ──

    private async Task OnSearchChanged(string text)
    {
        _searchText = text;
        await LoadMediaItems();
        UpdateUrl();
    }

    private async Task OnSortChanged(string sort)
    {
        _sortBy = sort;
        await LoadMediaItems();
        UpdateUrl();
    }

    private Task OnGroupChanged(string group)
    {
        _groupBy = group;
        UpdateUrl();
        return Task.CompletedTask;
    }

    private Task OnPosterSizeChanged(int size)
    {
        _posterSize = size;
        return Task.CompletedTask;
    }

    // ── Author link handler ──

    private async Task OnAuthorLinkClicked(string authorName)
    {
        // Load people if not yet loaded
        if (_people.Count == 0) await LoadPeople();

        var person = _people.FirstOrDefault(p =>
            string.Equals(p.Name, authorName, StringComparison.OrdinalIgnoreCase));
        if (person is not null)
        {
            _activeTab = "people";
            _selectedPerson = person;
            _selectedMedia = null;
            _selectedUniverse = null;
            UpdateUrl();
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Alert toggle handlers ──

    private async Task ToggleReviewFilter()
    {
        _filterReview = !_filterReview;
        _filterProvisional = false;
        _filterQuarantine = false;
        _filterWaitingForProvider = false;
        await LoadMediaItems();
        UpdateUrl();
    }

    private async Task ToggleProvisionalFilter()
    {
        _filterProvisional = !_filterProvisional;
        _filterReview = false;
        _filterQuarantine = false;
        _filterWaitingForProvider = false;
        await LoadMediaItems();
        UpdateUrl();
    }

    private async Task ToggleQuarantineFilter()
    {
        _filterQuarantine = !_filterQuarantine;
        _filterReview = false;
        _filterProvisional = false;
        _filterWaitingForProvider = false;
        await LoadMediaItems();
        UpdateUrl();
    }

    private async Task ToggleWaitingForProviderFilter()
    {
        _filterWaitingForProvider = !_filterWaitingForProvider;
        _filterReview = false;
        _filterProvisional = false;
        _filterQuarantine = false;
        await LoadMediaItems();
        UpdateUrl();
    }

    // ── Row click handlers (open detail drawer) ──

    private async Task OnMediaRowClicked(Guid entityId)
    {
        _selectedMedia = _mediaItems.FirstOrDefault(i => i.EntityId == entityId);
        _selectedPerson = null;
        _selectedUniverse = null;
        UpdateUrl();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnPersonRowClicked(Guid personId)
    {
        _selectedPerson = _people.FirstOrDefault(p => p.Id == personId);
        _selectedMedia = null;
        _selectedUniverse = null;
        UpdateUrl();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnUniverseRowClicked(Guid universeId)
    {
        _selectedUniverse = _universes.FirstOrDefault(u => u.Id == universeId);
        _selectedMedia = null;
        _selectedPerson = null;
        UpdateUrl();
        await InvokeAsync(StateHasChanged);
    }

    private void CloseDetailDrawer()
    {
        _selectedMedia = null;
        _selectedPerson = null;
        _selectedUniverse = null;
        UpdateUrl();
    }

    private async Task OnPurgeItem(Guid entityId)
    {
        await ApiClient.BatchDeleteRegistryItemsAsync([entityId]);
        Snackbar.Add(L["Vault_ItemPurged"], Severity.Info);
        CloseDetailDrawer();
        await LoadMediaItems();
        await LoadCounts();
    }

    // ── Match / alias handlers ──

    private async Task OnApplyMatchClicked(Guid matchEntityId)
    {
        // TODO: Wire to Engine re-identify endpoint once available
        Snackbar.Add("Match applied — re-identifying item...", Severity.Info);
        CloseDetailDrawer();
        await LoadMediaItems();
        await LoadCounts();
    }

    private async Task OnPersonAliasClicked(Guid aliasPersonId)
    {
        if (_people.Count == 0) await LoadPeople();
        var person = _people.FirstOrDefault(p => p.Id == aliasPersonId);
        if (person is not null)
        {
            _activeTab = "people";
            _selectedPerson = person;
            _selectedMedia = null;
            _selectedUniverse = null;
            UpdateUrl();
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Hub drawer ──

    private async Task OnHubClicked(Guid hubId)
    {
        _selectedHub = _managedHubs.FirstOrDefault(h => h.Id == hubId);
        if (_selectedHub is not null)
        {
            _selectedHubItems = await ApiClient.GetHubItemsAsync(hubId, 20);
        }
        UpdateUrl();
    }

    private void CloseHubDrawer()
    {
        _selectedHub = null;
        _selectedHubItems = [];
        UpdateUrl();
    }

    private async Task OnHubEnabledToggled((Guid Id, bool Enabled) args)
    {
        await ApiClient.UpdateHubEnabledAsync(args.Id, args.Enabled);
        var hub = _managedHubs.FirstOrDefault(h => h.Id == args.Id);
        if (hub is not null)
        {
            hub.IsEnabled = args.Enabled;
            hub.Status = !args.Enabled ? "Disabled" : hub.ItemCount == 0 ? "Empty" : "Active";
        }
        if (_selectedHub?.Id == args.Id)
            _selectedHub.IsEnabled = args.Enabled;
    }

    private async Task OnHubFeaturedToggled((Guid Id, bool Featured) args)
    {
        await ApiClient.UpdateHubFeaturedAsync(args.Id, args.Featured);
        var hub = _managedHubs.FirstOrDefault(h => h.Id == args.Id);
        if (hub is not null) hub.IsFeatured = args.Featured;
        if (_selectedHub?.Id == args.Id)
            _selectedHub.IsFeatured = args.Featured;
    }

    // ── Delete confirm ──

    private async Task OnDeleteConfirmed()
    {
        if (_deleteItemId.HasValue)
        {
            await ApiClient.BatchDeleteRegistryItemsAsync([_deleteItemId.Value]);
            Snackbar.Add(L["Vault_ItemDeleted"], Severity.Info);
            _deleteItemId = null;
            await LoadMediaItems();
            await LoadCounts();
        }
    }

    // ── URL state management ──

    private void UpdateUrl(bool replace = false)
    {
        var tab = _activeTab;
        var path = $"/vault/{tab}";
        var queryParts = new List<string>();

        // Item (drawer open)
        var selectedId = _activeTab switch
        {
            "media" => _selectedMedia?.EntityId,
            "people" => _selectedPerson?.Id,
            "universes" => _selectedUniverse?.Id,
            "hubs" => _selectedHub?.Id,
            _ => null
        };
        if (selectedId.HasValue)
            queryParts.Add($"item={selectedId.Value}");

        // Filters
        if (_filterReview) queryParts.Add("filter=review");
        else if (_filterQuarantine) queryParts.Add("filter=quarantine");
        else if (_filterProvisional) queryParts.Add("filter=provisional");
        else if (_filterWaitingForProvider) queryParts.Add("filter=waiting");

        // Search
        if (!string.IsNullOrWhiteSpace(_searchText))
            queryParts.Add($"search={Uri.EscapeDataString(_searchText)}");

        // Sort
        if (_sortBy != "newest")
            queryParts.Add($"sort={_sortBy}");

        // Group
        if (_groupBy != "none")
            queryParts.Add($"group={_groupBy}");

        // Media type filter
        if (_activeTab == "media" && _enabledMediaTypes.Count < 6)
            queryParts.Add($"type={string.Join(",", _enabledMediaTypes)}");

        // People role filter
        if (_activeTab == "people" && _enabledRoles.Count < _allRoleCounts.Count && _enabledRoles.Count > 0)
            queryParts.Add($"role={string.Join(",", _enabledRoles)}");

        var query = queryParts.Count > 0 ? "?" + string.Join("&", queryParts) : "";
        Nav.NavigateTo(path + query, replace: replace);
    }

    private void ReadUrlState()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);

        // Tab from route parameter
        if (!string.IsNullOrEmpty(Tab) && _tabs.Any(t => t.Id == Tab.ToLowerInvariant()))
            _activeTab = Tab.ToLowerInvariant();

        // Query parameters
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var filter = query["filter"];
        _filterReview = filter == "review";
        _filterQuarantine = filter == "quarantine";
        _filterProvisional = filter == "provisional";
        _filterWaitingForProvider = filter == "waiting";

        if (query["search"] is string search && !string.IsNullOrEmpty(search))
            _searchText = search;

        if (query["sort"] is string sort && !string.IsNullOrEmpty(sort))
            _sortBy = sort;

        if (query["group"] is string group && !string.IsNullOrEmpty(group))
            _groupBy = group;

        if (query["type"] is string types && !string.IsNullOrEmpty(types))
        {
            _enabledMediaTypes = new HashSet<string>(types.Split(','));
        }

        if (query["role"] is string roles && !string.IsNullOrEmpty(roles))
        {
            _enabledRoles = new HashSet<string>(roles.Split(','));
        }

        // Item ID for opening drawer — deferred to after data loads
        _pendingItemId = query["item"] is string itemStr && Guid.TryParse(itemStr, out var itemId) ? itemId : null;
    }

    private async Task OpenItemFromUrl(Guid itemId)
    {
        switch (_activeTab)
        {
            case "media":
                _selectedMedia = _mediaItems.FirstOrDefault(i => i.EntityId == itemId);
                break;
            case "people":
                _selectedPerson = _people.FirstOrDefault(p => p.Id == itemId);
                break;
            case "universes":
                _selectedUniverse = _universes.FirstOrDefault(u => u.Id == itemId);
                break;
            case "hubs":
                _selectedHub = _managedHubs.FirstOrDefault(h => h.Id == itemId);
                if (_selectedHub is not null)
                    _selectedHubItems = await ApiClient.GetHubItemsAsync(itemId, 20);
                break;
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Only react to popstate (back/forward), not programmatic navigation
        if (!e.IsNavigationIntercepted) return;
        ReadUrlState();
        _ = InvokeAsync(async () =>
        {
            if (_activeTab == "people") await LoadPeople();
            else if (_activeTab == "universes") await LoadUniverses();
            else if (_activeTab == "hubs") await LoadManagedHubs();
            else await LoadMediaItems();
            StateHasChanged();
        });
    }

    // ── People stats bar ──

    private List<StatCardModel> BuildPeopleStatsCards()
    {
        var cards = new List<StatCardModel>
        {
            new() { Id = "AllPeople", Icon = Icons.Material.Outlined.People, Count = _people.Count, Label = "PEOPLE", Color = "#C9922E" }
        };

        // Role icons mapping
        var roleIcons = new Dictionary<string, string>
        {
            ["Author"] = Icons.Material.Outlined.Edit,
            ["Narrator"] = Icons.Material.Outlined.RecordVoiceOver,
            ["Director"] = Icons.Material.Outlined.Movie,
            ["Illustrator"] = Icons.Material.Outlined.Brush,
            ["Cast Member"] = Icons.Material.Outlined.TheaterComedy,
            ["Voice Actor"] = Icons.Material.Outlined.Mic,
            ["Screenwriter"] = Icons.Material.Outlined.Description,
            ["Composer"] = Icons.Material.Outlined.MusicNote,
            ["Translator"] = Icons.Material.Outlined.Translate,
            ["Editor"] = Icons.Material.Outlined.ContentCut,
            ["Host"] = Icons.Material.Outlined.Podcasts,
            ["Producer"] = Icons.Material.Outlined.AccountTree,
        };

        var roleColors = new Dictionary<string, string>
        {
            ["Author"] = "#5DCAA5",
            ["Narrator"] = "#A78BFA",
            ["Director"] = "#60A5FA",
            ["Illustrator"] = "#7C4DFF",
            ["Cast Member"] = "#FBBF24",
            ["Voice Actor"] = "#22D3EE",
            ["Screenwriter"] = "#FB923C",
            ["Composer"] = "#EC4899",
            ["Translator"] = "#34D399",
            ["Editor"] = "#F87171",
            ["Host"] = "#FB923C",
            ["Producer"] = "#818CF8",
        };

        foreach (var kvp in _allRoleCounts.OrderByDescending(k => k.Value))
        {
            cards.Add(new StatCardModel
            {
                Id = kvp.Key,
                Icon = roleIcons.GetValueOrDefault(kvp.Key, Icons.Material.Outlined.Person),
                Count = kvp.Value,
                Label = kvp.Key.ToUpperInvariant(),
                Color = roleColors.GetValueOrDefault(kvp.Key, "#60A5FA"),
                IsActive = _enabledRoles.Contains(kvp.Key),
            });
        }

        return cards;
    }

    private List<PersonListItemDto> FilteredPeople =>
        _enabledRoles.Count == 0 || _enabledRoles.Count == _allRoleCounts.Count
            ? _people
            : _people.Where(p => p.Roles.Any(r => _enabledRoles.Contains(r))).ToList();
}

