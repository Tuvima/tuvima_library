    private async Task SwitchPrimaryTab(string primaryId)
    {
        _primaryTab = primaryId;
        if (primaryId == "action_center")
        {
            _activeTab = "action_center";
            // action center always expanded when tab is selected
            await LoadConflictItems();
        }
        else if (_subTabs.TryGetValue(primaryId, out var subs) && subs.Length > 0)
        {
            await SwitchTab(subs[0].Id);
        }
        else
        {
            StateHasChanged();
        }
    }

    private async Task SwitchTab(string tabId)
    {
        if (_activeTab == tabId) return; // already on this tab
        _activeTab = tabId;
        _searchText = "";
        // groupBy removed
        _activeGroupType = null;
        _activeGroupId = null;
        _selectedItems.Clear();
        ClearStatusFilters();

        // Update primary tab to match sub-tab selection
        if (IsMediaTab(tabId))
            _primaryTab = "media";
        else if (tabId.StartsWith("people"))
            _primaryTab = "people";
        else if (tabId.StartsWith("universes"))
            _primaryTab = "universes";

        // Set view mode from saved preferences
        _viewMode = IsMediaTab(tabId) ? GetDefaultViewMode(tabId) : "all";

        if (tabId.StartsWith("people"))
        {
            _sortBy = "name";
            _peopleDisplayCount = PeoplePageSize;
            await LoadPeople();
        }
        else if (tabId.StartsWith("universes"))
        {
            await LoadUniverses();
        }
        else
        {
            _sortBy = tabId == "new" ? "newest" : "title";
            if (IsContainerView)
                await LoadContainerItems();
            else
                await LoadMediaItems();
        }

        UpdateUrl();
    }

