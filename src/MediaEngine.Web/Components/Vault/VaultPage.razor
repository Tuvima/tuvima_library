    private void OnContainerRowClicked(Guid hubId)
    {
        var groupType = GetGroupTypeForContainerTab(_activeTab);
        if (groupType is null) return;

        var container = _containerDisplayItems.FirstOrDefault(i => i.EntityId == hubId);
        var containerName = container?.Title;

        // Check if this is a system-view-backed container (all items share the same hub ID)
        var systemGroupField = GetSystemViewGroupField();

        if (systemGroupField is not null && !string.IsNullOrWhiteSpace(containerName))
        {
            // System-view mode: pass group name/field for generic drill-down
            _activeGroupName = containerName;
            _activeGroupField = systemGroupField;
            _activeGroupMediaType = GetMediaTypeForTab(_activeTab);

            // For artist view, also set artist-specific fields for legacy path
            if (_viewMode == "artists" && _activeTab == "music")
            {
                _activeArtistName = containerName;
                _artistAlbumHubIds = _contentGroups
                    .Where(g => string.Equals(g.PrimaryMediaType, "Music", StringComparison.OrdinalIgnoreCase)
                             && string.Equals(g.Creator, containerName, StringComparison.OrdinalIgnoreCase))
                    .Select(g => g.HubId)
                    .ToList();
            }

            NavigateToGroup(groupType, hubId);
            return;
        }

        NavigateToGroup(groupType, hubId);
    }

