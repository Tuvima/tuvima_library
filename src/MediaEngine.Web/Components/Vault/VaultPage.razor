@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Vault
@using MediaEngine.Storage.Models

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer StateContainer
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<SharedStrings> L
@inject NavigationManager Nav

@implements IDisposable

<div class="vault-layout">

    @* ── 1. TITLE ROW ── *@
    <div class="vault-header">
        <div class="vault-title-row">
            <h1 class="vault-title">@L["Vault_Title"]</h1>
        </div>

        @* ── 2. PRIMARY TAB ROW (categories + Action Center + Add button) ── *@
        <div class="vault-tab-row">
            <div class="vault-tab-bar">
                @foreach (var tab in _primaryTabs)
                {
                    <button class="vault-tab @(_primaryTab == tab.Id ? "vault-tab--active" : "")"
                            @onclick="() => SwitchPrimaryTab(tab.Id)">
                        <MudIcon Icon="@tab.Icon" Style="font-size: 16px;" />
                        <span>@tab.Label</span>
                    </button>
                }
                @if (_actionCenterTotal > 0)
                {
                    <button class="vault-tab vault-tab--action-center @(_primaryTab == "action_center" ? "vault-tab--active" : "") vault-tab--alert"
                            @onclick='() => SwitchPrimaryTab("action_center")'>
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 16px;" />
                        <span>Action Center</span>
                        <span class="vault-tab-badge vault-tab-badge--alert">@_actionCenterTotal</span>
                    </button>
                }
            </div>
            <button class="vault-add-btn" @onclick="() => _addMediaOpen = true">
                <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size: 16px;" />
                <span>@L["Vault_AddMedia"]</span>
            </button>
        </div>

        @* ── 3. SUB-TAB ROW (context-aware, only when not action_center) ── *@
        @if (_primaryTab != "action_center" && _subTabs.TryGetValue(_primaryTab, out var subs))
        {
            <div class="vault-subtab-row">
                <div class="vault-tab-bar vault-tab-bar--sub">
                    @foreach (var sub in subs)
                    {
                        var count = GetTabBadgeCount(sub.Id);
                        <button class="vault-tab vault-tab--sub @(_activeTab == sub.Id ? "vault-tab--active" : "")"
                                @onclick="() => SwitchTab(sub.Id)">
                            <span>@sub.Label</span>
                            @if (count > 0)
                            {
                                <span class="vault-tab-badge">@(count >= 1000 ? $"{count/1000.0:0.#}k" : count)</span>
                            }
                        </button>
                    }
                </div>
            </div>
        }

        @if (StateContainer.BatchProgress is { IsComplete: false } bp)
        {
            <div class="vault-progress-banner">
                <div class="vault-progress-info">
                    @if (!string.IsNullOrEmpty(bp.CurrentStage))
                    {
                        <span class="vault-progress-stage">@bp.CurrentStage</span>
                    }
                    <span class="vault-progress-count">@bp.FilesProcessed of @bp.FilesTotal files</span>
                    @if (bp.EstimatedSecondsRemaining.HasValue)
                    {
                        <span class="vault-progress-eta">~@(bp.EstimatedSecondsRemaining.Value)s remaining</span>
                    }
                </div>
                <div class="vault-progress-bar-track">
                    <div class="vault-progress-bar-fill" style="width: @(bp.FilesTotal > 0 ? bp.ProgressPercent : 0)%"></div>
                </div>
                @if (bp.RecentTitles?.Count > 0)
                {
                    <div class="vault-progress-recent">@string.Join(" · ", bp.RecentTitles.Take(3))</div>
                }
            </div>
        }
    </div>

    @* ── 3. TOOLBAR ROW ── *@
    <div class="vault-toolbar-row">
        <VaultToolbar ActiveTab="@_activeTab"
                      TabId="@_activeTab"
                      SearchText="@_searchText"
                      PosterSize="@_posterSize"
                      ViewMode="@_viewMode"
                      ViewModeChanged="OnViewModeChanged"
                      SearchTextChanged="OnSearchChanged"
                      PosterSizeChanged="OnPosterSizeChanged"
                      ShowBackButton="@(_activeGroupId.HasValue)"
                      OnBack="NavigateBackFromGroup"
                      OnColumnPickerRequested="() => _showColumnPicker = true" />
    </div>

    @* ── 5. BODY (full-width content) ── *@
    <div class="vault-body">
        <div class="vault-content">
            @if (_activeGroupId.HasValue && !string.IsNullOrEmpty(_activeGroupType))
            {
                @* ── Group drill-down sub-page ── *@
                <MediaGroupPage GroupType="@_activeGroupType"
                                GroupId="@_activeGroupId.Value"
                                ArtistAlbumHubIds="@_artistAlbumHubIds"
                                ArtistName="@_activeArtistName"
                                GroupName="@_activeGroupName"
                                GroupField="@_activeGroupField"
                                MediaType="@_activeGroupMediaType"
                                ShowUnowned="@_vaultPrefs.ShowUnowned"
                                ShowUnownedChanged="OnShowUnownedChanged"
                                OnBack="NavigateBackFromGroup"
                                OnItemClicked="OpenDetailDrawerFromGroup"
                                OnItemEditClicked="OpenDetailDrawerFromGroup"
                                OnAlbumTileClicked="OnAlbumTileClickedFromGroup"
                                OnAlbumNameClicked="OnAlbumNameClickedFromGroup"
                                OnPersonClicked="OnArtistPhotoClickedFromGroup"
                                OnBatchDelete="OnBatchDelete"
                                OnBatchSync="OnBatchSync"
                                OnContainerRefresh="OnContainerRefresh"
                                OnContainerDelete="OnContainerDelete" />
            }
            else if (IsMediaTab(_activeTab))
            {
                @if (_activeTab == "music" && _viewMode == "albums")
                {
                    <VaultMusicGrid Items="@_mediaItems"
                                    CardSize="@_posterSize"
                                    Loading="@_loading"
                                    OnCardClicked="OnMediaRowClicked"
                                    OnAlbumNameClicked="OnAlbumNameClickedFromGroup" />
                }
                else if (IsContainerView)
                {
                    @* Container view: show content groups (shows, albums, series, artists) *@
                    <VaultConfigurableTable @ref="_configurableTableRef"
                                             Columns="@VaultColumnDefinitions.GetColumnsByTab(_activeTab, _viewMode)"
                                             VisibleColumnKeys="@_visibleColumnKeys"
                                             Items="@_containerDisplayItems"
                                             Loading="@_loading"
                                             PosterSize="@_posterSize"
                                             OnRowClicked="OnContainerRowClicked"
                                             OnAuthorClicked="OnAuthorLinkClicked"
                                             SelectedItems="@_selectedItems"
                                             SelectedItemsChanged="OnSelectionChanged"
                                             ActiveSortKey="@_activeSortKey"
                                             SortAscending="@_sortAscending"
                                             OnSortRequested="OnColumnSortRequested"
                                             IsDrillable="@((VaultItemViewModel _) => true)"
                                             OnEditClicked="OnManageEdit"
                                             OnDeleteClicked="OnManageDelete" />
                }
                else
                {
                    @* Flat view: show individual items *@
                    <VaultConfigurableTable @ref="_configurableTableRef"
                                             Columns="@VaultColumnDefinitions.GetColumnsByTab(_activeTab)"
                                             VisibleColumnKeys="@_visibleColumnKeys"
                                             Items="@_mediaItems"
                                             Loading="@_loading"
                                             PosterSize="@_posterSize"
                                             OnRowClicked="OnMediaRowClicked"
                                             OnAuthorClicked="OnAuthorLinkClicked"
                                             SelectedItems="@_selectedItems"
                                             SelectedItemsChanged="OnSelectionChanged"
                                             ActiveSortKey="@_activeSortKey"
                                             SortAscending="@_sortAscending"
                                             OnSortRequested="OnColumnSortRequested"
                                             OnEditClicked="OnManageEdit"
                                             OnDeleteClicked="OnManageDelete" />
                }
                @if (_hasMore)
                {
                    <div class="vault-load-more">
                        <button class="vault-load-more-btn" @onclick="LoadMore">
                            @L["Vault_LoadMore"]
                        </button>
                    </div>
                }
            }
            else if (_primaryTab == "action_center")
            {
                <VaultConfigurableTable @ref="_configurableTableRef"
                                         Columns="@VaultColumnDefinitions.GetActionCenterColumns()"
                                         VisibleColumnKeys="@_visibleColumnKeys"
                                         Items="@(_conflictItems ?? new List<VaultItemViewModel>())"
                                         Loading="@_loading"
                                         PosterSize="@_posterSize"
                                         OnRowClicked="OnActionCenterEdit"
                                         OnAuthorClicked="OnAuthorLinkClicked"
                                         SelectedItems="@_selectedItems"
                                         SelectedItemsChanged="OnSelectionChanged"
                                         ActiveSortKey="@_activeSortKey"
                                         SortAscending="@_sortAscending"
                                         OnSortRequested="OnColumnSortRequested"
                                         OnEditClicked="OnManageEdit"
                                         OnDeleteClicked="OnActionCenterDelete" />
            }
            else if (_activeTab.StartsWith("people"))
            {
                <VaultPeopleTable People="@FilteredPeople"
                                  Presence="@_personPresence"
                                  Loading="@_loadingPeople"
                                  OnRowClicked="OnPersonRowClicked" />
                @if (HasMorePeople)
                {
                    <div class="vault-load-more">
                        <button class="vault-load-more-btn" @onclick="LoadMorePeople">
                            @L["Vault_LoadMore"]
                        </button>
                    </div>
                }
            }
            else if (_activeTab.StartsWith("universes"))
            {
                <VaultUniversesTable Universes="@_universes"
                                     Loading="@_loadingUniverses"
                                     PeopleCount="@_universePeopleCounts"
                                     OnRowClicked="OnUniverseRowClicked" />
            }
        </div>
    </div>

    @* ── HUB DETAIL DRAWER ── *@
    @if (_selectedHub is not null)
    {
        <VaultHubDrawer Hub="@_selectedHub"
                        Items="@_selectedHubItems"
                        OnClose="CloseHubDrawer"
                        OnEnabledToggled="OnHubEnabledToggled"
                        OnFeaturedToggled="OnHubFeaturedToggled" />
    }

    @* ── 5. DETAIL DRAWER ── *@
    @if (_selectedMedia is not null || _selectedPerson is not null || _selectedUniverse is not null)
    {
        <VaultDetailDrawer MediaItem="@_selectedMedia"
                           Person="@_selectedPerson"
                           Universe="@_selectedUniverse"
                           OnClose="CloseDetailDrawer"
                           OnPurge="OnPurgeItem"
                           OnApplyMatch="OnApplyMatchClicked"
                           OnPersonAliasClicked="OnPersonAliasClicked"
                           OnCreatorClicked="OnCreatorNameClicked" />
    }

    @* ── 6. ADD MEDIA DRAWER ── *@
    @if (_addMediaOpen)
    {
        <VaultAddMediaDrawer OnClose="() => _addMediaOpen = false" />
    }

    @* ── 7. DELETE CONFIRM ── *@
    @if (_deleteItemId.HasValue || _showBatchDeleteConfirm)
    {
        <VaultDeleteConfirm ItemTitle="@_deleteItemTitle"
                            Count="@(_showBatchDeleteConfirm ? _selectedItems.Count : 1)"
                            OnConfirm="OnDeleteConfirmed"
                            OnCancel="CancelDelete" />
    }

    @* ── 8. BATCH ACTION BAR ── *@
    <VaultBatchBar SelectedCount="@_selectedItems.Count"
                   OnDelete="OnBatchDelete"
                   OnSyncNow="OnBatchSync"
                   OnClearSelection="() => { _selectedItems.Clear(); StateHasChanged(); }" />

    @* ── 9. COLUMN PICKER ── *@
    @if (_showColumnPicker)
    {
        <VaultColumnPicker AllColumns="@(IsContainerView ? VaultColumnDefinitions.GetColumnsByTab(_activeTab, _viewMode) : VaultColumnDefinitions.GetColumnsByTab(_activeTab))"
                           VisibleKeys="@_visibleColumnKeys"
                           VisibleKeysChanged="OnColumnVisibilityChanged"
                           ViewKey="@_activeTab"
                           OnClose="() => _showColumnPicker = false" />
    }
</div>

@code {
    // ── Parameters ──
    [Parameter] public string? Tab { get; set; }

    // ── State ──
    private string _activeTab = "new";
    // _groupBy removed — grouping is no longer supported in the Vault
    private string _sortBy = "newest";
    private string? _activeSortKey;
    private bool _sortAscending = true;
    private string _searchText = "";
    private string _viewMode = "all";
    private bool _loading;
    private bool _loadingPeople;
    private bool _loadingUniverses;
    private Dictionary<Guid, int>? _universePeopleCounts;

    // ── View mode + preferences ──
    private VaultPreferencesSettings _vaultPrefs = new();
    private List<ContentGroupViewModel> _tabContentGroups = [];
    private List<VaultItemViewModel> _containerDisplayItems = [];

    // ── Filter state ──
    private bool _filterReview;
    private bool _filterQuarantine;
    private bool _filterProvisional;
    private bool _filterWaitingForProvider;

    // ── Data ──
    private List<VaultItemViewModel> _mediaItems = [];
    private List<PersonListItemDto> _people = [];
    private List<HubViewModel> _universes = [];
    private List<ManagedHubViewModel> _managedHubs = [];
    private List<ContentGroupViewModel> _contentGroups = [];
    private RegistryFourStateCountsDto _counts = new();
    private Dictionary<string, int> _mediaTypeCounts = new();
    private bool _hasMore;
    private int _loadedCount;
    // ── Hub drawer state ──
    private ManagedHubViewModel? _selectedHub;
    private List<HubItemViewModel> _selectedHubItems = [];

    // ── Computed counts ──
    private int _needsReviewCount => _counts.InReview;
    private int _provisionalCount => _counts.Provisional;
    private int _quarantinedCount => _counts.Rejected;
    private int _waitingForProviderCount => _counts.WaitingForProvider;
    private int _actionCenterTotal => _needsReviewCount + _quarantinedCount + _waitingForProviderCount;

    /// <summary>
    /// Count of universes that have fictional entities older than 30 days —
    /// populated by a LoreDeltaDiscovered SignalR event.
    /// Shown as an informational amber banner in the Vault header.
    /// </summary>
    private int _staleUniverseCount;

    // ── Hub type filter ──
    private HashSet<string> _enabledHubTypes = new(["Smart", "System", "Mix", "Playlist", "ContentGroups"]);

    // ── People state ──
    private Dictionary<string, Dictionary<string, int>> _personPresence = new();
    private int _peopleDisplayCount = 50;
    private const int PeoplePageSize = 50;

    // ── URL state ──
    private Guid? _pendingItemId;

    // ── Poster size ──
    private int _posterSize = 48;

    // ── Add media drawer ──
    private bool _addMediaOpen;

    // ── Batch selection state ──
    private HashSet<Guid> _selectedItems = [];

    // ── Column picker state ──
    private bool _showColumnPicker;
    private List<string> _visibleColumnKeys = [];

    // ── Table ref for expand/collapse all ──
    private VaultConfigurableTable? _configurableTableRef;

    // ── Group drill-down sub-page state ──
    private string? _activeGroupType;
    private Guid? _activeGroupId;
    private List<Guid>? _artistAlbumHubIds;
    private string? _activeArtistName;
    private string? _activeGroupName;
    private string? _activeGroupField;
    private string? _activeGroupMediaType;

    // ── Detail drawer state ──
    private VaultItemViewModel? _selectedMedia;
    private PersonListItemDto? _selectedPerson;
    private HubViewModel? _selectedUniverse;

    // ── Delete confirm state ──
    private Guid? _deleteItemId;
    private string _deleteItemTitle = "";
    private bool _showBatchDeleteConfirm;

    // ── Action Center state ──
    // _actionCenterExpanded removed — Action Center tab always shows expanded
    private List<VaultItemViewModel>? _conflictItems;

    // ── Hub counts (used by LoadManagedHubs) ──
    private Dictionary<string, int> _hubCounts = new();

    // ── Primary tab categories ──
    private static readonly (string Id, string Label, string Icon)[] _primaryTabs =
    [
        ("media",     "Media",     Icons.Material.Outlined.VideoLibrary),
        ("people",    "People",    Icons.Material.Outlined.People),
        ("universes", "Universes", Icons.Material.Outlined.Public),
    ];

    // ── Sub-tabs per primary category ──
    private static readonly Dictionary<string, (string Id, string Label, string Icon)[]> _subTabs = new()
    {
        ["media"] =
        [
            ("new",        "New",        Icons.Material.Outlined.NewReleases),
            ("movies",     "Movies",     Icons.Material.Outlined.VideoLibrary),
            ("tv",         "TV",         Icons.Material.Outlined.LiveTv),
            ("music",      "Music",      Icons.Material.Outlined.MusicNote),
            ("books",      "Books",      Icons.Material.Outlined.MenuBook),
            ("audiobooks", "Audiobooks", Icons.Material.Outlined.Headphones),
            ("podcasts",   "Podcasts",   Icons.Material.Outlined.Mic),
            ("comics",     "Comics",     Icons.Material.Outlined.AutoStories),
        ],
        ["people"] =
        [
            ("people_all",       "All",       Icons.Material.Outlined.People),
            ("people_authors",   "Authors",   Icons.Material.Outlined.MenuBook),
            ("people_directors", "Directors", Icons.Material.Outlined.Movie),
            ("people_actors",    "Actors",    Icons.Material.Outlined.TheaterComedy),
            ("people_musicians", "Musicians", Icons.Material.Outlined.MusicNote),
        ],
        ["universes"] =
        [
            ("universes_all", "All", Icons.Material.Outlined.Public),
        ],
    };

    private string _primaryTab = "media";

    // ── Legacy tab list (kept for URL parsing compatibility) ──
    private static readonly (string Id, string Label, string Icon)[] _tabs =
    [
        ("new",        "New",        Icons.Material.Outlined.NewReleases),
        ("movies",     "Movies",     Icons.Material.Outlined.VideoLibrary),
        ("tv",         "TV",         Icons.Material.Outlined.LiveTv),
        ("music",      "Music",      Icons.Material.Outlined.MusicNote),
        ("books",      "Books",      Icons.Material.Outlined.MenuBook),
        ("audiobooks", "Audiobooks", Icons.Material.Outlined.Headphones),
        ("podcasts",   "Podcasts",   Icons.Material.Outlined.Mic),
        ("comics",     "Comics",     Icons.Material.Outlined.AutoStories),
        ("people",     "People",     Icons.Material.Outlined.People),
        ("universes",  "Universes",  Icons.Material.Outlined.Public),
    ];

    // ── Tab helpers ──

    private static readonly string[] _mediaTabIds = ["new", "movies", "tv", "music", "books", "audiobooks", "podcasts", "comics"];

    private static bool IsMediaTab(string tabId) => _mediaTabIds.Contains(tabId);

    private static string? GetMediaTypeForTab(string tabId) => tabId switch
    {
        "movies"     => "Movies",
        "tv"         => "TV",
        "music"      => "Music",
        "books"      => "Books",
        "audiobooks" => "Audiobooks",
        "podcasts"   => "Podcasts",
        "comics"     => "Comics",
        _            => null, // "new" tab — no type filter
    };

    /// <summary>True when the current tab + view mode is showing containers (not individual files).</summary>
    private bool IsContainerView => _viewMode is "shows" or "artists" or "albums" or "series";

    /// <summary>Returns the default view mode for a given tab (from saved preferences or built-in defaults).</summary>
    private string GetDefaultViewMode(string tabId)
    {
        // TV is always by-show — never flat
        if (tabId == "tv") return "shows";
        return _vaultPrefs.ViewModes.TryGetValue(tabId, out var saved) ? saved : tabId switch
        {
            "music"     => "artists",
            "podcasts"  => "shows",
            "comics"    => "series",
            _           => "all",
        };
    }

    /// <summary>Maps a view mode to the content group type for drill-down.</summary>
    private string? GetGroupTypeForContainerTab(string tabId) => tabId switch
    {
        "movies" => "movie-series",
        "tv" => "tv-show",
        "music" when _viewMode == "artists" => "artist",
        "music" when _viewMode == "albums" => "album",
        "books" => "book-series",
        "audiobooks" => "book-series",
        "podcasts" => "podcast-show",
        "comics" => "comic-series",
        _ => null,
    };

    private int GetTabBadgeCount(string tabId) => tabId switch
    {
        "movies"           => _mediaTypeCounts.GetValueOrDefault("Movies", 0),
        "tv"               => _mediaTypeCounts.GetValueOrDefault("TV", 0),
        "music"            => _mediaTypeCounts.GetValueOrDefault("Music", 0),
        "books"            => _mediaTypeCounts.GetValueOrDefault("Books", 0),
        "audiobooks"       => _mediaTypeCounts.GetValueOrDefault("Audiobooks", 0),
        "podcasts"         => _mediaTypeCounts.GetValueOrDefault("Podcasts", 0),
        "comics"           => _mediaTypeCounts.GetValueOrDefault("Comics", 0),
        "people_all"       => _people.Count,
        "universes_all"    => _universes.Count,
        _                  => 0,
    };

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        Orchestrator.OnActivityChanged += OnActivityChanged;
        Orchestrator.OnLoreDeltaDiscovered += OnLoreDeltaDiscovered;
        Nav.LocationChanged += OnLocationChanged;
        StateContainer.OnStateChanged += OnBatchProgressChanged;

        // Load vault preferences (view modes, show unowned)
        _vaultPrefs = await ApiClient.GetVaultPreferencesAsync() ?? new VaultPreferencesSettings();

        ReadUrlState();

        // Set view mode from preferences if not overridden by URL
        if (_viewMode == "all" && IsMediaTab(_activeTab))
            _viewMode = GetDefaultViewMode(_activeTab);

        await LoadCounts();
        _mediaTypeCounts = await ApiClient.GetRegistryTypeCountsAsync();
        await LoadConflictItems();

        if (_activeTab.StartsWith("people")) await LoadPeople();
        else if (_activeTab.StartsWith("universes")) await LoadUniverses();
        else if (IsContainerView) await LoadContainerItems();
        else await LoadMediaItems();

        if (_pendingItemId.HasValue)
        {
            await OpenItemFromUrl(_pendingItemId.Value);
            _pendingItemId = null;
        }
    }

    public void Dispose()
    {
        Orchestrator.OnActivityChanged -= OnActivityChanged;
        Orchestrator.OnLoreDeltaDiscovered -= OnLoreDeltaDiscovered;
        Nav.LocationChanged -= OnLocationChanged;
        StateContainer.OnStateChanged -= OnBatchProgressChanged;
    }

    private void OnLoreDeltaDiscovered(string universeQid, int changedCount)
    {
        InvokeAsync(() =>
        {
            _staleUniverseCount++;
            StateHasChanged();
        });
    }

    private void OnBatchProgressChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async void OnActivityChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadCounts();
            _mediaTypeCounts = await ApiClient.GetRegistryTypeCountsAsync();
            await LoadConflictItems();
            if (IsMediaTab(_activeTab))
            {
                if (IsContainerView) await LoadContainerItems();
                else await LoadMediaItems();
            }
            StateHasChanged();
        });
    }

    // ── Data loading ──

    private async Task LoadCounts()
    {
        var counts = await ApiClient.GetRegistryFourStateCountsAsync();
        if (counts is not null) _counts = counts;
    }

    private async Task LoadMediaItems(bool append = false)
    {
        if (!append) _loading = true;
        StateHasChanged();

        string? statusFilter = null;
        if (_filterReview) statusFilter = "InReview";
        else if (_filterProvisional) statusFilter = "Provisional";
        else if (_filterQuarantine) statusFilter = "Rejected";
        else if (_filterWaitingForProvider) statusFilter = "WaitingForProvider";

        var offset = append ? _loadedCount : 0;
        var isNewTab = _activeTab == "new";

        var response = await ApiClient.GetRegistryItemsAsync(
            offset: offset, limit: 50,
            search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
            type: GetMediaTypeForTab(_activeTab),
            status: statusFilter,
            sort: isNewTab && _sortBy == "newest" ? "-created_at" : VaultHelpers.GetSortParam(_sortBy),
            maxDays: isNewTab ? 30 : null);

        var items = response?.Items?.Select(VaultItemViewModel.From).ToList() ?? [];

        if (append)
            _mediaItems.AddRange(items);
        else
            _mediaItems = items;

        _hasMore = response?.HasMore ?? false;
        _loadedCount = _mediaItems.Count;
        _loading = false;
    }

    private async Task LoadMore()
    {
        if (IsContainerView)
            return; // Containers don't paginate for now
        await LoadMediaItems(append: true);
    }

    /// <summary>
    /// Maps the current tab + view mode to the group_by_field used in System view hubs.
    /// Returns null when the view is not backed by a system view hub.
    /// </summary>
    private static Guid GenerateDeterministicGuid(string name)
    {
        var bytes = System.Security.Cryptography.MD5.HashData(
            System.Text.Encoding.UTF8.GetBytes(name));
        return new Guid(bytes);
    }

    private string? GetSystemViewGroupField() => (_activeTab, _viewMode) switch
    {
        ("tv", "shows")         => "show_name",
        ("podcasts", "shows")   => "show_name",
        ("music", "artists")    => "artist",
        ("music", "albums")     => "album",
        ("books", "series")     => "series",
        ("audiobooks", "series") => "series",
        ("comics", "series")    => "series",
        _                       => null,
    };

    /// <summary>Loads content groups for the current tab's container view and converts to display items.</summary>
    private async Task LoadContainerItems()
    {
        _loading = true;
        StateHasChanged();

        var mediaType = GetMediaTypeForTab(_activeTab);
        var systemGroupField = GetSystemViewGroupField();

        if (systemGroupField is not null)
        {
            // This view is backed by a System view hub seeded by HubSeeder — resolve via system-views endpoint.
            var groups = await ApiClient.GetSystemViewGroupsAsync(mediaType, systemGroupField);

            if (!string.IsNullOrWhiteSpace(_searchText))
                groups = groups.Where(g =>
                    g.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)).ToList();

            _tabContentGroups = groups;
            _containerDisplayItems = groups.Select(g => new VaultItemViewModel
            {
                // System view groups share the same HubId — generate a unique deterministic ID
                // from the display name so the click handler can distinguish them.
                EntityId = GenerateDeterministicGuid(g.DisplayName),
                Title    = g.DisplayName,
                MediaType = g.PrimaryMediaType,
                CoverUrl = g.CoverUrl,
                Author   = g.Creator,
                Year     = null,
                TrackCount = g.WorkCount.ToString(),
            }).ToList();
        }
        else
        {
            // Fallback: use ContentGroup hubs (albums/series created during ingestion by MediaEntityChainFactory)
            if (_contentGroups.Count == 0)
                _contentGroups = await ApiClient.GetContentGroupsAsync();

            _tabContentGroups = mediaType is not null
                ? _contentGroups.Where(g =>
                    string.Equals(g.PrimaryMediaType, mediaType, StringComparison.OrdinalIgnoreCase)).ToList()
                : _contentGroups;

            if (!string.IsNullOrWhiteSpace(_searchText))
                _tabContentGroups = _tabContentGroups.Where(g =>
                    g.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)).ToList();

            _containerDisplayItems = _tabContentGroups.Select(g => new VaultItemViewModel
            {
                EntityId = g.HubId,
                Title    = g.DisplayName,
                MediaType = g.PrimaryMediaType,
                CoverUrl = g.CoverUrl,
                Author   = g.Creator,
                Year     = null,
                TrackCount = g.WorkCount.ToString(),
            }).ToList();
        }

        _hasMore = false; // Containers don't paginate
        _loading = false;
    }

    private async Task LoadPeople()
    {
        _loadingPeople = true;
        StateHasChanged();

        var result = await ApiClient.GetPersonsAsync(limit: 500);
        _people = result?.ToList() ?? [];

        if (_people.Count > 0)
        {
            _personPresence = await ApiClient.GetPersonPresenceAsync(_people.Select(p => p.Id));
        }

        _loadingPeople = false;
    }

    private async Task LoadUniverses()
    {
        if (_universes.Count > 0) return; // already loaded
        _loadingUniverses = true;
        StateHasChanged();

        _universes = await ApiClient.GetParentHubsAsync() ?? [];

        if (_universes.Count > 0)
        {
            var counts = new Dictionary<Guid, int>();
            foreach (var u in _universes)
            {
                var people = await ApiClient.GetPersonsByHubAsync(u.Id);
                counts[u.Id] = people?.Count ?? 0;
            }
            _universePeopleCounts = counts;
        }

        _loadingUniverses = false;
    }

    private async Task LoadManagedHubs()
    {
        if (_managedHubs.Count > 0) return; // already loaded
        StateHasChanged();

        var hubsTask   = ApiClient.GetManagedHubsAsync();
        var countsTask = ApiClient.GetManagedHubCountsAsync();
        var groupsTask = ApiClient.GetContentGroupsAsync();

        await Task.WhenAll(hubsTask, countsTask, groupsTask);

        _managedHubs   = hubsTask.Result;
        _hubCounts     = countsTask.Result;
        _contentGroups = groupsTask.Result;
    }

    private async Task LoadConflictItems()
    {
        var response = await ApiClient.GetRegistryItemsAsync(
            offset: 0, limit: 20, status: "InReview");
        var reviewItems = response?.Items?.Select(VaultItemViewModel.From).ToList() ?? [];

        var rejectedResponse = await ApiClient.GetRegistryItemsAsync(
            offset: 0, limit: 20, status: "Rejected");
        var rejectedItems = rejectedResponse?.Items?.Select(VaultItemViewModel.From).ToList() ?? [];

        _conflictItems = [.. reviewItems, .. rejectedItems];
    }

