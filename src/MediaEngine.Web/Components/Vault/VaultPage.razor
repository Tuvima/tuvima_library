@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Vault

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer StateContainer
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@implements IDisposable

<div class="vault-layout">

    @* ── 1. PIPELINE HEADER ── *@
    <div class="vault-header">
        <div class="vault-header-top">
            <div>
                <div class="vault-progress-row">
                    @if (_batchActive)
                    {
                        <div class="vault-pulse"></div>
                        <span class="vault-progress-text">@_batchProcessed of @_batchTotal processing</span>
                        <div class="vault-progress-track">
                            <div class="vault-progress-fill" style="width: @BatchPercent%;"></div>
                        </div>
                    }
                    else
                    {
                        <div class="vault-pulse-idle"></div>
                        <span class="vault-progress-text">@_counts.Identified of @_counts.All identified</span>
                        <div class="vault-progress-track">
                            <div class="vault-progress-fill" style="width: @IdentifiedPercent%;"></div>
                        </div>
                    }
                </div>
                <h1 class="vault-title">Library Vault</h1>
            </div>

            <div class="vault-header-actions">
                @* Tab switcher *@
                <div class="vault-tab-bar">
                    @foreach (var tab in _tabs)
                    {
                        <button class="vault-tab @(_activeTab == tab.Id ? "vault-tab--active" : "")"
                                @onclick="() => SwitchTab(tab.Id)">
                            <MudIcon Icon="@tab.Icon" Style="font-size: 16px;" />
                            <span>@tab.Label</span>
                        </button>
                    }
                </div>

                @* Add Media button *@
                <button class="vault-add-btn">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size: 16px;" />
                    <span>Add Media</span>
                </button>
            </div>
        </div>

        @* ── 2. STATS BAR (card-based filters) ── *@
        <VaultStatsBar Cards="@_statsCards" OnCardToggled="OnStatCardToggled" />

        @* ── Alert badges (moved to compact form) ── *@
        <div class="vault-alert-badges">
            @if (_needsReviewCount > 0)
            {
                <button class="vault-alert vault-alert--amber @(_filterReview ? "vault-alert--on" : "")"
                        @onclick="ToggleReviewFilter">
                    <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Style="font-size: 14px;" />
                    <span>@_needsReviewCount need review</span>
                </button>
            }
            @if (_quarantinedCount > 0)
            {
                <button class="vault-alert vault-alert--red @(_filterQuarantine ? "vault-alert--on" : "")"
                        @onclick="ToggleQuarantineFilter">
                    <MudIcon Icon="@Icons.Material.Outlined.Delete" Style="font-size: 12px;" />
                    <span>@_quarantinedCount quarantined</span>
                </button>
            }
        </div>
    </div>

    @* ── 3. TOOLBAR ── *@
    <VaultToolbar ActiveTab="@_activeTab"
                  SearchText="@_searchText"
                  SortBy="@_sortBy"
                  GroupBy="@_groupBy"
                  ViewMode="@_viewMode"
                  IsFilterOpen="@_filterOpen"
                  FilterMediaType="@_filterMediaType"
                  FilterReview="@_filterReview"
                  FilterQuarantine="@_filterQuarantine"
                  FilterMinConfidence="@_filterMinConfidence"
                  FilterMissingArt="@_filterMissingArt"
                  ActiveFilterCount="@_activeFilterCount"
                  SearchTextChanged="OnSearchChanged"
                  SortByChanged="OnSortChanged"
                  GroupByChanged="OnGroupChanged"
                  ViewModeChanged="OnViewModeChanged"
                  FilterToggled="OnFilterToggled"
                  FilterMediaTypeChanged="OnMediaTypeFilterChanged"
                  FilterReviewChanged="OnReviewFilterChanged"
                  FilterQuarantineChanged="OnQuarantineFilterChanged"
                  FilterMinConfidenceChanged="OnMinConfidenceChanged"
                  FilterMissingArtChanged="OnMissingArtChanged" />

    @* ── 4. CONTENT AREA ── *@
    <div class="vault-content">
        @if (_activeTab == "media")
        {
            @if (_viewMode == "list")
            {
                <VaultMediaTable Items="@_mediaItems"
                                 GroupBy="@_groupBy"
                                 Loading="@_loading"
                                 OnResolveClicked="OnResolveClicked"
                                 OnDeleteClicked="OnDeleteClicked"
                                 OnMoreClicked="OnMoreClicked" />
            }
            else
            {
                <VaultMediaGrid Items="@_mediaItems"
                                Loading="@_loading"
                                OnCardClicked="OnResolveClicked"
                                OnDeleteClicked="OnDeleteClicked" />
            }
        }
        else if (_activeTab == "people")
        {
            <VaultPeopleTable People="@_people"
                              Loading="@_loadingPeople"
                              OnMoreClicked="OnPersonMoreClicked" />
        }
        else if (_activeTab == "universes")
        {
            <VaultUniversesTable Universes="@_universes"
                                 Loading="@_loadingUniverses"
                                 OnMoreClicked="OnUniverseMoreClicked" />
        }
        else if (_activeTab == "hubs")
        {
            <VaultHubsTable Hubs="@_managedHubs"
                            Loading="@_loadingHubs"
                            EnabledTypes="@_enabledHubTypes"
                            OnHubClicked="OnHubClicked" />
        }
    </div>

    @* ── HUB DETAIL DRAWER ── *@
    @if (_selectedHub is not null)
    {
        <VaultHubDrawer Hub="@_selectedHub"
                        Items="@_selectedHubItems"
                        OnClose="CloseHubDrawer"
                        OnEnabledToggled="OnHubEnabledToggled"
                        OnFeaturedToggled="OnHubFeaturedToggled" />
    }

    @* ── 5. RESOLUTION OVERLAY ── *@
    @if (_resolveItem is not null)
    {
        <VaultResolutionOverlay Item="@_resolveItem"
                                OnClose="CloseResolution"
                                OnReject="OnRejectFromOverlay"
                                OnApply="OnApplyResolution" />
    }

    @* ── 6. DELETE CONFIRM ── *@
    @if (_deleteItemId.HasValue)
    {
        <VaultDeleteConfirm ItemTitle="@_deleteItemTitle"
                            OnConfirm="OnDeleteConfirmed"
                            OnCancel="() => _deleteItemId = null" />
    }
</div>

@code {
    // ── State ──
    private string _activeTab = "media";
    private string _viewMode = "list";
    private string _groupBy = "none";
    private string _sortBy = "newest";
    private string _searchText = "";
    private bool _filterOpen;
    private bool _loading;
    private bool _loadingPeople;
    private bool _loadingUniverses;

    // ── Filter state ──
    private bool _filterReview;
    private bool _filterQuarantine;
    private string? _filterMediaType;
    private double? _filterMinConfidence;
    private bool _filterMissingArt;

    private int _activeFilterCount =>
        (_filterReview ? 1 : 0) +
        (_filterQuarantine ? 1 : 0) +
        (_filterMediaType is not null ? 1 : 0) +
        (_filterMinConfidence.HasValue ? 1 : 0) +
        (_filterMissingArt ? 1 : 0);

    // ── Data ──
    private List<VaultItemViewModel> _mediaItems = [];
    private List<PersonListItemDto> _people = [];
    private List<HubViewModel> _universes = [];
    private List<ManagedHubViewModel> _managedHubs = [];
    private RegistryFourStateCountsDto _counts = new();
    private bool _loadingHubs;

    // ── Hub drawer state ──
    private ManagedHubViewModel? _selectedHub;
    private List<HubItemViewModel> _selectedHubItems = [];

    // ── Computed counts ──
    private int _needsReviewCount => _counts.InReview + _counts.Provisional;
    private int _quarantinedCount => _counts.Rejected;
    private double IdentifiedPercent => _counts.All > 0 ? (double)_counts.Identified / _counts.All * 100 : 0;

    // ── Live batch progress (from SignalR) ──
    private bool _batchActive => StateContainer.BatchProgress is not null && !StateContainer.BatchProgress.IsComplete;
    private int _batchProcessed => StateContainer.BatchProgress?.FilesProcessed ?? 0;
    private int _batchTotal => StateContainer.BatchProgress?.FilesTotal ?? 0;
    private double BatchPercent => _batchTotal > 0 ? (double)_batchProcessed / _batchTotal * 100 : 0;

    // ── Stats bar state ──
    private HashSet<string> _enabledMediaTypes = new(["Movies", "Books", "Audiobooks", "TV", "Music", "Podcasts"]);
    private HashSet<string> _enabledHubTypes = new(["Smart", "System", "Mix", "Playlist"]);

    // ── Overlay state ──
    private VaultItemViewModel? _resolveItem;
    private Guid? _deleteItemId;
    private string _deleteItemTitle = "";

    // ── Tab definitions ──
    private static readonly (string Id, string Label, string Icon)[] _tabs =
    [
        ("media", "Media", Icons.Material.Outlined.VideoLibrary),
        ("people", "People", Icons.Material.Outlined.People),
        ("universes", "Universes", Icons.Material.Outlined.Public),
        ("hubs", "Hubs", Icons.Material.Outlined.AutoAwesome),
    ];

    // ── Stats bar computation ──
    private List<StatCardModel> _statsCards => _activeTab switch
    {
        "media" => new List<StatCardModel>
        {
            new() { Id = "Movies", Icon = Icons.Material.Outlined.VideoLibrary, Count = 2105, Label = "MOVIES", Color = "#60A5FA", IsActive = _enabledMediaTypes.Contains("Movies") },
            new() { Id = "Books", Icon = Icons.Material.Outlined.MenuBook, Count = 1240, Label = "BOOKS", Color = "#5DCAA5", IsActive = _enabledMediaTypes.Contains("Books") },
            new() { Id = "Audiobooks", Icon = Icons.Material.Outlined.Headphones, Count = 852, Label = "AUDIOBOOKS", Color = "#A78BFA", IsActive = _enabledMediaTypes.Contains("Audiobooks") },
            new() { Id = "TV", Icon = Icons.Material.Outlined.LiveTv, Count = 432, Label = "TV", Color = "#FBBF24", IsActive = _enabledMediaTypes.Contains("TV") },
            new() { Id = "Music", Icon = Icons.Material.Outlined.MusicNote, Count = 15420, Label = "MUSIC", Color = "#22D3EE", IsActive = _enabledMediaTypes.Contains("Music") },
            new() { Id = "Podcasts", Icon = Icons.Material.Outlined.Mic, Count = 98, Label = "PODCASTS", Color = "#FB923C", IsActive = _enabledMediaTypes.Contains("Podcasts") },
        },
        "people" => new List<StatCardModel>
        {
            new() { Id = "Actors", Icon = Icons.Material.Outlined.RecentActors, Count = 12400, Label = "ACTORS", Color = "#60A5FA" },
            new() { Id = "Directors", Icon = Icons.Material.Outlined.TheaterComedy, Count = 842, Label = "DIRECTORS", Color = "#FBBF24" },
            new() { Id = "Authors", Icon = Icons.Material.Outlined.MenuBook, Count = 3105, Label = "AUTHORS", Color = "#5DCAA5" },
        },
        "universes" => new List<StatCardModel>
        {
            new() { Id = "Universes", Icon = Icons.Material.Outlined.Public, Count = _universes.Count, Label = "UNIVERSES", Color = "#A78BFA" },
            new() { Id = "Series", Icon = Icons.Material.Outlined.Layers, Count = 24, Label = "SERIES", Color = "#60A5FA" },
            new() { Id = "Orphaned", Icon = Icons.Material.Outlined.Inventory2, Count = 3, Label = "ORPHANED", Color = "#FB923C" },
        },
        "hubs" => new List<StatCardModel>
        {
            new() { Id = "Smart", Icon = Icons.Material.Outlined.AutoAwesome, Count = _hubCounts.GetValueOrDefault("Smart", 0), Label = "SMART HUBS", Color = "#60A5FA", IsActive = _enabledHubTypes.Contains("Smart") },
            new() { Id = "System", Icon = Icons.Material.Outlined.Bookmarks, Count = _hubCounts.GetValueOrDefault("System", 0), Label = "SYSTEM LISTS", Color = "#5DCAA5", IsActive = _enabledHubTypes.Contains("System") },
            new() { Id = "Mix", Icon = Icons.Material.Outlined.AutoAwesome, Count = _hubCounts.GetValueOrDefault("Mix", 0), Label = "PERSONALIZED MIXES", Color = "#A78BFA", IsActive = _enabledHubTypes.Contains("Mix") },
            new() { Id = "Playlist", Icon = Icons.Material.Outlined.QueueMusic, Count = _hubCounts.GetValueOrDefault("Playlist", 0), Label = "PLAYLISTS", Color = "#C9922E", IsActive = _enabledHubTypes.Contains("Playlist") },
        },
        _ => []
    };

    private Dictionary<string, int> _hubCounts = new();

    private async Task OnStatCardToggled(string cardId)
    {
        if (_activeTab == "media")
        {
            if (_enabledMediaTypes.Contains(cardId))
                _enabledMediaTypes.Remove(cardId);
            else
                _enabledMediaTypes.Add(cardId);
            // Map card ID to filter — for now just refresh
            await LoadMediaItems();
        }
        else if (_activeTab == "hubs")
        {
            if (_enabledHubTypes.Contains(cardId))
                _enabledHubTypes.Remove(cardId);
            else
                _enabledHubTypes.Add(cardId);
            StateHasChanged();
        }
    }

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        Orchestrator.OnActivityChanged += OnActivityChanged;
        await LoadCounts();
        await LoadMediaItems();
    }

    public void Dispose()
    {
        Orchestrator.OnActivityChanged -= OnActivityChanged;
    }

    private async void OnActivityChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadCounts();
            await LoadMediaItems();
            StateHasChanged();
        });
    }

    // ── Data loading ──

    private async Task LoadCounts()
    {
        var counts = await ApiClient.GetRegistryFourStateCountsAsync();
        if (counts is not null) _counts = counts;
    }

    private async Task LoadMediaItems()
    {
        _loading = true;
        StateHasChanged();

        // Build the status filter from toggle state
        // Both on = show both InReview + Rejected; one on = that status; neither = null (all)
        string? statusFilter = null;
        if (_filterReview && _filterQuarantine)
            statusFilter = null; // API doesn't support OR, so we'll client-filter
        else if (_filterReview)
            statusFilter = "InReview";
        else if (_filterQuarantine)
            statusFilter = "Rejected";

        var response = await ApiClient.GetRegistryItemsAsync(
            offset: 0, limit: 200,
            search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
            type: _filterMediaType,
            status: (_filterReview && _filterQuarantine) ? null : statusFilter,
            minConfidence: _filterMinConfidence,
            sort: VaultHelpers.GetSortParam(_sortBy));

        var items = response?.Items?.Select(VaultItemViewModel.From).ToList() ?? [];

        // Client-side filtering for cases the API can't handle in one call
        if (_filterReview && _filterQuarantine)
        {
            items = items.Where(i =>
                i.VaultDisplayStatus is VaultStatus.NeedsReview or VaultStatus.Failed or VaultStatus.Quarantined)
                .ToList();
        }

        if (_filterMissingArt)
        {
            items = items.Where(i => string.IsNullOrEmpty(i.CoverUrl)).ToList();
        }

        _mediaItems = items;
        _loading = false;
    }

    private async Task LoadPeople()
    {
        if (_people.Count > 0) return; // already loaded
        _loadingPeople = true;
        StateHasChanged();

        var result = await ApiClient.GetPersonsAsync(limit: 200);
        _people = result?.ToList() ?? [];
        _loadingPeople = false;
    }

    private async Task LoadUniverses()
    {
        if (_universes.Count > 0) return; // already loaded
        _loadingUniverses = true;
        StateHasChanged();

        _universes = await ApiClient.GetHubsAsync() ?? [];
        _loadingUniverses = false;
    }

    private async Task LoadManagedHubs()
    {
        if (_managedHubs.Count > 0) return; // already loaded
        _loadingHubs = true;
        StateHasChanged();

        _managedHubs = await ApiClient.GetManagedHubsAsync();
        _hubCounts = await ApiClient.GetManagedHubCountsAsync();
        _loadingHubs = false;
    }

    // ── Tab switching ──

    private async Task SwitchTab(string tabId)
    {
        _activeTab = tabId;
        if (tabId == "people") await LoadPeople();
        else if (tabId == "universes") await LoadUniverses();
        else if (tabId == "hubs") await LoadManagedHubs();
    }

    // ── Toolbar callbacks ──

    private async Task OnSearchChanged(string text)
    {
        _searchText = text;
        await LoadMediaItems();
    }

    private async Task OnSortChanged(string sort)
    {
        _sortBy = sort;
        await LoadMediaItems();
    }

    private Task OnGroupChanged(string group)
    {
        _groupBy = group;
        return Task.CompletedTask;
    }

    private Task OnViewModeChanged(string mode)
    {
        _viewMode = mode;
        return Task.CompletedTask;
    }

    private Task OnFilterToggled()
    {
        _filterOpen = !_filterOpen;
        return Task.CompletedTask;
    }

    // ── Alert toggle handlers ──

    private async Task ToggleReviewFilter()
    {
        _filterReview = !_filterReview;
        await LoadMediaItems();
    }

    private async Task ToggleQuarantineFilter()
    {
        _filterQuarantine = !_filterQuarantine;
        await LoadMediaItems();
    }

    private async Task ClearAllFilters()
    {
        _filterReview = false;
        _filterQuarantine = false;
        _filterMediaType = null;
        _filterMinConfidence = null;
        _filterMissingArt = false;
        await LoadMediaItems();
    }

    // ── Filter panel callbacks ──

    private async Task OnMediaTypeFilterChanged(string? type)
    {
        _filterMediaType = type;
        await LoadMediaItems();
    }

    private async Task OnReviewFilterChanged(bool on)
    {
        _filterReview = on;
        await LoadMediaItems();
    }

    private async Task OnQuarantineFilterChanged(bool on)
    {
        _filterQuarantine = on;
        await LoadMediaItems();
    }

    private async Task OnMinConfidenceChanged(double? min)
    {
        _filterMinConfidence = min;
        await LoadMediaItems();
    }

    private async Task OnMissingArtChanged(bool on)
    {
        _filterMissingArt = on;
        await LoadMediaItems();
    }

    // ── Actions ──

    private Task OnResolveClicked(Guid entityId)
    {
        _resolveItem = _mediaItems.FirstOrDefault(i => i.EntityId == entityId);
        return Task.CompletedTask;
    }

    private Task OnDeleteClicked(Guid entityId)
    {
        var item = _mediaItems.FirstOrDefault(i => i.EntityId == entityId);
        if (item is not null)
        {
            _deleteItemId = entityId;
            _deleteItemTitle = item.Title;
        }
        return Task.CompletedTask;
    }

    private Task OnMoreClicked(Guid entityId)
    {
        // Placeholder for context menu
        return Task.CompletedTask;
    }

    private Task OnPersonMoreClicked(Guid personId)
    {
        return Task.CompletedTask;
    }

    private Task OnUniverseMoreClicked(Guid universeId)
    {
        return Task.CompletedTask;
    }

    // ── Hub drawer ──

    private async Task OnHubClicked(Guid hubId)
    {
        _selectedHub = _managedHubs.FirstOrDefault(h => h.Id == hubId);
        if (_selectedHub is not null)
        {
            _selectedHubItems = await ApiClient.GetHubItemsAsync(hubId, 20);
        }
    }

    private void CloseHubDrawer()
    {
        _selectedHub = null;
        _selectedHubItems = [];
    }

    private async Task OnHubEnabledToggled((Guid Id, bool Enabled) args)
    {
        await ApiClient.UpdateHubEnabledAsync(args.Id, args.Enabled);
        var hub = _managedHubs.FirstOrDefault(h => h.Id == args.Id);
        if (hub is not null)
        {
            hub.IsEnabled = args.Enabled;
            hub.Status = !args.Enabled ? "Disabled" : hub.ItemCount == 0 ? "Empty" : "Active";
        }
        if (_selectedHub?.Id == args.Id)
            _selectedHub.IsEnabled = args.Enabled;
    }

    private async Task OnHubFeaturedToggled((Guid Id, bool Featured) args)
    {
        await ApiClient.UpdateHubFeaturedAsync(args.Id, args.Featured);
        var hub = _managedHubs.FirstOrDefault(h => h.Id == args.Id);
        if (hub is not null) hub.IsFeatured = args.Featured;
        if (_selectedHub?.Id == args.Id)
            _selectedHub.IsFeatured = args.Featured;
    }

    // ── Resolution overlay ──

    private void CloseResolution() => _resolveItem = null;

    private async Task OnRejectFromOverlay(Guid entityId)
    {
        await ApiClient.RejectRegistryItemAsync(entityId);
        _resolveItem = null;
        Snackbar.Add("Item quarantined", Severity.Warning);
        await LoadMediaItems();
        await LoadCounts();
    }

    private async Task OnApplyResolution(Guid entityId)
    {
        _resolveItem = null;
        Snackbar.Add("Resolution applied", Severity.Success);
        await LoadMediaItems();
        await LoadCounts();
    }

    // ── Delete confirm ──

    private async Task OnDeleteConfirmed()
    {
        if (_deleteItemId.HasValue)
        {
            await ApiClient.BatchDeleteRegistryItemsAsync([_deleteItemId.Value]);
            Snackbar.Add("Item deleted", Severity.Info);
            _deleteItemId = null;
            await LoadMediaItems();
            await LoadCounts();
        }
    }
}

<style>
    .vault-layout {
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
        color: rgba(255, 255, 255, 0.85);
        font-family: inherit;
        padding-left: 16px;
    }

    /* ── Pipeline Header ── */
    .vault-header {
        padding: 24px 0 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        flex-shrink: 0;
    }

    .vault-header-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 0 24px;
        margin-bottom: 16px;
    }

    .vault-progress-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
    }

    .vault-pulse {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(96, 165, 250, 0.8);
        box-shadow: 0 0 8px rgba(96, 165, 250, 0.6);
        animation: vault-pulse-anim 2s ease-in-out infinite;
    }

    @@keyframes vault-pulse-anim {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    .vault-progress-text {
        font-size: 10px;
        font-weight: 800;
        color: rgba(96, 165, 250, 0.8);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .vault-progress-track {
        width: 128px;
        height: 4px;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 4px;
        overflow: hidden;
    }

    .vault-progress-fill {
        height: 100%;
        background: rgba(96, 165, 250, 0.7);
        transition: width 1s ease;
        border-radius: 4px;
    }

    .vault-title {
        font-size: 30px;
        font-weight: 900;
        color: #fff;
        letter-spacing: -0.02em;
        line-height: 1;
        margin: 0;
    }

    .vault-header-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    /* ── Tab bar ── */
    .vault-tab-bar {
        display: flex;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 4px;
        gap: 4px;
    }

    .vault-tab {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 8px;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.35);
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .vault-tab:hover {
        color: rgba(255, 255, 255, 0.6);
    }

    .vault-tab--active {
        background: rgba(255, 255, 255, 0.06);
        color: #fff;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    /* ── Add button ── */
    .vault-add-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 20px;
        background: rgba(96, 165, 250, 0.85);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: background 0.15s;
        box-shadow: 0 4px 12px rgba(96, 165, 250, 0.2);
        white-space: nowrap;
    }

    .vault-add-btn:hover {
        background: rgba(96, 165, 250, 1);
    }

    /* ── Alert badges ── */
    .vault-alert-badges {
        display: flex;
        gap: 8px;
        padding: 8px 24px 0;
    }

    .vault-alert {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
