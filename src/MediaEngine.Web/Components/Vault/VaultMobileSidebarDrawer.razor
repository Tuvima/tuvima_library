@namespace MediaEngine.Web.Components.Vault

@if (IsOpen)
{
    <div class="vmsb-overlay" @onclick="Close">
        <div class="vmsb-panel" @onclick:stopPropagation="true">

            <div class="vmsb-header">
                <span class="vmsb-header-label">Views</span>
                <button class="vmsb-close" @onclick="Close">
                    <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 18px;" />
                </button>
            </div>

            <div class="vmsb-nav">

                @* ── PINNED: Always shown for Media tab ── *@
                @if (ActiveTab == "media")
                {
                    <div class="vmsb-section">
                        <div class="vmsb-section-label">Pinned</div>
                        @RenderItem("recent",          Icons.Material.Outlined.NewReleases,   "Recently Added")
                        @RenderItem("needs-review",    Icons.Material.Outlined.ErrorOutline,  "Needs Review")
                        @RenderItem("quarantined",     Icons.Material.Outlined.Block,         "Quarantined")
                    </div>
                    <div class="vmsb-divider"></div>
                }

                @* ── TAB-SPECIFIC VIEWS ── *@
                <div class="vmsb-section">
                    <div class="vmsb-section-label">@GetSectionLabel()</div>

                    @if (ActiveTab == "media")
                    {
                        @switch (SelectedMediaType)
                        {
                            case null:
                            case "":
                                @RenderItem("all", Icons.Material.Outlined.ViewList, "All Media")
                                break;

                            case "Books":
                                @RenderItem("all",     Icons.Material.Outlined.ViewList,        "All Books")
                                @RenderItem("series",  Icons.Material.Outlined.Layers,           "Series")
                                @RenderItem("authors", Icons.Material.Outlined.Edit,             "Authors")
                                break;

                            case "Audiobooks":
                                @RenderItem("all",       Icons.Material.Outlined.ViewList,          "All Audiobooks")
                                @RenderItem("series",    Icons.Material.Outlined.Layers,             "Series")
                                @RenderItem("narrators", Icons.Material.Outlined.RecordVoiceOver,    "Narrators")
                                break;

                            case "Movies":
                                @RenderItem("all",       Icons.Material.Outlined.ViewList,      "All Movies")
                                @RenderItem("directors", Icons.Material.Outlined.Movie,          "Directors")
                                @RenderItem("decades",   Icons.Material.Outlined.CalendarMonth,  "Decades")
                                break;

                            case "TV":
                                @RenderItem("shows", Icons.Material.Outlined.LiveTv, "All Shows")
                                break;

                            case "Music":
                                @RenderItem("all",    Icons.Material.Outlined.ViewList,  "All Music")
                                @RenderItem("albums", Icons.Material.Outlined.Album,     "Albums")
                                @RenderItem("artists",Icons.Material.Outlined.Person,    "Artists")
                                @RenderItem("genres", Icons.Material.Outlined.Category,  "Genres")
                                break;

                            case "Comics":
                                @RenderItem("all",    Icons.Material.Outlined.ViewList, "All Comics")
                                @RenderItem("series", Icons.Material.Outlined.Layers,   "Series")
                                break;

                            case "Podcasts":
                                @RenderItem("all",      Icons.Material.Outlined.ViewList, "All Podcasts")
                                @RenderItem("episodes", Icons.Material.Outlined.List,     "Episodes")
                                break;

                            default:
                                @RenderItem("all", Icons.Material.Outlined.ViewList, "All Media")
                                break;
                        }
                    }
                    else if (ActiveTab == "people")
                    {
                        @RenderItem("all",    Icons.Material.Outlined.ViewList,     "All People")
                        @RenderItem("by-role",Icons.Material.Outlined.Badge,        "By Role")
                        @RenderItem("recent", Icons.Material.Outlined.NewReleases,  "Recently Added")
                    }
                    else if (ActiveTab == "universes")
                    {
                        @RenderItem("all",              Icons.Material.Outlined.ViewList, "All Universes")
                        @RenderItem("by-size",          Icons.Material.Outlined.Sort,     "By Size")
                        @RenderItem("recently-updated", Icons.Material.Outlined.Update,   "Recently Updated")
                    }
                    else if (ActiveTab == "hubs")
                    {
                        @RenderItem("all",       Icons.Material.Outlined.ViewList,    "All Hubs")
                        @RenderItem("smart",     Icons.Material.Outlined.AutoAwesome, "Smart")
                        @RenderItem("system",    Icons.Material.Outlined.Bookmarks,   "System")
                        @RenderItem("mixes",     Icons.Material.Outlined.AutoAwesome, "Mixes")
                        @RenderItem("playlists", Icons.Material.Outlined.QueueMusic,  "Playlists")
                    }
                </div>

            </div>
        </div>
    </div>
}

@* ── RENDER HELPER ── *@
@code {

    private RenderFragment RenderItem(string key, string icon, string label) =>
    @<button class="vmsb-item @(ActiveView == key ? "vmsb-item--active" : "")"
             @onclick="() => SelectView(key)">
        <MudIcon Icon="@icon"
                 Style="@($"font-size: 16px; color: {(ActiveView == key ? "rgba(96,165,250,0.9)" : "rgba(255,255,255,0.3)")};")"/>
        <span class="vmsb-item-label">@label</span>
    </button>;

}

@code {

    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public string ActiveTab { get; set; } = "media";
    [Parameter] public string? SelectedMediaType { get; set; }
    [Parameter] public string ActiveView { get; set; } = "recent";
    [Parameter] public EventCallback<string> ActiveViewChanged { get; set; }

    private async Task SelectView(string key)
    {
        await ActiveViewChanged.InvokeAsync(key);
        await Close();
    }

    private async Task Close()
    {
        await IsOpenChanged.InvokeAsync(false);
    }

    private string GetSectionLabel() => ActiveTab switch
    {
        "media"     => SelectedMediaType ?? "All Media",
        "people"    => "People",
        "universes" => "Universes",
        "hubs"      => "Hubs",
        _           => "Views"
    };

}

<style>
    /* ── OVERLAY ── */
    .vmsb-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1100;
        animation: vmsb-fade-in 0.15s ease;
    }

    @@keyframes vmsb-fade-in {
        from { opacity: 0; }
        to   { opacity: 1; }
    }

    /* ── PANEL ── */
    .vmsb-panel {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 280px;
        max-width: 80vw;
        background: #14181d;
        border-right: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        flex-direction: column;
        animation: vmsb-slide-in 0.2s ease;
    }

    @@keyframes vmsb-slide-in {
        from { transform: translateX(-100%); }
        to   { transform: translateX(0); }
    }

    /* ── HEADER ── */
    .vmsb-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        flex-shrink: 0;
    }

    .vmsb-header-label {
        font-size: 14px;
        font-weight: 700;
        color: white;
    }

    .vmsb-close {
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.4);
        cursor: pointer;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .vmsb-close:hover {
        color: white;
    }

    /* ── NAV SCROLL AREA ── */
    .vmsb-nav {
        flex: 1;
        overflow-y: auto;
        padding: 8px 0;
        scrollbar-width: none;
    }

    .vmsb-nav::-webkit-scrollbar {
        display: none;
    }

    /* ── SECTION ── */
    .vmsb-section {
        padding: 4px 0;
    }

    .vmsb-section-label {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.2);
        padding: 8px 16px 4px;
    }

    /* ── DIVIDER ── */
    .vmsb-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.04);
        margin: 4px 0;
    }

    /* ── VIEW ITEMS ── */
    .vmsb-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        cursor: pointer;
        transition: background 0.15s;
        border: none;
        background: none;
        width: 100%;
        text-align: left;
    }

    .vmsb-item:hover {
        background: rgba(255, 255, 255, 0.04);
    }

    .vmsb-item--active {
        background: rgba(96, 165, 250, 0.08);
        color: rgba(96, 165, 250, 0.9);
    }

    .vmsb-item-label {
        font-size: 12px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.5);
    }

    .vmsb-item--active .vmsb-item-label {
        color: rgba(96, 165, 250, 0.9);
    }
</style>
