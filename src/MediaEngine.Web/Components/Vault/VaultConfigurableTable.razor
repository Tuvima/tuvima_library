@namespace MediaEngine.Web.Components.Vault
@using MediaEngine.Web.Models.ViewDTOs
@using Microsoft.AspNetCore.Components.Web

@inject IStringLocalizer<SharedStrings> L

@if (Items.Count == 0 && !Loading)
{
    <div class="vmt-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Inbox" Style="font-size: 3rem; opacity: 0.15; margin-bottom: 12px;" />
        <p style="color: rgba(255,255,255,0.25); font-size: 0.85rem;">No items match your current filters.</p>
    </div>
}
else
{
    <div class="vmt-container">
        @if (GroupBy != "none")
        {
            @foreach (var group in GetGroups())
            {
                <div class="vmt-group">
                    <div class="vmt-group-header" @onclick="() => ToggleGroup(group.Key)">
                        <MudIcon Icon="@(IsGroupExpanded(group.Key) ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                 Style="font-size: 14px; opacity: 0.4;" />
                        @{
                            var groupAllSelected = group.Items.Count > 0 && group.Items.All(i => SelectedItems.Contains(i.EntityId));
                        }
                        <input type="checkbox"
                               class="vct-checkbox"
                               checked="@groupAllSelected"
                               @onclick:stopPropagation="true"
                               @onchange="() => ToggleGroupSelection(group.Items)" />
                        <span class="vmt-group-label">@group.Label</span>
                        <div class="vmt-group-line"></div>
                        <span class="vmt-group-count">@group.Items.Count items</span>
                    </div>
                    @if (IsGroupExpanded(group.Key))
                    {
                        <div class="vmt-table-wrap">
                            @RenderTable(group.Items)
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="vmt-table-wrap">
                @RenderTable(Items)
            </div>
        }

        @if (Loading)
        {
            <div class="vmt-loading">
                <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                     Style="color: rgba(255,255,255,0.15);" />
            </div>
        }
    </div>
}

@if (_hoverCover is not null)
{
    <div class="vmt-hover-overlay" style="top: @(_hoverY)px; left: @(_hoverX)px;">
        <img src="@_hoverCover" alt="" class="vmt-hover-img" />
    </div>
}

@code {
    [Parameter] public List<VaultColumnDef> Columns { get; set; } = [];
    [Parameter] public List<VaultItemViewModel> Items { get; set; } = [];
    [Parameter] public string GroupBy { get; set; } = "none";
    [Parameter] public bool Loading { get; set; }
    [Parameter] public int PosterSize { get; set; } = 48;
    [Parameter] public EventCallback<Guid> OnRowClicked { get; set; }
    [Parameter] public EventCallback<string> OnAuthorClicked { get; set; }

    // Batch selection
    [Parameter] public HashSet<Guid> SelectedItems { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedItemsChanged { get; set; }

    private readonly Dictionary<string, bool> _expandedGroups = new();
    private string? _hoverCover;
    private double _hoverX;
    private double _hoverY;
    private int _lastClickedIndex = -1;

    private List<VaultColumnDef> VisibleColumns => Columns.Where(c => c.DefaultVisible).ToList();

    private void ShowHover(string? coverUrl, MouseEventArgs e)
    {
        if (string.IsNullOrEmpty(coverUrl)) return;
        _hoverCover = coverUrl;
        _hoverX = e.ClientX + 20;
        _hoverY = e.ClientY - 100;
    }

    private void HideHover()
    {
        _hoverCover = null;
    }

    private bool IsAllSelected(List<VaultItemViewModel> items) =>
        items.Count > 0 && items.All(i => SelectedItems.Contains(i.EntityId));

    private async Task ToggleSelectAll(List<VaultItemViewModel> items)
    {
        var allSelected = IsAllSelected(items);
        var updated = new HashSet<Guid>(SelectedItems);
        if (allSelected)
            foreach (var item in items) updated.Remove(item.EntityId);
        else
            foreach (var item in items) updated.Add(item.EntityId);
        SelectedItems = updated;
        await SelectedItemsChanged.InvokeAsync(SelectedItems);
    }

    private async Task ToggleItem(VaultItemViewModel item, List<VaultItemViewModel> contextList, MouseEventArgs e)
    {
        var updated = new HashSet<Guid>(SelectedItems);
        var currentIndex = contextList.IndexOf(item);

        if (e.ShiftKey && _lastClickedIndex >= 0 && currentIndex >= 0)
        {
            var start = Math.Min(_lastClickedIndex, currentIndex);
            var end = Math.Max(_lastClickedIndex, currentIndex);
            for (var i = start; i <= end; i++)
                updated.Add(contextList[i].EntityId);
        }
        else
        {
            if (updated.Contains(item.EntityId))
                updated.Remove(item.EntityId);
            else
                updated.Add(item.EntityId);
            _lastClickedIndex = currentIndex;
        }

        SelectedItems = updated;
        await SelectedItemsChanged.InvokeAsync(SelectedItems);
    }

    private async Task ToggleGroupSelection(List<VaultItemViewModel> groupItems)
    {
        var allSelected = groupItems.Count > 0 && groupItems.All(i => SelectedItems.Contains(i.EntityId));
        var updated = new HashSet<Guid>(SelectedItems);
        if (allSelected)
            foreach (var item in groupItems) updated.Remove(item.EntityId);
        else
            foreach (var item in groupItems) updated.Add(item.EntityId);
        SelectedItems = updated;
        await SelectedItemsChanged.InvokeAsync(SelectedItems);
    }

    private RenderFragment RenderTable(List<VaultItemViewModel> items) => __builder =>
    {
        var cols = VisibleColumns;
        <table class="vmt-table">
            <thead>
                <tr class="vmt-thead-row">
                    @foreach (var col in cols)
                    {
                        var alignClass = col.Align switch
                        {
                            "center" => "vmt-th--center",
                            "right" => "vmt-th--right",
                            _ => ""
                        };
                        var paddingStyle = col.Key == "media" ? "padding-left: 24px;" : "";
                        var paddingRightStyle = col.Key == "status" && GroupBy == "none" ? "padding-right: 24px;" : "";
                        <th class="vmt-th @alignClass" style="width: @col.Width; @paddingStyle @paddingRightStyle">
                            @if (col.RenderType == ColumnRenderType.Checkbox)
                            {
                                <input type="checkbox"
                                       class="vct-checkbox"
                                       checked="@IsAllSelected(items)"
                                       @onchange="() => ToggleSelectAll(items)" />
                            }
                            else
                            {
                                @col.Label
                            }
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    var isQuarantined = item.VaultDisplayStatus == VaultStatus.Quarantined;
                    var isSelected = SelectedItems.Contains(item.EntityId);
                    <tr class="vmt-row @(isQuarantined ? "vmt-row--quarantined" : "") @(isSelected ? "vmt-row--selected" : "")"
                        style="cursor: pointer;"
                        @onclick="() => OnRowClicked.InvokeAsync(item.EntityId)">
                        @foreach (var col in cols)
                        {
                            var tdAlignClass = col.Align switch
                            {
                                "center" => "vmt-td--center",
                                "right" => "vmt-td--right",
                                _ => ""
                            };
                            var tdPaddingStyle = col.Key == "media" ? "padding-left: 24px;" : "";
                            var tdPaddingRightStyle = col.Key == "status" ? "padding-right: 24px;" : "";

                            <td class="vmt-td @tdAlignClass" style="@tdPaddingStyle @tdPaddingRightStyle">
                                @switch (col.RenderType)
                                {
                                    case ColumnRenderType.Checkbox:
                                        <input type="checkbox"
                                               class="vct-checkbox"
                                               checked="@isSelected"
                                               @onclick:stopPropagation="true"
                                               @onclick="(e) => ToggleItem(item, items, e)" />
                                        break;

                                    case ColumnRenderType.MediaCell:
                                        <div class="vmt-media-cell">
                                            <div class="vmt-poster-wrap">
                                                <div class="vmt-thumb" style="width: @(PosterSize)px; min-height: @(PosterSize)px;"
                                                     @onmouseenter="(e) => ShowHover(item.CoverUrl, e)"
                                                     @onmouseleave="HideHover">
                                                    @if (!string.IsNullOrEmpty(item.CoverUrl))
                                                    {
                                                        <img src="@item.CoverUrl" alt="@item.Title" class="vmt-thumb-img" loading="lazy" />
                                                    }
                                                    else
                                                    {
                                                        <MudIcon Icon="@VaultHelpers.GetMediaTypeIcon(item.MediaType)"
                                                                 Style="font-size: 20px; opacity: 0.25;" />
                                                    }
                                                </div>
                                                <div class="vmt-type-badge" style="color: @VaultHelpers.GetMediaTypeColor(item.MediaType);">
                                                    <MudIcon Icon="@VaultHelpers.GetMediaTypeIcon(item.MediaType)" Style="font-size: 14px;" />
                                                </div>
                                            </div>
                                            <div class="vmt-media-info">
                                                <p class="vmt-title @(isQuarantined || item.VaultDisplayStatus == VaultStatus.Failed ? "vmt-title--muted" : "")">@item.Title</p>
                                                @if (!string.IsNullOrEmpty(item.OriginalTitle) && item.OriginalTitle != item.Title)
                                                {
                                                    <p class="vmt-original-title">@item.OriginalTitle</p>
                                                }
                                                <p class="vmt-subtitle">@VaultHelpers.FormatMediaType(item.MediaType) @(item.Year is not null ? $"• {item.Year}" : "")</p>
                                                @{
                                                    var creatorName = GetCreatorForMediaType(item);
                                                }
                                                @if (!string.IsNullOrEmpty(creatorName))
                                                {
                                                    <button class="vmt-creator-link" @onclick:stopPropagation="true"
                                                            @onclick="() => OnAuthorClicked.InvokeAsync(creatorName)">
                                                        @creatorName.ToUpperInvariant()
                                                    </button>
                                                }
                                                @if (item.VaultDisplayStatus is VaultStatus.NeedsReview or VaultStatus.Failed && !string.IsNullOrEmpty(item.ReviewTrigger))
                                                {
                                                    <p class="vmt-review-reason">@VaultHelpers.GetReviewTriggerLabel(item.ReviewTrigger)</p>
                                                }
                                                @if (item.VaultDisplayStatus == VaultStatus.WaitingForProvider)
                                                {
                                                    <p class="vmt-provider-waiting">
                                                        @if (!string.IsNullOrEmpty(item.FailedProviderName))
                                                        {
                                                            @($"Waiting for {item.FailedProviderName} to come back online…")
                                                        }
                                                        else
                                                        {
                                                            @("Waiting for provider to come back online…")
                                                        }
                                                    </p>
                                                }
                                            </div>
                                        </div>
                                        break;

                                    case ColumnRenderType.Pipeline:
                                        <div class="vmt-pipeline">
                                            <StageGate Stage="@item.Stage1" />
                                            <StageGate Stage="@item.Stage2" />
                                            <StageGate Stage="@item.Stage3" IsLast="true" />
                                        </div>
                                        break;

                                    case ColumnRenderType.StatusPill:
                                        <div style="display: flex; justify-content: @(col.Align == "right" ? "flex-end" : col.Align == "center" ? "center" : "flex-start");">
                                            <StatusPill Status="@item.VaultDisplayStatus" QuarantineDays="@item.QuarantineDays" />
                                        </div>
                                        break;

                                    case ColumnRenderType.UniverseLink:
                                        @if (!string.IsNullOrEmpty(item.UniverseName))
                                        {
                                            <span class="vmt-universe-linked">@item.UniverseName.ToUpperInvariant()</span>
                                        }
                                        else
                                        {
                                            <span class="vmt-universe-standalone">Standalone</span>
                                        }
                                        break;

                                    case ColumnRenderType.Date:
                                        <span class="vct-text-cell">@FormatRelativeTime(item.CreatedAt)</span>
                                        break;

                                    case ColumnRenderType.Duration:
                                        <span class="vct-text-cell">—</span>
                                        break;

                                    case ColumnRenderType.FileSize:
                                        <span class="vct-text-cell">@VaultHelpers.FormatFileSize(item.FileSizeBytes)</span>
                                        break;

                                    case ColumnRenderType.Rating:
                                        <span class="vct-text-cell">—</span>
                                        break;

                                    case ColumnRenderType.Text:
                                        <span class="vct-text-cell">@GetTextValue(item, col.PropertyName)</span>
                                        break;

                                    default:
                                        <span class="vct-text-cell">—</span>
                                        break;
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    };

    // ── Grouping ──

    private record TableGroup(string Key, string Label, List<VaultItemViewModel> Items);

    private bool IsGroupExpanded(string key)
    {
        if (_expandedGroups.TryGetValue(key, out var val)) return val;
        return true;
    }

    private void ToggleGroup(string key) =>
        _expandedGroups[key] = !IsGroupExpanded(key);

    private List<TableGroup> GetGroups()
    {
        if (GroupBy == "type")
        {
            var order = new[] { "Books", "Audiobooks", "Movies", "TV", "Comics", "Music", "Podcasts" };
            var byType = Items.GroupBy(i => i.MediaType ?? "Unknown").ToDictionary(g => g.Key, g => g.ToList());
            var result = new List<TableGroup>();
            foreach (var mt in order)
                if (byType.TryGetValue(mt, out var items) && items.Count > 0)
                    result.Add(new TableGroup(mt, mt, items));
            foreach (var kvp in byType.Where(k => !order.Contains(k.Key)))
                if (kvp.Value.Count > 0)
                    result.Add(new TableGroup(kvp.Key, kvp.Key, kvp.Value));
            return result;
        }

        if (GroupBy == "status")
        {
            var groups = new List<TableGroup>();
            var verified   = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Verified).ToList();
            var provisional = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Provisional).ToList();
            var review      = Items.Where(i => i.VaultDisplayStatus == VaultStatus.NeedsReview).ToList();
            var failed      = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Failed).ToList();
            var quarantined = Items.Where(i => i.VaultDisplayStatus == VaultStatus.Quarantined).ToList();
            var waiting     = Items.Where(i => i.VaultDisplayStatus == VaultStatus.WaitingForProvider).ToList();
            if (verified.Count > 0)    groups.Add(new TableGroup("verified",    "Verified",              verified));
            if (provisional.Count > 0) groups.Add(new TableGroup("provisional", "Provisional",           provisional));
            if (review.Count > 0)      groups.Add(new TableGroup("review",      "Needs Review",          review));
            if (waiting.Count > 0)     groups.Add(new TableGroup("waiting",     "Waiting for Provider",  waiting));
            if (failed.Count > 0)      groups.Add(new TableGroup("failed",      "Failed",                failed));
            if (quarantined.Count > 0) groups.Add(new TableGroup("quarantined", "Quarantined",           quarantined));
            return groups;
        }

        if (GroupBy == "letter")
        {
            var byLetter = Items
                .GroupBy(i => string.IsNullOrEmpty(i.Title) ? "#" : i.Title[0].ToString().ToUpperInvariant())
                .OrderBy(g => g.Key)
                .Select(g => new TableGroup(g.Key, g.Key, g.ToList()))
                .ToList();
            return byLetter;
        }

        if (GroupBy == "universe")
        {
            var byUniverse = Items
                .GroupBy(i => i.UniverseName ?? "Standalone")
                .OrderBy(g => g.Key)
                .Select(g => new TableGroup(g.Key, g.Key, g.ToList()))
                .ToList();
            return byUniverse;
        }

        return [new TableGroup("all", "All", Items)];
    }

    // ── Helpers ──

    private static string? GetCreatorForMediaType(VaultItemViewModel item) => item.MediaType switch
    {
        "Movies" => item.Director ?? item.Author,
        "TV"     => null,
        "Music"  => item.Artist ?? item.Author,
        _        => item.Author,
    };

    private static string GetTextValue(VaultItemViewModel item, string? propertyName) =>
        propertyName switch
        {
            "Author"        => item.Author ?? "—",
            "Director"      => item.Director ?? "—",
            "Artist"        => item.Artist ?? "—",
            "Year"          => item.Year ?? "—",
            "Series"        => item.UniverseName ?? "—",
            "Narrator"      => item.Author ?? "—",   // placeholder — Narrator not on VaultItemViewModel yet
            "Album"         => "—",                   // placeholder
            "TrackNumber"   => "—",                   // placeholder
            "PodcastName"   => "—",                   // placeholder
            "EpisodeNumber" => "—",                   // placeholder
            "Season"        => "—",                   // placeholder
            "Episode"       => "—",                   // placeholder
            "IssueNumber"   => "—",                   // placeholder
            "Rating"        => "—",                   // placeholder
            "Name"          => item.Title,            // Hubs tab
            "Type"          => item.MediaType ?? "—", // Hubs tab
            "SeriesCount"   => "—",                   // Universes tab
            "PeopleCount"   => "—",                   // Universes tab
            "ItemCount"     => "—",                   // Hubs tab
            "Featured"      => "—",                   // Hubs tab
            _ => "—",
        };

    private static string FormatRelativeTime(DateTimeOffset dt)
    {
        var diff = DateTimeOffset.UtcNow - dt;
        if (diff.TotalMinutes < 60)  return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24)    return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 30)     return $"{(int)diff.TotalDays}d ago";
        if (diff.TotalDays < 365)    return $"{(int)(diff.TotalDays / 30)}mo ago";
        return $"{(int)(diff.TotalDays / 365)}y ago";
    }
}

<style>
    /* ── Row selection ── */
    .vmt-row--selected {
        background: rgba(96, 165, 250, 0.05);
    }

    /* ── Checkbox ── */
    .vct-checkbox {
        width: 16px;
        height: 16px;
        accent-color: #60A5FA;
        cursor: pointer;
    }

    /* ── Text cell ── */
    .vct-text-cell {
        font-size: 13px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.55);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* ── Reuse all vmt-* classes from VaultMediaTable ── */
    .vmt-container {
        /* outer wrapper */
    }

    .vmt-table-wrap {
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        overflow: visible;
    }

    .vmt-table {
        width: 100%;
        text-align: left;
        border-collapse: collapse;
        table-layout: fixed;
    }

    .vmt-thead-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        background: rgba(255, 255, 255, 0.015);
    }

    .vmt-th {
        padding: 16px;
        font-size: 10px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.25);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .vmt-th--center { text-align: center; }
    .vmt-th--right  { text-align: right; }

    .vmt-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.025);
        transition: background 0.15s;
    }

    .vmt-row:last-child {
        border-bottom: none;
    }

    .vmt-row:hover {
        background: rgba(96, 165, 250, 0.02);
    }

    .vmt-row--quarantined {
        opacity: 0.5;
    }

    .vmt-td {
        padding: 16px;
        vertical-align: middle;
        overflow: visible;
    }

    .vmt-td--center { text-align: center; }
    .vmt-td--right  { text-align: right; }

    .vmt-media-cell {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .vmt-poster-wrap {
        position: relative;
        flex-shrink: 0;
    }

    .vmt-thumb {
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.02);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .vmt-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.6;
        transition: opacity 0.15s;
    }

    .vmt-thumb:hover .vmt-thumb-img {
        opacity: 1;
    }

    .vmt-hover-overlay {
        position: fixed;
        z-index: 10000;
        pointer-events: none;
        animation: vmt-hover-fade-in 0.15s ease;
    }

    .vmt-hover-img {
        width: 200px;
        height: auto;
        max-height: 300px;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 16px 64px rgba(0,0,0,0.9), 0 0 0 1px rgba(255,255,255,0.08);
    }

    @@keyframes vmt-hover-fade-in {
        from { opacity: 0; transform: scale(0.92); }
        to   { opacity: 1; transform: scale(1); }
    }

    .vmt-type-badge {
        position: absolute;
        bottom: -4px;
        right: -6px;
        width: 22px;
        height: 22px;
        border-radius: 6px;
        background: #14181d;
        border: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.6);
        z-index: 2;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
    }

    .vmt-media-info {
        overflow: hidden;
    }

    .vmt-title {
        font-size: 14px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin: 0 0 4px 0;
    }

    .vmt-title--muted {
        color: rgba(255, 255, 255, 0.4);
    }

    .vmt-original-title {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
        margin: 2px 0 4px 0;
        opacity: 0.7;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vmt-subtitle {
        font-size: 10px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.02em;
        margin: 0;
    }

    .vmt-creator-link {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.3);
        margin-top: 2px;
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        text-align: left;
        transition: color 0.15s;
    }

    .vmt-creator-link:hover {
        color: #60A5FA;
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .vmt-review-reason {
        font-size: 10px;
        font-weight: 600;
        color: #EF9F27;
        margin-top: 4px;
        font-style: italic;
    }

    .vmt-provider-waiting {
        font-size: 10px;
        font-weight: 600;
        color: #38BDF8;
        margin-top: 4px;
        font-style: italic;
    }

    .vmt-pipeline {
        display: flex;
        justify-content: center;
    }

    .vmt-universe-linked {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #A78BFA;
    }

    .vmt-universe-standalone {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.2);
    }

    .vmt-group {
        margin-bottom: 32px;
    }

    .vmt-group-header {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 0 8px;
        margin-bottom: 12px;
        cursor: pointer;
        user-select: none;
    }

    .vmt-group-label {
        font-size: 10px;
        font-weight: 800;
        color: rgba(255, 255, 255, 0.35);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        white-space: nowrap;
    }

    .vmt-group-line {
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.04);
    }

    .vmt-group-count {
        font-size: 10px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.2);
