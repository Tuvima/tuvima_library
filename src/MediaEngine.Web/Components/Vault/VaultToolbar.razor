@using MediaEngine.Web.Models.ViewDTOs

@inject IStringLocalizer<SharedStrings> L

<div class="vault-toolbar">
    @* ── Back Button (drill-down mode) ── *@
    @if (ShowBackButton)
    {
        <button class="vault-back-btn" @onclick="() => OnBack.InvokeAsync()">
            <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size: 16px;" />
            <span>Back to @ResolvedTabId</span>
        </button>
    }

    @* ── Search ── *@
    <div class="vault-search-wrap">
        <MudIcon Icon="@Icons.Material.Outlined.Search"
                 Class="vault-search-icon" />
        <input type="text"
               class="vault-search-input"
               placeholder="@L["VaultToolbar_SearchPlaceholder"]"
               value="@SearchText"
               @oninput="OnSearchInput" />
    </div>

    @* ── View Mode Switcher ── *@
    @{
        var viewModes = GetViewModeOptions();
    }
    @if (viewModes.Count > 1)
    {
        <div class="vault-view-modes">
            @foreach (var mode in viewModes)
            {
                var isActive = ViewMode == mode.Value;
                <button class="vault-view-mode-btn @(isActive ? "vault-view-mode-btn--active" : "")"
                        title="@mode.Label"
                        @onclick="() => ViewModeChanged.InvokeAsync(mode.Value)">
                    <MudIcon Icon="@mode.Icon" Style="font-size: 14px;" />
                    <span>@mode.Label</span>
                </button>
            }
        </div>
    }

    @* ── Sort / Group controls ── *@
    <div class="vault-controls">
        @* Sort *@
        <div class="vault-control-group">
            @foreach (var opt in GetSortOptions())
            {
                var isActive = SortBy == opt.Value || SortBy == opt.ReverseValue;
                var isReversed = SortBy == opt.ReverseValue;
                <button class="vault-sort-btn @(isActive ? "vault-sort-btn--active" : "")"
                        @onclick="() => ToggleSort(opt.Value, opt.ReverseValue)">
                    <span>@opt.Label</span>
                    @if (isActive)
                    {
                        <MudIcon Icon="@(isReversed ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward)"
                                 Style="font-size: 12px;" />
                    }
                </button>
            }
        </div>

        @* ── Contextual filter dropdown ── *@
        @{
            var filterOpts = GetFilterOptions();
        }
        @if (filterOpts.Count > 0)
        {
            <div class="vault-control-divider"></div>
            <div class="vault-control-group">
                <select class="vault-select" value="@(FilterValue ?? filterOpts[0].Value)"
                        @onchange="OnFilterChanged">
                    @foreach (var opt in filterOpts)
                    {
                        <option value="@opt.Value">@opt.Label</option>
                    }
                </select>
            </div>
        }

        @* ── Group-by dropdown ── *@
        @{
            var groupOpts = GetGroupOptions();
        }
        @if (groupOpts.Count > 0 && (ResolvedTabId == "media" || IsTabWithGrouping(ResolvedTabId)))
        {
            <div class="vault-control-divider"></div>

            <div class="vault-control-group">
                <select class="vault-select" value="@GroupBy" @onchange="OnGroupChanged">
                    @foreach (var opt in groupOpts)
                    {
                        <option value="@opt.Value">@opt.Label</option>
                    }
                </select>
                @if (GroupBy != "none")
                {
                    <button class="vault-group-action-btn" title="Expand all" @onclick="() => OnExpandAll.InvokeAsync()">
                        <MudIcon Icon="@Icons.Material.Filled.UnfoldMore" Style="font-size: 16px;" />
                    </button>
                    <button class="vault-group-action-btn" title="Collapse all" @onclick="() => OnCollapseAll.InvokeAsync()">
                        <MudIcon Icon="@Icons.Material.Filled.UnfoldLess" Style="font-size: 16px;" />
                    </button>
                }
            </div>
        }

        @if (ResolvedTabId == "media" || ResolvedTabId == "music")
        {
            <div class="vault-control-divider"></div>

            @* Poster Size *@
            <div class="vault-control-group vault-poster-slider">
                <MudIcon Icon="@Icons.Material.Outlined.PhotoSizeSelectLarge"
                         Style="font-size: 14px; color: rgba(255,255,255,0.3);" />
                <input type="range" class="vault-range" min="40" max="72" step="4"
                       value="@PosterSize" @oninput="OnPosterSizeInput" />
            </div>
        }
    </div>

    @* ── Column Picker button ── *@
    <button class="vault-column-picker-btn" title="Choose columns"
            @onclick="() => OnColumnPickerRequested.InvokeAsync()">
        <MudIcon Icon="@Icons.Material.Outlined.ViewColumn" Style="font-size: 16px;" />
    </button>
</div>

@code {
    // ── Existing parameters (unchanged, preserved for backward compat) ──
    [Parameter] public string ActiveTab { get; set; } = "media";
    [Parameter] public string SearchText { get; set; } = "";
    [Parameter] public string SortBy { get; set; } = "newest";
    [Parameter] public string GroupBy { get; set; } = "none";

    [Parameter] public int PosterSize { get; set; } = 48;
    [Parameter] public EventCallback<int> PosterSizeChanged { get; set; }

    [Parameter] public EventCallback<string> SearchTextChanged { get; set; }
    [Parameter] public EventCallback<string> SortByChanged { get; set; }
    [Parameter] public EventCallback<string> GroupByChanged { get; set; }
    [Parameter] public EventCallback OnExpandAll { get; set; }
    [Parameter] public EventCallback OnCollapseAll { get; set; }

    // ── New parameters ──

    /// <summary>Active tab identifier for per-tab contextual controls.
    /// Takes precedence over <see cref="ActiveTab"/> when set.</summary>
    [Parameter] public string? TabId { get; set; }

    /// <summary>Show a back button (drill-down mode).</summary>
    [Parameter] public bool ShowBackButton { get; set; }

    /// <summary>Fires when the back button is clicked.</summary>
    [Parameter] public EventCallback OnBack { get; set; }

    /// <summary>Currently selected value for the contextual filter dropdown.</summary>
    [Parameter] public string? FilterValue { get; set; }

    /// <summary>Fires when the contextual filter selection changes.</summary>
    [Parameter] public EventCallback<string?> FilterValueChanged { get; set; }

    /// <summary>Fires when the column picker icon button is clicked.</summary>
    [Parameter] public EventCallback OnColumnPickerRequested { get; set; }

    /// <summary>Current view mode for the active tab (e.g. "all", "shows", "artists", "albums", "series").</summary>
    [Parameter] public string ViewMode { get; set; } = "all";

    /// <summary>Fires when the user switches view mode.</summary>
    [Parameter] public EventCallback<string> ViewModeChanged { get; set; }

    // ── Computed helpers ──

    /// <summary>Resolved tab ID: TabId if set, otherwise fall back to ActiveTab.</summary>
    private string ResolvedTabId => TabId ?? ActiveTab;

    private System.Timers.Timer? _debounceTimer;

    private void OnSearchInput(ChangeEventArgs e)
    {
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        var value = e.Value?.ToString() ?? "";
        _debounceTimer.Elapsed += async (_, _) =>
        {
            _debounceTimer?.Stop();
            await InvokeAsync(() => SearchTextChanged.InvokeAsync(value));
        };
        _debounceTimer.AutoReset = false;
        _debounceTimer.Start();
    }

    private record ViewModeOption(string Label, string Value, string Icon);

    private List<ViewModeOption> GetViewModeOptions() => ResolvedTabId switch
    {
        "movies"     => [new("All Movies", "all", Icons.Material.Outlined.ViewList), new("By Series", "series", Icons.Material.Outlined.Folder)],
        "tv"         => [new("By Show", "shows", Icons.Material.Outlined.Folder), new("All Episodes", "all", Icons.Material.Outlined.ViewList)],
        "music"      => [new("By Artist", "artists", Icons.Material.Outlined.Person), new("By Album", "albums", Icons.Material.Outlined.Album), new("All Songs", "all", Icons.Material.Outlined.ViewList)],
        "books"      => [new("All Books", "all", Icons.Material.Outlined.ViewList), new("By Series", "series", Icons.Material.Outlined.Folder)],
        "audiobooks" => [new("All Audiobooks", "all", Icons.Material.Outlined.ViewList), new("By Series", "series", Icons.Material.Outlined.Folder)],
        "podcasts"   => [new("By Show", "shows", Icons.Material.Outlined.Folder), new("All Episodes", "all", Icons.Material.Outlined.ViewList)],
        "comics"     => [new("By Series", "series", Icons.Material.Outlined.Folder), new("All Issues", "all", Icons.Material.Outlined.ViewList)],
        _ => [],
    };

    private record SortOption(string Label, string Value, string ReverseValue);
    private record SelectOption(string Label, string Value);

    private List<SortOption> GetSortOptions() => ResolvedTabId switch
    {
        "people" =>
        [
            new("Presence", "presence", "presence_asc"),
            new("Name", "name", "name_desc"),
            new("Newest", "newest", "oldest"),
        ],
        _ =>
        [
            new("Newest", "newest", "oldest"),
            new("Title", "title", "title_desc"),
        ],
    };

    /// <summary>Returns contextual filter options for the resolved tab.
    /// Returns an empty list for tabs that should not show the filter dropdown.</summary>
    private List<SelectOption> GetFilterOptions() => ResolvedTabId switch
    {
        "movies"     => [new("All Qualities", ""), new("4K", "4k"), new("1080p", "1080p"), new("HD", "hd")],
        "tv"         => [new("All", ""), new("Complete", "complete"), new("Active", "active"), new("Ended", "ended")],
        "music"      => [new("All Formats", ""), new("FLAC", "flac"), new("ALAC", "alac"), new("MP3", "mp3")],
        "books"      => [new("All Formats", ""), new("EPUB", "epub"), new("PDF", "pdf")],
        "audiobooks" => [new("All Formats", ""), new("M4B", "m4b"), new("AAX", "aax"), new("MP3", "mp3")],
        "podcasts"   => [new("All", ""), new("Active", "active"), new("Ended", "ended")],
        "comics"     => [new("All Formats", ""), new("CBZ", "cbz"), new("CBR", "cbr"), new("PDF", "pdf")],
        // new, people, universes, hubs — no filter dropdown
        _ => [],
    };

    /// <summary>Returns group-by options for the resolved tab.
    /// Returns an empty list for tabs where the group dropdown should be hidden.</summary>
    private List<SelectOption> GetGroupOptions() => ResolvedTabId switch
    {
        "movies"     => [new("None", "none"), new("Director", "director"), new("Year", "year"), new("Decade", "decade")],
        "tv"         => [new("None", "none"), new("Show", "show"), new("Season", "season")],
        "music"      => [new("None", "none"), new("Artist", "artist"), new("Album", "album"), new("Genre", "genre")],
        "books"      => [new("None", "none"), new("Author", "author"), new("Series", "series")],
        "audiobooks" => [new("None", "none"), new("Author", "author"), new("Narrator", "narrator")],
        "podcasts"   => [new("None", "none"), new("Show", "show")],
        "comics"     => [new("None", "none"), new("Series", "series"), new("Year", "year")],
        "media"      => [new("None", "none"), new("Type", "type"), new("Status", "status"), new("Letter", "letter"), new("Universe / Series", "universe"), new("Author / Director", "author"), new("Artist", "artist"), new("Genre", "genre"), new("Decade", "decade")],
        "new"        => [new("None", "none"), new("Type", "type")],
        "people"     => [new("None", "none"), new("Role", "role")],
        // universes, hubs — hide group dropdown
        _ => [],
    };

    /// <summary>Returns true for tabs that should display the group-by dropdown
    /// (all named tabs except universes and hubs).</summary>
    private static bool IsTabWithGrouping(string tabId) => tabId switch
    {
        "universes" or "hubs" => false,
        _ => true,
    };

    private async Task ToggleSort(string value, string reverseValue)
    {
        var newSort = SortBy == value ? reverseValue : (SortBy == reverseValue ? value : value);
        await SortByChanged.InvokeAsync(newSort);
    }

    private async Task OnGroupChanged(ChangeEventArgs e) =>
        await GroupByChanged.InvokeAsync(e.Value?.ToString() ?? "none");

    private async Task OnFilterChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        // Normalise empty string → null so callers can do a simple null check
        await FilterValueChanged.InvokeAsync(string.IsNullOrEmpty(val) ? null : val);
    }

    private async Task OnPosterSizeInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            await PosterSizeChanged.InvokeAsync(val);
    }

    public void Dispose()
    {
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();
    }
}

<style>
    .vault-toolbar {
        display: flex;
        gap: 12px;
        align-items: center;
        flex: 1;
    }

    /* ── Back button ── */
    .vault-back-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 10px;
        color: rgba(255, 255, 255, 0.5);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.075em;
        padding: 6px 12px 6px 8px;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .vault-back-btn:hover {
        color: rgba(255, 255, 255, 0.85);
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.12);
    }

    /* ── Search ── */
    .vault-search-wrap {
        position: relative;
        flex: 1;
        max-width: 320px;
    }

    .vault-search-icon {
        position: absolute;
        left: 14px;
        top: 10px;
        font-size: 16px !important;
        color: rgba(255, 255, 255, 0.2);
        transition: color 0.2s;
    }

    .vault-search-wrap:focus-within .vault-search-icon {
        color: rgba(96, 165, 250, 0.7);
    }

    .vault-search-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 8px 16px 8px 40px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.85);
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .vault-search-input::placeholder {
        color: rgba(255, 255, 255, 0.2);
    }

    .vault-search-input:focus {
        border-color: rgba(96, 165, 250, 0.3);
        box-shadow: 0 0 0 1px rgba(96, 165, 250, 0.15);
    }

    /* ── Controls container ── */
    .vault-controls {
        display: flex;
        align-items: center;
        gap: 4px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 4px 8px;
    }

    .vault-control-group {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 4px;
    }

    .vault-select {
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.5);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        outline: none;
        cursor: pointer;
        padding: 6px 4px;
    }

    .vault-select option {
        background: #14181d;
        color: rgba(255, 255, 255, 0.85);
    }

    .vault-control-divider {
        width: 1px;
        height: 24px;
        background: rgba(255, 255, 255, 0.06);
    }

    .vault-group-action-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: none;
        background: transparent;
        color: rgba(255, 255, 255, 0.3);
        cursor: pointer;
        transition: all 0.15s;
        padding: 0;
    }

    .vault-group-action-btn:hover {
        color: rgba(255, 255, 255, 0.7);
        background: rgba(255, 255, 255, 0.06);
    }

    /* ── Poster Size Slider ── */
    .vault-poster-slider {
        min-width: 80px;
    }

    .vault-range {
        -webkit-appearance: none;
        appearance: none;
        width: 60px;
        height: 4px;
        border-radius: 2px;
        background: rgba(255, 255, 255, 0.1);
        outline: none;
        cursor: pointer;
    }

    .vault-range::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
        cursor: pointer;
        transition: background 0.15s;
    }

    .vault-range::-webkit-slider-thumb:hover {
        background: rgba(96, 165, 250, 0.8);
    }

    .vault-range::-moz-range-thumb {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
        border: none;
        cursor: pointer;
    }

    /* ── Sort toggle buttons ── */
    .vault-sort-btn {
        display: flex;
        align-items: center;
        gap: 4px;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.35);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        padding: 6px 8px;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .vault-sort-btn:hover {
        color: rgba(255, 255, 255, 0.6);
        background: rgba(255, 255, 255, 0.04);
    }

    .vault-sort-btn--active {
        color: rgba(96, 165, 250, 0.9);
        background: rgba(96, 165, 250, 0.08);
    }

    /* ── Column Picker button ── */
    .vault-column-picker-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.02);
        color: rgba(255, 255, 255, 0.3);
        cursor: pointer;
        transition: all 0.15s;
        padding: 0;
        flex-shrink: 0;
    }

    .vault-column-picker-btn:hover {
        color: rgba(255, 255, 255, 0.75);
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.12);
    }

    /* ── Mobile ── */
    @@media (max-width: 768px) {
        .vault-toolbar {
            flex-wrap: wrap;
        }

        .vault-search-wrap {
            flex: 1 1 100%;
            max-width: none;
            order: -1;
        }

        .vault-controls {
            flex: 1;
            overflow-x: auto;
            scrollbar-width: none;
        }

        .vault-controls::-webkit-scrollbar {
            display: none;
        }

        .vault-view-modes {
            order: -1;
            flex: 1 1 100%;
            justify-content: center;
        }
    }

    /* ── View Mode Switcher ── */
    .vault-view-modes {
        display: flex;
        align-items: center;
        gap: 2px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 10px;
        padding: 3px;
        flex-shrink: 0;
    }

    .vault-view-mode-btn {
        display: flex;
        align-items: center;
        gap: 5px;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.3);
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        padding: 5px 10px;
        border-radius: 7px;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .vault-view-mode-btn:hover {
        color: rgba(255, 255, 255, 0.6);
        background: rgba(255, 255, 255, 0.03);
    }

    .vault-view-mode-btn--active {
        color: rgba(96, 165, 250, 0.9);
        background: rgba(96, 165, 250, 0.08);
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
    }
</style>
