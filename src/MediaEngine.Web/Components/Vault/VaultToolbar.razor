@using MediaEngine.Web.Models.ViewDTOs

@inject IStringLocalizer<SharedStrings> L

<div class="vault-toolbar">
    @* ── Search ── *@
    <div class="vault-search-wrap">
        <MudIcon Icon="@Icons.Material.Outlined.Search"
                 Class="vault-search-icon" />
        <input type="text"
               class="vault-search-input"
               placeholder="@L["VaultToolbar_SearchPlaceholder"]"
               value="@SearchText"
               @oninput="OnSearchInput" />
    </div>

    @* ── Sort / Group controls ── *@
    <div class="vault-controls">
        @* Sort *@
        <div class="vault-control-group">
            <select class="vault-select" value="@SortBy" @onchange="OnSortChanged">
                <option value="newest">@L["VaultToolbar_SortNewest"]</option>
                <option value="oldest">@L["VaultToolbar_SortOldest"]</option>
                <option value="confidence">@L["VaultToolbar_SortConfidence"]</option>
            </select>
        </div>

        <div class="vault-control-divider"></div>

        @* Group *@
        <div class="vault-control-group">
            <select class="vault-select" value="@GroupBy" @onchange="OnGroupChanged">
                <option value="none">@L["VaultToolbar_GroupNone"]</option>
                <option value="type">@L["VaultToolbar_GroupType"]</option>
                <option value="status">@L["VaultToolbar_GroupStatus"]</option>
                <option value="letter">@L["VaultToolbar_GroupLetter"]</option>
            </select>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ActiveTab { get; set; } = "media";
    [Parameter] public string SearchText { get; set; } = "";
    [Parameter] public string SortBy { get; set; } = "newest";
    [Parameter] public string GroupBy { get; set; } = "none";

    // Callbacks
    [Parameter] public EventCallback<string> SearchTextChanged { get; set; }
    [Parameter] public EventCallback<string> SortByChanged { get; set; }
    [Parameter] public EventCallback<string> GroupByChanged { get; set; }

    private System.Timers.Timer? _debounceTimer;

    private void OnSearchInput(ChangeEventArgs e)
    {
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        var value = e.Value?.ToString() ?? "";
        _debounceTimer.Elapsed += async (_, _) =>
        {
            _debounceTimer?.Stop();
            await InvokeAsync(() => SearchTextChanged.InvokeAsync(value));
        };
        _debounceTimer.AutoReset = false;
        _debounceTimer.Start();
    }

    private async Task OnSortChanged(ChangeEventArgs e) =>
        await SortByChanged.InvokeAsync(e.Value?.ToString() ?? "newest");

    private async Task OnGroupChanged(ChangeEventArgs e) =>
        await GroupByChanged.InvokeAsync(e.Value?.ToString() ?? "none");

    public void Dispose()
    {
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();
    }
}

<style>
    .vault-toolbar {
        display: flex;
        gap: 12px;
        align-items: center;
        flex: 1;
    }

    /* ── Search ── */
    .vault-search-wrap {
        position: relative;
        flex: 1;
        max-width: 320px;
    }

    .vault-search-icon {
        position: absolute;
        left: 14px;
        top: 10px;
        font-size: 16px !important;
        color: rgba(255, 255, 255, 0.2);
        transition: color 0.2s;
    }

    .vault-search-wrap:focus-within .vault-search-icon {
        color: rgba(96, 165, 250, 0.7);
    }

    .vault-search-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 8px 16px 8px 40px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.85);
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .vault-search-input::placeholder {
        color: rgba(255, 255, 255, 0.2);
    }

    .vault-search-input:focus {
        border-color: rgba(96, 165, 250, 0.3);
        box-shadow: 0 0 0 1px rgba(96, 165, 250, 0.15);
    }

    /* ── Controls container ── */
    .vault-controls {
        display: flex;
        align-items: center;
        gap: 4px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 4px 8px;
    }

    .vault-control-group {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 4px;
    }

    .vault-select {
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.5);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        outline: none;
        cursor: pointer;
        padding: 6px 4px;
    }

    .vault-select option {
        background: #14181d;
        color: rgba(255, 255, 255, 0.85);
    }

    .vault-control-divider {
        width: 1px;
        height: 24px;
        background: rgba(255, 255, 255, 0.06);
    }

    /* ── Mobile ── */
    @@media (max-width: 768px) {
        .vault-toolbar {
            flex-wrap: wrap;
        }

        .vault-search-wrap {
            flex: 1 1 100%;
            max-width: none;
            order: -1;
        }

        .vault-controls {
            flex: 1;
            overflow-x: auto;
            scrollbar-width: none;
        }

        .vault-controls::-webkit-scrollbar {
            display: none;
        }
    }
</style>
