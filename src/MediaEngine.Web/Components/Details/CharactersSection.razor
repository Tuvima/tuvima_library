@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

@foreach (var group in Groups)
{
    <section class="tl-detail-panel">
        <div class="tl-section-heading tl-credit-group__heading">
            <h2>@group.Title</h2>
            <span class="tl-credit-group__count">@group.Characters.Count</span>
        </div>
        <div class="tl-character-grid">
            @foreach (var character in VisibleCharacters(group))
            {
                <CharacterCreditCard Credit="character" />
            }
        </div>
        @if (CanToggle(group))
        {
            <button type="button" class="tl-credit-group__toggle" @onclick="@(() => ToggleGroup(group))">
                @ToggleLabel(group)
            </button>
        }
    </section>
}

@code {
    [Parameter] public IReadOnlyList<CharacterGroupViewModel> Groups { get; set; } = [];

    private const int InitialVisibleCount = 8;
    private readonly HashSet<string> _expandedGroups = new(StringComparer.Ordinal);

    private IReadOnlyList<EntityCreditViewModel> VisibleCharacters(CharacterGroupViewModel group)
        => IsExpanded(group)
            ? group.Characters
            : group.Characters.Take(InitialVisibleCount).ToList();

    private bool CanToggle(CharacterGroupViewModel group) => group.Characters.Count > InitialVisibleCount;

    private string ToggleLabel(CharacterGroupViewModel group)
        => IsExpanded(group) ? "Show fewer" : $"Show all {group.Characters.Count}";

    private void ToggleGroup(CharacterGroupViewModel group)
    {
        var key = GroupKey(group);
        if (!_expandedGroups.Add(key))
            _expandedGroups.Remove(key);
    }

    private bool IsExpanded(CharacterGroupViewModel group) => _expandedGroups.Contains(GroupKey(group));

    private static string GroupKey(CharacterGroupViewModel group)
        => $"{group.GroupType}:{group.Title}:{group.Characters.Count}";
}
