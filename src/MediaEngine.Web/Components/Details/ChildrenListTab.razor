@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<div class="tl-detail-tab-panel">
    @foreach (var group in Groups)
    {
        <section class="tl-detail-panel">
            <div class="tl-section-heading"><h2>@group.Title</h2></div>
            <div class="tl-child-list">
                @foreach (var item in group.Items)
                {
                    <article class="tl-child-card">
                        <div class="tl-child-card__art">
                            @if (!string.IsNullOrWhiteSpace(item.ArtworkUrl))
                            {
                                <img src="@item.ArtworkUrl" alt="@item.Title" />
                            }
                            else
                            {
                                <GeneratedIdentity Name="@item.Title" />
                            }
                        </div>
                        <div class="tl-child-card__body">
                            <h3>@item.Title</h3>
                            @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                            {
                                <div class="tl-child-card__meta">@item.Subtitle</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p>@item.Description</p>
                            }
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<MediaGroupingViewModel> Groups { get; set; } = [];
}
