@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<SurfaceTabBar Items="@SurfaceTabs"
               ActiveKey="@ActiveTab"
               ActiveKeyChanged="@ActiveTabChanged"
               AriaLabel="Detail sections"
               Class="tl-detail-tabs"
               ItemClass="tl-detail-tab" />

@code {
    [Parameter] public IReadOnlyList<DetailTab> Tabs { get; set; } = [];
    [Parameter] public string ActiveTab { get; set; } = "overview";
    [Parameter] public EventCallback<string> ActiveTabChanged { get; set; }

    private IReadOnlyList<SurfaceTabItem> SurfaceTabs => Tabs
        .Select(tab => new SurfaceTabItem(tab.Key, tab.Label))
        .ToList();
}
