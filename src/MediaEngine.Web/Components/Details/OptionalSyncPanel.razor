@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

@if (Capability is not null && Capability.State != SyncCapabilityState.NotApplicable)
{
    <div class="tl-sync-callout">
        <MudIcon Icon="@(Capability.State == SyncCapabilityState.Enabled ? Icons.Material.Outlined.Link : Icons.Material.Outlined.CompareArrows)" Size="Size.Small" />
        <span>@(Capability.Reason ?? StateLabel)</span>
    </div>
}

@code {
    [Parameter] public ReadingListeningSyncCapabilityViewModel? Capability { get; set; }
    [Parameter] public MultiFormatState MultiFormatState { get; set; }

    private string StateLabel => Capability?.State switch
    {
        SyncCapabilityState.Enabled => "Read + Listen Sync is enabled.",
        SyncCapabilityState.AvailableNotEnabled => "Read + Listen Sync is available.",
        SyncCapabilityState.NeedsReview => "Sync needs review.",
        SyncCapabilityState.Unavailable => "Read + Listen Sync is unavailable.",
        _ => "Progress is tracked separately.",
    };
}
