@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<section class="tl-detail-panel tl-registry-panel">
    <div class="tl-section-heading"><h2>Registry</h2></div>
    <dl class="tl-detail-dl">
        <dt>Entity ID</dt>
        <dd>@Model.Id</dd>
        <dt>Entity Type</dt>
        <dd>@Model.EntityType</dd>
        <dt>Presentation Context</dt>
        <dd>@Model.PresentationContext</dd>
        <dt>Artwork Mode</dt>
        <dd>@Model.Artwork.PresentationMode</dd>
        <dt>Artwork Source</dt>
        <dd>@Model.Artwork.Source</dd>
        <dt>Identity Status</dt>
        <dd>@Model.IdentityStatus</dd>
    </dl>
</section>

@code {
    [Parameter, EditorRequired] public DetailPageViewModel Model { get; set; } = default!;
}
