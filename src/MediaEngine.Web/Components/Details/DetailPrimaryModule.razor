@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

@if (Model.PrimaryModule.Kind != DetailPrimaryModuleKind.None)
{
    <section class="@RootClass" aria-labelledby="detail-primary-module-title">
        @if (ShowHeader)
        {
            <header class="tl-detail-primary-module__header">
                <div class="tl-detail-primary-module__title">
                    <MudIcon Icon="@ModuleIcon" Size="Size.Small" />
                    <h2 id="detail-primary-module-title">@Model.PrimaryModule.Title</h2>
                </div>

                <div class="tl-detail-primary-module__controls">
                    <div class="tl-detail-primary-module__selectors">
                        @if (Model.PrimaryModule.SupportsRoleFilter && RoleOptions.Count > 1)
                        {
                            <AppSelect Value="@_selectedRole"
                                       ValueChanged="SelectRole"
                                       Options="@RoleSelectOptions"
                                       LeadingIcon="@Icons.Material.Outlined.Badge"
                                       Class="tl-detail-primary-module__role-filter"
                                       aria-label="Filter works by role" />
                        }
                    </div>

                    @if (Model.PrimaryModule.SupportsLaneFilter && HasMultipleOwnedLanes)
                    {
                        <div class="tl-detail-primary-module__filters" aria-label="Filter works by library lane">
                            @foreach (var lane in LaneOptions.Where(option => option.Key != "all"))
                            {
                                <AppNativeButton Type="button"
                                                 Class="@FilterClass(_selectedLane, lane.Key)"
                                                 OnClick="@(() => SelectLane(lane.Key))"
                                                 aria-pressed="@(_selectedLane == lane.Key)">
                                    @if (LaneIcon(lane.Key) is { } icon)
                                    {
                                        <MudIcon Icon="@icon" Size="Size.Small" />
                                    }
                                    @lane.Label
                                    <span>@lane.Count</span>
                                </AppNativeButton>
                            }
                        </div>
                    }
                </div>
            </header>
        }

        <div class="tl-detail-primary-module__viewport">
            @if (Model.PrimaryModule.Kind is DetailPrimaryModuleKind.Sequence or DetailPrimaryModuleKind.Episodes
                 && Model.SequencePlacement is not null)
            {
                <SequencePlacementPanel Placement="Model.SequencePlacement"
                                        DetailSurface="true"
                                        OnContainerSelected="OnContainerSelected" />
            }
            else if (Model.PrimaryModule.Kind == DetailPrimaryModuleKind.Tracks)
            {
                <MusicTrackList Groups="PrimaryGroups"
                                AlbumTitle="@Model.Title"
                                AlbumArtworkUrl="@ArtworkUrl"
                                Compact="Embedded"
                                AlbumIsSaved="IsInMyList"
                                OnSaveToList="OnSaveToList" />
            }
            else if (Model.PrimaryModule.Kind == DetailPrimaryModuleKind.Chapters)
            {
                <AudiobookChapterList Groups="PrimaryGroups"
                                      AudiobookTitle="@Model.Title"
                                      AudiobookArtworkUrl="@ArtworkUrl" />
            }
            else if (FilteredItems.Count == 0)
            {
                <p class="tl-detail-primary-module__empty">No owned library items are available for this section.</p>
            }
            else
            {
                <div class="tl-detail-primary-module__rail">
                    @foreach (var item in FilteredItems)
                    {
                        <a class="@ItemClass(item)" href="@ResolveRoute(item)">
                            <span class="tl-detail-primary-module__art">
                                @if (!string.IsNullOrWhiteSpace(item.ArtworkUrl))
                                {
                                    <img src="@item.ArtworkUrl" alt="" />
                                }
                                else
                                {
                                    <GeneratedIdentity Name="@item.Title" />
                                }
                            </span>
                            <span class="tl-detail-primary-module__copy">
                                <strong>@item.Title</strong>
                                @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                                {
                                    <small>@item.Subtitle</small>
                                }
                            </span>
                        </a>
                    }
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public DetailPageViewModel Model { get; set; } = default!;
    [Parameter] public bool Embedded { get; set; }
    [Parameter] public EventCallback<SequenceContainerOptionViewModel> OnContainerSelected { get; set; }
    [Parameter] public EventCallback OnSaveToList { get; set; }

    private string _selectedLane = "all";
    private string _selectedRole = "all";
    private string? _modelId;

    protected override void OnParametersSet()
    {
        if (string.Equals(_modelId, Model.Id, StringComparison.Ordinal))
            return;

        _modelId = Model.Id;
        _selectedLane = "all";
        _selectedRole = "all";
    }

    private IReadOnlyList<MediaGroupingViewModel> PrimaryGroups
        => Model.PrimaryModule.GroupKeys.Count == 0
            ? Model.MediaGroups
            : Model.MediaGroups
                .Where(group => Model.PrimaryModule.GroupKeys.Contains(group.Key, StringComparer.OrdinalIgnoreCase))
                .ToList();

    private IReadOnlyList<MediaGroupingItemViewModel> AllItems
        => PrimaryGroups
            .SelectMany(group => group.Items)
            .Where(item => item.IsOwned)
            .GroupBy(item => $"{item.EntityType}:{item.Id}", StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .ToList();

    private IReadOnlyList<MediaGroupingItemViewModel> FilteredItems
        => AllItems
            .Where(item => _selectedLane == "all" || string.Equals(ResolveLane(item), _selectedLane, StringComparison.OrdinalIgnoreCase))
            .Where(item => _selectedRole == "all" || item.Roles.Contains(_selectedRole, StringComparer.OrdinalIgnoreCase))
            .OrderBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private IReadOnlyList<FilterOption> LaneOptions
    {
        get
        {
            var values = AllItems
                .GroupBy(ResolveLane, StringComparer.OrdinalIgnoreCase)
                .Where(group => !string.Equals(group.Key, "other", StringComparison.OrdinalIgnoreCase))
                .OrderBy(group => LaneSort(group.Key))
                .Select(group => new FilterOption(group.Key, LaneLabel(group.Key), group.Count()))
                .ToList();
            return [new FilterOption("all", "All", AllItems.Count), .. values];
        }
    }

    private IReadOnlyList<FilterOption> RoleOptions
    {
        get
        {
            var values = AllItems
                .SelectMany(item => item.Roles)
                .Where(role => !string.IsNullOrWhiteSpace(role))
                .GroupBy(role => role, StringComparer.OrdinalIgnoreCase)
                .OrderByDescending(group => group.Count())
                .ThenBy(group => group.Key, StringComparer.OrdinalIgnoreCase)
                .Select(group => new FilterOption(group.Key, group.Key, group.Count()))
                .ToList();
            return [new FilterOption("all", "All roles", AllItems.Count), .. values];
        }
    }

    private bool HasMultipleOwnedLanes => LaneOptions.Count(option => option.Key != "all") > 1;

    private bool ShowHeader => Model.PrimaryModule.Kind is not DetailPrimaryModuleKind.Tracks
        and not DetailPrimaryModuleKind.Chapters
        and not DetailPrimaryModuleKind.Sequence
        and not DetailPrimaryModuleKind.Episodes;

    private string ModuleIcon => Model.EntityType is DetailEntityType.Person or DetailEntityType.MusicArtist
        ? Icons.Material.Outlined.Workspaces
        : Model.EntityType == DetailEntityType.Collection
            ? Icons.Material.Outlined.CollectionsBookmark
            : Icons.Material.Outlined.AccountTree;

    private IReadOnlyList<AppSelectOption> RoleSelectOptions => RoleOptions
        .Select(role => new AppSelectOption(role.Key, $"{role.Label} ({role.Count})"))
        .ToList();

    private string? ArtworkUrl => Model.Artwork.CoverUrl ?? Model.Artwork.PosterUrl ?? Model.Artwork.HeroArtwork.Url;

    private bool IsInMyList => Model.PrimaryActions
        .Concat(Model.SecondaryActions)
        .Concat(Model.OverflowActions)
        .FirstOrDefault(action => action.Key is "my-list" or "favorite")?.IsSelected == true;

    private string RootClass =>
        $"tl-detail-primary-module tl-detail-primary-module--{Model.PrimaryModule.Kind.ToString().ToLowerInvariant()} {(Embedded ? "tl-detail-primary-module--embedded" : "tl-detail-primary-module--below-hero")}";

    private static string FilterClass(string selected, string key)
        => $"tl-detail-primary-module__filter{(string.Equals(selected, key, StringComparison.OrdinalIgnoreCase) ? " is-active" : string.Empty)}";

    private string ItemClass(MediaGroupingItemViewModel item)
        => $"tl-detail-primary-module__item tl-detail-primary-module__item--{ArtworkShape(item.EntityType)}";

    private string ArtworkShape(DetailEntityType entityType)
        => Model.PrimaryModule.Kind == DetailPrimaryModuleKind.Works
            ? entityType switch
            {
                DetailEntityType.MusicAlbum or DetailEntityType.MusicTrack => "square",
                _ => "portrait",
            }
            : entityType switch
        {
            DetailEntityType.MusicAlbum or DetailEntityType.MusicTrack => "square",
            DetailEntityType.Movie or DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "wide",
            _ => "portrait",
        };

    private static string ResolveRoute(MediaGroupingItemViewModel item)
        => item.Actions.FirstOrDefault(action => !string.IsNullOrWhiteSpace(action.Route))?.Route
           ?? $"/details/{item.EntityType.ToString().ToLowerInvariant()}/{item.Id}";

    private static string ResolveLane(MediaGroupingItemViewModel item)
        => !string.IsNullOrWhiteSpace(item.Lane) ? item.Lane : item.EntityType switch
        {
            DetailEntityType.Movie or DetailEntityType.MovieSeries or DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "watch",
            DetailEntityType.MusicAlbum or DetailEntityType.MusicArtist or DetailEntityType.MusicTrack or DetailEntityType.Audiobook => "listen",
            DetailEntityType.Book or DetailEntityType.BookSeries or DetailEntityType.ComicIssue or DetailEntityType.ComicSeries => "read",
            _ => "other",
        };

    private static string LaneLabel(string key) => key switch
    {
        "read" => "Read",
        "watch" => "Watch",
        "listen" => "Listen",
        _ => "Other",
    };

    private static string? LaneIcon(string key) => key switch
    {
        "read" => Icons.Material.Outlined.MenuBook,
        "watch" => Icons.Material.Outlined.Tv,
        "listen" => Icons.Material.Outlined.Headphones,
        _ => null,
    };

    private static int LaneSort(string key) => key switch
    {
        "read" => 0,
        "watch" => 1,
        "listen" => 2,
        _ => 3,
    };

    private void SelectLane(string lane)
        => _selectedLane = string.Equals(_selectedLane, lane, StringComparison.OrdinalIgnoreCase) ? "all" : lane;

    private void SelectRole(string? role) => _selectedRole = role ?? "all";
    private sealed record FilterOption(string Key, string Label, int Count);
}
