@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<section class="tl-completion-view tl-episode-panel">
    <div class="tl-completion-summary">
        <div>
            <div class="tl-completion-summary__eyebrow">Episodes</div>
            <h2>Owned <strong>@AggregateOwned</strong> of @AggregateTotal episodes</h2>
            @if (!string.IsNullOrWhiteSpace(IncompleteHint))
            {
                <div class="tl-completion-summary__hint">@IncompleteHint</div>
            }
        </div>
        <div class="tl-completion-summary__meter" aria-label="@($"{AggregateOwned} of {AggregateTotal} episodes owned")">
            <div class="tl-completion-summary__bar">
                <span style="width: @($"{AggregateCompletion:F0}%")"></span>
            </div>
            <strong>@AggregateOwned / @AggregateTotal</strong>
        </div>
    </div>

    @if (Groups.Count == 0)
    {
        <div class="tl-episode-empty">No episodes are available yet.</div>
    }
    else
    {
        <div class="tl-completion-groups">
            @foreach (var group in Groups)
            {
                var collapsed = IsCollapsed(group);
                <section class="tl-completion-group @(collapsed ? "is-collapsed" : string.Empty)">
                    <button type="button"
                            class="tl-completion-group__header"
                            aria-expanded="@(collapsed ? "false" : "true")"
                            @onclick="@(() => ToggleGroup(group))">
                        <span class="tl-completion-group__title">@group.Title</span>
                        <span class="tl-completion-group__meta">@group.TotalCount @EpisodeWord(group.TotalCount)</span>
                        <span class="tl-completion-status tl-completion-status--owned">
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small" />
                            @group.OwnedCount owned
                        </span>
                        @if (group.MissingCount > 0)
                        {
                            <span class="tl-completion-status tl-completion-status--missing">@group.MissingCount missing</span>
                        }
                        <MudIcon Icon="@(collapsed ? Icons.Material.Outlined.KeyboardArrowDown : Icons.Material.Outlined.KeyboardArrowUp)" Size="Size.Small" />
                    </button>

                    @if (!collapsed)
                    {
                        <div class="tl-completion-list">
                            @foreach (var item in group.Items.Select((episode, index) => (episode, index)))
                            {
                                var route = item.episode.IsOwned
                                    ? item.episode.Actions.FirstOrDefault(action => !string.IsNullOrWhiteSpace(action.Route))?.Route
                                    : null;
                                var episodeNumber = EpisodeNumber(item.episode, item.index);
                                var runtime = RuntimeLabel(item.episode);
                                var secondaryMeta = SecondaryMetadata(item.episode, runtime);

                                <article class="tl-completion-row tl-episode-row @(item.episode.IsOwned ? "is-owned" : "is-missing")">
                                    <div class="tl-completion-row__number">@episodeNumber</div>
                                    <div class="tl-completion-row__body">
                                        <h3>@item.episode.Title</h3>
                                        @if (!string.IsNullOrWhiteSpace(secondaryMeta))
                                        {
                                            <div class="tl-completion-row__meta">@secondaryMeta</div>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(item.episode.Subtitle))
                                        {
                                            <div class="tl-completion-row__meta">@item.episode.Subtitle</div>
                                        }
                                    </div>
                                    <div class="tl-completion-row__state">
                                        @if (item.episode.IsOwned)
                                        {
                                            <span class="tl-completion-owned">
                                                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small" />
                                                Owned
                                            </span>
                                        }
                                    </div>
                                    <div class="tl-completion-row__detail">
                                        @if (!string.IsNullOrWhiteSpace(runtime))
                                        {
                                            <span>@runtime</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(item.episode.Quality))
                                        {
                                            <span>@item.episode.Quality</span>
                                        }
                                        @if (!item.episode.IsOwned)
                                        {
                                            <span>No file in library</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(route))
                                    {
                                        <a class="tl-completion-row__link" href="@route" aria-label="@($"Open {item.episode.Title}")"></a>
                                    }
                                </article>
                            }
                        </div>
                    }
                </section>
            }
        </div>
    }
</section>

@code {
    [Parameter] public IReadOnlyList<MediaGroupingViewModel> Groups { get; set; } = [];

    private readonly HashSet<string> _collapsedGroups = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _touchedGroups = new(StringComparer.OrdinalIgnoreCase);

    private int AggregateOwned => Groups.Sum(GroupOwnedCount);
    private int AggregateTotal => Groups.Sum(GroupTotalCount);
    private double AggregateCompletion => AggregateTotal == 0 ? 0 : AggregateOwned * 100.0 / AggregateTotal;
    private string? IncompleteHint => Groups.FirstOrDefault(group => GroupMissingCount(group) > 0) is { } group
        ? $"{group.Title} incomplete"
        : null;

    private bool IsCollapsed(MediaGroupingViewModel group)
    {
        if (_touchedGroups.Contains(group.Key))
            return _collapsedGroups.Contains(group.Key);

        return group.InitiallyCollapsed || GroupOwnedCount(group) == 0;
    }

    private void ToggleGroup(MediaGroupingViewModel group)
    {
        var collapsed = IsCollapsed(group);
        _touchedGroups.Add(group.Key);
        if (collapsed)
            _collapsedGroups.Remove(group.Key);
        else
            _collapsedGroups.Add(group.Key);
    }

    private static int GroupOwnedCount(MediaGroupingViewModel group) =>
        group.OwnedCount > 0 ? group.OwnedCount : group.Items.Count(item => item.IsOwned);

    private static int GroupTotalCount(MediaGroupingViewModel group) =>
        group.TotalCount > 0 ? group.TotalCount : group.Items.Count;

    private static int GroupMissingCount(MediaGroupingViewModel group) =>
        group.MissingCount > 0 ? group.MissingCount : Math.Max(0, GroupTotalCount(group) - GroupOwnedCount(group));

    private static string EpisodeNumber(MediaGroupingItemViewModel episode, int index)
    {
        var subtitle = episode.Subtitle ?? string.Empty;
        var marker = subtitle.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        for (var i = 0; i < marker.Length; i++)
        {
            if ((string.Equals(marker[i], "E", StringComparison.OrdinalIgnoreCase)
                || string.Equals(marker[i], "Episode", StringComparison.OrdinalIgnoreCase))
                && i < marker.Length - 1)
            {
                return $"E{marker[i + 1].Trim().PadLeft(2, '0')}";
            }

            if (marker[i].StartsWith('E') && marker[i].Length > 1 && int.TryParse(marker[i][1..], out var compact))
                return $"E{compact:00}";
        }

        return $"E{index + 1:00}";
    }

    private static string? RuntimeLabel(MediaGroupingItemViewModel episode)
        => episode.Metadata.FirstOrDefault(m => string.Equals(m.Kind, "duration", StringComparison.OrdinalIgnoreCase))?.Label
            ?? episode.Metadata.FirstOrDefault(m => LooksLikeRuntime(m.Label))?.Label;

    private static string? SecondaryMetadata(MediaGroupingItemViewModel episode, string? runtime)
    {
        var labels = episode.Metadata
            .Select(m => m.Label)
            .Where(label => !string.IsNullOrWhiteSpace(label) && !string.Equals(label, runtime, StringComparison.OrdinalIgnoreCase))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        return labels.Count == 0 ? null : string.Join(" | ", labels);
    }

    private static bool LooksLikeRuntime(string? value)
        => !string.IsNullOrWhiteSpace(value)
            && (value.Contains(':', StringComparison.Ordinal)
                || value.Contains("min", StringComparison.OrdinalIgnoreCase)
                || value.Contains("m", StringComparison.OrdinalIgnoreCase));

    private static string EpisodeWord(int count) => count == 1 ? "episode" : "episodes";
}
