@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<div class="tl-hero-art @ArtClass">
    @if (Model.Artwork.PresentationMode == ArtworkPresentationMode.PairedEditionGradient && Model.OwnedFormats.Count > 1)
    {
        <div class="tl-hero-art__paired-primary">
            @if (!string.IsNullOrWhiteSpace(Model.OwnedFormats[0].CoverUrl))
            {
                <img src="@Model.OwnedFormats[0].CoverUrl" alt="@Model.OwnedFormats[0].DisplayName" />
            }
            else
            {
                <GeneratedIdentity Name="@Model.OwnedFormats[0].DisplayName" />
            }
            <span>@Model.OwnedFormats[0].DisplayName</span>
        </div>
        @if (Model.OwnedFormats.Skip(1).FirstOrDefault() is { } alternate)
        {
            <div class="tl-hero-art__paired-mini">
                @if (!string.IsNullOrWhiteSpace(alternate.CoverUrl))
                {
                    <img src="@alternate.CoverUrl" alt="@alternate.DisplayName" />
                }
                else
                {
                    <GeneratedIdentity Name="@alternate.DisplayName" />
                }
                <span>@alternate.DisplayName</span>
            </div>
        }
        @if (Model.MultiFormatState == MultiFormatState.MultipleFormatsSyncEnabled)
        {
            <div class="tl-hero-art__sync">
                <MudIcon Icon="@Icons.Material.Outlined.Link" Size="Size.Small" />
            </div>
        }
    }
    else if (!string.IsNullOrWhiteSpace(ImageUrl))
    {
        <img src="@ImageUrl" alt="@Model.Title" />
    }
    else
    {
        <GeneratedIdentity Name="@Model.Title" />
    }
</div>

@code {
    [Parameter, EditorRequired] public DetailPageViewModel Model { get; set; } = default!;

    private string? ImageUrl => Model.Artwork.PortraitUrl
        ?? Model.Artwork.CharacterImageUrl
        ?? Model.Artwork.PosterUrl
        ?? Model.Artwork.CoverUrl;

    private string ArtClass => Model.EntityType is DetailEntityType.MusicAlbum or DetailEntityType.MusicArtist
        ? "tl-hero-art--square"
        : Model.EntityType is DetailEntityType.Person or DetailEntityType.Character
            ? "tl-hero-art--portrait"
            : "tl-hero-art--poster";
}
