@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<div class="tl-detail-tab-panel">
    <section class="tl-detail-panel">
        <div class="tl-section-heading"><h2>Details</h2></div>
        <dl class="tl-detail-dl">
            <dt>Type</dt>
            <dd>@Model.EntityType</dd>
            <dt>Library Status</dt>
            <dd>@Model.LibraryStatus</dd>
            <dt>Identity</dt>
            <dd>@Model.IdentityStatus</dd>
            @if (Model.PersonDetails is not null)
            {
                @if (!string.IsNullOrWhiteSpace(Model.PersonDetails.Occupation))
                {
                    <dt>Occupation</dt>
                    <dd>@Model.PersonDetails.Occupation</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.PersonDetails.Nationality))
                {
                    <dt>Nationality</dt>
                    <dd>@Model.PersonDetails.Nationality</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.PersonDetails.WikidataQid))
                {
                    <dt>Canonical identity</dt>
                    <dd>@Model.PersonDetails.WikidataQid</dd>
                }
            }
        </dl>
    </section>

    @if (Model.SourceLinks.Count > 0)
    {
        <section class="tl-detail-panel tl-source-links-panel">
            <div class="tl-section-heading"><h2>Sources</h2></div>
            <div class="tl-source-links">
                @foreach (var link in Model.SourceLinks)
                {
                    <a class="tl-source-link"
                       href="@link.Url"
                       target="_blank"
                       rel="noopener noreferrer"
                       title="@link.Tooltip">
                        <MudIcon Icon="@SourceIcon(link.Key)" Size="Size.Small" />
                        <span>@link.Label</span>
                        <small>@link.SourceName</small>
                    </a>
                }
            </div>
        </section>
    }
</div>

@code {
    [Parameter, EditorRequired] public DetailPageViewModel Model { get; set; } = default!;

    private static string SourceIcon(string key) => key switch
    {
        "wikidata" or "wikidata-series" => Icons.Material.Outlined.AccountTree,
        "wikipedia" => Icons.Material.Outlined.Article,
        _ => Icons.Material.Outlined.OpenInNew,
    };
}
