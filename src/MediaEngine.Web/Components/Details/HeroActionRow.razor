@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<div class="tl-detail-actions @(IsPrimaryHeroActionRow ? "tl-detail-actions--watch" : null)">
    <div class="tl-detail-primary-actions">
        @foreach (var action in PrimaryActions)
        {
            <button type="button"
                    class="tl-detail-action tl-detail-action--primary"
                    disabled="@action.IsDisabled"
                    title="@TooltipFor(action)"
                    @onclick="@(() => Select(action))">
                <MudIcon Icon="@IconFor(action)" Size="Size.Medium" />
                <span>@PrimaryLabel(action)</span>
            </button>
        }
    </div>

    <div class="tl-detail-secondary-actions">
        @foreach (var action in SecondaryActions)
        {
            @if (UsePrimaryHeroChrome && action.Key == "read-listen")
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--watch">
                    <MudTooltip Text="@TooltipFor(action)" Placement="Placement.Bottom">
                        <button type="button"
                                class="tl-detail-watch-secondary tl-detail-watch-secondary--icon @(action.IsStub ? "tl-detail-watch-secondary--stub" : null)"
                                aria-label="@action.Label"
                                disabled="@action.IsDisabled"
                                @onclick="@(() => Select(action))">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                        </button>
                    </MudTooltip>
                </div>
            }
            else if (action.DisplayStyle == "premium")
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--premium">
                    <button type="button"
                            class="tl-detail-premium-action @(action.IsStub ? "tl-detail-premium-action--stub" : null)"
                            aria-label="@action.Label"
                            disabled="@action.IsDisabled"
                            title="@TooltipFor(action)"
                            @onclick="@(() => Select(action))">
                        <span class="tl-detail-premium-action__icons" aria-hidden="true">
                            <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Size="Size.Small" />
                            <MudIcon Icon="@Icons.Material.Outlined.Sync" Size="Size.Small" />
                            <MudIcon Icon="@Icons.Material.Outlined.Headphones" Size="Size.Small" />
                        </span>
                        <span class="tl-detail-premium-action__copy">
                            <span class="tl-detail-premium-action__label">@action.Label</span>
                            @if (!string.IsNullOrWhiteSpace(action.Subtitle))
                            {
                                <span class="tl-detail-premium-action__subtitle">@action.Subtitle</span>
                            }
                        </span>
                    </button>
                </div>
            }
            else if (action.Key == "reaction-menu")
            {
                <div class="tl-detail-secondary-action @(IsPrimaryHeroActionRow ? "tl-detail-secondary-action--watch" : null)">
                    <div class="tl-hover-action-menu tl-reaction-menu" tabindex="0" aria-label="@action.Label">
                        <button type="button"
                                class="tl-detail-watch-secondary tl-detail-watch-secondary--icon tl-detail-reaction-button"
                                aria-label="@action.Label">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                        </button>
                        <div class="tl-hover-action-menu__tray">
                            @foreach (var child in OrderedReactionChildren(action))
                            {
                                <MudTooltip Text="@TooltipFor(child)" Placement="Placement.Bottom">
                                    <button type="button"
                                            class="tl-detail-watch-secondary tl-detail-watch-secondary--icon tl-detail-reaction-button"
                                            aria-label="@child.Label"
                                            disabled="@child.IsDisabled"
                                            @onclick="@(() => Select(child))">
                                        <MudIcon Icon="@IconFor(child)" Size="Size.Small" />
                                    </button>
                                </MudTooltip>
                            }
                        </div>
                    </div>
                    @if (!IsPrimaryHeroActionRow)
                    {
                        <span>@SecondaryLabel(action)</span>
                    }
                </div>
            }
            else if (action.Key == "format-tools")
            {
                <div class="tl-detail-secondary-action">
                    <div class="tl-hover-action-menu tl-format-menu" tabindex="0" aria-label="@action.Label">
                        <button type="button" class="tl-detail-icon-action" aria-label="@action.Label">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                        </button>
                        <div class="tl-hover-action-menu__tray">
                            @foreach (var child in action.Children)
                            {
                                <MudTooltip Text="@TooltipFor(child)" Placement="Placement.Bottom">
                                    <button type="button"
                                            class="tl-detail-icon-action"
                                            aria-label="@child.Label"
                                            disabled="@child.IsDisabled"
                                            @onclick="@(() => Select(child))">
                                        <MudIcon Icon="@IconFor(child)" Size="Size.Small" />
                                    </button>
                                </MudTooltip>
                            }
                        </div>
                    </div>
                    <span>@SecondaryLabel(action)</span>
                </div>
            }
            else if (UsePrimaryHeroChrome && action.Key == "add-to-collection")
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--watch">
                    <MudTooltip Text="@TooltipFor(action)" Placement="Placement.Bottom">
                        <button type="button"
                                class="tl-detail-watch-secondary tl-detail-watch-secondary--icon @(action.IsStub ? "tl-detail-watch-secondary--stub" : null)"
                                aria-label="@action.Label"
                                disabled="@action.IsDisabled"
                                @onclick="@(() => Select(action))">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                        </button>
                    </MudTooltip>
                </div>
            }
            else if (action.DisplayStyle == "button")
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--button">
                    <button type="button"
                            class="tl-detail-action tl-detail-action--secondary-button @(action.IsStub ? "tl-detail-action--stub" : null)"
                            disabled="@action.IsDisabled"
                            title="@TooltipFor(action)"
                            @onclick="@(() => Select(action))">
                        <MudIcon Icon="@IconFor(action)" Size="Size.Medium" />
                        <span>@action.Label</span>
                    </button>
                </div>
            }
            else if (IsPrimaryHeroActionRow && action.Key == "watch-party")
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--watch">
                    <MudTooltip Text="@TooltipFor(action)" Placement="Placement.Bottom">
                        <button type="button"
                                class="tl-detail-watch-secondary tl-detail-watch-secondary--icon @(action.IsStub ? "tl-detail-watch-secondary--stub" : null)"
                                aria-label="@action.Label"
                                disabled="@action.IsDisabled"
                                @onclick="@(() => Select(action))">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                        </button>
                    </MudTooltip>
                </div>
            }
            else if (IsPrimaryHeroActionRow && action.Key == "add-to-collection")
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--watch">
                    <MudTooltip Text="@TooltipFor(action)" Placement="Placement.Bottom">
                        <button type="button"
                                class="tl-detail-watch-secondary"
                                aria-label="@action.Label"
                                disabled="@action.IsDisabled"
                                @onclick="@(() => Select(action))">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                            <span>@action.Label</span>
                        </button>
                    </MudTooltip>
                </div>
            }
            else
            {
                <div class="tl-detail-secondary-action">
                    <MudTooltip Text="@TooltipFor(action)" Placement="Placement.Bottom">
                        <button type="button"
                                class="tl-detail-icon-action @(action.IsStub ? "tl-detail-icon-action--stub" : null)"
                                aria-label="@action.Label"
                                disabled="@action.IsDisabled"
                                @onclick="@(() => Select(action))">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                        </button>
                    </MudTooltip>
                    <span>@SecondaryLabel(action)</span>
                </div>
            }
        }

        @if (!IsPrimaryHeroActionRow && OverflowActions.Count > 0)
        {
            <div class="tl-detail-secondary-action">
                <OverflowActionMenu Actions="OverflowActions" OnActionSelected="OnActionSelected" />
                <span>More</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<DetailAction> PrimaryActions { get; set; } = [];
    [Parameter] public IReadOnlyList<DetailAction> SecondaryActions { get; set; } = [];
    [Parameter] public IReadOnlyList<DetailAction> OverflowActions { get; set; } = [];
    [Parameter] public bool UsePrimaryHeroChrome { get; set; }
    [Parameter] public EventCallback<DetailAction> OnActionSelected { get; set; }

    private bool IsWatchActionRow => PrimaryActions.Any(action => action.Key == "watch");
    private bool IsPrimaryHeroActionRow => IsWatchActionRow || UsePrimaryHeroChrome;

    private Task Select(DetailAction action)
        => action.IsDisabled ? Task.CompletedTask : OnActionSelected.InvokeAsync(action);

    private static string TooltipFor(DetailAction action)
        => action.Tooltip ?? (action.IsStub ? $"{action.Label} (coming soon)" : action.Label);

    private static string PrimaryLabel(DetailAction action)
        => action.Label;

    private static string SecondaryLabel(DetailAction action) => action.Key switch
    {
        "add-to-collection" => action.Label,
        "reaction-menu" => "Rate",
        "watch-party" => "Party",
        "format-tools" => "Tools",
        _ => action.Label,
    };

    private static IEnumerable<DetailAction> OrderedReactionChildren(DetailAction action)
        => action.Children.OrderBy(child => child.Key switch
        {
            "reaction-dislike" => 0,
            "reaction-like" => 1,
            _ => 2,
        });

    public static string IconFor(DetailAction action) => action.Icon switch
    {
        "play_arrow" => Icons.Material.Filled.PlayArrow,
        "headphones" => Icons.Material.Outlined.Headphones,
        "menu_book" => Icons.Material.Outlined.MenuBook,
        "groups" => Icons.Material.Outlined.Groups,
        "shuffle" => Icons.Material.Outlined.Shuffle,
        "add" => Icons.Material.Outlined.Add,
        "playlist_add" => Icons.Material.Outlined.PlaylistAdd,
        "thumb_up" => Icons.Material.Outlined.ThumbUp,
        "thumb_down" => Icons.Material.Outlined.ThumbDown,
        "favorite" => Icons.Material.Outlined.FavoriteBorder,
        "check_circle" => Icons.Material.Outlined.CheckCircle,
        "link" => Icons.Material.Outlined.Link,
        "compare_arrows" => Icons.Material.Outlined.CompareArrows,
        "image" => Icons.Material.Outlined.Image,
        "sync" => Icons.Material.Outlined.Sync,
        "delete" => Icons.Material.Outlined.Delete,
        "edit" => Icons.Material.Outlined.Edit,
        "info" => Icons.Material.Outlined.Info,
        "account_tree" => Icons.Material.Outlined.AccountTree,
        "auto_stories" => Icons.Material.Outlined.AutoStories,
        "read_listen" => Icons.Material.Outlined.Sync,
        "settings" => Icons.Material.Outlined.Settings,
        _ => Icons.Material.Outlined.OpenInNew,
    };
}
