@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<div class="tl-detail-actions @(IsPrimaryHeroActionRow ? "tl-detail-actions--watch" : null)">
    <div class="tl-detail-primary-actions">
        @foreach (var action in PrimaryActions)
        {
            <AppNativeButton Type="button" Class='@($"tl-media-action tl-media-action--primary tl-detail-action tl-detail-action--primary tl-detail-action--{ActionKeyClass(action)}")' Disabled="@action.IsDisabled" Title="@TooltipFor(action)" OnClick="@(() => Select(action))" @attributes="AttributesFor(action)">
                <MudIcon Icon="@IconFor(action)" Size="Size.Medium" />
                <span>@PrimaryLabel(action)</span>
            </AppNativeButton>
        }
    </div>

    <div class="tl-detail-secondary-actions">
        @foreach (var action in VisibleSecondaryActions)
        {
            @if (UsePrimaryHeroChrome && action.Key == "read-listen")
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--watch">
                    <MudTooltip Text="@TooltipFor(action)" Placement="Placement.Bottom">
                        <AppNativeButton Type="button" Class='@($"tl-detail-watch-secondary tl-detail-watch-secondary--icon {ActionStateClass(action)} {(action.IsStub ? " tl-detail-watch-secondary--stub" : null)}")' AriaLabel="@action.Label" Disabled="@action.IsDisabled" OnClick="@(() => Select(action))">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                        </AppNativeButton>
                    </MudTooltip>
                </div>
            }
            else if (action.DisplayStyle == "premium")
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--premium">
                    <AppNativeButton Type="button" Class='@($"tl-detail-premium-action {ActionStateClass(action)} {(action.IsStub ? " tl-detail-premium-action--stub" : null)}")' AriaLabel="@action.Label" Disabled="@action.IsDisabled" Title="@TooltipFor(action)" OnClick="@(() => Select(action))">
                        <span class="tl-detail-premium-action__icons" aria-hidden="true">
                            <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Size="Size.Small" />
                            <MudIcon Icon="@Icons.Material.Outlined.Sync" Size="Size.Small" />
                            <MudIcon Icon="@Icons.Material.Outlined.Headphones" Size="Size.Small" />
                        </span>
                        <span class="tl-detail-premium-action__copy">
                            <span class="tl-detail-premium-action__label">@action.Label</span>
                            @if (!string.IsNullOrWhiteSpace(action.Subtitle))
                            {
                                <span class="tl-detail-premium-action__subtitle">@action.Subtitle</span>
                            }
                        </span>
                    </AppNativeButton>
                </div>
            }
            else if (action.Key == "reaction-menu")
            {
                <div class="tl-detail-secondary-action @(IsPrimaryHeroActionRow ? "tl-detail-secondary-action--watch" : null)">
                    <div class="tl-hover-action-menu tl-reaction-menu" tabindex="0" aria-label="@action.Label">
                        <AppNativeButton Type="button" Class="tl-media-action tl-media-action--flat tl-detail-flat-action tl-detail-reaction-button" AriaLabel="@action.Label">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                            <span>@SecondaryLabel(action)</span>
                        </AppNativeButton>
                        <div class="tl-hover-action-menu__tray">
                            @foreach (var child in OrderedReactionChildren(action))
                            {
                                <MudTooltip Text="@TooltipFor(child)" Placement="Placement.Bottom">
                                    <AppNativeButton Type="button" Class='@($"tl-detail-reaction-choice {ReactionStateClass(child)}")' AriaLabel="@child.Label" Disabled="@child.IsDisabled" OnClick="@(() => SelectReaction(child))">
                                        <MudIcon Icon="@IconFor(child)" Size="Size.Small" />
                                    </AppNativeButton>
                                </MudTooltip>
                            }
                        </div>
                    </div>
                    @if (!IsPrimaryHeroActionRow)
                    {
                        <span>@SecondaryLabel(action)</span>
                    }
                </div>
            }
            else if (action.Key == "format-tools")
            {
                <div class="tl-detail-secondary-action">
                    <div class="tl-hover-action-menu tl-format-menu" tabindex="0" aria-label="@action.Label">
                        <AppNativeButton Type="button" Class="tl-detail-icon-action" AriaLabel="@action.Label">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                        </AppNativeButton>
                        <div class="tl-hover-action-menu__tray">
                            @foreach (var child in action.Children)
                            {
                                <MudTooltip Text="@TooltipFor(child)" Placement="Placement.Bottom">
                                    <AppNativeButton Type="button" Class="tl-detail-icon-action" AriaLabel="@child.Label" Disabled="@child.IsDisabled" OnClick="@(() => Select(child))">
                                        <MudIcon Icon="@IconFor(child)" Size="Size.Small" />
                                    </AppNativeButton>
                                </MudTooltip>
                            }
                        </div>
                    </div>
                    <span>@SecondaryLabel(action)</span>
                </div>
            }
            else if (UsePrimaryHeroChrome && action.Key == "add-to-collection")
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--watch">
                    <MudTooltip Text="@TooltipFor(action)" Placement="Placement.Bottom">
                        <AppNativeButton Type="button" Class='@($"tl-media-action tl-media-action--flat tl-detail-flat-action {ActionStateClass(action)} {(action.IsStub ? " tl-detail-flat-action--stub" : null)}")' AriaLabel="@action.Label" Disabled="@action.IsDisabled" OnClick="@(() => Select(action))">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                            <span>@SecondaryLabel(action)</span>
                        </AppNativeButton>
                    </MudTooltip>
                </div>
            }
            else if (action.DisplayStyle == "button")
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--button">
                    <AppNativeButton Type="button" Class='@($"tl-detail-action tl-detail-action--secondary-button {ActionStateClass(action)} {(action.IsStub ? " tl-detail-action--stub" : null)}")' Disabled="@action.IsDisabled" Title="@TooltipFor(action)" OnClick="@(() => Select(action))">
                        <MudIcon Icon="@IconFor(action)" Size="Size.Medium" />
                        <span>@action.Label</span>
                    </AppNativeButton>
                </div>
            }
            else if (IsPrimaryHeroActionRow)
            {
                <div class="tl-detail-secondary-action tl-detail-secondary-action--watch">
                    <MudTooltip Text="@TooltipFor(action)" Placement="Placement.Bottom">
                        <AppNativeButton Type="button" Class='@($"tl-media-action tl-media-action--flat tl-detail-flat-action {ActionStateClass(action)} {(action.IsStub ? " tl-detail-flat-action--stub" : null)}")' AriaLabel="@action.Label" Disabled="@action.IsDisabled" OnClick="@(() => Select(action))">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                            <span>@SecondaryLabel(action)</span>
                        </AppNativeButton>
                    </MudTooltip>
                </div>
            }
            else
            {
                <div class="tl-detail-secondary-action">
                    <MudTooltip Text="@TooltipFor(action)" Placement="Placement.Bottom">
                        <AppNativeButton Type="button" Class='@($"tl-detail-icon-action {ActionStateClass(action)} {(action.IsStub ? " tl-detail-icon-action--stub" : null)}")' AriaLabel="@action.Label" Disabled="@action.IsDisabled" OnClick="@(() => Select(action))">
                            <MudIcon Icon="@IconFor(action)" Size="Size.Small" />
                        </AppNativeButton>
                    </MudTooltip>
                    <span>@SecondaryLabel(action)</span>
                </div>
            }
        }

        @if (IsPrimaryHeroActionRow && OverflowMenuActions.Count > 0)
        {
            <div class="tl-detail-secondary-action tl-detail-secondary-action--watch">
                <OverflowActionMenu Actions="OverflowMenuActions"
                                    ButtonClass="tl-detail-watch-secondary tl-detail-watch-secondary--icon"
                                    OnActionSelected="OnActionSelected" />
            </div>
        }
        else if (!IsPrimaryHeroActionRow && OverflowMenuActions.Count > 0)
        {
            <div class="tl-detail-secondary-action">
                <OverflowActionMenu Actions="OverflowMenuActions" OnActionSelected="OnActionSelected" />
                <span>More</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<DetailAction> PrimaryActions { get; set; } = [];
    [Parameter] public IReadOnlyList<DetailAction> SecondaryActions { get; set; } = [];
    [Parameter] public IReadOnlyList<DetailAction> OverflowActions { get; set; } = [];
    [Parameter] public DetailAction? InlineEditAction { get; set; }
    [Parameter] public bool UsePrimaryHeroChrome { get; set; }
    [Parameter] public EventCallback<DetailAction> OnActionSelected { get; set; }
    [Parameter] public Func<DetailAction, IReadOnlyDictionary<string, object>?>? ActionAttributes { get; set; }

    private bool IsWatchActionRow => PrimaryActions.Any(action => action.Key == "watch");
    private bool IsPrimaryHeroActionRow => IsWatchActionRow || UsePrimaryHeroChrome;
    private IReadOnlyList<DetailAction> VisibleSecondaryActions
        => (InlineEditAction is null ? SecondaryActions : SecondaryActions.Concat([InlineEditAction]))
            .DistinctBy(action => action.Key, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private IReadOnlyList<DetailAction> OverflowMenuActions => OverflowActions;

    private Task Select(DetailAction action)
        => action.IsDisabled ? Task.CompletedTask : OnActionSelected.InvokeAsync(action);

    private string? _selectedReactionKey;

    private async Task SelectReaction(DetailAction action)
    {
        if (action.IsDisabled)
            return;

        _selectedReactionKey = action.Key;
        await OnActionSelected.InvokeAsync(action);
    }

    private IReadOnlyDictionary<string, object>? AttributesFor(DetailAction action) =>
        ActionAttributes?.Invoke(action);

    private static string TooltipFor(DetailAction action)
        => action.Tooltip ?? (action.IsStub ? $"{action.Label} (coming soon)" : action.Label);

    private static string PrimaryLabel(DetailAction action)
        => action.Label;

    private static string SecondaryLabel(DetailAction action) => action.Key switch
    {
        "add-to-collection" => action.Label,
        "reaction-menu" => "Rate",
        "format-tools" => "Tools",
        _ => action.Label,
    };

    private static string ActionStateClass(DetailAction action)
        => action.IsSelected ? "is-selected" : string.Empty;

    private string ReactionStateClass(DetailAction action)
        => string.Equals(_selectedReactionKey, action.Key, StringComparison.OrdinalIgnoreCase) ? "is-selected" : string.Empty;

    private static string ActionKeyClass(DetailAction action)
        => new string(action.Key.Select(character => char.IsLetterOrDigit(character) ? char.ToLowerInvariant(character) : '-').ToArray()).Trim('-');

    private static IEnumerable<DetailAction> OrderedReactionChildren(DetailAction action)
        => action.Children.OrderBy(child => child.Key switch
        {
            "reaction-dislike" => 0,
            "reaction-like" => 1,
            _ => 2,
        });

    public static string IconFor(DetailAction action) => action.Icon switch
    {
        "play_arrow" => Icons.Material.Filled.PlayArrow,
        "restart_alt" => Icons.Material.Outlined.RestartAlt,
        "headphones" => Icons.Material.Outlined.Headphones,
        "menu_book" => Icons.Material.Outlined.MenuBook,
        "groups" => Icons.Material.Outlined.Groups,
        "shuffle" => Icons.Material.Outlined.Shuffle,
        "add" => Icons.Material.Outlined.Add,
        "playlist_add" => Icons.Material.Outlined.PlaylistAdd,
        "thumb_up" => Icons.Material.Outlined.ThumbUp,
        "thumb_down" => Icons.Material.Outlined.ThumbDown,
        "favorite" when action.IsSelected => Icons.Material.Filled.Favorite,
        "favorite_filled" => Icons.Material.Filled.Favorite,
        "favorite" => Icons.Material.Outlined.FavoriteBorder,
        "playlist_add_check" => Icons.Material.Filled.PlaylistAddCheck,
        "check_circle" => Icons.Material.Outlined.CheckCircle,
        "link" => Icons.Material.Outlined.Link,
        "compare_arrows" => Icons.Material.Outlined.CompareArrows,
        "image" => Icons.Material.Outlined.Image,
        "sync" => Icons.Material.Outlined.Sync,
        "delete" => Icons.Material.Outlined.Delete,
        "edit" => Icons.Material.Outlined.Edit,
        "info" => Icons.Material.Outlined.Info,
        "arrow_back" => Icons.Material.Outlined.ArrowBack,
        "account_tree" => Icons.Material.Outlined.AccountTree,
        "auto_stories" => Icons.Material.Outlined.AutoStories,
        "read_listen" => Icons.Material.Outlined.Sync,
        "settings" => Icons.Material.Outlined.Settings,
        _ => Icons.Material.Outlined.OpenInNew,
    };
}
