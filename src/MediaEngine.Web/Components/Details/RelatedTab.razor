@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<section class="tl-detail-tab-panel tl-related-tab" aria-labelledby="related-tab-title">
    <header class="tl-related-tab__header">
        <span>Related</span>
        <h2 id="related-tab-title">More from your library</h2>
    </header>

    @if (RelatedItems.Count == 0)
    {
        <p class="tl-related-tab__empty">No related library items are available yet.</p>
    }
    else
    {
        <div class="tl-related-tab__grid">
            @foreach (var item in RelatedItems)
            {
                <a class="@ItemClass(item)" href="@ResolveRoute(item)">
                    <span class="tl-related-tab__art">
                        @if (!string.IsNullOrWhiteSpace(item.ArtworkUrl))
                        {
                            <img src="@item.ArtworkUrl" alt="" />
                        }
                        else
                        {
                            <GeneratedIdentity Name="@item.Title" />
                        }
                    </span>
                    <strong>@item.Title</strong>
                    @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                    {
                        <small>@item.Subtitle</small>
                    }
                </a>
            }
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public DetailPageViewModel Model { get; set; } = default!;

    private IReadOnlyList<MediaGroupingItemViewModel> RelatedItems =>
        Model.MediaGroups
            .Where(IsRecommendationGroup)
            .SelectMany(group => group.Items)
            .Where(item => !string.Equals(item.Id, Model.Id, StringComparison.OrdinalIgnoreCase))
            .Where(IsRecommendationCandidate)
            .GroupBy(item => $"{item.EntityType}:{item.Id}", StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .Take(24)
            .ToList();

    private static bool IsRecommendationGroup(MediaGroupingViewModel group)
    {
        var key = group.Key ?? string.Empty;
        var title = group.Title ?? string.Empty;
        return key.Equals("related", StringComparison.OrdinalIgnoreCase)
            || key.Equals("recommendations", StringComparison.OrdinalIgnoreCase)
            || key.Equals("more-like-this", StringComparison.OrdinalIgnoreCase)
            || title.Contains("more like", StringComparison.OrdinalIgnoreCase)
            || title.Contains("recommend", StringComparison.OrdinalIgnoreCase)
            || title.Contains("similar", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsRecommendationCandidate(MediaGroupingItemViewModel item)
        => item.EntityType is not DetailEntityType.TvEpisode
           && !item.Actions.Any(action =>
               action.Route?.Contains("/episode/", StringComparison.OrdinalIgnoreCase) == true
               || action.Route?.Contains("/tvepisode/", StringComparison.OrdinalIgnoreCase) == true);

    private static string ResolveRoute(MediaGroupingItemViewModel item)
        => item.Actions.FirstOrDefault(action => !string.IsNullOrWhiteSpace(action.Route))?.Route
           ?? $"/details/{item.EntityType.ToString().ToLowerInvariant()}/{item.Id}";

    private static string ItemClass(MediaGroupingItemViewModel item)
        => $"tl-related-tab__item tl-related-tab__item--{ArtworkShape(item.EntityType)}";

    private static string ArtworkShape(DetailEntityType entityType) => entityType switch
    {
        DetailEntityType.MusicAlbum or DetailEntityType.MusicTrack => "square",
        DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "wide",
        _ => "portrait",
    };
}
