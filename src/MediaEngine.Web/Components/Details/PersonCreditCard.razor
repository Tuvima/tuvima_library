@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

@if (!string.IsNullOrWhiteSpace(Route))
{
    <a class="tl-credit-card tl-credit-card--link" href="@Route">
        @CreditContent
    </a>
}
else
{
    <article class="tl-credit-card">
        @CreditContent
    </article>
}

@code {
    [Parameter, EditorRequired] public EntityCreditViewModel Credit { get; set; } = default!;

    private RenderFragment CreditContent => @<text>
        <div class="tl-credit-card__image">
            @if (!string.IsNullOrWhiteSpace(Credit.ImageUrl))
            {
                <img src="@Credit.ImageUrl" alt="@Credit.DisplayName" />
            }
            else
            {
                <GeneratedIdentity Name="@Credit.DisplayName" />
            }
        </div>
        <div class="tl-credit-card__body">
            <div class="tl-credit-card__name">@Credit.DisplayName</div>
            <div class="tl-credit-card__role">@Credit.PrimaryRole</div>
            @if (!string.IsNullOrWhiteSpace(Credit.CharacterName))
            {
                <div class="tl-credit-card__role">as @Credit.CharacterName</div>
            }
        </div>
    </text>;

    private string? Route
    {
        get
        {
            if (!Guid.TryParse(Credit.EntityId, out var id))
                return null;

            return Credit.EntityType switch
            {
                RelatedEntityType.Person => $"/person/{id:D}",
                RelatedEntityType.Character => $"/details/character/{id:D}?context=universe",
                RelatedEntityType.MusicArtist => $"/details/musicartist/{id:D}?context=listen",
                RelatedEntityType.Universe => $"/details/universe/{id:D}?context=universe",
                RelatedEntityType.Series => $"/details/bookseries/{id:D}?context=read",
                _ => null,
            };
        }
    }
}
