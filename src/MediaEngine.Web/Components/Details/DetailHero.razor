@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<section class="tl-detail-hero @Presentation.HeroClass" style="@Presentation.GradientStyle">
    <HeroBackdrop Artwork="Model.Artwork" EntityType="Model.EntityType" HeroBrand="Model.HeroBrand" />
    @if (Presentation.ShowTitleBar)
    {
        <div class="tl-detail-titlebar">
            <div class="tl-detail-titlebar__title">@Model.Title</div>
        </div>
    }
    <div class="tl-detail-hero__inner">
        <div class="tl-detail-hero__copy">
            @if (!string.IsNullOrWhiteSpace(Presentation.Eyebrow))
            {
                <div class="tl-detail-hero__eyebrow">@Presentation.Eyebrow</div>
            }

            @if (Presentation.UseLogo)
            {
                <img class="tl-detail-hero__logo" src="@Presentation.LogoUrl" alt="@Presentation.Title" />
            }
            else
            {
                <h1>@Presentation.Title</h1>
            }

            @if (!string.IsNullOrWhiteSpace(Presentation.Subtitle))
            {
                <p class="tl-detail-hero__subtitle">@Presentation.Subtitle</p>
            }

            <HeroMetadataPills Metadata="Model.Metadata"
                               EntityType="Model.EntityType"
                               IdentityStatus="Model.IdentityStatus"
                               IsWatchHero="Presentation.IsWatchHero"
                               UsePrimaryHeroChrome="Presentation.UsePrimaryHeroChrome"
                               IsAdminView="Model.IsAdminView" />

            @if (Presentation.CapabilityPills.Count > 0)
            {
                <div class="tl-detail-capability-row" aria-label="Availability">
                    @foreach (var pill in Presentation.CapabilityPills)
                    {
                        <span class="tl-detail-capability-pill">@pill.Label</span>
                    }
                </div>
            }

            <HeroActionRow PrimaryActions="Model.PrimaryActions"
                           SecondaryActions="Model.SecondaryActions"
                           OverflowActions="Model.OverflowActions"
                           UsePrimaryHeroChrome="Presentation.UsePrimaryHeroChrome"
                           OnActionSelected="OnActionSelected" />

            <HeroProgressBlock Progress="Presentation.Progress" />

            @if (!string.IsNullOrWhiteSpace(Presentation.HeroCopy))
            {
                <p class="tl-detail-hero__tagline">@Presentation.HeroCopy</p>
            }

            <HeroGenreChips Metadata="Model.Metadata" />
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public DetailPageViewModel Model { get; set; } = default!;
    [Parameter] public EventCallback<DetailAction> OnActionSelected { get; set; }

    private DetailHeroPresentation Presentation => DetailHeroPresentation.From(Model);
}
