@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details
@using MediaEngine.Web.Components.Shared

<CinematicHeroSurface Artwork="Model.Artwork"
                      EntityType="Model.EntityType"
                      HeroBrand="Model.HeroBrand"
                      Title="Model.Title"
                      ShowTitleBar="Presentation.ShowTitleBar"
                      Class="@($"cinematic-hero-surface--detail {Presentation.HeroClass} {TitleDensityClass}")"
                      Css="Presentation.GradientStyle">
    @if (Model.EntityType == DetailEntityType.Person && Model.PersonDetails is not null)
    {
        <div class="tl-detail-hero__inner tl-detail-person-hero__inner">
            <div class="tl-detail-hero__copy tl-detail-person-hero__copy">
                @if (!string.IsNullOrWhiteSpace(PersonEyebrow))
                {
                    <div class="tl-detail-hero__eyebrow">@PersonEyebrow</div>
                }

                <h1>@Presentation.Title</h1>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="tl-detail-person-summary">
                        <p>@Model.Description</p>
                    </div>
                }

                @if (PersonHeroFacts.Count > 0)
                {
                    <div class="tl-detail-person-fact-row">
                        @foreach (var fact in PersonHeroFacts)
                        {
                            <span class="tl-detail-person-fact">
                                <MudIcon Icon="@fact.Icon" Size="Size.Small" />
                                <span>@fact.Label</span>
                            </span>
                        }
                    </div>
                }

                @if (Model.PersonDetails.ExternalLinks.Count > 0)
                {
                    <div class="tl-detail-person-links" aria-label="External links">
                        @foreach (var link in Model.PersonDetails.ExternalLinks)
                        {
                            <a class="tl-detail-person-link"
                               href="@link.Url"
                               target="_blank"
                               rel="noopener noreferrer"
                               title="@link.Label"
                               aria-label="@link.Label">
                                <AppIcon Name="@PersonExternalIcon(link)"
                                         Size="1.08rem"
                                         Title="@link.Label"
                                         Decorative="false" />
                                <span>@link.Label</span>
                            </a>
                        }
                    </div>
                }
            </div>
            <div class="tl-detail-person-portrait" aria-label="@Model.Title portrait">
                @if (!string.IsNullOrWhiteSpace(Model.Artwork.PortraitUrl))
                {
                    <img src="@Model.Artwork.PortraitUrl" alt="@Model.Title" />
                }
                else
                {
                    <GeneratedIdentity Name="@Model.Title" />
                }
            </div>
        </div>
    }
    else
    {
        <div class="tl-detail-hero__inner">
            <div class="tl-detail-hero__copy">
            <div class="tl-detail-hero__identity">
            @if (!(Presentation.IsWatchHero && HasHeroBrand) && !string.IsNullOrWhiteSpace(Presentation.Eyebrow))
            {
                <div class="tl-detail-hero__eyebrow">@Presentation.Eyebrow</div>
            }

            <p class="@SeriesContextClass" aria-hidden="@(SeriesContextLabel is null)">
                <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Size="Size.Small" />
                <span>@SeriesContextLabel</span>
            </p>

            @if (Presentation.UseLogo)
            {
                <img class="tl-detail-hero__logo" src="@Presentation.LogoUrl" alt="@Presentation.Title" />
            }
            else
            {
                <h1>@Presentation.Title</h1>
            }

            @if (HeroCreditLines.Count > 0)
            {
                <div class="@HeroCreditStackClass" aria-label="Primary credits">
                    @foreach (var line in HeroCreditLines)
                    {
                        <div class="tl-detail-hero-credit-stack__line">
                            <span class="tl-detail-hero-credit-stack__label">@line.Label</span>
                            <span class="tl-detail-hero-credit-stack__value">@line.Value</span>
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Presentation.Subtitle))
            {
                <p class="tl-detail-hero__subtitle">@Presentation.Subtitle</p>
            }
            </div>

            <HeroMetadataPills Metadata="Model.Metadata"
                               EntityType="Model.EntityType"
                               IdentityStatus="Model.IdentityStatus"
                               IsWatchHero="Presentation.IsWatchHero"
                               UsePrimaryHeroChrome="Presentation.UsePrimaryHeroChrome"
                               HeroBrand="Model.HeroBrand"
                               RenderHeroBrandInMetadata="false"
                               IsAdminView="Model.IsAdminView" />

            @if (Presentation.CapabilityPills.Count > 0)
            {
                <div class="tl-detail-capability-row" aria-label="Availability">
                    @foreach (var pill in Presentation.CapabilityPills)
                    {
                        <span class="tl-detail-capability-pill">@pill.Label</span>
                    }
                </div>
            }

            <HeroActionRow PrimaryActions="Model.PrimaryActions"
                           SecondaryActions="Model.SecondaryActions"
                           OverflowActions="Model.OverflowActions"
                           InlineEditAction="InlineEditAction"
                           UsePrimaryHeroChrome="Presentation.UsePrimaryHeroChrome"
                           ActionAttributes="ActionAttributes"
                           OnActionSelected="OnActionSelected" />

            <HeroProgressBlock Progress="Presentation.Progress" />

            @if (!string.IsNullOrWhiteSpace(Presentation.HeroCopy))
            {
                <div class="tl-detail-hero__synopsis">
                    @if (!string.IsNullOrWhiteSpace(WatchEpisodeHeading))
                    {
                        <h2>@WatchEpisodeHeading</h2>
                    }
                    <p class="@HeroSummaryClass"
                       data-ai-summary-slot="tldr"
                       aria-live="polite">@Presentation.HeroCopy</p>
                    @if (Presentation.HeroCopyHasMore)
                    {
                        <a class="tl-detail-hero__overview-link"
                           href="#overview"
                           @onclick="OpenOverviewAsync"
                           @onclick:preventDefault="true">(more in overview)</a>
                    }
                </div>
            }

            </div>
        </div>
    }
</CinematicHeroSurface>

@code {
    [Parameter, EditorRequired] public DetailPageViewModel Model { get; set; } = default!;
    [Parameter] public EventCallback<DetailAction> OnActionSelected { get; set; }
    [Parameter] public EventCallback<string> OnTabRequested { get; set; }
    [Parameter] public Func<DetailAction, IReadOnlyDictionary<string, object>?>? ActionAttributes { get; set; }

    private DetailHeroPresentation Presentation => DetailHeroPresentation.From(Model);
    private string? SeriesContextLabel => BuildSeriesContextLabel(Model.EntityType, Model.SequencePlacement);
    private string? WatchEpisodeHeading => BuildWatchEpisodeHeading();
    private string SeriesContextClass => $"tl-detail-hero__series-context{(SeriesContextLabel is null ? " is-empty" : string.Empty)}";
    private string HeroSummaryClass => $"tl-detail-hero__tagline tl-detail-hero__tagline--ai{(string.IsNullOrWhiteSpace(Presentation.HeroCopy) ? " is-empty" : string.Empty)}";
    private string TitleDensityClass => ResolveTitleDensityClass(Presentation.Title, Presentation.UseLogo);
    private IReadOnlyList<(string Label, string Value)> HeroCreditLines => BuildHeroCreditLines();
    private string HeroCreditStackClass => Model.EntityType == DetailEntityType.Audiobook
        ? "tl-detail-hero-credit-stack tl-detail-hero-credit-stack--audiobook"
        : "tl-detail-hero-credit-stack";
    private bool HasHeroBrand => Model.HeroBrand is not null
        && (!string.IsNullOrWhiteSpace(Model.HeroBrand.ImageUrl) || !string.IsNullOrWhiteSpace(Model.HeroBrand.Label));
    private bool CanInlineEdit => Model.EntityType is DetailEntityType.Work
        or DetailEntityType.Movie
        or DetailEntityType.MovieSeries
        or DetailEntityType.TvShow
        or DetailEntityType.TvSeason
        or DetailEntityType.TvEpisode
        or DetailEntityType.Book
        or DetailEntityType.BookSeries
        or DetailEntityType.Audiobook
        or DetailEntityType.ComicIssue
        or DetailEntityType.ComicSeries
        or DetailEntityType.MusicAlbum
        or DetailEntityType.MusicArtist
        or DetailEntityType.MusicTrack
        or DetailEntityType.Collection;
    private DetailAction? InlineEditAction => CanInlineEdit
        ? new DetailAction
        {
            Key = "edit-media",
            Label = "Edit",
            Icon = "edit",
            Tooltip = "Edit",
        }
        : null;

    private string? EpisodePositionFromWatchAction()
    {
        var label = Model.PrimaryActions
            .FirstOrDefault(action => string.Equals(action.Key, "watch", StringComparison.OrdinalIgnoreCase))
            ?.Label;
        if (string.IsNullOrWhiteSpace(label))
            return null;

        var parts = label.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        for (var index = 0; index < parts.Length - 1; index++)
        {
            if (parts[index].StartsWith('S')
                && parts[index].Length > 1
                && parts[index][1..].All(char.IsDigit)
                && parts[index + 1].StartsWith('E')
                && parts[index + 1].Length > 1
                && parts[index + 1][1..].All(char.IsDigit))
            {
                return $"{parts[index]} {parts[index + 1]}";
            }
        }

        return null;
    }

    private string? BuildWatchEpisodeHeading()
    {
        if (Model.EntityType is not (DetailEntityType.TvShow or DetailEntityType.TvEpisode))
            return null;

        var position = EpisodePositionFromWatchAction();
        if (string.IsNullOrWhiteSpace(position))
            return null;

        var episodeTitle = Model.SequencePlacement?.CurrentItem.Title;
        return string.IsNullOrWhiteSpace(episodeTitle)
            ? position
            : $"{position}: {episodeTitle.Trim()}";
    }

    private Task OpenOverviewAsync() => OnTabRequested.InvokeAsync("overview");

    private string? PersonEyebrow => FirstNonBlank(PersonRoleLabel, Model.PersonDetails?.Occupation);

    private string? PersonRoleLabel => Model.PersonDetails?.Roles.Count > 0
        ? string.Join(" / ", Model.PersonDetails.Roles.Take(3))
        : null;

    private IReadOnlyList<(string Icon, string Label)> PersonHeroFacts
    {
        get
        {
            var details = Model.PersonDetails;
            if (details is null)
                return [];

            var facts = new List<(string Icon, string Label)>();
            var birth = FormatBirthFact(details.DateOfBirth, details.DateOfDeath);
            if (!string.IsNullOrWhiteSpace(birth))
                facts.Add((Icons.Material.Outlined.CalendarMonth, birth));
            if (!string.IsNullOrWhiteSpace(details.PlaceOfBirth))
                facts.Add((Icons.Material.Outlined.Place, details.PlaceOfBirth!));
            if (Model.MediaGroups.Sum(group => group.Items.Count) > 0)
                facts.Add((Icons.Material.Outlined.VideoLibrary, $"{Model.MediaGroups.Sum(group => group.Items.Count)} titles in library"));
            return facts;
        }
    }

    private static string? FormatBirthFact(string? born, string? died)
    {
        if (string.IsNullOrWhiteSpace(born) && string.IsNullOrWhiteSpace(died))
            return null;
        if (string.IsNullOrWhiteSpace(died))
            return FormatDateLabel(born);
        return $"{FormatDateLabel(born)} - {FormatDateLabel(died)}";
    }

    private static string? FormatDateLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;
        return DateTimeOffset.TryParse(value, out var parsed)
            ? parsed.ToString("MMM d, yyyy", System.Globalization.CultureInfo.InvariantCulture)
            : value;
    }

    private static string? BuildSeriesContextLabel(DetailEntityType entityType, SequencePlacementViewModel? placement)
    {
        if (entityType is DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode
            || placement is null
            || string.IsNullOrWhiteSpace(placement.ContainerTitle))
        {
            return null;
        }

        var containerTitle = placement.ContainerTitle.Trim();

        var position = FirstNonBlank(
            placement.PositionText,
            placement.CurrentItem.PositionText,
            placement.PositionLabel,
            placement.CurrentItem.PositionLabel,
            placement.PositionNumber?.ToString(),
            placement.CurrentItem.PositionNumber?.ToString());
        if (string.IsNullOrWhiteSpace(position))
            return containerTitle;

        var itemLabel = FirstNonBlank(placement.ItemLabel, "Item")!;
        var positionedItem = position.StartsWith(itemLabel, StringComparison.OrdinalIgnoreCase)
            ? position
            : $"{itemLabel} {position}";
        return $"{containerTitle} · {positionedItem}";
    }

    private static string? FirstNonBlank(params string?[] values)
        => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private static string ResolveTitleDensityClass(string title, bool useLogo)
    {
        if (useLogo || string.IsNullOrWhiteSpace(title))
            return string.Empty;

        var words = title.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var normalizedLength = title.Count(character => !char.IsWhiteSpace(character));
        var longestWordLength = words.Length == 0 ? 0 : words.Max(word => word.Trim(' ', '-', ':', ';', ',', '.', '\'').Length);

        if (normalizedLength >= 42 || words.Length >= 8 || longestWordLength >= 14)
            return "tl-detail-hero--title-dense";

        if (normalizedLength >= 30 || words.Length >= 5 || longestWordLength >= 11)
            return "tl-detail-hero--title-long";

        return string.Empty;
    }

    private IReadOnlyList<(string Label, string Value)> BuildHeroCreditLines()
    {
        var lines = new List<(string Label, string Value)>();
        switch (Model.EntityType)
        {
            case DetailEntityType.Book:
            case DetailEntityType.Work:
                AddCreditLine(lines, "Author", CreditGroupType.Authors);
                break;
            case DetailEntityType.Audiobook:
                AddCreditLine(lines, "Author", CreditGroupType.Authors);
                AddCreditLine(lines, "Narrator", CreditGroupType.Narrators);
                break;
            case DetailEntityType.ComicIssue:
            case DetailEntityType.ComicSeries:
                AddCreditLine(lines, "Author", CreditGroupType.Authors, CreditGroupType.Writers);
                AddCreditLine(lines, "Illustrator", CreditGroupType.Illustrators, CreditGroupType.CreativeTeam);
                break;
            case DetailEntityType.MusicAlbum:
                AddCreditLine(lines, "Artist", CreditGroupType.PrimaryArtists);
                AddCreditLine(lines, "Featuring", CreditGroupType.FeaturedArtists);
                break;
            case DetailEntityType.MusicTrack:
                AddCreditLine(lines, "Artist", CreditGroupType.PrimaryArtists);
                if (!string.IsNullOrWhiteSpace(Model.Subtitle))
                    lines.Add(("Album", Model.Subtitle!));
                break;
        }

        return lines
            .Where(line => !string.IsNullOrWhiteSpace(line.Value))
            .DistinctBy(line => $"{line.Label}:{line.Value}", StringComparer.OrdinalIgnoreCase)
            .Take(3)
            .ToList();
    }

    private void AddCreditLine(List<(string Label, string Value)> lines, string label, params CreditGroupType[] groupTypes)
    {
        var value = CreditNames(groupTypes);
        if (!string.IsNullOrWhiteSpace(value))
            lines.Add((label, value));
    }

    private string? CreditNames(params CreditGroupType[] groupTypes)
    {
        var names = Model.ContributorGroups
            .Where(group => groupTypes.Contains(group.GroupType))
            .SelectMany(group => group.Credits)
            .OrderBy(credit => credit.SortOrder)
            .Select(credit => credit.DisplayName)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(3)
            .ToList();

        return names.Count == 0 ? null : string.Join(", ", names);
    }

    private static string PersonExternalIcon(PersonExternalLink link) =>
        link.Key.ToLowerInvariant() switch
        {
            "instagram" => "fab:instagram",
            "twitter" => "fab:x-twitter",
            "x" => "fab:x-twitter",
            "tiktok" => "fab:tiktok",
            "mastodon" => "fab:mastodon",
            "wikidata" => "fab:wikipedia-w",
            "wikipedia" => "fab:wikipedia-w",
            "imdb" => "fab:imdb",
            "website" => "fa:globe",
            _ => "fa:up-right-from-square",
        };

    private static IReadOnlyList<string> PersonParagraphs(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return [];

        var normalized = value
            .Replace("\\r\\n", "\n", StringComparison.Ordinal)
            .Replace("\\n", "\n", StringComparison.Ordinal)
            .Replace("\r\n", "\n", StringComparison.Ordinal)
            .Replace('\r', '\n')
            .Replace("<br />", "\n", StringComparison.OrdinalIgnoreCase)
            .Replace("<br/>", "\n", StringComparison.OrdinalIgnoreCase)
            .Replace("<br>", "\n", StringComparison.OrdinalIgnoreCase);

        return normalized
            .Split(["\n\n"], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(paragraph => string.Join('\n',
                paragraph.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)))
            .Where(paragraph => !string.IsNullOrWhiteSpace(paragraph))
            .ToList();
    }
}
