@namespace MediaEngine.Web.Components.Details
@using System.Globalization
@using MediaEngine.Contracts.Details

@if (Progress is not null)
{
    <AppCssElement Tag="div" Class="tl-detail-hero-progress" Css="@ProgressStyle" aria-label="@ProgressLabel">
        @if (HasStructuredProgress)
        {
            <div class="tl-detail-hero-progress__summary">
                <span class="tl-detail-hero-progress__context">
                    <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Size="Size.Small" />
                    <span>@Progress!.ContextLabel</span>
                </span>
                <span class="tl-detail-hero-progress__percent">@Progress.PercentLabel</span>
            </div>
        }
        else
        {
            <div class="tl-detail-hero-progress__label">@ProgressLabel</div>
        }
        <div class="tl-detail-hero-progress__track" role="progressbar"
             aria-valuemin="0"
             aria-valuemax="100"
             aria-valuenow="@ProgressPercent">
            <span class="tl-detail-hero-progress__fill"></span>
        </div>
        @if (HasStructuredProgress)
        {
            <div class="tl-detail-hero-progress__meta">
                <span>@Progress!.RemainingLabel</span>
                <span>@Progress.SecondaryLabel</span>
            </div>
        }
    </AppCssElement>
}

@code {
    [Parameter] public ProgressViewModel? Progress { get; set; }

    private int ProgressPercent => Progress is null
        ? 0
        : Math.Clamp((int)Math.Round(Progress.Percent, MidpointRounding.AwayFromZero), 0, 100);

    private string ProgressStyle
        => $"--hero-progress:{ProgressPercent.ToString(CultureInfo.InvariantCulture)}%;";

    private string ProgressLabel => string.IsNullOrWhiteSpace(Progress?.Label)
        ? $"{ProgressPercent}% watched"
        : Progress.Label;

    private bool HasStructuredProgress =>
        !string.IsNullOrWhiteSpace(Progress?.ContextLabel);
}
