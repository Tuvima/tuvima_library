@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details
@using MediaEngine.Web.Services.Playback
@inject ListenPlaybackService Playback

@if (Model is not null)
{
    <article class="tl-detail-page">
        <DetailHero Model="Model" OnActionSelected="HandleDetailActionAsync" />

        @if (Model.PreviewContributors.Count > 0 && Model.EntityType != DetailEntityType.MusicAlbum)
        {
            <PeoplePreviewStrip Title="@CreditPreviewTitle(Model)"
                                Credits="Model.PreviewContributors" />
        }

        <DetailTabs Tabs="Model.Tabs" ActiveTab="@_activeTab" ActiveTabChanged="SetActiveTab" />

        <section class="tl-detail-body">
            @if (_activeTab is "overview")
            {
                <MediaEngine.Web.Components.Details.OverviewTab Model="Model" />
            }
            else if (_activeTab is "episodes")
            {
                <EpisodesTab Groups="Model.MediaGroups" />
            }
            else if (_activeTab is "series")
            {
                @if (Model.SeriesPlacement is not null)
                {
                    <SeriesPlacementPanel Placement="Model.SeriesPlacement" />
                }
                else
                {
                    <ChildrenListTab Groups="Model.MediaGroups" />
                }
            }
            else if (_activeTab is "tracks" or "items" or "media" or "works" or "albums")
            {
                @if (Model.EntityType == DetailEntityType.MusicAlbum && _activeTab == "tracks")
                {
                    <MusicTrackList Groups="Model.MediaGroups"
                                    AlbumTitle="@Model.Title"
                                    AlbumArtworkUrl="@(Model.Artwork.CoverUrl ?? Model.Artwork.PosterUrl)" />
                }
                else
                {
                    <ChildrenListTab Groups="Model.MediaGroups" />
                }
            }
            else if (_activeTab is "contributors" or "people" or "credits" or "cast")
            {
                <PeopleAndCharactersTab ContributorGroups="Model.ContributorGroups"
                                        CharacterGroups="Model.CharacterGroups" />
            }
            else if (_activeTab is "characters" or "portrayals")
            {
                <CharactersSection Groups="Model.CharacterGroups" />
            }
            else if (_activeTab is "universe" or "timeline" or "relationships" or "related")
            {
                <UniverseTab Relationships="Model.RelationshipStrip" Groups="Model.MediaGroups" />
            }
            else if (_activeTab is "formats")
            {
                <FormatsTab Formats="Model.OwnedFormats" />
            }
            else if (_activeTab is "sync")
            {
                <SyncTab Sync="Model.ReadingListeningSync" Capability="Model.SyncCapability" />
            }
            else if (_activeTab is "editions")
            {
                <EditionsTab Formats="Model.OwnedFormats" />
            }
            else if (_activeTab is "registry")
            {
                <RegistryTab Model="Model" />
            }
            else
            {
                <DetailsTab Model="Model" />
            }
        </section>
    </article>
}

@code {
    [Parameter, EditorRequired] public DetailPageViewModel? Model { get; set; }
    [Parameter] public EventCallback<DetailAction> OnActionSelected { get; set; }

    private string _activeTab = "overview";
    private string? _loadedModelKey;

    protected override void OnParametersSet()
    {
        var firstVisible = Model?.Tabs.FirstOrDefault(tab => !tab.IsAdminOnly || Model.IsAdminView);
        var modelKey = Model is null ? null : $"{Model.EntityType}:{Model.Id}:{Model.PresentationContext}";

        if (firstVisible is not null && modelKey != _loadedModelKey)
        {
            _activeTab = firstVisible.Key;
            _loadedModelKey = modelKey;
        }
        else if (firstVisible is not null && !Model!.Tabs.Any(tab => tab.Key == _activeTab && (!tab.IsAdminOnly || Model.IsAdminView)))
        {
            _activeTab = firstVisible.Key;
        }
    }

    private void SetActiveTab(string key) => _activeTab = key;

    private async Task HandleDetailActionAsync(DetailAction action)
    {
        if (Model?.EntityType == DetailEntityType.MusicAlbum && action.Key is "play-album" or "shuffle")
        {
            await PlayAlbumAsync(shuffle: action.Key == "shuffle");
            return;
        }

        await OnActionSelected.InvokeAsync(action);
    }

    private async Task PlayAlbumAsync(bool shuffle)
    {
        if (Model is null)
            return;

        var tracks = Model.MediaGroups
            .SelectMany(group => group.Items)
            .Where(item => item.EntityType == DetailEntityType.MusicTrack)
            .OrderBy(TrackSortKey)
            .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
            .Select(ToQueueItem)
            .Where(item => item.WorkId != Guid.Empty)
            .ToList();

        await Playback.ReplaceQueueItemsAsync(tracks, 0, Model.Title, shuffle);
    }

    private ListenQueueItem ToQueueItem(MediaGroupingItemViewModel item)
        => new()
        {
            WorkId = Guid.TryParse(item.Id, out var workId) ? workId : Guid.Empty,
            MediaType = "Music",
            Title = item.Title,
            Subtitle = item.Artist,
            Album = Model?.Title,
            CoverUrl = item.ArtworkUrl ?? Model?.Artwork.CoverUrl ?? Model?.Artwork.PosterUrl,
            Duration = item.Duration,
        };

    private static int TrackSortKey(MediaGroupingItemViewModel item)
        => int.TryParse(item.TrackNumber, out var parsed) ? parsed : int.MaxValue;

    private static string CreditPreviewTitle(DetailPageViewModel model) => model.EntityType switch
    {
        DetailEntityType.Movie => "Cast & Crew",
        DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "Cast & Crew",
        DetailEntityType.Book => "Authors",
        DetailEntityType.Audiobook => "Author & Narrator",
        DetailEntityType.Work when model.OwnedFormats.Any(f => f.FormatType == MediaFormatType.Audiobook) => "Author & Narrator",
        DetailEntityType.Work => "Authors",
        DetailEntityType.ComicIssue or DetailEntityType.ComicSeries => "Creative Team",
        DetailEntityType.MusicAlbum => "Artists & Credits",
        DetailEntityType.MusicArtist => model.PresentationContext == DetailPresentationContext.Listen ? "Artists & Credits" : "Related People",
        DetailEntityType.Person => model.PresentationContext switch
        {
            DetailPresentationContext.Listen => "Music Credits",
            DetailPresentationContext.Watch => "Movies & TV",
            DetailPresentationContext.Read => "Books & Audiobooks",
            _ => "Related Works",
        },
        DetailEntityType.Character => "Portrayals",
        DetailEntityType.Universe => "People",
        _ => "Credits",
    };
}
