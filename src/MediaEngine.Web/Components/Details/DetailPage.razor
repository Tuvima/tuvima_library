@namespace MediaEngine.Web.Components.Details
@using System.Globalization
@using System.Text.RegularExpressions
@using MediaEngine.Contracts.Details
@using MediaEngine.Contracts.Playback
@using MediaEngine.Web.Components.Discovery
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@using MediaEngine.Web.Services.Editing
@using MediaEngine.Web.Services.Playback
@inject IEngineApiClient ApiClient
@inject MediaEditorLauncherService MediaEditorLauncher
@inject CollectionEditorLauncherService CollectionEditorLauncher
@inject IDialogService DialogService
@inject FavoriteService Favorites
@inject MediaReactionService Reactions
@inject PlaybackSessionController Playback
@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav
@inject ISnackbar Snackbar

@if (Model is not null)
{
    <article class="tl-detail-page">
        @if (IsAudioDetail)
        {
            <AudioDetailLayout Model="Model"
                               Tabs="VisibleTabs"
                               ActiveTab="@CurrentActiveTab"
                               ActiveTabChanged="SetActiveTabAsync"
                               OnActionSelected="HandleDetailActionAsync"
                               ActionAttributes="AudiobookActionAttributes"
                               OnContainerSelected="HandleContainerSelectedAsync" />
        }
        else
        {
            <DetailHero Model="Model" OnActionSelected="HandleDetailActionAsync" />

            <DetailTabs Tabs="VisibleTabs" ActiveTab="@CurrentActiveTab" ActiveTabChanged="SetActiveTabAsync" />

            <section class="tl-detail-body">
                @if (CurrentActiveTab is "overview")
                {
                    <MediaEngine.Web.Components.Details.OverviewTab Model="Model"
                                                                     OnTabRequested="SetActiveTabAsync"
                                                                     OnContainerSelected="HandleContainerSelectedAsync" />
                }
                else if (CurrentActiveTab is "episodes")
                {
                    @if (Model.SequencePlacement is not null)
                    {
                        <SequencePlacementPanel Placement="Model.SequencePlacement"
                                                OnContainerSelected="HandleContainerSelectedAsync" />
                    }
                    else
                    {
                        <ChildrenListTab Groups="Model.MediaGroups" />
                    }
                }
                else if (CurrentActiveTab is "series")
                {
                    @if (Model.SequencePlacement is not null)
                    {
                        <SequencePlacementPanel Placement="Model.SequencePlacement"
                                                OnContainerSelected="HandleContainerSelectedAsync" />
                    }
                    else
                    {
                        <ChildrenListTab Groups="Model.MediaGroups" />
                    }
                }
                else if (CurrentActiveTab is "tracks" or "items" or "issues" or "media" or "works" or "albums")
                {
                    @if (Model.SequencePlacement is not null && CurrentActiveTab is "issues" or "media" or "works")
                    {
                        <SequencePlacementPanel Placement="Model.SequencePlacement"
                                                OnContainerSelected="HandleContainerSelectedAsync" />
                    }
                    else if (Model.EntityType == DetailEntityType.MusicAlbum && CurrentActiveTab == "tracks")
                    {
                        <MusicTrackList Groups="Model.MediaGroups"
                                        AlbumTitle="@Model.Title"
                                        AlbumArtworkUrl="@(Model.Artwork.CoverUrl ?? Model.Artwork.PosterUrl)" />
                    }
                    else
                    {
                        <ChildrenListTab Groups="Model.MediaGroups" />
                    }
                }
                else if (CurrentActiveTab is "contributors" or "people" or "credits" or "cast")
                {
                    <PeopleAndCharactersTab ContributorGroups="Model.ContributorGroups"
                                            CharacterGroups="Model.CharacterGroups"
                                            IncludeCharacters="IncludeCharactersInPeopleTab" />
                }
                else if (CurrentActiveTab is "characters" or "portrayals")
                {
                    <CharactersSection Groups="Model.CharacterGroups" />
                }
                else if (CurrentActiveTab is "universe" or "timeline" or "relationships" or "related")
                {
                    <UniverseTab Relationships="Model.RelationshipStrip" Groups="Model.MediaGroups" />
                }
                else if (CurrentActiveTab is "formats")
                {
                    <FormatsTab Formats="Model.OwnedFormats" />
                }
                else if (CurrentActiveTab is "sync")
                {
                    <SyncTab Sync="Model.ReadingListeningSync" Capability="Model.SyncCapability" />
                }
                else if (CurrentActiveTab is "editions")
                {
                    <EditionsTab Formats="Model.OwnedFormats" />
                }
                else if (CurrentActiveTab is "registry")
                {
                    <RegistryTab Model="Model" />
                }
                else
                {
                    <DetailsTab Model="Model" />
                }
            </section>
        }
    </article>
}

@code {
    [Parameter, EditorRequired] public DetailPageViewModel? Model { get; set; }
    [Parameter] public string? ActiveTab { get; set; }
    [Parameter] public EventCallback<string> ActiveTabChanged { get; set; }
    [Parameter] public EventCallback<DetailAction> OnActionSelected { get; set; }


    private IReadOnlyList<DetailTab> VisibleTabs =>
        Model is null ? [] : DetailTabNavigation.GetVisibleTabs(Model);

    private string CurrentActiveTab =>
        VisibleTabs.Any(tab => string.Equals(tab.Key, ActiveTab, StringComparison.OrdinalIgnoreCase))
            ? VisibleTabs.First(tab => string.Equals(tab.Key, ActiveTab, StringComparison.OrdinalIgnoreCase)).Key
            : VisibleTabs.FirstOrDefault()?.Key ?? "overview";

    private bool IncludeCharactersInPeopleTab => CurrentActiveTab is not "cast";

    private bool IsAudioDetail => Model?.EntityType is DetailEntityType.MusicAlbum or DetailEntityType.Audiobook;

    private Task SetActiveTabAsync(string key) => ActiveTabChanged.InvokeAsync(key);

    private async Task HandleContainerSelectedAsync(SequenceContainerOptionViewModel option)
    {
        if (Model is null || string.IsNullOrWhiteSpace(option.ContainerId) || !Guid.TryParse(Model.Id, out var id))
            return;

        var profile = await Orchestrator.GetActiveProfileAsync();
        var updated = await ApiClient.GetDetailPageAsync(Model.EntityType, id, Model.PresentationContext, option.ContainerId, profile?.Id);
        if (updated is not null)
            Model = updated;
    }

    private async Task HandleDetailActionAsync(DetailAction action)
    {
        if (action.Key == "read")
        {
            await OpenReaderAsync(action);
            return;
        }

        if (action.Key is "edit-media" or "edit")
        {
            await OpenInlineEditorAsync();
            return;
        }

        if (action.Key is "add-to-collection" or "save")
        {
            await OpenAddToCollectionAsync();
            return;
        }

        if (action.Key == "my-list")
        {
            await ToggleFavoriteAsync(action);
            return;
        }

        if (action.Key is "reaction-dislike" or "reaction-like" or "reaction-love")
        {
            await SetReactionAsync(action);
            return;
        }

        if (action.Key == "details")
        {
            await SetActiveTabAsync("details");
            return;
        }

        if (action.Key == "sync-settings")
        {
            if (Model?.Tabs.Any(tab => tab.Key == "sync" && (!tab.IsAdminOnly || Model.IsAdminView)) == true)
                await SetActiveTabAsync("sync");

            return;
        }

        if (!string.IsNullOrWhiteSpace(action.Route))
        {
            Nav.NavigateTo(action.Route);
            return;
        }

        if (Model?.EntityType == DetailEntityType.MusicAlbum && action.Key is "play-album" or "shuffle")
        {
            await PlayAlbumAsync(shuffle: action.Key == "shuffle");
            return;
        }

        var isAudiobookListenAction = string.Equals(action.Key, "listen", StringComparison.OrdinalIgnoreCase)
            || string.Equals(action.Label, "Listen", StringComparison.OrdinalIgnoreCase);
        if (Model?.EntityType == DetailEntityType.Audiobook && (isAudiobookListenAction || IsContinueAction(action)))
        {
            await PlayAudiobookAsync(IsContinueAction(action));
            return;
        }

        await OnActionSelected.InvokeAsync(action);
    }

    private async Task OpenInlineEditorAsync()
    {
        if (Model is null || !Guid.TryParse(Model.Id, out var entityId))
            return;

        try
        {
            var target = ResolveEditorTarget(entityId);
            if (string.Equals(target.EntityKind, "Collection", StringComparison.OrdinalIgnoreCase))
            {
                var collection = await ResolveManagedCollectionForEditorAsync(target.EntityId);
                if (collection is null)
                {
                    Snackbar.Add("Collection editor could not load this collection.", Severity.Error);
                    return;
                }

                var collectionApplied = await CollectionEditorLauncher.OpenAsync(new CollectionEditorLaunchRequest
                {
                    EditingCollection = collection,
                    ActiveProfileId = collection.ProfileId,
                    CanManageSharedCollections = Model.IsAdminView || collection.CanShare,
                    Mode = "Collection",
                });

                if (collectionApplied)
                    await RefreshCurrentDetailAsync();

                return;
            }

            var applied = await MediaEditorLauncher.OpenAsync(new MediaEditorLaunchRequest
            {
                EntityIds = [target.EntityId],
                LaunchEntityId = target.EntityId,
                LaunchEntityKind = target.EntityKind,
                ContainerMode = target.ContainerMode,
                Mode = SharedMediaEditorMode.Normal,
                InitialTab = target.InitialTab ?? "details",
                InitialScope = target.InitialScope,
                MediaType = ResolveEditorMediaType(Model.EntityType, Model.PresentationContext),
                HeaderTitle = Model.Title,
                HeaderSubtitle = Model.Subtitle,
                CoverUrl = Model.Artwork.CoverUrl ?? Model.Artwork.PosterUrl ?? Model.Artwork.PortraitUrl,
                OnArtworkChanged = RefreshAfterEditorArtworkChangeAsync,
                PreviewItems =
                [
                    new MediaEditorPreviewItem
                    {
                        EntityId = entityId,
                        Title = Model.Title,
                        CoverUrl = Model.Artwork.CoverUrl ?? Model.Artwork.PosterUrl ?? Model.Artwork.PortraitUrl,
                        MediaType = ResolveEditorMediaType(Model.EntityType, Model.PresentationContext),
                    },
                ],
            });

            if (applied)
            {
                await RefreshCurrentDetailAsync();
                Snackbar.Add("Media details updated.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Media editor could not open: {ex.Message}", Severity.Error);
        }
    }

    private (Guid EntityId, string EntityKind, string ContainerMode, string? InitialTab, string? InitialScope) ResolveEditorTarget(Guid fallbackEntityId)
    {
        var target = Model?.EditorTarget;
        return target is not null && Guid.TryParse(target.EntityId, out var targetId)
            ? (targetId, target.EntityKind, target.ContainerMode, target.InitialTab, target.InitialScope)
            : (fallbackEntityId, Model?.EntityType.ToString() ?? "Work", "Canonical", "details", null);
    }

    private async Task<CollectionListItemViewModel?> ResolveManagedCollectionForEditorAsync(Guid collectionId)
    {
        var collections = await ApiClient.GetManagedCollectionsAsync();
        var collection = collections.FirstOrDefault(item => item.Id == collectionId);
        return collection is null ? null : ToCollectionListItem(collection);
    }

    private static CollectionListItemViewModel ToCollectionListItem(ManagedCollectionViewModel collection) =>
        new()
        {
            Id = collection.Id,
            Name = collection.Name,
            Description = collection.Description,
            IconName = collection.IconName,
            CollectionType = collection.CollectionType,
            Resolution = collection.Resolution,
            Scope = collection.Scope,
            ProfileId = collection.ProfileId,
            Visibility = collection.Visibility,
            IsEnabled = collection.IsEnabled,
            IsFeatured = collection.IsFeatured,
            ItemCount = collection.ItemCount,
            RuleJson = collection.RuleJson,
            RuleHash = collection.RuleHash,
            MatchMode = collection.MatchMode,
            SortField = collection.SortField,
            SortDirection = collection.SortDirection,
            LiveUpdating = collection.LiveUpdating,
            CoverUrl = collection.SquareArtworkUrl,
            CreatedAt = collection.CreatedAt,
            CanEdit = collection.CanEdit,
            CanShare = collection.CanShare,
        };

    private async Task RefreshCurrentDetailAsync()
    {
        if (Model is null || !Guid.TryParse(Model.Id, out var entityId))
            return;

        var profile = await Orchestrator.GetActiveProfileAsync();
        var updated = await ApiClient.GetDetailPageAsync(Model.EntityType, entityId, Model.PresentationContext, profileId: profile?.Id);
        if (updated is not null)
        {
            Model = updated;
            StateHasChanged();
        }
    }

    private async Task OpenAddToCollectionAsync()
    {
        if (Model is null || !Guid.TryParse(Model.EditorTarget?.EntityId ?? Model.Id, out var workId))
            return;

        if (string.Equals(Model.EditorTarget?.EntityKind, "Collection", StringComparison.OrdinalIgnoreCase))
            return;

        var dialog = await DialogService.ShowAsync<AddToCollectionDialog>(
            "Add to collection",
            new DialogParameters
            {
                { nameof(AddToCollectionDialog.WorkId), workId },
                { nameof(AddToCollectionDialog.WorkTitle), Model.Title },
            },
            new DialogOptions
            {
                CloseButton = false,
                NoHeader = true,
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                BackdropClick = true,
                CloseOnEscapeKey = true,
            });

        if (dialog is not null)
            await dialog.Result;
    }

    private async Task RefreshAfterEditorArtworkChangeAsync()
    {
        if (Model is null || !Guid.TryParse(Model.Id, out var entityId))
            return;

        var profile = await Orchestrator.GetActiveProfileAsync();
        var updated = await ApiClient.GetDetailPageAsync(Model.EntityType, entityId, Model.PresentationContext, profileId: profile?.Id);
        if (updated is not null)
        {
            Model = updated;
            StateHasChanged();
        }
    }

    private async Task OpenReaderAsync(DetailAction action)
    {
        if (!string.IsNullOrWhiteSpace(action.Route) && action.Route.StartsWith("/read/", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo(action.Route);
            return;
        }

        if (Model is null || !Guid.TryParse(Model.Id, out var workId))
        {
            await OnActionSelected.InvokeAsync(action);
            return;
        }

        var assetId = await ApiClient.ResolveWorkToAssetAsync(workId);
        if (assetId.HasValue)
        {
            Nav.NavigateTo($"/read/{assetId.Value:D}");
            return;
        }

        await OnActionSelected.InvokeAsync(action);
    }

    private async Task ToggleFavoriteAsync(DetailAction action)
    {
        if (Model is null)
            return;

        var profile = await Orchestrator.GetActiveProfileAsync();
        if (!TryResolveFavoriteWorkId(out var workId))
        {
            Snackbar.Add("This item cannot be added to My List yet.", Severity.Warning);
            return;
        }

        var membership = await Favorites.ToggleAsync(workId, profile?.Id);
        if (membership is null)
        {
            Snackbar.Add("My List requires an active profile.", Severity.Warning);
            return;
        }

        SetFavoriteSelection(Model.PrimaryActions, membership.IsFavorite);
        SetFavoriteSelection(Model.SecondaryActions, membership.IsFavorite);
        SetFavoriteSelection(Model.OverflowActions, membership.IsFavorite);
        action.IsSelected = membership.IsFavorite;
        StateHasChanged();
        await OnActionSelected.InvokeAsync(action);
    }

    private bool TryResolveFavoriteWorkId(out Guid workId)
    {
        workId = Guid.Empty;
        var target = Model?.EditorTarget;
        if (target is not null)
        {
            return !string.Equals(target.EntityKind, "Collection", StringComparison.OrdinalIgnoreCase)
                && Guid.TryParse(target.EntityId, out workId);
        }

        return Model is not null
            && Model.EntityType is not DetailEntityType.Collection
            && Guid.TryParse(Model.Id, out workId);
    }

    private static void SetFavoriteSelection(IEnumerable<DetailAction> actions, bool isFavorite)
    {
        foreach (var item in actions)
        {
            if (item.Key == "my-list")
                item.IsSelected = isFavorite;

            SetFavoriteSelection(item.Children, isFavorite);
        }
    }

    private async Task SetReactionAsync(DetailAction action)
    {
        if (!TryResolveFavoriteWorkId(out var workId))
        {
            Snackbar.Add("This item cannot be rated yet.", Severity.Warning);
            return;
        }

        var reaction = action.Key switch
        {
            "reaction-dislike" => MediaReaction.Dislike,
            "reaction-like" => MediaReaction.Like,
            "reaction-love" => MediaReaction.Love,
            _ => MediaReaction.Neutral,
        };

        var profile = await Orchestrator.GetActiveProfileAsync();
        var current = await Reactions.GetReactionAsync(workId, profile?.Id);
        await Reactions.SetReactionAsync(workId, current == reaction ? MediaReaction.Neutral : reaction, profile?.Id);
        await OnActionSelected.InvokeAsync(action);
    }

    private async Task PlayAlbumAsync(bool shuffle)
    {
        if (Model is null)
            return;

        var tracks = Model.MediaGroups
            .SelectMany(group => group.Items)
            .Where(item => item.EntityType == DetailEntityType.MusicTrack)
            .OrderBy(TrackSortKey)
            .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
            .Select(ToQueueItem)
            .Where(item => item.WorkId != Guid.Empty)
            .ToList();

        await Playback.ReplaceQueueItemsAsync(tracks, 0, Model.Title, shuffle);
    }

    private ListenQueueItem ToQueueItem(MediaGroupingItemViewModel item)
        => new()
        {
            WorkId = Guid.TryParse(item.Id, out var workId) ? workId : Guid.Empty,
            AssetId = Guid.TryParse(item.AssetId, out var assetId) ? assetId : null,
            MediaType = "Music",
            Title = item.Title,
            Subtitle = item.Artist,
            Album = Model?.Title,
            CoverUrl = item.ArtworkUrl ?? Model?.Artwork.CoverUrl ?? Model?.Artwork.PosterUrl,
            Duration = item.Duration,
            InitialPositionSeconds = item.StartSeconds,
        };

    private async Task PlayAudiobookAsync(bool preferResume)
    {
        if (Model is null)
            return;

        var chapters = Model.MediaGroups
            .SelectMany(group => group.Items)
            .Where(item => item.EntityType == DetailEntityType.Audiobook)
            .OrderBy(TrackSortKey)
            .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (chapters.Count == 0)
            return;

        var totalDurationSeconds = ResolveAudiobookTotalSeconds(chapters);
        var resumePositionSeconds = preferResume
            ? ResolveAudiobookResumePosition(chapters, Model.Progress?.Percent, Playback.AudiobookNearStartGuardSeconds, totalDurationSeconds)
            : null;
        var startItem = preferResume
            ? ResolveAudiobookResumeItem(chapters, resumePositionSeconds)
            : chapters.FirstOrDefault();
        if (startItem is null)
            return;

        var item = ToAudiobookQueueItem(startItem, chapters, resumePositionSeconds);
        if (item.WorkId == Guid.Empty)
            return;

        await Playback.StartAudiobookAsync(
            new AudiobookStartRequest(
                item,
                preferResume ? AudiobookStartKinds.Resume : AudiobookStartKinds.Chapter,
                resumePositionSeconds,
                startItem.ChapterIndex,
                Model.Title));
    }

    private IReadOnlyDictionary<string, object>? AudiobookActionAttributes(DetailAction action)
    {
        var isListenAction = string.Equals(action.Key, "listen", StringComparison.OrdinalIgnoreCase)
            || string.Equals(action.Label, "Listen", StringComparison.OrdinalIgnoreCase);
        if (Model?.EntityType != DetailEntityType.Audiobook || action.IsDisabled || (!isListenAction && !IsContinueAction(action)))
        {
            return null;
        }

        var chapters = Model.MediaGroups
            .SelectMany(group => group.Items)
            .Where(item => item.EntityType == DetailEntityType.Audiobook)
            .OrderBy(TrackSortKey)
            .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();
        if (chapters.Count == 0)
        {
            return null;
        }

        var preferResume = IsContinueAction(action);
        var totalDurationSeconds = ResolveAudiobookTotalSeconds(chapters);
        var resumePositionSeconds = preferResume
            ? ResolveAudiobookResumePosition(chapters, Model.Progress?.Percent, Playback.AudiobookNearStartGuardSeconds, totalDurationSeconds)
            : null;
        var startItem = preferResume
            ? ResolveAudiobookResumeItem(chapters, resumePositionSeconds)
            : chapters.FirstOrDefault();
        if (startItem is null || !Guid.TryParse(startItem.AssetId, out var assetId))
        {
            return null;
        }

        var positionSeconds = resumePositionSeconds ?? ResumePositionFor(startItem) ?? startItem.StartSeconds ?? 0;
        if (preferResume && positionSeconds > 0)
        {
            positionSeconds = Math.Max(0, positionSeconds - Playback.ResumeRewindSeconds);
        }

        var playbackRate = Playback.IsAudiobookMode
            ? Playback.PlaybackRate
            : (double)new ListeningSettingsDto().AudiobookDefaultSpeed;

        return new Dictionary<string, object>
        {
            ["data-listen-immediate-start"] = "audiobook",
            ["data-listen-start-kind"] = preferResume ? AudiobookStartKinds.Resume : AudiobookStartKinds.Chapter,
            ["data-listen-start-url"] = $"/engine-stream/{assetId:D}",
            ["data-listen-start-position"] = positionSeconds.ToString("0.###", CultureInfo.InvariantCulture),
            ["data-listen-start-progress"] = (Model.Progress?.Percent ?? 0).ToString("0.###", CultureInfo.InvariantCulture),
            ["data-listen-start-duration"] = (totalDurationSeconds ?? 0).ToString("0.###", CultureInfo.InvariantCulture),
            ["data-listen-start-rewind"] = (preferResume ? Playback.ResumeRewindSeconds : 0).ToString(CultureInfo.InvariantCulture),
            ["data-listen-start-rate"] = playbackRate.ToString("0.###", CultureInfo.InvariantCulture),
            ["data-listen-start-volume"] = Playback.Volume.ToString("0.###", CultureInfo.InvariantCulture),
            ["data-listen-start-muted"] = Playback.IsMuted ? "true" : "false",
        };
    }

    private static bool IsContinueAction(DetailAction action) =>
        string.Equals(action.Key, "continue", StringComparison.OrdinalIgnoreCase)
        || string.Equals(action.Label, "Continue", StringComparison.OrdinalIgnoreCase)
        || string.Equals(action.Label, "Continue Listening", StringComparison.OrdinalIgnoreCase);

    private static MediaGroupingItemViewModel? ResolveAudiobookResumeItem(
        IReadOnlyList<MediaGroupingItemViewModel> chapters,
        double? resumePositionSeconds)
    {
        if (resumePositionSeconds is > 0)
        {
            return ChapterAtPosition(chapters, resumePositionSeconds.Value)
                ?? chapters.FirstOrDefault(item => item.ResumePositionSeconds is > 0)
                ?? chapters.FirstOrDefault(item => item.ProgressPercent is > 0 and < 99.5)
                ?? chapters.FirstOrDefault(item => !IsCompletedChapter(item) && !IsIntroChapter(item))
                ?? chapters.FirstOrDefault(item => !IsCompletedChapter(item))
                ?? chapters.FirstOrDefault();
        }

        return chapters.FirstOrDefault(item => item.ResumePositionSeconds is > 0)
            ?? chapters.FirstOrDefault(item => item.ProgressPercent is > 0 and < 99.5)
            ?? chapters.FirstOrDefault(item => !IsCompletedChapter(item) && !IsIntroChapter(item))
            ?? chapters.FirstOrDefault(item => !IsCompletedChapter(item))
            ?? chapters.FirstOrDefault();
    }

    private static double? ResolveAudiobookResumePosition(
        IReadOnlyList<MediaGroupingItemViewModel> chapters,
        double? pageProgressPercent,
        int nearStartGuardSeconds,
        double? knownTotalSeconds = null)
    {
        double? inferredPagePosition = null;
        if (pageProgressPercent is > 0 and < 99.5)
        {
            var totalSeconds = knownTotalSeconds is > 0
                ? knownTotalSeconds
                : TotalAudiobookSeconds(chapters);
            if (totalSeconds is > 0)
            {
                inferredPagePosition = totalSeconds.Value * Math.Clamp(pageProgressPercent.Value, 0, 100) / 100d;
            }
        }

        var explicitPosition = chapters
            .Where(item => item.ResumePositionSeconds is > 0)
            .Select(item => item.ResumePositionSeconds!.Value)
            .OrderDescending()
            .FirstOrDefault();
        if (explicitPosition > 0)
        {
            if (explicitPosition <= Math.Max(0, nearStartGuardSeconds)
                && inferredPagePosition > explicitPosition + Math.Max(0, nearStartGuardSeconds))
            {
                return inferredPagePosition;
            }

            return explicitPosition;
        }

        var chapterProgressPosition = chapters
            .Where(item => item.ProgressPercent is > 0 and < 99.5)
            .Select(ResumePositionFor)
            .Where(position => position is > 0)
            .Select(position => position!.Value)
            .OrderDescending()
            .FirstOrDefault();
        if (chapterProgressPosition > 0)
        {
            return chapterProgressPosition;
        }

        if (inferredPagePosition is > 0)
        {
            return inferredPagePosition;
        }

        return null;
    }

    private double? ResolveAudiobookTotalSeconds(IReadOnlyList<MediaGroupingItemViewModel> chapters)
    {
        var total = TotalAudiobookSeconds(chapters);
        if (total is > 0)
        {
            return total;
        }

        foreach (var label in Model?.Metadata
                     .Where(item => string.Equals(item.Kind, "duration", StringComparison.OrdinalIgnoreCase))
                     .Select(item => item.Label) ?? [])
        {
            if (TryParseDurationSeconds(label) is { } seconds)
            {
                return seconds;
            }
        }

        foreach (var runtime in Model?.OwnedFormats
                     .Where(item => item.FormatType == MediaFormatType.Audiobook)
                     .Select(item => item.Runtime) ?? [])
        {
            if (TryParseDurationSeconds(runtime) is { } seconds)
            {
                return seconds;
            }
        }

        return null;
    }

    private static MediaGroupingItemViewModel? ChapterAtPosition(
        IReadOnlyList<MediaGroupingItemViewModel> chapters,
        double positionSeconds) =>
        chapters.LastOrDefault(item =>
        {
            var start = Math.Max(0, item.StartSeconds ?? 0);
            var end = item.EndSeconds ?? (item.DurationSeconds is > 0 ? start + item.DurationSeconds.Value : (double?)null);
            return positionSeconds >= start - 0.5d
                && (!end.HasValue || positionSeconds < end.Value - 0.5d);
        });

    private static double? TotalAudiobookSeconds(IReadOnlyList<MediaGroupingItemViewModel> chapters)
    {
        var maxEnd = chapters
            .Select(item => item.EndSeconds ?? (item.StartSeconds.HasValue && item.DurationSeconds.HasValue
                ? item.StartSeconds.Value + item.DurationSeconds.Value
                : item.DurationSeconds))
            .Where(seconds => seconds is > 0)
            .Select(seconds => seconds!.Value)
            .DefaultIfEmpty()
            .Max();

        if (maxEnd > 0)
        {
            return maxEnd;
        }

        var durations = chapters
            .Select(item => item.DurationSeconds)
            .Where(seconds => seconds is > 0)
            .Select(seconds => seconds!.Value)
            .ToList();
        return durations.Count == chapters.Count && durations.Count > 0
            ? durations.Sum()
            : null;
    }

    private static double? TryParseDurationSeconds(string? duration)
    {
        if (string.IsNullOrWhiteSpace(duration))
        {
            return null;
        }

        var trimmed = duration.Trim();
        var clockParts = trimmed.Split(':', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        if (clockParts.Length is 2 or 3 && clockParts.All(part => double.TryParse(part, NumberStyles.Float, CultureInfo.InvariantCulture, out _)))
        {
            var total = 0d;
            foreach (var part in clockParts)
            {
                total = total * 60d + double.Parse(part, NumberStyles.Float, CultureInfo.InvariantCulture);
            }

            return total > 0 ? total : null;
        }

        var matches = Regex.Matches(
            trimmed,
            @"(?<value>\d+(?:\.\d+)?)\s*(?<unit>hours?|hrs?|h|minutes?|mins?|m|seconds?|secs?|s)\b",
            RegexOptions.IgnoreCase | RegexOptions.CultureInvariant);
        if (matches.Count == 0)
        {
            return null;
        }

        var seconds = 0d;
        foreach (Match match in matches)
        {
            if (!double.TryParse(match.Groups["value"].Value, NumberStyles.Float, CultureInfo.InvariantCulture, out var value))
            {
                continue;
            }

            var unit = match.Groups["unit"].Value.ToLowerInvariant();
            seconds += unit[0] switch
            {
                'h' => value * 3600d,
                'm' => value * 60d,
                's' => value,
                _ => 0d,
            };
        }

        return seconds > 0 ? seconds : null;
    }

    private static bool IsCompletedChapter(MediaGroupingItemViewModel item) =>
        item.ProgressPercent is >= 99.5;

    private static bool IsIntroChapter(MediaGroupingItemViewModel item) =>
        item.ChapterIndex == 0
        && string.Equals(item.Title, "Intro", StringComparison.OrdinalIgnoreCase)
        && item.StartSeconds is null or <= 5
        && item.DurationSeconds is null or <= 120;

    private ListenQueueItem ToAudiobookQueueItem(MediaGroupingItemViewModel item, IReadOnlyList<MediaGroupingItemViewModel> chapters, double? initialPositionSeconds = null)
        => new()
        {
            WorkId = Guid.TryParse(item.Id, out var workId) ? workId : Guid.Empty,
            AssetId = Guid.TryParse(item.AssetId, out var assetId) ? assetId : null,
            MediaType = "Audiobooks",
            Title = Model?.Title ?? item.Title,
            Subtitle = item.Title,
            Album = Model?.Title,
            CoverUrl = item.ArtworkUrl ?? Model?.Artwork.CoverUrl ?? Model?.Artwork.PosterUrl,
            Duration = item.Duration,
            InitialPositionSeconds = initialPositionSeconds ?? ResumePositionFor(item),
            Chapters = chapters.Select(ToPlaybackChapter).ToList(),
            ChapterIndex = item.ChapterIndex,
        };

    private static PlaybackChapterDto ToPlaybackChapter(MediaGroupingItemViewModel item)
        => new()
        {
            Index = Math.Max(0, item.ChapterIndex ?? 0),
            Title = string.IsNullOrWhiteSpace(item.Title)
                ? PlaybackSessionController.CleanChapterTitle(item.Title, Math.Max(0, item.ChapterIndex ?? 0))
                : item.Title.Trim(),
            StartSeconds = Math.Max(0, item.StartSeconds ?? 0),
            EndSeconds = item.EndSeconds,
        };

    private static double? ResumePositionFor(MediaGroupingItemViewModel item)
    {
        if (item.ResumePositionSeconds is > 0)
        {
            return item.ResumePositionSeconds;
        }

        if (item.ProgressPercent is > 0 and < 100)
        {
            var start = Math.Max(0, item.StartSeconds ?? 0);
            var end = item.EndSeconds;
            if (end is > 0 && end.Value > start)
            {
                return start + (end.Value - start) * Math.Clamp(item.ProgressPercent.Value, 0, 100) / 100d;
            }
        }

        return item.StartSeconds;
    }

    private static int TrackSortKey(MediaGroupingItemViewModel item)
        => int.TryParse(item.TrackNumber, out var parsed) ? parsed : int.MaxValue;

    private static string ResolveEditorMediaType(DetailEntityType entityType, DetailPresentationContext context)
        => entityType switch
        {
            DetailEntityType.Movie or DetailEntityType.MovieSeries => "Movies",
            DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "TV",
            DetailEntityType.Audiobook => "Audiobooks",
            DetailEntityType.ComicIssue or DetailEntityType.ComicSeries => "Comics",
            DetailEntityType.MusicAlbum or DetailEntityType.MusicArtist or DetailEntityType.MusicTrack => "Music",
            DetailEntityType.Book or DetailEntityType.BookSeries => "Books",
            _ when context == DetailPresentationContext.Watch => "Movies",
            _ when context == DetailPresentationContext.Listen => "Music",
            _ when context == DetailPresentationContext.Comics => "Comics",
            _ => "Books",
        };

}
