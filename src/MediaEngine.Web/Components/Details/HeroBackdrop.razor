@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<div class="@StageClass" style="@StageStyle">
    @if (IsBackdropMode && !string.IsNullOrWhiteSpace(HeroImageUrl))
    {
        <div class="tl-detail-hero__artwork tl-detail-media-stage__background" aria-hidden="true"></div>
        <div class="tl-detail-hero__overlays tl-detail-media-stage__overlay" aria-hidden="true"></div>
    }
    else if (IsArtworkFallbackMode && !string.IsNullOrWhiteSpace(HeroImageUrl))
    {
        <div class="tl-detail-hero__cover-atmosphere tl-detail-media-stage__cover-atmosphere" aria-hidden="true"></div>
        <div class="tl-detail-hero__overlays tl-detail-media-stage__overlay" aria-hidden="true"></div>
        <div class="tl-detail-hero__foreground-art tl-detail-media-stage__cover-wrap">
            <div class="@ForegroundClass">
                @if (ForegroundTreatment == HeroForegroundTreatment.Book)
                {
                    <span class="tl-detail-media-stage__book-pages" aria-hidden="true"></span>
                    <span class="tl-detail-media-stage__book-spine" aria-hidden="true"></span>
                }
                else if (ForegroundTreatment == HeroForegroundTreatment.Album)
                {
                    <span class="tl-detail-media-stage__vinyl" aria-hidden="true"></span>
                }

                <img class="tl-detail-media-stage__cover" src="@HeroImageUrl" alt="" @onerror="HandleImageError" />
            </div>
        </div>
    }
    else
    {
        <div class="tl-detail-hero__placeholder tl-detail-media-stage__placeholder" aria-hidden="true"></div>
        <div class="tl-detail-hero__overlays tl-detail-media-stage__overlay" aria-hidden="true"></div>
    }

    @if (ShouldRenderHeroBrand)
    {
        <div class="tl-detail-hero-brand">
            @if (!string.IsNullOrWhiteSpace(HeroBrand?.ImageUrl))
            {
                <img src="@HeroBrand.ImageUrl" alt="@HeroBrand.Label" />
            }
            else
            {
                <span>@HeroBrand?.Label</span>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public ArtworkSet Artwork { get; set; } = default!;
    [Parameter] public DetailEntityType EntityType { get; set; }
    [Parameter] public HeroBrandViewModel? HeroBrand { get; set; }

    private bool _imageFailed;
    private string? _lastHeroImageUrl;

    private bool ShouldRenderHeroBrand => !string.IsNullOrWhiteSpace(HeroBrand?.ImageUrl);
    private HeroArtworkViewModel HeroArtwork => Artwork.HeroArtwork;
    private string? HeroImageUrl => HeroArtwork.HasImage && !string.IsNullOrWhiteSpace(HeroArtwork.Url) && !_imageFailed
        ? HeroArtwork.Url
        : null;
    private HeroArtworkMode EffectiveMode => string.IsNullOrWhiteSpace(HeroImageUrl)
        ? HeroArtworkMode.Placeholder
        : NormalizeMode(HeroArtwork.Mode);
    private bool IsBackdropMode => EffectiveMode is HeroArtworkMode.BackdropWithLogo or HeroArtworkMode.BackdropWithRenderedTitle;
    private bool IsArtworkFallbackMode => EffectiveMode == HeroArtworkMode.ArtworkFallback;
    private HeroForegroundTreatment ForegroundTreatment => EntityType switch
    {
        DetailEntityType.Book or DetailEntityType.Audiobook or DetailEntityType.Work => HeroForegroundTreatment.Book,
        DetailEntityType.MusicAlbum => HeroForegroundTreatment.Album,
        DetailEntityType.MusicArtist or DetailEntityType.Person or DetailEntityType.Character => HeroForegroundTreatment.Portrait,
        _ => HeroForegroundTreatment.Poster,
    };
    private string ForegroundClass => $"tl-detail-media-stage__foreground tl-detail-media-stage__foreground--{ForegroundTreatment.ToString().ToLowerInvariant()}";

    private string StageClass
    {
        get
        {
            var imageClass = EffectiveMode switch
            {
                HeroArtworkMode.BackdropWithLogo => "tl-detail-media-stage--background tl-detail-media-stage--backdrop-with-logo",
                HeroArtworkMode.BackdropWithRenderedTitle => "tl-detail-media-stage--background tl-detail-media-stage--backdrop-with-rendered-title",
                HeroArtworkMode.ArtworkFallback => "tl-detail-media-stage--artwork-fallback tl-detail-media-stage--cover-fallback",
                _ => "tl-detail-media-stage--placeholder",
            };
            var entityClass = EntityType switch
            {
                DetailEntityType.Movie or DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "tl-detail-media-stage--landscape",
                DetailEntityType.MusicAlbum => "tl-detail-media-stage--square",
                DetailEntityType.Book or DetailEntityType.Audiobook or DetailEntityType.Work => "tl-detail-media-stage--book",
                DetailEntityType.ComicIssue or DetailEntityType.ComicSeries => "tl-detail-media-stage--poster",
                DetailEntityType.Person or DetailEntityType.MusicArtist or DetailEntityType.Character => "tl-detail-media-stage--portrait",
                _ => "tl-detail-media-stage--poster",
            };

            return $"tl-detail-media-stage tl-detail-hero__stage {imageClass} {entityClass}";
        }
    }

    private string StageStyle
    {
        get
        {
            if (string.IsNullOrWhiteSpace(HeroImageUrl))
                return string.Empty;

            var position = HeroArtwork.BackgroundPosition ?? "center";
            var mobilePosition = HeroArtwork.MobilePosition ?? position;
            return $"--hero-image:url(\"{EscapeCssString(HeroImageUrl)}\");--hero-image-position:{position};--mobile-image-position:{mobilePosition};";
        }
    }

    protected override void OnParametersSet()
    {
        var nextUrl = Artwork.HeroArtwork.Url;
        if (!string.Equals(nextUrl, _lastHeroImageUrl, StringComparison.Ordinal))
        {
            _imageFailed = false;
            _lastHeroImageUrl = nextUrl;
        }
    }

    private void HandleImageError() => _imageFailed = true;

    private static HeroArtworkMode NormalizeMode(HeroArtworkMode mode) => mode switch
    {
#pragma warning disable CS0618
        HeroArtworkMode.Background => HeroArtworkMode.BackdropWithRenderedTitle,
        HeroArtworkMode.CoverFallback => HeroArtworkMode.ArtworkFallback,
#pragma warning restore CS0618
        _ => mode,
    };

    private static string EscapeCssString(string value)
        => value.Replace("\\", "\\\\", StringComparison.Ordinal).Replace("\"", "\\\"", StringComparison.Ordinal);

    private enum HeroForegroundTreatment
    {
        Book,
        Poster,
        Album,
        Portrait
    }
}
