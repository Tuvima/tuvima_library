@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<div class="@StageClass" style="@StageStyle">
    @if (EffectiveMode == HeroArtworkMode.Background && !string.IsNullOrWhiteSpace(HeroImageUrl))
    {
        <img class="tl-detail-media-stage__background" src="@HeroImageUrl" alt="" @onerror="HandleImageError" />
        <div class="tl-detail-media-stage__overlay" aria-hidden="true"></div>
    }
    else if (EffectiveMode == HeroArtworkMode.CoverFallback && !string.IsNullOrWhiteSpace(HeroImageUrl))
    {
        <div class="tl-detail-media-stage__cover-atmosphere" aria-hidden="true"></div>
        <div class="tl-detail-media-stage__overlay" aria-hidden="true"></div>
        <div class="tl-detail-media-stage__cover-wrap">
            <img class="tl-detail-media-stage__cover" src="@HeroImageUrl" alt="" @onerror="HandleImageError" />
        </div>
    }
    else
    {
        <div class="tl-detail-media-stage__placeholder" aria-hidden="true"></div>
    }

    @if (ShouldRenderHeroBrand)
    {
        <div class="tl-detail-hero-brand">
            @if (!string.IsNullOrWhiteSpace(HeroBrand?.ImageUrl))
            {
                <img src="@HeroBrand.ImageUrl" alt="@HeroBrand.Label" />
            }
            else
            {
                <span>@HeroBrand?.Label</span>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public ArtworkSet Artwork { get; set; } = default!;
    [Parameter] public DetailEntityType EntityType { get; set; }
    [Parameter] public HeroBrandViewModel? HeroBrand { get; set; }

    private bool _imageFailed;
    private string? _lastHeroImageUrl;

    private bool IsTvEntity => EntityType is DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode;
    private bool ShouldRenderHeroBrand => IsTvEntity && (!string.IsNullOrWhiteSpace(HeroBrand?.ImageUrl) || !string.IsNullOrWhiteSpace(HeroBrand?.Label));
    private HeroArtworkViewModel HeroArtwork => Artwork.HeroArtwork;
    private string? HeroImageUrl => HeroArtwork.HasImage && !string.IsNullOrWhiteSpace(HeroArtwork.Url) && !_imageFailed
        ? HeroArtwork.Url
        : null;
    private HeroArtworkMode EffectiveMode => string.IsNullOrWhiteSpace(HeroImageUrl)
        ? HeroArtworkMode.Placeholder
        : HeroArtwork.Mode;

    private string StageClass
    {
        get
        {
            var imageClass = EffectiveMode switch
            {
                HeroArtworkMode.Background => "tl-detail-media-stage--background",
                HeroArtworkMode.CoverFallback => "tl-detail-media-stage--cover-fallback",
                _ => "tl-detail-media-stage--placeholder",
            };
            var entityClass = EntityType switch
            {
                DetailEntityType.Movie or DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "tl-detail-media-stage--landscape",
                DetailEntityType.MusicAlbum => "tl-detail-media-stage--square",
                DetailEntityType.Person or DetailEntityType.MusicArtist or DetailEntityType.Character => "tl-detail-media-stage--portrait",
                _ => "tl-detail-media-stage--poster",
            };

            return $"tl-detail-media-stage {imageClass} {entityClass}";
        }
    }

    private string StageStyle
    {
        get
        {
            if (string.IsNullOrWhiteSpace(HeroImageUrl))
                return string.Empty;

            var position = HeroArtwork.BackgroundPosition ?? "center";
            var mobilePosition = HeroArtwork.MobilePosition ?? position;
            return $"--hero-image:url(\"{EscapeCssString(HeroImageUrl)}\");--hero-image-position:{position};--mobile-image-position:{mobilePosition};";
        }
    }

    protected override void OnParametersSet()
    {
        var nextUrl = Artwork.HeroArtwork.Url;
        if (!string.Equals(nextUrl, _lastHeroImageUrl, StringComparison.Ordinal))
        {
            _imageFailed = false;
            _lastHeroImageUrl = nextUrl;
        }
    }

    private void HandleImageError() => _imageFailed = true;

    private static string EscapeCssString(string value)
        => value.Replace("\\", "\\\\", StringComparison.Ordinal).Replace("\"", "\\\"", StringComparison.Ordinal);
}
