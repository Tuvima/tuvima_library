@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<div class="tl-detail-overflow-list" role="none">
    @foreach (var action in Actions)
    {
        <button type="button"
                role="menuitem"
                disabled="@action.IsDisabled"
                class="@GetActionClass(action)"
                @onclick="@(() => SelectAsync(action))">
            <MudIcon Icon="@HeroActionRow.IconFor(action)" Size="Size.Small" />
            <span>@action.Label</span>
        </button>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<DetailAction> Actions { get; set; } = [];
    [Parameter] public EventCallback<DetailAction> OnActionSelected { get; set; }

    private Task SelectAsync(DetailAction action)
        => action.IsDisabled ? Task.CompletedTask : OnActionSelected.InvokeAsync(action);

    private static string GetActionClass(DetailAction action)
        => action.IsDestructive
            ? "tl-detail-overflow-item tl-menu-danger"
            : "tl-detail-overflow-item";
}
