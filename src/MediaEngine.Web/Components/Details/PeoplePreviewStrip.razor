@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<section class="tl-credit-preview tl-credit-preview--bar">
    <div class="tl-credit-preview__heading">
        <h2>@Title</h2>
    </div>
    <div class="tl-credit-strip">
        @foreach (var credit in Credits)
        {
            <PersonCreditCard Credit="credit" />
        }
    </div>
</section>

@code {
    [Parameter] public string Title { get; set; } = "People";
    [Parameter] public IReadOnlyList<EntityCreditViewModel> Credits { get; set; } = [];
}
