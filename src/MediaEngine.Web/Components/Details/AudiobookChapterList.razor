@namespace MediaEngine.Web.Components.Details
@using System.Globalization
@using MediaEngine.Contracts.Details
@using MediaEngine.Contracts.Playback
@using MediaEngine.Web.Services.Playback
@inject PlaybackSessionController Playback

@{
    var rows = ChapterRows;
}

@if (rows.Count > 0)
{
    <section class="tl-audiobook-chapters" aria-label="@($"{AudiobookTitle} chapters")">
        <div class="tl-audiobook-chapters__header">
            <div>
                <h2>Chapters</h2>
                <p>@rows.Count chapter@(rows.Count == 1 ? string.Empty : "s") available in the player</p>
            </div>
        </div>

        <div class="tl-audiobook-chapters__list">
            @foreach (var row in rows)
            {
                var isPlaying = row.IsCurrent && Playback.IsPlaying && !Playback.NeedsUserGestureToStart;
                var statusLabel = StatusLabelFor(row, isPlaying);
                <AppNativeButton Type="button"
                                 Class="@($"tl-audiobook-chapters__row {(row.IsCurrent ? "is-current" : null)} {(row.IsIntro ? "is-intro" : null)}")"
                                 OnClick="@(() => ActivateChapterAsync(row))"
                                 Disabled="@(!row.Item.IsOwned)"
                                 AriaLabel="@ActionLabel(row.Chapter, row.IsCurrent, isPlaying)"
                                 title="@ActionLabel(row.Chapter, row.IsCurrent, isPlaying)">
                    <span class="tl-audiobook-chapters__copy">
                        <strong>@row.Chapter.Title</strong>
                        @if (!string.IsNullOrWhiteSpace(row.SubtitleLabel))
                        {
                            <span>@row.SubtitleLabel</span>
                        }
                    </span>
                    <span class="tl-audiobook-chapters__status">
                        @if (row.IsCurrent)
                        {
                            <span class="@($"tl-audiobook-chapters__equalizer {(isPlaying ? "is-playing" : null)}")" aria-hidden="true">
                                <span></span>
                                <span></span>
                                <span></span>
                            </span>
                        }
                        <span>@statusLabel</span>
                    </span>
                    <span class="tl-audiobook-chapters__duration">@row.DurationLabel</span>
                    <span class="tl-audiobook-chapters__action" aria-hidden="true">
                        <MudIcon Icon="@(isPlaying ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)" Class="tl-u-font-size-24px" />
                    </span>
                </AppNativeButton>
            }
        </div>
    </section>
}

@code {
    [Parameter] public IReadOnlyList<MediaGroupingViewModel> Groups { get; set; } = [];
    [Parameter] public string AudiobookTitle { get; set; } = "Audiobook";
    [Parameter] public string? AudiobookArtworkUrl { get; set; }

    private IReadOnlyList<MediaGroupingItemViewModel> ChapterItems =>
        Groups.SelectMany(group => group.Items)
            .Where(item => item.EntityType == DetailEntityType.Audiobook)
            .OrderBy(item => item.StartSeconds ?? double.MaxValue)
            .ThenBy(item => item.ChapterIndex ?? int.MaxValue)
            .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private IReadOnlyList<ChapterRow> ChapterRows => BuildChapterRows(ChapterItems);

    private IReadOnlyList<ChapterRow> BuildChapterRows(IReadOnlyList<MediaGroupingItemViewModel> items)
    {
        var rows = new List<ChapterRow>(items.Count);

        for (var ordinal = 0; ordinal < items.Count; ordinal++)
        {
            var item = items[ordinal];
            var chapter = ToPlaybackChapter(item, ordinal);
            var isIntro = IsIntroChapter(item, chapter);
            var isCurrent = IsCurrentChapter(item);

            rows.Add(new ChapterRow(
                item,
                chapter,
                DisplayDuration(item, chapter),
                ProgressLabelFor(item),
                string.Empty,
                isCurrent,
                isIntro));
        }

        return rows;
    }

    private Task ActivateChapterAsync(ChapterRow row)
    {
        if (!row.Item.IsOwned)
        {
            return Task.CompletedTask;
        }

        if (row.IsCurrent)
        {
            return Playback.RequestTransportCommandAsync(new("toggle-play"));
        }

        return Playback.PlayAudiobookChapterAsync(ToQueueItem(row), row.Chapter, AudiobookTitle);
    }

    private ListenQueueItem ToQueueItem(ChapterRow row) => new()
    {
        WorkId = ItemId(row.Item),
        AssetId = Guid.TryParse(row.Item.AssetId, out var assetId) ? assetId : null,
        MediaType = "Audiobooks",
        Title = AudiobookTitle,
        Subtitle = row.Chapter.Title,
        Album = AudiobookTitle,
        CoverUrl = row.Item.ArtworkUrl ?? AudiobookArtworkUrl,
        Duration = row.DurationLabel,
        InitialPositionSeconds = row.Chapter.StartSeconds,
        Chapters = ChapterRows.Select(chapterRow => chapterRow.Chapter).ToList(),
        ChapterIndex = row.Chapter.Index,
        StartAtExactPosition = true,
    };

    private PlaybackChapterDto ToPlaybackChapter(MediaGroupingItemViewModel item, int ordinal) => new()
    {
        Index = ordinal,
        Title = string.IsNullOrWhiteSpace(item.Title) ? PlaybackSessionController.CleanChapterTitle(item.Title, ordinal) : item.Title.Trim(),
        StartSeconds = Math.Max(0, item.StartSeconds ?? 0),
        EndSeconds = item.EndSeconds,
    };

    private PlaybackChapterDto ToPlaybackChapter(MediaGroupingItemViewModel item) =>
        ToPlaybackChapter(item, ChapterOrdinal(item));

    private int ChapterOrdinal(MediaGroupingItemViewModel item)
    {
        for (var index = 0; index < ChapterItems.Count; index++)
        {
            if (ReferenceEquals(ChapterItems[index], item) || ChapterItems[index].Id == item.Id && ChapterItems[index].StartSeconds == item.StartSeconds)
            {
                return index;
            }
        }

        return Math.Max(0, item.ChapterIndex ?? 0);
    }

    private static bool IsIntroChapter(MediaGroupingItemViewModel item, PlaybackChapterDto chapter) =>
        item.ChapterIndex == 0
        && string.Equals(chapter.Title, "Intro", StringComparison.OrdinalIgnoreCase)
        && chapter.StartSeconds <= 5;

    private static string ActionLabel(PlaybackChapterDto chapter, bool isCurrent, bool isPlaying) =>
        isCurrent
            ? isPlaying ? $"Pause {chapter.Title}" : $"Resume {chapter.Title}"
            : $"Play {chapter.Title}";

    private bool IsCurrentChapter(MediaGroupingItemViewModel item)
    {
        if (!Playback.IsAudiobookMode || Playback.CurrentItem is null)
        {
            return false;
        }

        if (Guid.TryParse(item.AssetId, out var assetId)
            && Playback.CurrentItem.AssetId.HasValue
            && Playback.CurrentItem.AssetId.Value != assetId)
        {
            return false;
        }

        if (!item.StartSeconds.HasValue)
        {
            return false;
        }

        var current = Playback.CurrentTimeSeconds;
        return current >= item.StartSeconds.Value - 0.5d
            && (!item.EndSeconds.HasValue || current < item.EndSeconds.Value - 0.5d);
    }

    private static string DisplayDuration(MediaGroupingItemViewModel item, PlaybackChapterDto chapter)
    {
        if (chapter.EndSeconds is > 0 && chapter.EndSeconds.Value > chapter.StartSeconds)
        {
            return FormatTimestamp(chapter.EndSeconds.Value - chapter.StartSeconds);
        }

        if (item.DurationSeconds is > 0)
        {
            return FormatTimestamp(item.DurationSeconds.Value);
        }

        return item.Duration ?? string.Empty;
    }

    private static string FormatTimestamp(double seconds)
    {
        var span = TimeSpan.FromSeconds(Math.Max(0, seconds));
        return span.TotalHours >= 1
            ? span.ToString(@"h\:mm\:ss", CultureInfo.InvariantCulture)
            : span.ToString(@"m\:ss", CultureInfo.InvariantCulture);
    }

    private static string ProgressLabelFor(MediaGroupingItemViewModel item)
    {
        if (!item.ProgressPercent.HasValue)
        {
            return string.Empty;
        }

        var percent = Math.Clamp(item.ProgressPercent.Value, 0d, 100d);
        if (percent <= 0)
        {
            return string.Empty;
        }

        if (percent >= 99.5d)
        {
            return "Done";
        }

        if (percent < 1d)
        {
            return "Started";
        }

        var rounded = Math.Clamp((int)Math.Round(percent, MidpointRounding.AwayFromZero), 1, 99);
        return $"{rounded}% listened";
    }

    private static string StatusLabelFor(ChapterRow row, bool isPlaying)
    {
        if (!row.IsCurrent)
        {
            return row.StatusLabel;
        }

        return isPlaying ? "Now playing" : "Current position";
    }

    private static Guid ItemId(MediaGroupingItemViewModel item) =>
        Guid.TryParse(item.Id, out var id) ? id : Guid.Empty;

    private sealed record ChapterRow(
        MediaGroupingItemViewModel Item,
        PlaybackChapterDto Chapter,
        string DurationLabel,
        string StatusLabel,
        string SubtitleLabel,
        bool IsCurrent,
        bool IsIntro);
}
