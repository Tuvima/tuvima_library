@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<AudioItemTable Groups="Groups"
                SourceTitle="@AudiobookTitle"
                ArtworkUrl="@AudiobookArtworkUrl"
                IsAudiobook="true" />

@code {
    [Parameter] public IReadOnlyList<MediaGroupingViewModel> Groups { get; set; } = [];
    [Parameter] public string AudiobookTitle { get; set; } = "Audiobook";
    [Parameter] public string? AudiobookArtworkUrl { get; set; }
}
