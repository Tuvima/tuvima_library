@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<div class="tl-detail-tab-panel tl-overview-surface @(Model.EntityType == DetailEntityType.Person ? "tl-overview-surface--person" : "tl-overview-surface--media")">
    @if (Model.EntityType == DetailEntityType.Person && Model.PersonDetails is not null)
    {
        <section class="tl-overview-section tl-overview-section--copy">
            <header class="tl-overview-section__heading">
                <span>Biography</span>
            </header>
            @if (!string.IsNullOrWhiteSpace(PersonOverviewDescription))
            {
                <div class="tl-overview-section__prose">
                    @foreach (var paragraph in OverviewParagraphs(PersonOverviewDescription))
                    {
                        <p>@paragraph</p>
                    }
                    <DescriptionAttribution Attribution="Model.DescriptionAttribution" />
                </div>
            }
            else
            {
                <p class="tl-overview-section__empty">No biography is available yet.</p>
            }
        </section>

        <aside class="tl-overview-section tl-overview-section--secondary tl-overview-section--facts">
            <header class="tl-overview-section__heading">
                <span>Details</span>
            </header>
            @if (QuickFacts.Count > 0)
            {
                <dl class="tl-overview-facts">
                    @foreach (var fact in QuickFacts)
                    {
                        <div>
                            <dt>@fact.Label</dt>
                            <dd>@fact.Value</dd>
                        </div>
                    }
                </dl>
            }

            @if (RelatedPeople.Count > 0)
            {
                <div class="tl-overview-linked-people">
                    <h3>Linked people</h3>
                    @foreach (var person in RelatedPeople)
                    {
                        <a class="tl-detail-person-related" href="@person.Route">
                            <span>@person.Name</span>
                            @if (!string.IsNullOrWhiteSpace(person.Subtitle))
                            {
                                <small>@person.Subtitle</small>
                            }
                        </a>
                    }
                </div>
            }
        </aside>
    }
    else
    {
        <section class="tl-overview-section tl-overview-section--copy">
            <header class="tl-overview-section__heading">
                <span>Overview</span>
            </header>
            @if (OverviewDescriptionParagraphs.Count == 0)
            {
                <p class="tl-overview-section__empty">No overview is available yet.</p>
            }
            else
            {
                <div class="tl-overview-section__prose">
                    @foreach (var paragraph in OverviewDescriptionParagraphs)
                    {
                        <p>@paragraph</p>
                    }
                </div>
                <DescriptionAttribution Attribution="Model.DescriptionAttribution" Compact="true" />
            }
        </section>

        <aside class="tl-overview-section tl-overview-section--secondary tl-overview-section--credits">
            <header class="tl-overview-section__heading">
                <span>@CreditPanelTitle</span>
                @if (OverviewCreditRows.Count > 0)
                {
                    <AppNativeButton Type="button"
                                     Class="tl-overview-section__credits-link"
                                     OnClick="@(() => OnTabRequested.InvokeAsync(CreditTabKey))">
                        View full @CreditPanelTitle.ToLowerInvariant()
                        <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Size="Size.Small" />
                    </AppNativeButton>
                }
            </header>
            @if (OverviewCreditRows.Count == 0)
            {
                <p class="tl-overview-section__empty">No linked people are available yet.</p>
            }
            else
            {
                <div class="tl-overview-credit-rows">
                    @foreach (var credit in OverviewCreditRows)
                    {
                        <PersonCreditCard Credit="credit" Compact="true" />
                    }
                </div>
            }
        </aside>
    }
</div>

@code {
    [Parameter, EditorRequired] public DetailPageViewModel Model { get; set; } = default!;
    [Parameter] public EventCallback<string> OnTabRequested { get; set; }
    [Parameter] public EventCallback<SequenceContainerOptionViewModel> OnContainerSelected { get; set; }

    private bool _creditsExpanded;

    private bool IsCanonicalSeriesContainer => Model.EntityType is DetailEntityType.MovieSeries
        or DetailEntityType.BookSeries
        or DetailEntityType.ComicSeries;

    private string? PersonOverviewDescription => Model.PersonDetails?.Biography ?? Model.Description;

    private bool ShowSeriesDescription =>
        !string.IsNullOrWhiteSpace(Model.SequencePlacement?.ContainerDescription)
        && !string.Equals(
            Model.SequencePlacement.ContainerDescription.Trim(),
            Model.Description?.Trim(),
            StringComparison.Ordinal);

    private IReadOnlyList<string> OverviewDescriptionParagraphs
    {
        get
        {
            var paragraphs = new List<string>();
            if (ShowSeriesDescription)
                paragraphs.AddRange(OverviewParagraphs(Model.SequencePlacement?.ContainerDescription));

            paragraphs.AddRange(OverviewParagraphs(Model.Description));
            return paragraphs
                .Where(paragraph => !string.IsNullOrWhiteSpace(paragraph))
                .Distinct(StringComparer.Ordinal)
                .Take(4)
                .ToList();
        }
    }

    private sealed record OverviewCreditGroup(string Title, IReadOnlyList<EntityCreditViewModel> Credits, int TotalCount);

    private string CreditPanelTitle => Model.EntityType switch
    {
        DetailEntityType.Movie or DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "Cast",
        _ => "Credits",
    };

    private string CreditTabKey => IsVideo ? "cast" : "credits";

    private IReadOnlyList<EntityCreditViewModel> OverviewCreditRows =>
        OverviewCreditGroups
            .SelectMany(group => group.Credits)
            .GroupBy(
                credit => string.IsNullOrWhiteSpace(credit.EntityId)
                    ? $"{credit.DisplayName}:{credit.PrimaryRole}"
                    : credit.EntityId,
                StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .Take(IsVideo ? 4 : 3)
            .ToList();

    private IReadOnlyList<(string Label, string Value)> QuickFacts
    {
        get
        {
            var person = Model.PersonDetails;
            if (person is null)
                return [];

            var facts = new List<(string Label, string Value)>();
            AddFact(facts, "Born", JoinLines(FormatDateLabel(person.DateOfBirth), person.PlaceOfBirth));
            AddFact(facts, "Died", JoinLines(FormatDateLabel(person.DateOfDeath), person.PlaceOfDeath));
            AddFact(facts, "Occupation", person.Occupation);
            AddFact(facts, "Roles", person.Roles.Count == 0 ? null : string.Join(", ", person.Roles));
            AddFact(facts, "Nationality", person.Nationality);
            AddFact(facts, "Identity", person.IsGroup ? "Group" : person.IsPseudonym ? "Pseudonym" : null);
            return facts;
        }
    }

    private IReadOnlyList<PersonRelatedLink> RelatedPeople
    {
        get
        {
            var person = Model.PersonDetails;
            if (person is null)
                return [];

            return person.Aliases
                .Concat(person.IsGroup ? person.GroupMembers : person.MemberOfGroups)
                .Where(item => !string.IsNullOrWhiteSpace(item.Route))
                .ToList();
        }
    }

    private IReadOnlyList<OverviewCreditGroup> OverviewCreditGroups
    {
        get
        {
            if (IsVideo)
                return BuildVideoCreditGroups();
            if (IsBookish)
                return BuildPrimaryThenExpandableGroups(
                    new HashSet<CreditGroupType> { CreditGroupType.Authors, CreditGroupType.Narrators },
                    new HashSet<CreditGroupType> { CreditGroupType.Authors, CreditGroupType.Narrators });
            if (IsComic)
                return BuildPrimaryThenExpandableGroups(
                    new HashSet<CreditGroupType> { CreditGroupType.Writers, CreditGroupType.Illustrators },
                    new HashSet<CreditGroupType> { CreditGroupType.Writers, CreditGroupType.Illustrators, CreditGroupType.CreativeTeam });

            return Model.ContributorGroups
                .Select(group =>
                {
                    var count = ShouldShowAllOverviewCredits ? group.Credits.Count : group.InitialVisibleCount;
                    return ToOverviewGroup(group, group.Credits.Take(count).ToList());
                })
                .Where(group => group.Credits.Count > 0)
                .ToList();
        }
    }

    private bool IsVideo => Model.EntityType is DetailEntityType.Movie or DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode;
    private bool IsTv => Model.EntityType is DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode;
    private bool IsBookish => Model.EntityType is DetailEntityType.Book or DetailEntityType.Audiobook or DetailEntityType.Work;
    private bool IsComic => Model.EntityType is DetailEntityType.ComicIssue or DetailEntityType.ComicSeries;
    private bool ShowCreditsHeader => !IsBookish && !IsVideo;
    private bool ShowCreditCounts => !IsBookish && !IsVideo;
    private string OverviewCreditsListClass => $"tl-media-overview-credits-list{(IsBookish ? " tl-media-overview-credits-list--bookish" : string.Empty)}{(IsVideo ? " tl-media-overview-credits-list--video" : string.Empty)}";

    private bool ShowCastTabLink => IsVideo
        && (TotalCredits(CreditGroupType.Cast) > 0 || Model.CharacterGroups.Count > 0);

    private bool ShowInlineCreditsToggle => !IsVideo && HiddenOverviewCreditCount > 0;

    private bool ShouldShowAllOverviewCredits => !IsVideo && RawHiddenOverviewCreditCount <= 1;

    private int HiddenOverviewCreditCount
        => _creditsExpanded || ShouldShowAllOverviewCredits ? 0 : RawHiddenOverviewCreditCount;

    private int RawHiddenOverviewCreditCount
    {
        get
        {
            if (IsBookish)
                return Model.ContributorGroups.Where(group => group.GroupType is not CreditGroupType.Authors and not CreditGroupType.Narrators).Sum(group => group.Credits.Count);
            if (IsComic)
                return Model.ContributorGroups.Where(group => group.GroupType is not CreditGroupType.Writers and not CreditGroupType.Illustrators).Sum(group => group.Credits.Count);

            return Model.ContributorGroups.Sum(group => Math.Max(0, group.Credits.Count - group.InitialVisibleCount));
        }
    }

    private IReadOnlyList<OverviewCreditGroup> BuildVideoCreditGroups()
    {
        var groups = new List<OverviewCreditGroup>();
        var directors = IsTv ? [] : CreditsFor(CreditGroupType.Directors).Take(2).ToList();
        if (directors.Count > 0)
            groups.Add(new OverviewCreditGroup("Director", directors, TotalCredits(CreditGroupType.Directors)));

        var cast = CreditsFor(CreditGroupType.Cast).Take(8).ToList();
        if (cast.Count > 0)
            groups.Add(new OverviewCreditGroup("Cast", cast, TotalCredits(CreditGroupType.Cast)));

        return groups;
    }

    private string OverviewCreditGroupClass(OverviewCreditGroup group)
    {
        var classes = "tl-overview-credit-group";
        if (IsVideo && string.Equals(group.Title, "Director", StringComparison.OrdinalIgnoreCase))
            classes += " tl-overview-credit-group--director";
        if (IsVideo && string.Equals(group.Title, "Cast", StringComparison.OrdinalIgnoreCase))
            classes += " tl-overview-credit-group--cast";
        return classes;
    }

    private IReadOnlyList<OverviewCreditGroup> BuildPrimaryThenExpandableGroups(
        IReadOnlySet<CreditGroupType> primaryTypes,
        IReadOnlySet<CreditGroupType> collapsedTypes)
    {
        var showAllCredits = _creditsExpanded || ShouldShowAllOverviewCredits;
        IReadOnlySet<CreditGroupType> visibleTypes = showAllCredits
            ? Model.ContributorGroups.Select(group => group.GroupType).ToHashSet()
            : collapsedTypes;

        return Model.ContributorGroups
            .Where(group => visibleTypes.Contains(group.GroupType))
            .OrderBy(group => primaryTypes.Contains(group.GroupType) ? 0 : 1)
            .ThenBy(group => group.DisplayPriority)
            .ThenBy(group => group.Title, StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var count = showAllCredits || primaryTypes.Contains(group.GroupType)
                    ? group.Credits.Count
                    : group.InitialVisibleCount;
                return ToOverviewGroup(group, group.Credits.Take(count).ToList());
            })
            .Where(group => group.Credits.Count > 0)
            .ToList();
    }

    private OverviewCreditGroup ToOverviewGroup(CreditGroupViewModel group, IReadOnlyList<EntityCreditViewModel> credits)
        => new(group.Title, credits, group.Credits.Count);

    private IReadOnlyList<EntityCreditViewModel> CreditsFor(CreditGroupType type)
        => Model.ContributorGroups
            .Where(group => group.GroupType == type)
            .SelectMany(group => group.Credits)
            .OrderBy(credit => credit.SortOrder)
            .ToList();

    private int TotalCredits(CreditGroupType type)
        => Model.ContributorGroups.Where(group => group.GroupType == type).Sum(group => group.Credits.Count);

    private void ToggleCreditsExpanded() => _creditsExpanded = !_creditsExpanded;

    private static void AddFact(List<(string Label, string Value)> facts, string label, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
            facts.Add((label, value));
    }

    private static string? JoinLines(params string?[] values)
    {
        var parts = values.Where(value => !string.IsNullOrWhiteSpace(value)).ToList();
        return parts.Count == 0 ? null : string.Join("\n", parts);
    }

    private static string? FormatDateLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;
        return DateTimeOffset.TryParse(value, out var parsed)
            ? parsed.ToString("MMM d, yyyy", System.Globalization.CultureInfo.InvariantCulture)
            : value;
    }

    private static IReadOnlyList<string> OverviewParagraphs(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return [];

        var normalized = value
            .Replace("\\r\\n", "\n", StringComparison.Ordinal)
            .Replace("\\n", "\n", StringComparison.Ordinal)
            .Replace("\r\n", "\n", StringComparison.Ordinal)
            .Replace('\r', '\n')
            .Replace("<br />", "\n", StringComparison.OrdinalIgnoreCase)
            .Replace("<br/>", "\n", StringComparison.OrdinalIgnoreCase)
            .Replace("<br>", "\n", StringComparison.OrdinalIgnoreCase);

        var paragraphs = normalized
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(paragraph => !string.IsNullOrWhiteSpace(paragraph))
            .ToList();

        return paragraphs.Count == 1 && paragraphs[0].Length > 900
            ? SplitLongParagraph(paragraphs[0])
            : paragraphs;
    }

    private static IReadOnlyList<string> SplitLongParagraph(string value)
    {
        var sentences = System.Text.RegularExpressions.Regex
            .Split(value, @"(?<=\.)\s+")
            .Select(sentence => sentence.Trim())
            .Where(sentence => sentence.Length > 0)
            .ToList();

        var paragraphs = new List<string>();
        var current = new System.Text.StringBuilder();
        foreach (var sentence in sentences)
        {
            if (current.Length > 0 && current.Length + sentence.Length > 520)
            {
                paragraphs.Add(current.ToString().Trim());
                current.Clear();
            }

            if (current.Length > 0)
                current.Append(' ');

            current.Append(sentence);
        }

        if (current.Length > 0)
            paragraphs.Add(current.ToString().Trim());

        return paragraphs;
    }
}
