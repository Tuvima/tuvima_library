@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details
@using MediaEngine.Contracts.Settings
@using MediaEngine.Web.Services.Integration
@using System.Globalization
@using Microsoft.JSInterop
@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject IJSRuntime Js

<section class="tl-series-placement @PanelClass">
    <div class="tl-series-layout">
    <aside class="tl-series-header">
        @if (Compact)
        {
            <div class="tl-series-eyebrow">
                <span>@HeadingLabel</span>
                <small>@HeadingValue</small>
            </div>
        }
        else
        {
        <div class="tl-series-controls">
            <div class="tl-series-heading">
                @if (IsSeasonContainer)
                {
                    <a class="tl-series-show-link" href="@ShowDetailRoute">@ContainerTitleDisplay</a>
                    <span aria-hidden="true">:</span>
                    <strong>@HeadingValue</strong>
                }
                else
                {
                    <span>@HeadingLabel:</span>
                    <strong>@HeadingValue</strong>
                }
            </div>
            @if (CanChooseDistinctContainer)
            {
                <div class="tl-series-control-row">
                    <AppSelect Value="@SelectedContainerValue"
                               ValueChanged="SelectContainerValueAsync"
                               Options="@ContainerSelectOptions"
                               LeadingIcon="@Icons.Material.Outlined.Layers"
                               Size="AppControlSize.Large"
                               Class="tl-series-control tl-series-control--set"
                               PopoverClass="app-select__popover tl-series-select-popover"
                               aria-label="Choose series" />
                    @if (ShowSetDefault)
                    {
                        <div class="tl-series-default-control">
                            <AppNativeButton Type="button" Class="tl-series-default-action" Disabled="@_settingDefault" OnClick="SetDefaultSequenceAsync">
                                <MudIcon Icon="@Icons.Material.Outlined.StarOutline" Size="Size.Small" />
                                <span>Make default</span>
                            </AppNativeButton>
                            <small>Use as your default series</small>
                        </div>
                    }
                </div>
            }
            @if (ShowGroupSelector)
            {
                <AppSelect Value="@SelectedGroupKey"
                           ValueChanged="SelectGroup"
                           Options="@GroupSelectOptions"
                           Size="AppControlSize.Large"
                           Class="tl-series-control tl-series-control--group"
                           PopoverClass="app-select__popover tl-series-select-popover"
                           aria-label="@GroupSelectorAriaLabel" />
            }
        </div>
        }

        <div class="tl-series-position-summary" aria-label="@PositionSummary">
            <div class="@CoverageVisualClass">
                @if (ShowCoverageDonut)
                {
                    <MudChart T="double"
                              ChartType="ChartType.Donut"
                              ChartSeries="@SequenceDonutSeries"
                              ChartLabels="@SequenceDonutLabels"
                              ChartOptions="@SequenceDonutOptions"
                              Width="8.8rem"
                              Height="8.8rem" />
                }
                <div class="@CoverageCenterClass">
                    @if (IsComicSequence && HasCurrentPosition)
                    {
                        <span class="tl-series-position-summary__total">@CoverageSecondaryText</span>
                        <span class="tl-series-position-summary__number">@CoveragePrimaryText</span>
                    }
                    else
                    {
                        <span class="tl-series-position-summary__number">@CoveragePrimaryText</span>
                        <span class="tl-series-position-summary__total">@CoverageSecondaryText</span>
                    }
                </div>
            </div>
        </div>

        @if (!IsSeasonContainer && SeriesDateRange is not null)
        {
            <div class="tl-series-date-range">
                <MudIcon Icon="@Icons.Material.Outlined.CalendarMonth" Size="Size.Small" />
                <span>@SeriesDateRange</span>
            </div>
        }

        @if (!Compact && !IsSeasonContainer && !string.IsNullOrWhiteSpace(Placement.ContainerDescription))
        {
            <p class="tl-series-description">@Placement.ContainerDescription</p>
        }

        @if (!Compact && IsSeasonContainer && !string.IsNullOrWhiteSpace(Placement.ContainerDescription))
        {
            <section class="tl-series-information" aria-labelledby="series-description-heading">
                <h2 id="series-description-heading"><span>Series Description</span></h2>
                <p id="series-description-copy" class="@SeriesDescriptionClass" @ref="_seriesDescriptionElement">@Placement.ContainerDescription</p>
                @if (HasExpandableSeriesDescription)
                {
                    <AppNativeButton Type="button"
                                     Class="tl-series-information__toggle"
                                     AdditionalAttributes="SeriesDescriptionToggleAttributes"
                                     OnClick="ToggleSeriesDescription">
                        @(_seriesDescriptionExpanded ? "Less" : "More")
                    </AppNativeButton>
                }
            </section>
        }

        <div class="tl-series-owned-summary">
            <MudIcon Icon="@Icons.Material.Outlined.Layers" Size="Size.Small" />
            <span>@OwnedSummary</span>
            @if (ShowCoverageDonut)
            {
                <span class="tl-series-owned-summary__dot" aria-hidden="true"></span>
                <span>@MissingCount missing</span>
            }
            @if (SeriesWikidataUrl is not null)
            {
                <a class="tl-series-source-link"
                   href="@SeriesWikidataUrl"
                   target="_blank"
                   rel="noopener noreferrer"
                    aria-label="Open @SeriesWikidataQid on Wikidata in a new tab">
                    <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Size="Size.Small" />
                    <span>@SourceKindLabel: Wikidata (@SeriesWikidataQid)</span>
                </a>
            }
            @if (ComicVineSeriesUrl is not null)
            {
                <a class="tl-series-source-link"
                   href="@ComicVineSeriesUrl"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Open this comic series on Comic Vine in a new tab">
                    <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Size="Size.Small" />
                    <span>@SourceKindLabel: Comic Vine</span>
                </a>
            }
            @if (!string.IsNullOrWhiteSpace(Placement.ContainerWikipediaUrl))
            {
                <a class="tl-series-source-link"
                   href="@Placement.ContainerWikipediaUrl"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="Open the series article on Wikipedia in a new tab">
                    <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Size="Size.Small" />
                    <span>@SourceKindLabel: Wikipedia</span>
                </a>
            }
        </div>

    </aside>

    <div class="tl-series-content">
        @if (!Compact && (ShowJumpSelector || CanShowMissingToggle))
        {
            <div class="tl-series-content__toolbar">
                @if (ShowJumpSelector)
                {
                    <div class="tl-series-jump">
                        <AppSelect Label="Jump to"
                                   Value="@JumpSelectionValue"
                                   ValueChanged="SelectJump"
                                   Options="@JumpSelectOptions"
                                   Class="tl-series-control tl-series-control--jump"
                                   PopoverClass="app-select__popover tl-series-select-popover" />
                    </div>
                }
                @if (CanShowMissingToggle)
                {
                    <MudCheckBox T="bool"
                                 @bind-Value="_showMissing"
                                 Class="tl-series-show-missing"
                                 Color="Color.Primary"
                                 Dense="true"
                                 Label="Show Missing" />
                }
            </div>
        }

        <div class="tl-series-carousel">
        <AppIconButton Class="@LeftArrowClass"
                       Icon="@Icons.Material.Outlined.ChevronLeft"
                       Size="Size.Large"
                       aria-label="@($"Previous {Placement.ItemPluralLabel.ToLowerInvariant()}")"
                       Disabled="@(!CanPageLeft)"
                       OnClick="PageLeft" />
        <AppCssElement Tag="div" Class="tl-series-strip" Css="@SequenceGridStyle" aria-label="@($"{Placement.ContainerTitle} order")">
            @foreach (var item in VisibleItems)
            {
                var route = SequenceItemRoute(item);
                if (IsSeasonContainer)
                {
                    <article class="@SequenceItemClass(item)">
                        @SequenceItemContent(item)
                    </article>
                }
                else if (route is not null)
                {
                    <a class="@SequenceItemClass(item)" href="@route" aria-label="Open @SequenceItemTitle(item)">
                        @SequenceItemContent(item)
                    </a>
                }
                else
                {
                    <article class="@SequenceItemClass(item)">
                        @SequenceItemContent(item)
                    </article>
                }
            }
        </AppCssElement>
        <AppIconButton Class="@RightArrowClass"
                       Icon="@Icons.Material.Outlined.ChevronRight"
                       Size="Size.Large"
                       aria-label="@($"More {Placement.ItemPluralLabel.ToLowerInvariant()}")"
                       Disabled="@(!CanPageRight)"
                       OnClick="PageRight" />
        </div>

        @if (HasMoreConfiguredMissingItems)
        {
            <AppNativeButton Type="button"
                             Class="tl-series-load-missing"
                             OnClick="LoadMoreMissingItems">
                Load more missing @Placement.ItemPluralLabel.ToLowerInvariant()
            </AppNativeButton>
        }

    </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public SequencePlacementViewModel Placement { get; set; } = default!;
    [Parameter] public EventCallback<SequenceContainerOptionViewModel> OnContainerSelected { get; set; }
    [Parameter] public bool Compact { get; set; }

    private const int LongSequenceThreshold = 6;
    private const int WindowSize = 12;
    private string? _placementKey;
    private string? _selectedGroupKey;
    private string? _jumpSelectionValue;
    private int _windowCenterIndex;
    private bool _canCurateSequence;
    private bool _settingDefault;
    private bool _seriesDescriptionExpanded;
    private bool _hasExpandableSeriesDescription;
    private bool _needsSeriesDescriptionMeasurement = true;
    private bool _showMissing;
    private int _visibleMissingLimit;
    private MissingItemDisplayPolicy? _missingItemPolicy;
    private ElementReference _seriesDescriptionElement;

    private string PanelClass => $"{MediaShapeClass}{(IsLongSequence ? " tl-series-placement--long" : string.Empty)}{(Compact ? " tl-series-placement--compact" : string.Empty)}";
    private string MediaShapeClass => Placement.CurrentItem.EntityType switch
    {
        DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "tl-series-panel--landscape",
        DetailEntityType.MusicAlbum or DetailEntityType.MusicArtist or DetailEntityType.MusicTrack => "tl-series-panel--square",
        _ => "tl-series-panel--portrait",
    };

    private IReadOnlyList<SequenceGroupViewModel> VisibleGroups
    {
        get
        {
            if (Placement.Groups.Count == 0)
            {
                return [new SequenceGroupViewModel { Key = "all", Title = Placement.ItemPluralLabel, Items = Placement.OrderedItems }];
            }

            var nonEmptyGroups = Placement.Groups.Where(group => group.Items.Count > 0).ToList();
            var scopedGroups = nonEmptyGroups
                .Where(group => !string.Equals(group.Key, "all", StringComparison.OrdinalIgnoreCase))
                .ToList();
            return scopedGroups.Count > 0 ? scopedGroups : nonEmptyGroups;
        }
    }

    private bool ShowGroupSelector => VisibleGroups.Count > 1 && !string.IsNullOrWhiteSpace(Placement.GroupLabel);
    private bool IsSeasonContainer => string.Equals(Placement.GroupLabel, "Season", StringComparison.OrdinalIgnoreCase)
        && Placement.CurrentItem.EntityType is DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode;
    private string HeadingLabel => IsSeasonContainer ? "Season" : "Series";
    private string HeadingValue => IsSeasonContainer
        ? SeasonHeading
        : ContainerTitleDisplay;
    private string SeasonHeading
    {
        get
        {
            var title = ActiveGroup?.Title ?? Placement.GroupLabel ?? "Season";
            var year = ActiveItems
                .Select(item => SequenceYear(item.PublicationDate))
                .Where(value => value.HasValue)
                .Select(value => value!.Value)
                .OrderBy(value => value)
                .FirstOrDefault();
            return year > 0 ? $"{title} ({year})" : title;
        }
    }
    private string ShowDetailRoute => Guid.TryParse(Placement.ContainerId, out var showId)
        ? $"/watch/tv/show/{showId:D}"
        : "#";
    private string GroupSelectorAriaLabel => IsSeasonContainer ? "Choose season" : "Choose series section";
    private string SourceKindLabel => IsSeasonContainer ? "Show" : "Series";
    private bool HasExpandableSeriesDescription => _hasExpandableSeriesDescription;
    private string SeriesDescriptionClass => $"tl-series-information__copy{(_seriesDescriptionExpanded ? " is-expanded" : string.Empty)}";
    private IReadOnlyDictionary<string, object> SeriesDescriptionToggleAttributes => new Dictionary<string, object>
    {
        ["aria-controls"] = "series-description-copy",
        ["aria-expanded"] = _seriesDescriptionExpanded.ToString().ToLowerInvariant(),
    };
    private IReadOnlyList<AppSelectOption> GroupSelectOptions => VisibleGroups
        .Select(group => new AppSelectOption(group.Key, group.Title))
        .ToList();

    private string? SelectedGroupKey
    {
        get
        {
            if (VisibleGroups.Count == 0)
                return null;

            if (!string.IsNullOrWhiteSpace(_selectedGroupKey) && VisibleGroups.Any(group => group.Key == _selectedGroupKey))
                return _selectedGroupKey;

            _selectedGroupKey = !string.IsNullOrWhiteSpace(Placement.CurrentGroupKey)
                && VisibleGroups.Any(group => group.Key == Placement.CurrentGroupKey)
                    ? Placement.CurrentGroupKey
                    : VisibleGroups[0].Key;

            return _selectedGroupKey;
        }
    }

    private SequenceGroupViewModel? ActiveGroup
        => SelectedGroupKey is null
            ? null
            : VisibleGroups.FirstOrDefault(group => group.Key == SelectedGroupKey);

    private IReadOnlyList<SequenceItemViewModel> GroupItems
        => ShowGroupSelector
            ? ActiveGroup?.Items ?? []
            : Placement.OrderedItems;
    private IReadOnlyList<SequenceItemViewModel> ActiveItems => ApplyMissingItemPolicy(GroupItems);
    private bool CanShowMissingToggle => _missingItemPolicy?.Enabled == true
        && (Placement.Groups.Count > 0
            ? ActiveGroup?.HasAuthoritativeTotal == true
            : Placement.HasAuthoritativeTotal)
        && GroupItems.Any(item => !item.IsOwned);
    private bool UsesPagedMissingItems => string.Equals(
        _missingItemPolicy?.Presentation,
        "paged",
        StringComparison.OrdinalIgnoreCase);
    private bool HasMoreConfiguredMissingItems => CanShowMissingToggle
        && _showMissing
        && UsesPagedMissingItems
        && GroupItems.Count(item => !item.IsOwned) > _visibleMissingLimit;
    private bool IsLongSequence => TotalItems >= LongSequenceThreshold;
    private bool ShowJumpSelector => ActiveItems.Count > 5;
    private string? JumpSelectionValue => _jumpSelectionValue;
    private IReadOnlyList<AppSelectOption> JumpSelectOptions => ActiveItems
        .Select((item, index) => new AppSelectOption(
            index.ToString(CultureInfo.InvariantCulture),
            $"#{SequenceNumber(item)} — {SequenceItemTitle(item)}"))
        .ToList();
    private int OwnedCount => GroupItems.Count(item => item.IsOwned);
    private int MissingCount => Math.Max(0, TotalItems - OwnedCount);
    private bool IsComicSequence => Placement.CurrentItem.EntityType is DetailEntityType.ComicIssue or DetailEntityType.ComicSeries;
    private bool ShowCoverageDonut => !IsComicSequence && Placement.HasAuthoritativeTotal && TotalItems > 0;
    private int TotalItems => ShowGroupSelector
        ? Math.Max(GroupItems.Count, ActiveGroup?.TotalKnownItems ?? GroupItems.Count)
        : Math.Max(GroupItems.Count, Placement.TotalKnownItems ?? GroupItems.Count);
    private bool HasCurrentPosition => FirstNonBlank(
        Placement.PositionText,
        Placement.CurrentItem.PositionText,
        Placement.PositionLabel,
        Placement.CurrentItem.PositionLabel,
        Placement.PositionNumber?.ToString(CultureInfo.InvariantCulture),
        Placement.CurrentItem.PositionNumber?.ToString(CultureInfo.InvariantCulture),
        SequenceNumberOrNull(Placement.CurrentItem)) is not null;
    private string CurrentPositionText => FirstNonBlank(
        Placement.PositionText,
        Placement.CurrentItem.PositionText,
        Placement.PositionLabel,
        Placement.CurrentItem.PositionLabel,
        Placement.PositionNumber?.ToString(CultureInfo.InvariantCulture),
        Placement.CurrentItem.PositionNumber?.ToString(CultureInfo.InvariantCulture),
        SequenceNumberOrNull(Placement.CurrentItem),
        !HasCurrentPosition && TotalItems > 0 ? OwnedCount.ToString(CultureInfo.InvariantCulture) : null,
        "?")!;
    private string PositionSummary => FirstNonBlank(
        Placement.PositionSummary,
        !HasCurrentPosition && OwnedCount > 0 ? $"{OwnedSummary} in {LowerContainerLabel}" : null,
        HasCurrentPosition ? $"{ItemNoun} {CurrentPositionText} in {Placement.ContainerTitle}" : null,
        ContainerTitleDisplay)!;
    private string ContainerTitleDisplay => TitleCaseDisplay(Placement.ContainerTitle, Placement.ContainerLabel);
    private string LowerContainerLabel => FirstNonBlank(Placement.ContainerLabel, "sequence")!.ToLowerInvariant();
    private string SequenceGridStyle => $"--series-count:{Math.Max(1, VisibleItems.Count)};";
    private int VisibleCount => ActiveItems.Count <= WindowSize ? ActiveItems.Count : WindowSize;
    private int WindowStart => Math.Clamp(_windowCenterIndex - (VisibleCount / 2), 0, Math.Max(0, ActiveItems.Count - VisibleCount));
    private IReadOnlyList<SequenceItemViewModel> VisibleItems => ActiveItems.Skip(WindowStart).Take(VisibleCount).ToList();
    private bool CanPageLeft => WindowStart > 0;
    private bool CanPageRight => WindowStart + VisibleCount < ActiveItems.Count;
    private string LeftArrowClass => $"tl-series-carousel__arrow tl-series-carousel__arrow--left{(CanPageLeft ? string.Empty : " is-hidden")}";
    private string RightArrowClass => $"tl-series-carousel__arrow tl-series-carousel__arrow--right{(CanPageRight ? string.Empty : " is-hidden")}";
    private IReadOnlyList<SequenceContainerOptionViewModel> DistinctAvailableContainers => BuildDistinctContainerOptions(Placement.AvailableContainers);
    private bool CanChooseDistinctContainer => Placement.CanChooseContainer && DistinctAvailableContainers.Count > 1;
    private string? SelectedContainerValue => DistinctAvailableContainers.FirstOrDefault(option => option.IsSelected)?.ContainerId
        ?? Placement.SelectedContainerId;
    private IReadOnlyList<AppSelectOption> ContainerSelectOptions => DistinctAvailableContainers
        .Select(option => new AppSelectOption(option.ContainerId, option.ContainerTitle))
        .ToList();
    private bool ShowSetDefault => _canCurateSequence && CanChooseDistinctContainer && Placement.CanSetDefaultContainer && !string.IsNullOrWhiteSpace(Placement.SelectedContainerId);
    private string CoverageVisualClass => $"tl-series-position-summary__donut{(ShowCoverageDonut ? string.Empty : " is-count-only")}";
    private string CoverageCenterClass => $"tl-series-position-summary__center{(!ShowCoverageDonut ? " is-stacked" : string.Empty)}{(IsComicSequence && HasCurrentPosition ? " is-comic-position" : string.Empty)}";
    private string CoveragePrimaryText => ShowCoverageDonut
        ? OwnedCount.ToString(CultureInfo.InvariantCulture)
        : IsComicSequence && HasCurrentPosition
            ? CurrentPositionText
            : OwnedCount.ToString(CultureInfo.InvariantCulture);
    private string CoverageSecondaryText => ShowCoverageDonut
        ? $"of {TotalItems}"
        : IsComicSequence && HasCurrentPosition
            ? ItemNoun.ToLowerInvariant()
            : "owned";
    private string OwnedSummary => $"{OwnedCount} {(OwnedCount == 1 ? ItemNoun : Placement.ItemPluralLabel).ToLowerInvariant()} owned";
    private List<ChartSeries<double>> SequenceDonutSeries =>
    [
        new() { Name = Placement.ItemPluralLabel, Data = new ChartData<double>([Math.Max(OwnedCount, 0), Math.Max(MissingCount, 0)]) },
    ];
    private string[] SequenceDonutLabels => ["Owned", "Missing"];
    private DonutChartOptions SequenceDonutOptions { get; } = new()
    {
        ShowLegend = false,
        ShowToolTips = false,
        DonutRingRatio = 0.42,
        ChartPalette = ["#3F94F6", "#5E43D6"],
    };
    private string MissingIcon => Placement.CurrentItem.EntityType switch
    {
        DetailEntityType.Movie or DetailEntityType.MovieSeries or DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => Icons.Material.Outlined.Movie,
        DetailEntityType.MusicAlbum or DetailEntityType.MusicArtist or DetailEntityType.MusicTrack => Icons.Material.Outlined.Album,
        _ => Icons.Material.Outlined.MenuBook,
    };
    private string ItemNoun => FirstNonBlank(Placement.ItemLabel, "Item")!;
    private string CurrentItemBadge => $"This {ItemNoun.ToLowerInvariant()}";
    private string? SeriesDateRange
    {
        get
        {
            var years = ActiveItems
                .Select(item => SequenceYear(item.PublicationDate))
                .Where(year => year.HasValue)
                .Select(year => year!.Value)
                .Distinct()
                .OrderBy(year => year)
                .ToList();
            if (years.Count == 0)
                return null;
            return years.Count == 1 ? years[0].ToString() : $"{years[0]} – {years[^1]}";
        }
    }
    private string? SeriesWikidataQid => ResolveSeriesWikidataQid();
    private string? SeriesWikidataUrl => SeriesWikidataQid is { } qid
        ? $"https://www.wikidata.org/wiki/{qid}"
        : null;
    private string? ComicVineSeriesUrl
    {
        get
        {
            if (!IsComicSequence)
                return null;

            var providerIdentity = DistinctAvailableContainers
                .Where(option => option.IsSelected || ContainerOptionMatches(option, Placement.SelectedContainerId))
                .SelectMany(option => new[] { option.ContainerId, option.SourceContainerId }.Concat(option.EquivalentContainerIds))
                .FirstOrDefault(identity => identity?.StartsWith("comicvine:volume:", StringComparison.OrdinalIgnoreCase) == true);
            var volumeId = providerIdentity?.Split(':', StringSplitOptions.RemoveEmptyEntries).LastOrDefault();
            return long.TryParse(volumeId, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsedVolumeId)
                ? $"https://comicvine.gamespot.com/volume/4050-{parsedVolumeId}/"
                : null;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var key = $"{Placement.ContainerId}:{Placement.CurrentItem.Id}:{Placement.OrderedItems.Count}:{Placement.Groups.Count}:{Placement.ContainerDescription}";
        if (!string.Equals(key, _placementKey, StringComparison.Ordinal))
        {
            _placementKey = key;
            _selectedGroupKey = Placement.CurrentGroupKey;
            _seriesDescriptionExpanded = false;
            _hasExpandableSeriesDescription = false;
            _needsSeriesDescriptionMeasurement = true;
            var preferences = await ApiClient.GetLibraryPreferencesAsync();
            _missingItemPolicy = preferences is not null
                && preferences.MissingItemDisplay.TryGetValue(ResolveMediaPolicyKey(), out var policy)
                    ? policy
                    : null;
            _showMissing = string.Equals(
                _missingItemPolicy?.DefaultVisibility,
                "shown",
                StringComparison.OrdinalIgnoreCase);
            _visibleMissingLimit = _missingItemPolicy?.PageSize ?? 0;
            ResetWindowToCurrentItem();
        }

        var profile = await Orchestrator.GetActiveProfileAsync();
        _canCurateSequence = profile?.Role is "Administrator" or "Curator";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_needsSeriesDescriptionMeasurement
            || Compact
            || !IsSeasonContainer
            || string.IsNullOrWhiteSpace(Placement.ContainerDescription))
        {
            return;
        }

        _needsSeriesDescriptionMeasurement = false;
        var hasOverflow = await Js.InvokeAsync<bool>("isElementContentOverflowing", _seriesDescriptionElement);
        if (_hasExpandableSeriesDescription != hasOverflow)
        {
            _hasExpandableSeriesDescription = hasOverflow;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleSeriesDescription()
        => _seriesDescriptionExpanded = !_seriesDescriptionExpanded;

    private void SelectGroup(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        _selectedGroupKey = value;
        _visibleMissingLimit = _missingItemPolicy?.PageSize ?? 0;
        ResetWindowToCurrentItem();
    }

    private IReadOnlyList<SequenceItemViewModel> ApplyMissingItemPolicy(
        IReadOnlyList<SequenceItemViewModel> source)
    {
        if (!CanShowMissingToggle || !_showMissing)
            return source.Where(item => item.IsOwned).ToList();

        if (!UsesPagedMissingItems)
            return source;

        var missingRemaining = Math.Max(0, _visibleMissingLimit);
        return source.Where(item => item.IsOwned || missingRemaining-- > 0).ToList();
    }

    private void LoadMoreMissingItems()
    {
        _visibleMissingLimit += _missingItemPolicy?.PageSize ?? 0;
        ResetWindowToCurrentItem();
    }

    private string ResolveMediaPolicyKey() => Placement.CurrentItem.EntityType switch
    {
        DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "tv",
        DetailEntityType.ComicSeries or DetailEntityType.ComicIssue => "comics",
        DetailEntityType.BookSeries or DetailEntityType.Book => "books",
        DetailEntityType.MovieSeries or DetailEntityType.Movie => "movies",
        DetailEntityType.MusicArtist or DetailEntityType.MusicAlbum or DetailEntityType.MusicTrack => "music",
        DetailEntityType.Audiobook => "audiobooks",
        _ => string.Empty,
    };

    private void ResetWindowToCurrentItem()
    {
        var currentIndex = ActiveItems.ToList().FindIndex(item => item.IsCurrent);
        _windowCenterIndex = Math.Max(0, currentIndex);
        _jumpSelectionValue = ShowJumpSelector && currentIndex >= 0
            ? currentIndex.ToString(CultureInfo.InvariantCulture)
            : null;
    }

    private void SelectJump(string? value)
    {
        if (!int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var index)
            || index < 0
            || index >= ActiveItems.Count)
        {
            return;
        }

        _jumpSelectionValue = value;
        _windowCenterIndex = index;
    }

    private void PageLeft()
        => _windowCenterIndex = Math.Max(0, _windowCenterIndex - Math.Max(1, VisibleCount - 2));

    private void PageRight()
        => _windowCenterIndex = Math.Min(Math.Max(0, ActiveItems.Count - 1), _windowCenterIndex + Math.Max(1, VisibleCount - 2));

    private Task SelectContainerAsync(SequenceContainerOptionViewModel option)
        => OnContainerSelected.InvokeAsync(option);

    private Task SelectContainerValueAsync(string? containerId)
    {
        var option = DistinctAvailableContainers.FirstOrDefault(candidate =>
            string.Equals(candidate.ContainerId, containerId, StringComparison.OrdinalIgnoreCase));
        return option is null ? Task.CompletedTask : SelectContainerAsync(option);
    }

    private async Task SetDefaultSequenceAsync()
    {
        if (_settingDefault || string.IsNullOrWhiteSpace(Placement.SelectedContainerId) || !Guid.TryParse(Placement.CurrentItem.Id, out var workId))
            return;

        _settingDefault = true;
        try
        {
            await ApiClient.SetDefaultSequenceAsync(Placement.CurrentItem.EntityType, workId, Placement.SelectedContainerId, Placement.ContainerTitle);
        }
        finally
        {
            _settingDefault = false;
        }
    }

    private string SequenceItemTitle(SequenceItemViewModel item)
        => FirstNonBlank(item.Title, $"{ItemNoun} {SequenceNumber(item)}")!;

    private string SequenceItemClass(SequenceItemViewModel item)
        => $"tl-series-item{(item.IsCurrent ? " is-current" : string.Empty)}{(item.IsOwned ? " is-owned" : " is-missing")}{(SequenceItemRoute(item) is not null ? " is-clickable" : string.Empty)}{(IsSeasonContainer ? " is-season-episode" : string.Empty)}";

    private string? SequenceItemRoute(SequenceItemViewModel item)
    {
        if (!item.IsOwned || item.IsCurrent)
            return null;

        if (!string.IsNullOrWhiteSpace(item.Route))
            return item.Route;

        if (item.EntityType == DetailEntityType.TvEpisode || !Guid.TryParse(item.Id, out var id))
            return null;

        return $"/details/{ToRouteEntityType(item.EntityType)}/{id:D}?context={ContextKey(item.EntityType)}";
    }

    private RenderFragment SequenceItemContent(SequenceItemViewModel item) => @<text>
        @if (!IsSeasonContainer)
        {
            <div class="tl-series-item__position">
                <span class="tl-series-item__node">@SequenceNumber(item)</span>
            </div>
        }

        <div class="tl-series-item__art">
            @if (!string.IsNullOrWhiteSpace(item.ArtworkUrl))
            {
                <img src="@item.ArtworkUrl" alt="@item.Title" />
            }
            else
            {
                @if (item.IsOwned)
                {
                    <div class="tl-series-item__missing-art is-owned-placeholder" aria-label="Artwork unavailable">
                        <MudIcon Icon="@MissingIcon" Size="Size.Large" />
                        <span>Artwork unavailable</span>
                    </div>
                }
                else
                {
                    <div class="tl-series-item__missing-art" aria-label="Missing from library">
                        <MudIcon Icon="@MissingIcon" Size="Size.Large" />
                        <span>Not in library</span>
                    </div>
                }
            }
            @if (item.IsCurrent && !Compact)
            {
                <div class="tl-series-item__current-badge">@CurrentItemBadge</div>
            }
            @if (IsSeasonContainer && item.IsOwned)
            {
                @if (SequenceItemRoute(item) is { } playRoute)
                {
                    <a class="tl-series-episode-play"
                       href="@playRoute"
                       aria-label="@EpisodeWatchLabel(item)"
                       title="@EpisodeWatchLabel(item)">
                        <MudIcon Icon="@Icons.Material.Outlined.PlayArrow" Size="Size.Large" />
                    </a>
                }
            }
        </div>
        @if (IsSeasonContainer)
        {
            <div class="tl-series-item__title-row">
                <div class="@SequenceItemTitleClass(item)">@SequenceItemDisplayTitle(item)</div>
                @if (EpisodeDetailRoute(item) is { } detailRoute)
                {
                    <AppIconButton Icon="@Icons.Material.Outlined.MoreVert"
                                   Href="@detailRoute"
                                   Size="Size.Small"
                                   Class="tl-series-episode-details"
                                   AriaLabel="@($"Open details for {SequenceItemTitle(item)}")"
                                   Tooltip="Episode details" />
                }
            </div>
        }
        else
        {
            <div class="@SequenceItemTitleClass(item)">@SequenceItemTitle(item)</div>
        }
        @if (IsSeasonContainer && (SequenceItemAirDate(item) is not null || !string.IsNullOrWhiteSpace(item.Duration)))
        {
            <div class="tl-series-item__meta">
                @if (SequenceItemAirDate(item) is { } airDate)
                {
                    <span><MudIcon Icon="@Icons.Material.Outlined.CalendarMonth" Size="Size.Small" />@airDate</span>
                }
                @if (!string.IsNullOrWhiteSpace(item.Duration))
                {
                    <span><MudIcon Icon="@Icons.Material.Outlined.Schedule" Size="Size.Small" />@item.Duration</span>
                }
            </div>
        }
        @if (IsSeasonContainer && !string.IsNullOrWhiteSpace(item.Description))
        {
            <p class="tl-series-item__description">@item.Description</p>
        }
        @if (!IsSeasonContainer && SequenceItemDate(item) is { } itemDate)
        {
            <div class="tl-series-item__date">@itemDate</div>
        }
    </text>;

    private string SequenceItemDisplayTitle(SequenceItemViewModel item)
        => IsSeasonContainer
            ? $"{EpisodeNumberLabel(item)}: {SequenceItemTitle(item)}"
            : SequenceItemTitle(item);

    private static string EpisodeNumberLabel(SequenceItemViewModel item)
    {
        var value = SequenceNumberOrNull(item)?.Trim();
        if (string.IsNullOrWhiteSpace(value))
            return "Episode";

        return value.StartsWith('E') && value.Length > 1
            ? value
            : value.StartsWith("Episode ", StringComparison.OrdinalIgnoreCase)
                ? $"E{value["Episode ".Length..]}"
                : $"E{value}";
    }

    private string? EpisodeDetailRoute(SequenceItemViewModel item)
        => IsSeasonContainer && item.IsOwned && Guid.TryParse(item.Id, out var episodeId) && ShowDetailRoute != "#"
            ? $"{ShowDetailRoute}?episode={episodeId:D}"
            : null;

    private string EpisodeWatchLabel(SequenceItemViewModel item)
    {
        var season = ActiveGroup?.Key?.Trim();
        if (!string.IsNullOrWhiteSpace(season))
        {
            season = season.StartsWith("season-", StringComparison.OrdinalIgnoreCase)
                ? season["season-".Length..]
                : season.StartsWith("season ", StringComparison.OrdinalIgnoreCase)
                    ? season["season ".Length..]
                    : season;
            season = season.TrimStart('0');
            if (season.Length == 0)
            {
                season = "0";
            }
        }

        var episode = SequenceNumberOrNull(item)?.Trim();
        if (!string.IsNullOrWhiteSpace(episode))
        {
            episode = episode.StartsWith("Episode ", StringComparison.OrdinalIgnoreCase)
                ? episode["Episode ".Length..]
                : episode.StartsWith('E') && episode.Length > 1 && char.IsDigit(episode[1])
                    ? episode[1..]
                    : episode;
            episode = episode.TrimStart('0');
            if (episode.Length == 0)
            {
                episode = "0";
            }
        }

        return !string.IsNullOrWhiteSpace(season) && !string.IsNullOrWhiteSpace(episode)
            ? $"Watch S{season} E{episode}"
            : !string.IsNullOrWhiteSpace(episode)
                ? $"Watch E{episode}"
                : $"Watch {SequenceItemTitle(item)}";
    }

    private static string ToRouteEntityType(DetailEntityType entityType)
        => entityType.ToString().Replace("Tv", "tv-", StringComparison.Ordinal).ToLowerInvariant();

    private static string ContextKey(DetailEntityType entityType) => entityType switch
    {
        DetailEntityType.Movie or DetailEntityType.MovieSeries or DetailEntityType.TvShow or DetailEntityType.TvSeason or DetailEntityType.TvEpisode => "watch",
        DetailEntityType.MusicAlbum or DetailEntityType.MusicArtist or DetailEntityType.MusicTrack or DetailEntityType.Audiobook => "listen",
        DetailEntityType.Book or DetailEntityType.BookSeries or DetailEntityType.ComicIssue or DetailEntityType.ComicSeries or DetailEntityType.Work => "read",
        _ => "default",
    };

    private string SequenceItemTitleClass(SequenceItemViewModel item)
    {
        if (IsSeasonContainer)
            return "tl-series-item__title";

        var length = SequenceItemTitle(item).Length;
        return $"tl-series-item__title{(length > 44 ? " is-very-long" : length > 26 ? " is-long" : string.Empty)}";
    }

    private static string? SequenceItemDate(SequenceItemViewModel item)
        => SequenceYear(item.PublicationDate)?.ToString()
           ?? FirstNonBlank(item.PublicationDate);

    private static string? SequenceItemAirDate(SequenceItemViewModel item)
    {
        if (string.IsNullOrWhiteSpace(item.PublicationDate))
            return null;

        var value = item.PublicationDate.Trim();
        return DateTimeOffset.TryParse(value, CultureInfo.CurrentCulture, DateTimeStyles.AllowWhiteSpaces, out var parsed)
            ? parsed.ToString("MMM d, yyyy", CultureInfo.CurrentCulture)
            : value;
    }

    private static int? SequenceYear(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;
        var trimmed = value.Trim();
        if (trimmed.Length >= 4 && int.TryParse(trimmed[..4], out var year) && year is >= 1000 and <= 9999)
            return year;
        return DateTimeOffset.TryParse(trimmed, out var parsed) ? parsed.Year : null;
    }

    private static string SequenceNumber(SequenceItemViewModel item)
        => FirstNonBlank(
            item.PositionText,
            item.PositionLabel,
            item.PositionNumber?.ToString(CultureInfo.InvariantCulture),
            "?")!;

    private static string? SequenceNumberOrNull(SequenceItemViewModel item)
        => FirstNonBlank(
            item.PositionText,
            item.PositionLabel,
            item.PositionNumber?.ToString(CultureInfo.InvariantCulture));

    private static string? FirstNonBlank(params string?[] values)
        => values.FirstOrDefault(v => !string.IsNullOrWhiteSpace(v));

    private static string TitleCaseDisplay(string? value, string fallback)
    {
        if (string.IsNullOrWhiteSpace(value))
            return fallback;

        var textInfo = CultureInfo.CurrentCulture.TextInfo;
        return string.Join(' ', value.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(word => word.Length == 0 || word.All(char.IsUpper)
                ? word
                : textInfo.ToTitleCase(word)));
    }

    private static IReadOnlyList<SequenceContainerOptionViewModel> BuildDistinctContainerOptions(IReadOnlyList<SequenceContainerOptionViewModel> options)
    {
        var candidates = options.Any(IsTrustedContainerOption)
            ? options.Where(option => !IsTitleOnlyContainerOption(option)).ToList()
            : options.ToList();

        if (candidates.Count <= 1)
            return candidates;

        var distinct = new List<SequenceContainerOptionViewModel>();
        foreach (var option in candidates)
        {
            var existingIndex = distinct.FindIndex(existing => ShouldMergeContainerOptions(existing, option));
            if (existingIndex >= 0)
            {
                distinct[existingIndex] = MergeContainerOptions(distinct[existingIndex], option);
                continue;
            }

            distinct.Add(option);
        }

        return distinct;
    }

    private static bool IsTrustedContainerOption(SequenceContainerOptionViewModel option)
        => Guid.TryParse(option.ContainerId, out _)
           || Guid.TryParse(option.SourceContainerId, out _)
           || LooksLikeContainerId(option.ContainerId)
           || LooksLikeContainerId(option.SourceContainerId)
           || option.EquivalentContainerIds.Any(alias => Guid.TryParse(alias, out _) || LooksLikeContainerId(alias));

    private static bool IsTitleOnlyContainerOption(SequenceContainerOptionViewModel option)
        => string.IsNullOrWhiteSpace(option.SourceContainerId)
           && !Guid.TryParse(option.ContainerId, out _)
           && !LooksLikeContainerId(option.ContainerId);

    private static bool ShouldMergeContainerOptions(SequenceContainerOptionViewModel existing, SequenceContainerOptionViewModel candidate)
    {
        if (ContainerOptionMatches(existing, candidate.ContainerId)
            || ContainerOptionMatches(existing, candidate.SourceContainerId)
            || candidate.EquivalentContainerIds.Any(alias => ContainerOptionMatches(existing, alias)))
        {
            return true;
        }

        return false;
    }

    private static SequenceContainerOptionViewModel MergeContainerOptions(SequenceContainerOptionViewModel existing, SequenceContainerOptionViewModel candidate)
        => new()
        {
            ContainerId = PreferRoutableContainerId(existing.ContainerId, candidate.ContainerId),
            SourceContainerId = FirstNonBlank(existing.SourceContainerId, candidate.SourceContainerId),
            ContainerTitle = PreferContainerTitle(existing.ContainerTitle, candidate.ContainerTitle),
            IsSelected = existing.IsSelected || candidate.IsSelected,
            IsDefault = existing.IsDefault || candidate.IsDefault,
            MediaScope = FirstNonBlank(existing.MediaScope, candidate.MediaScope),
            EquivalentContainerIds = BuildContainerAliases(existing, candidate),
        };

    private static IReadOnlyList<string> BuildContainerAliases(SequenceContainerOptionViewModel existing, SequenceContainerOptionViewModel candidate)
    {
        var aliases = new List<string>();
        AddContainerAlias(aliases, existing.ContainerId);
        AddContainerAlias(aliases, existing.SourceContainerId);
        AddContainerAlias(aliases, candidate.ContainerId);
        AddContainerAlias(aliases, candidate.SourceContainerId);
        foreach (var alias in existing.EquivalentContainerIds.Concat(candidate.EquivalentContainerIds))
        {
            AddContainerAlias(aliases, alias);
        }

        return aliases;
    }

    private static void AddContainerAlias(List<string> aliases, string? value)
    {
        var normalized = NormalizeContainerId(value);
        if (!string.IsNullOrWhiteSpace(normalized)
            && !aliases.Any(alias => string.Equals(NormalizeContainerId(alias), normalized, StringComparison.OrdinalIgnoreCase)))
        {
            aliases.Add(normalized);
        }
    }

    private static bool ContainerOptionMatches(SequenceContainerOptionViewModel option, string? id)
    {
        var normalized = NormalizeContainerId(id);
        return !string.IsNullOrWhiteSpace(normalized)
               && (string.Equals(NormalizeContainerId(option.ContainerId), normalized, StringComparison.OrdinalIgnoreCase)
                   || string.Equals(NormalizeContainerId(option.SourceContainerId), normalized, StringComparison.OrdinalIgnoreCase)
                   || option.EquivalentContainerIds.Any(alias => string.Equals(NormalizeContainerId(alias), normalized, StringComparison.OrdinalIgnoreCase)));
    }

    private static string? NormalizeContainerId(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var trimmed = value.Trim();
        if (trimmed.Contains('/', StringComparison.Ordinal))
            trimmed = trimmed[(trimmed.LastIndexOf('/') + 1)..];

        return trimmed;
    }

    private static string PreferRoutableContainerId(string existing, string candidate)
        => Guid.TryParse(existing, out _) ? existing : Guid.TryParse(candidate, out _) ? candidate : existing;

    private static string PreferContainerTitle(string existing, string candidate)
        => string.IsNullOrWhiteSpace(existing) || LooksLikeContainerId(existing) ? candidate : existing;

    private static bool LooksLikeContainerId(string? value)
        => Guid.TryParse(value, out _)
           || (!string.IsNullOrWhiteSpace(value) && value.Length > 1 && value[0] == 'Q' && value.Skip(1).All(char.IsDigit))
           || (!string.IsNullOrWhiteSpace(value) && value.Contains(':', StringComparison.Ordinal));

    private string? ResolveSeriesWikidataQid()
    {
        var candidates = new[] { Placement.SourceContainerId, Placement.ContainerId }
            .Concat(DistinctAvailableContainers
                .Where(option => option.IsSelected)
                .SelectMany(option => new[] { option.SourceContainerId, option.ContainerId }.Concat(option.EquivalentContainerIds)));

        return candidates
            .Select(NormalizeContainerId)
            .FirstOrDefault(IsWikidataQid);
    }

    private static bool IsWikidataQid(string? value)
        => !string.IsNullOrWhiteSpace(value)
           && value.Length > 1
           && value[0] is 'Q' or 'q'
           && value.Skip(1).All(char.IsDigit);
}
