@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<AppCssElement Tag="div" Class="@AudioDetailClass" Css="@AudioChromeStyle">
    <DetailHero Model="Model"
                OnActionSelected="SelectActionAsync"
                OnTabRequested="ActiveTabChanged"
                ActionAttributes="ActionAttributes" />

    @if (Model.EntityType == DetailEntityType.MusicAlbum)
    {
        <section class="tl-audio-detail__list">
            <MusicTrackList Groups="Model.MediaGroups"
                            AlbumTitle="@Model.Title"
                            AlbumArtworkUrl="@ArtworkUrl" />
        </section>
    }

    @if (SupplementalTabs.Count > 0)
    {
        <DetailTabs Tabs="SupplementalTabs"
                    ActiveTab="@SupplementalActiveTab"
                    ActiveTabChanged="ActiveTabChanged" />

        <section class="tl-detail-body tl-audio-detail__body">
            @if (SupplementalActiveTab is "overview")
            {
                <MediaEngine.Web.Components.Details.OverviewTab Model="Model"
                                                                 OnTabRequested="ActiveTabChanged"
                                                                 OnContainerSelected="OnContainerSelected" />
            }
            else if (SupplementalActiveTab is "chapters")
            {
                <AudiobookChapterList Groups="Model.MediaGroups"
                                      AudiobookTitle="@Model.Title"
                                      AudiobookArtworkUrl="@ArtworkUrl" />
            }
            else if (SupplementalActiveTab is "contributors" or "people" or "credits" or "cast")
            {
                <PeopleAndCharactersTab ContributorGroups="Model.ContributorGroups"
                                        CharacterGroups="Model.CharacterGroups"
                                        IncludeCharacters="true" />
            }
            else if (SupplementalActiveTab is "universe" or "timeline" or "relationships" or "related")
            {
                <UniverseTab Relationships="Model.RelationshipStrip" Groups="SupplementalGroups" />
            }
            else
            {
                <DetailsTab Model="Model" />
            }
        </section>
    }
</AppCssElement>

@code {
    [Parameter, EditorRequired] public DetailPageViewModel Model { get; set; } = default!;
    [Parameter] public IReadOnlyList<DetailTab> Tabs { get; set; } = [];
    [Parameter] public string ActiveTab { get; set; } = "overview";
    [Parameter] public EventCallback<string> ActiveTabChanged { get; set; }
    [Parameter] public EventCallback<DetailAction> OnActionSelected { get; set; }
    [Parameter] public EventCallback<SequenceContainerOptionViewModel> OnContainerSelected { get; set; }
    [Parameter] public Func<DetailAction, IReadOnlyDictionary<string, object>?>? ActionAttributes { get; set; }

    private Task SelectActionAsync(DetailAction action) =>
        OnActionSelected.InvokeAsync(action);

    private string? ArtworkUrl => Model.Artwork.CoverUrl ?? Model.Artwork.PosterUrl ?? Model.Artwork.HeroArtwork.Url;

    private string AudioDetailClass =>
        $"tl-audio-detail{(Model.EntityType == DetailEntityType.Audiobook ? " tl-audio-detail--audiobook" : " tl-audio-detail--music")}";

    private string AudioChromeStyle =>
        $"{DetailHeroPresentation.From(Model).GradientStyle}{ArtworkColorFallbacks}";

    private string ArtworkColorFallbacks =>
        "--tl-audio-primary:" + FirstNonBlank(Model.Artwork.PrimaryColor, "#dca53e") + ";" +
        "--tl-audio-secondary:" + FirstNonBlank(Model.Artwork.SecondaryColor, "#0b1019") + ";" +
        "--tl-audio-accent:" + FirstNonBlank(Model.Artwork.AccentColor, "#dca53e") + ";";

    private IReadOnlyList<DetailTab> SupplementalTabs =>
        Tabs.Where(tab => tab.Key is not "tracks").ToList();

    private string SupplementalActiveTab =>
        SupplementalTabs.Any(tab => string.Equals(tab.Key, ActiveTab, StringComparison.OrdinalIgnoreCase))
            ? SupplementalTabs.First(tab => string.Equals(tab.Key, ActiveTab, StringComparison.OrdinalIgnoreCase)).Key
            : SupplementalTabs.FirstOrDefault()?.Key ?? "overview";

    private IReadOnlyList<MediaGroupingViewModel> SupplementalGroups =>
        Model.MediaGroups
            .Where(group => group.Key is not "tracks" and not "chapters")
            .ToList();

    private static string? FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));
}
