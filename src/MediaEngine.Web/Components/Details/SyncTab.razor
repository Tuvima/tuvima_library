@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<section class="tl-detail-panel">
    <div class="tl-section-heading"><h2>Read + Listen Sync</h2></div>
    @if (Sync is not null)
    {
        <p class="tl-detail-copy">@Sync.CurrentChapterTitle</p>
    }
    else if (Capability is not null)
    {
        <p class="tl-detail-copy">@Capability.Reason</p>
    }
    else
    {
        <p class="tl-detail-copy">Sync is not available for this item.</p>
    }
</section>

@code {
    [Parameter] public ReadingListeningSyncViewModel? Sync { get; set; }
    [Parameter] public ReadingListeningSyncCapabilityViewModel? Capability { get; set; }
}
