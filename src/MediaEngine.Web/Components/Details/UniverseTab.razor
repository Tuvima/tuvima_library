@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

<div class="tl-detail-tab-panel">
    @if (Relationships.Count > 0)
    {
        <section class="tl-detail-panel">
            <div class="tl-section-heading"><h2>Relationships</h2></div>
            @foreach (var group in Relationships)
            {
                <div class="tl-related-group">
                    <span>@group.Title</span>
                    @foreach (var chip in group.Items)
                    {
                        <RelatedEntityChip Chip="chip" />
                    }
                </div>
            }
        </section>
    }
    <ChildrenListTab Groups="Groups" />
</div>

@code {
    [Parameter] public IReadOnlyList<RelationshipGroup> Relationships { get; set; } = [];
    [Parameter] public IReadOnlyList<MediaGroupingViewModel> Groups { get; set; } = [];

    private RenderSnapshot _lastSnapshot;
    private bool _shouldRender = true;
    private bool _hasRendered;

    protected override void OnParametersSet()
    {
        var next = new RenderSnapshot(
            Relationships.Count,
            Groups.Count,
            string.Join("|", Relationships.Select(static group => $"{group.Title}:{group.Items.Count}")),
            string.Join("|", Groups.Select(static group => $"{group.Title}:{group.Items.Count}")));

        _shouldRender = !_hasRendered || !_lastSnapshot.Equals(next);
        _lastSnapshot = next;
        _hasRendered = true;
    }

    // Avoid re-rendering the expensive relationship and children lists unless their visible groups changed.
    protected override bool ShouldRender() => _shouldRender;

    internal readonly record struct RenderSnapshot(
        int RelationshipCount,
        int GroupCount,
        string RelationshipKeys,
        string GroupKeys);
}
