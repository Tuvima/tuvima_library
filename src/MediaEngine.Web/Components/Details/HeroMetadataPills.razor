@namespace MediaEngine.Web.Components.Details
@using MediaEngine.Contracts.Details

@{
    var inlineStatItems = InlineStatItems;
    var statItems = StatItems;
}

<div class="tl-detail-metadata-stack">
    @if (UsePrimaryHeroChrome && inlineStatItems.Count > 0)
    {
        <div class="tl-detail-watch-metadata-row" aria-label="Media details">
            @foreach (var entry in inlineStatItems.Select((item, index) => new { item, index }))
            {
                @if (KindEquals(entry.item, "genre"))
                {
                    @if (entry.index == 0 || !KindEquals(inlineStatItems[entry.index - 1], "genre"))
                    {
                        var genreItems = inlineStatItems.Where(item => KindEquals(item, "genre")).ToList();
                        <span class="tl-detail-watch-genre-group">
                            @foreach (var genreEntry in genreItems.Select((item, index) => new { item, index }))
                            {
                                <a class="@WatchStatClass(genreEntry.item)" href="@genreEntry.item.Route" title="@genreEntry.item.Tooltip">@WatchStatContent(genreEntry.item)</a>@if (genreEntry.index < genreItems.Count - 1){<span class="tl-detail-watch-genre-comma" aria-hidden="true">, </span>}
                            }
                        </span>
                        @if (entry.index + genreItems.Count < inlineStatItems.Count)
                        {
                            <span class="tl-detail-watch-metadata-separator" aria-hidden="true"> · </span>
                        }
                    }
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(entry.item.Route))
                    {
                        <a class="@WatchStatClass(entry.item)" href="@entry.item.Route" title="@entry.item.Tooltip">@WatchStatContent(entry.item)</a>
                    }
                    else
                    {
                        <span class="@WatchStatClass(entry.item)" title="@entry.item.Tooltip">@WatchStatContent(entry.item)</span>
                    }
                    @if (entry.index < inlineStatItems.Count - 1)
                    {
                        <span class="tl-detail-watch-metadata-separator" aria-hidden="true"> · </span>
                    }
                }
            }
        </div>
    }
    else if (statItems.Count > 0 || ShouldRenderHeroBrand)
    {
        <div class="tl-detail-metadata-row" aria-label="Media details">
            @if (ShouldRenderHeroBrand)
            {
                <span class="@HeroBrandBadgeClass"
                      title="@HeroBrand!.Label"
                      aria-label="@HeroBrand.Label">
                    @if (!string.IsNullOrWhiteSpace(HeroBrand.ImageUrl))
                    {
                        <img src="@HeroBrand.ImageUrl" alt="@HeroBrand.Label" />
                    }
                    else
                    {
                        <span>@HeroBrand.Label</span>
                    }
                </span>
            }
            @foreach (var item in statItems)
            {
                @if (!string.IsNullOrWhiteSpace(item.Route))
                {
                    <a class="@StatClass(item)" href="@item.Route" title="@item.Tooltip">
                        <MudIcon Icon="@IconFor(item)" Size="Size.Small" />
                        <span class="tl-detail-metadata-item__value">@item.Label</span>
                        <span class="tl-detail-metadata-item__label">@LabelFor(item)</span>
                    </a>
                }
                else
                {
                    <span class="@StatClass(item)" title="@item.Tooltip">
                        <MudIcon Icon="@IconFor(item)" Size="Size.Small" />
                        <span class="tl-detail-metadata-item__value">@item.Label</span>
                        <span class="tl-detail-metadata-item__label">@LabelFor(item)</span>
                    </span>
                }
            }
            @if (IsAdminView)
            {
                <span class="tl-detail-admin-health">@IdentityStatusLabel</span>
            }
        </div>
    }

</div>

@code {
    [Parameter] public IReadOnlyList<MetadataPill> Metadata { get; set; } = [];
    [Parameter] public DetailEntityType EntityType { get; set; }
    [Parameter] public CanonicalIdentityStatus IdentityStatus { get; set; }
    [Parameter] public bool IsAdminView { get; set; }
    [Parameter] public bool IsWatchHero { get; set; }
    [Parameter] public bool UsePrimaryHeroChrome { get; set; }
    [Parameter] public HeroBrandViewModel? HeroBrand { get; set; }
    [Parameter] public bool RenderHeroBrandInMetadata { get; set; } = true;

    private bool ShouldRenderHeroBrand => IsWatchHero
        && RenderHeroBrandInMetadata
        && HeroBrand is not null
        && (!string.IsNullOrWhiteSpace(HeroBrand.ImageUrl) || !string.IsNullOrWhiteSpace(HeroBrand.Label));

    private string HeroBrandBadgeClass => !string.IsNullOrWhiteSpace(HeroBrand?.ImageUrl)
        ? "tl-detail-hero-brand-badge tl-detail-hero-brand-badge--image"
        : "tl-detail-hero-brand-badge tl-detail-hero-brand-badge--text";

    private IReadOnlyList<MetadataPill> StatItems =>
        LimitGenres(Metadata)
            .Where(IsHeroStat)
            .Where(item => !ShouldSuppressTypeStat(item))
            .OrderBy(StatSort)
            .Take(EntityType == DetailEntityType.MusicAlbum ? 8 : 7)
            .ToList();

    private IReadOnlyList<MetadataPill> InlineStatItems
        => IsWatchHero ? WatchStatItems : PrimaryChromeStatItems;

    private IReadOnlyList<MetadataPill> WatchStatItems
    {
        get
        {
            return LimitGenres(Metadata)
                .Where(IsWatchHeroStat)
                .Where(item => !string.IsNullOrWhiteSpace(item.Label))
                .GroupBy(item => WatchStatGroupKey(item), StringComparer.OrdinalIgnoreCase)
                .Select(group => group.First())
                .OrderBy(WatchStatSort)
                .Take(8)
                .ToList();
        }
    }

    private IReadOnlyList<MetadataPill> PrimaryChromeStatItems =>
            LimitGenres(Metadata)
            .Where(IsPrimaryChromeHeroStat)
            .Where(item => !string.IsNullOrWhiteSpace(item.Label))
            .GroupBy(item => WatchStatGroupKey(item), StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .OrderBy(PrimaryChromeStatSort)
            .Take(5)
            .ToList();

    private string IdentityStatusLabel => IdentityStatus switch
    {
        CanonicalIdentityStatus.WikidataLinked => "Wikidata linked",
        CanonicalIdentityStatus.ProviderMatched => "Provider matched",
        CanonicalIdentityStatus.NeedsReview => "Needs review",
        CanonicalIdentityStatus.LocalOnly => "Local only",
        _ => "Identity unknown",
    };

    private static bool KindEquals(MetadataPill item, string kind)
        => string.Equals(item.Kind, kind, StringComparison.OrdinalIgnoreCase);

    private bool ShouldSuppressTypeStat(MetadataPill item)
        => IsWatchHero
        && KindEquals(item, "type")
        && (EntityType == DetailEntityType.TvShow || string.Equals(item.Label, "TV Show", StringComparison.OrdinalIgnoreCase));

    private static bool IsHeroStat(MetadataPill item)
    {
        var kind = item.Kind?.ToLowerInvariant();
        return kind is "certification" or "content_rating" or "rating" or "type" or "duration" or "year"
            or "page_count" or "track_count" or "season_count" or "episode_count" or "genre" or "quality";
    }

    private bool IsWatchHeroStat(MetadataPill item)
    {
        var kind = item.Kind?.ToLowerInvariant();
        if (EntityType == DetailEntityType.TvShow)
        {
            return kind is "certification" or "content_rating" or "year" or "episode_count" or "duration" or "genre" or "quality" or "subtitles" or "rating";
        }

        return kind is "certification" or "content_rating" or "rating" or "duration" or "year" or "genre" or "quality" or "subtitles";
    }

    private static bool IsPrimaryChromeHeroStat(MetadataPill item)
    {
        var kind = item.Kind?.ToLowerInvariant();
        return kind is "certification" or "content_rating" or "rating" or "duration" or "year"
            or "page_count" or "track_count" or "season_count" or "episode_count" or "genre" or "quality" or "subtitles";
    }

    private static int StatSort(MetadataPill item) => item.Kind?.ToLowerInvariant() switch
    {
        "certification" or "content_rating" => 1,
        "type" => 2,
        "year" => 3,
        "duration" => 4,
        "page_count" or "track_count" or "season_count" or "episode_count" => 5,
        "genre" => 6,
        "quality" => 7,
        "rating" => 8,
        _ => 8,
    };

    private static int WatchStatSort(MetadataPill item) => item.Kind?.ToLowerInvariant() switch
    {
        "certification" or "content_rating" => 0,
        "year" => 1,
        "episode_count" => 2,
        "duration" => 3,
        "genre" => 4,
        "quality" => 5,
        "subtitles" => 6,
        "rating" => 7,
        _ => 8,
    };

    private static int PrimaryChromeStatSort(MetadataPill item) => item.Kind?.ToLowerInvariant() switch
    {
        "certification" or "content_rating" => 0,
        "year" => 1,
        "duration" => 2,
        "page_count" or "track_count" or "season_count" or "episode_count" => 3,
        "genre" => 4,
        "quality" => 5,
        "subtitles" => 6,
        "rating" => 7,
        _ => 8,
    };

    private static string StatClass(MetadataPill item)
        => KindEquals(item, "rating")
            ? "tl-detail-metadata-item tl-detail-metadata-item--rating"
            : "tl-detail-metadata-item";

    private static string WatchStatClass(MetadataPill item)
        => item.Kind?.ToLowerInvariant() switch
        {
            "rating" => "tl-detail-watch-metadata-item tl-detail-watch-metadata-item--rating",
            "certification" or "content_rating" => "tl-detail-watch-metadata-item tl-detail-watch-metadata-item--classification",
            _ => "tl-detail-watch-metadata-item",
        };

    private static string? WatchIconFor(MetadataPill item) => item.Kind?.ToLowerInvariant() switch
    {
        "year" => Icons.Material.Outlined.CalendarMonth,
        "episode_count" => Icons.Material.Outlined.VideoLibrary,
        "duration" => Icons.Material.Outlined.Schedule,
        "quality" => Icons.Material.Outlined.Tv,
        "subtitles" => Icons.Material.Outlined.ClosedCaption,
        _ => null,
    };

    private static string WatchStatGroupKey(MetadataPill item)
        => item.Kind?.ToLowerInvariant() switch
        {
            "certification" or "content_rating" => "content-rating",
            "genre" => $"genre:{item.Label}",
            _ => item.Kind ?? item.Label,
        };

    private static IEnumerable<MetadataPill> LimitGenres(IEnumerable<MetadataPill> items)
    {
        var genreCount = 0;
        foreach (var item in items)
        {
            if (KindEquals(item, "genre") && ++genreCount > 2)
                continue;

            yield return item;
        }
    }

    private static RenderFragment WatchStatContent(MetadataPill item) => builder =>
    {
        var sequence = 0;
        var icon = KindEquals(item, "rating") ? Icons.Material.Filled.Star : WatchIconFor(item);
        if (!string.IsNullOrWhiteSpace(icon))
        {
            builder.OpenComponent<MudIcon>(sequence++);
            builder.AddAttribute(sequence++, nameof(MudIcon.Icon), icon);
            builder.AddAttribute(sequence++, nameof(MudIcon.Size), Size.Small);
            builder.CloseComponent();
        }

        builder.OpenElement(sequence++, "span");
        builder.AddContent(sequence++, item.Label);
        builder.CloseElement();
    };

    private static string IconFor(MetadataPill item) => item.Kind?.ToLowerInvariant() switch
    {
        "rating" => Icons.Material.Filled.Star,
        "type" => Icons.Material.Outlined.Category,
        "year" => Icons.Material.Outlined.CalendarMonth,
        "duration" => Icons.Material.Outlined.Schedule,
        "page_count" => Icons.Material.Outlined.Article,
        "track_count" => Icons.Material.Outlined.QueueMusic,
        "season_count" => Icons.Material.Outlined.LiveTv,
        "episode_count" => Icons.Material.Outlined.VideoLibrary,
        "genre" => Icons.Material.Outlined.LocalOffer,
        "quality" => Icons.Material.Outlined.GraphicEq,
        _ => Icons.Material.Outlined.Info,
    };

    private string LabelFor(MetadataPill item) => item.Kind?.ToLowerInvariant() switch
    {
        "rating" => "Rating",
        "year" => EntityType switch
        {
            DetailEntityType.Book or DetailEntityType.Audiobook or DetailEntityType.ComicIssue => "Published",
            DetailEntityType.MusicAlbum => "Released",
            _ => "Release Year",
        },
        "duration" => EntityType switch
        {
            DetailEntityType.Movie or DetailEntityType.TvEpisode => "Runtime",
            DetailEntityType.TvShow or DetailEntityType.TvSeason => "Total Runtime",
            DetailEntityType.Audiobook or DetailEntityType.MusicAlbum => "Length",
            _ => "Duration",
        },
        "audio" => "Language",
        "type" => "Type",
        "page_count" => "Length",
        "track_count" => "Tracks",
        "season_count" => "Seasons",
        "episode_count" => "Episodes",
        "genre" => "Genre",
        "quality" => "Quality",
        _ => item.Kind ?? "Detail",
    };
}
