@namespace MediaEngine.Web.Components.Discovery
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="discovery-card @ShapeClass @PresentationClass @(_expanded ? "is-expanded" : "")"
     @ref="_cardRef"
     style="--discovery-accent: @Item.AccentColor;"
     tabindex="0"
     @onkeydown="HandleKeyDown">
    <div class="discovery-card-frame">
        <div class="discovery-card-media" @onclick="OpenCard">
            @if (ShowPreviewStack)
            {
                <div class="discovery-card-stack" aria-hidden="true">
                    @for (var index = 0; index < PreviewImages.Count; index++)
                    {
                        <img src="@PreviewImages[index]"
                             alt=""
                             class="discovery-card-stack-image"
                             style="@GetStackStyle(index)" />
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(CardImageUrl))
            {
                <img src="@CardImageUrl" alt="@Item.Title" class="discovery-card-image" loading="lazy" />
            }
            else
            {
                <div class="discovery-card-fallback">
                    <MudIcon Icon="@FallbackIcon" Style="font-size: 44px; color: rgba(255,255,255,0.18);" />
                    <span>@Item.Title</span>
                </div>
            }

            <div class="discovery-card-gradient"></div>

            @if (!ShowPreviewStack && !string.IsNullOrWhiteSpace(Item.LogoUrl))
            {
                <img src="@Item.LogoUrl" alt="@Item.Title" class="discovery-card-logo" />
            }

            @if (!string.IsNullOrWhiteSpace(MediaKindIcon))
            {
                <div class="discovery-card-badge" title="@MediaKindLabel">
                    <MudIcon Icon="@MediaKindIcon" />
                    <span class="discovery-visually-hidden">@MediaKindLabel</span>
                </div>
            }

            @if (Item.ProgressPct is > 0)
            {
                <div class="discovery-card-progress">
                    <div class="discovery-card-progress-fill" style="width: @($"{Math.Min(100, Item.ProgressPct.Value):F0}%");"></div>
                </div>
            }

            <button type="button"
                    class="discovery-card-touch-toggle"
                    aria-label="Show quick actions"
                    @onclick="ToggleExpanded"
                    @onclick:stopPropagation="true">
                <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" />
            </button>
        </div>

        <div class="discovery-card-hover-panel">
            <div class="discovery-card-hover-art @(UseFallbackCoverLayout ? "is-cover-focus" : null) @(ShowHoverPoster ? "is-with-poster" : null) @(string.IsNullOrWhiteSpace(HoverBackdropUrl) ? "is-empty" : null)">
                @if (!string.IsNullOrWhiteSpace(HoverBackdropUrl))
                {
                    <img src="@HoverBackdropUrl" alt="" class="discovery-card-hover-backdrop-image" loading="lazy" @onerror="HandleHoverBackdropError" />
                }
                else
                {
                    <div class="discovery-card-hover-backdrop-fallback"></div>
                }

                @if (ShowHoverPoster)
                {
                    <div class="discovery-card-hover-poster-shell">
                        <img src="@HoverPosterUrl" alt="@Item.Title" class="discovery-card-hover-poster" loading="lazy" />
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Item.LogoUrl))
                {
                    <img src="@Item.LogoUrl" alt="@Item.Title" class="discovery-card-hover-logo" />
                }
                else if (!ShowHoverPoster && string.IsNullOrWhiteSpace(HoverBackdropUrl))
                {
                    <div class="discovery-card-hover-fallback">
                        <MudIcon Icon="@FallbackIcon" />
                    </div>
                }
            </div>

            <div class="discovery-card-hover-body">
                <div class="discovery-card-hover-actions">
                    <div class="discovery-card-hover-actions-left">
                        <button type="button"
                                class="discovery-card-icon-button discovery-card-icon-button-primary"
                                aria-label="@Item.PrimaryActionLabel"
                                title="@Item.PrimaryActionLabel"
                                @onclick="OpenPrimary"
                                @onclick:stopPropagation="true">
                            <MudIcon Icon="@PrimaryIcon" />
                        </button>

                        @if (Item.CanAddToCollection)
                        {
                            <button type="button"
                                    class="discovery-card-icon-button"
                                    aria-label="Add to collection"
                                    title="Add to collection"
                                    @onclick="OpenAddToCollectionAsync"
                                    @onclick:stopPropagation="true">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" />
                            </button>
                        }
                    </div>

                    <button type="button"
                            class="discovery-card-icon-button"
                            aria-label="Details"
                            title="Details"
                            @onclick="OpenDetails"
                            @onclick:stopPropagation="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" />
                    </button>
                </div>

                <div class="discovery-card-hover-heading">
                    <div class="discovery-card-hover-title">@Item.Title</div>
                    @if (!string.IsNullOrWhiteSpace(DisplaySubtitle))
                    {
                        <div class="discovery-card-hover-subtitle">@DisplaySubtitle</div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Item.StatusText))
                {
                    <div class="discovery-card-hover-status">@Item.StatusText</div>
                }

                @if (ShowMetaRow)
                {
                    <div class="discovery-card-hover-meta-row">
                        @if (!string.IsNullOrWhiteSpace(MediaKindIcon))
                        {
                            <span class="discovery-card-meta-icon" title="@MediaKindLabel">
                                <MudIcon Icon="@MediaKindIcon" />
                                <span class="discovery-visually-hidden">@MediaKindLabel</span>
                            </span>
                        }

                        @if (!string.IsNullOrWhiteSpace(HoverMetaDisplay))
                        {
                            <div class="discovery-card-hover-meta">@HoverMetaDisplay</div>
                        }
                    </div>
                }

                @if (Item.ContextLines.Count > 0)
                {
                    <div class="discovery-card-hover-context-list">
                        @foreach (var line in Item.ContextLines)
                        {
                            <div class="discovery-card-hover-context">@line</div>
                        }
                    </div>
                }

                @if (GenreChips.Count > 0)
                {
                    <div class="discovery-card-hover-chips">
                        @foreach (var chip in GenreChips)
                        {
                            <span class="discovery-card-chip">@chip</span>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Item.Description))
                {
                    <p class="discovery-card-hover-description">@Item.Description</p>
                }
            </div>
        </div>
    </div>

    <div class="discovery-card-caption">
        <div class="discovery-card-title">@Item.Title</div>
        @if (!string.IsNullOrWhiteSpace(Item.Subtitle))
        {
            <div class="discovery-card-subtitle">@Item.Subtitle</div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public DiscoveryCardViewModel Item { get; set; } = default!;

    private bool _expanded;
    private bool _hoverRegistered;
    private bool _lastExpandedState;
    private int _hoverBackdropIndex;
    private ElementReference _cardRef;

    private string ShapeClass => Item.Shape switch
    {
        DiscoveryCardShape.Landscape => "is-landscape",
        DiscoveryCardShape.Square => "is-square",
        _ => "is-portrait",
    };

    private string PresentationClass => Item.Presentation switch
    {
        DiscoveryCardPresentation.TvSeries => "is-tv-series",
        DiscoveryCardPresentation.MovieSeries => "is-movie-series",
        DiscoveryCardPresentation.BookSeries => "is-book-series",
        DiscoveryCardPresentation.ComicSeries => "is-comic-series",
        DiscoveryCardPresentation.AudiobookSeries => "is-audiobook-series",
        DiscoveryCardPresentation.Album => "is-album",
        DiscoveryCardPresentation.Artist => "is-artist",
        _ => "is-default",
    };

    private bool ShowPreviewStack =>
        (Item.Presentation == DiscoveryCardPresentation.MovieSeries && PreviewImages.Count > 0)
        || (string.IsNullOrWhiteSpace(CardImageUrl) && PreviewImages.Count > 0);

    private string CardImageUrl => Item.Presentation switch
    {
        DiscoveryCardPresentation.Album or DiscoveryCardPresentation.Artist => Item.CoverUrl ?? Item.BackgroundUrl ?? Item.BannerUrl ?? string.Empty,
        _ when Item.Shape == DiscoveryCardShape.Landscape => Item.BackgroundUrl ?? Item.BannerUrl ?? Item.CoverUrl ?? string.Empty,
        _ => Item.CoverUrl ?? Item.BackgroundUrl ?? Item.BannerUrl ?? string.Empty,
    };

    private string? WideBackdropUrl => FirstNonBlank(
        Item.BackgroundUrl,
        Item.BannerUrl);

    private string? BaseHoverPosterUrl => FirstNonBlank(
        Item.CoverUrl,
        CardImageUrl,
        PreviewImages.FirstOrDefault());

    private IReadOnlyList<string> HoverBackdropCandidates =>
        (UseFallbackCoverLayout
            ? new[]
            {
                Item.HeroUrl,
            }
            : new[]
            {
                WideBackdropUrl,
                Item.HeroUrl,
                CardImageUrl,
                PreviewImages.FirstOrDefault(),
            })
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Cast<string>()
        .ToList();

    private string? HoverBackdropUrl => HoverBackdropCandidates.Skip(_hoverBackdropIndex).FirstOrDefault();

    private string? HoverPosterUrl => BaseHoverPosterUrl ?? HoverBackdropUrl;

    private bool UseFallbackCoverLayout =>
        string.IsNullOrWhiteSpace(WideBackdropUrl)
        && !string.IsNullOrWhiteSpace(BaseHoverPosterUrl);

    private bool ShowHoverPoster => UseFallbackCoverLayout;

    private IReadOnlyList<string> PreviewImages =>
        Item.PreviewImages
            .Where(image => !string.IsNullOrWhiteSpace(image))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(3)
            .ToList();

    private IReadOnlyList<string> GenreChips =>
        Item.Genres
            .Where(genre => !string.IsNullOrWhiteSpace(genre))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(3)
            .ToList();

    private string PrimaryIcon => Item.MediaKind switch
    {
        "Movie" or "TV" => Icons.Material.Filled.PlayArrow,
        "Music" or "Audiobook" => Icons.Material.Filled.PlayArrow,
        _ => Icons.Material.Filled.AutoStories,
    };

    private string FallbackIcon => Item.Presentation switch
    {
        DiscoveryCardPresentation.Album => Icons.Material.Filled.Album,
        DiscoveryCardPresentation.Artist => Icons.Material.Filled.Person,
        DiscoveryCardPresentation.MovieSeries or DiscoveryCardPresentation.TvSeries => Icons.Material.Filled.Movie,
        DiscoveryCardPresentation.ComicSeries => Icons.Material.Filled.AutoStories,
        DiscoveryCardPresentation.AudiobookSeries => Icons.Material.Filled.Headphones,
        _ => Item.MediaKind switch
        {
            "Movie" or "TV" => Icons.Material.Filled.Movie,
            "Music" => Icons.Material.Filled.Album,
            "Audiobook" => Icons.Material.Filled.Headphones,
            _ => Icons.Material.Filled.MenuBook,
        },
    };

    private string MediaKindLabel => Item.MediaKind switch
    {
        "Movie" => "Movie",
        "TV" => "TV",
        "Music" => "Music",
        "Audiobook" => "Audiobook",
        "Comic" => "Comic",
        "Book" => "Book",
        _ => string.IsNullOrWhiteSpace(Item.MediaKind) ? "Media" : Item.MediaKind,
    };

    private string MediaKindIcon => MediaKindLabel switch
    {
        "Movie" => Icons.Material.Filled.Movie,
        "TV" => Icons.Material.Filled.LiveTv,
        "Music" => Icons.Material.Filled.MusicNote,
        "Audiobook" => Icons.Material.Filled.Headphones,
        "Comic" => Icons.Material.Filled.AutoStories,
        "Book" => Icons.Material.Filled.MenuBook,
        _ => Icons.Material.Filled.Theaters,
    };

    private string DisplaySubtitle => Item.Subtitle ?? Item.Creator ?? string.Empty;

    private string HoverMetaDisplay
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Item.MetaText))
                return string.Empty;

            var parts = Item.MetaText
                .Split('/', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
                .ToList();

            if (parts.Count > 0 && string.Equals(parts[0], MediaKindLabel, StringComparison.OrdinalIgnoreCase))
                parts.RemoveAt(0);

            return string.Join(" / ", parts);
        }
    }

    private bool ShowMetaRow => !string.IsNullOrWhiteSpace(MediaKindIcon) || !string.IsNullOrWhiteSpace(HoverMetaDisplay);

    protected override void OnParametersSet()
    {
        _hoverBackdropIndex = 0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("registerDiscoveryCardHover", _cardRef);
            _hoverRegistered = true;
        }

        if (_expanded != _lastExpandedState)
        {
            _lastExpandedState = _expanded;

            if (_expanded)
            {
                await JS.InvokeVoidAsync("positionDiscoveryCardHover", _cardRef);
            }
            else
            {
                await JS.InvokeVoidAsync("clearDiscoveryCardHover", _cardRef);
            }
        }
    }

    private void ToggleExpanded() => _expanded = !_expanded;

    private void OpenPrimary()
    {
        _expanded = false;
        Nav.NavigateTo(Item.PrimaryNavigationUrl ?? Item.NavigationUrl);
    }

    private void OpenCard()
    {
        _expanded = false;
        Nav.NavigateTo(Item.NavigationUrl);
    }

    private void OpenDetails()
    {
        _expanded = false;
        Nav.NavigateTo(Item.DetailsNavigationUrl ?? Item.NavigationUrl);
    }

    private async Task OpenAddToCollectionAsync()
    {
        if (Item.WorkId is null)
            return;

        var parameters = new DialogParameters
        {
            { nameof(AddToCollectionDialog.WorkId), Item.WorkId.Value },
            { nameof(AddToCollectionDialog.WorkTitle), Item.Title }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = false,
            BackdropClick = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<AddToCollectionDialog>("Add to collection", parameters, options);
        await dialog.Result;
        _expanded = false;
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or " ")
        {
            OpenCard();
        }
        else if (args.Key == "Escape")
        {
            _expanded = false;
        }
    }

    private string GetStackStyle(int index) => Item.Shape switch
    {
        DiscoveryCardShape.Landscape => index switch
        {
            0 => "left: 28%; top: 56%; width: 30%; transform: translate(-50%, -50%) rotate(-8deg); z-index: 1;",
            1 => "left: 50%; top: 48%; width: 34%; transform: translate(-50%, -50%) rotate(0deg); z-index: 3;",
            _ => "left: 72%; top: 56%; width: 30%; transform: translate(-50%, -50%) rotate(8deg); z-index: 2;",
        },
        DiscoveryCardShape.Square => index switch
        {
            0 => "left: 34%; top: 58%; width: 38%; transform: translate(-50%, -50%) rotate(-10deg); z-index: 1;",
            1 => "left: 52%; top: 48%; width: 44%; transform: translate(-50%, -50%) rotate(0deg); z-index: 3;",
            _ => "left: 70%; top: 58%; width: 38%; transform: translate(-50%, -50%) rotate(10deg); z-index: 2;",
        },
        _ => index switch
        {
            0 => "left: 36%; top: 60%; width: 54%; transform: translate(-50%, -50%) rotate(-10deg); z-index: 1;",
            1 => "left: 52%; top: 48%; width: 60%; transform: translate(-50%, -50%) rotate(0deg); z-index: 3;",
            _ => "left: 68%; top: 60%; width: 54%; transform: translate(-50%, -50%) rotate(10deg); z-index: 2;",
        },
    };

    private static string? FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private void HandleHoverBackdropError()
    {
        if (_hoverBackdropIndex < HoverBackdropCandidates.Count - 1)
        {
            _hoverBackdropIndex++;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (!_hoverRegistered)
            return;

        try
        {
            await JS.InvokeVoidAsync("unregisterDiscoveryCardHover", _cardRef);
        }
        catch
        {
            // Ignore teardown issues during circuit disposal.
        }
    }
}

<style>
    .discovery-card {
        --discovery-hover-shift-x: 0px;
        --discovery-hover-lift: clamp(8px, 1.2vw, 12px);
        --discovery-hover-clearance: clamp(182px, 20vw, 244px);
        --discovery-card-media-height: clamp(192px, 18.4vw, 232px);
        --discovery-hover-panel-width: clamp(320px, 24vw, 380px);
        display: flex;
        flex-direction: column;
        gap: 12px;
        color: #f8fafc;
        outline: none;
        position: relative;
        isolation: isolate;
        overflow: visible;
        scroll-snap-align: start;
        z-index: 0;
        transition: z-index 0.18s ease;
    }

    .discovery-card.is-portrait {
        width: calc(var(--discovery-card-media-height) * 2 / 3);
        --discovery-hover-panel-width: clamp(320px, 25vw, 366px);
    }

    .discovery-card.is-landscape {
        width: calc(var(--discovery-card-media-height) * 16 / 9);
        --discovery-hover-panel-width: clamp(348px, 27vw, 430px);
    }

    .discovery-card.is-square {
        width: var(--discovery-card-media-height);
        --discovery-hover-panel-width: clamp(320px, 25vw, 372px);
    }

    .discovery-card-frame {
        position: relative;
        display: flex;
        flex-direction: column;
        overflow: visible;
    }

    .discovery-card:hover,
    .discovery-card:focus-within,
    .discovery-card.is-expanded {
        z-index: 24;
    }

    .discovery-card-media {
        position: relative;
        overflow: hidden;
        height: var(--discovery-card-media-height);
        border-radius: var(--app-radius-md);
        background:
            radial-gradient(circle at top left, color-mix(in srgb, var(--discovery-accent) 28%, transparent) 0%, transparent 55%),
            linear-gradient(180deg, rgba(16, 21, 36, 0.94) 0%, rgba(7, 10, 18, 0.96) 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.26);
        cursor: pointer;
        z-index: 1;
        transform-origin: center top;
        transition: transform 0.2s ease, border-color 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
    }

    .discovery-card:hover .discovery-card-media,
    .discovery-card:focus-within .discovery-card-media,
    .discovery-card.is-expanded .discovery-card-media {
        transform: translateY(calc(-1 * var(--discovery-hover-lift))) scale(1.01);
        border-color: color-mix(in srgb, var(--discovery-accent) 42%, rgba(255, 255, 255, 0.16));
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.3);
    }

    .discovery-card-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.45s ease;
    }

    .discovery-card.is-tv-series .discovery-card-image,
    .discovery-card.is-artist .discovery-card-image {
        object-position: center top;
    }

    .discovery-card:hover .discovery-card-image,
    .discovery-card:focus-within .discovery-card-image,
    .discovery-card.is-expanded .discovery-card-image {
        transform: scale(1.04);
    }

    .discovery-card-stack {
        position: absolute;
        inset: 0;
    }

    .discovery-card-stack-image {
        position: absolute;
        aspect-ratio: 2 / 3;
        border-radius: var(--app-radius-md);
        object-fit: cover;
        box-shadow: 0 20px 36px rgba(0, 0, 0, 0.34);
        border: 1px solid rgba(255, 255, 255, 0.14);
        opacity: 0.98;
    }

    .discovery-card.is-movie-series .discovery-card-stack-image {
        border-radius: var(--app-radius-md);
    }

    .discovery-card-fallback {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 18px;
        text-align: center;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.92rem;
        font-weight: 700;
        color: rgba(248, 250, 252, 0.72);
    }

    .discovery-card-gradient {
        position: absolute;
        inset: 0;
        background:
            linear-gradient(180deg, rgba(0, 0, 0, 0.02) 0%, rgba(2, 6, 16, 0.18) 42%, rgba(2, 6, 16, 0.88) 100%),
            linear-gradient(180deg, transparent 0%, color-mix(in srgb, var(--discovery-accent) 18%, transparent) 100%);
        pointer-events: none;
    }

    .discovery-card-logo {
        position: absolute;
        left: 14px;
        bottom: 18px;
        width: min(calc(100% - 28px), 170px);
        max-height: 54px;
        object-fit: contain;
        object-position: left bottom;
        filter: drop-shadow(0 8px 18px rgba(0, 0, 0, 0.42));
        z-index: 2;
    }

    .discovery-card-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        width: 36px;
        height: 36px;
        border-radius: var(--app-radius-md);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(2, 6, 16, 0.74);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(248, 250, 252, 0.94);
        z-index: 2;
        backdrop-filter: blur(12px);
    }

    .discovery-card-progress {
        position: absolute;
        left: 14px;
        right: 14px;
        bottom: 12px;
        height: 4px;
        border-radius: var(--app-radius-md);
        background: rgba(255, 255, 255, 0.16);
        overflow: hidden;
        z-index: 2;
    }

    .discovery-card-progress-fill {
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--discovery-accent) 0%, rgba(255, 255, 255, 0.92) 100%);
    }

    .discovery-card-touch-toggle {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 38px;
        height: 38px;
        border: none;
        border-radius: var(--app-radius-md);
        background: rgba(2, 6, 16, 0.62);
        color: rgba(248, 250, 252, 0.94);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 3;
    }

    .discovery-card-hover-panel {
        position: absolute;
        left: 0;
        right: auto;
        top: 0;
        width: min(84vw, var(--discovery-hover-panel-width));
        min-width: 100%;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        z-index: 4;
        transform: translate(var(--discovery-hover-shift-x), 12px) scale(0.982);
        transform-origin: left top;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--app-radius-md);
        background: linear-gradient(180deg, rgba(17, 20, 29, 0.96) 0%, rgba(7, 10, 18, 0.995) 100%);
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.42);
        overflow: hidden;
        backdrop-filter: blur(24px) saturate(142%);
        transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0.18s;
    }

    .discovery-card:hover .discovery-card-hover-panel,
    .discovery-card:focus-within .discovery-card-hover-panel,
    .discovery-card.is-expanded .discovery-card-hover-panel {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translate(var(--discovery-hover-shift-x), calc(-1 * var(--discovery-hover-lift)));
        transition-delay: 0s;
    }

    .discovery-card-hover-art {
        position: relative;
        aspect-ratio: 16 / 8.8;
        min-height: 142px;
        overflow: hidden;
    }

    .discovery-card-hover-art::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at top right, color-mix(in srgb, var(--discovery-accent) 18%, transparent) 0%, transparent 34%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0) 22%);
        z-index: 1;
        pointer-events: none;
    }

    .discovery-card-hover-art::after {
        content: "";
        position: absolute;
        inset: auto 0 0 0;
        height: 62%;
        background: linear-gradient(180deg, rgba(5, 8, 14, 0) 0%, rgba(5, 8, 14, 0.92) 100%);
        z-index: 3;
        pointer-events: none;
    }

    .discovery-card-hover-backdrop-image,
    .discovery-card-hover-backdrop-fallback {
        position: absolute;
        inset: 0;
