@namespace MediaEngine.Web.Components.Discovery
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="discovery-card @ShapeClass @PresentationClass @HoverLayoutClass @SurfaceClass @HoverPlacementClass @(_expanded ? "is-expanded" : "")"
     @ref="_cardRef"
     style="--discovery-accent: @Item.AccentColor;"
     tabindex="0"
     @onkeydown="HandleKeyDown">
    <div class="discovery-card-frame">
        <div class="discovery-card-media @(HasArtworkSurface ? "has-artwork-surface" : null)" @onclick="OpenDetails">
            @if (ShowPreviewStack)
            {
                <div class="discovery-card-stack" aria-hidden="true">
                    @for (var index = 0; index < PreviewImages.Count; index++)
                    {
                        <img src="@PreviewImages[index]" alt="" class="discovery-card-stack-image" style="@GetStackStyle(index)" />
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(CardImageUrl))
            {
                <img src="@CardImageUrl" alt="@Item.Title" class="discovery-card-image @TileImageFitClass" loading="lazy" />
            }
            else
            {
                <div class="discovery-card-fallback">
                    <MudIcon Icon="@FallbackIcon" Style="font-size:44px;color:rgba(255,255,255,.18);" />
                    <span>@Item.Title</span>
                </div>
            }

            <div class="discovery-card-gradient @(ShowTileLogo ? "is-banner-gradient" : "is-cover-gradient")"></div>

            @if (ShowTileLogo)
            {
                <img src="@Item.LogoUrl" alt="@Item.Title" class="discovery-card-logo" />
            }

            @if (!string.IsNullOrWhiteSpace(MediaKindIcon))
            {
                <div class="discovery-card-badge" title="@MediaKindLabel">
                    <MudIcon Icon="@MediaKindIcon" />
                    <span class="discovery-visually-hidden">@MediaKindLabel</span>
                </div>
            }

            @if (Item.ProgressPct is > 0)
            {
                <div class="discovery-card-progress">
                    <div class="discovery-card-progress-fill" style="width:@($"{Math.Min(100, Item.ProgressPct.Value):F0}%");"></div>
                </div>
            }

            <button type="button"
                    class="discovery-card-touch-toggle"
                    aria-label="Show quick actions"
                    @onclick="ToggleExpanded"
                    @onclick:stopPropagation="true">
                <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" />
            </button>
        </div>

        <div class="discovery-card-hover-panel @ShapeClass @PresentationClass @HoverLayoutClass @SurfaceClass @HoverPlacementClass"
             style="@HoverPanelStyle">
            <div class="discovery-card-hover-art @(string.IsNullOrWhiteSpace(ActiveHoverImageUrl) ? "is-empty" : null)"
                 @onclick="OpenDetails"
                 @onclick:stopPropagation="true">
                @if (!string.IsNullOrWhiteSpace(ActiveHoverImageUrl))
                {
                    <img src="@ActiveHoverImageUrl"
                         alt="@Item.Title"
                         class="discovery-card-hover-image @HoverImageFitClass"
                         loading="lazy"
                         @onerror="HandleHoverImageError" />
                }
                else
                {
                    <div class="discovery-card-hover-fallback">
                        <MudIcon Icon="@FallbackIcon" />
                    </div>
                }

                @if (ShowHoverLogo)
                {
                    <img src="@Item.LogoUrl" alt="@Item.Title" class="discovery-card-hover-logo" />
                }
            </div>

            <div class="discovery-card-hover-body">
                <div class="discovery-card-hover-actions">
                    <div class="discovery-card-hover-actions-left">
                        <button type="button"
                                class="discovery-card-icon-button discovery-card-icon-button-primary"
                                aria-label="@Item.PrimaryActionLabel"
                                title="@Item.PrimaryActionLabel"
                                @onclick="OpenPrimary"
                                @onclick:stopPropagation="true">
                            <MudIcon Icon="@PrimaryIcon" />
                        </button>

                        @if (Item.CanAddToCollection)
                        {
                            <button type="button"
                                    class="discovery-card-icon-button"
                                    aria-label="Add to collection"
                                    title="Add to collection"
                                    @onclick="OpenAddToCollectionAsync"
                                    @onclick:stopPropagation="true">
                                <MudIcon Icon="@Icons.Material.Outlined.Add" />
                            </button>
                        }
                    </div>

                </div>

                <div class="discovery-card-hover-heading">
                    <div class="discovery-card-hover-title">@Item.Title</div>
                    @if (!UseCompactHover && !string.IsNullOrWhiteSpace(DisplaySubtitle))
                    {
                        <div class="discovery-card-hover-subtitle">@DisplaySubtitle</div>
                    }
                </div>

                @if (UseCompactHover)
                {
                    <div class="discovery-card-hover-facts">
                        @foreach (var fact in CompactHoverFacts)
                        {
                            <span class="discovery-card-hover-fact">@fact</span>
                        }
                    </div>
                }

                @if (!UseCompactHover && !string.IsNullOrWhiteSpace(Item.StatusText))
                {
                    <div class="discovery-card-hover-status">@Item.StatusText</div>
                }

                @if (!UseCompactHover && ShowMetaRow)
                {
                    <div class="discovery-card-hover-meta-row">
                        @if (!string.IsNullOrWhiteSpace(MediaKindIcon))
                        {
                            <span class="discovery-card-meta-icon" title="@MediaKindLabel">
                                <MudIcon Icon="@MediaKindIcon" />
                                <span class="discovery-visually-hidden">@MediaKindLabel</span>
                            </span>
                        }

                        @if (!string.IsNullOrWhiteSpace(HoverMetaDisplay))
                        {
                            <div class="discovery-card-hover-meta">@HoverMetaDisplay</div>
                        }
                    </div>
                }

                @if (!UseCompactHover && ShowHoverContextLines)
                {
                    <div class="discovery-card-hover-context-list">
                        @foreach (var line in Item.ContextLines)
                        {
                            <div class="discovery-card-hover-context">@line</div>
                        }
                    </div>
                }

                @if (!UseCompactHover && DisplayChips.Count > 0)
                {
                    <div class="discovery-card-hover-chips">
                        @foreach (var chip in DisplayChips)
                        {
                            <span class="discovery-card-chip">@chip</span>
                        }
                    </div>
                }

                @if (!UseCompactHover && ShowHoverDescription)
                {
                    <p class="discovery-card-hover-description">@DisplaySummary</p>
                }
            </div>
        </div>
    </div>

    @if (ShowCaption)
    {
        <div class="discovery-card-caption">
            <div class="discovery-card-title">@Item.Title</div>
            @if (!string.IsNullOrWhiteSpace(Item.Subtitle))
            {
                <div class="discovery-card-subtitle">@Item.Subtitle</div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public DiscoveryCardViewModel Item { get; set; } = default!;

    private bool _expanded;
    private bool _hoverRegistered;
    private bool _lastExpandedState;
    private int _hoverImageIndex;
    private ElementReference _cardRef;

    private string ShapeClass => Item.Shape switch
    {
        DiscoveryCardShape.Landscape => "is-landscape",
        DiscoveryCardShape.Square => "is-square",
        _ => "is-portrait",
    };

    private string PresentationClass => Item.Presentation switch
    {
        DiscoveryCardPresentation.TvSeries => "is-tv-series",
        DiscoveryCardPresentation.MovieSeries => "is-movie-series",
        DiscoveryCardPresentation.BookSeries => "is-book-series",
        DiscoveryCardPresentation.ComicSeries => "is-comic-series",
        DiscoveryCardPresentation.AudiobookSeries => "is-audiobook-series",
        DiscoveryCardPresentation.Album => "is-album",
        DiscoveryCardPresentation.Artist => "is-artist",
        _ => "is-default",
    };

    private string HoverLayoutClass => Item.HoverLayout == DiscoveryHoverLayout.BannerPopover ? "is-banner-popover" : "is-art-popover";

    private string HoverPlacementClass => Item.PreviewPlacement == DiscoveryPreviewPlacement.Bottom ? "is-placement-bottom" : "is-placement-smart";

    private string SurfaceClass => Item.SurfaceKind switch
    {
        DiscoverySurfaceKind.BannerLandscape => "is-banner-surface",
        DiscoverySurfaceKind.CoverSquare => "is-cover-square",
        DiscoverySurfaceKind.ArtistPhotoSquare => "is-artist-photo-square",
        _ => "is-cover-portrait",
    };

    private bool ShowPreviewStack => string.IsNullOrWhiteSpace(CardImageUrl) && PreviewImages.Count > 0;

    private string CardImageUrl => Item.TileImageUrl ?? string.Empty;

    private bool HasArtworkSurface => !string.IsNullOrWhiteSpace(CardImageUrl) || ShowPreviewStack;

    private IReadOnlyList<string> HoverImageCandidates => new[]
        {
            Item.HoverImageUrl,
            Item.TileImageUrl,
            PreviewImages.FirstOrDefault(),
        }
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Cast<string>()
        .ToList();

    private string? ActiveHoverImageUrl => HoverImageCandidates.Skip(_hoverImageIndex).FirstOrDefault();

    private bool ShowTileLogo => Item.SurfaceKind == DiscoverySurfaceKind.BannerLandscape && !ShowPreviewStack && !string.IsNullOrWhiteSpace(Item.LogoUrl);

    private bool ShowHoverLogo => Item.HoverLayout == DiscoveryHoverLayout.BannerPopover && !string.IsNullOrWhiteSpace(Item.LogoUrl);

    private IReadOnlyList<string> PreviewImages => Item.PreviewImages
        .Where(image => !string.IsNullOrWhiteSpace(image))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Take(3)
        .ToList();

    private IReadOnlyList<string> DisplayChips => (Item.VibeTags.Count > 0 ? Item.VibeTags : Item.Genres)
        .Where(chip => !string.IsNullOrWhiteSpace(chip))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Take(3)
        .ToList();

    private string? DisplaySummary => Item.Tldr ?? Item.Description;

    private string TileImageFitClass => Item.TileImageFitMode == DiscoveryImageFitMode.Contain ? "is-contained" : "is-fill";

    private string HoverImageFitClass => Item.HoverImageFitMode == DiscoveryImageFitMode.Contain ? "is-contained" : "is-fill";

    private bool ShowHoverContextLines => Item.HoverLayout == DiscoveryHoverLayout.BannerPopover && Item.ContextLines.Count > 0;

    private bool ShowHoverDescription => Item.HoverLayout == DiscoveryHoverLayout.BannerPopover && !string.IsNullOrWhiteSpace(DisplaySummary);

    private bool ShowCaption => Item.TileTextMode != DiscoveryTileTextMode.CoverOnly;

    private IReadOnlyList<string> CompactHoverFacts => Item.HoverFacts
        .Where(fact => !string.IsNullOrWhiteSpace(fact))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Take(4)
        .ToList();

    private bool UseCompactHover => CompactHoverFacts.Count > 0;

    private string HoverPanelWidth => Item.Shape switch
    {
        DiscoveryCardShape.Landscape => "clamp(360px, 28vw, 440px)",
        DiscoveryCardShape.Square => "clamp(248px, 18vw, 292px)",
        _ => "clamp(430px, 40vw, 560px)",
    };

    private string HoverPanelStyle => $"--discovery-accent: {Item.AccentColor}; --discovery-hover-panel-width: {HoverPanelWidth};";

    private string PrimaryIcon => Item.MediaKind switch
    {
        "Movie" or "TV" or "Music" or "Audiobook" => Icons.Material.Filled.PlayArrow,
        _ => Icons.Material.Filled.AutoStories,
    };

    private string FallbackIcon => Item.Presentation switch
    {
        DiscoveryCardPresentation.Album => Icons.Material.Filled.Album,
        DiscoveryCardPresentation.Artist => Icons.Material.Filled.Person,
        DiscoveryCardPresentation.MovieSeries or DiscoveryCardPresentation.TvSeries => Icons.Material.Filled.Movie,
        DiscoveryCardPresentation.ComicSeries => Icons.Material.Filled.AutoStories,
        DiscoveryCardPresentation.AudiobookSeries => Icons.Material.Filled.Headphones,
        _ => Item.MediaKind switch
        {
            "Movie" or "TV" => Icons.Material.Filled.Movie,
            "Music" => Icons.Material.Filled.Album,
            "Audiobook" => Icons.Material.Filled.Headphones,
            _ => Icons.Material.Filled.MenuBook,
        },
    };

    private string MediaKindLabel => Item.MediaKind switch
    {
        "Movie" => "Movie",
        "TV" => "TV",
        "Music" => "Music",
        "Audiobook" => "Audiobook",
        "Comic" => "Comic",
        "Book" => "Book",
        _ => string.IsNullOrWhiteSpace(Item.MediaKind) ? "Media" : Item.MediaKind,
    };

    private string MediaKindIcon => MediaKindLabel switch
    {
        "Movie" => Icons.Material.Filled.Movie,
        "TV" => Icons.Material.Filled.LiveTv,
        "Music" => Icons.Material.Filled.MusicNote,
        "Audiobook" => Icons.Material.Filled.Headphones,
        "Comic" => Icons.Material.Filled.AutoStories,
        "Book" => Icons.Material.Filled.MenuBook,
        _ => Icons.Material.Filled.Theaters,
    };

    private string DisplaySubtitle => Item.Subtitle ?? Item.Creator ?? string.Empty;

    private string HoverMetaDisplay
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Item.MetaText))
            {
                return string.Empty;
            }

            var parts = Item.MetaText.Split('/', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList();
            if (parts.Count > 0 && string.Equals(parts[0], MediaKindLabel, StringComparison.OrdinalIgnoreCase))
            {
                parts.RemoveAt(0);
            }

            return string.Join(" / ", parts);
        }
    }

    private bool ShowMetaRow => !string.IsNullOrWhiteSpace(MediaKindIcon) || !string.IsNullOrWhiteSpace(HoverMetaDisplay);

    protected override void OnParametersSet() => _hoverImageIndex = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("registerDiscoveryCardHover", _cardRef);
            _hoverRegistered = true;
        }

        if (_expanded != _lastExpandedState)
        {
            _lastExpandedState = _expanded;
            await JS.InvokeVoidAsync("setDiscoveryCardHoverExpanded", _cardRef, _expanded);
        }
    }

    private void ToggleExpanded() => _expanded = !_expanded;

    private void OpenPrimary()
    {
        _expanded = false;
        Nav.NavigateTo(Item.PrimaryNavigationUrl ?? Item.NavigationUrl);
    }

    private void OpenCard()
    {
        OpenDetails();
    }

    private void OpenDetails()
    {
        _expanded = false;
        Nav.NavigateTo(Item.DetailsNavigationUrl ?? Item.NavigationUrl);
    }

    private async Task OpenAddToCollectionAsync()
    {
        if (Item.WorkId is null)
        {
            return;
        }

        var parameters = new DialogParameters
        {
            { nameof(AddToCollectionDialog.WorkId), Item.WorkId.Value },
            { nameof(AddToCollectionDialog.WorkTitle), Item.Title }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = false, BackdropClick = true, CloseButton = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<AddToCollectionDialog>("Add to collection", parameters, options);
        await dialog.Result;
        _expanded = false;
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or " ")
        {
            OpenDetails();
        }
        else if (args.Key == "Escape")
        {
            _expanded = false;
        }
    }

    private string GetStackStyle(int index) => Item.Shape switch
    {
        DiscoveryCardShape.Landscape => index switch
        {
            0 => "left:28%;top:56%;width:30%;transform:translate(-50%,-50%) rotate(-8deg);z-index:1;",
            1 => "left:50%;top:48%;width:34%;transform:translate(-50%,-50%) rotate(0deg);z-index:3;",
            _ => "left:72%;top:56%;width:30%;transform:translate(-50%,-50%) rotate(8deg);z-index:2;",
        },
        DiscoveryCardShape.Square => index switch
        {
            0 => "left:34%;top:58%;width:38%;transform:translate(-50%,-50%) rotate(-10deg);z-index:1;",
            1 => "left:52%;top:48%;width:44%;transform:translate(-50%,-50%) rotate(0deg);z-index:3;",
            _ => "left:70%;top:58%;width:38%;transform:translate(-50%,-50%) rotate(10deg);z-index:2;",
        },
        _ => index switch
        {
            0 => "left:36%;top:60%;width:54%;transform:translate(-50%,-50%) rotate(-10deg);z-index:1;",
            1 => "left:52%;top:48%;width:60%;transform:translate(-50%,-50%) rotate(0deg);z-index:3;",
            _ => "left:68%;top:60%;width:54%;transform:translate(-50%,-50%) rotate(10deg);z-index:2;",
        },
    };

    private static string? FirstNonBlank(params string?[] values) => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private void HandleHoverImageError()
    {
        if (_hoverImageIndex < HoverImageCandidates.Count - 1)
        {
            _hoverImageIndex++;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (!_hoverRegistered)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("unregisterDiscoveryCardHover", _cardRef);
        }
        catch
        {
        }
    }
}

<style>
    .discovery-card { --discovery-hover-lift:clamp(8px,1.2vw,12px); --discovery-card-media-height:clamp(192px,18.4vw,232px); --discovery-card-media-aspect:2 / 3; --discovery-hover-panel-width:clamp(320px,24vw,380px); display:flex; flex:0 0 auto; flex-direction:column; gap:12px; color:#f8fafc; outline:none; position:relative; overflow:visible; scroll-snap-align:start; z-index:0; transition:z-index .18s ease; }
    .discovery-card.is-portrait { width:calc(var(--discovery-card-media-height) * 2 / 3); --discovery-card-media-aspect:2 / 3; --discovery-hover-panel-width:clamp(430px,40vw,560px); --discovery-hover-clearance:clamp(286px,32vw,420px); }
    .discovery-card.is-landscape { width:calc(var(--discovery-card-media-height) * 16 / 9); --discovery-card-media-aspect:16 / 9; --discovery-hover-panel-width:clamp(360px,28vw,440px); }
    .discovery-card.is-square { width:var(--discovery-card-media-height); --discovery-card-media-aspect:1 / 1; --discovery-hover-panel-width:clamp(248px,18vw,292px); --discovery-hover-clearance:clamp(254px,28vw,356px); }
    .discovery-card-frame { position:relative; display:flex; flex-direction:column; overflow:visible; width:100%; }
    .discovery-card:hover, .discovery-card:focus-within, .discovery-card.is-expanded, .discovery-card.is-hover-active { z-index:24; }
    .discovery-card-media { position:relative; overflow:hidden; width:100%; height:auto; aspect-ratio:var(--discovery-card-media-aspect); border-radius:var(--app-radius-md); background:radial-gradient(circle at top left,color-mix(in srgb,var(--discovery-accent) 28%,transparent) 0%,transparent 55%),linear-gradient(180deg,rgba(16,21,36,.94) 0%,rgba(7,10,18,.96) 100%); border:1px solid rgba(255,255,255,.08); box-shadow:0 18px 44px rgba(0,0,0,.26); cursor:pointer; z-index:1; transform-origin:center top; transition:transform .2s ease,border-color .18s ease,box-shadow .18s ease; }
    .discovery-card-media.has-artwork-surface { background:transparent; border-color:transparent; }
    .discovery-card:hover .discovery-card-media, .discovery-card:focus-within .discovery-card-media, .discovery-card.is-expanded .discovery-card-media, .discovery-card.is-hover-active .discovery-card-media { transform:translateY(calc(-1 * var(--discovery-hover-lift))) scale(1.01); border-color:color-mix(in srgb,var(--discovery-accent) 42%,rgba(255,255,255,.16)); box-shadow:0 18px 40px rgba(0,0,0,.3); }
    .discovery-card:hover .discovery-card-media.has-artwork-surface, .discovery-card:focus-within .discovery-card-media.has-artwork-surface, .discovery-card.is-expanded .discovery-card-media.has-artwork-surface, .discovery-card.is-hover-active .discovery-card-media.has-artwork-surface { border-color:transparent; }
    .discovery-card-image { width:100%; height:100%; display:block; transition:transform .45s ease; }
    .discovery-card-image.is-fill { object-fit:cover; }
    .discovery-card-image.is-contained { object-fit:contain; padding:0; background:transparent; }
    .discovery-card:hover .discovery-card-image, .discovery-card:focus-within .discovery-card-image, .discovery-card.is-expanded .discovery-card-image, .discovery-card.is-hover-active .discovery-card-image { transform:scale(1.04); }
    .discovery-card-stack { position:absolute; inset:0; }
    .discovery-card-stack-image { position:absolute; aspect-ratio:2 / 3; border-radius:var(--app-radius-md); object-fit:cover; box-shadow:0 20px 36px rgba(0,0,0,.34); border:1px solid rgba(255,255,255,.14); opacity:.98; }
    .discovery-card-fallback, .discovery-card-hover-fallback { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; }
    .discovery-card-fallback { flex-direction:column; gap:12px; padding:18px; text-align:center; font-family: var(--app-font-sans, 'Nunito', sans-serif); font-size:.92rem; font-weight:700; color:rgba(248,250,252,.72); }
    .discovery-card-hover-fallback { color:rgba(255,255,255,.2); }
    .discovery-card-hover-fallback .mud-icon-root { font-size:68px; }
    .discovery-card-gradient { position:absolute; inset:0; pointer-events:none; }
    .discovery-card-gradient.is-banner-gradient { background:linear-gradient(180deg,rgba(0,0,0,.02) 0%,rgba(2,6,16,.18) 42%,rgba(2,6,16,.88) 100%),linear-gradient(180deg,transparent 0%,color-mix(in srgb,var(--discovery-accent) 18%,transparent) 100%); }
    .discovery-card-gradient.is-cover-gradient { background:linear-gradient(180deg,rgba(255,255,255,.02) 0%,rgba(255,255,255,0) 34%,rgba(2,6,16,.42) 100%),linear-gradient(180deg,transparent 0%,color-mix(in srgb,var(--discovery-accent) 12%,transparent) 100%); }
    .discovery-card-logo, .discovery-card-hover-logo { object-fit:contain; object-position:left bottom; filter:drop-shadow(0 8px 18px rgba(0,0,0,.42)); z-index:2; }
    .discovery-card-logo { position:absolute; left:14px; bottom:18px; width:min(calc(100% - 28px),170px); max-height:54px; }
    .discovery-card-hover-logo { position:absolute; left:14px; bottom:14px; width:min(calc(100% - 28px),220px); max-height:54px; }
    .discovery-card-badge { position:absolute; top:14px; left:14px; width:36px; height:36px; border-radius:var(--app-radius-md); display:inline-flex; align-items:center; justify-content:center; background:rgba(2,6,16,.74); border:1px solid rgba(255,255,255,.1); color:rgba(248,250,252,.94); z-index:2; backdrop-filter:blur(12px); }
    .discovery-card-progress { position:absolute; left:14px; right:14px; bottom:12px; height:4px; border-radius:var(--app-radius-md); background:rgba(255,255,255,.16); overflow:hidden; z-index:2; }
    .discovery-card-progress-fill { height:100%; border-radius:inherit; background:linear-gradient(90deg,var(--discovery-accent) 0%,rgba(255,255,255,.92) 100%); }
    .discovery-card-touch-toggle { position:absolute; top:12px; right:12px; width:38px; height:38px; border:none; border-radius:var(--app-radius-md); background:rgba(2,6,16,.62); color:rgba(248,250,252,.94); display:none; align-items:center; justify-content:center; z-index:3; }
    .discovery-card-hover-panel { position:fixed; left:-9999px; top:-9999px; width:min(84vw,var(--discovery-hover-panel-width, 360px)); max-width:440px; max-height:min(70vh,560px); opacity:0; visibility:hidden; pointer-events:none; z-index:4001; transform:translateY(12px) scale(.982); transform-origin:left top; border:1px solid rgba(255,255,255,.08); border-radius:var(--app-radius-md); background:linear-gradient(180deg,rgba(17,20,29,.96) 0%,rgba(7,10,18,.995) 100%); box-shadow:0 24px 48px rgba(0,0,0,.42); overflow:hidden; backdrop-filter:blur(24px) saturate(142%); transition:opacity .18s ease,transform .18s ease,visibility 0s linear .18s; }
    .discovery-card-hover-panel.is-art-popover.is-portrait { display:grid; grid-template-columns:minmax(150px,38%) minmax(220px,1fr); align-items:stretch; max-width:560px; }
    .discovery-card-hover-panel.is-placement-bottom.is-art-popover.is-portrait { display:block; width:min(84vw, clamp(150px, 14vw, 220px)); max-width:220px; }
