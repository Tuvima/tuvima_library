@namespace MediaEngine.Web.Components.Discovery
@inject NavigationManager Nav

@if (Hero is not null)
{
    <AppCssElement Tag="section" Class='@($"discovery-hero-shell {HeroSurfaceClass}")' Css="@($"--hero-accent: {Hero.AccentColor};")">
        <div class="discovery-hero-backdrop">
            @if (!string.IsNullOrWhiteSpace(ActiveHeroBackdropUrl))
            {
                <img src="@ActiveHeroBackdropUrl" alt="" class="discovery-hero-backdrop-image" @onerror="HandleHeroBackdropError" />
            }
        </div>
        <div class="discovery-hero-overlay"></div>
        <div class="discovery-hero-texture"></div>

        <div class="discovery-hero-content">
            <div class="discovery-hero-copy">
                @if (!string.IsNullOrWhiteSpace(Hero.Eyebrow))
                {
                    <div class="discovery-hero-eyebrow">@Hero.Eyebrow</div>
                }

                @if (!string.IsNullOrWhiteSpace(Hero.LogoUrl) && Hero.SurfaceKind == MediaTileSurfaceKind.BannerLandscape)
                {
                    <img src="@Hero.LogoUrl" alt="@Hero.Title" class="discovery-hero-logo" />
                }
                else
                {
                    <h1 class="discovery-hero-title">@Hero.Title</h1>
                }

                @if (!string.IsNullOrWhiteSpace(Hero.Subtitle))
                {
                    <div class="discovery-hero-subtitle">@Hero.Subtitle</div>
                }

                @if (!string.IsNullOrWhiteSpace(Hero.StatusText))
                {
                    <div class="discovery-hero-status">@Hero.StatusText</div>
                }

                @if (ShowMetaRow)
                {
                    <div class="discovery-hero-meta-row">
                        @if (!string.IsNullOrWhiteSpace(HeroMediaIcon))
                        {
                            <span class="discovery-hero-kind" title="@HeroMediaKindLabel">
                                <MudIcon Icon="@HeroMediaIcon" />
                                <span class="discovery-visually-hidden">@HeroMediaKindLabel</span>
                            </span>
                        }

                        @if (!string.IsNullOrWhiteSpace(HeroMetaDisplay))
                        {
                            <div class="discovery-hero-meta">@HeroMetaDisplay</div>
                        }
                    </div>
                }

                @if (DisplayChips.Count > 0)
                {
                    <div class="discovery-hero-chips">
                        @foreach (var chip in DisplayChips)
                        {
                            <span class="discovery-hero-chip">@chip</span>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(DisplaySummary))
                {
                    <p class="discovery-hero-description">@DisplaySummary</p>
                }

                @if (Hero.ProgressPct is > 0)
                {
                    <div class="discovery-hero-progress">
                        <div class="discovery-hero-progress-label">Progress</div>
                        <div class="discovery-hero-progress-bar">
                            <AppCssElement Tag="div" Class="discovery-hero-progress-fill" Css="@($"width: {$"{Math.Min(100, Hero.ProgressPct.Value):F0}%"};")"></AppCssElement>
                        </div>
                    </div>
                }

                <div class="discovery-hero-actions">
                    <AppButton Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Class="discovery-hero-btn discovery-hero-btn-primary"
                               OnClick="OpenPrimary">
                        @Hero.PrimaryActionLabel
                    </AppButton>

                    @if (!string.IsNullOrWhiteSpace(Hero.SecondaryNavigationUrl))
                    {
                        <AppButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Outlined.Info"
                                   Class="discovery-hero-btn discovery-hero-btn-secondary"
                                   OnClick="OpenSecondary">
                            @Hero.SecondaryActionLabel
                        </AppButton>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Hero.PreviewImageUrl))
            {
                <div class="discovery-hero-preview @PreviewClass">
                    <img src="@Hero.PreviewImageUrl" alt="@Hero.Title" class="discovery-hero-preview-image @PreviewImageFitClass" />
                </div>
            }
        </div>
    </AppCssElement>
}

@code {
    [Parameter, EditorRequired] public DiscoveryHeroViewModel Hero { get; set; } = default!;

    private int _heroBackdropIndex;

    private string HeroSurfaceClass => Hero.SurfaceKind == MediaTileSurfaceKind.BannerLandscape ? "is-banner-hero" : "is-cover-hero";

    private string PreviewClass => Hero.PreviewSurfaceKind switch
    {
        MediaTileSurfaceKind.CoverSquare or MediaTileSurfaceKind.ArtistPhotoSquare => "is-square-preview",
        MediaTileSurfaceKind.BannerLandscape => "is-landscape-preview",
        _ => "is-portrait-preview",
    };

    private string PreviewImageFitClass => Hero.TileImageFitMode == MediaTileImageFitMode.Contain
        ? "is-contained"
        : "is-fill";

    private IReadOnlyList<string> HeroBackdropCandidates =>
        new[]
        {
            Hero.HeroBackgroundImageUrl,
            Hero.BackgroundImageUrl,
            Hero.BannerImageUrl,
            Hero.PreviewImageUrl,
        }
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Cast<string>()
        .ToList();

    private string? ActiveHeroBackdropUrl => HeroBackdropCandidates.Skip(_heroBackdropIndex).FirstOrDefault();

    private string? HeroMediaKindLabel => ExtractLeadingMediaKind(Hero.MetaText);

    private string? HeroMediaIcon => ResolveMediaIcon(HeroMediaKindLabel);

    private string HeroMetaDisplay => TrimLeadingMediaKind(Hero.MetaText, HeroMediaKindLabel);

    private bool ShowMetaRow => !string.IsNullOrWhiteSpace(HeroMediaIcon) || !string.IsNullOrWhiteSpace(HeroMetaDisplay);

    private IReadOnlyList<string> DisplayChips => Hero.VibeTags
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Take(3)
        .ToList();

    private string? DisplaySummary => Hero.Tldr ?? Hero.Description;

    protected override void OnParametersSet() => _heroBackdropIndex = 0;

    private void OpenPrimary() => Nav.NavigateTo(Hero.PrimaryNavigationUrl);

    private void OpenSecondary()
    {
        if (!string.IsNullOrWhiteSpace(Hero.SecondaryNavigationUrl))
        {
            Nav.NavigateTo(Hero.SecondaryNavigationUrl);
        }
    }

    private void HandleHeroBackdropError()
    {
        if (_heroBackdropIndex < HeroBackdropCandidates.Count - 1)
        {
            _heroBackdropIndex++;
            StateHasChanged();
        }
    }

    private static string? ExtractLeadingMediaKind(string? metaText)
    {
        if (string.IsNullOrWhiteSpace(metaText))
        {
            return null;
        }

        var first = metaText.Split('/', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
        return ResolveMediaIcon(first) is not null ? first : null;
    }

    private static string TrimLeadingMediaKind(string? metaText, string? mediaKind)
    {
        if (string.IsNullOrWhiteSpace(metaText))
        {
            return string.Empty;
        }

        if (string.IsNullOrWhiteSpace(mediaKind))
        {
            return metaText;
        }

        var parts = metaText.Split('/', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList();
        if (parts.Count > 0 && string.Equals(parts[0], mediaKind, StringComparison.OrdinalIgnoreCase))
        {
            parts.RemoveAt(0);
        }

        return string.Join(" / ", parts);
    }

    private static string? ResolveMediaIcon(string? mediaKind) => mediaKind?.Trim() switch
    {
        "Book" => Icons.Material.Filled.MenuBook,
        "Audiobook" => Icons.Material.Filled.Headphones,
        "Movie" => Icons.Material.Filled.Movie,
        "TV" => Icons.Material.Filled.LiveTv,
        "Comic" => Icons.Material.Filled.AutoStories,
        "Music" => Icons.Material.Filled.MusicNote,
        _ => null,
    };
}
