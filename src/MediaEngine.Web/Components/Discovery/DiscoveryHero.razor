@namespace MediaEngine.Web.Components.Discovery
@inject NavigationManager Nav

@if (Hero is not null)
{
    <section class="discovery-hero-shell" style="--hero-accent: @Hero.AccentColor;">
        <div class="discovery-hero-backdrop" style="@BackgroundStyle"></div>
        <div class="discovery-hero-texture"></div>

        <div class="discovery-hero-content">
            <div class="discovery-hero-copy">
                @if (!string.IsNullOrWhiteSpace(Hero.Eyebrow))
                {
                    <div class="discovery-hero-eyebrow">@Hero.Eyebrow</div>
                }

                @if (!string.IsNullOrWhiteSpace(Hero.LogoUrl))
                {
                    <img src="@Hero.LogoUrl" alt="@Hero.Title" class="discovery-hero-logo" />
                }
                else
                {
                    <h1 class="discovery-hero-title">@Hero.Title</h1>
                }

                @if (!string.IsNullOrWhiteSpace(Hero.Subtitle))
                {
                    <div class="discovery-hero-subtitle">@Hero.Subtitle</div>
                }

                @if (!string.IsNullOrWhiteSpace(Hero.StatusText))
                {
                    <div class="discovery-hero-status">@Hero.StatusText</div>
                }

                @if (ShowMetaRow)
                {
                    <div class="discovery-hero-meta-row">
                        @if (!string.IsNullOrWhiteSpace(HeroMediaIcon))
                        {
                            <span class="discovery-hero-kind" title="@HeroMediaKindLabel">
                                <MudIcon Icon="@HeroMediaIcon" />
                                <span class="discovery-visually-hidden">@HeroMediaKindLabel</span>
                            </span>
                        }

                        @if (!string.IsNullOrWhiteSpace(HeroMetaDisplay))
                        {
                            <div class="discovery-hero-meta">@HeroMetaDisplay</div>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Hero.Description))
                {
                    <p class="discovery-hero-description">@Hero.Description</p>
                }

                @if (Hero.ProgressPct is > 0)
                {
                    <div class="discovery-hero-progress">
                        <div class="discovery-hero-progress-label">Progress</div>
                        <div class="discovery-hero-progress-bar">
                            <div class="discovery-hero-progress-fill" style="width: @($"{Math.Min(100, Hero.ProgressPct.Value):F0}%");"></div>
                        </div>
                    </div>
                }

                <div class="discovery-hero-actions">
                    <button type="button" class="discovery-hero-btn discovery-hero-btn-primary" @onclick="OpenPrimary">
                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Class="mr-1" />
                        @Hero.PrimaryActionLabel
                    </button>

                    @if (!string.IsNullOrWhiteSpace(Hero.SecondaryNavigationUrl))
                    {
                        <button type="button" class="discovery-hero-btn discovery-hero-btn-secondary" @onclick="OpenSecondary">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Class="mr-1" />
                            @Hero.SecondaryActionLabel
                        </button>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Hero.PreviewImageUrl))
            {
                <div class="discovery-hero-preview">
                    <img src="@Hero.PreviewImageUrl" alt="@Hero.Title" class="discovery-hero-preview-image" />
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public DiscoveryHeroViewModel Hero { get; set; } = default!;

    private string BackgroundStyle
    {
        get
        {
            var backdrop = Hero.BackgroundImageUrl ?? Hero.BannerImageUrl ?? Hero.PreviewImageUrl;
            if (string.IsNullOrWhiteSpace(backdrop))
            {
                return "background: radial-gradient(circle at top right, rgba(28, 231, 131, 0.16) 0%, rgba(4, 6, 12, 0) 28%), linear-gradient(135deg, rgba(4,6,12,0.98) 0%, rgba(2,4,8,1) 100%);";
            }

            return $"background-image: linear-gradient(180deg, rgba(3,5,10,0.12) 0%, rgba(3,5,10,0.58) 42%, rgba(3,5,10,0.98) 100%), linear-gradient(90deg, rgba(3,5,10,0.98) 0%, rgba(3,5,10,0.86) 34%, rgba(3,5,10,0.24) 74%, rgba(3,5,10,0.96) 100%), url('{backdrop}');";
        }
    }

    private string? HeroMediaKindLabel => ExtractLeadingMediaKind(Hero.MetaText);

    private string? HeroMediaIcon => ResolveMediaIcon(HeroMediaKindLabel);

    private string HeroMetaDisplay => TrimLeadingMediaKind(Hero.MetaText, HeroMediaKindLabel);

    private bool ShowMetaRow => !string.IsNullOrWhiteSpace(HeroMediaIcon) || !string.IsNullOrWhiteSpace(HeroMetaDisplay);

    private void OpenPrimary() => Nav.NavigateTo(Hero.PrimaryNavigationUrl);

    private void OpenSecondary()
    {
        if (!string.IsNullOrWhiteSpace(Hero.SecondaryNavigationUrl))
            Nav.NavigateTo(Hero.SecondaryNavigationUrl);
    }

    private static string? ExtractLeadingMediaKind(string? metaText)
    {
        if (string.IsNullOrWhiteSpace(metaText))
            return null;

        var first = metaText
            .Split('/', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .FirstOrDefault();

        return ResolveMediaIcon(first) is not null ? first : null;
    }

    private static string TrimLeadingMediaKind(string? metaText, string? mediaKind)
    {
        if (string.IsNullOrWhiteSpace(metaText))
            return string.Empty;

        if (string.IsNullOrWhiteSpace(mediaKind))
            return metaText;

        var parts = metaText
            .Split('/', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .ToList();

        if (parts.Count > 0 && string.Equals(parts[0], mediaKind, StringComparison.OrdinalIgnoreCase))
            parts.RemoveAt(0);

        return string.Join(" / ", parts);
    }

    private static string? ResolveMediaIcon(string? mediaKind) => mediaKind?.Trim() switch
    {
        "Book" => Icons.Material.Filled.MenuBook,
        "Audiobook" => Icons.Material.Filled.Headphones,
        "Movie" => Icons.Material.Filled.Movie,
        "TV" => Icons.Material.Filled.LiveTv,
        "Comic" => Icons.Material.Filled.AutoStories,
        "Music" => Icons.Material.Filled.MusicNote,
        _ => null,
    };
}

<style>
    .discovery-hero-shell {
        position: relative;
        overflow: hidden;
        border-radius: 0;
        min-height: clamp(440px, 56vw, 660px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: #03050a;
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
    }

    .discovery-hero-shell::after {
        content: "";
        position: absolute;
        inset: auto 0 0 0;
        height: 220px;
        background: linear-gradient(180deg, rgba(3, 5, 10, 0) 0%, rgba(3, 5, 10, 0.96) 100%);
        z-index: 0;
        pointer-events: none;
    }

    .discovery-hero-backdrop {
        position: absolute;
        inset: 0;
        background-position: center top;
        background-size: cover;
        transform: scale(1.03);
    }

    .discovery-hero-texture {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at top right, color-mix(in srgb, var(--hero-accent) 14%, transparent) 0%, transparent 32%),
            linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0) 20%);
        mix-blend-mode: screen;
        opacity: 0.46;
        z-index: 0;
        pointer-events: none;
    }

    .discovery-hero-content {
        position: relative;
        z-index: 1;
        min-height: inherit;
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(220px, 340px);
        align-items: end;
        gap: 28px;
        padding: clamp(28px, 5vw, 48px);
    }

    .discovery-hero-copy {
        max-width: 760px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        padding: clamp(22px, 3vw, 30px);
        padding-top: clamp(26px, 4vw, 36px);
        border-radius: 28px;
        background: linear-gradient(180deg, rgba(5, 8, 14, 0.68) 0%, rgba(5, 8, 14, 0.46) 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(22px) saturate(138%);
        box-shadow: 0 28px 60px rgba(0, 0, 0, 0.18);
    }

    .discovery-hero-eyebrow {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        padding: 7px 12px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--hero-accent) 18%, rgba(255, 255, 255, 0.02));
        border: 1px solid color-mix(in srgb, var(--hero-accent) 36%, rgba(255, 255, 255, 0.12));
        font-family: 'Montserrat', sans-serif;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(226, 232, 240, 0.94);
    }

    .discovery-hero-logo {
        width: min(100%, 460px);
        max-height: 180px;
        object-fit: contain;
        object-position: left center;
        display: block;
        filter: drop-shadow(0 14px 28px rgba(0, 0, 0, 0.32));
    }

    .discovery-hero-title {
        margin: 0;
        font-family: Georgia, 'Times New Roman', serif;
        font-size: clamp(2.8rem, 6vw, 5.8rem);
        font-weight: 700;
        line-height: 0.93;
        letter-spacing: -0.04em;
        color: rgba(248, 250, 252, 0.98);
        text-wrap: balance;
    }

    .discovery-hero-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: clamp(1rem, 1.6vw, 1.2rem);
        font-weight: 600;
        color: rgba(226, 232, 240, 0.9);
    }

    .discovery-hero-status {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.88rem;
        font-weight: 700;
        color: color-mix(in srgb, var(--hero-accent) 82%, white 10%);
    }

    .discovery-hero-meta-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
    }

    .discovery-hero-kind {
        width: 34px;
        height: 34px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(248, 250, 252, 0.92);
        backdrop-filter: blur(12px);
    }

    .discovery-hero-meta {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(226, 232, 240, 0.82);
    }

    .discovery-hero-description {
        margin: 0;
        max-width: 640px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.98rem;
        line-height: 1.7;
        color: rgba(226, 232, 240, 0.78);
    }

    .discovery-hero-progress {
        display: flex;
        flex-direction: column;
        gap: 8px;
        max-width: 320px;
        margin-top: 4px;
    }

    .discovery-hero-progress-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(148, 163, 184, 0.92);
    }

    .discovery-hero-progress-bar {
        height: 6px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
    }

    .discovery-hero-progress-fill {
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--hero-accent) 0%, rgba(255, 255, 255, 0.92) 100%);
    }

    .discovery-hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 8px;
    }

    .discovery-hero-btn {
        min-height: 48px;
        border: none;
        border-radius: 999px;
        padding: 0 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        cursor: pointer;
        transition: transform 0.18s ease, opacity 0.18s ease;
    }

    .discovery-hero-btn:hover {
        transform: translateY(-1px);
    }

    .discovery-hero-btn-primary {
        background: linear-gradient(135deg, var(--hero-accent) 0%, rgba(255,255,255,0.92) 100%);
        color: #051018;
    }

    .discovery-hero-btn-secondary {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(248, 250, 252, 0.96);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .discovery-hero-preview {
        align-self: end;
        justify-self: end;
        width: min(100%, 320px);
        aspect-ratio: 2 / 3;
        overflow: hidden;
        border-radius: 28px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 30px 56px rgba(0, 0, 0, 0.42);
        background: linear-gradient(180deg, rgba(10, 14, 22, 0.92) 0%, rgba(5, 8, 14, 0.96) 100%);
        backdrop-filter: blur(18px) saturate(130%);
    }

    .discovery-hero-preview-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .discovery-visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    @@media (max-width: 960px) {
        .discovery-hero-content {
            grid-template-columns: 1fr;
            align-items: end;
        }

        .discovery-hero-preview {
            width: min(58vw, 280px);
            justify-self: start;
        }
    }

    @@media (max-width: 640px) {
        .discovery-hero-shell {
            min-height: 0;
        }

        .discovery-hero-content {
            padding: 22px;
        }

        .discovery-hero-copy {
            gap: 12px;
            padding: 20px;
        }

        .discovery-hero-logo {
            width: min(100%, 320px);
            max-height: 120px;
        }

        .discovery-hero-preview {
            width: min(58vw, 220px);
            border-radius: 22px;
        }
    }
</style>
