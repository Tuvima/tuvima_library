@namespace MediaEngine.Web.Components.Discovery
@inject IJSRuntime JS

@if (Shelf.Items.Count > 0)
{
    <section class="discovery-shelf">
        <div class="discovery-shelf-header">
            <div class="discovery-shelf-copy">
                <h2 class="discovery-shelf-title">@Shelf.Title</h2>
                @if (!string.IsNullOrWhiteSpace(Shelf.Subtitle))
                {
                    <p class="discovery-shelf-subtitle">@Shelf.Subtitle</p>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(Shelf.SeeAllRoute))
            {
                <a href="@Shelf.SeeAllRoute" class="discovery-shelf-link">See all</a>
            }
        </div>

        <div class="discovery-shelf-track">
            @if (Shelf.Items.Count > 1 && !_atStart)
            {
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                               Color="Color.Inherit"
                               Class="discovery-shelf-arrow discovery-shelf-arrow-left"
                               aria-label="Scroll left"
                               OnClick="ScrollLeftAsync" />
            }

            <div class="discovery-shelf-scroll" @ref="_scrollRef">
                @foreach (var item in Shelf.Items)
                {
                    <DiscoveryCard Item="@item" />
                }
            </div>

            @if (Shelf.Items.Count > 1 && !_atEnd)
            {
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                               Color="Color.Inherit"
                               Class="discovery-shelf-arrow discovery-shelf-arrow-right"
                               aria-label="Scroll right"
                               OnClick="ScrollRightAsync" />
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public DiscoveryShelfViewModel Shelf { get; set; } = default!;

    private ElementReference _scrollRef;
    private bool _atStart = true;
    private bool _atEnd;

    protected override void OnParametersSet()
    {
        _atStart = true;
        _atEnd = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if ((firstRender || Shelf.Items.Count > 1) && Shelf.Items.Count > 1)
        {
            var state = await JS.InvokeAsync<ScrollBoundary>("getSwimlaneScrollState", _scrollRef);
            _atStart = state.AtStart;
            _atEnd = state.AtEnd;

            if (firstRender)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task ScrollLeftAsync()
    {
        var state = await JS.InvokeAsync<ScrollBoundary>("scrollSwimlaneEx", _scrollRef, "left");
        _atStart = state.AtStart;
        _atEnd = state.AtEnd;
    }

    private async Task ScrollRightAsync()
    {
        var state = await JS.InvokeAsync<ScrollBoundary>("scrollSwimlaneEx", _scrollRef, "right");
        _atStart = state.AtStart;
        _atEnd = state.AtEnd;
    }

    private sealed class ScrollBoundary
    {
        public bool AtStart { get; set; }
        public bool AtEnd { get; set; }
    }
}

<style>
    .discovery-shelf {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .discovery-shelf-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
    }

    .discovery-shelf-copy {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .discovery-shelf-title {
        margin: 0;
        font-family: Georgia, 'Times New Roman', serif;
        font-size: clamp(1.4rem, 2vw, 2rem);
        font-weight: 700;
        line-height: 1;
        color: rgba(248, 250, 252, 0.96);
    }

    .discovery-shelf-subtitle {
        margin: 0;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.92rem;
        line-height: 1.5;
        color: rgba(148, 163, 184, 0.88);
    }

    .discovery-shelf-link {
        color: rgba(248, 250, 252, 0.8);
        text-decoration: none;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .discovery-shelf-link:hover {
        color: white;
    }

    .discovery-shelf-track {
        position: relative;
        overflow: visible;
    }

    .discovery-shelf-scroll {
        --discovery-hover-clearance: clamp(240px, 26vw, 332px);
        --discovery-hover-lift: clamp(12px, 1.8vw, 18px);
        display: flex;
        align-items: flex-start;
        gap: clamp(16px, 1.6vw, 24px);
        overflow-x: auto;
        scroll-snap-type: x proximity;
        padding: calc(var(--discovery-hover-lift) + 8px) 2px calc(var(--discovery-hover-clearance) + 24px);
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .discovery-shelf-scroll::-webkit-scrollbar {
        display: none;
    }

    .discovery-shelf-arrow {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 56px;
        z-index: 3;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(248, 250, 252, 0.92);
        opacity: 0;
        transition: opacity 0.18s ease;
        border-radius: var(--app-radius-md);
    }

    .discovery-shelf-track:hover .discovery-shelf-arrow {
        opacity: 1;
    }

    .discovery-shelf-arrow-left {
        left: 0;
        background: linear-gradient(90deg, rgba(6, 10, 18, 0.96) 24%, transparent 100%);
    }

    .discovery-shelf-arrow-right {
        right: 0;
        background: linear-gradient(270deg, rgba(6, 10, 18, 0.96) 24%, transparent 100%);
    }

    @@media (hover: none) {
        .discovery-shelf-arrow {
            display: none;
        }
    }

    @@media (max-width: 640px) {
        .discovery-shelf-header {
            align-items: flex-start;
            flex-direction: column;
        }
    }
</style>
