@namespace MediaEngine.Web.Components.Discovery
@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar

<AppDialog Class="add-to-collection-dialog">
    <DialogContent>
        <div class="add-to-collection-shell">
            <div class="add-to-collection-header">
                <div class="add-to-collection-eyebrow">Collections</div>
                <h2 class="add-to-collection-title">Add "@WorkTitle" to a collection</h2>
                <p class="add-to-collection-copy">
                    Pick an existing collection to surface this title in curated rows and mixes.
                </p>
            </div>

            <div class="add-to-collection-toolbar">
                <AppTextField T="string"
                              Value="_searchText"
                              ValueChanged="OnSearchChanged"
                              Placeholder="Search collections..."
                              Variant="Variant.Outlined"
                              Immediate="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Search"
                              Class="add-to-collection-search" />
            </div>

            @if (_loading)
            {
                <div class="add-to-collection-state">
                    <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                    <span>Loading collections...</span>
                </div>
            }
            else if (FilteredCollections.Count == 0)
            {
                <div class="add-to-collection-state">
                    <MudIcon Icon="@Icons.Material.Filled.CollectionsBookmark"
                             Class="tl-u-font-size-40px tl-u-color-tl-text-faint" />
                    <span>No collections match that search.</span>
                </div>
            }
            else
            {
                <div class="add-to-collection-list">
                    @foreach (var collection in FilteredCollections)
                    {
                        var isSelected = _selectedCollectionId == collection.Id;
                        <AppNativeButton Type="button" Class='@($"add-to-collection-item {(isSelected ? " is-selected" : "")}")' Css="@($"--collection-accent: {collection.TypeColor};")" OnClick="() => SelectCollection(collection.Id)">
                            <div class="add-to-collection-item-main">
                                <div class="add-to-collection-item-name">@collection.Name</div>
                                @if (!string.IsNullOrWhiteSpace(collection.Description))
                                {
                                    <div class="add-to-collection-item-description">@collection.Description</div>
                                }
                            </div>
                            <div class="add-to-collection-item-meta">
                                <span class="add-to-collection-chip">@collection.TypeLabel</span>
                                <span class="add-to-collection-count">@collection.ItemCount items</span>
                            </div>
                        </AppNativeButton>
                    }
                </div>
            }

            <div class="add-to-collection-actions">
                <AppNativeButton Type="button" Class="add-to-collection-btn add-to-collection-btn-secondary" OnClick="Cancel">
                    Cancel
                </AppNativeButton>
                <AppNativeButton Type="button" Class="add-to-collection-btn add-to-collection-btn-primary" Disabled="@(_saving || _selectedCollectionId is null)" OnClick="SaveAsync">
                    @if (_saving)
                    {
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                    }
                    Add to collection
                </AppNativeButton>
            </div>
        </div>
    </DialogContent>
</AppDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired] public Guid WorkId { get; set; }
    [Parameter, EditorRequired] public string WorkTitle { get; set; } = string.Empty;

    private readonly List<ManagedCollectionViewModel> _collections = [];
    private Guid? _selectedCollectionId;
    private bool _loading = true;
    private bool _saving;
    private string _searchText = string.Empty;

    private IReadOnlyList<ManagedCollectionViewModel> FilteredCollections =>
        _collections
            .Where(collection =>
                string.IsNullOrWhiteSpace(_searchText)
                || collection.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                || (collection.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
                || collection.TypeLabel.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var collections = await ApiClient.GetManagedCollectionsAsync();
            _collections.AddRange(
                collections
                    .Where(collection => collection.IsEnabled)
                    .OrderByDescending(collection => collection.IsFeatured)
                    .ThenByDescending(collection => collection.ItemCount)
                    .ThenBy(collection => collection.Name, StringComparer.OrdinalIgnoreCase));

            _selectedCollectionId = _collections.FirstOrDefault()?.Id;
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnSearchChanged(string value)
    {
        _searchText = value;
        return Task.CompletedTask;
    }

    private void SelectCollection(Guid id)
    {
        _selectedCollectionId = id;
    }

    private async Task SaveAsync()
    {
        if (_selectedCollectionId is null)
        {
            return;
        }

        _saving = true;

        try
        {
            var ok = await ApiClient.AddCollectionItemAsync(_selectedCollectionId.Value, WorkId);
            if (!ok)
            {
                Snackbar.Add("The item could not be added to that collection.", Severity.Error);
                return;
            }

            Snackbar.Add($"Added \"{WorkTitle}\" to the selected collection.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}