@namespace MediaEngine.Web.Components.Discovery

@if (Hubs.Count > 0)
{
    <section class="discovery-hubs">
        <div class="discovery-hubs-header">
            <div>
                <h2 class="discovery-hubs-title">@Title</h2>
                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <p class="discovery-hubs-subtitle">@Subtitle</p>
                }
            </div>
        </div>

        <div class="discovery-hubs-grid">
            @foreach (var hub in Hubs)
            {
                <a href="@hub.NavigationUrl"
                   class="discovery-hub-card tl-card-hover--media"
                   style="--hub-accent: @(string.IsNullOrWhiteSpace(hub.AccentColor) ? "#1CE783" : hub.AccentColor);">
                    @if (!string.IsNullOrWhiteSpace(hub.ImageUrl))
                    {
                        <img src="@hub.ImageUrl" alt="@hub.Title" class="discovery-hub-image" loading="lazy" />
                    }
                    else if (GetPreviewImages(hub).Count > 0)
                    {
                        <div class="discovery-hub-stack" aria-hidden="true">
                            @for (var index = 0; index < GetPreviewImages(hub).Count; index++)
                            {
                                var previewImage = GetPreviewImages(hub)[index];
                                <img src="@previewImage"
                                     alt=""
                                     class="discovery-hub-stack-image"
                                     style="@GetStackStyle(index)" />
                            }
                        </div>
                    }

                    <div class="discovery-hub-overlay"></div>

                    <div class="discovery-hub-copy">
                        @if (!string.IsNullOrWhiteSpace(hub.Badge))
                        {
                            <div class="discovery-hub-badge">@hub.Badge</div>
                        }

                        <div class="discovery-hub-title">@hub.Title</div>

                        @if (!string.IsNullOrWhiteSpace(hub.Subtitle))
                        {
                            <div class="discovery-hub-subtitle">@hub.Subtitle</div>
                        }

                        <div class="discovery-hub-footer">
                            @if (!string.IsNullOrWhiteSpace(hub.CountLabel))
                            {
                                <span>@hub.CountLabel</span>
                            }
                            <span>Open</span>
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<DiscoveryHubViewModel> Hubs { get; set; } = [];
    [Parameter] public string Title { get; set; } = "Collections";
    [Parameter] public string? Subtitle { get; set; } = "Dynamic groupings built from your library.";

    private static IReadOnlyList<string> GetPreviewImages(DiscoveryHubViewModel hub) =>
        hub.PreviewImages
            .Where(image => !string.IsNullOrWhiteSpace(image))
            .Take(3)
            .ToList();

    private static string GetStackStyle(int index) => index switch
    {
        0 => "left: 28%; top: 56%; width: 34%; transform: translate(-50%, -50%) rotate(-8deg); z-index: 1;",
        1 => "left: 50%; top: 48%; width: 38%; transform: translate(-50%, -50%) rotate(0deg); z-index: 3;",
        _ => "left: 72%; top: 56%; width: 34%; transform: translate(-50%, -50%) rotate(8deg); z-index: 2;",
    };
}

<style>
    .discovery-hubs {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .discovery-hubs-title {
        margin: 0;
        font-family: Georgia, 'Times New Roman', serif;
        font-size: clamp(1.4rem, 2vw, 2rem);
        font-weight: 700;
        line-height: 1;
        color: rgba(248, 250, 252, 0.96);
    }

    .discovery-hubs-subtitle {
        margin: 8px 0 0;
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.92rem;
        line-height: 1.5;
        color: rgba(148, 163, 184, 0.88);
    }

    .discovery-hubs-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .discovery-hub-card {
        position: relative;
        overflow: hidden;
        min-height: 160px;
        border-radius: var(--app-radius-md);
        border: 1px solid var(--tl-border-subtle);
        background:
            radial-gradient(circle at top left, color-mix(in srgb, var(--hub-accent) 35%, transparent) 0%, transparent 54%),
            linear-gradient(180deg, rgba(13, 18, 30, 0.98) 0%, rgba(7, 10, 18, 0.98) 100%);
        text-decoration: none;
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.2);
        transition: transform var(--tl-motion-duration-medium) var(--tl-motion-ease-emphasized), border-color var(--tl-motion-duration-medium) var(--tl-motion-ease-standard), box-shadow var(--tl-motion-duration-medium) var(--tl-motion-ease-standard);
    }

    .discovery-hub-card.tl-card-hover--media:hover,
    .discovery-hub-card.tl-card-hover--media:focus-visible {
        transition-delay: 180ms;
    }

    .discovery-hub-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        opacity: 0.58;
        transition: transform var(--tl-motion-duration-slow) var(--tl-motion-ease-emphasized), filter var(--tl-motion-duration-medium) var(--tl-motion-ease-standard), opacity var(--tl-motion-duration-medium) var(--tl-motion-ease-standard);
    }

    .discovery-hub-card:hover .discovery-hub-image,
    .discovery-hub-card:focus-visible .discovery-hub-image {
        transform: scale(var(--tl-hover-artwork-scale)) translateY(var(--tl-hover-artwork-pan-y));
        filter: saturate(1.08) contrast(1.04);
        opacity: 0.72;
        transition-delay: 180ms;
    }

    .discovery-hub-stack {
        position: absolute;
        inset: 0;
    }

    .discovery-hub-stack-image {
        position: absolute;
        aspect-ratio: 2 / 3;
        border-radius: var(--app-radius-md);
        object-fit: cover;
        box-shadow: 0 20px 36px rgba(0, 0, 0, 0.34);
        border: 1px solid rgba(255, 255, 255, 0.14);
        opacity: 0.96;
        transition: transform var(--tl-motion-duration-slow) var(--tl-motion-ease-emphasized), filter var(--tl-motion-duration-medium) var(--tl-motion-ease-standard);
    }

    .discovery-hub-card:hover .discovery-hub-stack-image,
    .discovery-hub-card:focus-visible .discovery-hub-stack-image {
        filter: saturate(1.08) contrast(1.04);
        transition-delay: 180ms;
    }

    .discovery-hub-overlay {
        position: absolute;
        inset: 0;
        background:
            linear-gradient(180deg, rgba(6, 10, 18, 0.28) 0%, rgba(6, 10, 18, 0.84) 100%),
            linear-gradient(180deg, transparent 0%, color-mix(in srgb, var(--hub-accent) 18%, transparent) 100%);
    }

    .discovery-hub-copy {
        position: relative;
        z-index: 1;
        min-height: 160px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        gap: 8px;
        padding: 18px;
    }

    .discovery-hub-badge {
        width: fit-content;
        display: inline-flex;
        align-items: center;
        padding: 5px 9px;
        border-radius: var(--app-radius-sm);
        background: rgba(2, 6, 16, 0.64);
        border: 1px solid var(--tl-border-subtle);
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(248, 250, 252, 0.94);
    }

    .discovery-hub-title {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 1.02rem;
        font-weight: 700;
        line-height: 1.2;
        color: rgba(248, 250, 252, 0.96);
    }

    .discovery-hub-subtitle {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.82rem;
        color: rgba(226, 232, 240, 0.74);
    }

    .discovery-hub-footer {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        min-width: 0;
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(248, 250, 252, 0.88);
    }

    @@media (min-width: 900px) {
        .discovery-hubs-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }
    }

    @@media (min-width: 1280px) {
        .discovery-hubs-grid {
            grid-template-columns: repeat(5, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .discovery-hubs-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .discovery-hub-card,
        .discovery-hub-image,
        .discovery-hub-stack-image {
            transition-duration: 1ms !important;
            transform: none !important;
            animation: none !important;
        }
    }
</style>
