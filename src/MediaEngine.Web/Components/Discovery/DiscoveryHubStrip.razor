@namespace MediaEngine.Web.Components.Discovery

@if (Hubs.Count > 0)
{
    <section class="discovery-hubs">
        <div class="discovery-hubs-header">
            <div>
                <h2 class="discovery-hubs-title">@Title</h2>
                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <p class="discovery-hubs-subtitle">@Subtitle</p>
                }
            </div>
        </div>

        <div class="discovery-hubs-grid">
            @foreach (var hub in Hubs)
            {
                <AppCssElement Tag="a"
                   href="@hub.NavigationUrl"
                   Class="discovery-hub-card tl-card-hover--media"
                   Css="@($"--hub-accent: {(string.IsNullOrWhiteSpace(hub.AccentColor) ? "#1CE783" : hub.AccentColor)};")">
                    @if (!string.IsNullOrWhiteSpace(hub.ImageUrl))
                    {
                        <img src="@hub.ImageUrl" alt="@hub.Title" class="discovery-hub-image" loading="lazy" />
                    }
                    else if (GetPreviewImages(hub).Count > 0)
                    {
                        <div class="discovery-hub-stack" aria-hidden="true">
                            @for (var index = 0; index < GetPreviewImages(hub).Count; index++)
                            {
                                var previewImage = GetPreviewImages(hub)[index];
                                <AppCssElement Tag="img" src="@previewImage"
                                     alt=""
                                     Class="discovery-hub-stack-image"
                                     Css="@GetStackStyle(index)" />
                            }
                        </div>
                    }

                    <div class="discovery-hub-overlay"></div>

                    <div class="discovery-hub-copy">
                        @if (!string.IsNullOrWhiteSpace(hub.Badge))
                        {
                            <div class="discovery-hub-badge">@hub.Badge</div>
                        }

                        <div class="discovery-hub-title">@hub.Title</div>

                        @if (!string.IsNullOrWhiteSpace(hub.Subtitle))
                        {
                            <div class="discovery-hub-subtitle">@hub.Subtitle</div>
                        }

                        <div class="discovery-hub-footer">
                            @if (!string.IsNullOrWhiteSpace(hub.CountLabel))
                            {
                                <span>@hub.CountLabel</span>
                            }
                            <span>Open</span>
                        </div>
                    </div>
                </AppCssElement>
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<DiscoveryHubViewModel> Hubs { get; set; } = [];
    [Parameter] public string Title { get; set; } = "Collections";
    [Parameter] public string? Subtitle { get; set; } = "Dynamic groupings built from your library.";

    private static IReadOnlyList<string> GetPreviewImages(DiscoveryHubViewModel hub) =>
        hub.PreviewImages
            .Where(image => !string.IsNullOrWhiteSpace(image))
            .Take(3)
            .ToList();

    private static string GetStackStyle(int index) => index switch
    {
        0 => "left: 28%; top: 56%; width: 34%; transform: translate(-50%, -50%) rotate(-8deg); z-index: 1;",
        1 => "left: 50%; top: 48%; width: 38%; transform: translate(-50%, -50%) rotate(0deg); z-index: 3;",
        _ => "left: 72%; top: 56%; width: 34%; transform: translate(-50%, -50%) rotate(8deg); z-index: 2;",
    };
}
