@page "/read"
@page "/read/{Tab}"
@using MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Components.MediaHub
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.MediaTiles
@inject MediaTileComposerService MediaTiles

@namespace MediaEngine.Web.Components.Pages

<PageTitle>Read - Tuvima</PageTitle>

@if (string.IsNullOrWhiteSpace(Tab))
{
    @if (_loading)
    {
        <div class="browse-shell__loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Class="tl-u-color-tl-text-faint" />
        </div>
    }
    else if (_loadFailed)
    {
        <AppErrorState Title="Read failed to load"
                       Message="The Dashboard could not load the Read landing from the Engine."
                       Retry="LoadLandingAsync" />
    }
    else if (_landingPage is not null)
    {
        <MediaHubPage SectionType="MediaHubSectionType.Read"
                      Title="Read"
                      Subtitle="Books and comics from your local library"
                      SelectedMode="all"
                      AvailableModes="@ReadModes"
                      HeroItem="@_landingPage.Hero"
                      HeroItems="@_landingPage.Spotlights"
                      Shelves="@ReadHubShelves"
                      SearchPlaceholder="Search books and comics..."
                      RouteBase="/read" />
    }
}
else
{
    <MediaBrowseShell Tab="@Tab"
                      Preset="@Preset" />
}

@code {
    [Parameter] public string? Tab { get; set; }

    private DiscoveryPageViewModel? _landingPage;
    private bool _loading = true;
    private bool _loadFailed;

    private static readonly IReadOnlyList<MediaHubModeViewModel> ReadModes =
    [
        new("all", "All", "/read"),
        new("books", "Books", "/read/books"),
        new("comics", "Comics", "/read/comics"),
    ];

    private IReadOnlyList<MediaHubShelfViewModel> ReadHubShelves => _landingPage?.Shelves
        .Where(shelf => !IsReadSeriesShelf(shelf))
        .Select((shelf, index) => MediaHubShelfViewModel.FromShelf(
            HubShelfKey(shelf, index),
            shelf,
            IsContinueShelf(shelf)))
        .ToList() ?? [];

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(Tab) || _landingPage is not null)
        {
            _loading = false;
            return;
        }

        await LoadLandingAsync();
    }

    private async Task LoadLandingAsync()
    {
        _loading = true;
        _loadFailed = false;

        try
        {
            _landingPage = await MediaTiles.BuildReadAsync();
        }
        catch
        {
            _loadFailed = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private static bool IsReadSeriesShelf(MediaTileShelfViewModel shelf) =>
        string.Equals(shelf.Title, "Series & Reading Lists", StringComparison.OrdinalIgnoreCase)
        || string.Equals(shelf.Subtitle, "Book series, comic runs, and grouped reading", StringComparison.OrdinalIgnoreCase)
        || shelf.SeeAllRoute?.Contains("grouping=series", StringComparison.OrdinalIgnoreCase) == true;

    private static bool IsContinueShelf(MediaTileShelfViewModel shelf) =>
        shelf.Title.Contains("Continue", StringComparison.OrdinalIgnoreCase);

    private static string HubShelfKey(MediaTileShelfViewModel shelf, int index) =>
        string.IsNullOrWhiteSpace(shelf.Title)
            ? $"read-shelf-{index}"
            : $"read-{shelf.Title.ToLowerInvariant().Replace(' ', '-')}";

    private static readonly LibraryBrowsePreset Preset = new()
    {
        RouteBase = "/read",
        Title = "Read",
        HeroVariant = BrowseHeroVariant.Read,
        UseExplicitDefaultTabRoute = true,
        Tabs =
        [
            new BrowseTabPreset
            {
                Id = "books",
                Label = "Books",
                MediaType = "Books",
                GroupingOptions =
                [
                    new("all", "All Books", Icons.Material.Outlined.AutoStories),
                    new("series", "Series", Icons.Material.Outlined.CollectionsBookmark),
                ],
                DefaultGrouping = "all",
                DefaultLayout = LibraryLayoutMode.Card,
            },
            new BrowseTabPreset
            {
                Id = "comics",
                Label = "Comics",
                MediaType = "Comics",
                GroupingOptions =
                [
                    new("series", "Volumes", Icons.Material.Outlined.CollectionsBookmark),
                    new("all", "Issues", Icons.Material.Outlined.ViewAgenda),
                ],
                DefaultGrouping = "series",
                DefaultLayout = LibraryLayoutMode.Card,
            },
        ],
    };
}
