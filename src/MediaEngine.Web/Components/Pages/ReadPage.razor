@page "/read"
@inject DiscoveryComposerService Discovery
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer State
@implements IDisposable

<PageTitle>Read - Tuvima</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" Style="border-radius: 4px;" />
}
else
{
    <GlobalBackground ImageUrl="@_page.Hero?.BackgroundImageUrl" Color="@_page.AccentColor" />

    <div class="read-discovery-page">
        @if (_page.Hero is not null)
        {
            <DiscoveryHero Hero="@_page.Hero" />
        }

        @if (_page.Hubs.Count > 0)
        {
            <DiscoveryHubStrip Hubs="@_page.Hubs"
                               Title="Reading collections"
                               Subtitle="Series, sagas, and grouped shelves built dynamically from your library." />
        }

        <div class="read-discovery-shelves">
            @foreach (var shelf in _page.Shelves)
            {
                <DiscoveryShelf Shelf="@shelf" />
            }
        </div>

        <section class="read-discovery-catalog-shell">
            <div class="read-discovery-catalog-header">
                <div>
                    <h2 class="read-discovery-catalog-title">Browse your reading library</h2>
                    <p class="read-discovery-catalog-copy">
                        Search, filter, and sort books and comics without leaving the discovery flow.
                    </p>
                </div>

                <div class="read-discovery-toolbar">
                    <div class="read-discovery-tabs">
                        @foreach (var tab in _tabs)
                        {
                            <button type="button"
                                    class="read-discovery-tab @(_activeTab == tab ? "is-active" : "")"
                                    style="@(_activeTab == tab ? $"--tab-accent: {_page.AccentColor};" : string.Empty)"
                                    @onclick="() => SetTab(tab)">
                                @tab
                            </button>
                        }
                    </div>

                    <div class="read-discovery-filters">
                        <div class="read-discovery-status">
                            @foreach (var status in _statuses)
                            {
                                <button type="button"
                                        class="read-discovery-chip @(_activeStatus == status ? "is-active" : "")"
                                        style="@(_activeStatus == status ? $"--chip-accent: {_page.AccentColor};" : string.Empty)"
                                        @onclick="() => SetStatus(status)">
                                    @status
                                </button>
                            }
                        </div>

                        <MudTextField T="string"
                                      Value="_searchText"
                                      ValueChanged="OnSearchChanged"
                                      Placeholder="Search titles, creators, and series..."
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Outlined.Search"
                                      Class="read-discovery-search" />

                        <MudSelect T="string"
                                   Value="_sortBy"
                                   ValueChanged="OnSortChanged"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Class="read-discovery-sort">
                            <MudSelectItem T="string" Value="@("Newest")">Newest</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Title")">Title</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Year")">Year</MudSelectItem>
                        </MudSelect>
                    </div>
                </div>
            </div>

            @if (_filteredCatalog.Count == 0)
            {
                <div class="read-discovery-empty">
                    <MudIcon Icon="@Icons.Material.Filled.AutoStories"
                             Style="font-size: 48px; color: rgba(255,255,255,0.18);" />
                    <p>No reading titles match these filters.</p>
                </div>
            }
            else
            {
                <div class="read-discovery-catalog">
                    @foreach (var card in _filteredCatalog)
                    {
                        <DiscoveryCard Item="@card" />
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    private static readonly string[] _tabs = ["All", "Books", "Comics"];
    private static readonly string[] _statuses = ["All", "In Progress", "Finished"];

    private bool _loading = true;
    private string _activeTab = "All";
    private string _activeStatus = "All";
    private string _searchText = string.Empty;
    private string _sortBy = "Newest";
    private DiscoveryPageViewModel _page = new() { Key = "read", AccentColor = "#5DCAA5" };
    private List<DiscoveryCardViewModel> _filteredCatalog = [];

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        try
        {
            _page = await Discovery.BuildReadAsync();
            ApplyFilters();
        }
        catch
        {
            _page = new DiscoveryPageViewModel
            {
                Key = "read",
                AccentColor = "#5DCAA5",
                EmptyTitle = "Nothing to read yet.",
                EmptySubtitle = "Books and comics appear here once they are added to the library."
            };
            _filteredCatalog = [];
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<DiscoveryCardViewModel> cards = _page.Catalog;

        cards = _activeTab switch
        {
            "Books" => cards.Where(card => string.Equals(card.MediaKind, "Book", StringComparison.OrdinalIgnoreCase)),
            "Comics" => cards.Where(card => string.Equals(card.MediaKind, "Comic", StringComparison.OrdinalIgnoreCase)),
            _ => cards
        };

        cards = _activeStatus switch
        {
            "In Progress" => cards.Where(card => card.ProgressPct is > 0 and < 99.5),
            "Finished" => cards.Where(card => card.ProgressPct >= 99.5),
            _ => cards
        };

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var term = _searchText.Trim();
            cards = cards.Where(card => MatchesSearch(card, term));
        }

        cards = _sortBy switch
        {
            "Title" => cards.OrderBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            "Year" => cards.OrderByDescending(card => card.SortYear).ThenBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            _ => cards.OrderByDescending(card => card.SortTimestamp).ThenBy(card => card.Title, StringComparer.OrdinalIgnoreCase)
        };

        _filteredCatalog = cards.ToList();
    }

    private static bool MatchesSearch(DiscoveryCardViewModel card, string term) =>
        card.Title.Contains(term, StringComparison.OrdinalIgnoreCase)
        || (card.Subtitle?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || (card.Creator?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || (card.CollectionKey?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || (card.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || card.Genres.Any(genre => genre.Contains(term, StringComparison.OrdinalIgnoreCase));

    private void SetTab(string tab)
    {
        _activeTab = tab;
        ApplyFilters();
    }

    private void SetStatus(string status)
    {
        _activeStatus = status;
        ApplyFilters();
    }

    private Task OnSearchChanged(string value)
    {
        _searchText = value;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private Task OnSortChanged(string value)
    {
        _sortBy = value;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private void OnStateChanged()
    {
        _ = InvokeAsync(LoadAsync);
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }
}

<style>
    .read-discovery-page {
        display: flex;
        flex-direction: column;
        gap: 34px;
        padding: 0 1.5rem 5rem;
    }

    .read-discovery-shelves {
        display: flex;
        flex-direction: column;
        gap: 36px;
    }

    .read-discovery-catalog-shell {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .read-discovery-catalog-header {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .read-discovery-catalog-title {
        margin: 0;
        font-family: Georgia, 'Times New Roman', serif;
        font-size: clamp(1.5rem, 2vw, 2.15rem);
        font-weight: 700;
        line-height: 1;
        color: rgba(248, 250, 252, 0.96);
    }

    .read-discovery-catalog-copy {
        margin: 10px 0 0;
        max-width: 620px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.94rem;
        line-height: 1.6;
        color: rgba(148, 163, 184, 0.88);
    }

    .read-discovery-toolbar {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .read-discovery-tabs,
    .read-discovery-status {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .read-discovery-tab,
    .read-discovery-chip {
        min-height: 38px;
        padding: 0 16px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.03);
        color: rgba(226, 232, 240, 0.86);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        cursor: pointer;
        transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease;
    }

    .read-discovery-tab:hover,
    .read-discovery-chip:hover {
        transform: translateY(-1px);
        border-color: rgba(255, 255, 255, 0.14);
    }

    .read-discovery-tab.is-active,
    .read-discovery-chip.is-active {
        border-color: color-mix(in srgb, var(--tab-accent, var(--chip-accent)) 54%, rgba(255,255,255,0.12));
        background: color-mix(in srgb, var(--tab-accent, var(--chip-accent)) 18%, rgba(255,255,255,0.02));
        color: rgba(248, 250, 252, 0.96);
    }

    .read-discovery-filters {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(240px, 420px) 160px;
        gap: 14px;
        align-items: start;
    }

    .read-discovery-search,
    .read-discovery-sort {
        width: 100%;
    }

    .read-discovery-catalog {
        display: flex;
        flex-wrap: wrap;
        gap: 22px;
    }

    .read-discovery-empty {
        min-height: 220px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        color: rgba(226, 232, 240, 0.7);
        font-family: 'Montserrat', sans-serif;
    }

    @@media (min-width: 768px) {
        .read-discovery-page {
            padding: 0 4rem 5rem;
        }
    }

    @@media (max-width: 960px) {
        .read-discovery-filters {
            grid-template-columns: 1fr;
        }
    }
</style>
