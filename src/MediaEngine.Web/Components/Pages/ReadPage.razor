@page "/read"
@page "/read/{Tab}"
@using MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Components.MediaHub
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.MediaTiles
@inject MediaTileComposerService MediaTiles

@namespace MediaEngine.Web.Components.Pages

<PageTitle>Read - Tuvima</PageTitle>

<MediaSectionShell Title="Read" NavigationGroups="@ReadNavigationGroups">
    <MediaLaneHeader Title="Read"
                     Modes="@ReadModes"
                     ActiveMode="@ActiveReadMode" />

    @if (string.IsNullOrWhiteSpace(Tab))
    {
        @if (_loading)
        {
            <div class="browse-shell__loading">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" Class="tl-u-color-tl-text-faint" />
            </div>
        }
        else if (_loadFailed)
        {
            <AppErrorState Title="Read failed to load"
                           Message="The Dashboard could not load the Read landing from the Engine."
                           Retry="LoadLandingAsync" />
        }
        else if (_landingPage is not null)
        {
            <MediaHubPage SectionType="MediaHubSectionType.Read"
                          Title="Read"
                          Subtitle="Books and comics from your local library"
                          SelectedMode="all"
                          AvailableModes="@ReadModes"
                          Shelves="@ReadHubShelves"
                          SearchPlaceholder="Search books and comics..."
                          RouteBase="/read"
                          SupportsHero="false"
                          SupportsHeader="false"
                          SupportsNavigation="false" />
        }
    }
    else
    {
        <MediaBrowseShell Tab="@Tab"
                          Preset="@Preset"
                          ShowTitleBlock="false"
                          ShowTabNavigation="false" />
    }
</MediaSectionShell>

@code {
    [Parameter] public string? Tab { get; set; }

    private DiscoveryPageViewModel? _landingPage;
    private bool _loading = true;
    private bool _loadFailed;

    private string ActiveReadMode => Tab?.Trim().ToLowerInvariant() switch
    {
        "books" => "books",
        "comics" => "comics",
        _ => "all",
    };

    private static readonly IReadOnlyList<MediaHubModeViewModel> ReadModes =
    [
        new("all", "Discover", "/read"),
        new("books", "Books", "/read/books"),
        new("comics", "Comics", "/read/comics"),
    ];

    private static IReadOnlyList<MediaSectionNavigationGroup> ReadNavigationGroups =>
    [
        new("Library",
        [
            new("Discover", "/read", Icons.Material.Outlined.Explore, Exact: true),
            new("Books", "/read/books", Icons.Material.Outlined.MenuBook),
            new("Comics", "/read/comics", Icons.Material.Outlined.AutoStories),
        ]),
        new("Reading",
        [
            new("My List", "/my-list", Icons.Material.Outlined.BookmarkBorder, Exact: true),
            new("In Progress", "/read/books?status=in-progress", Icons.Material.Outlined.Timelapse, Exact: true),
            new("Unread", "/read/books?status=not-started", Icons.Material.Outlined.MarkEmailUnread, Exact: true),
            new("Recently Added", "/read/books?sort=newest", Icons.Material.Outlined.Schedule, Exact: true),
        ]),
    ];

    private IReadOnlyList<MediaHubShelfViewModel> ReadHubShelves => _landingPage?.Shelves
        .Select(shelf => MediaHubShelfViewModel.FromShelf(shelf))
        .ToList() ?? [];

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(Tab) || _landingPage is not null)
        {
            _loading = false;
            return;
        }

        await LoadLandingAsync();
    }

    private async Task LoadLandingAsync()
    {
        _loading = true;
        _loadFailed = false;

        try
        {
            _landingPage = await MediaTiles.BuildReadAsync();
        }
        catch
        {
            _loadFailed = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private static readonly LibraryBrowsePreset Preset = new()
    {
        RouteBase = "/read",
        Title = "Read",
        HeroVariant = BrowseHeroVariant.Read,
        UseExplicitDefaultTabRoute = true,
        Tabs =
        [
            new BrowseTabPreset
            {
                Id = "books",
                Label = "Books",
                MediaType = "Books",
                GroupingOptions =
                [
                    new("all", "Books", Icons.Material.Outlined.AutoStories),
                    new("authors", "Authors", Icons.Material.Outlined.PersonOutline),
                    new("series", "Series", Icons.Material.Outlined.CollectionsBookmark),
                    new("timeline", "Timeline", Icons.Material.Outlined.Timeline),
                ],
                DefaultGrouping = "all",
                DefaultLayout = LibraryLayoutMode.Card,
                YearSemantic = "Original publication year",
            },
            new BrowseTabPreset
            {
                Id = "comics",
                Label = "Comics",
                MediaType = "Comics",
                GroupingOptions =
                [
                    new("series", "Volumes", Icons.Material.Outlined.CollectionsBookmark),
                    new("all", "Issues", Icons.Material.Outlined.ViewAgenda),
                    new("creators", "Creators", Icons.Material.Outlined.PeopleOutline),
                    new("publishers", "Publishers", Icons.Material.Outlined.Business),
                    new("timeline", "Timeline", Icons.Material.Outlined.Timeline),
                ],
                DefaultGrouping = "series",
                DefaultLayout = LibraryLayoutMode.Card,
                YearSemantic = "Issue publication year",
            },
        ],
    };
}
