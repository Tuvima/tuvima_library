@page "/book/{Id:guid}"
@using MediaEngine.Web.Components.Universe

<PageTitle>@(Id.ToString()) — Tuvima Library</PageTitle>

<BookDetailContent WorkId="@Id"
                   AutoOpenEdit="@(AutoEdit == true)"
                   PreferredMode="@Mode" />

@code {
    [Parameter] public Guid Id { get; set; }

    [SupplyParameterFromQuery(Name = "edit")]
    public bool? AutoEdit { get; set; }

    [SupplyParameterFromQuery(Name = "mode")]
    public string? Mode { get; set; }
}
