@page "/book/{Id:guid}"
@inject UIOrchestratorService  Orchestrator
@inject UniverseStateContainer  State
@inject NavigationManager       Nav

<PageTitle>@(_work?.Title ?? "Book") — Tuvima Library</PageTitle>

@* — Edit-metadata panel — *@
<HubEditPanel @bind-IsOpen="_editDrawerOpen"
              HubId="@(_hub?.Id ?? Guid.Empty)"
              EntityId="@(_work?.Id ?? Guid.Empty)"
              MediaType="@_work?.MediaType"
              CurrentCoverUrl="@_work?.CoverUrl"
              OnApplied="@OnEditApplied" />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else if (_work is null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">Book not found.</MudAlert>
    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Nav.NavigateTo("/"))">
        Back to Home
    </MudButton>
}
else
{
    @* — Fixed hero background — *@
    @if (!string.IsNullOrEmpty(_work.HeroUrl))
    {
        <div class="detail-hero-fixed">
            <img src="@_work.HeroUrl" alt="" />
        </div>
        <div class="detail-hero-fade"></div>
    }
    else if (!string.IsNullOrEmpty(_work.CoverUrl))
    {
        <div class="detail-hero-fixed detail-hero-cover-blur">
            <img src="@_work.CoverUrl" alt="" />
        </div>
        <div class="detail-hero-fade"></div>
    }

    @* — Scrollable content layer — *@
    <div class="detail-content-layer book-detail-page">

        @* — Breadcrumb — *@
        <div class="book-detail-breadcrumb-outer">
            <nav class="book-detail-breadcrumb">
                <button class="book-detail-bc-link" @onclick="@(() => Nav.NavigateTo("/"))">Home</button>
                <span class="book-detail-bc-sep">/</span>
                <button class="book-detail-bc-link" @onclick="@(() => Nav.NavigateTo(GetLane().Route))">@GetLane().Label</button>
                @if (!string.IsNullOrEmpty(_work.Author))
                {
                    <span class="book-detail-bc-sep">/</span>
                    @if (_authorPerson is not null)
                    {
                        <button class="book-detail-bc-link book-detail-bc-author"
                                @onclick="@(() => Nav.NavigateTo($"/person/{_authorPerson.Id}"))">
                            @_work.Author
                        </button>
                    }
                    else
                    {
                        <span class="book-detail-bc-current">@_work.Author</span>
                    }
                }
                <span class="book-detail-bc-sep">/</span>
                <span class="book-detail-bc-current">@_work.Title</span>
            </nav>
        </div>

        @* — Main 3-column panel — *@
        <div class="book-detail-main-outer">
            <div class="book-detail-main-panel">

                @* — Left sidebar — *@
                <aside class="book-detail-sidebar">

                    @* — Author slot (reserved height to prevent layout shift) — *@
                    <div class="book-detail-sidebar-item book-detail-sidebar-person-slot" style="min-height: 80px;">
                        <span class="book-detail-sidebar-label">Author</span>
                        @if (!string.IsNullOrEmpty(_work.Author))
                        {
                            @if (_authorPerson is not null)
                            {
                                <div class="book-detail-sidebar-author-wrap"
                                     @onclick="@(() => Nav.NavigateTo($"/person/{_authorPerson.Id}"))">
                                    @if (!string.IsNullOrEmpty(_authorPerson.LocalHeadshotUrl))
                                    {
                                        <img src="@_authorPerson.LocalHeadshotUrl" alt="@_authorPerson.Name"
                                             class="book-detail-sidebar-avatar" />
                                    }
                                    else if (!string.IsNullOrEmpty(_authorPerson.HeadshotUrl))
                                    {
                                        <img src="@_authorPerson.HeadshotUrl" alt="@_authorPerson.Name"
                                             class="book-detail-sidebar-avatar" />
                                    }
                                    else
                                    {
                                        <div class="book-detail-sidebar-avatar book-detail-sidebar-avatar-initials">
                                            @_authorPerson.Initials
                                        </div>
                                    }
                                    <span class="book-detail-sidebar-author">@_work.Author</span>
                                </div>
                            }
                            else
                            {
                                <span class="book-detail-sidebar-value">@_work.Author</span>
                            }
                        }
                        else
                        {
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" Height="16px" />
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" Class="mt-2" />
                        }
                    </div>

                    @* — Narrator slot (reserved height to prevent layout shift) — *@
                    <div class="book-detail-sidebar-item book-detail-sidebar-person-slot" style="min-height: 80px;">
                        <span class="book-detail-sidebar-label">Narrator</span>
                        @if (_narratorPerson is not null)
                        {
                            <div class="book-detail-sidebar-author-wrap"
                                 @onclick="@(() => Nav.NavigateTo($"/person/{_narratorPerson.Id}"))">
                                @if (!string.IsNullOrEmpty(_narratorPerson.LocalHeadshotUrl))
                                {
                                    <img src="@_narratorPerson.LocalHeadshotUrl" alt="@_narratorPerson.Name"
                                         class="book-detail-sidebar-avatar" />
                                }
                                else if (!string.IsNullOrEmpty(_narratorPerson.HeadshotUrl))
                                {
                                    <img src="@_narratorPerson.HeadshotUrl" alt="@_narratorPerson.Name"
                                         class="book-detail-sidebar-avatar" />
                                }
                                else
                                {
                                    <div class="book-detail-sidebar-avatar book-detail-sidebar-avatar-initials">
                                        @_narratorPerson.Initials
                                    </div>
                                }
                                <span class="book-detail-sidebar-author">@_narratorPerson.Name</span>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(ActiveWork?.Narrator))
                        {
                            <div class="book-detail-sidebar-narrator-text">
                                <MudIcon Icon="@Icons.Material.Filled.Headphones"
                                         Style="font-size: 0.9rem; color: rgba(201,146,46,0.7); margin-right: 5px;" />
                                <span class="book-detail-sidebar-value">@ActiveWork!.Narrator</span>
                            </div>
                        }
                        else
                        {
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="120px" Height="16px" />
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" Class="mt-2" />
                        }
                    </div>

                    @{
                        var genres        = GenreTags;
                        var visibleGenres = _showAllGenres ? genres : genres.Take(3).ToList();
                        var hiddenCount   = genres.Count - 3;
                    }
                    @if (genres.Count > 0)
                    {
                        <div class="book-detail-sidebar-item">
                            <span class="book-detail-sidebar-label">Genre(s)</span>
                            <div class="book-detail-genre-row">
                                @foreach (var tag in visibleGenres)
                                {
                                    <span class="book-detail-genre-chip">@tag</span>
                                }
                                @if (!_showAllGenres && hiddenCount > 0)
                                {
                                    <button class="book-detail-genre-more"
                                            @onclick="@(() => _showAllGenres = true)">
                                        +@hiddenCount more
                                    </button>
                                }
                                @if (_showAllGenres && genres.Count > 3)
                                {
                                    <button class="book-detail-genre-more"
                                            @onclick="@(() => _showAllGenres = false)">
                                        Less
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_work.DisplayIdentifier))
                    {
                        <div class="book-detail-sidebar-item">
                            <span class="book-detail-sidebar-label">@_work.DisplayIdentifierLabel</span>
                            <span class="book-detail-sidebar-value">@_work.DisplayIdentifier</span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_work.Series))
                    {
                        <div class="book-detail-sidebar-item">
                            <span class="book-detail-sidebar-label">Series</span>
                            <span class="book-detail-sidebar-value">
                                @_work.Series
                                @if (!string.IsNullOrEmpty(_work.SeriesPosition))
                                {
                                    <span class="book-detail-series-pos">#@_work.SeriesPosition</span>
                                }
                            </span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_work.FictionalUniverseQid))
                    {
                        <div class="book-detail-sidebar-item">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth
                                       StartIcon="@Icons.Material.Filled.AccountTree"
                                       OnClick="@(() => Nav.NavigateTo($"/universe/{_work.FictionalUniverseQid}/explore"))">
                                Explore Universe
                            </MudButton>
                        </div>
                    }

                </aside>

                @* — Shared variables — *@
                @{
                    var activeCoverUrl = ActiveWork?.CoverUrl ?? _work.CoverUrl;
                    var coverIsAudio   = ActiveFormatKey == "audiobook";
                    var progressPct    = _activeJourney?.ProgressPct ?? 0;
                    var hasProgress    = progressPct is > 0 and < 99.5;
                    var _fmts          = AvailableFormats();
                    var ratingStars    = GetRatingStars();
                    var hasRating      = !string.IsNullOrEmpty(ratingStars);
                    var hasTime        = _work.ReadingTimeDisplay is not null;
                    var hasYear        = !string.IsNullOrEmpty(_work.Year);
                    var metaCount      = (hasRating ? 1 : 0) + (hasTime ? 1 : 0) + (hasYear ? 1 : 0);
                }

                @* — Center content — *@
                <div class="book-detail-content">

                    @* Title — desktop *@
                    <h1 class="book-detail-title book-desktop-only">@_work.Title</h1>

                    @* Format slider — desktop only *@
                    @if (_fmts.Count > 1)
                    {
                        <div class="book-format-slider book-desktop-only">
                            @foreach (var fmt in _fmts)
                            {
                                var isSliderActive = ActiveFormatKey == fmt.Key;
                                <button class="book-format-slider-btn @(isSliderActive ? "active" : "")"
                                        @onclick="@(() => _selectedFormatKey = fmt.Key)">
                                    <span class="book-format-slider-content">
                                        <MudIcon Icon="@fmt.Icon" Style="font-size: 1rem; flex-shrink:0;" />
                                        @fmt.Label
                                    </span>
                                </button>
                            }
                        </div>
                    }

                    @* Metadata: line 1 = rating + year; line 2 = reading time *@
                    @if (metaCount > 0)
                    {
                        <div class="book-detail-meta-rows">
                            @if (hasRating || hasYear)
                            {
                                <div class="book-detail-meta-row">
                                    @if (hasRating)
                                    {
                                        <span class="book-detail-meta-segment">
                                            <span class="book-detail-meta-stars">@ratingStars</span>
                                            <span class="book-detail-meta-rating-val">@_work.Rating</span>
                                        </span>
                                    }
                                    @if (hasRating && hasYear)
                                    {
                                        <span class="book-detail-meta-divider">|</span>
                                    }
                                    @if (hasYear)
                                    {
                                        <span class="book-detail-meta-segment">@_work.Year</span>
                                    }
                                </div>
                            }
                            @if (hasTime)
                            {
                                <div class="book-detail-meta-row">
                                    <span class="book-detail-meta-segment">@_work.ReadingTimeDisplay</span>
                                </div>
                            }
                        </div>
                    }

                    @* Genre chips — center column *@
                    @if (GenreTags.Count > 0)
                    {
                        <div class="book-detail-genre-badges">
                            @foreach (var tag in GenreTags.Take(4))
                            {
                                <span class="book-detail-center-genre-chip">@tag</span>
                            }
                        </div>
                    }

                    @* Primary CTA — desktop only *@
                    <button class="hub-primary-cta book-desktop-only" @onclick="@OnPrimaryAction">
                        <div class="hub-primary-cta-inner">
                            <MudIcon Icon="@GetPrimaryActionIcon()"
                                     Style="font-size: 1.2rem; color: #1a1208; flex-shrink:0;" />
                            <span class="hub-primary-cta-label">@PrimaryActionLabel()</span>
                        </div>
                        @if (hasProgress)
                        {
                            <div class="hub-primary-cta-progress"
                                 style="width: @(progressPct.ToString("F0"))%">
                            </div>
                        }
                    </button>

                    @* Secondary action circles — desktop only *@
                    <div class="book-detail-actions book-desktop-only">

                        <button class="book-detail-action-btn" @onclick="@OnAddTo">
                            <div class="book-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.PlaylistAdd"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.4rem;" />
                            </div>
                            <span class="book-detail-action-label">Add To</span>
                        </button>

                        <button class="book-detail-action-btn" @onclick="@OnShare">
                            <div class="book-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.IosShare"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.3rem;" />
                            </div>
                            <span class="book-detail-action-label">Share</span>
                        </button>

                        <button class="book-detail-action-btn" @onclick="@(() => _editDrawerOpen = true)">
                            <div class="book-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.Edit"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.3rem;" />
                            </div>
                            <span class="book-detail-action-label">Edit</span>
                        </button>

                        <MudMenu Dense="true"
                                 AnchorOrigin="Origin.BottomLeft"
                                 TransformOrigin="Origin.TopLeft">
                            <ActivatorContent>
                                <button class="book-detail-action-btn">
                                    <div class="book-detail-action-circle">
                                        <MudIcon Icon="@Icons.Material.Filled.MoreHoriz"
                                                 Style="color: rgba(248,248,248,0.65); font-size: 1.4rem;" />
                                    </div>
                                    <span class="book-detail-action-label">More</span>
                                </button>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenuItem OnClick="@OnUpdateMetadata"
                                             Icon="@Icons.Material.Filled.Sync">
                                    Update Metadata
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(async () => await OnMarkFinished())"
                                             Icon="@Icons.Material.Filled.CheckCircle">
                                    Mark as Finished
                                </MudMenuItem>
                                <MudMenuItem OnClick="@OnReportIssue"
                                             Icon="@Icons.Material.Filled.Flag">
                                    Report Issue
                                </MudMenuItem>
                                <MudDivider />
                                <MudMenuItem Disabled="true"
                                             Icon="@Icons.Material.Filled.DeleteForever">
                                    Delete
                                </MudMenuItem>
                            </ChildContent>
                        </MudMenu>

                    </div>

                    @* Description *@
                    @if (!string.IsNullOrEmpty(_work.Description))
                    {
                        <div class="book-detail-description-wrap">
                            <p class="book-detail-description">
                                @(_showFullDescription ? _work.Description : Truncate(_work.Description, 400))
                            </p>
                            @if (_work.Description.Length > 400)
                            {
                                <button class="book-detail-expand-btn"
                                        @onclick="@(() => _showFullDescription = !_showFullDescription)">
                                    @(_showFullDescription ? "Show less" : "Show more")
                                </button>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_work.DescriptionSource))
                        {
                            <p class="book-detail-attribution">
                                @_work.DescriptionSource
                            </p>
                        }
                    }

                    @* Progress label *@
                    @if (_activeJourney is not null && _activeJourney.ProgressPct is > 0 and < 99.5)
                    {
                        <div class="book-detail-progress-wrap">
                            <div class="book-detail-progress-bar-track">
                                <div class="book-detail-progress-bar-fill"
                                     style="width: @(_activeJourney.ProgressPct.ToString("F0"))%">
                                </div>
                            </div>
                            <span class="book-detail-progress-label">@_activeJourney.ProgressDisplay</span>
                        </div>
                    }

                </div>

                @* — Right panel: cover art (desktop); full stack (mobile) — *@
                <div class="book-detail-cover-panel">

                    @* Title — mobile only *@
                    <h1 class="book-detail-title book-mobile-only">@_work.Title</h1>

                    @* Format slider — mobile only *@
                    @if (_fmts.Count > 1)
                    {
                        <div class="book-format-slider book-mobile-only">
                            @foreach (var fmt in _fmts)
                            {
                                var isSliderActive = ActiveFormatKey == fmt.Key;
                                <button class="book-format-slider-btn @(isSliderActive ? "active" : "")"
                                        @onclick="@(() => _selectedFormatKey = fmt.Key)">
                                    <span class="book-format-slider-content">
                                        <MudIcon Icon="@fmt.Icon" Style="font-size: 1rem; flex-shrink:0;" />
                                        @fmt.Label
                                    </span>
                                </button>
                            }
                        </div>
                    }

                    @* Cover art *@
                    <div class="book-detail-cover-wrap" @onclick="@(() => _lightboxOpen = !string.IsNullOrEmpty(activeCoverUrl))">
                        @if (!string.IsNullOrEmpty(activeCoverUrl))
                        {
                            <img src="@activeCoverUrl" alt="@_work.Title"
                                 class="book-detail-cover @(coverIsAudio ? "book-detail-cover-audio" : "")" />
                        }
                        else
                        {
                            <div class="book-detail-cover @(coverIsAudio ? "book-detail-cover-audio" : "") book-detail-cover-placeholder">
                                <MudIcon Icon="@GetBookIcon()" Style="font-size: 64px; color: rgba(255,255,255,0.18);" />
                            </div>
                        }
                    </div>

                    @* Primary CTA — mobile only *@
                    <button class="hub-primary-cta book-mobile-only" @onclick="@OnPrimaryAction">
                        <div class="hub-primary-cta-inner">
                            <MudIcon Icon="@GetPrimaryActionIcon()"
                                     Style="font-size: 1.2rem; color: #1a1208; flex-shrink:0;" />
                            <span class="hub-primary-cta-label">@PrimaryActionLabel()</span>
                        </div>
                        @if (hasProgress)
                        {
                            <div class="hub-primary-cta-progress"
                                 style="width: @(progressPct.ToString("F0"))%">
                            </div>
                        }
                    </button>

                    @* Secondary action circles — mobile only *@
                    <div class="book-detail-actions book-mobile-only">

                        <button class="book-detail-action-btn" @onclick="@OnAddTo">
                            <div class="book-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.PlaylistAdd"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.4rem;" />
                            </div>
                            <span class="book-detail-action-label">Add To</span>
                        </button>

                        <button class="book-detail-action-btn" @onclick="@OnShare">
                            <div class="book-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.IosShare"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.3rem;" />
                            </div>
                            <span class="book-detail-action-label">Share</span>
                        </button>

                        <button class="book-detail-action-btn" @onclick="@(() => _editDrawerOpen = true)">
                            <div class="book-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.Edit"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.3rem;" />
                            </div>
                            <span class="book-detail-action-label">Edit</span>
                        </button>

                        <MudMenu Dense="true"
                                 AnchorOrigin="Origin.BottomLeft"
                                 TransformOrigin="Origin.TopLeft">
                            <ActivatorContent>
                                <button class="book-detail-action-btn">
                                    <div class="book-detail-action-circle">
                                        <MudIcon Icon="@Icons.Material.Filled.MoreHoriz"
                                                 Style="color: rgba(248,248,248,0.65); font-size: 1.4rem;" />
                                    </div>
                                    <span class="book-detail-action-label">More</span>
                                </button>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenuItem OnClick="@OnUpdateMetadata"
                                             Icon="@Icons.Material.Filled.Sync">
                                    Update Metadata
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(async () => await OnMarkFinished())"
                                             Icon="@Icons.Material.Filled.CheckCircle">
                                    Mark as Finished
                                </MudMenuItem>
                                <MudMenuItem OnClick="@OnReportIssue"
                                             Icon="@Icons.Material.Filled.Flag">
                                    Report Issue
                                </MudMenuItem>
                                <MudDivider />
                                <MudMenuItem Disabled="true"
                                             Icon="@Icons.Material.Filled.DeleteForever">
                                    Delete
                                </MudMenuItem>
                            </ChildContent>
                        </MudMenu>

                    </div>

                </div>

            </div>
        </div>

        @* — "More by this author" swimlane — *@
        @if (_related is not null && _related.Hubs.Count > 0)
        {
            <div class="book-detail-related-section">
                <PosterSwimlane Title="@_related.SectionTitle"
                                Items="@_related.Hubs.SelectMany(h => h.Works.Select(w => PosterItemViewModel.FromWork(w, h.CoverUrl, h.DominantHexColor))).ToList()"
                                OnItemSelected="@(item => Nav.NavigateTo(item.NavigationUrl))" />
            </div>
        }

    </div>
}

@* — Cover art lightbox — *@
@{
    var _lbCoverUrl = _work is not null ? (ActiveWork?.CoverUrl ?? _work.CoverUrl) : null;
}
@if (_lightboxOpen && _work is not null)
{
    <div class="book-cover-lightbox" @onclick="@(() => _lightboxOpen = false)">
        @if (!string.IsNullOrEmpty(_lbCoverUrl))
        {
            <img src="@_lbCoverUrl" alt="@_work.Title"
                 class="book-cover-lightbox-img"
                 @onclick:stopPropagation="true" />
        }
        <button class="book-cover-lightbox-close" @onclick="@(() => _lightboxOpen = false)">
            <MudIcon Icon="@Icons.Material.Filled.Close" />
        </button>
    </div>
}

@* — Toast — *@
@if (_toastMessage is not null)
{
    <div class="book-detail-toast">@_toastMessage</div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool                    _loading            = true;
    private HubViewModel?           _hub;
    private WorkViewModel?          _work;
    private PersonViewModel?        _authorPerson;
    private PersonViewModel?        _narratorPerson;
    private JourneyItemViewModel?   _activeJourney;
    private RelatedHubsViewModel?   _related;
    private string?                 _toastMessage;
    private bool                    _showFullDescription;
    private bool                    _showAllGenres;
    private bool                    _editDrawerOpen;
    private bool                    _lightboxOpen;
    private System.Threading.Timer? _toastTimer;
    /// <summary>Currently selected format key ("epub", "audiobook").
    /// Null means default (primary media type).</summary>
    private string?                 _selectedFormatKey;

    // — Lifecycle —

    protected override async Task OnParametersSetAsync()
    {
        _loading             = true;
        _showFullDescription = false;
        _showAllGenres       = false;
        _editDrawerOpen      = false;
        _lightboxOpen        = false;
        _selectedFormatKey   = null;

        if (!State.IsLoaded)
            await Orchestrator.GetHubsAsync();

        // Find the hub containing this work, then the work itself
        _hub  = State.Hubs.FirstOrDefault(h => h.Works.Any(w => w.Id == Id));
        _work = _hub?.Works.FirstOrDefault(w => w.Id == Id);

        if (_hub is not null && _work is not null)
        {
            var personsTask = Orchestrator.GetPersonsByHubAsync(_hub.Id);
            var journeyTask = Orchestrator.GetJourneyAsync(limit: 50, hubId: _hub.Id);
            var relatedTask = Orchestrator.GetRelatedHubsAsync(_hub.Id);

            await Task.WhenAll(personsTask, journeyTask, relatedTask);

            var persons = personsTask.Result;
            var journey = journeyTask.Result;
            _related    = relatedTask.Result;

            _authorPerson = ResolveAuthorPerson(persons, _work.AuthorQid, _work.Author);
            _narratorPerson = persons.FirstOrDefault(p =>
                string.Equals(p.Role, "Narrator", StringComparison.OrdinalIgnoreCase));

            // Progress resolution: journey endpoint filtered to this hub
            _activeJourney = journey
                .OrderByDescending(j => j.LastAccessed)
                .FirstOrDefault(j => j.WorkId == _work.Id)
                ?? journey.OrderByDescending(j => j.LastAccessed).FirstOrDefault();

            // Fallback: resolve work -> asset -> progress
            if (_activeJourney is null)
            {
                var assetId = await Orchestrator.ResolveWorkToAssetAsync(_work.Id);
                if (assetId.HasValue)
                {
                    var progress = await Orchestrator.GetProgressAsync(assetId.Value);
                    if (progress is not null && progress.ProgressPct > 0)
                    {
                        _activeJourney = new JourneyItemViewModel
                        {
                            AssetId            = assetId.Value,
                            WorkId             = _work.Id,
                            HubId              = _hub.Id,
                            Title              = _work.Title,
                            Author             = _work.Author,
                            CoverUrl           = _work.CoverUrl,
                            MediaType          = _work.MediaType,
                            ProgressPct        = progress.ProgressPct,
                            LastAccessed       = progress.LastAccessed.HasValue
                                ? new DateTimeOffset(progress.LastAccessed.Value)
                                : DateTimeOffset.UtcNow,
                            HubDisplayName     = _hub.DisplayName,
                            ExtendedProperties = progress.ExtendedProperties,
                        };
                    }
                }
            }
        }

        _loading = false;
    }

    // — Action handlers —

    private async Task OnPrimaryAction()
    {
        if (_work is null) return;
        var work = ActiveWork ?? _work;

        var formatKey = GetFormatKey(work.MediaType);
        if (formatKey is "epub" or "audiobook")
        {
            var assetId = await Orchestrator.ResolveWorkToAssetAsync(work.Id);
            if (assetId.HasValue)
            {
                Nav.NavigateTo($"/read/{assetId.Value}?returnHubId={_hub?.Id}");
            }
            else
            {
                ShowToast("Could not find a readable file for this title");
            }
        }
        else
        {
            ShowToast("Playback for this format is coming soon");
        }
    }

    private void OnAddTo()       => ShowToast("Reading list coming soon");
    private void OnShare()       => ShowToast("Share link copied");
    private void OnReportIssue() => ShowToast("Issue reporting coming soon");

    private async Task OnMarkFinished()
    {
        if (_work is null) return;
        await Orchestrator.SaveProgressAsync(_work.Id, null, 100.0);
        ShowToast("Marked as finished \u2713");
    }

    private async Task OnUpdateMetadata()
    {
        if (_work is null) { ShowToast("No content found to update"); return; }
        ShowToast("Updating metadata\u2026");
        var result = await Orchestrator.TriggerHydrationAsync(_work.Id);
        ShowToast(result is not null
            ? "Metadata updated successfully"
            : "Metadata update failed \u2014 check Engine logs");
    }

    private async Task OnEditApplied()
    {
        _loading = true;
        StateHasChanged();
        State.Invalidate();
        await OnParametersSetAsync();
    }

    private void ShowToast(string message)
    {
        _toastMessage = message;
        _toastTimer?.Dispose();
        _toastTimer = new System.Threading.Timer(_ =>
        {
            _toastMessage = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, System.Threading.Timeout.Infinite);
        StateHasChanged();
    }

    // — Display helpers —

    private List<string> GenreTags =>
        _work?.Genres.Count > 0
            ? _work.Genres.ToList()
            : _work?.Genre?
                .Split(['|', ',', ';'], StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
                .Where(g => g != "|")
                .ToList() ?? [];

    // — Format selector helpers (ebook vs audiobook editions of the same work) —

    private record FormatOption(string Key, string Label, string Icon, WorkViewModel Work);

    /// <summary>
    /// Builds format options from sibling works in the same hub that share
    /// the same title (different editions of the same work in different formats).
    /// </summary>
    private List<FormatOption> AvailableFormats()
    {
        if (_hub is null || _work is null) return [];
        return _hub.Works
            .GroupBy(w => GetFormatKey(w.MediaType))
            .Select(g => new FormatOption(
                g.Key,
                GetFormatLabel(g.Key),
                GetFormatMudIcon(g.Key),
                g.First()))
            .ToList();
    }

    private string ActiveFormatKey =>
        _selectedFormatKey
        ?? (_work is not null ? GetFormatKey(_work.MediaType) : "epub");

    private WorkViewModel? ActiveWork =>
        _hub?.Works.FirstOrDefault(w => GetFormatKey(w.MediaType) == ActiveFormatKey)
        ?? _work;

    private static string GetFormatKey(string mediaType)
    {
        var mt = mediaType.ToLowerInvariant();
        if (mt.Contains("epub") || mt is "book" or "books")                    return "epub";
        if (mt.Contains("audio") || mt.Contains("m4b"))                        return "audiobook";
        if (mt.Contains("video") || mt.Contains("movie") || mt is "mp4" or "movies" or "tv") return "video";
        if (mt.Contains("comic") || mt.Contains("cbz"))                        return "comic";
        return mt;
    }

    private static string GetFormatLabel(string key) => key switch
    {
        "epub"      => "eBook",
        "audiobook" => "Audiobook",
        "video"     => "Movie",
        "comic"     => "Comic",
        _           => key
    };

    private static string GetFormatMudIcon(string key) => key switch
    {
        "epub"      => Icons.Material.Filled.MenuBook,
        "audiobook" => Icons.Material.Filled.Headphones,
        "video"     => Icons.Material.Filled.PlayCircle,
        "comic"     => Icons.Material.Filled.AutoStories,
        _           => Icons.Material.Filled.Folder
    };

    private (string Label, string Route) GetLane()
    {
        var mt = _work?.MediaType?.ToLowerInvariant() ?? "";
        if (mt.Contains("m4b") || mt.Contains("audiobook") || mt.Contains("audio"))
                                                                                   return ("Audiobooks", "/books");
        if (mt.Contains("epub") || mt.Contains("book"))                            return ("Books",      "/books");
        if (mt.Contains("video") || mt.Contains("movie") || mt.Contains("mkv") ||
            mt.Contains("mp4")   || mt.Contains("tv"))                             return ("Video",      "/video");
        if (mt.Contains("comic") || mt.Contains("cbz"))                            return ("Comics",     "/comics");
        if (mt.Contains("music"))                                                   return ("Music",      "/music");
        if (mt.Contains("podcast"))                                                 return ("Podcasts",   "/podcasts");
        return ("Books", "/books");
    }

    private string PrimaryActionLabel()
    {
        var pct = _activeJourney?.ProgressPct;
        var baseLabel = (ActiveFormatKey, pct) switch
        {
            ("video",     >= 99.5) => "Watch Again",
            ("video",     > 0)     => "Continue Watching",
            ("video",     _)       => "Watch",
            ("audiobook", >= 99.5) => "Listen Again",
            ("audiobook", > 0)     => "Continue Listening",
            ("audiobook", _)       => "Listen",
            (_,           >= 99.5) => "Read Again",
            (_,           > 0)     => "Continue Reading",
            _                      => "Read"
        };

        if (pct is > 0 and < 99.5)
            return $"{baseLabel} \u00b7 {Math.Max(1, pct.Value):F0}%";

        return baseLabel;
    }

    private string GetPrimaryActionIcon() => ActiveFormatKey switch
    {
        "video"     => Icons.Material.Filled.PlayArrow,
        "audiobook" => Icons.Material.Filled.Headphones,
        _           => Icons.Material.Filled.MenuBook
    };

    private string GetRatingStars()
    {
        if (string.IsNullOrEmpty(_work?.Rating)) return "";
        if (!double.TryParse(_work.Rating,
                System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture,
                out var r))
            return "";
        r = Math.Max(0, Math.Min(5, r));
        var full  = (int)Math.Floor(r);
        var empty = 5 - full;
        return new string('\u2605', full) + new string('\u2606', empty);
    }

    private string GetBookIcon()
    {
        var mt = _work?.MediaType?.ToLowerInvariant() ?? "";
        if (mt.Contains("video") || mt.Contains("movie")) return Icons.Material.Filled.PlayCircle;
        if (mt.Contains("epub")  || mt.Contains("book"))  return Icons.Material.Filled.MenuBook;
        if (mt.Contains("audio"))                          return Icons.Material.Filled.Headphones;
        if (mt.Contains("comic") || mt.Contains("cbz"))   return Icons.Material.Filled.AutoStories;
        return Icons.Material.Filled.Folder;
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength].TrimEnd() + "\u2026";

    /// <summary>
    /// Resolves the best-matching Author person using QID-based matching.
    /// Same algorithm as HubDetail.
    /// </summary>
    private static PersonViewModel? ResolveAuthorPerson(
        IReadOnlyList<PersonViewModel> persons, string? authorQidCanonical,
        string? canonicalAuthor)
    {
        if (persons.Count == 0) return null;

        if (!string.IsNullOrEmpty(authorQidCanonical))
        {
            var entries = authorQidCanonical
                .Split("|||", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(entry =>
                {
                    var sep = entry.IndexOf("::", StringComparison.Ordinal);
                    return sep > 0
                        ? (Qid: entry[..sep], Label: entry[(sep + 2)..])
                        : (Qid: entry, Label: string.Empty);
                })
                .ToList();

            if (!string.IsNullOrEmpty(canonicalAuthor))
            {
                var normAuthor = CollapseFormatting(canonicalAuthor);
                foreach (var (qid, label) in entries)
                {
                    if (!string.Equals(CollapseFormatting(label), normAuthor, StringComparison.OrdinalIgnoreCase))
                        continue;
                    var match = persons.FirstOrDefault(p =>
                        string.Equals(p.Role, "Author", StringComparison.OrdinalIgnoreCase) &&
                        string.Equals(p.WikidataQid, qid, StringComparison.OrdinalIgnoreCase));
                    if (match is not null) return match;
                }
            }

            foreach (var (qid, _) in entries)
            {
                var match = persons.FirstOrDefault(p =>
                    string.Equals(p.Role, "Author", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(p.WikidataQid, qid, StringComparison.OrdinalIgnoreCase));
                if (match is not null) return match;
            }
        }

        return persons.FirstOrDefault(p =>
            string.Equals(p.Role, "Author", StringComparison.OrdinalIgnoreCase));
    }

    private static string CollapseFormatting(string value)
        => System.Text.RegularExpressions.Regex.Replace(value, @"\s*([.\-])\s*", "$1");

    public void Dispose() => _toastTimer?.Dispose();
}

