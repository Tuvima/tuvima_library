@* Route "/" has moved to LibraryBrowsePage.razor — this file is retained for reference. *@
@page "/home-legacy"
@inject UIOrchestratorService  Orchestrator
@inject UniverseStateContainer  State
@inject DeviceContextService    DeviceContext
@inject NavigationManager       Nav
@inject IWebHostEnvironment     Env
@inject IPhraseTemplateService  Phrases
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

<PageTitle>Tuvima Library</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_collections.Count == 0 && _libraryWorks.Count == 0)
{
    @* ── Empty state — library has no content yet ── *@
    <div class="home-empty-state">
        <img src="/images/tuvima-icon.svg" alt="Tuvima" class="home-empty-icon" />
        <h2 class="home-empty-title">@L["Home_EmptyTitle"]</h2>
        <p class="home-empty-subtitle">
            @L["Home_EmptySubtitle"]
        </p>

        @if (Env.IsDevelopment())
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.AutoStories"
                       Size="MudBlazor.Size.Large"
                       OnClick="HandleSeedLibrary"
                       Disabled="@_seeding"
                       Style="font-family: 'Montserrat', sans-serif; font-weight: 600; text-transform: none; border-radius: 8px;">
                @if (_seeding)
                {
                    <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="mr-2" />
                    <text>@L["Home_Seeding"]</text>
                }
                else
                {
                    <text>@L["Home_SeedLibrary"]</text>
                }
            </MudButton>
        }

        @if (_seedMessage is not null)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3" Style="max-width: 480px;">
                @_seedMessage
            </MudAlert>
        }
    </div>
}
else
{
    @* ── Page ambient background — tracks current carousel slide ── *@
    @if (_ambientColor is not null)
    {
        <div class="page-ambient-bg"
             style="--ambient-color: @_ambientColor"
             aria-hidden="true"></div>
    }

    @* ── TODO: Parent Collection (Franchise) swimlane ──────────────────────────────
         When GetParentCollectionsAsync() returns results, add a "Franchises" swimlane
         here using PosterSwimlane with the Parent Collections. The data model fully
         supports this via CollectionViewModel.IsParentCollection / ChildCollectionCount.
         Full Home page swimlane redesign for Parent Collection grouping is deferred.
    ── *@

    @* ── Hero Carousel ── *@
    @if (_carouselCount > 0 && _showHero)
    {
        <div class="hero-carousel"
             @onmouseenter="PauseCarousel"
             @onmouseleave="ResumeCarousel">

            @* ── Active slide — @key forces DOM recreation → CSS fade triggers ── *@
            <div class="hero-carousel-slide" @key="_carouselIndex">
                <CollectionHero Data="@CurrentSlideData"
                         Visible="true"
                         OnClicked="HandleSlideClick"
                         OnCtaClicked="HandleSlideCta" />
            </div>

            @* ── Navigation controls (only when multiple slides) ── *@
            @if (_carouselCount > 1)
            {
                <button class="carousel-arrow carousel-arrow-left"
                        @onclick="PrevSlide"
                        @onclick:stopPropagation="true"
                        aria-label="@L["Home_CarouselPrevious"]">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" />
                </button>

                <button class="carousel-arrow carousel-arrow-right"
                        @onclick="NextSlide"
                        @onclick:stopPropagation="true"
                        aria-label="@L["Home_CarouselNext"]">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
                </button>

                <div class="carousel-dots">
                    @for (int i = 0; i < _carouselCount; i++)
                    {
                        var idx = i;
                        <button class="carousel-dot @(idx == _carouselIndex ? "active" : "")"
                                @onclick="() => GoToSlide(idx)"
                                @onclick:stopPropagation="true"
                                aria-label="Slide @(idx + 1)" />
                    }
                </div>
            }
        </div>
    }

    @* ── Search Bar ── *@
    <div class="home-search-bar">
        <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 16px; color: rgba(255,255,255,0.30);" />
        <input class="home-search-input"
               type="text"
               placeholder="@L["Home_SearchPlaceholder"]"
               @oninput="OnSearchInput"
               @onkeydown="HandleSearchKeyDown" />
    </div>

    @* ── Mobile filter bar (library dropdown only — no filter chips on Home) ── *@
    <MobileFilterBar CurrentLane="null" />

    @if (!string.IsNullOrWhiteSpace(_debouncedSearchTerm))
    {
        @* ── Search results ── *@
        @if (_homeSearchLoading)
        {
            <div style="padding: 32px 0;">
                <MudProgressCircular Indeterminate="true" Size="MudBlazor.Size.Small"
                                     Style="width: 20px; height: 20px; color: rgba(255,255,255,0.25);" />
            </div>
        }
        else if (_homeSearchResults.Count == 0)
        {
            <div style="padding: 32px 0; display: flex; flex-direction: column; gap: 8px;">
                <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Style="font-size: 32px; color: rgba(255,255,255,0.12);" />
                <span style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: rgba(255,255,255,0.20);">No results for "@_debouncedSearchTerm"</span>
            </div>
        }
        else
        {
            <div class="home-search-results">
                <div class="home-search-results-header">
                    @_homeSearchResults.Count result@(_homeSearchResults.Count == 1 ? "" : "s")
                </div>
                @foreach (var result in _homeSearchResults)
                {
                    var navUrl = "/book/" + result.WorkId;
                    <div class="home-search-card" @onclick="() => Nav.NavigateTo(navUrl)">
                        <div class="home-search-card-info">
                            <span class="home-search-card-title">@result.Title</span>
                            <span class="home-search-card-meta">
                                @if (!string.IsNullOrWhiteSpace(result.Author))
                                {
                                    @result.Author<text> · </text>
                                }
                                @result.MediaType
                            </span>
                        </div>
                        <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                    </div>
                }
            </div>
        }
    }
    else
    {
        @* ── Continue Your Journey — in-progress individual items ── *@
        @if (_journeyItems.Count > 0)
        {
            <PosterSwimlane Title="@L["Home_ContinueYourJourney"]"
                            Items="@_journeyItems.Take(10).Select(PosterItemViewModel.FromJourney).ToList()"
                            OnItemSelected="HandleItemSelected"
                            CardWidth="@_cardWidth" />
        }

        @* ── Recently Added — individual works, newest collection first ── *@
        @if (_recentWorks.Count > 0)
        {
            <PosterSwimlane Title="@L["Home_RecentlyAdded"]"
                            TotalCount="@_recentWorks.Count"
                            Items="@_recentWorks.Take(12).ToList()"
                            OnItemSelected="HandleItemSelected"
                            CardWidth="@_cardWidth" />
        }

        @* ── Suggestions — by same authors/genres as recent activity, or broad library explore ── *@
        @if (_suggestedWorks.Count > 0)
        {
            <PosterSwimlane Title="@_suggestionsTitle"
                            Items="@_suggestedWorks"
                            OnItemSelected="HandleItemSelected"
                            CardWidth="@_cardWidth" />
        }
    }
}

@code {
    private bool               _loading = true;
    private bool               _seeding;
    private string?            _error;
    private string?            _seedMessage;
    private List<CollectionViewModel> _collections         = [];
    private List<WorkViewModel> _libraryWorks = [];
    private List<(WorkViewModel Work, CollectionViewModel Collection)> _carouselWorks = [];

    // ── Home swimlane data (individual works, not collections) ───────────────────────
    private List<PosterItemViewModel> _recentWorks    = [];
    private List<PosterItemViewModel> _suggestedWorks = [];

    // ── Journey items ────────────────────────────────────────────────────────
    private List<JourneyItemViewModel> _journeyItems = [];

    // ── Carousel state ───────────────────────────────────────────────────────
    private int                    _carouselIndex  = 0;
    private bool                   _carouselPaused = false;
    private CancellationTokenSource _carouselCts   = new();

    private bool _useJourneyCarousel => _journeyItems.Count > 0;
    private int  _carouselCount      => _useJourneyCarousel ? _journeyItems.Count : _carouselWorks.Count;

    private int _cardWidth => DeviceContext.Settings.Pages.Home.SwimlaneCardWidth;

    private string _suggestionsTitle =>
        _journeyItems.Count > 0 ? L["Home_YouMightLike"] : L["Home_ExploreYourLibrary"];

    // ── Search state ────────────────────────────────────────────────────────
    private string _searchTerm = "";
    private string _debouncedSearchTerm = "";
    private Timer? _debounceTimer;
    private bool _homeSearchLoading;
    private List<SearchResultViewModel> _homeSearchResults = [];

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? "";
        _debounceTimer?.Dispose();
        _debounceTimer = new Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                _debouncedSearchTerm = _searchTerm;
                if (!string.IsNullOrWhiteSpace(_debouncedSearchTerm))
                    await RunHomeSearchAsync(_debouncedSearchTerm);
                StateHasChanged();
            });
        }, null, 300, Timeout.Infinite);
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _debounceTimer?.Dispose();
            _debouncedSearchTerm = _searchTerm;
            if (!string.IsNullOrWhiteSpace(_debouncedSearchTerm))
                _ = InvokeAsync(async () =>
                {
                    await RunHomeSearchAsync(_debouncedSearchTerm);
                    StateHasChanged();
                });
            else
                StateHasChanged();
        }
    }

    private async Task RunHomeSearchAsync(string term)
    {
        _homeSearchLoading = true;
        StateHasChanged();
        try
        {
            _homeSearchResults = await Orchestrator.SearchWorksAsync(term);
        }
        catch
        {
            _homeSearchResults = [];
        }
        _homeSearchLoading = false;
    }

    // ── Device-context helpers ────────────────────────────────────────────────

    private string _pendingDisplay =>
        DeviceContext.Settings.Pages.Home.PendingFilesDisplay;

    private bool _showHero =>
        DeviceContext.Settings.Pages.Home.CollectionHeroEnabled
        && DeviceContext.Settings.Pages.Home.CollectionHeroLayout != "hidden";

    // ── Current slide data — bridges carousel index to unified HeroData ──────

    private HeroData? CurrentSlideData
    {
        get
        {
            if (_useJourneyCarousel && _carouselIndex < _journeyItems.Count)
            {
                var item = _journeyItems[_carouselIndex];
                var data = HeroData.FromJourney(item);
                var phrase = ResolveHeroPhrase(data);
                return data with { Subtitle = phrase };
            }
            if (_carouselWorks.Count > 0 && _carouselIndex < _carouselWorks.Count)
            {
                var (work, collection) = _carouselWorks[_carouselIndex];
                var data = HeroData.FromWork(work, collection);
                var phrase = ResolveHeroPhrase(data);
                return data with { Subtitle = phrase };
            }
            return null;
        }
    }

    private string? ResolveHeroPhrase(HeroData data)
    {
        var hasProgress = data.ProgressPct is > 0;
        var isCompleted = data.ProgressPct is >= 99.5;

        var slot = isCompleted
            ? PhraseSlot.HeroCompleted
            : hasProgress
                ? (!string.IsNullOrEmpty(data.Series) ? PhraseSlot.HeroJourneySeries : PhraseSlot.HeroJourneyStandalone)
                : !string.IsNullOrEmpty(data.Series)
                    ? PhraseSlot.HeroDiscoverSeries
                    : !string.IsNullOrEmpty(data.Author)
                        ? PhraseSlot.HeroDiscoverAuthor
                        : PhraseSlot.HeroDiscoverStandalone;

        var ctx = new PhraseContext
        {
            EntityId = data.EntityId,
            Title = data.Title,
            Author = data.Author,
            Series = data.Series,
            Genre = data.Genre,
            MediaType = data.MediaTypeLabel,
            ProgressPct = data.ProgressPct,
        };

        var phrase = Phrases.Resolve(slot, ctx);
        return string.IsNullOrEmpty(phrase.Text) ? null : phrase.Text;
    }

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadCollectionsAsync(showSpinner: true);
        _ = StartCarouselAsync(_carouselCts.Token);
    }

    // ── Collection loading ───────────────────────────────────────────────────────────

    private async Task LoadCollectionsAsync(bool showSpinner = true)
    {
        if (showSpinner)
            _loading = true;

        _error = null;

        try
        {
            _collections = await Orchestrator.GetCollectionsAsync();
            _libraryWorks = await Orchestrator.GetLibraryWorksAsync();

            // Load up to 5 in-progress items for the carousel primary pool.
            _journeyItems = await Orchestrator.GetJourneyAsync(limit: 5);

            ApplyFilter();
        }
        catch (Exception ex)
        {
            _error = $"Could not reach the Engine: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilter()
    {
        var all = _collections;

        // Carousel fallback pool — recently added works shown when no journey items.
        // Carousel still uses collection data for hero banner (cover art, dominant colour).
        _carouselWorks = all
            .OrderByDescending(h => h.CreatedAt)
            .SelectMany(h => h.Works.Select(w => (Work: w, Collection: h)))
            .Take(5)
            .ToList();

        // Recently Added — built directly from library works (API returns newest first).
        _recentWorks = _libraryWorks
            .Select(w => PosterItemViewModel.FromWork(w, null, null))
            .Take(20)
            .ToList();

        // Suggestions — works not currently in progress, prioritising same authors.
        var journeyWorkIds = _journeyItems.Select(j => j.WorkId).ToHashSet();
        var recentAuthors  = _journeyItems
            .Select(j => j.Author)
            .Where(a => !string.IsNullOrEmpty(a))
            .Select(a => a!)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var candidates = _libraryWorks
            .Where(w => !journeyWorkIds.Contains(w.Id))
            .ToList();

        // Prefer works by recently-read authors; fall back to all candidates.
        var authorMatches = candidates
            .Where(w => !string.IsNullOrEmpty(w.Author) && recentAuthors.Contains(w.Author!))
            .ToList();

        _suggestedWorks = (authorMatches.Count >= 4 ? authorMatches : candidates)
            .Select(w => PosterItemViewModel.FromWork(w, null, null))
            .Take(12)
            .ToList();

        // Keep index in bounds if data changed.
        if (_carouselIndex >= _carouselCount)
            _carouselIndex = 0;
    }

    // ── Ambient background color — tracks current carousel slide ─────────────

    private string? _ambientColor
    {
        get
        {
            if (!_useJourneyCarousel && _carouselWorks.Count > 0)
                return _carouselWorks[Math.Min(_carouselIndex, _carouselWorks.Count - 1)].Collection.DominantHexColor;

            // Journey mode: look up the collection by ID.
            if (_journeyItems.Count > 0 && _carouselIndex < _journeyItems.Count)
            {
                var collectionId = _journeyItems[_carouselIndex].CollectionId;
                return _collections.FirstOrDefault(h => h.Id == collectionId)?.DominantHexColor;
            }

            return _collections.FirstOrDefault()?.DominantHexColor;
        }
    }

    // ── Carousel timer ────────────────────────────────────────────────────────

    private async Task StartCarouselAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(6));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                if (!_carouselPaused && _carouselCount > 1)
                {
                    _carouselIndex = (_carouselIndex + 1) % _carouselCount;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task GoToSlide(int idx)
    {
        _carouselIndex = ((idx % Math.Max(1, _carouselCount)) + _carouselCount) % _carouselCount;

        // Reset the timer so it doesn't immediately advance after a manual click.
        await _carouselCts.CancelAsync();
        _carouselCts = new CancellationTokenSource();
        _ = StartCarouselAsync(_carouselCts.Token);

        await InvokeAsync(StateHasChanged);
    }

    private Task NextSlide() =>
        GoToSlide((_carouselIndex + 1) % Math.Max(1, _carouselCount));

    private Task PrevSlide() =>
        GoToSlide((_carouselIndex - 1 + Math.Max(1, _carouselCount)) % Math.Max(1, _carouselCount));

    private void PauseCarousel()  => _carouselPaused = true;
    private void ResumeCarousel() => _carouselPaused = false;

    // ── Carousel click handlers ──────────────────────────────────────────────

    private void HandleSlideClick()
    {
        if (_useJourneyCarousel && _carouselIndex < _journeyItems.Count)
        {
            HandleJourneyCollectionNavigate(_journeyItems[_carouselIndex]);
        }
        else if (_carouselWorks.Count > 0 && _carouselIndex < _carouselWorks.Count)
        {
            var (work, _) = _carouselWorks[_carouselIndex];
            Nav.NavigateTo($"/book/{work.Id}");
        }
    }

    private void HandleSlideCta()
    {
        if (_useJourneyCarousel && _carouselIndex < _journeyItems.Count)
        {
            HandleJourneyPlay(_journeyItems[_carouselIndex]);
        }
    }

    // ── Collection / Item selection ──────────────────────────────────────────────────

    private void HandleCollectionSelected(CollectionViewModel collection)
    {
        Nav.NavigateTo($"/book/{collection.Works.FirstOrDefault()?.Id ?? collection.Id}");
    }

    private void HandleItemSelected(PosterItemViewModel item)
    {
        Nav.NavigateTo(item.NavigationUrl);
    }

    /// <summary>Cover or title clicked — open Collection Detail with progress context.</summary>
    private void HandleJourneyCollectionNavigate(JourneyItemViewModel item)
    {
        if (item.CollectionId.HasValue)
            Nav.NavigateTo($"/book/{item.CollectionId.Value}?lastAssetId={item.AssetId}");
    }

    /// <summary>CTA button clicked — go directly to the reader/player for this asset.</summary>
    private void HandleJourneyPlay(JourneyItemViewModel item)
    {
        var t = item.MediaType.ToLowerInvariant();

        if (t.Contains("epub") || t.Contains("book"))
        {
            // Navigate directly into the EPUB reader
            var url = $"/read/{item.AssetId}";
            if (item.CollectionId.HasValue) url += $"?returnCollectionId={item.CollectionId.Value}";
            Nav.NavigateTo(url);
        }
        else if (item.CollectionId.HasValue)
        {
            // Audio, video, comics — no dedicated player yet; open collection detail with asset context
            Nav.NavigateTo($"/book/{item.CollectionId.Value}?lastAssetId={item.AssetId}");
        }
    }

    // ── Seed library (dev only) ───────────────────────────────────────────────

    private async Task HandleSeedLibrary()
    {
        _seeding = true;
        _seedMessage = null;
        StateHasChanged();

        bool success = await Orchestrator.SeedLibraryAsync();
        _seeding = false;
        _seedMessage = success
            ? L["Home_SeedSuccess"]
            : L["Home_SeedFailure"];
        StateHasChanged();
    }

    // ── SignalR live refresh ──────────────────────────────────────────────────

    private void OnStateChanged()
    {
        InvokeAsync(() =>
        {
            if (State.IsLoaded && (_collections.Count > 0 || _libraryWorks.Count > 0))
            {
                ApplyFilter();
                StateHasChanged();
            }
            else
            {
                _ = LoadCollectionsAsync(showSpinner: false).ContinueWith(_ => InvokeAsync(StateHasChanged));
            }
        });
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
        State.OnStateChanged -= OnStateChanged;
        _carouselCts.Cancel();
        _carouselCts.Dispose();
    }
}

<style>
    /* ── Hero carousel container ─────────────────────────────────────── */
    .hero-carousel {
        position: relative;
        margin-bottom: 2rem;
    }

    /* ── Slide fade-in — triggered by @@key recreation ──────────────── */
    .hero-carousel-slide {
        animation: heroSlideFadeIn 0.55s ease;
    }

    @@keyframes heroSlideFadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0);   }
    }

    /* ── Arrow buttons ───────────────────────────────────────────────── */
    .carousel-arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 20;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: none;
        background: rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        color: rgba(255, 255, 255, 0.85);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease, opacity 0.2s ease;
        opacity: 0;
    }

    .hero-carousel:hover .carousel-arrow {
        opacity: 1;
    }

    .carousel-arrow:hover {
        background: rgba(201, 146, 46, 0.70);
        color: #fff;
    }

    .carousel-arrow-left  { left:  16px; }
    .carousel-arrow-right { right: 16px; }

    /* ── Dot indicators ──────────────────────────────────────────────── */
    .carousel-dots {
        position: absolute;
        bottom: 16px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 20;
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .carousel-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: none;
        background: rgba(255, 255, 255, 0.35);
        cursor: pointer;
        padding: 0;
        transition: background 0.25s ease, transform 0.25s ease;
    }

    .carousel-dot.active {
        background: #C9922E;
        transform: scale(1.35);
    }

    .carousel-dot:hover:not(.active) {
        background: rgba(255, 255, 255, 0.65);
    }

    /* ── Home search bar ── */
    .home-search-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 16px 0;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.03);
        transition: border-color 0.15s ease, background 0.15s ease;
    }

    .home-search-bar:focus-within {
        border-color: rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.05);
    }

    .home-search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: rgba(255, 255, 255, 0.85);
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        font-weight: 400;
    }

    .home-search-input::placeholder {
        color: rgba(255, 255, 255, 0.25);
    }

    /* ── Home search results ── */
    .home-search-results {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 0 0 32px 0;
    }

    .home-search-results-header {
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.35);
        padding: 0 0 12px 0;
    }

    .home-search-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s ease;
    }

    .home-search-card:hover {
        background: rgba(255, 255, 255, 0.04);
    }

    .home-search-card-info {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .home-search-card-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.80);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .home-search-card-meta {
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.35);
    }

    /* ── Empty state ─────────────────────────────────────────────────── */
    .home-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
