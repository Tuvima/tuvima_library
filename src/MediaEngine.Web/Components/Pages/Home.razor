@page "/"
@inject UIOrchestratorService  Orchestrator
@inject ThemeService            ThemeService
@inject UniverseStateContainer  State
@inject DeviceContextService    DeviceContext
@implements IDisposable

<PageTitle>Tuvima Library</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    @* ── Pending files alert (Watch Folder) — respects device settings ── *@
    @if (!DeviceContext.IsFeatureDisabled("pending_files_alert") && _pendingDisplay != "hidden")
    {
        <PendingFilesAlert Class="mb-4" DisplayMode="@_pendingDisplay" />
    }

    @* ── Hero banners ── *@
    @if (_showHero)
    {
        <HubHero Hub="@_heroHub"
                 SecondaryHub="@_secondaryHub"
                 Layout="@DeviceContext.Settings.Pages.Home.HubHeroLayout" />
    }

    @* ── Continue your Journey (horizontal scroll row) ── *@
    @if (_nonHeroHubs is { Count: > 0 })
    {
        <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight: 600;">
            Continue your Journey
        </MudText>

        <div class="content-row mb-6">
            @foreach (var hub in _nonHeroHubs.Take(8))
            {
                <div class="content-card" @onclick="() => HandleHubSelected(hub)">
                    <div class="content-card-artwork"
                         style="background: #1A1A1A;">
                        <MudIcon Icon="@GetHubIcon(hub)"
                                 Style="font-size: 40px; color: rgba(255,255,255,0.35);" />
                    </div>
                    <div class="content-card-info">
                        <span class="content-card-title">@hub.DisplayName</span>
                        <span class="content-card-meta">
                            @hub.WorkCount @(hub.WorkCount == 1 ? "work" : "works") · @hub.MediaTypes
                        </span>
                    </div>
                </div>
            }
        </div>
    }

    @* ── Recently Added ── *@
    @if (_recentHubs is { Count: > 0 })
    {
        <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight: 600;">
            Recently Added
        </MudText>

        <div class="content-row mb-6">
            @foreach (var hub in _recentHubs.Take(8))
            {
                <div class="content-card" @onclick="() => HandleHubSelected(hub)">
                    <div class="content-card-artwork"
                         style="background: #1A1A1A;">
                        <MudIcon Icon="@GetHubIcon(hub)"
                                 Style="font-size: 40px; color: rgba(255,255,255,0.35);" />
                    </div>
                    <div class="content-card-info">
                        <span class="content-card-title">@hub.DisplayName</span>
                        <span class="content-card-meta">
                            @hub.WorkCount @(hub.WorkCount == 1 ? "work" : "works") · @hub.MediaTypes
                        </span>
                    </div>
                </div>
            }
        </div>
    }

    @* ── Your Universes grid (all hubs) ── *@
    <UniverseStack Hubs="@State.FilteredHubs.ToList()"
                   Class="mt-2"
                   OnHubSelected="HandleHubSelected"
                   Columns="@DeviceContext.Settings.Pages.Home.BentoColumns"
                   TileStyle="@DeviceContext.Settings.Pages.Home.BentoTileStyle" />
}

@code {
    private bool               _loading = true;
    private string?            _error;
    private HubViewModel?      _heroHub;
    private HubViewModel?      _secondaryHub;
    private List<HubViewModel> _hubs = [];
    private List<HubViewModel> _nonHeroHubs = [];
    private List<HubViewModel> _recentHubs = [];

    // ── Device-context computed helpers ──────────────────────────────────────

    private string _pendingDisplay =>
        DeviceContext.Settings.Pages.Home.PendingFilesDisplay;

    private bool _showHero =>
        DeviceContext.Settings.Pages.Home.HubHeroEnabled
        && DeviceContext.Settings.Pages.Home.HubHeroLayout != "hidden";

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadHubsAsync(showSpinner: true);
    }

    // ── Hub loading ───────────────────────────────────────────────────────────

    private async Task LoadHubsAsync(bool showSpinner = true)
    {
        if (showSpinner)
            _loading = true;

        _error = null;

        try
        {
            _hubs = await Orchestrator.GetHubsAsync();
            ApplyFilter();
        }
        catch (Exception ex)
        {
            _error = $"Could not reach the Engine: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilter()
    {
        var filtered = State.FilteredHubs;
        _heroHub = filtered.FirstOrDefault();
        _secondaryHub = filtered.Count > 1 ? filtered[1] : null;

        // Non-hero hubs: skip the first two (used in hero banners).
        _nonHeroHubs = filtered.Count > 2 ? filtered.Skip(2).ToList() : [];

        // Recently added: reverse order of all hubs for the "Recently Added" row.
        _recentHubs = filtered.AsEnumerable().Reverse().ToList();
    }

    // ── Hub selection ─────────────────────────────────────────────────────────

    private void HandleHubSelected(HubViewModel hub)
    {
        _heroHub = hub;
        _secondaryHub = State.FilteredHubs.FirstOrDefault(h => h.Id != hub.Id);
        _nonHeroHubs = State.FilteredHubs.Where(h => h.Id != hub.Id && h.Id != _secondaryHub?.Id).ToList();
    }

    // ── Icon helper ──────────────────────────────────────────────────────────

    private static string GetHubIcon(HubViewModel hub)
    {
        var types = hub.Works.Select(w => w.MediaType.ToLowerInvariant()).Distinct().ToList();

        if (types.Any(t => t.Contains("video") || t.Contains("movie")))
            return MudBlazor.Icons.Material.Filled.PlayCircle;
        if (types.Any(t => t.Contains("epub") || t.Contains("book")))
            return MudBlazor.Icons.Material.Filled.MenuBook;
        if (types.Any(t => t.Contains("audio")))
            return MudBlazor.Icons.Material.Filled.Headphones;
        if (types.Any(t => t.Contains("comic") || t.Contains("cbz") || t.Contains("cbr")))
            return MudBlazor.Icons.Material.Filled.AutoStories;

        return MudBlazor.Icons.Material.Filled.Folder;
    }

    // ── SignalR live refresh ──────────────────────────────────────────────────

    private void OnStateChanged()
    {
        InvokeAsync(() =>
        {
            if (State.IsLoaded && _hubs.Count > 0)
            {
                ApplyFilter();
                StateHasChanged();
            }
            else
            {
                _ = LoadHubsAsync(showSpinner: false).ContinueWith(_ => InvokeAsync(StateHasChanged));
            }
        });
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }
}

<style>
    /* ── Horizontal content row ──────────────────────────────────────── */
    .content-row {
        display: flex;
        gap: 16px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        padding-bottom: 8px;
        scrollbar-width: thin;
    }

    .content-row::-webkit-scrollbar {
        height: 4px;
    }

    .content-row::-webkit-scrollbar-thumb {
        background: var(--app-glass-border);
        border-radius: 4px;
    }

    /* ── Content card ────────────────────────────────────────────────── */
    .content-card {
        flex-shrink: 0;
        width: 200px;
        cursor: pointer;
        scroll-snap-align: start;
        transition: transform 0.2s ease;
    }

    .content-card:hover {
        transform: translateY(-3px);
    }

    .content-card-artwork {
        width: 100%;
        aspect-ratio: 2 / 3;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 8px;
        overflow: hidden;
    }

    .content-card-info {
        display: flex;
        flex-direction: column;
        padding: 0 4px;
    }

    .content-card-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .content-card-meta {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        font-weight: 400;
        color: var(--app-text-muted);
        margin-top: 2px;
    }

    /* ── Responsive ──────────────────────────────────────────────────── */
    @@media (max-width: 600px) {
        .content-card {
            width: 150px;
        }
    }
</style>
