@page "/"
@inject UIOrchestratorService  Orchestrator
@inject UniverseStateContainer  State
@inject DeviceContextService    DeviceContext
@inject NavigationManager       Nav
@inject IWebHostEnvironment     Env
@implements IDisposable

<PageTitle>Tuvima Library</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_hubs.Count == 0)
{
    @* ── Empty state — library has no content yet ── *@
    <div class="home-empty-state">
        <img src="/images/tuvima-icon.svg" alt="Tuvima" class="home-empty-icon" />
        <h2 class="home-empty-title">Your library is empty</h2>
        <p class="home-empty-subtitle">
            Drop files into your Watch Folder, or seed the library with sample books to get started.
        </p>

        @if (Env.IsDevelopment())
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.AutoStories"
                       Size="MudBlazor.Size.Large"
                       OnClick="HandleSeedLibrary"
                       Disabled="@_seeding"
                       Style="font-family: 'Montserrat', sans-serif; font-weight: 600; text-transform: none; border-radius: 8px;">
                @if (_seeding)
                {
                    <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="mr-2" />
                    <text>Seeding...</text>
                }
                else
                {
                    <text>Seed Library</text>
                }
            </MudButton>
        }

        @if (_seedMessage is not null)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3" Style="max-width: 480px;">
                @_seedMessage
            </MudAlert>
        }
    </div>
}
else
{
    @* ── Pending files alert (Watch Folder) — respects device settings ── *@
    @if (!DeviceContext.IsFeatureDisabled("pending_files_alert") && _pendingDisplay != "hidden")
    {
        <PendingFilesAlert Class="mb-4" DisplayMode="@_pendingDisplay" />
    }

    @* ── Page ambient background — tracks current carousel slide ── *@
    @if (_ambientColor is not null)
    {
        <div class="page-ambient-bg"
             style="--ambient-color: @_ambientColor"
             aria-hidden="true"></div>
    }

    @* ── Hero Carousel ── *@
    @if (_carouselCount > 0 && _showHero)
    {
        <div class="hero-carousel"
             @onmouseenter="PauseCarousel"
             @onmouseleave="ResumeCarousel">

            @* ── Active slide — @key forces DOM recreation → CSS fade triggers ── *@
            <div class="hero-carousel-slide" @key="_carouselIndex">
                @if (_useJourneyCarousel)
                {
                    var item = _journeyItems[_carouselIndex];
                    var journeyHub = _hubs.FirstOrDefault(h => h.Id == item.HubId);

                    @* Journey slide: same hero-stack layout as lane pages, plus CTA button *@
                    <div class="hero-stack">

                        @* Layer 1: Visual background — full-bleed, using the hub's backdrop *@
                        <div class="hero-stack-bg">
                            <div class="hero-bleed-wrapper">
                                @if (journeyHub is not null)
                                {
                                    <HubHero Hub="@journeyHub"
                                             BackgroundOnly="true"
                                             Visible="true" />
                                }
                            </div>
                        </div>

                        @* Layer 2: Text + CTA — stacked column, aligned to bottom of hero *@
                        <div class="hero-stack-text">
                            <div class="hero-journey-col" @onclick="@(() => HandleJourneyHubNavigate(item))">
                                <h2 class="hero-cinema-title">@item.Title</h2>

                                <div class="hero-cinema-badges">
                                    @if (!string.IsNullOrEmpty(item.FormatMediaType))
                                    {
                                        <span class="hero-badge">@item.FormatMediaType</span>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Series))
                                    {
                                        <span class="hero-badge">@item.Series@(!string.IsNullOrEmpty(item.SeriesPosition) ? $" #{item.SeriesPosition}" : "")</span>
                                    }
                                </div>

                                @if (!string.IsNullOrEmpty(item.Author))
                                {
                                    <p class="hero-cinema-subtitle">@item.Author</p>
                                }
                                @if (!string.IsNullOrEmpty(item.Narrator) && item.Narrator != item.Author)
                                {
                                    <p class="hero-cinema-series">Narrated by @item.Narrator</p>
                                }
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <p class="hero-cinema-description">@HeroTruncate(item.Description, 200)</p>
                                }

                                @* CTA button — stopPropagation so hub-nav click above doesn't also fire *@
                                <button class="hub-primary-cta mt-3"
                                        @onclick="@(() => HandleJourneyPlay(item))"
                                        @onclick:stopPropagation="true"
                                        style="align-self: flex-start;">
                                    <div class="hub-primary-cta-inner">
                                        <MudIcon Icon="@GetJourneyIcon(item)"
                                                 Style="font-size: 1.2rem; color: #1a1208; flex-shrink:0;" />
                                        <span class="hub-primary-cta-label">@item.ActionLabel</span>
                                    </div>
                                    @if (item.ProgressPct is > 0 and < 99.5)
                                    {
                                        <div class="hub-primary-cta-progress"
                                             style="width: @(item.ProgressPct.ToString("F0"))%"></div>
                                    }
                                </button>
                            </div>
                        </div>

                    </div>
                }
                else
                {
                    var hub = _carouselHubs[_carouselIndex];
                    <div class="hero-stack" @onclick="@(() => HandleHubSelected(hub))">

                        @* Layer 1: Visual background — full-bleed *@
                        <div class="hero-stack-bg">
                            <div class="hero-bleed-wrapper">
                                <HubHero Hub="@hub"
                                         BackgroundOnly="true"
                                         Visible="true" />
                            </div>
                        </div>

                        @* Layer 2: Text — normal container flow, identical to MediaLanePage hero *@
                        <div class="hero-stack-text">
                            <h2 class="hero-cinema-title">@hub.DisplayName</h2>

                            <div class="hero-cinema-badges">
                                @if (!string.IsNullOrEmpty(hub.Year))
                                {
                                    <span class="hero-badge">@hub.Year</span>
                                }
                                @if (!string.IsNullOrEmpty(hub.PrimaryMediaType))
                                {
                                    <span class="hero-badge">@HeroFormatMediaType(hub.PrimaryMediaType)</span>
                                }
                                @if (!string.IsNullOrEmpty(hub.Genre))
                                {
                                    @foreach (var genre in hub.Genre.Split(',', ';').Take(2).Select(g => g.Trim()).Where(g => g.Length > 0))
                                    {
                                        <span class="hero-badge">@genre</span>
                                    }
                                }
                                @if (!string.IsNullOrEmpty(hub.Rating))
                                {
                                    <span class="hero-badge">@hub.Rating</span>
                                }
                                @if (hub.WorkCount > 1)
                                {
                                    <span class="hero-badge">@hub.WorkCount works</span>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(hub.Series))
                            {
                                <p class="hero-cinema-series">@hub.Series</p>
                            }
                            @if (!string.IsNullOrEmpty(hub.Author))
                            {
                                <p class="hero-cinema-subtitle">@hub.Author</p>
                            }
                            @if (!string.IsNullOrEmpty(hub.Description))
                            {
                                <p class="hero-cinema-description">@HeroTruncate(hub.Description, 200)</p>
                            }
                        </div>

                    </div>
                }
            </div>

            @* ── Navigation controls (only when multiple slides) ── *@
            @if (_carouselCount > 1)
            {
                <button class="carousel-arrow carousel-arrow-left"
                        @onclick="PrevSlide"
                        @onclick:stopPropagation="true"
                        aria-label="Previous">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" />
                </button>

                <button class="carousel-arrow carousel-arrow-right"
                        @onclick="NextSlide"
                        @onclick:stopPropagation="true"
                        aria-label="Next">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
                </button>

                <div class="carousel-dots">
                    @for (int i = 0; i < _carouselCount; i++)
                    {
                        var idx = i;
                        <button class="carousel-dot @(idx == _carouselIndex ? "active" : "")"
                                @onclick="() => GoToSlide(idx)"
                                @onclick:stopPropagation="true"
                                aria-label="Slide @(idx + 1)" />
                    }
                </div>
            }
        </div>
    }

    @* ── Your Library ── *@
    <PosterSwimlane Title="Your Library"
                    TotalCount="@_nonHeroHubs.Count"
                    Hubs="@_nonHeroHubs.Take(12).ToList()"
                    OnHubSelected="HandleHubSelected"
                    CardWidth="@_cardWidth" />

    @* ── Recently Added — newest first ── *@
    <PosterSwimlane Title="Recently Added"
                    TotalCount="@_recentHubs.Count"
                    Hubs="@_recentHubs.Take(12).ToList()"
                    OnHubSelected="HandleHubSelected"
                    CardWidth="@_cardWidth" />

    @* ── Grouped swimlanes by media type ── *@
    @foreach (var group in _mediaTypeGroups)
    {
        <PosterSwimlane Title="@group.Title"
                        TotalCount="@group.Hubs.Count"
                        Hubs="@group.Hubs"
                        OnHubSelected="HandleHubSelected"
                        CardWidth="@_cardWidth" />
    }
}

@code {
    private bool               _loading = true;
    private bool               _seeding;
    private string?            _error;
    private string?            _seedMessage;
    private List<HubViewModel> _hubs         = [];
    private List<HubViewModel> _nonHeroHubs  = [];
    private List<HubViewModel> _recentHubs   = [];
    private List<HubViewModel> _carouselHubs = [];
    private List<MediaTypeGroup> _mediaTypeGroups = [];

    // ── Journey items ────────────────────────────────────────────────────────
    private List<JourneyItemViewModel> _journeyItems = [];

    // ── Carousel state ───────────────────────────────────────────────────────
    private int                    _carouselIndex  = 0;
    private bool                   _carouselPaused = false;
    private CancellationTokenSource _carouselCts   = new();

    private bool _useJourneyCarousel => _journeyItems.Count > 0;
    private int  _carouselCount      => _useJourneyCarousel ? _journeyItems.Count : _carouselHubs.Count;

    private int _cardWidth => DeviceContext.Settings.Pages.Home.SwimlaneCardWidth;

    private sealed record MediaTypeGroup(string Title, IReadOnlyList<HubViewModel> Hubs);

    // ── Device-context helpers ────────────────────────────────────────────────

    private string _pendingDisplay =>
        DeviceContext.Settings.Pages.Home.PendingFilesDisplay;

    private bool _showHero =>
        DeviceContext.Settings.Pages.Home.HubHeroEnabled
        && DeviceContext.Settings.Pages.Home.HubHeroLayout != "hidden";

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadHubsAsync(showSpinner: true);
        _ = StartCarouselAsync(_carouselCts.Token);
    }

    // ── Hub loading ───────────────────────────────────────────────────────────

    private async Task LoadHubsAsync(bool showSpinner = true)
    {
        if (showSpinner)
            _loading = true;

        _error = null;

        try
        {
            _hubs = await Orchestrator.GetHubsAsync();

            // Load up to 5 in-progress items for the carousel primary pool.
            _journeyItems = await Orchestrator.GetJourneyAsync(limit: 5);

            ApplyFilter();
        }
        catch (Exception ex)
        {
            _error = $"Could not reach the Engine: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilter()
    {
        var all = _hubs;

        // Non-hero hubs (all, for "Your Library" swimlane).
        _nonHeroHubs = all.ToList();

        // Recently added: newest first — also the carousel fallback pool.
        _recentHubs   = all.OrderByDescending(h => h.CreatedAt).ToList();
        _carouselHubs = _recentHubs.Take(5).ToList();

        // Group by media type label for swimlane sections.
        _mediaTypeGroups = all
            .Where(h => !string.IsNullOrEmpty(h.PrimaryMediaType))
            .GroupBy(h => FormatMediaType(h.PrimaryMediaType!))
            .Where(g => g.Count() >= 2)
            .Select(g => new MediaTypeGroup(g.Key, g.ToList()))
            .ToList();

        // Keep index in bounds if data changed.
        if (_carouselIndex >= _carouselCount)
            _carouselIndex = 0;
    }

    // ── Ambient background color — tracks current carousel slide ─────────────

    private string? _ambientColor
    {
        get
        {
            if (!_useJourneyCarousel && _carouselHubs.Count > 0)
                return _carouselHubs[Math.Min(_carouselIndex, _carouselHubs.Count - 1)].DominantHexColor;

            // Journey mode: look up the hub by ID.
            if (_journeyItems.Count > 0 && _carouselIndex < _journeyItems.Count)
            {
                var hubId = _journeyItems[_carouselIndex].HubId;
                return _hubs.FirstOrDefault(h => h.Id == hubId)?.DominantHexColor;
            }

            return _hubs.FirstOrDefault()?.DominantHexColor;
        }
    }

    // ── Carousel timer ────────────────────────────────────────────────────────

    private async Task StartCarouselAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(6));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                if (!_carouselPaused && _carouselCount > 1)
                {
                    _carouselIndex = (_carouselIndex + 1) % _carouselCount;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task GoToSlide(int idx)
    {
        _carouselIndex = ((idx % Math.Max(1, _carouselCount)) + _carouselCount) % _carouselCount;

        // Reset the timer so it doesn't immediately advance after a manual click.
        await _carouselCts.CancelAsync();
        _carouselCts = new CancellationTokenSource();
        _ = StartCarouselAsync(_carouselCts.Token);

        await InvokeAsync(StateHasChanged);
    }

    private Task NextSlide() =>
        GoToSlide((_carouselIndex + 1) % Math.Max(1, _carouselCount));

    private Task PrevSlide() =>
        GoToSlide((_carouselIndex - 1 + Math.Max(1, _carouselCount)) % Math.Max(1, _carouselCount));

    private void PauseCarousel()  => _carouselPaused = true;
    private void ResumeCarousel() => _carouselPaused = false;

    // ── Formatting helpers ────────────────────────────────────────────────────

    private static string FormatMediaType(string mediaType)
    {
        var t = mediaType.ToLowerInvariant();
        if (t.Contains("epub"))                          return "Books";
        if (t.Contains("m4b") || t.Contains("audio"))   return "Audiobooks";
        if (t.Contains("book"))                          return "Books";
        if (t.Contains("video") || t.Contains("movie")) return "Movies";
        if (t.Contains("comic") || t.Contains("cbz"))   return "Comics";
        if (t.Contains("mkv") || t.Contains("mp4"))     return "Videos";
        return mediaType;
    }

    private static string HeroFormatMediaType(string mediaType)
    {
        var t = mediaType.ToLowerInvariant();
        if (t.Contains("epub"))                          return "Book";
        if (t.Contains("m4b") || t.Contains("audio"))   return "Audiobook";
        if (t.Contains("book"))                          return "Book";
        if (t.Contains("video") || t.Contains("movie")) return "Movie";
        if (t.Contains("comic") || t.Contains("cbz"))   return "Comic";
        if (t.Contains("mkv") || t.Contains("mp4"))     return "Video";
        return mediaType;
    }

    private static string HeroTruncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength].TrimEnd() + "…";

    private static string GetJourneyIcon(JourneyItemViewModel item)
    {
        var t = (item.MediaType ?? "").ToLowerInvariant();
        if (t.Contains("audio"))                          return Icons.Material.Filled.Headphones;
        if (t.Contains("video") || t.Contains("movie"))  return Icons.Material.Filled.PlayArrow;
        return Icons.Material.Filled.MenuBook;
    }

    // ── Hub selection ─────────────────────────────────────────────────────────

    private void HandleHubSelected(HubViewModel hub)
    {
        Nav.NavigateTo($"/hub/{hub.Id}");
    }

    /// <summary>Cover or title clicked — open Hub Detail with progress context.</summary>
    private void HandleJourneyHubNavigate(JourneyItemViewModel item)
    {
        if (item.HubId.HasValue)
            Nav.NavigateTo($"/hub/{item.HubId.Value}?lastAssetId={item.AssetId}");
    }

    /// <summary>CTA button clicked — go directly to the reader/player for this asset.</summary>
    private void HandleJourneyPlay(JourneyItemViewModel item)
    {
        var t = item.MediaType.ToLowerInvariant();

        if (t.Contains("epub") || t.Contains("book"))
        {
            // Navigate directly into the EPUB reader
            var url = $"/read/{item.AssetId}";
            if (item.HubId.HasValue) url += $"?returnHubId={item.HubId.Value}";
            Nav.NavigateTo(url);
        }
        else if (item.HubId.HasValue)
        {
            // Audio, video, comics — no dedicated player yet; open hub detail with asset context
            Nav.NavigateTo($"/hub/{item.HubId.Value}?lastAssetId={item.AssetId}");
        }
    }

    // ── Seed library (dev only) ───────────────────────────────────────────────

    private async Task HandleSeedLibrary()
    {
        _seeding = true;
        _seedMessage = null;
        StateHasChanged();

        bool success = await Orchestrator.SeedLibraryAsync();
        _seeding = false;
        _seedMessage = success
            ? "7 books are being processed — they'll appear here momentarily."
            : "Could not seed the library. Make sure the Watch Folder is configured.";
        StateHasChanged();
    }

    // ── SignalR live refresh ──────────────────────────────────────────────────

    private void OnStateChanged()
    {
        InvokeAsync(() =>
        {
            if (State.IsLoaded && _hubs.Count > 0)
            {
                ApplyFilter();
                StateHasChanged();
            }
            else
            {
                _ = LoadHubsAsync(showSpinner: false).ContinueWith(_ => InvokeAsync(StateHasChanged));
            }
        });
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
        _carouselCts.Cancel();
        _carouselCts.Dispose();
    }
}

<style>
    /* ── Hero carousel container ─────────────────────────────────────── */
    .hero-carousel {
        position: relative;
        margin-bottom: 2rem;
    }

    /* ── Slide fade-in — triggered by @@key recreation ──────────────── */
    .hero-carousel-slide {
        animation: heroSlideFadeIn 0.55s ease;
    }

    @@keyframes heroSlideFadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0);   }
    }

    /* ── Arrow buttons ───────────────────────────────────────────────── */
    .carousel-arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 20;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: none;
        background: rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        color: rgba(255, 255, 255, 0.85);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease, opacity 0.2s ease;
        opacity: 0;
    }

    .hero-carousel:hover .carousel-arrow {
        opacity: 1;
    }

    .carousel-arrow:hover {
        background: rgba(201, 146, 46, 0.70);
        color: #fff;
    }

    .carousel-arrow-left  { left:  16px; }
    .carousel-arrow-right { right: 16px; }

    /* ── Dot indicators ──────────────────────────────────────────────── */
    .carousel-dots {
        position: absolute;
        bottom: 16px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 20;
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .carousel-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: none;
        background: rgba(255, 255, 255, 0.35);
        cursor: pointer;
        padding: 0;
        transition: background 0.25s ease, transform 0.25s ease;
    }

    .carousel-dot.active {
        background: #C9922E;
        transform: scale(1.35);
    }

    .carousel-dot:hover:not(.active) {
        background: rgba(255, 255, 255, 0.65);
    }

    /* ── Journey column — stacks metadata vertically inside hero-stack-text ── */
    /* hero-stack-text uses display:flex, so this div becomes the flex item.   */
    /* flex-direction:column here stacks title → badges → author → desc → CTA */
    .hero-journey-col {
        display: flex;
        flex-direction: column;
        max-width: 640px;
        cursor: pointer;
    }

    .hero-journey-col .hub-primary-cta {
        margin-top: 16px;
    }

    /* ── Empty state ─────────────────────────────────────────────────── */
    .home-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        gap: 16px;
        text-align: center;
        padding: 2rem;
    }

    .home-empty-icon {
        width: 80px;
        height: 80px;
        opacity: 0.4;
        margin-bottom: 8px;
    }

    .home-empty-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: rgba(248, 248, 248, 0.85);
        margin: 0;
    }

    .home-empty-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.95rem;
        font-weight: 400;
        color: rgba(248, 248, 248, 0.50);
        max-width: 420px;
        line-height: 1.5;
        margin: 0;
    }
</style>
