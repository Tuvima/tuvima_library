@page "/read"
@page "/watch"
@page "/listen"
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer State
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable
@using MediaEngine.Web.Models.ViewDTOs

<PageTitle>@_config.PageTitle</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else
{
    @* ── Ambient background from hero ── *@
    <GlobalBackground ImageUrl="@(_heroData?.CoverUrl)"
                      Color="@_config.AccentColor" />

    @* ── Mini hero ── *@
    <div class="category-page-gutter">
        <CategoryHero Data="@_heroData"
                      CategoryLabel="@_config.Key"
                      AccentColor="@_config.AccentColor"
                      ItemCount="@_filteredWorks.Count"
                      OnClicked="HandleHeroClick"
                      OnCtaClicked="HandleHeroCta" />
    </div>

    @* ── Header with sub-filter toggle ── *@
    <div class="category-page-gutter category-header">
        <div>
            <p class="category-count" style="color: @_config.AccentColor;">
                @_filteredWorks.Count @(_filteredWorks.Count == 1 ? "Title" : "Titles")
                in @(_activeSubFilter == "All" ? "Collection" : _activeSubFilter)
            </p>
            <div class="category-toggle">
                @foreach (var opt in _config.SubFilters)
                {
                    <button class="category-toggle-btn @(_activeSubFilter == opt ? "category-toggle-btn-active" : "")"
                            style="@(_activeSubFilter == opt ? $"background: {_config.AccentColor}; box-shadow: 0 4px 12px {_config.AccentColor}33;" : "")"
                            @onclick="() => OnSubFilterChanged(opt)">
                        @opt
                    </button>
                }
            </div>
        </div>
    </div>

    @* ── Filter bar: status, genres, search ── *@
    <div class="category-page-gutter category-filters">
        <div class="category-filters-left">
            @* Status filter *@
            <div class="category-status-filters">
                @foreach (var stat in new[] { "All", "In Progress", "Finished" })
                {
                    <button class="category-status-btn @(_activeStatus == stat ? "category-status-btn-active" : "")"
                            style="@(_activeStatus == stat ? $"color: {_config.AccentColor};" : "")"
                            @onclick="() => OnStatusChanged(stat)">
                        @stat
                    </button>
                }
            </div>
        </div>

        <div class="category-filters-right">
            @* Genre dropdown *@
            <div class="category-genre-dropdown">
                <button class="category-genre-trigger @(_selectedGenres.Count > 0 ? "category-genre-trigger-active" : "")"
                        style="@(_selectedGenres.Count > 0 ? $"background: {_config.AccentColor}; border-color: {_config.AccentColor}; color: black;" : "")"
                        @onclick="() => _genreMenuOpen = !_genreMenuOpen">
                    <MudIcon Icon="@MudBlazor.Icons.Material.Outlined.Label" Size="Size.Small" Style="font-size: 14px;" />
                    @(_selectedGenres.Count > 0 ? $"Genres ({_selectedGenres.Count})" : "Genres")
                    <MudIcon Icon="@MudBlazor.Icons.Material.Filled.ExpandMore" Size="Size.Small"
                             Style="@($"font-size: 14px; transition: transform 0.2s; {(_genreMenuOpen ? "transform: rotate(180deg);" : "")}")" />
                </button>

                @if (_genreMenuOpen)
                {
                    <div class="category-genre-backdrop" @onclick="() => _genreMenuOpen = false"></div>
                    <div class="category-genre-menu">
                        @foreach (var genre in _availableGenres)
                        {
                            <button class="category-genre-item" @onclick="() => ToggleGenre(genre)">
                                <span style="@(_selectedGenres.Contains(genre) ? $"color: {_config.AccentColor};" : "")">@genre</span>
                                @if (_selectedGenres.Contains(genre))
                                {
                                    <MudIcon Icon="@MudBlazor.Icons.Material.Filled.Check" Size="Size.Small"
                                             Style="@($"font-size: 14px; color: {_config.AccentColor};")" />
                                }
                            </button>
                        }
                        @if (_selectedGenres.Count > 0)
                        {
                            <button class="category-genre-clear" @onclick="() => { _selectedGenres.Clear(); ApplyFilters(); }">
                                Clear All
                            </button>
                        }
                    </div>
                }
            </div>

            @* Search *@
            <div class="category-search">
                <MudIcon Icon="@MudBlazor.Icons.Material.Outlined.Search" Size="Size.Small"
                         Style="font-size: 14px; position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: rgba(148,163,184,0.50);" />
                <input type="text" placeholder="Search library..."
                       value="@_searchText" @oninput="OnSearchInput"
                       class="category-search-input" />
            </div>
        </div>
    </div>

    @* ── Grid of items ── *@
    <div class="category-page-gutter">
        <div class="category-grid">
            @foreach (var work in _filteredWorks)
            {
                var item = PosterItemViewModel.FromWork(work);
                <LibraryCard Item="@item" OnItemSelected="HandleItemSelected" />
            }
        </div>
    </div>
}

@code {
    // ── Category configuration ────────────────────────────────────────────

    private sealed record CategoryConfig(
        string Key,
        string PageTitle,
        string AccentColor,
        string[] MediaTypes,
        string[] SubFilters,
        string ContinueLabel);

    private static CategoryConfig ResolveConfig(string path) => path switch
    {
        "read" => new("read", "Read — Tuvima", "#5DCAA5", ["Books", "Audiobooks", "Comics"],
            ["All", "Books", "Comics", "Audiobooks"], "Continue Reading"),
        "watch" => new("watch", "Watch — Tuvima", "#60A5FA", ["Movies", "TV"],
            ["All", "Movies", "TV Shows"], "Continue Watching"),
        "listen" => new("listen", "Listen — Tuvima", "#A78BFA", ["Music", "Audiobooks", "Podcasts"],
            ["All", "Music", "Audiobooks", "Podcasts"], "Continue Listening"),
        _ => new("read", "Read — Tuvima", "#5DCAA5", ["Books", "Audiobooks", "Comics"],
            ["All", "Books", "Comics", "Audiobooks"], "Continue Reading"),
    };

    private static string[] MediaTypesForSubFilter(string categoryKey, string subFilter)
    {
        if (subFilter == "All") return [];
        return (categoryKey, subFilter) switch
        {
            ("read", "Books") => ["Books"],
            ("read", "Comics") => ["Comics"],
            ("read", "Audiobooks") => ["Audiobooks"],
            ("watch", "Movies") => ["Movies"],
            ("watch", "TV Shows") => ["TV"],
            ("listen", "Music") => ["Music"],
            ("listen", "Audiobooks") => ["Audiobooks"],
            ("listen", "Podcasts") => ["Podcasts"],
            _ => [],
        };
    }

    // ── State ─────────────────────────────────────────────────────────────

    private CategoryConfig _config = ResolveConfig("read");
    private string _activeSubFilter = "All";
    private string _activeStatus = "All";
    private List<string> _selectedGenres = [];
    private bool _genreMenuOpen;
    private string _searchText = "";
    private bool _loading = true;

    // Data
    private List<WorkViewModel> _allWorks = [];
    private List<WorkViewModel> _filteredWorks = [];
    private List<JourneyItemViewModel> _journeyItems = [];
    private List<string> _availableGenres = [];
    private HeroData? _heroData;

    // ── Lifecycle ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        ResolveFromUrl();
        await LoadAsync();
    }

    private void ResolveFromUrl()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Split('#')[0].Trim('/');
        _config = ResolveConfig(path);
        _activeSubFilter = "All";
        _activeStatus = "All";
        _selectedGenres = [];
        _searchText = "";
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var path = new Uri(e.Location).AbsolutePath.Trim('/');
        if (path is "read" or "watch" or "listen")
        {
            ResolveFromUrl();
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Data loading ──────────────────────────────────────────────────────

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _allWorks = await Orchestrator.GetLibraryWorksAsync();
            _journeyItems = await Orchestrator.GetJourneyAsync(limit: 10);

            // Filter to category media types
            _allWorks = _allWorks
                .Where(w => _config.MediaTypes.Any(mt =>
                    (w.MediaType ?? "").Contains(mt, StringComparison.OrdinalIgnoreCase)))
                .ToList();

            _journeyItems = _journeyItems
                .Where(j => _config.MediaTypes.Any(mt =>
                    (j.MediaType ?? "").Contains(mt, StringComparison.OrdinalIgnoreCase)))
                .ToList();

            // Build genre list dynamically
            _availableGenres = _allWorks
                .SelectMany(w => w.Genres)
                .Where(g => !string.IsNullOrEmpty(g))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(g => g)
                .ToList();

            BuildHero();
            ApplyFilters();
        }
        catch { }
        finally { _loading = false; }
    }

    // ── Filtering ─────────────────────────────────────────────────────────

    private void ApplyFilters()
    {
        var works = _allWorks.AsEnumerable();

        // Sub-filter (media type within category)
        var subTypes = MediaTypesForSubFilter(_config.Key, _activeSubFilter);
        if (subTypes.Length > 0)
        {
            works = works.Where(w => subTypes.Any(st =>
                (w.MediaType ?? "").Contains(st, StringComparison.OrdinalIgnoreCase)));
        }

        // Status filter
        if (_activeStatus == "In Progress")
        {
            var inProgressIds = _journeyItems
                .Where(j => j.ProgressPct is > 0 and < 100)
                .Select(j => j.WorkId)
                .ToHashSet();
            works = works.Where(w => inProgressIds.Contains(w.Id));
        }
        else if (_activeStatus == "Finished")
        {
            var finishedIds = _journeyItems
                .Where(j => j.ProgressPct >= 100)
                .Select(j => j.WorkId)
                .ToHashSet();
            works = works.Where(w => finishedIds.Contains(w.Id));
        }

        // Genre filter
        if (_selectedGenres.Count > 0)
        {
            works = works.Where(w => w.Genres.Any(g => _selectedGenres.Contains(g, StringComparer.OrdinalIgnoreCase)));
        }

        // Search
        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var term = _searchText.Trim();
            works = works.Where(w =>
                (w.Title?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (w.Author?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        _filteredWorks = works.ToList();
    }

    // ── Hero building ─────────────────────────────────────────────────────

    private void BuildHero()
    {
        var topJourney = _journeyItems
            .OrderByDescending(j => j.LastAccessed)
            .FirstOrDefault();

        if (topJourney is not null)
        {
            _heroData = HeroData.FromJourney(topJourney);
        }
        else
        {
            var newest = _allWorks
                .Where(w => !string.IsNullOrEmpty(w.CoverUrl))
                .OrderByDescending(w => w.Year ?? "0000")
                .FirstOrDefault();

            if (newest is not null)
            {
                _heroData = HeroData.FromWork(newest, null);
            }
        }
    }

    // ── Event handlers ────────────────────────────────────────────────────

    private void OnSubFilterChanged(string filter)
    {
        _activeSubFilter = filter;
        _selectedGenres = [];
        ApplyFilters();
    }

    private void OnStatusChanged(string status)
    {
        _activeStatus = status;
        ApplyFilters();
    }

    private void ToggleGenre(string genre)
    {
        if (_selectedGenres.Contains(genre))
            _selectedGenres.Remove(genre);
        else
            _selectedGenres.Add(genre);
        ApplyFilters();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void HandleItemSelected(PosterItemViewModel item) =>
        Nav.NavigateTo(item.NavigationUrl);

    private void HandleHeroClick()
    {
        // Navigate to the hero item
    }

    private void HandleHeroCta()
    {
        // Navigate to read/play the hero item
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}

<style>
    .category-page-gutter {
        padding: 0 1.5rem;
    }

    @@media (min-width: 768px) {
        .category-page-gutter {
            padding: 0 4rem;
        }
    }

    .category-header {
        padding-top: 3rem;
        padding-bottom: 1.5rem;
    }

    .category-count {
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.4em;
        margin-bottom: 1.5rem;
    }

    .category-toggle {
        display: flex;
        background: rgba(255, 255, 255, 0.05);
        padding: 4px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        width: fit-content;
    }

    .category-toggle-btn {
        padding: 8px 24px;
        border-radius: 999px;
        font-family: 'Montserrat', sans-serif;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
        color: rgba(148, 163, 184, 1);
        background: transparent;
    }

    .category-toggle-btn:hover {
        color: white;
    }

    .category-toggle-btn-active {
        color: black !important;
    }

    /* ── Filters ── */
    .category-filters {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        margin-bottom: 3rem;
    }

    @@media (min-width: 1024px) {
        .category-filters {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }

    .category-filters-left {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 2rem;
    }

    .category-filters-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .category-status-filters {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .category-status-btn {
        font-family: 'Montserrat', sans-serif;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(148, 163, 184, 0.60);
        background: none;
        border: none;
        cursor: pointer;
        transition: color 0.2s ease;
        padding: 0;
    }

    .category-status-btn:hover {
        color: white;
    }

    .category-status-btn-active {
        /* color set via inline style */
    }

    /* ── Genre dropdown ── */
    .category-genre-dropdown {
        position: relative;
    }

    .category-genre-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 20px;
        border-radius: 12px;
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        border: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(255, 255, 255, 0.05);
        color: rgba(248, 248, 248, 0.70);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .category-genre-trigger:hover {
        background: rgba(255, 255, 255, 0.10);
    }

    .category-genre-trigger-active {
        /* Inline styles handle active state */
    }

    .category-genre-backdrop {
        position: fixed;
        inset: 0;
        z-index: 49;
    }

    .category-genre-menu {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        width: 224px;
        background: rgba(15, 20, 31, 1);
        border: 1px solid rgba(255, 255, 255, 0.10);
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.60);
        z-index: 50;
        padding: 12px;
    }

    .category-genre-item {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 12px;
        border-radius: 8px;
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        font-weight: 700;
        color: rgba(148, 163, 184, 1);
        background: none;
        border: none;
        cursor: pointer;
        transition: background 0.15s ease;
    }

    .category-genre-item:hover {
        background: rgba(255, 255, 255, 0.05);
        color: white;
    }

    .category-genre-clear {
        width: 100%;
        margin-top: 8px;
        padding-top: 8px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        font-family: 'Montserrat', sans-serif;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(148, 163, 184, 0.50);
        background: none;
        border-left: none;
        border-right: none;
        border-bottom: none;
        cursor: pointer;
        text-align: center;
    }

    .category-genre-clear:hover {
        color: rgba(248, 113, 113, 0.85);
    }

    /* ── Search ── */
    .category-search {
        position: relative;
        flex-grow: 1;
    }

    @@media (min-width: 1024px) {
        .category-search {
            flex-grow: 0;
        }
    }

    .category-search-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 10px 24px 10px 40px;
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        color: white;
        outline: none;
        transition: all 0.2s ease;
    }

    @@media (min-width: 1024px) {
        .category-search-input {
            width: 200px;
        }
    }

    .category-search-input::placeholder {
        color: rgba(148, 163, 184, 0.50);
    }

    .category-search-input:focus {
        border-color: rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.10);
    }

    /* ── Grid ── */
    .category-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem 2rem;
        padding-bottom: 5rem;
    }

    @@media (min-width: 640px) {
        .category-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (min-width: 768px) {
        .category-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    @@media (min-width: 1024px) {
        .category-grid {
            grid-template-columns: repeat(5, 1fr);
        }
    }

    @@media (min-width: 1280px) {
        .category-grid {
            grid-template-columns: repeat(6, 1fr);
        }
    }
</style>
