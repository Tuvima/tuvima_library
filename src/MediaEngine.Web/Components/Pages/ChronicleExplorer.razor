@page "/universe/{Qid}/explore"
@using MediaEngine.Web.Components.Universe
@using MediaEngine.Web.Services.Theming
@inject IEngineApiClient ApiClient
@inject IJSRuntime JS
@inject ILogger<ChronicleExplorer> Logger
@inject DeviceContextService DeviceContext
@implements IAsyncDisposable

<PageTitle>Chronicle Explorer - @(_graph?.Universe.Label ?? Qid)</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
@if (DeviceContext.IsMobile)
{
    <AppPanel Class="chronicle-explorer-empty pa-6" Elevation="0">
        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" Color="Color.Default" />
        <MudText Typo="Typo.h5">Chronicle Explorer is unavailable on mobile</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            The relationship graph needs a larger workspace. Open this Universe from a desktop or tablet-sized web view.
        </MudText>
    </AppPanel>
}
else if (_loading)
{
    <AppPanel Class="chronicle-explorer-empty pa-6" Elevation="0">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">Loading Universe Graph data...</MudText>
    </AppPanel>
}
else if (_graph is null)
{
    <AppPanel Class="chronicle-explorer-empty pa-6" Elevation="0">
        <MudIcon Icon="@Icons.Material.Filled.Hub" Size="Size.Large" Color="Color.Default" />
        <MudText Typo="Typo.h5">Universe Graph unavailable</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Tuvima has not found enough real character, location, organization, event, or relationship data for this Universe yet.
        </MudText>
    </AppPanel>
}
else
{
<MudText Typo="Typo.h4" Class="chronicle-explorer-title mb-2">
        @(_graph?.Universe.Label ?? "Loading...")
    </MudText>
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
        <AppChip T="string" Color="Color.Primary" Size="Size.Small">
            @(_graph?.Nodes.Count ?? 0) entities
        </AppChip>
        <AppChip T="string" Color="Color.Secondary" Size="Size.Small">
            @(_graph?.Edges.Count ?? 0) relationships
        </AppChip>
        @if (_characterCount > 0)
        {
            <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                @_characterCount characters
            </AppChip>
        }
        @if (_locationCount > 0)
        {
            <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                @_locationCount locations
            </AppChip>
        }
        @if (_orgCount > 0)
        {
            <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                @_orgCount organizations
            </AppChip>
        }
    </MudStack>
@if (_loreDeltaChanges > 0)
    {
        <AppAlert Severity="Severity.Warning" Class="mb-3"
                  CloseIconClicked="@(() => _loreDeltaChanges = 0)">
            New Lore Discovered: @_loreDeltaChanges entities have been updated on Wikidata since last enrichment.
        </AppAlert>
    }
<AppTabs @bind-ActivePanelIndex="_activeMode" Class="mb-3"
             ApplyEffectsToContainer="false"
             SliderColor="Color.Warning"
             Rounded="false">
        <MudTabPanel Text="Web" Icon="@Icons.Material.Filled.Collections"
                     ToolTip="Full relationship graph" />
        <MudTabPanel Text="Paths" Icon="@Icons.Material.Filled.Route"
                     ToolTip="Six Degrees pathfinder" />
        <MudTabPanel Text="Family" Icon="@Icons.Material.Filled.AccountTree"
                     ToolTip="Family tree view" />
        <MudTabPanel Text="Cast" Icon="@Icons.Material.Filled.People"
                     ToolTip="Character to performer mapping" />
        <MudTabPanel Text="Adaptations" Icon="@Icons.Material.Filled.Merge"
                     ToolTip="Adaptation chain" />
        <MudTabPanel Text="Sources" Icon="@Icons.Material.Filled.FactCheck"
                     ToolTip="Supplemental lore sources" />
    </AppTabs>
@if (_activeMode == 0 || _activeMode == 1 || _activeMode == 2)
    {
@if (!_hasGraphData)
        {
            <AppPanel Class="chronicle-explorer-empty pa-6" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.Hub" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.h5">Universe Graph unavailable</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Tuvima has not found enough real character, location, organization, event, or relationship data for this Universe yet.
                </MudText>
            </AppPanel>
        }
        else
        {
@if (_activeMode == 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="chronicle-explorer-controls mb-3">
                @if (_hasTemporalData && !DeviceContext.IsTelevision)
                {
                    <div class="chronicle-explorer-timeline">
                        <MudSlider T="int" Value="@_timelineYear" ValueChanged="OnTimelineYearChanged"
                                   Min="@_minYear" Max="@_maxYear">
                            Timeline: @_timelineYear
                        </MudSlider>
                    </div>
                }
                else if (_hasTemporalData && DeviceContext.IsTelevision)
                {
                    <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                        Timeline available on desktop
                    </AppChip>
                }

                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <AppChip T="string" Color="@(_showCharacters ? Color.Primary : Color.Default)"
                             Variant="@(_showCharacters ? Variant.Filled : Variant.Outlined)"
                             OnClick="@(() => ToggleTypeFilter("Character"))">
                        Characters
                    </AppChip>
                    <AppChip T="string" Color="@(_showLocations ? Color.Success : Color.Default)"
                             Variant="@(_showLocations ? Variant.Filled : Variant.Outlined)"
                             OnClick="@(() => ToggleTypeFilter("Location"))">
                        Locations
                    </AppChip>
                    <AppChip T="string" Color="@(_showOrganizations ? Color.Warning : Color.Default)"
                             Variant="@(_showOrganizations ? Variant.Filled : Variant.Outlined)"
                             OnClick="@(() => ToggleTypeFilter("Organization"))">
                        Organizations
                    </AppChip>
                </MudStack>

                <AppSelect T="string" Value="@_layout" ValueChanged="OnLayoutChanged"
                           Label="Layout" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Class="chronicle-explorer-layout">
                    <MudSelectItem T="string" Value="@("cose")">Force-directed</MudSelectItem>
                    <MudSelectItem T="string" Value="@("concentric")">Concentric</MudSelectItem>
                    <MudSelectItem T="string" Value="@("grid")">Grid</MudSelectItem>
                    <MudSelectItem T="string" Value="@("dagre")">Hierarchical</MudSelectItem>
                </AppSelect>
            </MudStack>
        }
<MudGrid>
            <MudItem xs="12" md="@(_activeMode == 0 ? 7 : 8)">
                <div id="cytoscape-container"
                     class="chronicle-explorer-graph">
                </div>
            </MudItem>
            <MudItem xs="12" md="@(_activeMode == 0 ? 5 : 4)">
                <AppPanel Class="chronicle-explorer-panel pa-3">
                    @if (_activeMode == 0)
                    {
                        @* Mode 1: entity list *@
                        <AppTextField T="string" @bind-Value="_entitySearch" Placeholder="Search entities..."
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Immediate="true" Class="mb-3" />
                        <MudList T="GraphNodeDto" Dense="true">
                            @foreach (var entity in FilteredEntities)
                            {
                                <MudListItem T="GraphNodeDto" OnClick="@(() => OnEntityClick(entity))">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@GetEntityIcon(entity.Type)"
                                                 Color="@GetEntityColor(entity.Type)"
                                                 Size="Size.Small" />
                                        <MudText>@entity.Label</MudText>
                                        <MudSpacer />
                                        <MudText Typo="Typo.caption" Class="chronicle-explorer-entity-type">
                                            @entity.Type
                                        </MudText>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                    else if (_activeMode == 1)
                    {
                        @* Mode 2: PathFinder *@
                        <PathFinderPanel @ref="_pathFinderRef"
                                         UniverseQid="@Qid"
                                         Graph="@_graph"
                                         OnPathRequested="OnPathPairSet" />
                    }
                    else if (_activeMode == 2)
                    {
                        @* Mode 3: Family Tree *@
                        <FamilyTreeView UniverseQid="@Qid" Graph="@_graph" />
                    }
                </AppPanel>
            </MudItem>
        </MudGrid>
        }
    }
    else if (_activeMode == 3)
    {
<AppPanel Class="chronicle-explorer-full-panel pa-4">
            <CastComparison UniverseQid="@Qid" />
        </AppPanel>
    }
    else if (_activeMode == 4)
    {
<AppPanel Class="chronicle-explorer-full-panel pa-4">
            <AdaptationTree UniverseQid="@Qid" />
        </AppPanel>
    }
    else if (_activeMode == 5)
    {
<AppPanel Class="chronicle-explorer-full-panel pa-4">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.h6">Supplemental lore sources</MudText>
                    <MudSpacer />
                    <AppButton Label="Discover"
                               ButtonStyle="AppButtonStyle.Outlined"
                               Tone="AppUiTone.Primary"
                               StartIcon="@Icons.Material.Filled.TravelExplore"
                               Disabled="@_loreActionBusy"
                               OnClick="@DiscoverLoreSourcesAsync" />
                    <AppButton Label="Enrich"
                               ButtonStyle="AppButtonStyle.Filled"
                               Tone="AppUiTone.Primary"
                               StartIcon="@Icons.Material.Filled.AutoFixHigh"
                               Disabled="@(_loreActionBusy || !HasApprovedLoreSource)"
                               OnClick="@EnrichLoreSourcesAsync" />
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_loreMessage))
                {
                    <AppAlert Severity="@_loreMessageSeverity" Class="mb-1"
                              CloseIconClicked="@(() => _loreMessage = string.Empty)">
                        @_loreMessage
                    </AppAlert>
                }

                <MudGrid>
                    <MudItem xs="12" md="5">
                        <AppTextField T="string" @bind-Value="_manualSourceName"
                                      Label="Source name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <AppTextField T="string" @bind-Value="_manualSourceUrl"
                                      Label="Fandom URL"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex align-center">
                        <AppButton Label="Add"
                                   ButtonStyle="AppButtonStyle.Outlined"
                                   Tone="AppUiTone.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@(_loreActionBusy || string.IsNullOrWhiteSpace(_manualSourceUrl))"
                                   OnClick="@AddManualLoreSourceAsync" />
                    </MudItem>
                </MudGrid>

                @if (_loreSourcesLoading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_loreSources.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        No supplemental lore sources have been found or added for this Universe.
                    </MudText>
                }
                else
                {
                    <AppTable Class="chronicle-source-table">
                        <thead>
                        <tr>
                            <th>Source</th>
                            <th>Status</th>
                            <th>Confidence</th>
                            <th>Last enriched</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var source in _loreSources)
                        {
                            <tr>
                                <td>
                                    <MudStack Spacing="0">
                                        <MudLink Href="@source.BaseUrl" Target="_blank">@source.SourceName</MudLink>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@source.PluginId</MudText>
                                    </MudStack>
                                </td>
                                <td>
                                    <AppChip T="string" Size="Size.Small"
                                             Color="@GetSourceStatusColor(source.Status)"
                                             Variant="@GetSourceStatusVariant(source.Status)">
                                        @source.Status
                                    </AppChip>
                                </td>
                                <td>@source.Confidence.ToString("P0")</td>
                                <td>@(source.LastEnrichedAt?.ToLocalTime().ToString("g") ?? "-")</td>
                                <td>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1">
                                        @if (!source.Status.Equals("Approved", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <AppIconButton Icon="@Icons.Material.Filled.Check"
                                                           Tooltip="Approve"
                                                           AriaLabel="Approve source"
                                                           Tone="AppUiTone.Success"
                                                           Size="AppControlSize.Compact"
                                                           Disabled="@_loreActionBusy"
                                                           OnClick="@(() => ApproveLoreSourceAsync(source.Id))" />
                                        }
                                        @if (!source.Status.Equals("Rejected", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <AppIconButton Icon="@Icons.Material.Filled.Close"
                                                           Tooltip="Reject"
                                                           AriaLabel="Reject source"
                                                           Tone="AppUiTone.Error"
                                                           Size="AppControlSize.Compact"
                                                           Disabled="@_loreActionBusy"
                                                           OnClick="@(() => RejectLoreSourceAsync(source.Id))" />
                                        }
                                    </MudStack>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </AppTable>
                }
            </MudStack>
        </AppPanel>
    }
}
</MudContainer>
<MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.End" Width="400px"
           Elevation="2" Variant="@DrawerVariant.Temporary">
    @if (_selectedEntity is not null)
    {
        <MudDrawerHeader>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@GetEntityIcon(_selectedEntity.Type)"
                         Color="@GetEntityColor(_selectedEntity.Type)" />
                <MudText Typo="Typo.h6">@_selectedEntity.Label</MudText>
            </MudStack>
        </MudDrawerHeader>
        <div class="pa-4">
            <MudText Typo="Typo.body2" Class="mb-3">
                @(_selectedEntity.Description ?? "No description available.")
            </MudText>
            <MudText Typo="Typo.caption" Class="chronicle-explorer-qid">
                QID: @_selectedEntity.Id
            </MudText>

            @if (_selectedEntity.Works?.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Appears in</MudText>
                @foreach (var work in _selectedEntity.Works)
                {
                    <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                        @work.Label
                    </AppChip>
                }
            }

            @if (_selectedEntityEdges.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Relationships</MudText>
                @foreach (var edge in _selectedEntityEdges)
                {
                    <MudText Typo="Typo.body2" Class="mb-1">
                        @edge.Label
                        @GetNodeLabel(edge.Source == _selectedEntity.Id ? edge.Target : edge.Source)
                    </MudText>
                }
            }
        </div>
    }
</MudDrawer>

@code {
    [Parameter] public string Qid { get; set; } = string.Empty;

    private UniverseGraphResponse? _graph;
    private int _loreDeltaChanges;
    private bool _hasTemporalData;
    private int _minYear = 1900;
    private int _maxYear = 2030;
    private int _timelineYear = 2030;
    private string _layout = "cose";
    private string _entitySearch = string.Empty;
    private bool _drawerOpen;
    private GraphNodeDto? _selectedEntity;
    private List<GraphEdgeDto> _selectedEntityEdges = [];
    private DotNetObjectReference<ChronicleExplorer>? _dotNetRef;
    private int _characterCount;
    private int _locationCount;
    private int _orgCount;
    private int _activeMode = 0;  // 0=Web, 1=Paths, 2=Family, 3=Cast, 4=Adaptations, 5=Sources
    private int _previousMode = 0;
    private PathFinderPanel? _pathFinderRef;
    private bool _showCharacters = true;
    private bool _showLocations = true;
    private bool _showOrganizations = true;
    private bool _loading = true;
    private bool _hasGraphData;
    private bool _loreSourcesLoading;
    private bool _loreActionBusy;
    private string _manualSourceName = string.Empty;
    private string _manualSourceUrl = string.Empty;
    private string _loreMessage = string.Empty;
    private Severity _loreMessageSeverity = Severity.Info;
    private List<UniverseLoreSourceViewModel> _loreSources = [];

    private IEnumerable<GraphNodeDto> FilteredEntities =>
        _graph?.Nodes.Where(n =>
            string.IsNullOrWhiteSpace(_entitySearch) ||
            n.Label.Contains(_entitySearch, StringComparison.OrdinalIgnoreCase)) ?? [];

    private bool HasApprovedLoreSource =>
        _loreSources.Any(source => source.Status.Equals("Approved", StringComparison.OrdinalIgnoreCase));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _graph is not null && _hasGraphData && !DeviceContext.IsMobile)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("CytoscapeInterop.initGraph",
                "cytoscape-container",
                System.Text.Json.JsonSerializer.Serialize(_graph.Nodes),
                System.Text.Json.JsonSerializer.Serialize(_graph.Edges),
                _layout,
                _dotNetRef);
        }
        var needsGraph = _activeMode is 0 or 1 or 2;
        var prevNeedsGraph = _previousMode is 0 or 1 or 2;
        if (!firstRender && needsGraph && !prevNeedsGraph && _graph is not null && _hasGraphData && !DeviceContext.IsMobile)
        {
            _previousMode = _activeMode;
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("CytoscapeInterop.initGraph",
                "cytoscape-container",
                System.Text.Json.JsonSerializer.Serialize(_graph.Nodes),
                System.Text.Json.JsonSerializer.Serialize(_graph.Edges),
                _layout,
                _dotNetRef);
        }
        else if (!firstRender)
        {
            _previousMode = _activeMode;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _graph = await ApiClient.GetUniverseGraphAsync(Qid, includeSupplementalLore: true);
        if (_graph is not null)
        {
            _hasGraphData = _graph.Nodes.Count > 0 && _graph.Edges.Count > 0;
            _characterCount = _graph.Nodes.Count(n =>
                string.Equals(n.Type, "Character", StringComparison.OrdinalIgnoreCase));
            _locationCount = _graph.Nodes.Count(n =>
                string.Equals(n.Type, "Location", StringComparison.OrdinalIgnoreCase));
            _orgCount = _graph.Nodes.Count(n =>
                string.Equals(n.Type, "Organization", StringComparison.OrdinalIgnoreCase));
            _hasTemporalData = _graph.Edges.Any(e => !string.IsNullOrWhiteSpace(e.StartTime));
            if (_hasTemporalData)
            {
                var years = _graph.Edges
                    .Where(e => !string.IsNullOrWhiteSpace(e.StartTime))
                    .Select(e =>
                    {
                        var span = e.StartTime!.AsSpan(0, Math.Min(4, e.StartTime!.Length));
                        int.TryParse(span, out var y);
                        return y;
                    })
                    .Where(y => y > 0)
                    .ToList();
                if (years.Count > 0)
                {
                    _minYear = years.Min();
                    _maxYear = Math.Max(years.Max(), DateTime.UtcNow.Year);
                    _timelineYear = _maxYear;
                }
            }
        }
        try
        {
            await LoadLoreSourcesAsync();
            var deltas = await ApiClient.CheckLoreDeltaAsync(Qid);
            _loreDeltaChanges = deltas.Count(d => d.HasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not check lore delta for universe {Qid}.", Qid);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnTimelineYearChanged(int year)
    {
        _timelineYear = year;
        await JS.InvokeVoidAsync("CytoscapeInterop.filterByTimelineYear", year);
    }

    private async Task ToggleTypeFilter(string type)
    {
        switch (type)
        {
            case "Character":    _showCharacters = !_showCharacters; break;
            case "Location":     _showLocations = !_showLocations; break;
            case "Organization": _showOrganizations = !_showOrganizations; break;
        }

        var activeTypes = new List<string>();
        if (_showCharacters) activeTypes.Add("Character");
        if (_showLocations) activeTypes.Add("Location");
        if (_showOrganizations) activeTypes.Add("Organization");

        var types = string.Join(",", activeTypes);
        _graph = await ApiClient.GetUniverseGraphAsync(Qid, types: types, includeSupplementalLore: true);
        if (_graph is not null)
        {
            _hasGraphData = _graph.Nodes.Count > 0 && _graph.Edges.Count > 0;
            _characterCount = _graph.Nodes.Count(n =>
                string.Equals(n.Type, "Character", StringComparison.OrdinalIgnoreCase));
            _locationCount = _graph.Nodes.Count(n =>
                string.Equals(n.Type, "Location", StringComparison.OrdinalIgnoreCase));
            _orgCount = _graph.Nodes.Count(n =>
                string.Equals(n.Type, "Organization", StringComparison.OrdinalIgnoreCase));

            if (_hasGraphData)
            {
                await JS.InvokeVoidAsync("CytoscapeInterop.updateGraph",
                    System.Text.Json.JsonSerializer.Serialize(_graph.Nodes),
                    System.Text.Json.JsonSerializer.Serialize(_graph.Edges));
            }
        }
    }

    private async Task OnLayoutChanged(string layout)
    {
        _layout = layout;
        await JS.InvokeVoidAsync("CytoscapeInterop.setLayout", layout);
    }

    private async Task OnEntityClick(GraphNodeDto entity)
    {
        _selectedEntity = entity;
        _selectedEntityEdges = _graph?.Edges
            .Where(e => e.Source == entity.Id || e.Target == entity.Id)
            .ToList() ?? [];
        _drawerOpen = true;
        await JS.InvokeVoidAsync("CytoscapeInterop.focusNode", entity.Id);
    }
    [JSInvokable]
    public void OnNodeClick(string nodeQid)
    {
        var entity = _graph?.Nodes.FirstOrDefault(n => n.Id == nodeQid);
        if (entity is null) return;

        _selectedEntity = entity;
        _selectedEntityEdges = _graph?.Edges
            .Where(e => e.Source == entity.Id || e.Target == entity.Id)
            .ToList() ?? [];
        if (_activeMode == 1 && _pathFinderRef is not null)
        {
            _pathFinderRef.SetNode(nodeQid, entity.Label);
        }
        else
        {
            _drawerOpen = true;
        }

        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnEdgeClick(string sourceQid, string targetQid, string type)
    {
        OnNodeClick(sourceQid);
    }

    private async Task OnPathPairSet((string From, string To) pair)
    {
        await Task.CompletedTask;
    }

    private string GetNodeLabel(string qid) =>
        _graph?.Nodes.FirstOrDefault(n => n.Id == qid)?.Label ?? qid;

    private static string GetEntityIcon(string type) => type switch
    {
        "Character"    => Icons.Material.Filled.Person,
        "Location"     => Icons.Material.Filled.Place,
        "Organization" => Icons.Material.Filled.Business,
        _              => Icons.Material.Filled.Category,
    };

    private static Color GetEntityColor(string type) => type switch
    {
        "Character"    => Color.Primary,
        "Location"     => Color.Success,
        "Organization" => Color.Warning,
        _              => Color.Default,
    };

    private async Task LoadLoreSourcesAsync()
    {
        _loreSourcesLoading = true;
        try
        {
            _loreSources = (await ApiClient.GetUniverseLoreSourcesAsync(Qid)).ToList();
        }
        finally
        {
            _loreSourcesLoading = false;
        }
    }

    private async Task DiscoverLoreSourcesAsync()
    {
        _loreActionBusy = true;
        try
        {
            _loreSources = (await ApiClient.DiscoverUniverseLoreSourcesAsync(Qid)).ToList();
            SetLoreMessage("Source discovery completed.", Severity.Success);
        }
        finally
        {
            _loreActionBusy = false;
        }
    }

    private async Task AddManualLoreSourceAsync()
    {
        _loreActionBusy = true;
        try
        {
            var added = await ApiClient.AddUniverseLoreSourceAsync(
                Qid,
                new UniverseLoreManualSourceRequest
                {
                    SourceName = _manualSourceName,
                    BaseUrl = _manualSourceUrl,
                });
            if (added is null)
            {
                SetLoreMessage("The source could not be added.", Severity.Error);
                return;
            }

            _manualSourceName = string.Empty;
            _manualSourceUrl = string.Empty;
            await LoadLoreSourcesAsync();
            SetLoreMessage("Source added for approval.", Severity.Success);
        }
        finally
        {
            _loreActionBusy = false;
        }
    }

    private async Task ApproveLoreSourceAsync(Guid sourceId)
    {
        _loreActionBusy = true;
        try
        {
            _loreSources = (await ApiClient.ApproveUniverseLoreSourceAsync(Qid, sourceId)).ToList();
            SetLoreMessage("Source approved.", Severity.Success);
        }
        finally
        {
            _loreActionBusy = false;
        }
    }

    private async Task RejectLoreSourceAsync(Guid sourceId)
    {
        _loreActionBusy = true;
        try
        {
            _loreSources = (await ApiClient.RejectUniverseLoreSourceAsync(Qid, sourceId)).ToList();
            SetLoreMessage("Source rejected.", Severity.Info);
        }
        finally
        {
            _loreActionBusy = false;
        }
    }

    private async Task EnrichLoreSourcesAsync()
    {
        _loreActionBusy = true;
        try
        {
            var summary = await ApiClient.EnrichUniverseLoreAsync(Qid);
            if (summary is null)
            {
                SetLoreMessage("Lore enrichment did not complete.", Severity.Error);
                return;
            }

            await LoadLoreSourcesAsync();
            _graph = await ApiClient.GetUniverseGraphAsync(Qid, includeSupplementalLore: true);
            if (_graph is not null)
            {
                _hasGraphData = _graph.Nodes.Count > 0 && _graph.Edges.Count > 0;
                _characterCount = _graph.Nodes.Count(n =>
                    string.Equals(n.Type, "Character", StringComparison.OrdinalIgnoreCase));
                _locationCount = _graph.Nodes.Count(n =>
                    string.Equals(n.Type, "Location", StringComparison.OrdinalIgnoreCase));
                _orgCount = _graph.Nodes.Count(n =>
                    string.Equals(n.Type, "Organization", StringComparison.OrdinalIgnoreCase));
            }

            SetLoreMessage(
                $"Enriched {summary.EntitiesWritten} entities from {summary.SourcesEnriched} source(s).",
                Severity.Success);
        }
        finally
        {
            _loreActionBusy = false;
        }
    }

    private void SetLoreMessage(string message, Severity severity)
    {
        _loreMessage = message;
        _loreMessageSeverity = severity;
    }

    private static Color GetSourceStatusColor(string status) => status switch
    {
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Warning,
    };

    private static Variant GetSourceStatusVariant(string status) => status switch
    {
        "Approved" => Variant.Filled,
        _ => Variant.Outlined,
    };

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("CytoscapeInterop.destroy");
        }
        catch (JSDisconnectedException)
        {
        }
        _dotNetRef?.Dispose();
    }
}
