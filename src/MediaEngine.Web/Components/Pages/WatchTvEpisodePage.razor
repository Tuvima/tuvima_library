@page "/watch/tv/show/{CollectionId:guid}/episode/{WorkId:guid}"
@using MediaEngine.Contracts.Details
@using MediaEngine.Web.Components.Details
@using MediaEngine.Web.Services.Integration
@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav

@namespace MediaEngine.Web.Components.Pages

<PageTitle>@((_detail?.Title ?? "Episode")) - Tuvima</PageTitle>

@if (_loading)
{
    <div class="tl-detail-page">
        <div class="tl-glass-panel">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        </div>
    </div>
}
else if (_detail is null)
{
    <div class="tl-detail-page">
        <div class="tl-glass-panel">
            <MudText Typo="Typo.h5">Episode not found</MudText>
            <MudText Typo="Typo.body2">This episode could not be loaded from your library.</MudText>
        </div>
    </div>
}
else
{
    <DetailPage Model="_detail" ActiveTab="@_activeTab" ActiveTabChanged="HandleTabChangedAsync" OnActionSelected="HandleActionAsync" />
}

@code {
    [Parameter] public Guid CollectionId { get; set; }
    [Parameter] public Guid WorkId { get; set; }

    private DetailPageViewModel? _detail;
    private bool _loading = true;
    private string? _activeTab;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        var profile = await Orchestrator.GetActiveProfileAsync();
        _detail = await ApiClient.GetDetailPageAsync(DetailEntityType.TvEpisode, WorkId, DetailPresentationContext.Watch, profileId: profile?.Id);
        ApplyDetailTabRoute();
        _loading = false;
    }

    private Task HandleActionAsync(DetailAction action)
    {
        if (!string.IsNullOrWhiteSpace(action.Route))
            Nav.NavigateTo(action.Route);

        return Task.CompletedTask;
    }

    private Task HandleTabChangedAsync(string tab)
    {
        _activeTab = tab;
        return Task.CompletedTask;
    }

    private void ApplyDetailTabRoute()
    {
        if (_detail is null)
            return;

        var resolution = DetailTabNavigation.Resolve(_detail, _activeTab);
        _activeTab = resolution.ActiveTab;
    }
}
