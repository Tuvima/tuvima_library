@page "/books"
@inject UIOrchestratorService  Orchestrator
@inject UniverseStateContainer  State
@inject DeviceContextService    DeviceContext
@inject IEngineApiClient        Api
@inject NavigationManager       Nav
@implements IDisposable

@using MediaEngine.Web.Models.ViewDTOs

<PageTitle>Books - Tuvima</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else if (_allBookHubs.Count == 0)
{
    <div class="lane-empty-state">
        <MudIcon Icon="@Icons.Material.Filled.AutoStories" Size="Size.Large"
                 Style="opacity: 0.3; font-size: 4rem; margin-bottom: 16px;" />
        <h2 class="lane-empty-title">No books yet</h2>
        <p class="lane-empty-subtitle">
            Your book and audiobook collection will appear here. Drop EPUB or M4B files
            into your Watch Folder to get started.
        </p>
    </div>
}
else
{
    @* -- Page ambient background -- *@
    @if (_heroHub is not null)
    {
        <div class="page-ambient-bg"
             style="--ambient-color: @_heroHub.DominantHexColor"
             aria-hidden="true"></div>
    }

    @* -- Hero banner -- *@
    @if (_heroHub is not null)
    {
        <div class="hero-stack" @onclick="@(() => Nav.NavigateTo($"/hub/{_heroHub.Id}"))">
            <div class="hero-stack-bg">
                <div class="hero-bleed-wrapper">
                    <HubHero Hub="@_heroHub" BackgroundOnly="true" Visible="true" />
                </div>
            </div>
            <div class="hero-stack-text">
                <div class="hero-content-layout">
                    @if (!string.IsNullOrEmpty(_heroHub.CoverUrl))
                    {
                        <img src="@_heroHub.CoverUrl"
                             alt="@_heroHub.DisplayName"
                             class="hero-cover-art" />
                    }
                    <div class="hero-text-block">
                        <h2 class="hero-cinema-title">@_heroHub.DisplayName</h2>
                        <div class="hero-cinema-badges">
                            @if (!string.IsNullOrEmpty(_heroHub.Year))
                            { <span class="hero-badge">@_heroHub.Year</span> }
                            @if (!string.IsNullOrEmpty(_heroHub.PrimaryMediaType))
                            { <span class="hero-badge">@FormatMediaType(_heroHub.PrimaryMediaType)</span> }
                        </div>
                        @if (!string.IsNullOrEmpty(_heroHub.Author))
                        { <p class="hero-cinema-subtitle">@_heroHub.Author</p> }
                        @if (!string.IsNullOrEmpty(_heroHub.Description))
                        { <p class="hero-cinema-description">@Truncate(_heroHub.Description, 200)</p> }
                    </div>
                </div>
            </div>
        </div>
    }

    @* -- View mode toggle -- *@
    <div class="books-view-toggle">
        <MudToggleGroup T="string" Value="@_viewMode" ValueChanged="OnViewModeChanged"
                        Color="Color.Warning" CheckMark="false"
                        Style="font-family: Montserrat, sans-serif;">
            <MudToggleItem T="string" Value="@("smart")" Text="Smart Sections" />
            <MudToggleItem T="string" Value="@("az")" Text="Browse A-Z" />
        </MudToggleGroup>
    </div>

    @* -- Filter bar (both modes) -- *@
    <BookFilterBar FilterState="@_filterState"
                   FilterStateChanged="OnFilterChanged"
                   AvailableGenres="@_availableGenres"
                   AvailableSeries="@_availableSeries"
                   AvailableAuthors="@_availableAuthors" />

    @if (_viewMode == "az")
    {
        @* -- A-Z Browse mode -- *@
        <AlphabeticalGrid Hubs="@_displayHubs"
                          OnHubSelected="HandleHubSelected"
                          CardWidth="@_cardWidth" />
    }
    else
    {
        @* -- Smart Sections mode -- *@

        @* Continue Reading *@
        @if (_journeyHubs.Count > 0)
        {
            <PosterSwimlane Title="Continue Reading"
                            TotalCount="@_journeyHubs.Count"
                            Hubs="@_journeyHubs"
                            OnHubSelected="HandleHubSelected"
                            CardWidth="@_cardWidth" />
        }

        @* Recently Added *@
        @if (_recentHubs.Count > 0 && !_filterState.HasActiveFilters)
        {
            <PosterSwimlane Title="Recently Added"
                            TotalCount="@_recentHubs.Count"
                            Hubs="@_recentHubs.Take(12).ToList()"
                            OnHubSelected="HandleHubSelected"
                            CardWidth="@_cardWidth" />
        }

        @* Filtered results (when filters are active) *@
        @if (_filterState.HasActiveFilters)
        {
            <PosterSwimlane Title="@($"Results ({_displayHubs.Count})")"
                            TotalCount="@_displayHubs.Count"
                            Hubs="@_displayHubs.Take(24).ToList()"
                            OnHubSelected="HandleHubSelected"
                            CardWidth="@_cardWidth" />
        }
        else
        {
            @* Featured Authors *@
            @foreach (var authorGroup in _authorGroups.Take(5))
            {
                <PosterSwimlane Title="@authorGroup.AuthorName"
                                Hubs="@authorGroup.Hubs"
                                OnHubSelected="HandleHubSelected"
                                CardWidth="@_cardWidth">
                    <HeaderContent>
                        <AuthorSwimlaneHeader AuthorName="@authorGroup.AuthorName"
                                              HeadshotUrl="@authorGroup.HeadshotUrl"
                                              BookCount="@authorGroup.Hubs.Count" />
                    </HeaderContent>
                </PosterSwimlane>
            }

            @* By Series *@
            @foreach (var seriesGroup in _seriesGroups.Take(5))
            {
                <PosterSwimlane Title="@seriesGroup.SeriesName"
                                TotalCount="@seriesGroup.Hubs.Count"
                                Hubs="@seriesGroup.Hubs"
                                OnHubSelected="HandleHubSelected"
                                CardWidth="@_cardWidth" />
            }

            @* By Genre *@
            @foreach (var genreGroup in _genreGroups.Take(5))
            {
                <PosterSwimlane Title="@genreGroup.GenreName"
                                TotalCount="@genreGroup.Hubs.Count"
                                Hubs="@genreGroup.Hubs"
                                OnHubSelected="HandleHubSelected"
                                CardWidth="@_cardWidth" />
            }
        }
    }
}

@code {
    private bool _loading = true;
    private string _viewMode = "smart";
    private HubViewModel? _heroHub;
    private BookFilterState _filterState = new();

    private List<HubViewModel> _allBookHubs = [];
    private List<HubViewModel> _displayHubs = [];
    private List<HubViewModel> _recentHubs = [];
    private List<HubViewModel> _journeyHubs = [];
    private List<AuthorGroup> _authorGroups = [];
    private List<SeriesGroup> _seriesGroups = [];
    private List<GenreGroup> _genreGroups = [];

    private IReadOnlyList<string> _availableGenres = [];
    private IReadOnlyList<string> _availableAuthors = [];
    private IReadOnlyList<string> _availableSeries = [];
    private Dictionary<string, PersonViewModel> _authorPersons = new();

    private int _cardWidth => DeviceContext.Settings.Pages.Home.SwimlaneCardWidth;

    private sealed record AuthorGroup(string AuthorName, string? HeadshotUrl, IReadOnlyList<HubViewModel> Hubs);
    private sealed record SeriesGroup(string SeriesName, IReadOnlyList<HubViewModel> Hubs);
    private sealed record GenreGroup(string GenreName, IReadOnlyList<HubViewModel> Hubs);

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var allHubs = await Orchestrator.GetHubsAsync();
            _allBookHubs = allHubs
                .Where(h => IsBook(h.PrimaryMediaType))
                .ToList();

            // Load journey items for Continue Reading
            var journey = await Orchestrator.GetJourneyAsync(limit: 5);
            _journeyHubs = journey
                .Where(j => IsBook(j.MediaType))
                .Select(j => _allBookHubs.FirstOrDefault(h => h.Id == j.HubId))
                .Where(h => h is not null)
                .Cast<HubViewModel>()
                .ToList();

            // Load author persons for headshot matching
            try
            {
                var authors = await Api.GetPersonsByRoleAsync("Author", 50);
                _authorPersons = authors
                    .GroupBy(p => p.Name.ToLowerInvariant())
                    .ToDictionary(g => g.Key, g => g.First());
            }
            catch { _authorPersons = new(); }

            // Build available filter options
            BuildFilterOptions();
            ApplyFilters();
        }
        catch { _allBookHubs = []; }
        finally { _loading = false; }
    }

    private void BuildFilterOptions()
    {
        _availableGenres = _allBookHubs
            .Where(h => !string.IsNullOrEmpty(h.Genre))
            .SelectMany(h => h.Genre!.Split(',', ';').Select(g => g.Trim()))
            .Where(g => g.Length > 0)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(g => g)
            .ToList();

        _availableAuthors = _allBookHubs
            .Where(h => !string.IsNullOrEmpty(h.Author))
            .Select(h => h.Author!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(a => a)
            .ToList();

        _availableSeries = _allBookHubs
            .Where(h => !string.IsNullOrEmpty(h.Series))
            .Select(h => h.Series!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(s => s)
            .ToList();
    }

    private void ApplyFilters()
    {
        var filtered = _allBookHubs.AsEnumerable();

        // Format filter
        if (_filterState.Format == "eBooks")
            filtered = filtered.Where(h => IsEbook(h.PrimaryMediaType));
        else if (_filterState.Format == "Audiobooks")
            filtered = filtered.Where(h => IsAudiobook(h.PrimaryMediaType));

        // Genre filter
        if (_filterState.SelectedGenres.Count > 0)
            filtered = filtered.Where(h => !string.IsNullOrEmpty(h.Genre)
                && _filterState.SelectedGenres.Any(g =>
                    h.Genre!.Contains(g, StringComparison.OrdinalIgnoreCase)));

        // Author filter
        if (!string.IsNullOrEmpty(_filterState.AuthorSearch))
            filtered = filtered.Where(h => !string.IsNullOrEmpty(h.Author)
                && h.Author!.Contains(_filterState.AuthorSearch, StringComparison.OrdinalIgnoreCase));

        // Series filter
        if (!string.IsNullOrEmpty(_filterState.SeriesFilter))
            filtered = filtered.Where(h => !string.IsNullOrEmpty(h.Series)
                && h.Series!.Equals(_filterState.SeriesFilter, StringComparison.OrdinalIgnoreCase));

        // Year range
        if (!string.IsNullOrEmpty(_filterState.YearFrom) && int.TryParse(_filterState.YearFrom, out var from))
            filtered = filtered.Where(h => int.TryParse(h.Year, out var y) && y >= from);
        if (!string.IsNullOrEmpty(_filterState.YearTo) && int.TryParse(_filterState.YearTo, out var to))
            filtered = filtered.Where(h => int.TryParse(h.Year, out var y) && y <= to);

        // Sort
        filtered = _filterState.SortBy switch
        {
            "title-az"  => filtered.OrderBy(h => h.DisplayName),
            "title-za"  => filtered.OrderByDescending(h => h.DisplayName),
            "author-az" => filtered.OrderBy(h => h.Author ?? "zzz"),
            "year-new"  => filtered.OrderByDescending(h => h.Year ?? "0"),
            "year-old"  => filtered.OrderBy(h => h.Year ?? "9999"),
            _           => filtered.OrderByDescending(h => h.CreatedAt),
        };

        _displayHubs = filtered.ToList();

        // Hero selection
        var withCovers = _displayHubs.Where(h =>
            !string.IsNullOrEmpty(h.CoverUrl) || !string.IsNullOrEmpty(h.HeroUrl)).ToList();
        var heroPool = withCovers.Count > 0 ? withCovers : _displayHubs;
        _heroHub = heroPool.Count > 0 ? heroPool[Random.Shared.Next(heroPool.Count)] : null;

        // Recently Added
        _recentHubs = _displayHubs.OrderByDescending(h => h.CreatedAt).Take(12).ToList();

        // Build groups for smart sections
        BuildGroups();
    }

    private void BuildGroups()
    {
        // Author groups (top 5 by book count)
        _authorGroups = _displayHubs
            .Where(h => !string.IsNullOrEmpty(h.Author))
            .GroupBy(h => h.Author!, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 2)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g =>
            {
                var authorName = g.Key;
                _authorPersons.TryGetValue(authorName.ToLowerInvariant(), out var person);
                var headshot = person?.LocalHeadshotUrl ?? person?.HeadshotUrl;
                return new AuthorGroup(authorName, headshot, g.ToList());
            })
            .ToList();

        // Series groups
        _seriesGroups = _displayHubs
            .Where(h => !string.IsNullOrEmpty(h.Series))
            .GroupBy(h => h.Series!, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 2)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g => new SeriesGroup(g.Key,
                g.OrderBy(h => h.Year ?? "9999").ToList()))
            .ToList();

        // Genre groups (top genres by frequency)
        _genreGroups = _displayHubs
            .Where(h => !string.IsNullOrEmpty(h.Genre))
            .SelectMany(h => h.Genre!.Split(',', ';')
                .Select(g => g.Trim())
                .Where(g => g.Length > 0)
                .Select(g => (Genre: g, Hub: h)))
            .GroupBy(x => x.Genre, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 2)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g => new GenreGroup(g.Key,
                g.Select(x => x.Hub).Distinct().ToList()))
            .ToList();
    }

    private Task OnFilterChanged(BookFilterState newState)
    {
        _filterState = newState;
        ApplyFilters();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void OnViewModeChanged(string value)
    {
        _viewMode = value ?? "smart";
    }

    private void HandleHubSelected(HubViewModel hub) =>
        Nav.NavigateTo($"/hub/{hub.Id}");

    private void OnStateChanged()
    {
        InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });
    }

    private static bool IsBook(string? mt) =>
        mt is not null && (mt.Contains("Epub", StringComparison.OrdinalIgnoreCase)
            || mt.Contains("Audio", StringComparison.OrdinalIgnoreCase)
            || mt.Contains("M4B", StringComparison.OrdinalIgnoreCase)
            || mt.Contains("Book", StringComparison.OrdinalIgnoreCase));

    private static bool IsEbook(string? mt) =>
        mt is not null && (mt.Contains("Epub", StringComparison.OrdinalIgnoreCase)
            || mt.Contains("Book", StringComparison.OrdinalIgnoreCase));

    private static bool IsAudiobook(string? mt) =>
        mt is not null && (mt.Contains("Audio", StringComparison.OrdinalIgnoreCase)
            || mt.Contains("M4B", StringComparison.OrdinalIgnoreCase));

    private static string FormatMediaType(string mediaType)
    {
        var t = mediaType.ToLowerInvariant();
        if (t.Contains("epub") || t.Contains("book")) return "Book";
        if (t.Contains("audio") || t.Contains("m4b")) return "Audiobook";
        return mediaType;
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength].TrimEnd() + "\u2026";

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }
}

<style>
    .books-view-toggle {
        padding: 0.75rem 0 0.5rem 88px;
    }

    .lane-empty-state {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; min-height: 50vh; gap: 8px;
        text-align: center; padding: 2rem;
    }

    .lane-empty-title {
        font-family: Montserrat, sans-serif; font-size: 1.4rem;
        font-weight: 700; color: rgba(248,248,248,0.85); margin: 0;
    }

    .lane-empty-subtitle {
        font-family: Montserrat, sans-serif; font-size: 0.9rem;
        font-weight: 400; color: rgba(248,248,248,0.45);
        max-width: 420px; line-height: 1.5; margin: 0;
    }

    @@media (max-width: 768px) {
        .books-view-toggle { padding-left: 1rem; }
    }
</style>
