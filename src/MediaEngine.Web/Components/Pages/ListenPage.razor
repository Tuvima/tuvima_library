@page "/listen"
@inject DiscoveryComposerService Discovery
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer State
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Listen - Tuvima</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" Style="border-radius: 4px;" />
}
else
{
    <GlobalBackground ImageUrl="@_page.Hero?.BackgroundImageUrl" Color="@_page.AccentColor" />

    <div class="listen-discovery-page">
        @if (_page.Hero is not null)
        {
            <DiscoveryHero Hero="@_page.Hero" />
        }

        @if (_page.Hubs.Count > 0)
        {
            <DiscoveryHubStrip Hubs="@_page.Hubs"
                               Title="Listen collections"
                               Subtitle="Albums, artists, audiobook series, and mixes driven by the library you already own." />
        }

        <div class="listen-discovery-shelves">
            @foreach (var shelf in _page.Shelves)
            {
                <DiscoveryShelf Shelf="@shelf" />
            }
        </div>

        <section class="listen-discovery-catalog-shell">
            <div class="listen-discovery-catalog-header">
                <div>
                    <h2 class="listen-discovery-catalog-title">Browse your audio library</h2>
                    <p class="listen-discovery-catalog-copy">
                        Music stays album and artist driven, while audiobooks keep their own discovery view.
                    </p>
                </div>

                <div class="listen-discovery-toolbar">
                    <div class="listen-discovery-tabs">
                        @foreach (var tab in _tabs)
                        {
                            <button type="button"
                                    class="listen-discovery-tab @(_activeTab == tab ? "is-active" : "")"
                                    style="@(_activeTab == tab ? $"--tab-accent: {_page.AccentColor};" : string.Empty)"
                                    @onclick="() => SetTab(tab)">
                                @tab
                            </button>
                        }
                    </div>

                    @if (_activeTab != "Audiobooks")
                    {
                        <div class="listen-discovery-views">
                            @foreach (var view in _musicViews)
                            {
                                <button type="button"
                                        class="listen-discovery-view @(_viewMode == view ? "is-active" : "")"
                                        style="@(_viewMode == view ? $"--view-accent: {_page.AccentColor};" : string.Empty)"
                                        @onclick="() => SetView(view)">
                                    @view
                                </button>
                            }
                        </div>
                    }

                    <div class="listen-discovery-filters">
                        <MudTextField T="string"
                                      Value="_searchText"
                                      ValueChanged="OnSearchChanged"
                                      Placeholder="@SearchPlaceholder"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Outlined.Search"
                                      Class="listen-discovery-search" />

                        <MudSelect T="string"
                                   Value="_sortBy"
                                   ValueChanged="OnSortChanged"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Class="listen-discovery-sort">
                            <MudSelectItem T="string" Value="@("Newest")">Newest</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Title")">Title</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Creator")">Creator</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Year")">Year</MudSelectItem>
                        </MudSelect>
                    </div>
                </div>
            </div>

            @if (_activeTab == "Audiobooks")
            {
                @if (FilteredAudiobooks.Count == 0)
                {
                    <div class="listen-discovery-empty">
                        <MudIcon Icon="@Icons.Material.Filled.Headphones"
                                 Style="font-size: 48px; color: rgba(255,255,255,0.18);" />
                        <p>No audiobooks match these filters.</p>
                    </div>
                }
                else
                {
                    <div class="listen-discovery-catalog">
                        @foreach (var card in FilteredAudiobooks)
                        {
                            <DiscoveryCard Item="@card" />
                        }
                    </div>
                }
            }
            else if (_viewMode == "Artists")
            {
                @if (ArtistShelves.Count == 0)
                {
                    <div class="listen-discovery-empty">
                        <MudIcon Icon="@Icons.Material.Filled.MicExternalOn"
                                 Style="font-size: 48px; color: rgba(255,255,255,0.18);" />
                        <p>No artist groupings are available for this filter set.</p>
                    </div>
                }
                else
                {
                    <div class="listen-discovery-artist-sections">
                        @foreach (var shelf in ArtistShelves)
                        {
                            <DiscoveryShelf Shelf="@shelf" />
                        }
                    </div>
                }
            }
            else if (_viewMode == "Tracks")
            {
                @if (FilteredMusic.Count == 0)
                {
                    <div class="listen-discovery-empty">
                        <MudIcon Icon="@Icons.Material.Filled.MusicNote"
                                 Style="font-size: 48px; color: rgba(255,255,255,0.18);" />
                        <p>No music titles match these filters.</p>
                    </div>
                }
                else
                {
                    <div class="listen-discovery-tracks">
                        <div class="listen-discovery-track-header">
                            <div>Title</div>
                            <div>Creator</div>
                            <div>Type</div>
                            <div>Year</div>
                        </div>

                        <div class="listen-discovery-track-list">
                            @foreach (var card in FilteredMusic.Take(200))
                            {
                                <button type="button" class="listen-discovery-track-row" @onclick="() => OpenCard(card)">
                                    <div class="listen-discovery-track-title-cell">
                                        @if (!string.IsNullOrWhiteSpace(card.CoverUrl))
                                        {
                                            <img src="@card.CoverUrl" alt="@card.Title" class="listen-discovery-track-art" />
                                        }
                                        else
                                        {
                                            <div class="listen-discovery-track-art listen-discovery-track-art-fallback">
                                                <MudIcon Icon="@Icons.Material.Filled.Album" />
                                            </div>
                                        }
                                        <div class="listen-discovery-track-text">
                                            <div class="listen-discovery-track-title">@card.Title</div>
                                            @if (!string.IsNullOrWhiteSpace(card.Subtitle))
                                            {
                                                <div class="listen-discovery-track-subtitle">@card.Subtitle</div>
                                            }
                                        </div>
                                    </div>
                                    <div class="listen-discovery-track-cell">@((string.IsNullOrWhiteSpace(card.Creator) ? "-" : card.Creator))</div>
                                    <div class="listen-discovery-track-cell">@card.MediaKind</div>
                                    <div class="listen-discovery-track-cell">@(card.SortYear > 0 ? card.SortYear.ToString() : "-")</div>
                                </button>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                @if (_filteredCatalog.Count == 0)
                {
                    <div class="listen-discovery-empty">
                        <MudIcon Icon="@Icons.Material.Filled.Headphones"
                                 Style="font-size: 48px; color: rgba(255,255,255,0.18);" />
                        <p>No listen titles match these filters.</p>
                    </div>
                }
                else
                {
                    <div class="listen-discovery-catalog">
                        @foreach (var card in _filteredCatalog)
                        {
                            <DiscoveryCard Item="@card" />
                        }
                    </div>
                }
            }
        </section>
    </div>
}

@code {
    private static readonly string[] _tabs = ["All", "Music", "Audiobooks"];
    private static readonly string[] _musicViews = ["Albums", "Artists", "Tracks"];

    private bool _loading = true;
    private string _activeTab = "All";
    private string _viewMode = "Albums";
    private string _searchText = string.Empty;
    private string _sortBy = "Newest";
    private DiscoveryPageViewModel _page = new() { Key = "listen", AccentColor = "#1ED760" };
    private List<DiscoveryCardViewModel> _filteredCatalog = [];

    private string SearchPlaceholder => _activeTab switch
    {
        "Music" => "Search music, artists, albums, and series...",
        "Audiobooks" => "Search audiobooks, narrators, and series...",
        _ => "Search your music and audiobook library..."
    };

    private IReadOnlyList<DiscoveryCardViewModel> FilteredMusic =>
        _filteredCatalog
            .Where(card => string.Equals(card.MediaKind, "Music", StringComparison.OrdinalIgnoreCase))
            .ToList();

    private IReadOnlyList<DiscoveryCardViewModel> FilteredAudiobooks =>
        _filteredCatalog
            .Where(card => string.Equals(card.MediaKind, "Audiobook", StringComparison.OrdinalIgnoreCase))
            .ToList();

    private IReadOnlyList<DiscoveryShelfViewModel> ArtistShelves =>
        FilteredMusic
            .Where(card => !string.IsNullOrWhiteSpace(card.Creator))
            .GroupBy(card => card.Creator!, StringComparer.OrdinalIgnoreCase)
            .Where(group => group.Count() >= 2)
            .OrderByDescending(group => group.Count())
            .Take(8)
            .Select(group => new DiscoveryShelfViewModel
            {
                Title = group.Key,
                Subtitle = $"{group.Count()} titles",
                Items = group.Take(12).ToList()
            })
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        try
        {
            _page = await Discovery.BuildListenAsync();
            ApplyFilters();
        }
        catch
        {
            _page = new DiscoveryPageViewModel
            {
                Key = "listen",
                AccentColor = "#1ED760",
                EmptyTitle = "Nothing to listen to yet.",
                EmptySubtitle = "Music and audiobooks appear here once they are added to the library."
            };
            _filteredCatalog = [];
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<DiscoveryCardViewModel> cards = _page.Catalog;

        cards = _activeTab switch
        {
            "Music" => cards.Where(card => string.Equals(card.MediaKind, "Music", StringComparison.OrdinalIgnoreCase)),
            "Audiobooks" => cards.Where(card => string.Equals(card.MediaKind, "Audiobook", StringComparison.OrdinalIgnoreCase)),
            _ => cards
        };

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var term = _searchText.Trim();
            cards = cards.Where(card => MatchesSearch(card, term));
        }

        cards = _sortBy switch
        {
            "Title" => cards.OrderBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            "Creator" => cards.OrderBy(card => card.Creator, StringComparer.OrdinalIgnoreCase).ThenBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            "Year" => cards.OrderByDescending(card => card.SortYear).ThenBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            _ => cards.OrderByDescending(card => card.SortTimestamp).ThenBy(card => card.Title, StringComparer.OrdinalIgnoreCase)
        };

        _filteredCatalog = cards.ToList();
    }

    private static bool MatchesSearch(DiscoveryCardViewModel card, string term) =>
        card.Title.Contains(term, StringComparison.OrdinalIgnoreCase)
        || (card.Subtitle?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || (card.Creator?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || (card.CollectionKey?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || (card.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || card.Genres.Any(genre => genre.Contains(term, StringComparison.OrdinalIgnoreCase));

    private void SetTab(string tab)
    {
        _activeTab = tab;
        if (_activeTab == "Audiobooks")
        {
            _viewMode = "Albums";
        }

        ApplyFilters();
    }

    private void SetView(string view)
    {
        _viewMode = view;
    }

    private Task OnSearchChanged(string value)
    {
        _searchText = value;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private Task OnSortChanged(string value)
    {
        _sortBy = value;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private void OpenCard(DiscoveryCardViewModel card)
    {
        Nav.NavigateTo(card.NavigationUrl);
    }

    private void OnStateChanged()
    {
        _ = InvokeAsync(LoadAsync);
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }
}

<style>
    .listen-discovery-page {
        display: flex;
        flex-direction: column;
        gap: 34px;
        padding: 0 1.5rem 5rem;
    }

    .listen-discovery-shelves,
    .listen-discovery-artist-sections {
        display: flex;
        flex-direction: column;
        gap: 36px;
    }

    .listen-discovery-catalog-shell {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .listen-discovery-catalog-title {
        margin: 0;
        font-family: Georgia, 'Times New Roman', serif;
        font-size: clamp(1.5rem, 2vw, 2.15rem);
        font-weight: 700;
        line-height: 1;
        color: rgba(248, 250, 252, 0.96);
    }

    .listen-discovery-catalog-copy {
        margin: 10px 0 0;
        max-width: 640px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.94rem;
        line-height: 1.6;
        color: rgba(148, 163, 184, 0.88);
    }

    .listen-discovery-toolbar {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-top: 18px;
    }

    .listen-discovery-tabs,
    .listen-discovery-views {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .listen-discovery-tab,
    .listen-discovery-view {
        min-height: 38px;
        padding: 0 16px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.03);
        color: rgba(226, 232, 240, 0.86);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        cursor: pointer;
        transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease;
    }

    .listen-discovery-tab:hover,
    .listen-discovery-view:hover {
        transform: translateY(-1px);
        border-color: rgba(255, 255, 255, 0.14);
    }

    .listen-discovery-tab.is-active {
        border-color: color-mix(in srgb, var(--tab-accent) 54%, rgba(255,255,255,0.12));
        background: color-mix(in srgb, var(--tab-accent) 18%, rgba(255,255,255,0.02));
        color: rgba(248, 250, 252, 0.96);
    }

    .listen-discovery-view.is-active {
        border-color: color-mix(in srgb, var(--view-accent) 54%, rgba(255,255,255,0.12));
        background: color-mix(in srgb, var(--view-accent) 18%, rgba(255,255,255,0.02));
        color: rgba(248, 250, 252, 0.96);
    }

    .listen-discovery-filters {
        display: grid;
        grid-template-columns: minmax(260px, 420px) 160px;
        gap: 14px;
        justify-content: end;
    }

    .listen-discovery-search,
    .listen-discovery-sort {
        width: 100%;
    }

    .listen-discovery-catalog {
        display: flex;
        flex-wrap: wrap;
        gap: 22px;
    }

    .listen-discovery-tracks {
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.02);
        overflow: hidden;
    }

    .listen-discovery-track-header,
    .listen-discovery-track-row {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr) 130px 80px;
        gap: 16px;
        align-items: center;
        padding: 14px 18px;
    }

    .listen-discovery-track-header {
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        font-family: 'Montserrat', sans-serif;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(148, 163, 184, 0.82);
    }

    .listen-discovery-track-row {
        width: 100%;
        border: none;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
        background: transparent;
        color: rgba(248, 250, 252, 0.92);
        text-align: left;
        cursor: pointer;
        transition: background 0.16s ease;
    }

    .listen-discovery-track-row:hover {
        background: rgba(255, 255, 255, 0.04);
    }

    .listen-discovery-track-title-cell {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
    }

    .listen-discovery-track-art {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        object-fit: cover;
        flex-shrink: 0;
        background: rgba(255, 255, 255, 0.05);
    }

    .listen-discovery-track-art-fallback {
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.4);
    }

    .listen-discovery-track-text {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .listen-discovery-track-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.92rem;
        font-weight: 700;
        color: rgba(248, 250, 252, 0.96);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .listen-discovery-track-subtitle,
    .listen-discovery-track-cell {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        color: rgba(148, 163, 184, 0.88);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .listen-discovery-empty {
        min-height: 220px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        color: rgba(226, 232, 240, 0.7);
        font-family: 'Montserrat', sans-serif;
    }

    @@media (min-width: 768px) {
        .listen-discovery-page {
            padding: 0 4rem 5rem;
        }
    }

    @@media (max-width: 960px) {
        .listen-discovery-filters {
            grid-template-columns: 1fr;
            justify-content: stretch;
        }
    }

    @@media (max-width: 860px) {
        .listen-discovery-track-header,
        .listen-discovery-track-row {
            grid-template-columns: minmax(0, 1fr) 100px;
        }

        .listen-discovery-track-header div:nth-child(2),
        .listen-discovery-track-header div:nth-child(4),
        .listen-discovery-track-row div:nth-child(2),
        .listen-discovery-track-row div:nth-child(4) {
            display: none;
        }
    }
</style>
