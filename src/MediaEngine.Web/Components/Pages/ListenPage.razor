@page "/listen"
@page "/listen/music"
@page "/listen/music/{Section}"
@page "/listen/music/albums/{CollectionId:guid}"
@page "/listen/music/albums/by-name/{AlbumKey}"
@page "/listen/music/artists/{ArtistKey}"
@page "/listen/music/playlists/{CollectionId:guid}"
@page "/listen/music/playlists/system/{PlaylistKey}"
@page "/listen/audiobooks"
@page "/listen/audiobook/{WorkId:guid}"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Components.Discovery
@using MediaEngine.Web.Components.Listen
@using MediaEngine.Web.Models.ViewDTOs
@using MudBlazor

@namespace MediaEngine.Web.Components.Pages

<PageTitle>@PageTitleText</PageTitle>

@if (_redirecting || _loading)
{
    <div class="listen-state">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Style="color: rgba(255,255,255,0.32);" />
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="listen-state listen-state--error">
        <MudIcon Icon="@Icons.Material.Outlined.LibraryMusic" Style="font-size: 56px; opacity: 0.22;" />
        <h3>Listen could not load</h3>
        <p>@_error</p>
        <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="ReloadAsync">Try again</AppNativeButton>
    </div>
}
else
{
    <SidebarPageShell Class="listen-page">
        <Rail>
        <div class="listen-rail">
            @if (IsMusicMode)
            {
                <section class="listen-rail__section">
                    <div class="listen-rail__label">Music</div>
                    @foreach (var item in MusicLibraryItems)
                    {
                        <AppNativeButton Type="button" Class="@($"listen-rail__item @(IsRouteActive(item.Route) ? ")" is-active" : null)" OnClick="@(() => NavigateTo(item.Route))">
                            <MudIcon Icon="@item.Icon" Style="font-size: 18px;" />
                            <span>@item.Label</span>
                            <span class="listen-rail__meta">@item.Meta</span>
                        </AppNativeButton>
                    }
                </section>

                <section class="listen-rail__section">
                    <div class="listen-rail__label">Quick access</div>
                    @foreach (var item in QuickAccessItems)
                    {
                        <AppNativeButton Type="button" Class="@($"listen-rail__item @(IsRouteActive(item.Route) ? ")" is-active" : null)" OnClick="@(() => NavigateTo(item.Route))">
                            <MudIcon Icon="@item.Icon" Style="font-size: 18px;" />
                            <span>@item.Label</span>
                            @if (!string.IsNullOrWhiteSpace(item.Meta))
                            {
                                <span class="listen-rail__meta">@item.Meta</span>
                            }
                        </AppNativeButton>
                    }
                </section>

                <section class="listen-rail__section">
                    <div class="listen-rail__section-heading">
                        <AppNativeButton Type="button" Class="listen-rail__section-toggle" aria-expanded="@_playlistsExpanded" OnClick="@(() => _playlistsExpanded = !_playlistsExpanded)">
                            <span>Playlists</span>
                            <MudIcon Icon="@(_playlistsExpanded ? Icons.Material.Outlined.ExpandLess : Icons.Material.Outlined.ExpandMore)" Style="font-size: 18px;" />
                        </AppNativeButton>
                        <AppNativeButton Type="button" Class="listen-rail__add" AriaLabel="Add playlist" OnClick="TogglePlaylistCreateMenu">
                            <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 18px;" />
                        </AppNativeButton>
                        @if (_playlistCreateMenuOpen)
                        {
                            <div class="listen-rail__create-menu">
                                <AppNativeButton Type="button" OnClick='@(() => OpenPlaylistCreateDialog("Playlist"))'>New Playlist</AppNativeButton>
                                <AppNativeButton Type="button" OnClick='@(() => OpenPlaylistCreateDialog("Smart"))'>New Smart Playlist</AppNativeButton>
                            </div>
                        }
                    </div>

                    @if (_playlistsExpanded)
                    {
                        <AppNativeButton Type="button" Class="@($"listen-rail__item @(IsRouteActiveExact(PlaylistsRoute) ? ")" is-active" : null)" OnClick="@(() => NavigateTo(PlaylistsRoute))">
                            <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 18px;" />
                            <span>All Playlists</span>
                        </AppNativeButton>

                        @if (PlaylistCollections.Count == 0)
                        {
                            <div class="listen-playlist-dropzone"
                                 @ondragover:preventDefault="true"
                                 @ondrop="@(() => HandlePlaylistDropAsync())">
                                <div class="listen-playlist-dropzone__title">Drop songs here to create your first playlist</div>
                                <div class="listen-playlist-dropzone__meta">Or open Playlists to start one manually.</div>
                            </div>
                        }
                        else
                        {
                            @foreach (var playlist in PlaylistCollections)
                            {
                                <div class="listen-rail__playlist-row @(playlist.Id == _draggingPlaylistId ? "is-dragging" : null)"
                                     @ondragover:preventDefault="true"
                                     @ondrop="@(() => DropPlaylistReorderAsync(playlist.Id))">
                                    <AppNativeButton Type="button" Class="listen-rail__drag" draggable="true" AriaLabel="@($" Drag to reorder {playlist.Name}")" @ondragstart="@(() => BeginPlaylistReorder(playlist.Id))" @ondragend="EndPlaylistReorder">
                                        <MudIcon Icon="@Icons.Material.Outlined.DragIndicator" Style="font-size: 18px;" />
                                    </AppNativeButton>
                                    <AppNativeButton Type="button" Class="@($"listen-rail__item is-child @(IsRouteActive($")" /listen/music/playlists/{playlist.Id}") ? "is-active" : null)" OnClick="@(() => NavigateTo($" /listen/music/playlists/{playlist.Id}"))" @ondragover:preventDefault="true" @ondrop="@(() => CanAcceptPlaylistItems(playlist) ? HandlePlaylistDropAsync(playlist.Id) : Task.CompletedTask)">
                                        @if (!string.IsNullOrWhiteSpace(playlist.SquareArtworkUrl))
                                        {
                                            <span class="listen-rail__thumb"><img src="@playlist.SquareArtworkUrl" alt="" /></span>
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@PlaylistIconFor(playlist)" Style="font-size: 18px;" />
                                        }
                                        <span>@playlist.Name</span>
                                    </AppNativeButton>
                                    <AppNativeButton Type="button" Class="listen-rail__more" Title="Playlist options" AriaLabel="@($" {playlist.Name} options")" StopPropagation="true" OnClick="@(() => TogglePlaylistActionsMenu(playlist.Id))">
                                        <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Style="font-size: 18px;" />
                                    </AppNativeButton>
                                    @if (_playlistActionsMenuOpen && _playlistActionsCollectionId == playlist.Id)
                                    {
                                        <div class="listen-actions-menu listen-actions-menu--rail">
                                            <AppNativeButton Type="button" OnClick="@(() => OpenPlaylistEditorFromMenuAsync(playlist))">Edit Playlist</AppNativeButton>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    }
                </section>
            }
            else
            {
                <section class="listen-rail__section">
                    <div class="listen-rail__label">Audiobooks</div>
                    @foreach (var item in AudiobookLibraryItems)
                    {
                        <AppNativeButton Type="button" Class="@($"listen-rail__item @(IsRouteActive(item.Route) ? ")" is-active" : null)" OnClick="@(() => NavigateTo(item.Route))">
                            <MudIcon Icon="@item.Icon" Style="font-size: 18px;" />
                            <span>@item.Label</span>
                            @if (!string.IsNullOrWhiteSpace(item.Meta))
                            {
                                <span class="listen-rail__meta">@item.Meta</span>
                            }
                        </AppNativeButton>
                    }
                </section>
            }
        </div>
        </Rail>

        <ChildContent>
        <main class="listen-content">
            <header class="listen-topbar">
                <div class="listen-topbar__identity">
                    <div>
                        <h1>@(IsAudiobooksView ? "Audiobooks" : "Music")</h1>
                    </div>
                </div>

                <div class="listen-mode-switch" role="tablist" aria-label="Listen mode">
                    <AppNativeButton Type="button" role="tab" aria-selected="@IsMusicMode" Class="@($"listen-mode-switch__option @(IsMusicMode ? ")" is-active" : null)" OnClick="OpenMusicModeAsync">
                        Music
                    </AppNativeButton>
                    <AppNativeButton Type="button" role="tab" aria-selected="@IsAudiobooksView" Class="@($"listen-mode-switch__option @(IsAudiobooksView ? ")" is-active" : null)" OnClick="OpenAudiobooksModeAsync">
                        Audiobooks
                    </AppNativeButton>
                </div>
            </header>

            @if (IsMusicHome)
            {
                <section class="listen-home">
                    @if (_musicHomePage.Hero is not null)
                    {
                        <div class="listen-home__hero">
                            <DiscoveryHero Hero="@_musicHomePage.Hero" />
                        </div>
                    }

                    <div class="listen-home__content">
                        @foreach (var shelf in _musicHomePage.Shelves)
                        {
                            <DiscoveryShelf Shelf="@shelf" />
                        }

                        @if (HomePlaylistCards.Count > 0)
                        {
                            <section class="listen-section">
                                <div class="listen-section__header">
                                    <div>
                                        <div class="listen-kicker">Playlists</div>
                                        <h2>Your playlists</h2>
                                        <p class="listen-section__summary">Saved playlists created from your library.</p>
                                    </div>
                                </div>

                                <div class="listen-card-grid">
                                    @foreach (var playlist in HomePlaylistCards)
                                    {
                                        <AppNativeButton Type="button" Class="listen-card listen-card--playlist" OnClick="@(() => NavigateTo(playlist.Route))">
                                            <div class="listen-card__art listen-card__art--playlist">
                                                @if (!string.IsNullOrWhiteSpace(playlist.SquareArtworkUrl))
                                                {
                                                    <img src="@playlist.SquareArtworkUrl" alt="" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 42px;" />
                                                }
                                            </div>
                                            <div class="listen-card__meta listen-card__meta--label">@playlist.Type</div>
                                            <div class="listen-card__title">@playlist.Title</div>
                                            <div class="listen-card__meta">@playlist.Meta</div>
                                            <p>@playlist.Description</p>
                                        </AppNativeButton>
                                    }
                                </div>
                            </section>
                        }
                    </div>
                </section>
            }
            else if (IsAlbumsView)
            {
                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Music</div>
                            <h2>Albums</h2>
                            <p class="listen-section__summary">@Pluralize(FilteredAlbumGroups.Count, "album") ready to browse.</p>
                        </div>
                        <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => PlayTracksAsync(_musicWorks, null, " All Music", true))" Disabled="@(_musicWorks.Count == 0)">Shuffle library</AppNativeButton>
                    </div>

                    <div class="listen-filter-bar">
                        <AppNativeInput Class="listen-filter-input" @bind="_albumSearch" @bind:event="oninput" Placeholder="Search albums or artists" />
                        <AppNativeSelect Class="listen-filter-select" @bind="_albumSort">
                            <option value="recent">Recently added</option>
                            <option value="title">Title</option>
                            <option value="artist">Artist</option>
                            <option value="year">Year</option>
                        </AppNativeSelect>
                        <AppNativeSelect Class="listen-filter-select" @bind="_albumArtistFilter">
                            <option value="all">All artists</option>
                            @foreach (var artist in AlbumArtists)
                            {
                                <option value="@artist">@artist</option>
                            }
                        </AppNativeSelect>
                        <AppNativeSelect Class="listen-filter-select" @bind="_albumGenreFilter">
                            <option value="all">All genres</option>
                            @foreach (var genre in SongGenres)
                            {
                                <option value="@genre">@genre</option>
                            }
                        </AppNativeSelect>
                        <label class="listen-filter-toggle">
                            <AppNativeInput Type="checkbox" Checked="@_albumFavoriteOnly" OnChange="@((ChangeEventArgs args) => _albumFavoriteOnly = args.Value is true)" />
                            <span>Favorites</span>
                        </label>
                        <label class="listen-filter-toggle">
                            <AppNativeInput Type="checkbox" Checked="@_albumArtOnly" OnChange="@((ChangeEventArgs args) => _albumArtOnly = args.Value is true)" />
                            <span>With art</span>
                        </label>
                    </div>

                    @if (FilteredAlbumGroups.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 56px; opacity: 0.22;" />
                                <p>No albums are ready to browse yet.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="listen-card-grid listen-card-grid--albums">
                            @foreach (var album in FilteredAlbumGroups)
                            {
                                <AppNativeButton Type="button" Class="listen-card listen-card--album" OnClick="@(() => OpenAlbum(album))" AriaLabel="@($" Open album {album.DisplayName}")">
                                    <div class="listen-card__art listen-card__art--album">
                                        @if (!string.IsNullOrWhiteSpace(album.CoverUrl ?? album.ArtistPhotoUrl))
                                        {
                                            <img src="@(album.CoverUrl ?? album.ArtistPhotoUrl)"
                                                 alt="@album.DisplayName"
                                                 loading="lazy"
                                                 decoding="async" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 42px;" />
                                        }
                                    </div>
                                    <div class="listen-card__title">@album.DisplayName</div>
                                    <div class="listen-card__meta">@FirstNonBlank(album.Creator, album.Year, Pluralize(album.WorkCount, "track"))</div>
                                </AppNativeButton>
                            }
                        </div>
                    }
                </section>
            }
            else if (IsAlbumDetail && _albumDetail is not null)
            {
                <section class="listen-detail listen-detail--album">
                    <div class="listen-detail__art">
                        @if (!string.IsNullOrWhiteSpace(_albumDetail.CoverUrl))
                        {
                            <img src="@_albumDetail.CoverUrl" alt="@_albumDetail.DisplayName" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 64px;" />
                        }
                    </div>
                    <div class="listen-detail__copy">
                        <div class="listen-kicker">Album</div>
                        <h2>@_albumDetail.DisplayName</h2>
                        <div class="listen-detail__meta">
                            <span>@FirstNonBlank(_albumDetail.Creator, _albumDetail.YearRange, _albumDetail.ReleaseDate)</span>
                            <span>@Pluralize(_albumDetail.TotalItems, "track")</span>
                            @if (!string.IsNullOrWhiteSpace(_albumDetail.TotalDuration))
                            {
                                <span>@_albumDetail.TotalDuration</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_albumDetail.Description))
                        {
                            <p>@_albumDetail.Description</p>
                        }
                        <div class="listen-actions">
                            <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => NavigateTo(AlbumsRoute))">Back to albums</AppNativeButton>
                            <AppNativeButton Type="button" Class="listen-button listen-button--primary" OnClick="@(() => PlayTracksAsync(AlbumTracks, null, _albumDetail.DisplayName))" Disabled="@(AlbumTracks.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                <span>Play</span>
                            </AppNativeButton>
                            <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => PlayTracksAsync(AlbumTracks, null, _albumDetail.DisplayName, true))" Disabled="@(AlbumTracks.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.Shuffle" Size="Size.Small" />
                                <span>Shuffle</span>
                            </AppNativeButton>
                            @if (!string.IsNullOrWhiteSpace(_albumDetail.Creator))
                            {
                                <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => OpenArtist(_albumDetail.Creator!))">Artist</AppNativeButton>
                            }
                        </div>
                    </div>
                </section>

                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Tracks</div>
                            <h2>@Pluralize(AlbumTracks.Count, "track")</h2>
                        </div>
                    </div>
                    <ListenSongTable Tracks="@AlbumTracks"
                                     FavoriteIds="@_favoriteWorkIds"
                                     SourceLabel="@_albumDetail.DisplayName"
                                     AriaLabel="@($"{_albumDetail.DisplayName} songs")"
                                     ShowArtwork="false"
                                     ShowAlbum="false"
                                     ShowGenre="false"
                                     ShowDateAdded="false"
                                     DefaultSortColumn="track"
                                     DefaultSortDescending="false"
                                     OnPlayRequested="PlayTracksAsync"
                                     OnFavoriteToggled="ToggleFavoriteAsync"
                                     OnQueueRequested="QueueTrackAsync"
                                     OnEditRequested="EditTrackAsync"
                                     OnDeleteRequested="DeleteTrackAsync"
                                     OnDragStarted="OnTrackDragStarted"
                                     OnDragEnded="OnTrackDragEnded" />
                </section>
            }
            else if (IsArtistsSurface)
            {
                <section class="listen-artists">
                    <div class="listen-artists__list">
                        <div class="listen-section__header">
                            <div>
                                <div class="listen-kicker">Music</div>
                                <h2>Artists</h2>
                                <p class="listen-section__summary">@Pluralize(FilteredArtistGroups.Count, "artist") in your library.</p>
                            </div>
                        </div>

                        <div class="listen-filter-bar listen-filter-bar--compact">
                            <AppNativeInput Class="listen-filter-input" @bind="_artistSearch" @bind:event="oninput" Placeholder="Search artists" />
                            <AppNativeSelect Class="listen-filter-select" @bind="_artistSort">
                                <option value="name">Artist name</option>
                                <option value="tracks">Most tracks</option>
                            </AppNativeSelect>
                        </div>

                        <div class="listen-artists__list-body">
                            @foreach (var artist in FilteredArtistGroups)
                            {
                                <AppNativeButton Type="button" Class="@($"listen-list-item @(string.Equals(artist.DisplayName, SelectedArtistName, StringComparison.OrdinalIgnoreCase) ? ")" is-active" : null)" OnClick="@(() => SelectArtistAsync(artist.DisplayName))">
                                    <div class="listen-list-item__thumb">
                                        @if (!string.IsNullOrWhiteSpace(artist.ArtistPhotoUrl))
                                        {
                                            <img src="@artist.ArtistPhotoUrl" alt="@artist.DisplayName" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Outlined.PersonOutline" Style="font-size: 20px;" />
                                        }
                                    </div>
                                    <div>
                                        <div class="listen-card__title">@artist.DisplayName</div>
                                        <div class="listen-card__meta">@Pluralize(artist.WorkCount, "track")</div>
                                    </div>
                                </AppNativeButton>
                            }
                        </div>
                    </div>

                    <div class="listen-artists__detail">
                        @if (_artistLoading)
                        {
                            <div class="listen-empty">
                                <div>
                                    <MudProgressCircular Indeterminate="true" Size="Size.Large" Style="color: rgba(255,255,255,0.32);" />
                                    <p>Loading artist details...</p>
                                </div>
                            </div>
                        }
                        else if (_artistDetail is null)
                        {
                            <div class="listen-empty">
                                <div>
                                    <MudIcon Icon="@Icons.Material.Outlined.PersonOutline" Style="font-size: 56px; opacity: 0.22;" />
                                    <p>Choose an artist to view albums.</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <section class="listen-detail listen-detail--artist">
                                <div class="listen-detail__art">
                                    @if (!string.IsNullOrWhiteSpace(_artistDetail.ArtistPhotoUrl))
                                    {
                                        <img src="@_artistDetail.ArtistPhotoUrl" alt="@_artistDetail.DisplayName" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.PersonOutline" Style="font-size: 64px;" />
                                    }
                                </div>
                                <div class="listen-detail__copy">
                                    <div class="listen-kicker">Artist</div>
                                    <h2>@_artistDetail.DisplayName</h2>
                                    <div class="listen-detail__meta">
                                        <span>@Pluralize(ArtistAlbums.Count, "album")</span>
                                        <span>@Pluralize(ArtistTracks.Count, "track")</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(_artistDetail.Description))
                                    {
                                        <p>@_artistDetail.Description</p>
                                    }
                                    <div class="listen-actions">
                                        <AppNativeButton Type="button" Class="listen-button listen-button--primary" OnClick="@(() => PlayTracksAsync(ArtistTracks, null, _artistDetail.DisplayName))" Disabled="@(ArtistTracks.Count == 0)">
                                            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                            <span>Play</span>
                                        </AppNativeButton>
                                        <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => PlayTracksAsync(ArtistTracks, null, _artistDetail.DisplayName, true))" Disabled="@(ArtistTracks.Count == 0)">
                                            <MudIcon Icon="@Icons.Material.Filled.Shuffle" Size="Size.Small" />
                                            <span>Shuffle</span>
                                        </AppNativeButton>
                                        @if (_artistDetail.ArtistPersonId.HasValue)
                                        {
                                            <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => Nav.NavigateTo($" /details/person/{_artistDetail.ArtistPersonId.Value}"))">View artist page</AppNativeButton>
                                        }
                                    </div>
                                </div>
                            </section>

                            @if (ArtistAlbums.Count > 0)
                            {
                                <section class="listen-section">
                                    <div class="listen-section__header">
                                        <div>
                                            <div class="listen-kicker">Albums</div>
                                            <h2>Discography</h2>
                                            <p class="listen-section__summary">Open an album to view and manage its tracks.</p>
                                        </div>
                                    </div>
                                    <div class="listen-card-grid listen-card-grid--albums">
                                        @foreach (var album in ArtistAlbums)
                                        {
                                            var albumRoute = album.AlbumCollectionId.HasValue
                                                ? $"/listen/music/albums/{album.AlbumCollectionId.Value}"
                                                : BuildAlbumDetailRoute(album.SeasonLabel, _artistDetail?.DisplayName);

                                            @if (albumRoute is null)
                                            {
                                                <div class="listen-card listen-card--album" aria-label="Album tile">
                                                    <div class="listen-card__art listen-card__art--album">
                                                        @if (!string.IsNullOrWhiteSpace(album.CoverUrl))
                                                        {
                                                            <img src="@album.CoverUrl"
                                                                 alt="@(album.SeasonLabel ?? $"Album {album.SeasonNumber}")"
                                                                 loading="lazy"
                                                                 decoding="async" />
                                                        }
                                                        else
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 42px;" />
                                                        }
                                                    </div>
                                                    <div class="listen-card__title">@(album.SeasonLabel ?? $"Album {album.SeasonNumber}")</div>
                                                    <div class="listen-card__meta">@FirstNonBlank(album.Year, Pluralize(album.Episodes.Count, "track"))</div>
                                                </div>
                                            }
                                            else
                                            {
                                                <AppNativeButton Type="button" Class="listen-card listen-card--album" OnClick="@(() => NavigateTo(albumRoute))" AriaLabel="@($" Open album {album.SeasonLabel ?? $"Album {album.SeasonNumber}"}")">
                                                    <div class="listen-card__art listen-card__art--album">
                                                        @if (!string.IsNullOrWhiteSpace(album.CoverUrl))
                                                        {
                                                            <img src="@album.CoverUrl"
                                                                 alt="@(album.SeasonLabel ?? $"Album {album.SeasonNumber}")"
                                                                 loading="lazy"
                                                                 decoding="async" />
                                                        }
                                                        else
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 42px;" />
                                                        }
                                                    </div>
                                                    <div class="listen-card__title">@(album.SeasonLabel ?? $"Album {album.SeasonNumber}")</div>
                                                    <div class="listen-card__meta">@FirstNonBlank(album.Year, Pluralize(album.Episodes.Count, "track"))</div>
                                                </AppNativeButton>
                                            }
                                        }
                                    </div>
                                </section>
                            }

                            <section class="listen-section">
                                <div class="listen-section__header">
                                    <div>
                                        <div class="listen-kicker">Songs</div>
                                        <h2>@Pluralize(ArtistTracks.Count, "track")</h2>
                                    </div>
                                </div>

                                @if (ArtistTracks.Count == 0)
                                {
                                    <div class="listen-empty">
                                        <div>
                                            <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Style="font-size: 56px; opacity: 0.22;" />
                                            <p>No songs are ready for this artist yet.</p>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <ListenSongTable Tracks="@ArtistTracks"
                                                     FavoriteIds="@_favoriteWorkIds"
                                                     SourceLabel="@_artistDetail!.DisplayName"
                                                     AriaLabel="@($"{_artistDetail!.DisplayName} songs")"
                                                     ShowArtist="false"
                                                     ShowGenre="false"
                                                     ShowDateAdded="false"
                                                     DefaultSortColumn="album"
                                                     DefaultSortDescending="false"
                                                     OnPlayRequested="PlayTracksAsync"
                                                     OnFavoriteToggled="ToggleFavoriteAsync"
                                                     OnQueueRequested="QueueTrackAsync"
                                                     OnEditRequested="EditTrackAsync"
                                                     OnDeleteRequested="DeleteTrackAsync"
                                                     OnDragStarted="OnTrackDragStarted"
                                                     OnDragEnded="OnTrackDragEnded" />
                                }
                            </section>
                        }
                    </div>
                </section>
            }
            else if (IsSongsView)
            {
                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Music</div>
                            <h2>Songs</h2>
                        </div>
                        <div class="listen-actions">
                            <AppNativeButton Type="button" Class="listen-button listen-button--primary" OnClick='@(() => PlayTracksAsync(FilteredSongs, null, "All Music"))' Disabled="@(FilteredSongs.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                <span>Play</span>
                            </AppNativeButton>
                            <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick='@(() => PlayTracksAsync(FilteredSongs, null, "All Music", true))' Disabled="@(FilteredSongs.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.Shuffle" Size="Size.Small" />
                                <span>Shuffle</span>
                            </AppNativeButton>
                        </div>
                    </div>

                    <div class="listen-filter-bar listen-filter-bar--quick">
                        <AppNativeInput Class="listen-filter-input" @bind="_songSearch" @bind:event="oninput" Placeholder="Search songs, artists, or albums" />
                    </div>

                    @if (FilteredSongs.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Style="font-size: 56px; opacity: 0.22;" />
                                <p>No songs are ready to play yet.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <ListenSongTable Tracks="@FilteredSongs"
                                         FavoriteIds="@_favoriteWorkIds"
                                         SourceLabel="All Music"
                                         AriaLabel="Songs"
                                         OnPlayRequested="PlayTracksAsync"
                                         OnFavoriteToggled="ToggleFavoriteAsync"
                                         OnQueueRequested="QueueTrackAsync"
                                         OnEditRequested="EditTrackAsync"
                                         OnDeleteRequested="DeleteTrackAsync"
                                         OnDragStarted="OnTrackDragStarted"
                                         OnDragEnded="OnTrackDragEnded" />
                    }
                </section>
            }
            else if (IsPlaylistsView)
            {
                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Music</div>
                            <h2>Playlists</h2>
                            <p class="listen-section__summary">Saved playlists created from your library.</p>
                        </div>
                    </div>

                    @if (PlaylistCollections.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 56px; opacity: 0.22;" />
                                <p>No saved playlists yet. Favorites and recently added stay available from Quick access.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="listen-card-grid">
                            @foreach (var playlist in PlaylistCollections)
                            {
                                var card = ToPlaylistCard(playlist);

                                <AppNativeButton Type="button" Class="listen-card listen-card--playlist" OnClick="@(() => NavigateTo(card.Route))">
                                    <div class="listen-card__art listen-card__art--playlist">
                                        @if (!string.IsNullOrWhiteSpace(playlist.SquareArtworkUrl))
                                        {
                                            <img src="@playlist.SquareArtworkUrl" alt="" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 42px;" />
                                        }
                                    </div>
                                    <div class="listen-card__meta listen-card__meta--label">@card.Type</div>
                                    <div class="listen-card__title">@card.Title</div>
                                    <div class="listen-card__meta">@card.Meta</div>
                                    <p>@card.Description</p>
                                </AppNativeButton>
                            }
                        </div>
                    }
                </section>
            }
            else if (IsPlaylistSurface)
            {
                <section class="listen-detail listen-detail--collection">
                    <div class="listen-detail__collage">
                        @if (!string.IsNullOrWhiteSpace(ActivePlaylistCollection?.SquareArtworkUrl))
                        {
                            <img class="listen-detail__custom-art" src="@ActivePlaylistCollection.SquareArtworkUrl" alt="" />
                        }
                        else if (PlaylistCoverUrls.Count == 0)
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 64px;" />
                        }
                        else
                        {
                            @foreach (var cover in PlaylistCoverUrls)
                            {
                                <div class="listen-detail__collage-tile">
                                    <img src="@cover" alt="" />
                                </div>
                            }
                        }
                    </div>
                    <div class="listen-detail__copy">
                        <h2>@ActivePlaylistTitle</h2>
                        <div class="listen-actions">
                            <AppNativeButton Type="button" Class="listen-button listen-button--primary" OnClick="@(() => PlayTracksAsync(ActivePlaylistTracks, null, ActivePlaylistTitle))" Disabled="@(ActivePlaylistTracks.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                <span>Play</span>
                            </AppNativeButton>
                            <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => PlayTracksAsync(ActivePlaylistTracks, null, ActivePlaylistTitle, true))" Disabled="@(ActivePlaylistTracks.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.Shuffle" Size="Size.Small" />
                                <span>Shuffle</span>
                            </AppNativeButton>
                        </div>
                    </div>
                    @if (ActivePlaylistCollection is not null)
                    {
                        <AppNativeButton Type="button" Class="listen-detail__edit" Title="Playlist options" AriaLabel="Playlist options" OnClick="@(() => TogglePlaylistActionsMenu(ActivePlaylistCollection.Id))">
                            <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Size="Size.Small" />
                        </AppNativeButton>
                        @if (_playlistActionsMenuOpen && _playlistActionsCollectionId == ActivePlaylistCollection.Id)
                        {
                            <div class="listen-actions-menu listen-actions-menu--detail">
                                <AppNativeButton Type="button" OnClick="@(() => OpenPlaylistEditorFromMenuAsync())">Edit Playlist</AppNativeButton>
                                <details class="listen-actions-menu__details">
                                    <summary>Columns</summary>
                                    @foreach (var column in PlaylistColumns)
                                    {
                                        <label>
                                            <AppNativeInput Type="checkbox" Checked="@IsPlaylistColumnVisible(column.Key)" OnChange="@(() => TogglePlaylistColumn(column.Key))" />
                                            <span>@column.Label</span>
                                        </label>
                                    }
                                </details>
                            </div>
                        }
                    }
                </section>

                <section class="listen-section">
                    @if (ActivePlaylistTracks.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 56px; opacity: 0.22;" />
                                <p>This playlist is empty.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="listen-playlist-track-list" role="table" aria-label="@($"{ActivePlaylistTitle} songs")">
                            <div class="listen-playlist-track-list__head"
                                 style="@($"grid-template-columns: {PlaylistGridTemplate}")"
                                 role="row"
                                 @onmousemove="@(args => ResizeColumn(args.ClientX))"
                                 @onmouseup="EndColumnResize"
                                 @onmouseleave="EndColumnResize">
                                <span class="listen-playlist-track-list__song-head" role="columnheader">
                                    Song
                                    <span class="listen-column-resizer" @onmousedown:stopPropagation="true" @onmousedown="@((args) => BeginColumnResize("playlist", "song", args.ClientX))"></span>
                                </span>
                                @if (IsPlaylistColumnVisible("favorite"))
                                {
                                    <span class="listen-playlist-track-list__favorite-head" role="columnheader">
                                        Favorite
                                        <span class="listen-column-resizer" @onmousedown:stopPropagation="true" @onmousedown="@((args) => BeginColumnResize("playlist", "favorite", args.ClientX))"></span>
                                    </span>
                                }
                                @if (IsPlaylistColumnVisible("artist"))
                                {
                                    <span role="columnheader">
                                        Artist
                                        <span class="listen-column-resizer" @onmousedown:stopPropagation="true" @onmousedown="@((args) => BeginColumnResize("playlist", "artist", args.ClientX))"></span>
                                    </span>
                                }
                                @if (IsPlaylistColumnVisible("album"))
                                {
                                    <span role="columnheader">
                                        Album
                                        <span class="listen-column-resizer" @onmousedown:stopPropagation="true" @onmousedown="@((args) => BeginColumnResize("playlist", "album", args.ClientX))"></span>
                                    </span>
                                }
                                @if (IsPlaylistColumnVisible("time"))
                                {
                                    <span role="columnheader">
                                        Time
                                        <span class="listen-column-resizer" @onmousedown:stopPropagation="true" @onmousedown="@((args) => BeginColumnResize("playlist", "time", args.ClientX))"></span>
                                    </span>
                                }
                                <span role="columnheader" class="listen-playlist-track-list__actions-label">Queue / Edit / Remove</span>
                            </div>
                            @foreach (var row in ActivePlaylistTrackRows)
                            {
                                var track = row.Work;
                                var item = row.Item;
                                <div class="listen-playlist-track-row @(item is not null && item.Id == _draggingPlaylistTrackItemId ? "is-dragging" : null) @(item is not null && item.Id == _playlistTrackDropTargetItemId && !_playlistTrackDropAfter ? "is-drop-before" : null)"
                                     style="@($"grid-template-columns: {PlaylistGridTemplate}")"
                                     role="row"
                                     draggable="true"
                                     @ondragstart="@(() => item is null ? Task.CompletedTask : BeginPlaylistTrackReorderAsync(item.Id))"
                                     @ondragend="EndPlaylistTrackReorder"
                                     @ondblclick="@(() => PlayTracksAsync(ActivePlaylistTracks, track.Id, ActivePlaylistTitle))"
                                     @ondragover:preventDefault="true"
                                     @ondragover="@(() => item is null ? Task.CompletedTask : SetPlaylistTrackDropTargetAsync(item.Id, false))"
                                     @ondrop="@(() => item is null ? Task.CompletedTask : DropPlaylistTrackReorderAsync(item.Id))">
                                    <div class="listen-playlist-track-row__song listen-playlist-track-row__song--no-handle" role="cell">
                                        <div class="listen-playlist-track-row__art">
                                            @if (!string.IsNullOrWhiteSpace(track.CoverUrl))
                                            {
                                                <img src="@track.CoverUrl" alt="" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Size="Size.Small" />
                                            }
                                            <AppNativeButton Type="button" Class="listen-playlist-track-row__art-play" Title="Play song" AriaLabel="@($" Play {track.Title}")" StopPropagation="true" OnClick="@(() => PlayTracksAsync(ActivePlaylistTracks, track.Id, ActivePlaylistTitle))">
                                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                            </AppNativeButton>
                                        </div>
                                        <span class="listen-playlist-track-row__title">@track.Title</span>
                                    </div>
                                    @if (IsPlaylistColumnVisible("favorite"))
                                    {
                                        <div class="listen-playlist-track-row__favorite" role="cell">
                                            <AppNativeButton Type="button" Class="@($"listen-track-grid__favorite @(_favoriteWorkIds.Contains(track.Id) ? ")" is-active" : null)" AriaLabel="Toggle favorite" Title="Toggle favorite" StopPropagation="true" OnClick="@(() => ToggleFavoriteAsync(track))">
                                                <MudIcon Icon="@(_favoriteWorkIds.Contains(track.Id) ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)" Size="Size.Small" />
                                            </AppNativeButton>
                                        </div>
                                    }
                                    @if (IsPlaylistColumnVisible("artist"))
                                    {
                                        <span class="listen-playlist-track-row__meta" role="cell">@FirstNonBlank(track.Artist, track.Author)</span>
                                    }
                                    @if (IsPlaylistColumnVisible("album"))
                                    {
                                        <span class="listen-playlist-track-row__meta" role="cell">@FirstNonBlank(track.Album)</span>
                                    }
                                    @if (IsPlaylistColumnVisible("time"))
                                    {
                                        <span class="listen-playlist-track-row__time" role="cell">@GetTrackDuration(track)</span>
                                    }
                                    <div class="listen-playlist-track-row__actions" role="cell">
                                        <AppNativeButton Type="button" Class="listen-icon-button" Title="Add to queue" AriaLabel="@($" Add {track.Title} to queue")" StopPropagation="true" OnClick="@(() => QueueTrackAsync(track))">
                                            <MudIcon Icon="@Icons.Material.Outlined.PlaylistAdd" Size="Size.Small" />
                                        </AppNativeButton>
                                        <AppNativeButton Type="button" Class="listen-icon-button" Title="Edit song" AriaLabel="@($" Edit {track.Title}")" StopPropagation="true" OnClick="@(() => EditTrackAsync(track))">
                                            <MudIcon Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" />
                                        </AppNativeButton>
                                        <AppNativeButton Type="button" Class="listen-icon-button listen-icon-button--danger" Title="Remove from playlist" AriaLabel="@($" Remove {track.Title} from playlist")" Disabled="@(item is null)" StopPropagation="true" OnClick="@(() => item is null ? Task.CompletedTask : RemovePlaylistTrackAsync(item.Id))">
                                            <MudIcon Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" />
                                        </AppNativeButton>
                                    </div>
                                </div>
                            }
                            <div class="listen-playlist-track-end-zone @(_draggingPlaylistTrackItemId.HasValue ? "is-active" : null)"
                                 @ondragover:preventDefault="true"
                                 @ondragover="@(() => SetPlaylistTrackEndDropTargetAsync())"
                                 @ondrop="DropPlaylistTrackAtEndAsync"></div>
                        </div>
                    }
                </section>
            }
            else if (IsAudiobooksView)
            {
                <MediaBrowseShell Tab="audiobooks"
                                  Preset="@AudiobookBrowsePreset" />
            }
        </main>
        </ChildContent>
    </SidebarPageShell>
}
