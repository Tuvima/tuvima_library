@page "/listen"
@page "/listen/music"
@page "/listen/music/{Section}"
@page "/listen/music/albums/{CollectionId:guid}"
@page "/listen/music/albums/by-name/{AlbumKey}"
@page "/listen/music/artists/{ArtistKey}"
@page "/listen/music/playlists/{CollectionId:guid}"
@page "/listen/music/playlists/system/{PlaylistKey}"
@page "/listen/audiobooks"
@page "/listen/audiobook/{WorkId:guid}"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Components.Discovery
@using MediaEngine.Web.Components.Listen
@using MediaEngine.Web.Models.ViewDTOs
@using MudBlazor

@namespace MediaEngine.Web.Components.Pages

<PageTitle>@PageTitleText</PageTitle>

@if (_redirecting || _loading)
{
    <div class="listen-state">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Style="color: rgba(255,255,255,0.32);" />
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="listen-state listen-state--error">
        <MudIcon Icon="@Icons.Material.Outlined.LibraryMusic" Style="font-size: 56px; opacity: 0.22;" />
        <h3>Listen could not load</h3>
        <p>@_error</p>
        <button type="button" class="listen-button listen-button--secondary" @onclick="ReloadAsync">Try again</button>
    </div>
}
else
{
    <SidebarPageShell Class="listen-page">
        <Rail>
        <div class="listen-rail">
            @if (IsMusicMode)
            {
                <section class="listen-rail__section">
                    <div class="listen-rail__label">Music</div>
                    @foreach (var item in MusicLibraryItems)
                    {
                        <button type="button" class="listen-rail__item @(IsRouteActive(item.Route) ? "is-active" : null)" @onclick="@(() => NavigateTo(item.Route))">
                            <MudIcon Icon="@item.Icon" Style="font-size: 18px;" />
                            <span>@item.Label</span>
                            <span class="listen-rail__meta">@item.Meta</span>
                        </button>
                    }
                </section>

                <section class="listen-rail__section">
                    <div class="listen-rail__label">Quick access</div>
                    @foreach (var item in QuickAccessItems)
                    {
                        <button type="button" class="listen-rail__item @(IsRouteActive(item.Route) ? "is-active" : null)" @onclick="@(() => NavigateTo(item.Route))">
                            <MudIcon Icon="@item.Icon" Style="font-size: 18px;" />
                            <span>@item.Label</span>
                            @if (!string.IsNullOrWhiteSpace(item.Meta))
                            {
                                <span class="listen-rail__meta">@item.Meta</span>
                            }
                        </button>
                    }
                </section>

                <section class="listen-rail__section">
                    <div class="listen-rail__section-heading">
                        <button type="button"
                                class="listen-rail__section-toggle"
                                aria-expanded="@_playlistsExpanded"
                                @onclick="@(() => _playlistsExpanded = !_playlistsExpanded)">
                            <span>Playlists</span>
                            <MudIcon Icon="@(_playlistsExpanded ? Icons.Material.Outlined.ExpandLess : Icons.Material.Outlined.ExpandMore)" Style="font-size: 18px;" />
                        </button>
                        <button type="button"
                                class="listen-rail__add"
                                aria-label="Add playlist"
                                @onclick="TogglePlaylistCreateMenu">
                            <MudIcon Icon="@Icons.Material.Outlined.Add" Style="font-size: 18px;" />
                        </button>
                        @if (_playlistCreateMenuOpen)
                        {
                            <div class="listen-rail__create-menu">
                                <button type="button" @onclick='@(() => OpenPlaylistCreateDialog("Playlist"))'>New Playlist</button>
                                <button type="button" @onclick='@(() => OpenPlaylistCreateDialog("Smart"))'>New Smart Playlist</button>
                            </div>
                        }
                    </div>

                    @if (_playlistsExpanded)
                    {
                        <button type="button" class="listen-rail__item @(IsRouteActiveExact(PlaylistsRoute) ? "is-active" : null)" @onclick="@(() => NavigateTo(PlaylistsRoute))">
                            <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 18px;" />
                            <span>All Playlists</span>
                        </button>

                        @if (PlaylistCollections.Count == 0)
                        {
                            <div class="listen-playlist-dropzone"
                                 @ondragover:preventDefault="true"
                                 @ondrop="@(() => HandlePlaylistDropAsync())">
                                <div class="listen-playlist-dropzone__title">Drop songs here to create your first playlist</div>
                                <div class="listen-playlist-dropzone__meta">Or open Playlists to start one manually.</div>
                            </div>
                        }
                        else
                        {
                            @foreach (var playlist in PlaylistCollections)
                            {
                                <div class="listen-rail__playlist-row @(playlist.Id == _draggingPlaylistId ? "is-dragging" : null)"
                                     @ondragover:preventDefault="true"
                                     @ondrop="@(() => DropPlaylistReorderAsync(playlist.Id))">
                                    <button type="button"
                                            class="listen-rail__drag"
                                            draggable="true"
                                            aria-label="@($"Drag to reorder {playlist.Name}")"
                                            @ondragstart="@(() => BeginPlaylistReorder(playlist.Id))"
                                            @ondragend="EndPlaylistReorder">
                                        <MudIcon Icon="@Icons.Material.Outlined.DragIndicator" Style="font-size: 18px;" />
                                    </button>
                                    <button type="button"
                                            class="listen-rail__item is-child @(IsRouteActive($"/listen/music/playlists/{playlist.Id}") ? "is-active" : null)"
                                            @onclick="@(() => NavigateTo($"/listen/music/playlists/{playlist.Id}"))"
                                            @ondragover:preventDefault="true"
                                            @ondrop="@(() => CanAcceptPlaylistItems(playlist) ? HandlePlaylistDropAsync(playlist.Id) : Task.CompletedTask)">
                                        @if (!string.IsNullOrWhiteSpace(playlist.SquareArtworkUrl))
                                        {
                                            <span class="listen-rail__thumb"><img src="@playlist.SquareArtworkUrl" alt="" /></span>
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@PlaylistIconFor(playlist)" Style="font-size: 18px;" />
                                        }
                                        <span>@playlist.Name</span>
                                    </button>
                                </div>
                            }
                        }
                    }
                </section>
            }
            else
            {
                <section class="listen-rail__section">
                    <div class="listen-rail__label">Audiobooks</div>
                    @foreach (var item in AudiobookLibraryItems)
                    {
                        <button type="button" class="listen-rail__item @(IsRouteActive(item.Route) ? "is-active" : null)" @onclick="@(() => NavigateTo(item.Route))">
                            <MudIcon Icon="@item.Icon" Style="font-size: 18px;" />
                            <span>@item.Label</span>
                            @if (!string.IsNullOrWhiteSpace(item.Meta))
                            {
                                <span class="listen-rail__meta">@item.Meta</span>
                            }
                        </button>
                    }
                </section>
            }
        </div>
        </Rail>

        <ChildContent>
        <main class="listen-content">
            <header class="listen-topbar">
                <div class="listen-topbar__identity">
                    <div>
                        <h1>@(IsAudiobooksView ? "Audiobooks" : "Music")</h1>
                    </div>
                </div>

                <div class="listen-mode-switch" role="tablist" aria-label="Listen mode">
                    <button type="button"
                            role="tab"
                            aria-selected="@IsMusicMode"
                            class="listen-mode-switch__option @(IsMusicMode ? "is-active" : null)"
                            @onclick="OpenMusicModeAsync">
                        Music
                    </button>
                    <button type="button"
                            role="tab"
                            aria-selected="@IsAudiobooksView"
                            class="listen-mode-switch__option @(IsAudiobooksView ? "is-active" : null)"
                            @onclick="OpenAudiobooksModeAsync">
                        Audiobooks
                    </button>
                </div>
            </header>

            @if (IsMusicHome)
            {
                <section class="listen-home">
                    @if (_musicHomePage.Hero is not null)
                    {
                        <div class="listen-home__hero">
                            <DiscoveryHero Hero="@_musicHomePage.Hero" />
                        </div>
                    }

                    <div class="listen-home__content">
                        @foreach (var shelf in _musicHomePage.Shelves)
                        {
                            <DiscoveryShelf Shelf="@shelf" />
                        }

                        @if (HomePlaylistCards.Count > 0)
                        {
                            <section class="listen-section">
                                <div class="listen-section__header">
                                    <div>
                                        <div class="listen-kicker">Playlists</div>
                                        <h2>Your playlists</h2>
                                        <p class="listen-section__summary">Saved playlists created from your library.</p>
                                    </div>
                                </div>

                                <div class="listen-card-grid">
                                    @foreach (var playlist in HomePlaylistCards)
                                    {
                                        <button type="button"
                                                class="listen-card listen-card--playlist"
                                                @onclick="@(() => NavigateTo(playlist.Route))">
                                            <div class="listen-card__art listen-card__art--playlist">
                                                @if (!string.IsNullOrWhiteSpace(playlist.SquareArtworkUrl))
                                                {
                                                    <img src="@playlist.SquareArtworkUrl" alt="" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 42px;" />
                                                }
                                            </div>
                                            <div class="listen-card__meta listen-card__meta--label">@playlist.Type</div>
                                            <div class="listen-card__title">@playlist.Title</div>
                                            <div class="listen-card__meta">@playlist.Meta</div>
                                            <p>@playlist.Description</p>
                                        </button>
                                    }
                                </div>
                            </section>
                        }
                    </div>
                </section>
            }
            else if (IsAlbumsView)
            {
                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Music</div>
                            <h2>Albums</h2>
                            <p class="listen-section__summary">@Pluralize(FilteredAlbumGroups.Count, "album") ready to browse.</p>
                        </div>
                        <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => PlayTracksAsync(_musicWorks, null, "All Music", true))" disabled="@(_musicWorks.Count == 0)">Shuffle library</button>
                    </div>

                    <div class="listen-filter-bar">
                        <input class="listen-filter-input" @bind="_albumSearch" @bind:event="oninput" placeholder="Search albums or artists" />
                        <select class="listen-filter-select" @bind="_albumSort">
                            <option value="recent">Recently added</option>
                            <option value="title">Title</option>
                            <option value="artist">Artist</option>
                            <option value="year">Year</option>
                        </select>
                        <select class="listen-filter-select" @bind="_albumArtistFilter">
                            <option value="all">All artists</option>
                            @foreach (var artist in AlbumArtists)
                            {
                                <option value="@artist">@artist</option>
                            }
                        </select>
                        <select class="listen-filter-select" @bind="_albumGenreFilter">
                            <option value="all">All genres</option>
                            @foreach (var genre in SongGenres)
                            {
                                <option value="@genre">@genre</option>
                            }
                        </select>
                        <label class="listen-filter-toggle">
                            <input type="checkbox" @bind="_albumFavoriteOnly" />
                            <span>Favorites</span>
                        </label>
                        <label class="listen-filter-toggle">
                            <input type="checkbox" @bind="_albumArtOnly" />
                            <span>With art</span>
                        </label>
                    </div>

                    @if (FilteredAlbumGroups.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 56px; opacity: 0.22;" />
                                <p>No albums are ready to browse yet.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="listen-card-grid listen-card-grid--albums">
                            @foreach (var album in FilteredAlbumGroups)
                            {
                                <button type="button"
                                        class="listen-card listen-card--album"
                                        @onclick="@(() => OpenAlbum(album))"
                                        aria-label="@($"Open album {album.DisplayName}")">
                                    <div class="listen-card__art listen-card__art--album">
                                        @if (!string.IsNullOrWhiteSpace(album.CoverUrl ?? album.ArtistPhotoUrl))
                                        {
                                            <img src="@(album.CoverUrl ?? album.ArtistPhotoUrl)"
                                                 alt="@album.DisplayName"
                                                 loading="lazy"
                                                 decoding="async" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 42px;" />
                                        }
                                    </div>
                                    <div class="listen-card__title">@album.DisplayName</div>
                                    <div class="listen-card__meta">@FirstNonBlank(album.Creator, album.Year, Pluralize(album.WorkCount, "track"))</div>
                                </button>
                            }
                        </div>
                    }
                </section>
            }
            else if (IsAlbumDetail && _albumDetail is not null)
            {
                <section class="listen-detail listen-detail--album">
                    <div class="listen-detail__art">
                        @if (!string.IsNullOrWhiteSpace(_albumDetail.CoverUrl))
                        {
                            <img src="@_albumDetail.CoverUrl" alt="@_albumDetail.DisplayName" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 64px;" />
                        }
                    </div>
                    <div class="listen-detail__copy">
                        <div class="listen-kicker">Album</div>
                        <h2>@_albumDetail.DisplayName</h2>
                        <div class="listen-detail__meta">
                            <span>@FirstNonBlank(_albumDetail.Creator, _albumDetail.YearRange, _albumDetail.ReleaseDate)</span>
                            <span>@Pluralize(_albumDetail.TotalItems, "track")</span>
                            @if (!string.IsNullOrWhiteSpace(_albumDetail.TotalDuration))
                            {
                                <span>@_albumDetail.TotalDuration</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_albumDetail.Description))
                        {
                            <p>@_albumDetail.Description</p>
                        }
                        <div class="listen-actions">
                            <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => NavigateTo(AlbumsRoute))">Back to albums</button>
                            <button type="button" class="listen-button listen-button--primary" @onclick="@(() => PlayTracksAsync(AlbumTracks, null, _albumDetail.DisplayName))" disabled="@(AlbumTracks.Count == 0)">Play</button>
                            <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => PlayTracksAsync(AlbumTracks, null, _albumDetail.DisplayName, true))" disabled="@(AlbumTracks.Count == 0)">Shuffle</button>
                            @if (!string.IsNullOrWhiteSpace(_albumDetail.Creator))
                            {
                                <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => OpenArtist(_albumDetail.Creator!))">Artist</button>
                            }
                        </div>
                    </div>
                </section>

                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Tracks</div>
                            <h2>@Pluralize(AlbumTracks.Count, "track")</h2>
                        </div>
                    </div>
                    <div class="listen-track-toolbar">
                        <div class="listen-track-toolbar__status">@TrackSelectionStatusText</div>
                        <div class="listen-track-toolbar__actions">
                            <button type="button" class="listen-button listen-button--secondary" @onclick="PlaySelectedTracksAsync" disabled="@(!HasTrackSelection)">Play</button>
                            <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => QueueSelectedTracksAsync(true))" disabled="@(!HasTrackSelection)">Play next</button>
                            <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => QueueSelectedTracksAsync(false))" disabled="@(!HasTrackSelection)">Add to queue</button>
                            @if (HasTrackSelection)
                            {
                                <details class="listen-row-menu">
                                    <summary class="listen-row-menu__summary">Add to playlist</summary>
                                    <div class="listen-row-menu__panel">
                                        <button type="button" class="listen-row-menu__action" @onclick="@(() => AddSelectedTracksToPlaylistAsync())">Create new playlist</button>
                                        @foreach (var playlist in PlaylistCollections)
                                        {
                                            <button type="button" class="listen-row-menu__action" @onclick="@(() => AddSelectedTracksToPlaylistAsync(playlist.Id))">Add to @playlist.Name</button>
                                        }
                                    </div>
                                </details>
                            }
                            else
                            {
                                <button type="button" class="listen-button listen-button--secondary" disabled="true">Add to playlist</button>
                            }
                            <button type="button" class="listen-button listen-button--secondary" @onclick="EditSelectedTrackAsync" disabled="@(!HasTrackSelection)">Edit</button>
                            <button type="button" class="listen-button listen-button--secondary" @onclick="DeleteSelectedTracksAsync" disabled="@(!HasTrackSelection)">Delete</button>
                            <button type="button" class="listen-button listen-button--secondary" @onclick="OpenTrackColumnsAsync">Columns</button>
                        </div>
                    </div>

                    <ListenTrackDataGrid @ref="_trackGrid"
                                         Items="@BuildTrackGridItems(AlbumTracks)"
                                         Loading="@_loading"
                                         SelectedIds="@_selectedTrackIds"
                                         SelectedIdsChanged="OnTrackSelectionChanged"
                                         OnArtistClicked="OnTrackArtistClicked"
                                         OnFavoriteToggled="OnTrackFavoriteToggled"
                                         OnRowActivated="OnTrackRowActivated"
                                         OnRowContextRequested="OnTrackContextRequested"
                                         OnRowDragStarted="OnTrackDragStarted"
                                         OnRowDragEnded="OnTrackDragEnded"
                                         ViewKey="listen-tracks" />
                </section>
            }
            else if (IsArtistsSurface)
            {
                <section class="listen-artists">
                    <div class="listen-artists__list">
                        <div class="listen-section__header">
                            <div>
                                <div class="listen-kicker">Music</div>
                                <h2>Artists</h2>
                                <p class="listen-section__summary">@Pluralize(FilteredArtistGroups.Count, "artist") in your library.</p>
                            </div>
                        </div>

                        <div class="listen-filter-bar listen-filter-bar--compact">
                            <input class="listen-filter-input" @bind="_artistSearch" @bind:event="oninput" placeholder="Search artists" />
                            <select class="listen-filter-select" @bind="_artistSort">
                                <option value="name">Artist name</option>
                                <option value="tracks">Most tracks</option>
                            </select>
                        </div>

                        <div class="listen-artists__list-body">
                            @foreach (var artist in FilteredArtistGroups)
                            {
                                <button type="button"
                                        class="listen-list-item @(string.Equals(artist.DisplayName, SelectedArtistName, StringComparison.OrdinalIgnoreCase) ? "is-active" : null)"
                                        @onclick="@(() => SelectArtistAsync(artist.DisplayName))">
                                    <div class="listen-list-item__thumb">
                                        @if (!string.IsNullOrWhiteSpace(artist.ArtistPhotoUrl))
                                        {
                                            <img src="@artist.ArtistPhotoUrl" alt="@artist.DisplayName" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Outlined.PersonOutline" Style="font-size: 20px;" />
                                        }
                                    </div>
                                    <div>
                                        <div class="listen-card__title">@artist.DisplayName</div>
                                        <div class="listen-card__meta">@Pluralize(artist.WorkCount, "track")</div>
                                    </div>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="listen-artists__detail">
                        @if (_artistLoading)
                        {
                            <div class="listen-empty">
                                <div>
                                    <MudProgressCircular Indeterminate="true" Size="Size.Large" Style="color: rgba(255,255,255,0.32);" />
                                    <p>Loading artist details...</p>
                                </div>
                            </div>
                        }
                        else if (_artistDetail is null)
                        {
                            <div class="listen-empty">
                                <div>
                                    <MudIcon Icon="@Icons.Material.Outlined.PersonOutline" Style="font-size: 56px; opacity: 0.22;" />
                                    <p>Choose an artist to view albums.</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <section class="listen-detail listen-detail--artist">
                                <div class="listen-detail__art">
                                    @if (!string.IsNullOrWhiteSpace(_artistDetail.ArtistPhotoUrl))
                                    {
                                        <img src="@_artistDetail.ArtistPhotoUrl" alt="@_artistDetail.DisplayName" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.PersonOutline" Style="font-size: 64px;" />
                                    }
                                </div>
                                <div class="listen-detail__copy">
                                    <div class="listen-kicker">Artist</div>
                                    <h2>@_artistDetail.DisplayName</h2>
                                    <div class="listen-detail__meta">
                                        <span>@Pluralize(ArtistAlbums.Count, "album")</span>
                                        <span>@Pluralize(ArtistTracks.Count, "track")</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(_artistDetail.Description))
                                    {
                                        <p>@_artistDetail.Description</p>
                                    }
                                    <div class="listen-actions">
                                        <button type="button" class="listen-button listen-button--primary" @onclick="@(() => PlayTracksAsync(ArtistTracks, null, _artistDetail.DisplayName))" disabled="@(ArtistTracks.Count == 0)">Play</button>
                                        <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => PlayTracksAsync(ArtistTracks, null, _artistDetail.DisplayName, true))" disabled="@(ArtistTracks.Count == 0)">Shuffle</button>
                                        @if (_artistDetail.ArtistPersonId.HasValue)
                                        {
                                            <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => Nav.NavigateTo($"/person/{_artistDetail.ArtistPersonId.Value}"))">View artist page</button>
                                        }
                                    </div>
                                </div>
                            </section>

                            @if (ArtistAlbums.Count > 0)
                            {
                                <section class="listen-section">
                                    <div class="listen-section__header">
                                        <div>
                                            <div class="listen-kicker">Albums</div>
                                            <h2>Discography</h2>
                                            <p class="listen-section__summary">Open an album to view and manage its tracks.</p>
                                        </div>
                                    </div>
                                    <div class="listen-card-grid listen-card-grid--albums">
                                        @foreach (var album in ArtistAlbums)
                                        {
                                            var albumRoute = album.AlbumCollectionId.HasValue
                                                ? $"/listen/music/albums/{album.AlbumCollectionId.Value}"
                                                : BuildAlbumDetailRoute(album.SeasonLabel, _artistDetail?.DisplayName);

                                            @if (albumRoute is null)
                                            {
                                                <div class="listen-card listen-card--album" aria-label="Album tile">
                                                    <div class="listen-card__art listen-card__art--album">
                                                        @if (!string.IsNullOrWhiteSpace(album.CoverUrl))
                                                        {
                                                            <img src="@album.CoverUrl"
                                                                 alt="@(album.SeasonLabel ?? $"Album {album.SeasonNumber}")"
                                                                 loading="lazy"
                                                                 decoding="async" />
                                                        }
                                                        else
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 42px;" />
                                                        }
                                                    </div>
                                                    <div class="listen-card__title">@(album.SeasonLabel ?? $"Album {album.SeasonNumber}")</div>
                                                    <div class="listen-card__meta">@FirstNonBlank(album.Year, Pluralize(album.Episodes.Count, "track"))</div>
                                                </div>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="listen-card listen-card--album"
                                                        @onclick="@(() => NavigateTo(albumRoute))"
                                                        aria-label="@($"Open album {album.SeasonLabel ?? $"Album {album.SeasonNumber}"}")">
                                                    <div class="listen-card__art listen-card__art--album">
                                                        @if (!string.IsNullOrWhiteSpace(album.CoverUrl))
                                                        {
                                                            <img src="@album.CoverUrl"
                                                                 alt="@(album.SeasonLabel ?? $"Album {album.SeasonNumber}")"
                                                                 loading="lazy"
                                                                 decoding="async" />
                                                        }
                                                        else
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 42px;" />
                                                        }
                                                    </div>
                                                    <div class="listen-card__title">@(album.SeasonLabel ?? $"Album {album.SeasonNumber}")</div>
                                                    <div class="listen-card__meta">@FirstNonBlank(album.Year, Pluralize(album.Episodes.Count, "track"))</div>
                                                </button>
                                            }
                                        }
                                    </div>
                                </section>
                            }
                        }
                    </div>
                </section>
            }
            else if (IsSongsView)
            {
                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Music</div>
                            <h2>Songs</h2>
                            <p class="listen-section__summary">@Pluralize(FilteredSongs.Count, "song") in your library.</p>
                        </div>
                        <div class="listen-actions">
                            <button type="button" class="listen-button listen-button--primary" @onclick="@(() => PlayTracksAsync(FilteredSongs, null, "All Music"))" disabled="@(FilteredSongs.Count == 0)">Play all</button>
                            <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => PlayTracksAsync(FilteredSongs, null, "All Music", true))" disabled="@(FilteredSongs.Count == 0)">Shuffle</button>
                        </div>
                    </div>

                    <div class="listen-filter-bar">
                        <input class="listen-filter-input" @bind="_songSearch" @bind:event="oninput" placeholder="Search songs, artists, or albums" />
                        <select class="listen-filter-select" @bind="_songArtistFilter">
                            <option value="all">All artists</option>
                            @foreach (var artist in SongArtists)
                            {
                                <option value="@artist">@artist</option>
                            }
                        </select>
                        <select class="listen-filter-select" @bind="_songAlbumFilter">
                            <option value="all">All albums</option>
                            @foreach (var album in SongAlbums)
                            {
                                <option value="@album">@album</option>
                            }
                        </select>
                        <select class="listen-filter-select" @bind="_songGenreFilter">
                            <option value="all">All genres</option>
                            @foreach (var genre in SongGenres)
                            {
                                <option value="@genre">@genre</option>
                            }
                        </select>
                        <select class="listen-filter-select" @bind="_songFavoriteFilter">
                            <option value="all">All songs</option>
                            <option value="favorites">Favorites</option>
                            <option value="nonfavorites">Non-favorites</option>
                        </select>
                        <select class="listen-filter-select" @bind="_songDateAddedFilter">
                            <option value="all">Any date added</option>
                            <option value="7">Last 7 days</option>
                            <option value="30">Last 30 days</option>
                            <option value="90">Last 90 days</option>
                        </select>
                    </div>

                    @if (FilteredSongs.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Style="font-size: 56px; opacity: 0.22;" />
                                <p>No songs are ready to play yet.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="listen-track-toolbar">
                            <div class="listen-track-toolbar__status">@TrackSelectionStatusText</div>
                            <div class="listen-track-toolbar__actions">
                                <button type="button" class="listen-button listen-button--secondary" @onclick="PlaySelectedTracksAsync" disabled="@(!HasTrackSelection)">Play</button>
                                <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => QueueSelectedTracksAsync(true))" disabled="@(!HasTrackSelection)">Play next</button>
                                <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => QueueSelectedTracksAsync(false))" disabled="@(!HasTrackSelection)">Add to queue</button>
                                @if (HasTrackSelection)
                                {
                                    <details class="listen-row-menu">
                                        <summary class="listen-row-menu__summary">Add to playlist</summary>
                                        <div class="listen-row-menu__panel">
                                            <button type="button" class="listen-row-menu__action" @onclick="@(() => AddSelectedTracksToPlaylistAsync())">Create new playlist</button>
                                            @foreach (var playlist in ManualPlaylistCollections)
                                            {
                                                <button type="button" class="listen-row-menu__action" @onclick="@(() => AddSelectedTracksToPlaylistAsync(playlist.Id))">Add to @playlist.Name</button>
                                            }
                                        </div>
                                    </details>
                                }
                                else
                                {
                                    <button type="button" class="listen-button listen-button--secondary" disabled="true">Add to playlist</button>
                                }
                                <button type="button" class="listen-button listen-button--secondary" @onclick="EditSelectedTrackAsync" disabled="@(!HasTrackSelection)">Edit</button>
                                <button type="button" class="listen-button listen-button--secondary" @onclick="DeleteSelectedTracksAsync" disabled="@(!HasTrackSelection)">Delete</button>
                                <button type="button" class="listen-button listen-button--secondary" @onclick="OpenTrackColumnsAsync">Columns</button>
                            </div>
                        </div>

                        <ListenTrackDataGrid @ref="_trackGrid"
                                             Items="@BuildTrackGridItems(FilteredSongs)"
                                             Loading="@_loading"
                                             SelectedIds="@_selectedTrackIds"
                                             SelectedIdsChanged="OnTrackSelectionChanged"
                                             OnArtistClicked="OnTrackArtistClicked"
                                             OnFavoriteToggled="OnTrackFavoriteToggled"
                                             OnRowActivated="OnTrackRowActivated"
                                             OnRowContextRequested="OnTrackContextRequested"
                                             OnRowDragStarted="OnTrackDragStarted"
                                             OnRowDragEnded="OnTrackDragEnded"
                                             ViewKey="listen-tracks" />
                    }
                </section>
            }
            else if (IsPlaylistsView)
            {
                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Music</div>
                            <h2>Playlists</h2>
                            <p class="listen-section__summary">Saved playlists created from your library.</p>
                        </div>
                    </div>

                    @if (PlaylistCollections.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 56px; opacity: 0.22;" />
                                <p>No saved playlists yet. Favorites and recently added stay available from Quick access.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="listen-card-grid">
                            @foreach (var playlist in PlaylistCollections)
                            {
                                var card = ToPlaylistCard(playlist);

                                <button type="button"
                                        class="listen-card listen-card--playlist"
                                        @onclick="@(() => NavigateTo(card.Route))">
                                    <div class="listen-card__art listen-card__art--playlist">
                                        @if (!string.IsNullOrWhiteSpace(playlist.SquareArtworkUrl))
                                        {
                                            <img src="@playlist.SquareArtworkUrl" alt="" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 42px;" />
                                        }
                                    </div>
                                    <div class="listen-card__meta listen-card__meta--label">@card.Type</div>
                                    <div class="listen-card__title">@card.Title</div>
                                    <div class="listen-card__meta">@card.Meta</div>
                                    <p>@card.Description</p>
                                </button>
                            }
                        </div>
                    }
                </section>
            }
            else if (IsPlaylistSurface)
            {
                <section class="listen-detail listen-detail--collection">
                    <div class="listen-detail__collage">
                        @if (!string.IsNullOrWhiteSpace(ActivePlaylistCollection?.SquareArtworkUrl))
                        {
                            <img class="listen-detail__custom-art" src="@ActivePlaylistCollection.SquareArtworkUrl" alt="" />
                        }
                        else if (PlaylistCoverUrls.Count == 0)
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 64px;" />
                        }
                        else
                        {
                            @foreach (var cover in PlaylistCoverUrls)
                            {
                                <div class="listen-detail__collage-tile">
                                    <img src="@cover" alt="" />
                                </div>
                            }
                        }
                    </div>
                    <div class="listen-detail__copy">
                        <div class="listen-kicker">@ActivePlaylistTypeLabel</div>
                        <h2>@ActivePlaylistTitle</h2>
                        <div class="listen-detail__meta">
                            <span>@Pluralize(ActivePlaylistTracks.Count, "track")</span>
                            @if (!string.IsNullOrWhiteSpace(ActivePlaylistMeta))
                            {
                                <span>@ActivePlaylistMeta</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(ActivePlaylistDescription))
                        {
                            <p>@ActivePlaylistDescription</p>
                        }
                        <div class="listen-actions">
                            <button type="button" class="listen-button listen-button--primary" @onclick="@(() => PlayTracksAsync(ActivePlaylistTracks, null, ActivePlaylistTitle))" disabled="@(ActivePlaylistTracks.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                <span>Play</span>
                            </button>
                            <button type="button" class="listen-button listen-button--secondary" @onclick="@(() => PlayTracksAsync(ActivePlaylistTracks, null, ActivePlaylistTitle, true))" disabled="@(ActivePlaylistTracks.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.Shuffle" Size="Size.Small" />
                                <span>Shuffle</span>
                            </button>
                        </div>
                    </div>
                    @if (ActivePlaylistCollection is not null)
                    {
                        <button type="button"
                                class="listen-detail__edit"
                                title="Edit playlist"
                                aria-label="Edit playlist"
                                @onclick="OpenPlaylistEditorDialog">
                            <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Size="Size.Small" />
                        </button>
                    }
                </section>

                <section class="listen-section">
                    @if (ActivePlaylistTracks.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 56px; opacity: 0.22;" />
                                <p>This playlist is empty.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="listen-playlist-track-list" role="table" aria-label="@($"{ActivePlaylistTitle} songs")">
                            <div class="listen-playlist-track-list__head" role="row">
                                <span role="columnheader">Song</span>
                                <span role="columnheader">Artist</span>
                                <span role="columnheader">Album</span>
                                <span role="columnheader">Time</span>
                                <span role="columnheader" class="listen-playlist-track-list__actions-label">Actions</span>
                            </div>
                            @foreach (var row in ActivePlaylistTrackRows)
                            {
                                var track = row.Work;
                                var item = row.Item;
                                <div class="listen-playlist-track-row" role="row" @ondblclick="@(() => PlayTracksAsync(ActivePlaylistTracks, track.Id, ActivePlaylistTitle))">
                                    <div class="listen-playlist-track-row__song" role="cell">
                                        <div class="listen-playlist-track-row__move">
                                            <button type="button"
                                                    class="listen-icon-button"
                                                    title="Move up"
                                                    aria-label="@($"Move {track.Title} up")"
                                                    disabled="@(item is null || row.Index == 0)"
                                                    @onclick="@(() => item is null ? Task.CompletedTask : MovePlaylistTrackAsync(item.Id, -1))">
                                                <MudIcon Icon="@Icons.Material.Outlined.KeyboardArrowUp" Size="Size.Small" />
                                            </button>
                                            <button type="button"
                                                    class="listen-icon-button"
                                                    title="Move down"
                                                    aria-label="@($"Move {track.Title} down")"
                                                    disabled="@(item is null || row.Index == ActivePlaylistTrackRows.Count - 1)"
                                                    @onclick="@(() => item is null ? Task.CompletedTask : MovePlaylistTrackAsync(item.Id, 1))">
                                                <MudIcon Icon="@Icons.Material.Outlined.KeyboardArrowDown" Size="Size.Small" />
                                            </button>
                                        </div>
                                        <div class="listen-playlist-track-row__art">
                                            @if (!string.IsNullOrWhiteSpace(track.CoverUrl))
                                            {
                                                <img src="@track.CoverUrl" alt="" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Size="Size.Small" />
                                            }
                                        </div>
                                        <span class="listen-playlist-track-row__title">@track.Title</span>
                                    </div>
                                    <span class="listen-playlist-track-row__meta" role="cell">@FirstNonBlank(track.Artist, track.Author)</span>
                                    <span class="listen-playlist-track-row__meta" role="cell">@FirstNonBlank(track.Album)</span>
                                    <span class="listen-playlist-track-row__time" role="cell">@GetTrackDuration(track)</span>
                                    <div class="listen-playlist-track-row__actions" role="cell">
                                        <button type="button"
                                                class="listen-icon-button listen-icon-button--danger"
                                                title="Remove from playlist"
                                                aria-label="@($"Remove {track.Title} from playlist")"
                                                disabled="@(item is null)"
                                                @onclick="@(() => item is null ? Task.CompletedTask : RemovePlaylistTrackAsync(item.Id))">
                                            <MudIcon Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" />
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </section>
            }
            else if (IsAudiobooksView)
            {
                <MediaBrowseShell Tab="audiobooks"
                                  Preset="@AudiobookBrowsePreset" />
            }
        </main>
        @if (_trackContextMenuWorkId.HasValue && ContextMenuTrack is not null)
        {
            <div class="listen-context-menu" style="left:@($"{_trackContextMenuX}px"); top:@($"{_trackContextMenuY}px");" @onclick:stopPropagation="true">
                <div class="listen-context-menu__title">@ContextMenuTrack.Title</div>
                <button type="button" class="listen-context-menu__action" @onclick="@(() => PlayTracksAsync(CurrentTrackSurfaceTracks, ContextMenuTrack.Id, _trackContextMenuSourceLabel))">Play now</button>
                <button type="button" class="listen-context-menu__action" @onclick="@(() => Playback.InsertNextAsync(ContextMenuTrack))">Play next</button>
                <button type="button" class="listen-context-menu__action" @onclick="@(() => QueueTrackAsync(ContextMenuTrack))">Add to queue</button>
                <button type="button" class="listen-context-menu__action" @onclick="@(() => ToggleFavoriteAsync(ContextMenuTrack))">@(_favoriteWorkIds.Contains(ContextMenuTrack.Id) ? "Remove favorite" : "Favorite")</button>
                <button type="button" class="listen-context-menu__action" @onclick="@(() => ToggleDislikeAsync(ContextMenuTrack))">@(_dislikedWorkIds.Contains(ContextMenuTrack.Id) ? "Clear dislike" : "Dislike")</button>
                <button type="button" class="listen-context-menu__action" @onclick="@(() => EditTrackAsync(ContextMenuTrack))">Edit track</button>
                @if (!string.IsNullOrWhiteSpace(BuildAlbumRouteForTrack(ContextMenuTrack)))
                {
                    <button type="button" class="listen-context-menu__action" @onclick="@(() => NavigateTo(BuildAlbumRouteForTrack(ContextMenuTrack)!))">Open album</button>
                }
                <details class="listen-row-menu">
                    <summary class="listen-row-menu__summary">Add to playlist</summary>
                    <div class="listen-row-menu__panel">
                        <button type="button" class="listen-row-menu__action" @onclick="@(() => AddContextMenuTrackToPlaylistAsync())">Create new playlist</button>
                        @foreach (var playlist in ManualPlaylistCollections)
                        {
                            <button type="button" class="listen-row-menu__action" @onclick="@(() => AddContextMenuTrackToPlaylistAsync(playlist.Id))">Add to @playlist.Name</button>
                        }
                    </div>
                </details>
            </div>
            <button type="button" class="listen-context-menu__dismiss" @onclick="@(() => CloseTrackContextMenu())" aria-label="Close context menu"></button>
        }

        </ChildContent>
    </SidebarPageShell>
}
