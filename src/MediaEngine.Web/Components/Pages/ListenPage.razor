@page "/listen/music/playlists/{CollectionId:guid}"
@page "/listen/music/playlists/system/{PlaylistKey}"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using MediaEngine.Contracts.Details
@using MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Components.Details
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Components.Discovery
@using MediaEngine.Web.Components.Listen
@using MediaEngine.Web.Components.MediaHub
@using MediaEngine.Web.Models.ViewDTOs
@using MudBlazor
@namespace MediaEngine.Web.Components.Pages

<PageTitle>@PageTitleText</PageTitle>

@if (_redirecting)
{
    <div class="listen-state">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Class="tl-u-color-rgba-255-255-255-0-32" />
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="listen-state listen-state--error">
        <MudIcon Icon="@Icons.Material.Outlined.LibraryMusic" Class="tl-u-font-size-56px tl-u-opacity-0-22" />
        <h3>Listen could not load</h3>
        <p>@_error</p>
        <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="ReloadAsync">Try again</AppNativeButton>
    </div>
}
else
{
    <div class="@ListenPageClass">
        <aside class="listen-rail-shell">
            <div class="listen-rail">
                <ListenNavigationSection Label="Library"
                                         Items="@ListenLibraryItems"
                                         IsRouteActive="IsRouteActive"
                                         OnNavigate="NavigateRailLink" />

                <ListenNavigationSection Label="Formats"
                                         Items="@ListenFormatItems"
                                         IsRouteActive="IsRouteActive"
                                         OnNavigate="NavigateRailLink" />

                <ListenNavigationSection Label="Your Library"
                                         Items="@ListenYourLibraryItems"
                                         IsRouteActive="IsRouteActive"
                                         OnNavigate="NavigateRailLink" />

                <section class="listen-rail__section">
                    <div class="listen-rail__section-heading">
                        <AppNativeButton Type="button" Class="listen-rail__section-toggle" aria-expanded="@_playlistsExpanded" OnClick="@(() => _playlistsExpanded = !_playlistsExpanded)">
                            <span>Playlists</span>
                            <MudIcon Icon="@(_playlistsExpanded ? Icons.Material.Outlined.ExpandLess : Icons.Material.Outlined.ExpandMore)" Class="tl-u-font-size-18px" />
                        </AppNativeButton>
                        <AppNativeButton Type="button" Class="listen-rail__add" AriaLabel="Add playlist" OnClick="TogglePlaylistCreateMenu">
                            <MudIcon Icon="@Icons.Material.Outlined.Add" Class="tl-u-font-size-18px" />
                        </AppNativeButton>
                        @if (_playlistCreateMenuOpen)
                        {
                            <div class="listen-rail__create-menu">
                                <AppNativeButton Type="button" OnClick='@(() => OpenPlaylistCreateDialog("Playlist"))'>New Playlist</AppNativeButton>
                                <AppNativeButton Type="button" OnClick='@(() => OpenPlaylistCreateDialog("Smart"))'>New Smart Playlist</AppNativeButton>
                            </div>
                        }
                    </div>

                    @if (_playlistsExpanded)
                    {
                        @foreach (var item in ListenPinnedPlaylistItems)
                        {
                            <a @key="item.Route" href="@item.Route" target="_top" data-enhance-nav="false" class='@($"listen-rail__item {(IsRouteActive(item.Route) ? " is-active" : null)}")' aria-current="@(IsRouteActive(item.Route) ? "page" : null)" @onclick="@(() => NavigateRailLink(item.Route))" @onclick:preventDefault="true">
                                <MudIcon Icon="@item.Icon" Class="tl-u-font-size-18px" />
                                <span>@item.Label</span>
                            </a>
                        }

                        @foreach (var playlist in PlaylistCollections)
                        {
                            var playlistRoute = $"/listen/music/playlists/{playlist.Id}";
                            <div @key="playlist.Id" class="listen-rail__playlist-row @(playlist.Id == _draggingPlaylistId ? "is-dragging" : null)"
                                 @ondragover:preventDefault="true"
                                 @ondrop="@(() => DropPlaylistReorderAsync(playlist.Id))">
                                <AppNativeButton Type="button" Class="listen-rail__drag" draggable="true" AriaLabel="@($"Drag to reorder {playlist.Name}")" @ondragstart="@(() => BeginPlaylistReorder(playlist.Id))" @ondragend="EndPlaylistReorder">
                                    <MudIcon Icon="@Icons.Material.Outlined.DragIndicator" Class="tl-u-font-size-18px" />
                                </AppNativeButton>
                                <a href="@playlistRoute" target="_top" data-enhance-nav="false" class='@($"listen-rail__item is-child {(IsRouteActive(playlistRoute) ? "is-active" : null)}")' aria-current="@(IsRouteActive(playlistRoute) ? "page" : null)" @onclick="@(() => NavigateRailLink(playlistRoute))" @onclick:preventDefault="true" @ondragover:preventDefault="true" @ondrop="@(() => CanAcceptPlaylistItems(playlist) ? HandlePlaylistDropAsync(playlist.Id) : Task.CompletedTask)">
                                    @if (!string.IsNullOrWhiteSpace(playlist.SquareArtworkUrl))
                                    {
                                        <span class="listen-rail__thumb"><img src="@playlist.SquareArtworkUrl" alt="" /></span>
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@PlaylistIconFor(playlist)" Class="tl-u-font-size-18px" />
                                    }
                                    <span>@playlist.Name</span>
                                </a>
                                <AppNativeButton Type="button" Class="listen-rail__more" Title="Playlist options" AriaLabel="@($"{playlist.Name} options")" StopPropagation="true" OnClick="@(() => TogglePlaylistActionsMenu(playlist.Id))">
                                    <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Class="tl-u-font-size-18px" />
                                </AppNativeButton>
                                @if (_playlistActionsMenuOpen && _playlistActionsCollectionId == playlist.Id)
                                {
                                    <div class="listen-actions-menu listen-actions-menu--rail">
                                        <AppNativeButton Type="button" OnClick="@(() => OpenPlaylistEditorFromMenuAsync(playlist))">Edit Playlist</AppNativeButton>
                                    </div>
                                }
                            </div>
                        }
                    }
                </section>
            </div>
        </aside>

        <main class="listen-content">
            @if (!IsAudioDetailSurface)
            {
                <div class="listen-lane-header">
                    <MediaLaneHeader Title="Listen"
                                     Modes="@ListenHubModes"
                                     ActiveMode="@ActiveListenMode" />
                </div>
            }

            @if (IsMusicBrowseNavigationVisible)
            {
                <div class="listen-browse-mode">
                    <span>Browse as</span>
                    <AppBrowseModeSelector Options="@MusicBrowseOptions"
                                           Value="@MusicBrowseMode"
                                           ValueChanged="SetMusicBrowseMode"
                                           AriaLabel="Browse music as" />
                </div>
            }

            @if (_loading)
            {
                <div class="listen-state listen-state--content">
                    <MudProgressCircular Indeterminate="true" Size="Size.Large" Class="tl-u-color-rgba-255-255-255-0-32" />
                </div>
            }
            else if (IsListenHub)
            {
                <MediaHubPage SectionType="MediaHubSectionType.Listen"
                              Title="Listen"
                              Subtitle="Music and audiobooks from your local library"
                              SelectedMode="all"
                              AvailableModes="@ListenHubModes"
                              Shelves="@ListenHubShelves"
                              SearchPlaceholder="Search music and audiobooks..."
                              RouteBase="/listen"
                              SupportsHero="false"
                              SupportsHeader="false"
                              SupportsNavigation="false" />
            }
            else if (IsMusicTimelineView)
            {
                <section class="listen-section">
                    <AppTimelineResults Items="@MusicTimelineTiles"
                                        TileSizePx="@_albumTileSizePx"
                                        YearSemantic="Original album release year" />
                </section>
            }
            else if (IsAlbumsView)
            {
                <section class="listen-section">
                    <div class="listen-filter-bar listen-filter-bar--surface">
                        <label class="listen-filter-search">
                            <MudIcon Icon="@Icons.Material.Outlined.Search" />
                            <AppNativeInput Class="listen-filter-input"
                                            @bind="_albumSearch"
                                            @bind:event="oninput"
                                            Placeholder="Search albums or artists..."
                                            AriaLabel="Search albums or artists" />
                        </label>
                        <label class="listen-filter-field listen-filter-field--genre">
                            <span>Genres</span>
                            <AppNativeSelect Class="listen-filter-select" @bind="_albumGenreFilter" aria-label="Filter albums by genre">
                                <option value="all">All genres</option>
                                @foreach (var genre in SongGenres)
                                {
                                    <option value="@genre">@genre</option>
                                }
                            </AppNativeSelect>
                        </label>
                        <label class="listen-filter-field">
                            <span>Artist</span>
                            <AppNativeSelect Class="listen-filter-select" @bind="_albumArtistFilter" aria-label="Filter albums by artist">
                                <option value="all">All artists</option>
                                @foreach (var artist in AlbumArtists)
                                {
                                    <option value="@artist">@artist</option>
                                }
                            </AppNativeSelect>
                        </label>
                        <div class="listen-filter-toggle-stack">
                            <AppQuickFilterToggle Label="Favorites" @bind-Selected="_albumFavoriteOnly" />
                            <AppQuickFilterToggle Label="Complete Albums" @bind-Selected="_albumArtOnly" />
                        </div>
                        <div class="listen-display-group" aria-label="Album display controls">
                            <span class="listen-display-group__eyebrow">Display</span>
                            <label class="listen-filter-field listen-filter-field--sort">
                                <span>Sort by</span>
                                <AppNativeSelect Class="listen-filter-select" @bind="_albumSort" aria-label="Sort albums">
                                    <option value="recent">Recently added</option>
                                    <option value="title">Title</option>
                                    <option value="artist">Artist</option>
                                    <option value="year">Year</option>
                                </AppNativeSelect>
                            </label>
                            <label class="listen-tile-size" title="Adjust album tile size">
                                <span>Tile size</span>
                                <span class="listen-tile-size__control">
                                    <MudIcon Icon="@Icons.Material.Outlined.PhotoSizeSelectSmall" />
                                    <AppNativeInput Type="range"
                                                    Value="@_albumTileSizePx"
                                                    Min="96"
                                                    Max="208"
                                                    Step="8"
                                                    AriaLabel="Album tile size"
                                                    OnInput="UpdateAlbumTileSize" />
                                </span>
                            </label>
                        </div>
                    </div>

                    <div class="listen-section__header listen-section__header--results">
                        <div>
                            <h2>Albums</h2>
                            <p class="listen-section__summary">@Pluralize(FilteredAlbumGroups.Count, "album") ready to browse.</p>
                        </div>
                        <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => PlayTracksAsync(_musicWorks, null, " All Music", true))" Disabled="@(_musicWorks.Count == 0)">Shuffle library</AppNativeButton>
                    </div>

                    @if (FilteredAlbumGroups.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.Album" Class="tl-u-font-size-56px tl-u-opacity-0-22" />
                                <p>No albums are ready to browse yet.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <MediaTileGrid Items="@AlbumTiles"
                                       ShowCompactCaptions="true"
                                       TileSizePx="@_albumTileSizePx"
                                       Class="listen-card-grid listen-card-grid--albums" />
                    }
                </section>
            }
            else if (IsAlbumDetail && _albumDetail is not null)
            {
                <section class="listen-detail listen-detail--album">
                    <div class="listen-detail__art">
                        @if (!string.IsNullOrWhiteSpace(_albumDetail.CoverUrl))
                        {
                            <img src="@_albumDetail.CoverUrl" alt="@_albumDetail.DisplayName" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Album" Class="tl-u-font-size-64px" />
                        }
                    </div>
                    <div class="listen-detail__copy">
                        <div class="listen-kicker">Album</div>
                        <h2>@_albumDetail.DisplayName</h2>
                        <div class="listen-detail__meta">
                            <span>@FirstNonBlank(_albumDetail.Creator, _albumDetail.YearRange, _albumDetail.ReleaseDate)</span>
                            <span>@Pluralize(_albumDetail.TotalItems, "track")</span>
                            @if (!string.IsNullOrWhiteSpace(_albumDetail.TotalDuration))
                            {
                                <span>@_albumDetail.TotalDuration</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_albumDetail.Description))
                        {
                            <p>@_albumDetail.Description</p>
                        }
                        <div class="listen-actions">
                            <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => NavigateTo(AlbumsRoute))">Back to albums</AppNativeButton>
                            <AppNativeButton Type="button" Class="listen-button listen-button--primary" OnClick="@(() => PlayTracksAsync(AlbumTracks, null, _albumDetail.DisplayName))" Disabled="@(AlbumTracks.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                <span>Play</span>
                            </AppNativeButton>
                            <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => PlayTracksAsync(AlbumTracks, null, _albumDetail.DisplayName, true))" Disabled="@(AlbumTracks.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.Shuffle" Size="Size.Small" />
                                <span>Shuffle</span>
                            </AppNativeButton>
                            @if (!string.IsNullOrWhiteSpace(_albumDetail.Creator))
                            {
                                <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => OpenArtist(_albumDetail.Creator!))">Artist</AppNativeButton>
                            }
                        </div>
                    </div>
                </section>

                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Tracks</div>
                            <h2>@Pluralize(AlbumTracks.Count, "track")</h2>
                        </div>
                    </div>
                    <ListenSongTable Tracks="@AlbumTracks"
                                     FavoriteIds="@_favoriteWorkIds"
                                     SourceLabel="@_albumDetail.DisplayName"
                                     AriaLabel="@($"{_albumDetail.DisplayName} songs")"
                                     ShowArtwork="false"
                                     ShowAlbum="false"
                                     ShowGenre="false"
                                     ShowDateAdded="false"
                                     DefaultSortColumn="track"
                                     DefaultSortDescending="false"
                                     OnPlayRequested="PlayTracksAsync"
                                     OnFavoriteToggled="ToggleFavoriteAsync"
                                     OnQueueRequested="QueueTrackAsync"
                                     OnEditRequested="EditTrackAsync"
                                     OnDeleteRequested="DeleteTrackAsync"
                                     OnDragStarted="OnTrackDragStarted"
                                     OnDragEnded="OnTrackDragEnded" />
                </section>
            }
            else if (IsArtistsSurface)
            {
                @if (string.IsNullOrWhiteSpace(ArtistKey))
                {
                    <section class="listen-section listen-section--people">
                        <div class="listen-section__header">
                            <div>
                                <div class="listen-kicker">Music</div>
                                <h2>Artists</h2>
                                <p class="listen-section__summary">@Pluralize(ArtistPersonTiles.Count, "artist") in your library.</p>
                            </div>
                        </div>

                        <div class="listen-filter-bar listen-filter-bar--compact">
                            <AppNativeInput Class="listen-filter-input" @bind="_artistSearch" @bind:event="oninput" Placeholder="Search artists" />
                            <AppNativeSelect Class="listen-filter-select" @bind="_artistSort">
                                <option value="name">Artist name</option>
                                <option value="tracks">Most tracks</option>
                            </AppNativeSelect>
                        </div>

                        @if (ArtistPersonTiles.Count == 0)
                        {
                            <div class="listen-empty">
                                <div>
                                    <MudIcon Icon="@Icons.Material.Outlined.PersonOutline" Class="tl-u-font-size-56px tl-u-opacity-0-22" />
                                    <p>No artists match these filters.</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <MediaTileGrid Items="@ArtistPersonTiles"
                                           ShowCompactCaptions="true"
                                           HideGroupIndicators="true"
                                           TileSizePx="300"
                                           Class="listen-card-grid listen-card-grid--people" />
                        }
                    </section>
                }
                else
                {
                    <section class="listen-artists">
                    <div class="listen-artists__list">
                        <div class="listen-section__header">
                            <div>
                                <div class="listen-kicker">Music</div>
                                <h2>Artists</h2>
                                <p class="listen-section__summary">@Pluralize(FilteredArtistGroups.Count, "artist") in your library.</p>
                            </div>
                        </div>

                        <div class="listen-filter-bar listen-filter-bar--compact">
                            <AppNativeInput Class="listen-filter-input" @bind="_artistSearch" @bind:event="oninput" Placeholder="Search artists" />
                            <AppNativeSelect Class="listen-filter-select" @bind="_artistSort">
                                <option value="name">Artist name</option>
                                <option value="tracks">Most tracks</option>
                            </AppNativeSelect>
                        </div>

                        <div class="listen-artists__list-body">
                            @foreach (var artist in FilteredArtistGroups)
                            {
                                <AppNativeButton Type="button" Class='@($"listen-list-item {(string.Equals(artist.DisplayName, SelectedArtistName, StringComparison.OrdinalIgnoreCase) ? " is-active" : null)}")' OnClick="@(() => SelectArtistAsync(artist.DisplayName))">
                                    <div class="listen-list-item__thumb">
                                        @if (!string.IsNullOrWhiteSpace(artist.ArtistPhotoUrl))
                                        {
                                            <img src="@artist.ArtistPhotoUrl" alt="@artist.DisplayName" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Outlined.PersonOutline" Class="tl-u-font-size-20px" />
                                        }
                                    </div>
                                    <div>
                                        <div class="listen-card__title">@artist.DisplayName</div>
                                        <div class="listen-card__meta">@Pluralize(artist.WorkCount, "track")</div>
                                    </div>
                                </AppNativeButton>
                            }
                        </div>
                    </div>

                    <div class="listen-artists__detail">
                        @if (_artistLoading)
                        {
                            <div class="listen-empty">
                                <div>
                                    <MudProgressCircular Indeterminate="true" Size="Size.Large" Class="tl-u-color-rgba-255-255-255-0-32" />
                                    <p>Loading artist details...</p>
                                </div>
                            </div>
                        }
                        else if (_artistDetail is null)
                        {
                            <div class="listen-empty">
                                <div>
                                    <MudIcon Icon="@Icons.Material.Outlined.PersonOutline" Class="tl-u-font-size-56px tl-u-opacity-0-22" />
                                    <p>Choose an artist to view albums.</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <section class="listen-detail listen-detail--artist">
                                <div class="listen-detail__art">
                                    @if (!string.IsNullOrWhiteSpace(_artistDetail.ArtistPhotoUrl))
                                    {
                                        <img src="@_artistDetail.ArtistPhotoUrl" alt="@_artistDetail.DisplayName" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.PersonOutline" Class="tl-u-font-size-64px" />
                                    }
                                </div>
                                <div class="listen-detail__copy">
                                    <div class="listen-kicker">Artist</div>
                                    <h2>@_artistDetail.DisplayName</h2>
                                    <div class="listen-detail__meta">
                                        <span>@Pluralize(ArtistAlbums.Count, "album")</span>
                                        <span>@Pluralize(ArtistTracks.Count, "track")</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(_artistDetail.Description))
                                    {
                                        <p>@_artistDetail.Description</p>
                                    }
                                    <div class="listen-actions">
                                        <AppNativeButton Type="button" Class="listen-button listen-button--primary" OnClick="@(() => PlayTracksAsync(ArtistTracks, null, _artistDetail.DisplayName))" Disabled="@(ArtistTracks.Count == 0)">
                                            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                            <span>Play</span>
                                        </AppNativeButton>
                                        <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => PlayTracksAsync(ArtistTracks, null, _artistDetail.DisplayName, true))" Disabled="@(ArtistTracks.Count == 0)">
                                            <MudIcon Icon="@Icons.Material.Filled.Shuffle" Size="Size.Small" />
                                            <span>Shuffle</span>
                                        </AppNativeButton>
                                        @if (_artistDetail.ArtistPersonId.HasValue)
                                        {
                                            <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => Nav.NavigateTo($"/details/person/{_artistDetail.ArtistPersonId.Value}"))">View artist page</AppNativeButton>
                                        }
                                    </div>
                                </div>
                            </section>

                            @if (ArtistAlbums.Count > 0)
                            {
                                <section class="listen-section">
                                    <div class="listen-section__header">
                                        <div>
                                            <div class="listen-kicker">Albums</div>
                                            <h2>Discography</h2>
                                            <p class="listen-section__summary">Open an album to view and manage its tracks.</p>
                                        </div>
                                    </div>
                                    <MediaTileGrid Items="@ArtistAlbumTiles"
                                                   ShowCompactCaptions="true"
                                                   TileSizePx="@_albumTileSizePx"
                                                   Class="listen-card-grid listen-card-grid--albums" />
                                </section>
                            }

                            <section class="listen-section">
                                <div class="listen-section__header">
                                    <div>
                                        <div class="listen-kicker">Songs</div>
                                        <h2>@Pluralize(ArtistTracks.Count, "track")</h2>
                                    </div>
                                </div>

                                @if (ArtistTracks.Count == 0)
                                {
                                    <div class="listen-empty">
                                        <div>
                                            <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Class="tl-u-font-size-56px tl-u-opacity-0-22" />
                                            <p>No songs are ready for this artist yet.</p>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <ListenSongTable Tracks="@ArtistTracks"
                                                     FavoriteIds="@_favoriteWorkIds"
                                                     SourceLabel="@_artistDetail!.DisplayName"
                                                     AriaLabel="@($"{_artistDetail!.DisplayName} songs")"
                                                     ShowArtist="false"
                                                     ShowGenre="false"
                                                     ShowDateAdded="false"
                                                     DefaultSortColumn="album"
                                                     DefaultSortDescending="false"
                                                     OnPlayRequested="PlayTracksAsync"
                                                     OnFavoriteToggled="ToggleFavoriteAsync"
                                                     OnQueueRequested="QueueTrackAsync"
                                                     OnEditRequested="EditTrackAsync"
                                                     OnDeleteRequested="DeleteTrackAsync"
                                                     OnDragStarted="OnTrackDragStarted"
                                                     OnDragEnded="OnTrackDragEnded" />
                                }
                            </section>
                        }
                    </div>
                    </section>
                }
            }
            else if (IsSongsView)
            {
                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Music</div>
                            <h2>Songs</h2>
                        </div>
                        <div class="listen-actions">
                            <AppNativeButton Type="button" Class="listen-button listen-button--primary" OnClick='@(() => PlayTracksAsync(FilteredSongs, null, "All Music"))' Disabled="@(FilteredSongs.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                <span>Play</span>
                            </AppNativeButton>
                            <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick='@(() => PlayTracksAsync(FilteredSongs, null, "All Music", true))' Disabled="@(FilteredSongs.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.Shuffle" Size="Size.Small" />
                                <span>Shuffle</span>
                            </AppNativeButton>
                        </div>
                    </div>

                    <div class="listen-filter-bar listen-filter-bar--quick">
                        <AppNativeInput Class="listen-filter-input" @bind="_songSearch" @bind:event="oninput" Placeholder="Search songs, artists, or albums" />
                    </div>

                    @if (FilteredSongs.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Class="tl-u-font-size-56px tl-u-opacity-0-22" />
                                <p>No songs are ready to play yet.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <ListenSongTable Tracks="@FilteredSongs"
                                         FavoriteIds="@_favoriteWorkIds"
                                         SourceLabel="All Music"
                                         AriaLabel="Songs"
                                         OnPlayRequested="PlayTracksAsync"
                                         OnFavoriteToggled="ToggleFavoriteAsync"
                                         OnQueueRequested="QueueTrackAsync"
                                         OnEditRequested="EditTrackAsync"
                                         OnDeleteRequested="DeleteTrackAsync"
                                         OnDragStarted="OnTrackDragStarted"
                                         OnDragEnded="OnTrackDragEnded" />
                    }
                </section>
            }
            else if (IsPlaylistsView)
            {
                <section class="listen-section">
                    <div class="listen-section__header">
                        <div>
                            <div class="listen-kicker">Music</div>
                            <h2>Playlists</h2>
                            <p class="listen-section__summary">Saved playlists created from your library.</p>
                        </div>
                    </div>

                    @if (PlaylistCollections.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Class="tl-u-font-size-56px tl-u-opacity-0-22" />
                                <p>No saved playlists yet. Favorites and recently added stay available from Quick access.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <MediaTileGrid Items="@PlaylistTiles"
                                       ShowCompactCaptions="true"
                                       TileSizePx="@_albumTileSizePx"
                                       Class="listen-card-grid" />
                    }
                </section>
            }
            else if (IsPlaylistSurface)
            {
                <section class="listen-detail listen-detail--collection">
                    <div class="listen-detail__collage">
                        @if (!string.IsNullOrWhiteSpace(ActivePlaylistCollection?.SquareArtworkUrl))
                        {
                            <img class="listen-detail__custom-art" src="@ActivePlaylistCollection.SquareArtworkUrl" alt="" />
                        }
                        else if (PlaylistCoverUrls.Count == 0)
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Class="tl-u-font-size-64px" />
                        }
                        else
                        {
                            @foreach (var cover in PlaylistCoverUrls)
                            {
                                <div class="listen-detail__collage-tile">
                                    <img src="@cover" alt="" />
                                </div>
                            }
                        }
                    </div>
                    <div class="listen-detail__copy">
                        <h2>@ActivePlaylistTitle</h2>
                        <div class="listen-actions">
                            <AppNativeButton Type="button" Class="listen-button listen-button--primary" OnClick="@(() => PlayTracksAsync(ActivePlaylistTracks, null, ActivePlaylistTitle))" Disabled="@(ActivePlaylistTracks.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                <span>Play</span>
                            </AppNativeButton>
                            <AppNativeButton Type="button" Class="listen-button listen-button--secondary" OnClick="@(() => PlayTracksAsync(ActivePlaylistTracks, null, ActivePlaylistTitle, true))" Disabled="@(ActivePlaylistTracks.Count == 0)">
                                <MudIcon Icon="@Icons.Material.Filled.Shuffle" Size="Size.Small" />
                                <span>Shuffle</span>
                            </AppNativeButton>
                        </div>
                    </div>
                    @if (ActivePlaylistCollection is not null)
                    {
                        <AppNativeButton Type="button" Class="listen-detail__edit" Title="Playlist options" AriaLabel="Playlist options" OnClick="@(() => TogglePlaylistActionsMenu(ActivePlaylistCollection.Id))">
                            <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Size="Size.Small" />
                        </AppNativeButton>
                        @if (_playlistActionsMenuOpen && _playlistActionsCollectionId == ActivePlaylistCollection.Id)
                        {
                            <div class="listen-actions-menu listen-actions-menu--detail">
                                <AppNativeButton Type="button" OnClick="@(() => OpenPlaylistEditorFromMenuAsync())">Edit Playlist</AppNativeButton>
                                <details class="listen-actions-menu__details">
                                    <summary>Columns</summary>
                                    @foreach (var column in PlaylistColumns)
                                    {
                                        <label>
                                            <AppNativeInput Type="checkbox" Checked="@IsPlaylistColumnVisible(column.Key)" OnChange="@(() => TogglePlaylistColumn(column.Key))" />
                                            <span>@column.Label</span>
                                        </label>
                                    }
                                </details>
                            </div>
                        }
                    }
                </section>

                <section class="listen-section">
                    @if (ActivePlaylistTracks.Count == 0)
                    {
                        <div class="listen-empty">
                            <div>
                                <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Class="tl-u-font-size-56px tl-u-opacity-0-22" />
                                <p>This playlist is empty.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="listen-playlist-track-list" role="table" aria-label="@($"{ActivePlaylistTitle} songs")">
                            <AppCssElement Tag="div" Class="listen-playlist-track-list__head"
                                 Css="@($"grid-template-columns: {PlaylistGridTemplate}")"
                                 role="row"
                                 @onmousemove="@(args => ResizeColumn(args.ClientX))"
                                 @onmouseup="EndColumnResize"
                                 @onmouseleave="EndColumnResize">
                                <span class="listen-playlist-track-list__song-head" role="columnheader">
                                    Song
                                    <span class="listen-column-resizer" @onmousedown:stopPropagation="true" @onmousedown="@((args) => BeginColumnResize("playlist", "song", args.ClientX))"></span>
                                </span>
                                @if (IsPlaylistColumnVisible("favorite"))
                                {
                                    <span class="listen-playlist-track-list__favorite-head" role="columnheader">
                                        Favorite
                                        <span class="listen-column-resizer" @onmousedown:stopPropagation="true" @onmousedown="@((args) => BeginColumnResize("playlist", "favorite", args.ClientX))"></span>
                                    </span>
                                }
                                @if (IsPlaylistColumnVisible("artist"))
                                {
                                    <span role="columnheader">
                                        Artist
                                        <span class="listen-column-resizer" @onmousedown:stopPropagation="true" @onmousedown="@((args) => BeginColumnResize("playlist", "artist", args.ClientX))"></span>
                                    </span>
                                }
                                @if (IsPlaylistColumnVisible("album"))
                                {
                                    <span role="columnheader">
                                        Album
                                        <span class="listen-column-resizer" @onmousedown:stopPropagation="true" @onmousedown="@((args) => BeginColumnResize("playlist", "album", args.ClientX))"></span>
                                    </span>
                                }
                                @if (IsPlaylistColumnVisible("time"))
                                {
                                    <span role="columnheader">
                                        Time
                                        <span class="listen-column-resizer" @onmousedown:stopPropagation="true" @onmousedown="@((args) => BeginColumnResize("playlist", "time", args.ClientX))"></span>
                                    </span>
                                }
                                <span role="columnheader" class="listen-playlist-track-list__actions-label">Queue / Edit / Remove</span>
                            </AppCssElement>
                            @foreach (var row in ActivePlaylistTrackRows)
                            {
                                var track = row.Work;
                                var item = row.Item;
                                <AppCssElement Tag="div" Class='@($"listen-playlist-track-row {(item is not null && item.Id == _draggingPlaylistTrackItemId ? "is-dragging" : null)} {(item is not null && item.Id == _playlistTrackDropTargetItemId && !_playlistTrackDropAfter ? "is-drop-before" : null)}")'
                                     Css="@($"grid-template-columns: {PlaylistGridTemplate}")"
                                     role="row"
                                     draggable="true"
                                     OnDragStart="@((DragEventArgs _) => item is null ? Task.CompletedTask : BeginPlaylistTrackReorderAsync(item.Id))"
                                     OnDragEnd="@((DragEventArgs _) => EndPlaylistTrackReorder())"
                                     OnDoubleClick="@((MouseEventArgs _) => PlayTracksAsync(ActivePlaylistTracks, track.Id, ActivePlaylistTitle))"
                                     PreventDragOverDefault="true"
                                     OnDragOver="@((DragEventArgs _) => item is null ? Task.CompletedTask : SetPlaylistTrackDropTargetAsync(item.Id, false))"
                                     OnDrop="@((DragEventArgs _) => item is null ? Task.CompletedTask : DropPlaylistTrackReorderAsync(item.Id))">
                                    <div class="listen-playlist-track-row__song listen-playlist-track-row__song--no-handle" role="cell">
                                        <div class="listen-playlist-track-row__art">
                                            @if (!string.IsNullOrWhiteSpace(track.CoverUrl))
                                            {
                                                <img src="@track.CoverUrl" alt="" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Size="Size.Small" />
                                            }
                                            <AppNativeButton Type="button" Class="listen-playlist-track-row__art-play" Title="Play song" AriaLabel="@($" Play {track.Title}")" StopPropagation="true" OnClick="@(() => PlayTracksAsync(ActivePlaylistTracks, track.Id, ActivePlaylistTitle))">
                                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                            </AppNativeButton>
                                        </div>
                                        <span class="listen-playlist-track-row__title">@track.Title</span>
                                    </div>
                                    @if (IsPlaylistColumnVisible("favorite"))
                                    {
                                        <div class="listen-playlist-track-row__favorite" role="cell">
                                            <AppNativeButton Type="button" Class='@($"listen-track-grid__favorite {(_favoriteWorkIds.Contains(track.Id) ? " is-active" : null)}")' AriaLabel="Toggle favorite" Title="Toggle favorite" StopPropagation="true" OnClick="@(() => ToggleFavoriteAsync(track))">
                                                <MudIcon Icon="@(_favoriteWorkIds.Contains(track.Id) ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)" Size="Size.Small" />
                                            </AppNativeButton>
                                        </div>
                                    }
                                    @if (IsPlaylistColumnVisible("artist"))
                                    {
                                        <span class="listen-playlist-track-row__meta" role="cell">@FirstNonBlank(track.Artist, track.Author)</span>
                                    }
                                    @if (IsPlaylistColumnVisible("album"))
                                    {
                                        <span class="listen-playlist-track-row__meta" role="cell">@FirstNonBlank(track.Album)</span>
                                    }
                                    @if (IsPlaylistColumnVisible("time"))
                                    {
                                        <span class="listen-playlist-track-row__time" role="cell">@GetTrackDuration(track)</span>
                                    }
                                    <div class="listen-playlist-track-row__actions" role="cell">
                                        <AppNativeButton Type="button" Class="listen-icon-button" Title="Add to queue" AriaLabel="@($" Add {track.Title} to queue")" StopPropagation="true" OnClick="@(() => QueueTrackAsync(track))">
                                            <MudIcon Icon="@Icons.Material.Outlined.PlaylistAdd" Size="Size.Small" />
                                        </AppNativeButton>
                                        <AppNativeButton Type="button" Class="listen-icon-button" Title="Edit song" AriaLabel="@($" Edit {track.Title}")" StopPropagation="true" OnClick="@(() => EditTrackAsync(track))">
                                            <MudIcon Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" />
                                        </AppNativeButton>
                                        <AppNativeButton Type="button" Class="listen-icon-button listen-icon-button--danger" Title="Remove from playlist" AriaLabel="@($" Remove {track.Title} from playlist")" Disabled="@(item is null)" StopPropagation="true" OnClick="@(() => item is null ? Task.CompletedTask : RemovePlaylistTrackAsync(item.Id))">
                                            <MudIcon Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" />
                                        </AppNativeButton>
                                    </div>
                                </AppCssElement>
                            }
                            <div class="listen-playlist-track-end-zone @(_draggingPlaylistTrackItemId.HasValue ? "is-active" : null)"
                                 @ondragover:preventDefault="true"
                                 @ondragover="@(() => SetPlaylistTrackEndDropTargetAsync())"
                                 @ondrop="DropPlaylistTrackAtEndAsync"></div>
                        </div>
                    }
                </section>
            }
            else if (IsAudiobooksView)
            {
                <section class="audiobooks-dashboard" aria-label="Audiobooks dashboard">
                    <div class="audiobooks-toolbar" aria-label="Audiobook controls">
                        <label class="audiobooks-search">
                            <MudIcon Icon="@Icons.Material.Outlined.Search" Class="tl-u-font-size-20px" />
                            <AppNativeInput Value="@_audiobookSearch"
                                            OnInput="UpdateAudiobookSearch"
                                            Placeholder="Search audiobooks"
                                            AriaLabel="Search audiobooks" />
                        </label>

                        <div class="audiobooks-toolbar__controls">
                            <div class="audiobooks-segmented">
                                <span>Browse as</span>
                                <AppBrowseModeSelector Options="@AudiobookBrowseOptions"
                                                       Value="@_audiobookView"
                                                       ValueChanged="SetAudiobookView"
                                                       AriaLabel="Browse audiobooks as" />
                            </div>

                            <div class="audiobooks-filter-group">
                                <span>Filter by</span>
                                <div class="audiobooks-filters" aria-label="Audiobook filters">
                                    <AppQuickFilterToggle Label="In Progress"
                                                          Selected="@_audiobookInProgressOnly"
                                                          SelectedChanged="SetAudiobookInProgress" />
                                    <AppQuickFilterToggle Label="Unread"
                                                          Selected="@_audiobookUnreadOnly"
                                                          SelectedChanged="SetAudiobookUnread" />
                                    <AppNativeSelect Class="audiobooks-select" @bind="_audiobookLengthFilter" aria-label="Filter by length">
                                        <option value="all">Length</option>
                                        <option value="short">Under 6h</option>
                                        <option value="medium">6-14h</option>
                                        <option value="long">14h+</option>
                                    </AppNativeSelect>
                                </div>
                            </div>
                        </div>

                        <div class="audiobooks-toolbar__display" aria-label="Audiobook display controls">
                            <span class="audiobooks-toolbar__eyebrow">Display</span>
                            <label class="audiobooks-sort">
                                <span>Sort by</span>
                                <AppNativeSelect Class="audiobooks-select" @bind="_audiobookSort" aria-label="Sort audiobooks">
                                    <option value="recent">Recently Added</option>
                                    <option value="title">Title</option>
                                    <option value="author">Author</option>
                                    <option value="length">Length</option>
                                </AppNativeSelect>
                            </label>

                            <div class="audiobooks-view-controls">
                                @if (_audiobookLayout == LibraryLayoutMode.Card)
                                {
                                    <label class="audiobooks-tile-size" title="Adjust audiobook tile size">
                                        <span>Tile size</span>
                                        <AppNativeInput Type="range"
                                                        Value="@_audiobookTileSizePx"
                                                        Min="128"
                                                        Max="248"
                                                        Step="8"
                                                        AriaLabel="Audiobook tile size"
                                                        OnInput="UpdateAudiobookTileSize" />
                                    </label>
                                }
                                <div class="audiobooks-layout-toggle" role="group" aria-label="Audiobook layout">
                                    <AppNativeButton Type="button" Class="@AudiobookLayoutToggleClass(LibraryLayoutMode.Card)" aria-pressed="@(_audiobookLayout == LibraryLayoutMode.Card ? "true" : "false")" OnClick="@(() => _audiobookLayout = LibraryLayoutMode.Card)">
                                        <span>Cards</span>
                                    </AppNativeButton>
                                    <AppNativeButton Type="button" Class="@AudiobookLayoutToggleClass(LibraryLayoutMode.List)" aria-pressed="@(_audiobookLayout == LibraryLayoutMode.List ? "true" : "false")" OnClick="@(() => _audiobookLayout = LibraryLayoutMode.List)">
                                        <span>List</span>
                                    </AppNativeButton>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_audiobookSeriesFocus))
                    {
                        <div class="audiobooks-active-filter">
                            <span>Showing @_audiobookSeriesFocus</span>
                            <AppNativeButton Type="button" OnClick="ClearAudiobookSeriesFocus">Clear</AppNativeButton>
                        </div>
                    }

                    <section class="audiobooks-section audiobooks-section--continue">
                        <div class="audiobooks-section__header">
                            <h2>Continue Listening</h2>
                        </div>

                        @if (AudiobookContinueCards.Count == 0)
                        {
                            <div class="audiobooks-empty">No audiobook listening progress yet.</div>
                        }
                        else
                        {
                            <div class="audiobooks-continue-grid">
                                @foreach (var item in AudiobookContinueCards)
                                {
                                    var audiobook = item.Item;
                                    var title = AudiobookTitle(audiobook);
                                    var route = AudiobookRoute(audiobook);
                                    var coverUrl = AudiobookCoverUrl(audiobook);
                                    var progress = AudiobookProgressPercent(item);
                                    <article class="audiobooks-continue-card">
                                        <a class="audiobooks-continue-card__cover" href="@route">
                                            @if (!string.IsNullOrWhiteSpace(coverUrl))
                                            {
                                                <img src="@coverUrl" alt="@title" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Class="tl-u-font-size-48px" />
                                            }
                                        </a>
                                        <div class="audiobooks-continue-card__copy">
                                            <a class="audiobooks-card-title" href="@route">@title</a>
                                            <span>@AudiobookCreatorLine(audiobook)</span>
                                            <span>@AudiobookSecondaryLine(audiobook)</span>
                                            <progress class="audiobooks-progress" value="@progress" max="100" aria-label="@AudiobookProgressLabel(item)"></progress>
                                            <div class="audiobooks-continue-card__meta">
                                                <span>@AudiobookProgressLabel(item)</span>
                                                <span>@AudiobookRemainingLabel(item)</span>
                                            </div>
                                        </div>
                                        <AppNativeButton Type="button" Class="audiobooks-play-button" AriaLabel="@($"Play {title}")" OnClick='@(() => PlayAudiobookItemAsync(audiobook))'>
                                            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Class="tl-u-font-size-28px" />
                                        </AppNativeButton>
                                    </article>
                                }
                            </div>
                        }
                    </section>

                    <section class="audiobooks-section">
                        <div class="audiobooks-section__header">
                            <div>
                                <h2>@AudiobookBrowseTitle</h2>
                                <p>@AudiobookBrowseSummary</p>
                            </div>
                        </div>

                        @if (_audiobookView == "series")
                        {
                            @if (AudiobookSeriesGroups.Count == 0)
                            {
                                <div class="audiobooks-empty">No audiobook series match these filters.</div>
                            }
                            else
                            {
                                <div class="audiobooks-series-grid">
                                    @foreach (var series in AudiobookSeriesGroups)
                                    {
                                        <article class="audiobooks-series-card">
                                            <div class="audiobooks-series-card__covers">
                                                <span>
                                                    @if (!string.IsNullOrWhiteSpace(series.CoverUrl))
                                                    {
                                                        <img src="@series.CoverUrl" alt="@series.DisplayName" />
                                                    }
                                                    else
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Class="tl-u-font-size-38px" />
                                                    }
                                                </span>
                                            </div>
                                            <div class="audiobooks-series-card__copy">
                                                <h3>@series.DisplayName</h3>
                                                <span>@AudiobookSeriesMeta(series)</span>
                                                <p>@AudiobookSeriesDescription(series)</p>
                                                <AppNativeButton Type="button" Class="audiobooks-series-card__action" OnClick="@(() => ViewAudiobookSeries(series))">View Series</AppNativeButton>
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                        }
                        else if (_audiobookView == "authors")
                        {
                            @if (AudiobookAuthorPersonTiles.Count == 0)
                            {
                                <div class="audiobooks-empty">No audiobook authors match these filters.</div>
                            }
                            else
                            {
                                <MediaTileGrid Items="@AudiobookAuthorPersonTiles"
                                               ShowCompactCaptions="true"
                                               HideGroupIndicators="true"
                                               TileSizePx="300"
                                               Class="listen-card-grid listen-card-grid--people" />
                            }
                        }
                        else if (_audiobookView == "narrators")
                        {
                            @if (AudiobookNarratorPersonTiles.Count == 0)
                            {
                                <div class="audiobooks-empty">No audiobook narrators match these filters.</div>
                            }
                            else
                            {
                                <MediaTileGrid Items="@AudiobookNarratorPersonTiles"
                                               ShowCompactCaptions="true"
                                               HideGroupIndicators="true"
                                               TileSizePx="300"
                                               Class="listen-card-grid listen-card-grid--people" />
                            }
                        }
                        else if (_audiobookView == "timeline")
                        {
                            <AppTimelineResults Items="@AudiobookBrowseTiles"
                                                TileSizePx="@_audiobookTileSizePx"
                                                YearSemantic="Original work publication year" />
                        }
                        else if (AudiobookBrowseItems.Count == 0)
                        {
                            <div class="audiobooks-empty">No audiobooks match these filters.</div>
                        }
                        else
                        {
                            @if (_audiobookLayout == LibraryLayoutMode.Card)
                            {
                                <MediaTileGrid Items="@AudiobookBrowseTiles"
                                               ShowCompactCaptions="true"
                                               TileSizePx="@_audiobookTileSizePx"
                                               Class="listen-card-grid listen-card-grid--audiobooks" />
                            }
                            else
                            {
                                <div class="@AudiobookBooksLayoutClass">
                                    @foreach (var audiobook in AudiobookBrowseItems)
                                    {
                                        var title = AudiobookTitle(audiobook);
                                        var route = AudiobookRoute(audiobook);
                                        var coverUrl = AudiobookCoverUrl(audiobook);
                                        var progress = AudiobookProgressPercent(audiobook);
                                        <article class="audiobooks-book-card">
                                            <a class="audiobooks-book-card__cover" href="@route">
                                                @if (!string.IsNullOrWhiteSpace(coverUrl))
                                                {
                                                    <img src="@coverUrl" alt="@title" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Class="tl-u-font-size-42px" />
                                                }
                                            </a>
                                            <div class="audiobooks-book-card__copy">
                                                <a class="audiobooks-card-title" href="@route">@title</a>
                                                <span>@AudiobookCreatorLine(audiobook)</span>
                                                <span>@AudiobookSecondaryLine(audiobook)</span>
                                                <div class="audiobooks-book-card__badges">
                                                    <span>@AudiobookBadge(audiobook)</span>
                                                    <span>@AudiobookDurationLabel(audiobook)</span>
                                                </div>
                                                <div class="audiobooks-book-card__progress-row">
                                                    <progress class="audiobooks-progress" value="@progress" max="100" aria-label="@AudiobookProgressLabel(audiobook)"></progress>
                                                    <span>@AudiobookProgressLabel(audiobook)</span>
                                                </div>
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                        }
                    </section>

                    <section class="audiobooks-section audiobooks-section--featured">
                        <div class="audiobooks-section__header">
                            <h2>Featured Series</h2>
                        </div>

                        @if (FeaturedAudiobookSeries.Count == 0)
                        {
                            <div class="audiobooks-empty">No audiobook series with multiple owned works yet.</div>
                        }
                        else
                        {
                            <div class="audiobooks-featured-grid">
                                @foreach (var series in FeaturedAudiobookSeries)
                                {
                                    <article class="audiobooks-series-card audiobooks-series-card--featured">
                                        <div class="audiobooks-series-card__covers">
                                            <span>
                                                @if (!string.IsNullOrWhiteSpace(series.CoverUrl))
                                                {
                                                    <img src="@series.CoverUrl" alt="@series.DisplayName" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Class="tl-u-font-size-38px" />
                                                }
                                            </span>
                                        </div>
                                        <div class="audiobooks-series-card__copy">
                                            <h3>@series.DisplayName</h3>
                                            <span>@AudiobookSeriesMeta(series)</span>
                                            <p>@AudiobookSeriesDescription(series)</p>
                                            <AppNativeButton Type="button" Class="audiobooks-series-card__action" OnClick="@(() => ViewAudiobookSeries(series))">View Series</AppNativeButton>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    </section>
                </section>
            }
        </main>
    </div>
}
