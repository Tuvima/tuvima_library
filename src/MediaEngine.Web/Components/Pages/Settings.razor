@page "/settings"
@page "/settings/{Section}"
@rendermode InteractiveServer
@namespace MediaEngine.Web.Components.Pages
@using MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs
@inject NavigationManager Nav
@inject DeviceContextService DeviceContext
@inject UIOrchestratorService Orchestrator
@implements IDisposable

<PageTitle>@BrowserTitle</PageTitle>

<SidebarPageShell Class="settings-admin-shell">
    <Rail>
        @foreach (var group in VisibleTreeGroups)
        {
            <SidebarNavGroup Label="@group.Label"
                             Icon="@group.Icon"
                             Expandable="@group.Expandable"
                             Expanded="@IsTreeGroupActive(group)"
                             BadgeCount="@GetGroupBadgeCount(group)">
                @foreach (var item in GetVisibleTreeItems(group))
                {
                    <SidebarNavItem Label="@item.Label"
                                    Icon="@item.Icon"
                                    Href="@SettingsNav.RouteFor(item.Value)"
                                    Active="@(item.Value == _activeSection)"
                                    Child="@(group.Sections.Count > 1)"
                                    Level="@(group.Sections.Count > 1 ? 1 : 0)"
                                    BadgeCount="@GetBadgeCount(item)"
                                    Meta="@(group.Sections.Count > 1 ? null : GetItemMeta(item))" />

                    @if (item.Value == SettingsSection.AdminOverview)
                    {
                        @foreach (var childGroup in GetVisibleChildTreeGroups(group))
                        {
                            <SidebarNavGroup Label="@childGroup.Label"
                                             Icon="@childGroup.Icon"
                                             Expandable="@childGroup.Expandable"
                                             Expanded="@IsTreeGroupActive(childGroup)"
                                             BadgeCount="@GetGroupBadgeCount(childGroup)"
                                             Level="1">
                                @foreach (var childItem in GetVisibleTreeItems(childGroup))
                                {
                                    <SidebarNavItem Label="@childItem.Label"
                                                    Icon="@childItem.Icon"
                                                    Href="@SettingsNav.RouteFor(childItem.Value)"
                                                    Active="@(childItem.Value == _activeSection)"
                                                    Child="true"
                                                    Level="2"
                                                    BadgeCount="@GetBadgeCount(childItem)"
                                                    Meta="@null" />
                                }
                            </SidebarNavGroup>
                        }
                    }
                }
            </SidebarNavGroup>
        }
    </Rail>

    <Header>
        <SidebarPageHeader Eyebrow="@GetHeroEyebrow()"
                           Title="@GetHeroTitle()"
                           Subtitle="@GetSectionDescription(_activeSection)"
                           Status="@GetStatusLabel()"
                           Healthy="@(_systemStatus?.IsHealthy == true)">
            <Actions>
                <SettingsStatusBadge Status="@GetCurrentStatus()" />
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Outlined.RateReview"
                           Href="/settings/review">
                    Review @_reviewCount
                </MudButton>
            </Actions>
        </SidebarPageHeader>
    </Header>

    <ChildContent>
        <div class="settings-admin-style-scope">
            <MudPaper Elevation="0" Class="settings-admin-panel">
                @if (ShouldDeferForRoleResolution)
                {
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                        <MudProgressCircular Indeterminate="true" />
                    </MudStack>
                }
                else
                {
                    @if (IsEngineUnavailableForCurrentSection)
                    {
                        <MudAlert Severity="Severity.Error"
                                  Variant="Variant.Outlined"
                                  Icon="@Icons.Material.Outlined.CloudOff"
                                  Class="mb-4">
                            Engine state could not be loaded. This Settings section is shown in a degraded read-only state, and saved values are not being replaced with sample defaults.
                        </MudAlert>
                    }
                    @if (SettingsNav.GetItem(_activeSection).AdminOnly && !_profileRoleLoaded)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                            Checking profile permissions before showing administrator settings.
                        </MudAlert>
                    }
                    @if (IsLibraryOperationsSection(_activeSection))
                    {
                        <nav class="library-operations-tabs" aria-label="Library Operations sections">
                            @foreach (var tab in LibraryOperationsTabs)
                            {
                                <a class="library-operations-tabs__item @(tab.Section == _activeSection ? "is-active" : null)"
                                   href="@SettingsNav.RouteFor(tab.Section)"
                                   aria-current="@(tab.Section == _activeSection ? "page" : null)">
                                    <MudIcon Icon="@tab.Icon" Size="Size.Small" />
                                    <span>@tab.Label</span>
                                </a>
                            }
                        </nav>
                    }
                    @switch (_activeSection)
                    {
                        case SettingsSection.Overview:
                            <UserOverviewTab />
                            break;
                        case SettingsSection.AdminOverview:
                            <OverviewTab ReviewCount="_reviewCount" />
                            break;
                        case SettingsSection.Playback:
                            <PlaybackTab />
                            break;
                        case SettingsSection.Privacy:
                            <PrivacyHistoryTab />
                            break;
                        case SettingsSection.Libraries:
                            <LibrariesTab />
                            break;
                        case SettingsSection.Ingestion:
                            <IngestionTasksTab />
                            break;
                        case SettingsSection.Providers:
                            <ProviderPriorityTab />
                            break;
                        case SettingsSection.LocalAi:
                            <LocalAiSettingsTab />
                            break;
                        case SettingsSection.Plugins:
                            <PluginSettingsTab />
                            break;
                        case SettingsSection.Delivery:
                            <PlaybackDeliverySettingsTab />
                            break;
                        case SettingsSection.Access:
                            <UsersAccessSettingsTab />
                            break;
                        case SettingsSection.ActivityLogs:
                            <ActivityTab />
                            break;
                        case SettingsSection.Review:
                            <SettingsReviewQueueTab />
                            break;
                        case SettingsSection.Setup:
                            <SetupTab />
                            break;
                        case SettingsSection.ProviderTester:
                            <ProviderTesterToolTab />
                            break;
                        case SettingsSection.EnrichmentTester:
                            <EnrichmentTesterToolTab />
                            break;
                    }
                }
            </MudPaper>
        </div>
    </ChildContent>
</SidebarPageShell>

<CuratorsDrawer Open="@_drawerOpen"
                OpenChanged="@OnDrawerOpenChanged"
                EntityId="@_drawerEntityId"
                CurrentTitle="@_drawerTitle"
                OnCorrected="@OnDrawerCorrected" />

@code {
    [Parameter] public string? Section { get; set; }

    private SettingsSection _activeSection = SettingsSection.Overview;
    private string _currentRole = "Administrator";
    private ProfileViewModel? _activeProfile;
    private bool _profileRoleLoaded;

    private int _reviewCount;
    private SystemStatusViewModel? _systemStatus;
    private bool _shellStateLoading = true;

    private bool _drawerOpen;
    private Guid _drawerEntityId;
    private string _drawerTitle = string.Empty;

    private IReadOnlyList<SettingsTreeGroupDef> VisibleTreeGroups =>
        SettingsNav.FilteredTreeGroups(_currentRole).ToList();

    private SettingsGroupDef CurrentGroup => SettingsNav.GetGroup(_activeSection);
    private string BrowserTitle => $"{GetHeroTitle()} - Tuvima Library";
    private bool ShouldDeferForRoleResolution =>
        !_profileRoleLoaded && SettingsNav.GetItem(_activeSection).AdminOnly;
    private bool IsEngineUnavailableForCurrentSection =>
        !_shellStateLoading
        && _systemStatus is null
        && SettingsNav.GetItem(_activeSection).AdminOnly;

    protected override async Task OnInitializedAsync()
    {
        if (DeviceContext.IsPageDisabled("settings")
            || (DeviceContext.IsPageDisabled("preferences")
                && DeviceContext.IsPageDisabled("server_settings")))
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        ResolveSectionAndNormalize();
        await LoadActiveProfileRoleAsync();
        ResolveSectionAndNormalize();
        await LoadShellStateAsync();

        Orchestrator.OnReviewCountChanged += OnReviewCountChanged;
        Orchestrator.OnProfileChanged += OnProfileChanged;
    }

    protected override void OnParametersSet()
    {
        ResolveSectionAndNormalize();
    }

    public void Dispose()
    {
        Orchestrator.OnReviewCountChanged -= OnReviewCountChanged;
        Orchestrator.OnProfileChanged -= OnProfileChanged;
    }

    public void OpenCuratorsDrawer(Guid entityId, string title)
    {
        _drawerEntityId = entityId;
        _drawerTitle = title;
        _drawerOpen = true;
        StateHasChanged();
    }

    private async Task LoadShellStateAsync()
    {
        _shellStateLoading = true;

        try
        {
            _reviewCount = await Orchestrator.RefreshReviewCountAsync();
        }
        catch
        {
            _reviewCount = 0;
        }

        try
        {
            _systemStatus = await Orchestrator.GetSystemStatusAsync();
        }
        catch
        {
            _systemStatus = null;
        }

        _shellStateLoading = false;
    }

    private async Task LoadActiveProfileRoleAsync()
    {
        try
        {
            _activeProfile = await Orchestrator.GetActiveProfileAsync();
            _currentRole = string.IsNullOrWhiteSpace(_activeProfile?.Role)
                ? "Consumer"
                : _activeProfile.Role;
        }
        catch
        {
            _activeProfile = null;
            _currentRole = "Consumer";
        }
        finally
        {
            _profileRoleLoaded = true;
        }
    }

    private void ResolveSectionAndNormalize()
    {
        var resolution = SettingsNav.ResolveRoute(Section, _currentRole);
        _activeSection = resolution.Section;

        var currentPath = NormalizePath(Nav.ToBaseRelativePath(Nav.Uri));
        var targetPath = NormalizePath(resolution.CanonicalRoute);

        if (!string.Equals(currentPath, targetPath, StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo(resolution.CanonicalRoute, replace: true);
        }
    }

    private static string NormalizePath(string path)
    {
        var relative = path.Split('?', '#')[0].Trim();
        if (string.IsNullOrWhiteSpace(relative))
        {
            return "/";
        }

        return "/" + relative.Trim('/').TrimEnd('/');
    }

    private void OnReviewCountChanged()
    {
        _reviewCount = Orchestrator.ReviewCount;
        InvokeAsync(StateHasChanged);
    }

    private void OnProfileChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadActiveProfileRoleAsync();
            ResolveSectionAndNormalize();
            StateHasChanged();
        });
    }

    private async Task OnDrawerOpenChanged(bool open)
    {
        _drawerOpen = open;
        await Task.CompletedTask;
    }

    private void OnDrawerCorrected()
    {
        _drawerOpen = false;
        StateHasChanged();
    }

    private bool IsTreeGroupActive(SettingsTreeGroupDef group) =>
        group.Sections.Contains(_activeSection)
        || GetVisibleChildTreeGroups(group).Any(childGroup => childGroup.Sections.Contains(_activeSection));

    private int GetGroupBadgeCount(SettingsTreeGroupDef group) =>
        GetVisibleTreeItems(group).Sum(GetBadgeCount)
        + GetVisibleChildTreeGroups(group).Sum(GetGroupBadgeCount);

    private IReadOnlyList<SettingsItemDef> GetVisibleTreeItems(SettingsTreeGroupDef group) =>
        SettingsNav.FilteredTreeItems(group, _currentRole)
            .Where(IsItemEnabledByUiSettings)
            .ToList();

    private IReadOnlyList<SettingsTreeGroupDef> GetVisibleChildTreeGroups(SettingsTreeGroupDef group) =>
        SettingsNav.FilteredChildTreeGroups(group, _currentRole)
            .Where(childGroup => GetVisibleTreeItems(childGroup).Count > 0)
            .ToList();

    private bool IsItemEnabledByUiSettings(SettingsItemDef item) => item.Value switch
    {
        SettingsSection.ProviderTester => DeviceContext.Settings.Features.InternalTools
            && DeviceContext.Settings.Features.ProviderTester
            && !DeviceContext.IsFeatureDisabled("internal_tools")
            && !DeviceContext.IsFeatureDisabled("provider_tester"),
        SettingsSection.EnrichmentTester => DeviceContext.Settings.Features.InternalTools
            && DeviceContext.Settings.Features.EnrichmentTester
            && !DeviceContext.IsFeatureDisabled("internal_tools")
            && !DeviceContext.IsFeatureDisabled("enrichment_tester"),
        _ => true,
    };

    private int GetBadgeCount(SettingsItemDef item) =>
        string.Equals(item.BadgeKey, "review", StringComparison.OrdinalIgnoreCase)
            ? _reviewCount
            : 0;

    private static string? GetItemMeta(SettingsItemDef item) => item.Value switch
    {
        _ => item.Placeholder ? "Planned" : SettingsStatus.Label(item.Status),
    };

    private static readonly LibraryOperationsTabDef[] LibraryOperationsTabs =
    [
        new(SettingsSection.Libraries, "Libraries", Icons.Material.Outlined.FolderOpen),
        new(SettingsSection.Ingestion, "Ingestion", Icons.Material.Outlined.PendingActions),
        new(SettingsSection.Providers, "Providers", Icons.Material.Outlined.Storage),
        new(SettingsSection.ActivityLogs, "Activity", Icons.Material.Outlined.Timeline),
    ];

    private static bool IsLibraryOperationsSection(SettingsSection section) =>
        LibraryOperationsTabs.Any(tab => tab.Section == section);

    private string GetHeroEyebrow() =>
        IsLibraryOperationsSection(_activeSection) ? "Admin Settings" : CurrentGroup.Label;

    private string GetHeroTitle() =>
        IsLibraryOperationsSection(_activeSection)
            ? "Library Operations"
            : SettingsNav.GetItem(_activeSection).Label;

    private SettingsStatusKind GetCurrentStatus() =>
        IsEngineUnavailableForCurrentSection
            ? SettingsStatusKind.EngineUnavailable
            : SettingsNav.GetStatus(_activeSection);

    private string GetStatusLabel()
    {
        if (_shellStateLoading)
        {
            return "Checking engine";
        }

        return _systemStatus?.IsHealthy == true ? "Engine online" : "Engine unavailable";
    }

    private static string GetSectionDescription(SettingsSection section) => section switch
    {
        SettingsSection.Overview => "Your profile, personal history, library habits, and playback activity.",
        SettingsSection.Playback => "Personal defaults for watching, reading, listening, subtitles, resume, and progress behavior.",
        SettingsSection.Privacy => "Control personal history, tracking, personalization, and reset/export options.",
        SettingsSection.AdminOverview => "Monitor system health, library status, provider coverage, ingestion progress, and review work.",
        SettingsSection.Libraries or SettingsSection.Ingestion or SettingsSection.Providers or SettingsSection.ActivityLogs => "Manage ingestion, metadata providers, source folders, organization rules, and activity across your library.",
        SettingsSection.LocalAi => "Manage local models, AI feature toggles, vocabulary, hardware profile, and scheduled enrichment jobs.",
        SettingsSection.Plugins => "Manage optional extension features, tool health, background jobs, and guarded AI access.",
        SettingsSection.Delivery => "Configure direct play, transcoding, generated variants, offline downloads, and delivery defaults.",
        SettingsSection.Access => "Manage profiles, roles, sign-in, API keys, HTTPS, local access, and rate limits.",
        SettingsSection.Review => "Resolve uncertain matches and keep ingestion moving.",
        SettingsSection.Setup => "Guided configuration and readiness checks.",
        SettingsSection.ProviderTester => "Internal provider testing tool.",
        SettingsSection.EnrichmentTester => "Internal enrichment debugging tool.",
        _ => "Settings",
    };

    private sealed record LibraryOperationsTabDef(SettingsSection Section, string Label, string Icon);
}
