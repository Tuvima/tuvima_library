@page "/settings"
@page "/settings/{Section}"
@rendermode InteractiveServer
@namespace MediaEngine.Web.Components.Pages
@inject NavigationManager Nav
@inject DeviceContextService DeviceContext
@inject UIOrchestratorService Orchestrator
@implements IDisposable

@using MediaEngine.Web.Models.ViewDTOs

<PageTitle>Settings — Tuvima Library</PageTitle>

@* ── Dock-clearing wrapper (desktop: clears 64px floating dock) ── *@
<div class="settings-page-outer">

    @* ── Page header ────────────────────────────────────────────── *@
    <MudText Typo="Typo.h4" Class="mb-1">Settings</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Manage your experience.
    </MudText>

    @* ── Content area ───────────────────────────────────────────── *@
    <div class="settings-content-area">
        @RenderActiveTab
    </div>

</div>

@* ── Curator's Drawer (migrated from ServerSettings.razor) ───────────── *@
<CuratorsDrawer Open="@_drawerOpen"
                OpenChanged="@OnDrawerOpenChanged"
                EntityId="@_drawerEntityId"
                CurrentTitle="@_drawerTitle"
                OnCorrected="@OnDrawerCorrected" />

@code {
    // ── Route parameter ─────────────────────────────────────────────────────

    [Parameter] public string? Section { get; set; }

    // ── Active section state ────────────────────────────────────────────────

    private SettingsSection _activeSection = SettingsSection.Profile;

    // Default to Administrator until profile session management is wired.
    private string _currentRole = "Administrator";

    // ── Badge data ──────────────────────────────────────────────────────────

    private int _reviewCount;

    // ── Curator's Drawer state (migrated from ServerSettings.razor) ─────────

    private bool   _drawerOpen;
    private Guid   _drawerEntityId;
    private string _drawerTitle = string.Empty;

    // ── Lifecycle ───────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        // Redirect to home if settings page is disabled for this device class.
        if (DeviceContext.IsPageDisabled("settings")
            || (DeviceContext.IsPageDisabled("preferences")
                && DeviceContext.IsPageDisabled("server_settings")))
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        // Parse deep-link route parameter.
        ParseSection();

        // Fetch badge counts eagerly.
        await LoadReviewCountAsync();

        // Keep badge live while the Settings page is open.
        Orchestrator.OnReviewCountChanged += OnReviewCountChanged;
    }

    protected override void OnParametersSet()
    {
        ParseSection();
    }

    public void Dispose()
    {
        Orchestrator.OnReviewCountChanged -= OnReviewCountChanged;
    }

    private void OnReviewCountChanged()
    {
        _reviewCount = Orchestrator.ReviewCount;
        InvokeAsync(StateHasChanged);
    }

    // ── Deep-link parsing ───────────────────────────────────────────────────

    private void ParseSection()
    {
        var parsed = SettingsNav.ParseFromRoute(Section);
        if (parsed.HasValue)
            _activeSection = parsed.Value;
    }

    // ── Badge data loading ──────────────────────────────────────────────────

    private async Task LoadReviewCountAsync()
    {
        try
        {
            _reviewCount = await Orchestrator.RefreshReviewCountAsync();
        }
        catch
        {
            // Engine may be offline — badge stays at 0.
        }
    }

    // ── Curator's Drawer handlers (migrated from ServerSettings.razor) ──────

    /// <summary>
    /// Opens the Curator's Drawer for a specific entity.
    /// Called by child components (e.g. ConflictsTab) when the user clicks "Resolve".
    /// </summary>
    public void OpenCuratorsDrawer(Guid entityId, string title)
    {
        _drawerEntityId = entityId;
        _drawerTitle    = title;
        _drawerOpen     = true;
        StateHasChanged();
    }

    private async Task OnDrawerOpenChanged(bool open)
    {
        _drawerOpen = open;
        await Task.CompletedTask;
    }

    private void OnDrawerCorrected()
    {
        _drawerOpen = false;
        StateHasChanged();
    }

    private void OnConflictResolveClicked((Guid EntityId, string Key) args)
    {
        OpenCuratorsDrawer(args.EntityId, $"Resolve: {args.Key}");
    }

    // ── Role helpers ────────────────────────────────────────────────────────

    private bool HasAdminAccess =>
        string.Equals(_currentRole, "Administrator", StringComparison.OrdinalIgnoreCase)
        || string.Equals(_currentRole, "Curator", StringComparison.OrdinalIgnoreCase);

    // ── Content rendering ───────────────────────────────────────────────────

    private RenderFragment RenderActiveTab => __builder =>
    {
        switch (_activeSection)
        {
            // ── Preferences ──────────────────────────────────────────────
            case SettingsSection.Profile:
                <ProfileTab />
                break;
            case SettingsSection.Playback:
                <PlaybackTab />
                break;

            // ── Providers ────────────────────────────────────────────────
            case SettingsSection.ProviderConnections:
                // Absorbed into ProviderPriority — redirect
                Nav.NavigateTo(SettingsNav.RouteFor(SettingsSection.ProviderPriority), replace: true);
                break;
            case SettingsSection.ProviderPriority:
                <ProviderPriorityTab />
                break;
            case SettingsSection.WikidataConfig:
                <WikidataConfigTab />
                break;

            // ── Intelligence ─────────────────────────────────────────────
            case SettingsSection.AiModels:
                <ModelsTab />
                break;
            case SettingsSection.AiFeatures:
                <AiFeaturesTab />
                break;
            case SettingsSection.VibeVocabulary:
                <VibeVocabularyTab />
                break;
            case SettingsSection.AiSchedule:
                <AiScheduleTab />
                break;

            // ── Library ──────────────────────────────────────────────────
            case SettingsSection.LibraryFolders:
                <LibrariesTab />
                break;

            // ── Server ───────────────────────────────────────────────────
            case SettingsSection.StatusDashboard:
                <StatusDashboardTab />
                break;
            case SettingsSection.Security:
                <SecurityTab />
                break;
            case SettingsSection.Users:
                <UsersTab />
                break;
            case SettingsSection.Activity:
                <ActivityTab />
                break;
            case SettingsSection.Maintenance:
                <MaintenanceTab />
                break;
            case SettingsSection.Setup:
                <SetupTab />
                break;
        }
    };
}

<style>
    /* ── Outer wrapper: dock-clearing left indent (desktop only) ─── */
    /* Dock: left:12px + width:64px = right edge at 76px from screen.     */
    /* MudContainer adds 32px. We add 88px here → total 120px from edge,  */
    /* matching the swimlane content alignment.                            */
    @@media (min-width: 769px) {
        .settings-page-outer {
            padding-left: 16px;
        }
    }

    /* ── Content area ────────────────────────────────────────────────── */
    .settings-content-area {
        min-width: 0;
        max-width: 1100px;
    }

    /* ── Mobile / narrow viewport overrides ──────────────────────────── */
    @@media (max-width: 768px) {
        /* Reduce outer glass card padding: 32px → 16px */
        .settings-content-area > .mud-paper {
            padding: 16px !important;
        }

        /* Reduce inner card padding: 24px → 14px */
        .settings-content-area .mud-paper .mud-paper {
            padding: 14px !important;
        }
    }
</style>
