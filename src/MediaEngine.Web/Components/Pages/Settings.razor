@page "/settings"
@page "/settings/{Section}"
@rendermode InteractiveServer
@namespace MediaEngine.Web.Components.Pages
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs
@inject NavigationManager Nav
@inject DeviceContextService DeviceContext
@inject UIOrchestratorService Orchestrator
@implements IDisposable

<PageTitle>@BrowserTitle</PageTitle>

<div class="settings-shell">
    <AppPageHeader Eyebrow="Settings"
                   Title="@GetHeroTitle()"
                   Subtitle="@GetSectionDescription(_activeSection)"
                   StatusText="@GetStatusLabel()"
                   StatusTone="@GetStatusTone()"
                   Class="settings-shell-header">
        <Actions>
            <div class="settings-shell-role">
                <span class="settings-shell-role-label">Role</span>
                <span class="settings-shell-role-value">@_currentRole</span>
            </div>
        </Actions>

        <Stats>
            <div class="settings-shell-stats">
                <a href="/settings/review" class="settings-shell-stat settings-shell-stat--interactive">
                    <span class="settings-shell-stat-label">Pending review</span>
                    <span class="settings-shell-stat-value">@_reviewCount</span>
                </a>
                <div class="settings-shell-stat">
                    <span class="settings-shell-stat-label">Current area</span>
                    <span class="settings-shell-stat-value">@CurrentGroup.Label</span>
                </div>
                <div class="settings-shell-stat">
                    <span class="settings-shell-stat-label">Version</span>
                    <span class="settings-shell-stat-value">@(_systemStatus?.Version ?? "Unavailable")</span>
                </div>
            </div>
        </Stats>

        <ChildContent>
            <AppTabs Items="PrimaryTabItems"
                     ActiveKey="@CurrentGroup.Key"
                     AriaLabel="Settings sections"
                     UseTabRoles="false"
                     Class="settings-shell-primary-tabs" />

            @if (CurrentGroupItems.Count > 1)
            {
                <AppTabs Items="SecondaryTabItems"
                         ActiveKey="@_activeSection.ToString()"
                         Variant="secondary"
                         AriaLabel="@($"{CurrentGroup.Label} pages")"
                         UseTabRoles="false"
                         Class="settings-shell-secondary-tabs" />
            }
        </ChildContent>
    </AppPageHeader>

    <section class="settings-shell-panel">
        @switch (_activeSection)
        {
            case SettingsSection.Overview:
                <OverviewTab ReviewCount="_reviewCount" />
                break;
            case SettingsSection.Review:
                <LibraryPage ReviewOnly="true"
                             ShowReviewOverview="false"
                             HideTitleRow="true"
                             ReviewRoute="/settings/review" />
                break;
            case SettingsSection.Profile:
                <ProfileTab />
                break;
            case SettingsSection.Playback:
                <PlaybackTab />
                break;
            case SettingsSection.Folders:
                <LibrariesTab />
                break;
            case SettingsSection.Providers:
                <ProviderPriorityTab />
                break;
            case SettingsSection.Wikidata:
                <WikidataConfigTab />
                break;
            case SettingsSection.Models:
                <ModelsTab />
                break;
            case SettingsSection.Features:
                <AiFeaturesTab />
                break;
            case SettingsSection.Vocabulary:
                <VibeVocabularyTab />
                break;
            case SettingsSection.Schedule:
                <AiScheduleTab />
                break;
            case SettingsSection.System:
                <SystemTab />
                break;
            case SettingsSection.Security:
                <SecurityTab />
                break;
            case SettingsSection.Users:
                <UsersTab />
                break;
            case SettingsSection.Activity:
                <ActivityTab />
                break;
            case SettingsSection.Maintenance:
                <MaintenanceTab />
                break;
            case SettingsSection.Setup:
                <SetupTab />
                break;
        }
    </section>
</div>

<CuratorsDrawer Open="@_drawerOpen"
                OpenChanged="@OnDrawerOpenChanged"
                EntityId="@_drawerEntityId"
                CurrentTitle="@_drawerTitle"
                OnCorrected="@OnDrawerCorrected" />

@code {
    [Parameter] public string? Section { get; set; }

    private SettingsSection _activeSection = SettingsSection.Overview;
    private readonly string _currentRole = "Administrator";

    private int _reviewCount;
    private SystemStatusViewModel? _systemStatus;
    private bool _shellStateLoading = true;

    private bool _drawerOpen;
    private Guid _drawerEntityId;
    private string _drawerTitle = string.Empty;

    private IReadOnlyList<SettingsGroupDef> VisibleGroups => SettingsNav.FilteredGroups(_currentRole).ToList();
    private SettingsGroupDef CurrentGroup => SettingsNav.GetGroup(_activeSection);
    private IReadOnlyList<SettingsItemDef> CurrentGroupItems => SettingsNav.FilteredItems(CurrentGroup, _currentRole);
    private string BrowserTitle => $"{GetHeroTitle()} - Tuvima Library";
    private IReadOnlyList<AppNavItem> PrimaryTabItems =>
        VisibleGroups
            .Select(group => new AppNavItem
            {
                Key = group.Key,
                Label = group.Label,
                Icon = group.Icon,
                Href = SettingsNav.RouteFor(group.DefaultSection),
                Badge = FormatBadge(GetBadgeCount(SettingsNav.GetItem(group.DefaultSection)))
            })
            .ToList();

    private IReadOnlyList<AppNavItem> SecondaryTabItems =>
        CurrentGroupItems
            .Select(item => new AppNavItem
            {
                Key = item.Value.ToString(),
                Label = item.Label,
                Href = SettingsNav.RouteFor(item.Value),
                Badge = FormatBadge(GetBadgeCount(item))
            })
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        if (DeviceContext.IsPageDisabled("settings")
            || (DeviceContext.IsPageDisabled("preferences")
                && DeviceContext.IsPageDisabled("server_settings")))
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        ResolveSectionAndNormalize();
        await LoadShellStateAsync();

        Orchestrator.OnReviewCountChanged += OnReviewCountChanged;
    }

    protected override void OnParametersSet()
    {
        ResolveSectionAndNormalize();
    }

    public void Dispose()
    {
        Orchestrator.OnReviewCountChanged -= OnReviewCountChanged;
    }

    public void OpenCuratorsDrawer(Guid entityId, string title)
    {
        _drawerEntityId = entityId;
        _drawerTitle = title;
        _drawerOpen = true;
        StateHasChanged();
    }

    private async Task LoadShellStateAsync()
    {
        _shellStateLoading = true;

        try
        {
            _reviewCount = await Orchestrator.RefreshReviewCountAsync();
        }
        catch
        {
            _reviewCount = 0;
        }

        try
        {
            _systemStatus = await Orchestrator.GetSystemStatusAsync();
        }
        catch
        {
            _systemStatus = null;
        }

        _shellStateLoading = false;
    }

    private static string? FormatBadge(int count) => count > 0 ? count.ToString() : null;

    private void ResolveSectionAndNormalize()
    {
        var resolution = SettingsNav.ResolveRoute(Section, _currentRole);
        _activeSection = resolution.Section;

        var currentPath = NormalizePath(Nav.ToBaseRelativePath(Nav.Uri));
        var targetPath = NormalizePath(resolution.CanonicalRoute);

        if (!string.Equals(currentPath, targetPath, StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo(resolution.CanonicalRoute, replace: true);
        }
    }

    private static string NormalizePath(string path)
    {
        var relative = path.Split('?', '#')[0].Trim();
        if (string.IsNullOrWhiteSpace(relative))
            return "/";

        return "/" + relative.Trim('/').TrimEnd('/');
    }

    private void OnReviewCountChanged()
    {
        _reviewCount = Orchestrator.ReviewCount;
        InvokeAsync(StateHasChanged);
    }

    private async Task OnDrawerOpenChanged(bool open)
    {
        _drawerOpen = open;
        await Task.CompletedTask;
    }

    private void OnDrawerCorrected()
    {
        _drawerOpen = false;
        StateHasChanged();
    }

    private int GetBadgeCount(SettingsItemDef item) =>
        string.Equals(item.BadgeKey, "review", StringComparison.OrdinalIgnoreCase)
            ? _reviewCount
            : 0;

    private string GetHeroTitle() =>
        _activeSection == SettingsSection.Overview
            ? "Settings"
            : SettingsNav.GetItem(_activeSection).Label;

    private string GetStatusLabel()
    {
        if (_shellStateLoading)
            return "Checking engine";

        return _systemStatus?.IsHealthy == true ? "Engine online" : "Engine unavailable";
    }

    private string GetStatusTone() =>
        _shellStateLoading
            ? "neutral"
            : _systemStatus?.IsHealthy == true
                ? "healthy"
                : "warning";

    private static string GetSectionDescription(SettingsSection section) => section switch
    {
        SettingsSection.Overview => "Operational overview for ingestion, review, and library readiness.",
        SettingsSection.Review => "Resolve uncertain matches and keep the ingestion queue moving.",
        SettingsSection.Profile => "Account identity, locale, and personal defaults.",
        SettingsSection.Playback => "Default behavior for the built-in readers and players.",
        SettingsSection.Folders => "Watch paths, library roots, and file organization settings.",
        SettingsSection.Providers => "Provider priority, credentials, and enrichment coverage.",
        SettingsSection.Wikidata => "Identity resolution and Stage 3 universe enrichment controls.",
        SettingsSection.Models => "Installed AI models and runtime choices.",
        SettingsSection.Features => "Feature flags and AI workflow controls.",
        SettingsSection.Vocabulary => "Vocabulary tuning for vibe and recommendation features.",
        SettingsSection.Schedule => "Background timing for enrichment and AI jobs.",
        SettingsSection.System => "Live server health and core runtime settings.",
        SettingsSection.Security => "Connection rules, API keys, and access controls.",
        SettingsSection.Users => "Profiles, roles, and user management.",
        SettingsSection.Activity => "Recent operational history and retention.",
        SettingsSection.Maintenance => "Repair, cleanup, and recovery tools.",
        SettingsSection.Setup => "Guided configuration and readiness checks.",
        _ => "Settings",
    };
}
