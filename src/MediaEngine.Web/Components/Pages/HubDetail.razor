@page "/hub/{Id:guid}"
@inject UIOrchestratorService  Orchestrator
@inject UniverseStateContainer  State
@inject NavigationManager       Nav

<PageTitle>@(_hub?.DisplayName ?? "Hub") — Tuvima Library</PageTitle>

@* ── Edit-metadata drawer (stub) ───────────────────────────────────────────── *@
<MudDrawer @bind-Open="_editDrawerOpen" Anchor="Anchor.Right" Elevation="2"
           Variant="DrawerVariant.Temporary" Width="420px"
           Style="background: #0D1120; border-left: 1px solid rgba(255,255,255,0.08);">
    <MudDrawerHeader Style="border-bottom: 1px solid rgba(255,255,255,0.07); padding: 16px 20px;">
        <div style="display:flex; align-items:center; gap:12px; width:100%;">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Style="color: #C9922E;" />
            <MudText Typo="Typo.subtitle1"
                     Style="font-family:'Montserrat',sans-serif; font-weight:600; color:rgba(248,248,248,0.90); flex:1;">
                Edit Metadata
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _editDrawerOpen = false)"
                           Style="color:rgba(248,248,248,0.45);" />
        </div>
    </MudDrawerHeader>
    <div style="padding:28px 24px; display:flex; flex-direction:column; gap:20px;">
        <MudAlert Severity="Severity.Info" Dense="true"
                  Style="background:rgba(99,141,255,0.10); border:1px solid rgba(99,141,255,0.20); border-radius:10px;">
            Full metadata editing is coming in the next update.
            For now you can update metadata automatically, or go to Settings → Metadata.
        </MudAlert>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Sync"
                   OnClick="@OnUpdateMetadata"
                   Style="text-transform:none; font-family:'Montserrat',sans-serif; font-weight:600; border-radius:8px;">
            Update Metadata Now
        </MudButton>
        <MudButton Variant="Variant.Text" FullWidth="true"
                   OnClick="@(() => { _editDrawerOpen = false; Nav.NavigateTo("/settings"); })"
                   Style="text-transform:none; font-family:'Montserrat',sans-serif; color:rgba(248,248,248,0.50);">
            Open Settings → Metadata
        </MudButton>
    </div>
</MudDrawer>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else if (_hub is null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">Hub not found.</MudAlert>
    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Nav.NavigateTo("/"))">
        Back to Home
    </MudButton>
}
else
{
    @* ── Fixed hero background ── *@
    @if (!string.IsNullOrEmpty(_hub.HeroUrl))
    {
        <div class="detail-hero-fixed">
            <img src="@_hub.HeroUrl" alt="" />
        </div>
        <div class="detail-hero-fade"></div>
    }
    else if (!string.IsNullOrEmpty(_hub.CoverUrl))
    {
        <div class="detail-hero-fixed detail-hero-cover-blur">
            <img src="@_hub.CoverUrl" alt="" />
        </div>
        <div class="detail-hero-fade"></div>
    }

    @* ── Scrollable content layer ── *@
    <div class="detail-content-layer hub-detail-page">

        @* ── Breadcrumb (centered) ── *@
        <div class="hub-detail-breadcrumb-outer">
            <nav class="hub-detail-breadcrumb">
                <button class="hub-detail-bc-link" @onclick="@(() => Nav.NavigateTo("/"))">Home</button>
                <span class="hub-detail-bc-sep">/</span>
                <button class="hub-detail-bc-link" @onclick="@(() => Nav.NavigateTo(GetLane().Route))">@GetLane().Label</button>
                @if (!string.IsNullOrEmpty(_hub.Author))
                {
                    <span class="hub-detail-bc-sep">/</span>
                    @if (_authorPerson is not null)
                    {
                        <button class="hub-detail-bc-link hub-detail-bc-author"
                                @onclick="@(() => Nav.NavigateTo($"/person/{_authorPerson.Id}"))">
                            @_hub.Author
                        </button>
                    }
                    else
                    {
                        <span class="hub-detail-bc-current">@_hub.Author</span>
                    }
                }
            </nav>
        </div>

        @* ── Main 3-column panel ── *@
        <div class="hub-detail-main-outer">
            <div class="hub-detail-main-panel">

                @* Left sidebar *@
                <aside class="hub-detail-sidebar">

                    @if (!string.IsNullOrEmpty(_hub.Author))
                    {
                        <div class="hub-detail-sidebar-item">
                            <span class="hub-detail-sidebar-label">Author</span>
                            @if (_authorPerson is not null)
                            {
                                <button class="hub-detail-sidebar-author"
                                        @onclick="@(() => Nav.NavigateTo($"/person/{_authorPerson.Id}"))">
                                    @_hub.Author
                                </button>
                            }
                            else
                            {
                                <span class="hub-detail-sidebar-value">@_hub.Author</span>
                            }
                        </div>
                    }

                    <div class="hub-detail-sidebar-item">
                        <span class="hub-detail-sidebar-label">Format</span>
                        <span class="hub-detail-sidebar-value">@PrimaryFormatLabel()</span>
                    </div>

                    @{
                        var genres      = GenreTags;
                        var visibleGenres = _showAllGenres ? genres : genres.Take(3).ToList();
                        var hiddenCount   = genres.Count - 3;
                    }
                    @if (genres.Count > 0)
                    {
                        <div class="hub-detail-sidebar-item">
                            <span class="hub-detail-sidebar-label">Genre(s)</span>
                            <div class="hub-detail-genre-row">
                                @foreach (var tag in visibleGenres)
                                {
                                    <span class="hub-detail-genre-chip">@tag</span>
                                }
                                @if (!_showAllGenres && hiddenCount > 0)
                                {
                                    <button class="hub-detail-genre-more"
                                            @onclick="@(() => _showAllGenres = true)">
                                        +@hiddenCount more
                                    </button>
                                }
                                @if (_showAllGenres && genres.Count > 3)
                                {
                                    <button class="hub-detail-genre-more"
                                            @onclick="@(() => _showAllGenres = false)">
                                        Less
                                    </button>
                                }
                            </div>
                        </div>
                    }

                </aside>

                @* Center content *@
                <div class="hub-detail-content">

                    @* Title *@
                    <h1 class="hub-detail-title">@_hub.DisplayName</h1>

                    @* Metadata row: rating | reading time | year *@
                    @{
                        var ratingStars = GetRatingStars();
                        var hasRating   = !string.IsNullOrEmpty(ratingStars);
                        var hasTime     = _readingTimeDisplay is not null;
                        var hasYear     = !string.IsNullOrEmpty(_hub.Year);
                        var metaCount   = (hasRating ? 1 : 0) + (hasTime ? 1 : 0) + (hasYear ? 1 : 0);
                    }
                    @if (metaCount > 0)
                    {
                        <div class="hub-detail-meta-row">
                            @if (hasRating)
                            {
                                <span class="hub-detail-meta-segment">
                                    <span class="hub-detail-meta-stars">@ratingStars</span>
                                    <span class="hub-detail-meta-rating-val">@_hub.Rating</span>
                                </span>
                            }
                            @if (hasRating && (hasTime || hasYear))
                            {
                                <span class="hub-detail-meta-divider">|</span>
                            }
                            @if (hasTime)
                            {
                                <span class="hub-detail-meta-segment">@_readingTimeDisplay</span>
                            }
                            @if (hasTime && hasYear)
                            {
                                <span class="hub-detail-meta-divider">|</span>
                            }
                            @if (hasYear)
                            {
                                <span class="hub-detail-meta-segment">@_hub.Year</span>
                            }
                        </div>
                    }

                    @* Action bar — circular icon buttons *@
                    <div class="hub-detail-actions">

                        @* Read / Watch / Listen *@
                        <button class="hub-detail-action-btn" @onclick="@OnPrimaryAction">
                            <div class="hub-detail-action-circle hub-detail-action-circle-primary">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow"
                                         Style="color: #C9922E; font-size: 1.6rem;" />
                            </div>
                            <span class="hub-detail-action-label">@PrimaryActionShort()</span>
                        </button>

                        @* Add To *@
                        <button class="hub-detail-action-btn" @onclick="@OnAddTo">
                            <div class="hub-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.PlaylistAdd"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.4rem;" />
                            </div>
                            <span class="hub-detail-action-label">Add To</span>
                        </button>

                        @* Share *@
                        <button class="hub-detail-action-btn" @onclick="@OnShare">
                            <div class="hub-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.IosShare"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.3rem;" />
                            </div>
                            <span class="hub-detail-action-label">Share</span>
                        </button>

                        @* Edit *@
                        <button class="hub-detail-action-btn" @onclick="@(() => _editDrawerOpen = true)">
                            <div class="hub-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.Edit"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.3rem;" />
                            </div>
                            <span class="hub-detail-action-label">Edit</span>
                        </button>

                        @* ⋯ More *@
                        <MudMenu Dense="true"
                                 AnchorOrigin="Origin.BottomLeft"
                                 TransformOrigin="Origin.TopLeft">
                            <ActivatorContent>
                                <button class="hub-detail-action-btn">
                                    <div class="hub-detail-action-circle">
                                        <MudIcon Icon="@Icons.Material.Filled.MoreHoriz"
                                                 Style="color: rgba(248,248,248,0.65); font-size: 1.4rem;" />
                                    </div>
                                    <span class="hub-detail-action-label">More</span>
                                </button>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenuItem OnClick="@OnUpdateMetadata"
                                             Icon="@Icons.Material.Filled.Sync">
                                    Update Metadata
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(async () => await OnMarkFinished())"
                                             Icon="@Icons.Material.Filled.CheckCircle">
                                    Mark as Finished
                                </MudMenuItem>
                                <MudMenuItem OnClick="@OnReportIssue"
                                             Icon="@Icons.Material.Filled.Flag">
                                    Report Issue
                                </MudMenuItem>
                                <MudDivider />
                                <MudMenuItem Disabled="true"
                                             Icon="@Icons.Material.Filled.DeleteForever">
                                    Delete
                                </MudMenuItem>
                            </ChildContent>
                        </MudMenu>

                    </div>

                    @* Description *@
                    @if (!string.IsNullOrEmpty(_hub.Description))
                    {
                        <div class="hub-detail-description-wrap">
                            <p class="hub-detail-description">
                                @(_showFullDescription ? _hub.Description : Truncate(_hub.Description, 400))
                            </p>
                            @if (_hub.Description.Length > 400)
                            {
                                <button class="hub-detail-expand-btn"
                                        @onclick="@(() => _showFullDescription = !_showFullDescription)">
                                    @(_showFullDescription ? "Show less" : "Show more")
                                </button>
                            }
                        </div>
                    }

                    @* Progress bar *@
                    @if (_activeJourney is not null && _activeJourney.ProgressPct is > 0 and < 99.5)
                    {
                        <div class="hub-detail-progress-wrap">
                            <div class="hub-detail-progress-bar-track">
                                <div class="hub-detail-progress-bar-fill"
                                     style="width: @(_activeJourney.ProgressPct.ToString("F0"))%">
                                </div>
                            </div>
                            <span class="hub-detail-progress-label">@_activeJourney.ProgressDisplay</span>
                        </div>
                    }


                </div>

                @* Right: Cover art *@
                <div class="hub-detail-cover-wrap">
                    @if (!string.IsNullOrEmpty(_hub.CoverUrl))
                    {
                        <img src="@_hub.CoverUrl" alt="@_hub.DisplayName"
                             class="hub-detail-cover @(IsAudiobookHub() ? "hub-detail-cover-audio" : "")" />
                    }
                    else
                    {
                        <div class="hub-detail-cover @(IsAudiobookHub() ? "hub-detail-cover-audio" : "") hub-detail-cover-placeholder">
                            <MudIcon Icon="@GetHubIcon()" Style="font-size: 64px; color: rgba(255,255,255,0.18);" />
                        </div>
                    }
                </div>

            </div>
        </div>

        @* ── Related content swimlane ── *@
        @if (_related is not null && _related.Hubs.Count > 0)
        {
            <div class="hub-detail-related-section">
                <PosterSwimlane Title="@_related.SectionTitle"
                                Hubs="@_related.Hubs.ToList()"
                                OnHubSelected="@(hub => Nav.NavigateTo($"/hub/{hub.Id}"))" />
            </div>
        }

        @* ── Author section (full-width, bottom) ── *@
        @if (_authorPerson is not null)
        {
            <div class="hub-detail-author-section">
                <div class="hub-detail-author-inner">
                    <span class="hub-detail-author-section-label">Author</span>
                    <div class="hub-detail-author-circle-wrap"
                         @onclick="@(() => Nav.NavigateTo($"/person/{_authorPerson.Id}"))">
                        @if (!string.IsNullOrEmpty(_authorPerson.LocalHeadshotUrl))
                        {
                            <img src="@_authorPerson.LocalHeadshotUrl" alt="@_authorPerson.Name"
                                 class="hub-detail-author-circle" />
                        }
                        else if (!string.IsNullOrEmpty(_authorPerson.HeadshotUrl))
                        {
                            <img src="@_authorPerson.HeadshotUrl" alt="@_authorPerson.Name"
                                 class="hub-detail-author-circle" />
                        }
                        else
                        {
                            <div class="hub-detail-author-circle hub-detail-author-circle-initials">
                                @_authorPerson.Initials
                            </div>
                        }
                    </div>
                    <button class="hub-detail-author-link"
                            @onclick="@(() => Nav.NavigateTo($"/person/{_authorPerson.Id}"))">
                        @_authorPerson.Name
                    </button>
                </div>
            </div>
        }

    </div>
}

@* ── Toast ── *@
@if (_toastMessage is not null)
{
    <div class="hub-detail-toast">@_toastMessage</div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool                    _loading            = true;
    private HubViewModel?           _hub;
    private PersonViewModel?        _authorPerson;
    private JourneyItemViewModel?   _activeJourney;
    private RelatedHubsViewModel?   _related;
    private string?                 _readingTimeDisplay;
    private string?                 _toastMessage;
    private bool                    _showFullDescription;
    private bool                    _showAllGenres;
    private bool                    _editDrawerOpen;
    private System.Threading.Timer? _toastTimer;

    // ── Lifecycle ───────────────────────────────────────────────────────────

    protected override async Task OnParametersSetAsync()
    {
        _loading             = true;
        _showFullDescription = false;
        _showAllGenres       = false;
        _editDrawerOpen      = false;

        if (!State.IsLoaded)
            await Orchestrator.GetHubsAsync();

        _hub = State.Hubs.FirstOrDefault(h => h.Id == Id);

        if (_hub is not null)
        {
            var personsTask  = Orchestrator.GetPersonsByHubAsync(Id);
            var journeyTask  = Orchestrator.GetJourneyAsync(limit: 50);
            var relatedTask  = Orchestrator.GetRelatedHubsAsync(Id);

            await Task.WhenAll(personsTask, journeyTask, relatedTask);

            var persons = personsTask.Result;
            var journey = journeyTask.Result;
            _related    = relatedTask.Result;

            _authorPerson = persons.FirstOrDefault(p =>
                string.Equals(p.Role, "Author", StringComparison.OrdinalIgnoreCase) &&
                string.Equals(p.Name, _hub.Author, StringComparison.OrdinalIgnoreCase))
                ?? persons.FirstOrDefault(p =>
                string.Equals(p.Role, "Author", StringComparison.OrdinalIgnoreCase));

            var hubWorkIds = _hub.Works.Select(w => w.Id).ToHashSet();
            _activeJourney = journey
                .Where(j => j.HubId == Id || hubWorkIds.Contains(j.WorkId))
                .OrderByDescending(j => j.LastAccessed)
                .FirstOrDefault();

            _readingTimeDisplay = _hub.Works
                .Select(w => w.ReadingTimeDisplay)
                .FirstOrDefault(s => !string.IsNullOrEmpty(s));
        }

        _loading = false;
    }

    // ── Action handlers ──────────────────────────────────────────────────────

    private void OnPrimaryAction() => ShowToast("Playback coming soon");

    private void OnAddTo()       => ShowToast("Reading list coming soon");

    private void OnShare()       => ShowToast("Share link copied");

    private void OnReportIssue() => ShowToast("Issue reporting coming soon");

    private async Task OnMarkFinished()
    {
        if (_hub is null) return;
        var work = _hub.Works.FirstOrDefault();
        if (work is null) { ShowToast("No media asset found"); return; }
        await Orchestrator.SaveProgressAsync(work.Id, null, 100.0);
        ShowToast("Marked as finished ✓");
    }

    private async Task OnUpdateMetadata()
    {
        var workId = _hub?.Works.FirstOrDefault()?.Id;
        if (workId is null) { ShowToast("No content found to update"); return; }
        ShowToast("Updating metadata\u2026");
        var result = await Orchestrator.TriggerHydrationAsync(workId.Value);
        ShowToast(result is not null
            ? "Metadata updated successfully"
            : "Metadata update failed — check Engine logs");
    }

    private void ShowToast(string message)
    {
        _toastMessage = message;
        _toastTimer?.Dispose();
        _toastTimer = new System.Threading.Timer(_ =>
        {
            _toastMessage = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, System.Threading.Timeout.Infinite);
        StateHasChanged();
    }

    // ── Display helpers ──────────────────────────────────────────────────────

    private List<string> GenreTags =>
        _hub?.Genre?
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .ToList() ?? [];

    private (string Label, string Route) GetLane()
    {
        var mt = _hub?.PrimaryMediaType?.ToLowerInvariant() ?? "";
        if (mt.Contains("m4b") || mt.Contains("audiobook") || mt.Contains("audio"))
                                                                                   return ("Audiobooks", "/books");
        if (mt.Contains("epub") || mt.Contains("book"))                            return ("Books",      "/books");
        if (mt.Contains("video") || mt.Contains("movie") || mt.Contains("mkv") ||
            mt.Contains("mp4")   || mt.Contains("tv"))                             return ("Video",      "/video");
        if (mt.Contains("comic") || mt.Contains("cbz"))                            return ("Comics",     "/comics");
        if (mt.Contains("music"))                                                   return ("Music",      "/music");
        if (mt.Contains("podcast"))                                                 return ("Podcasts",   "/podcasts");
        return ("Books", "/books");
    }

    private string PrimaryActionShort()
    {
        var mt = _hub?.PrimaryMediaType?.ToLowerInvariant() ?? "";
        if (mt.Contains("video") || mt.Contains("movie") || mt.Contains("mkv")) return "Watch";
        if (mt.Contains("audio") || mt.Contains("m4b"))                          return "Listen";
        return "Read";
    }

    private string PrimaryFormatLabel()
    {
        var mt = _hub?.PrimaryMediaType?.ToLowerInvariant() ?? "";
        if (mt.Contains("epub") || mt.Contains("book"))    return "Book";
        if (mt.Contains("video") || mt.Contains("movie"))  return "Movie";
        if (mt.Contains("audio") || mt.Contains("m4b"))    return "Audiobook";
        if (mt.Contains("comic") || mt.Contains("cbz"))    return "Comic";
        if (mt.Contains("mkv")   || mt.Contains("mp4"))    return "Video";
        return _hub?.MediaTypes ?? "Media";
    }

    private string GetRatingStars()
    {
        if (string.IsNullOrEmpty(_hub?.Rating)) return "";
        if (!double.TryParse(_hub.Rating,
                System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture,
                out var r))
            return "";
        r = Math.Max(0, Math.Min(5, r));
        var full  = (int)Math.Floor(r);
        var empty = 5 - full;
        return new string('\u2605', full) + new string('\u2606', empty);
    }

    private bool IsAudiobookHub()
    {
        var mt = _hub?.PrimaryMediaType?.ToLowerInvariant() ?? "";
        return mt.Contains("audio") || mt.Contains("m4b") || mt == "audiobook";
    }

    private bool HasAudiobook() =>
        _hub?.Works.Any(w => { var t = w.MediaType.ToLowerInvariant(); return t.Contains("audio") || t.Contains("m4b"); }) ?? false;

    private bool HasBook() =>
        _hub?.Works.Any(w => { var t = w.MediaType.ToLowerInvariant(); return t.Contains("epub") || t.Contains("book"); }) ?? false;

    private string GetHubIcon()
    {
        var mt = _hub?.PrimaryMediaType?.ToLowerInvariant() ?? "";
        if (mt.Contains("video") || mt.Contains("movie")) return Icons.Material.Filled.PlayCircle;
        if (mt.Contains("epub")  || mt.Contains("book"))  return Icons.Material.Filled.MenuBook;
        if (mt.Contains("audio"))                          return Icons.Material.Filled.Headphones;
        if (mt.Contains("comic") || mt.Contains("cbz"))   return Icons.Material.Filled.AutoStories;
        return Icons.Material.Filled.Folder;
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength].TrimEnd() + "\u2026";

    public void Dispose() => _toastTimer?.Dispose();
}

<style>
    /* ── Page shell ── */
    .hub-detail-page {
        min-height: 100vh;
        padding-bottom: 5rem;
    }

    /* Suppress focus rings for mouse clicks; keep for keyboard nav */
    .hub-detail-page *:focus:not(:focus-visible) {
        outline: none !important;
        box-shadow: none !important;
    }

    .hub-detail-content:focus {
        outline: none;
    }

    /* ── Breadcrumb ── */
    .hub-detail-breadcrumb-outer {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
    }

    .hub-detail-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 14px 0;
        flex-wrap: wrap;
    }

    .hub-detail-bc-link {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.80rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.50);
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        transition: color 0.15s;
        line-height: 1;
    }

    .hub-detail-bc-link:hover     { color: rgba(248, 248, 248, 0.85); }
    .hub-detail-bc-author         { color: rgba(201, 146, 46, 0.70); }
    .hub-detail-bc-author:hover   { color: #C9922E; }

    .hub-detail-bc-sep {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        color: rgba(248, 248, 248, 0.22);
        user-select: none;
        line-height: 1;
    }

    .hub-detail-bc-current {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.80rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.45);
        line-height: 1;
    }

    /* ── Main panel outer (centers content) ── */
    .hub-detail-main-outer {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
    }

    /* ── 3-column panel ── */
    .hub-detail-main-panel {
        display: flex;
        gap: 28px;
        align-items: flex-start;
        margin-top: 12px;
        margin-bottom: 48px;
    }

    /* ── Left sidebar ── */
    .hub-detail-sidebar {
        width: 130px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        gap: 24px;
        text-align: right;
        padding-top: 14px; /* align with title baseline */
    }

    .hub-detail-sidebar-item {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .hub-detail-sidebar-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.62rem;
        font-weight: 700;
        color: rgba(248, 248, 248, 0.35);
        text-transform: uppercase;
        letter-spacing: 0.12em;
    }

    .hub-detail-sidebar-value {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.70);
        line-height: 1.3;
    }

    .hub-detail-sidebar-author {
