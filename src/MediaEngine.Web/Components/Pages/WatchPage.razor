@page "/watch"
@page "/watch/{Tab}"
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs

@namespace MediaEngine.Web.Components.Pages

<PageTitle>Watch - Tuvima</PageTitle>

<LibraryPage Tab="@Tab"
             Preset="@Preset" />

@code {
    [Parameter] public string? Tab { get; set; }

    private static readonly LibrarySurfacePreset Preset = new()
    {
        RouteBase = "/watch",
        Title = "Watch",
        VisibleMediaTabs = ["movies", "tv"],
        DefaultMediaTab = "movies",
        DefaultViewModes = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["tv"] = "shows",
        },
        HidePrimaryTabs = true,
    };
}
