@page "/watch"
@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav
@implements IDisposable
@using MediaEngine.Web.Models.ViewDTOs

<PageTitle>Watch — Tuvima</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else
{
    <GlobalBackground ImageUrl="@(_spotlight?.HeroUrl ?? _spotlight?.CoverUrl)" Color="@Accent" />

    <div class="watch-page">

        @* ── Spotlight (Landscape / cinematic) ── *@
        @if (_spotlight is not null)
        {
            <CompactHero Data="@_spotlight"
                         Mode="CompactHero.SpotlightMode.Landscape"
                         AccentColor="@Accent"
                         Eyebrow="@_spotlightEyebrow"
                         FallbackLabel="Play"
                         FallbackIcon="@MudBlazor.Icons.Material.Filled.PlayArrow"
                         OnClicked="HandleSpotlightClick"
                         OnCtaClicked="HandleSpotlightCta" />
        }

        @* ── Sub-filter tabs ── *@
        <div class="watch-tabs">
            @foreach (var opt in _subFilters)
            {
                <button class="watch-tab @(_activeSubFilter == opt ? "active" : "")"
                        style="@(_activeSubFilter == opt ? $"color: {Accent}; border-bottom-color: {Accent};" : "")"
                        @onclick="() => OnSubFilterChanged(opt)">
                    @opt
                </button>
            }
        </div>

        @* ── Filter strip ── *@
        <div class="watch-filters">
            <div class="watch-search">
                <MudIcon Icon="@MudBlazor.Icons.Material.Outlined.Search" Size="Size.Small"
                         Style="font-size: 14px; position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: rgba(148,163,184,0.50);" />
                <input type="text" placeholder="Search movies and TV..."
                       value="@_searchText" @oninput="OnSearchInput" class="watch-search-input" />
            </div>
        </div>

        @if (!HasAnyFilter)
        {
            @* ── Trending (recently added with cover art) ── *@
            @if (_trending.Count > 0)
            {
                <PosterSwimlane Title="Trending Now" Items="@_trending" OnItemSelected="HandleItemSelected" />
            }

            @* ── New Movies ── *@
            @if (_newMovies.Count > 0 && _activeSubFilter != "TV")
            {
                <PosterSwimlane Title="New Movies" Items="@_newMovies" OnItemSelected="HandleItemSelected" />
            }

            @* ── TV Shows ── *@
            @if (_newTV.Count > 0 && _activeSubFilter != "Movies")
            {
                <PosterSwimlane Title="TV Shows" Items="@_newTV" OnItemSelected="HandleItemSelected" />
            }

            @* ── Top genres ── *@
            @foreach (var group in _byGenre.Take(5))
            {
                <PosterSwimlane Title="@group.Name" Items="@group.Items" OnItemSelected="HandleItemSelected" />
            }
        }
        else
        {
            @* ── Filtered grid ── *@
            <div class="watch-grid-section">
                <div class="watch-grid-header">
                    <h3 class="watch-grid-title">Results (@_filteredWorks.Count)</h3>
                </div>
                <div class="watch-grid">
                    @foreach (var work in _filteredWorks)
                    {
                        var item = PosterItemViewModel.FromWork(work);
                        <LibraryCard Item="@item" OnItemSelected="HandleItemSelected" />
                    }
                </div>
                @if (_filteredWorks.Count == 0)
                {
                    <div class="watch-empty">
                        <MudIcon Icon="@MudBlazor.Icons.Material.Filled.Movie"
                                 Style="font-size: 48px; color: rgba(248,248,248,0.15);" />
                        <p>No titles match your search.</p>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private const string Accent = "#60A5FA";
    private static readonly string[] _mediaTypes = ["Movie", "video", "TV"];
    private static readonly string[] _subFilters = ["All", "Movies", "TV"];

    private bool _loading = true;
    private string _activeSubFilter = "All";
    private string _searchText = "";

    private List<WorkViewModel> _allWorks = [];
    private List<WorkViewModel> _filteredWorks = [];
    private List<JourneyItemViewModel> _journeyItems = [];

    private List<PosterItemViewModel> _trending = [];
    private List<PosterItemViewModel> _newMovies = [];
    private List<PosterItemViewModel> _newTV = [];
    private List<NamedGroup> _byGenre = [];

    private HeroData? _spotlight;
    private string _spotlightEyebrow = "Featured";

    private bool HasAnyFilter =>
        _activeSubFilter != "All" || !string.IsNullOrWhiteSpace(_searchText);

    private sealed record NamedGroup(string Name, IReadOnlyList<PosterItemViewModel> Items);

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadAsync();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (new Uri(e.Location).AbsolutePath.Trim('/') == "watch")
        {
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var works = await Orchestrator.GetLibraryWorksAsync();
            _journeyItems = await Orchestrator.GetJourneyAsync(limit: 10);

            _allWorks = works
                .Where(w => _mediaTypes.Any(mt =>
                    (w.MediaType ?? "").Contains(mt, StringComparison.OrdinalIgnoreCase)))
                .ToList();

            BuildSpotlight();
            BuildSwimlanes();
            ApplyFilters();
        }
        catch { /* Engine unreachable — show empty */ }
        finally { _loading = false; }
    }

    private void BuildSpotlight()
    {
        // Journey data is books-only today — skip and use "recently added with cover art".
        var newest = _allWorks
            .Where(w => !string.IsNullOrEmpty(w.CoverUrl))
            .OrderByDescending(w =>
                w.CanonicalValues.Select(cv => cv.LastScoredAt).DefaultIfEmpty(DateTimeOffset.MinValue).Max())
            .FirstOrDefault();

        _spotlight = newest is not null ? HeroData.FromWork(newest, null) : null;
        _spotlightEyebrow = "Featured";
    }

    private void BuildSwimlanes()
    {
        _trending = _allWorks
            .Where(w => !string.IsNullOrEmpty(w.CoverUrl))
            .OrderByDescending(w =>
                w.CanonicalValues.Select(cv => cv.LastScoredAt).DefaultIfEmpty(DateTimeOffset.MinValue).Max())
            .Take(15)
            .Select(w => PosterItemViewModel.FromWork(w))
            .ToList();

        _newMovies = _allWorks
            .Where(w => (w.MediaType ?? "").Contains("movie", StringComparison.OrdinalIgnoreCase)
                     || (w.MediaType ?? "").Contains("video", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(w => w.Year ?? "0000")
            .Take(20)
            .Select(w => PosterItemViewModel.FromWork(w))
            .ToList();

        _newTV = _allWorks
            .Where(w => (w.MediaType ?? "").Contains("tv", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(w => w.Year ?? "0000")
            .Take(20)
            .Select(w => PosterItemViewModel.FromWork(w))
            .ToList();

        _byGenre = _allWorks
            .Where(w => w.Genres.Count > 0)
            .SelectMany(w => w.Genres.Select(g => (Genre: g, Work: w)))
            .GroupBy(x => x.Genre, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 3)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g => new NamedGroup(g.Key,
                g.Select(x => PosterItemViewModel.FromWork(x.Work)).ToList()))
            .ToList();
    }

    private void ApplyFilters()
    {
        var works = _allWorks.AsEnumerable();

        if (_activeSubFilter == "Movies")
            works = works.Where(w => (w.MediaType ?? "").Contains("movie", StringComparison.OrdinalIgnoreCase)
                                   || (w.MediaType ?? "").Contains("video", StringComparison.OrdinalIgnoreCase));
        else if (_activeSubFilter == "TV")
            works = works.Where(w => (w.MediaType ?? "").Contains("tv", StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var term = _searchText.Trim();
            works = works.Where(w =>
                (w.Title?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (w.Director?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (w.Author?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        _filteredWorks = works.OrderBy(w => w.Title).ToList();
    }

    private void OnSubFilterChanged(string filter) { _activeSubFilter = filter; ApplyFilters(); }
    private void OnSearchInput(ChangeEventArgs e)   { _searchText = e.Value?.ToString() ?? ""; ApplyFilters(); }

    private void HandleItemSelected(PosterItemViewModel item) => Nav.NavigateTo(item.NavigationUrl);
    private void HandleSpotlightClick() { if (_spotlight?.EntityId is { } id) Nav.NavigateTo($"/book/{id}"); }
    private void HandleSpotlightCta()    { if (_spotlight?.EntityId is { } id) Nav.NavigateTo($"/book/{id}"); }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}

<style>
    .watch-page {
        padding: 0 1.5rem 5rem;
    }

    @@media (min-width: 768px) {
        .watch-page {
            padding: 0 4rem 5rem;
        }
    }

    /* ── Sub-filter tabs ── */
    .watch-tabs {
        display: flex;
        gap: 28px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        margin-bottom: 1.5rem;
        margin-top: 0.5rem;
    }

    .watch-tab {
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        font-weight: 600;
        color: rgba(148, 163, 184, 0.65);
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        padding: 10px 0;
        cursor: pointer;
        transition: color 0.2s ease, border-color 0.2s ease;
    }

    .watch-tab:hover { color: rgba(248, 248, 248, 0.85); }
    .watch-tab.active { font-weight: 700; }

    /* ── Filter strip ── */
    .watch-filters {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .watch-search {
        position: relative;
        flex: 1;
        min-width: 180px;
        max-width: 260px;
    }

    .watch-search-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 10px;
        padding: 9px 18px 9px 38px;
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        color: white;
        outline: none;
        transition: all 0.2s ease;
    }

    .watch-search-input::placeholder { color: rgba(148, 163, 184, 0.50); }
    .watch-search-input:focus {
        border-color: rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.08);
    }

    /* ── Filtered grid ── */
    .watch-grid-section { margin-top: 1rem; }

    .watch-grid-header {
        padding-left: 16px;
        margin-bottom: 1rem;
    }

    .watch-grid-title {
        font-family: 'Montserrat', sans-serif;
        font-size: clamp(1.25rem, 1.4vw, 1.55rem);
        font-weight: 600;
        color: rgba(248, 248, 248, 0.90);
        margin: 0;
    }

    .watch-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem 1.5rem;
        padding-left: 16px;
    }

    @@media (min-width: 640px)  { .watch-grid { grid-template-columns: repeat(3, 1fr); } }
    @@media (min-width: 768px)  { .watch-grid { grid-template-columns: repeat(4, 1fr); } }
    @@media (min-width: 1024px) { .watch-grid { grid-template-columns: repeat(5, 1fr); } }
    @@media (min-width: 1280px) { .watch-grid { grid-template-columns: repeat(6, 1fr); } }

    .watch-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 3rem 1rem;
        color: rgba(248, 248, 248, 0.45);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
    }
</style>
