@page "/watch"
@page "/watch/{Tab}"
@using MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.MediaTiles
@inject MediaTileComposerService MediaTiles

@namespace MediaEngine.Web.Components.Pages

<PageTitle>Watch - Tuvima</PageTitle>

@if (string.IsNullOrWhiteSpace(Tab))
{
    @if (_loading)
    {
        <div class="browse-shell__loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Class="tl-u-color-tl-text-faint" />
        </div>
    }
    else if (_loadFailed)
    {
        <AppErrorState Title="Watch failed to load"
                       Message="The Dashboard could not load the Watch landing from the Engine."
                       Retry="LoadLandingAsync" />
    }
    else if (_landingPage is not null)
    {
        <LaneLandingView Page="@_landingPage"
                         Title="Watch"
                         Subtitle="Movies and shows from your local library"
                         BrowseAllRoute="/watch/movies"
                         HideMediaKindBadges="true"
                         HideSourceBadges="true" />
    }
}
else
{
    <MediaBrowseShell Tab="@Tab"
                      Preset="@Preset" />
}

@code {
    [Parameter] public string? Tab { get; set; }

    private DiscoveryPageViewModel? _landingPage;
    private bool _loading = true;
    private bool _loadFailed;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(Tab) || _landingPage is not null)
        {
            _loading = false;
            return;
        }

        await LoadLandingAsync();
    }

    private async Task LoadLandingAsync()
    {
        _loading = true;
        _loadFailed = false;

        try
        {
            _landingPage = await MediaTiles.BuildWatchAsync();
        }
        catch
        {
            _loadFailed = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private static readonly LibraryBrowsePreset Preset = new()
    {
        RouteBase = "/watch",
        Title = "Watch",
        HeroVariant = BrowseHeroVariant.Watch,
        UseExplicitDefaultTabRoute = true,
        Tabs =
        [
            new BrowseTabPreset
            {
                Id = "movies",
                Label = "Movies",
                MediaType = "Movies",
                GroupingOptions =
                [
                    new("all", "All Movies", Icons.Material.Outlined.LocalMovies),
                    new("series", "Series", Icons.Material.Outlined.Collections),
                ],
                DefaultGrouping = "all",
                DefaultLayout = LibraryLayoutMode.Card,
            },
            new BrowseTabPreset
            {
                Id = "tv",
                Label = "TV",
                MediaType = "TV",
                GroupingOptions = [new("shows", "Shows", Icons.Material.Outlined.LiveTv)],
                DefaultGrouping = "shows",
                DefaultLayout = LibraryLayoutMode.Card,
            },
        ],
    };
}
