@page "/watch"
@inject DiscoveryComposerService Discovery
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer State
@implements IDisposable

<PageTitle>Watch - Tuvima</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" Style="border-radius: 4px;" />
}
else
{
    <GlobalBackground ImageUrl="@_page.Hero?.BackgroundImageUrl" Color="@_page.AccentColor" />

    <div class="watch-discovery-page">
        @if (_page.Hero is not null)
        {
            <DiscoveryHero Hero="@_page.Hero" />
        }

        @if (_page.Hubs.Count > 0)
        {
            <DiscoveryHubStrip Hubs="@_page.Hubs"
                               Title="Watch collections"
                               Subtitle="Shows, franchises, and dynamic viewing groups inspired by streaming-style browsing." />
        }

        <div class="watch-discovery-shelves">
            @foreach (var shelf in _page.Shelves)
            {
                <DiscoveryShelf Shelf="@shelf" />
            }
        </div>

        <section class="watch-discovery-catalog-shell">
            <div class="watch-discovery-catalog-header">
                <div>
                    <h2 class="watch-discovery-catalog-title">Browse your watch library</h2>
                    <p class="watch-discovery-catalog-copy">
                        Keep home personal, and use watch for direct discovery across movies, TV, genres, and collection groupings.
                    </p>
                </div>

                <div class="watch-discovery-toolbar">
                    <div class="watch-discovery-tabs">
                        @foreach (var tab in _tabs)
                        {
                            <button type="button"
                                    class="watch-discovery-tab @(_activeTab == tab ? "is-active" : "")"
                                    style="@(_activeTab == tab ? $"--tab-accent: {_page.AccentColor};" : string.Empty)"
                                    @onclick="() => SetTab(tab)">
                                @tab
                            </button>
                        }
                    </div>

                    <div class="watch-discovery-filters">
                        <div class="watch-discovery-genres">
                            @foreach (var genre in AvailableGenres)
                            {
                                <button type="button"
                                        class="watch-discovery-chip @(_activeGenre == genre ? "is-active" : "")"
                                        style="@(_activeGenre == genre ? $"--chip-accent: {_page.AccentColor};" : string.Empty)"
                                        @onclick="() => SetGenre(genre)">
                                    @genre
                                </button>
                            }
                        </div>

                        <MudTextField T="string"
                                      Value="_searchText"
                                      ValueChanged="OnSearchChanged"
                                      Placeholder="Search movies, shows, creators, and genres..."
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Outlined.Search"
                                      Class="watch-discovery-search" />

                        <MudSelect T="string"
                                   Value="_sortBy"
                                   ValueChanged="OnSortChanged"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Class="watch-discovery-sort">
                            <MudSelectItem T="string" Value="@("Newest")">Newest</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Title")">Title</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Year")">Year</MudSelectItem>
                        </MudSelect>
                    </div>
                </div>
            </div>

            @if (_filteredCatalog.Count == 0)
            {
                <div class="watch-discovery-empty">
                    <MudIcon Icon="@Icons.Material.Filled.Movie"
                             Style="font-size: 48px; color: rgba(255,255,255,0.18);" />
                    <p>No watch titles match these filters.</p>
                </div>
            }
            else
            {
                <div class="watch-discovery-catalog">
                    @foreach (var card in _filteredCatalog)
                    {
                        <DiscoveryCard Item="@card" />
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    private static readonly string[] _tabs = ["All", "Movies", "TV"];

    private bool _loading = true;
    private string _activeTab = "All";
    private string _activeGenre = "All genres";
    private string _searchText = string.Empty;
    private string _sortBy = "Newest";
    private DiscoveryPageViewModel _page = new() { Key = "watch", AccentColor = "#60A5FA" };
    private List<DiscoveryCardViewModel> _filteredCatalog = [];

    private IReadOnlyList<string> AvailableGenres =>
        ["All genres", .. _page.Catalog
            .SelectMany(card => card.Genres)
            .Where(genre => !string.IsNullOrWhiteSpace(genre))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(genre => genre, StringComparer.OrdinalIgnoreCase)
            .Take(8)];

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        try
        {
            _page = await Discovery.BuildWatchAsync();
            ApplyFilters();
        }
        catch
        {
            _page = new DiscoveryPageViewModel
            {
                Key = "watch",
                AccentColor = "#60A5FA",
                EmptyTitle = "Nothing to watch yet.",
                EmptySubtitle = "Movies and TV appear here once they are added to the library."
            };
            _filteredCatalog = [];
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<DiscoveryCardViewModel> cards = _page.Catalog;

        cards = _activeTab switch
        {
            "Movies" => cards.Where(card => string.Equals(card.MediaKind, "Movie", StringComparison.OrdinalIgnoreCase)),
            "TV" => cards.Where(card => string.Equals(card.MediaKind, "TV", StringComparison.OrdinalIgnoreCase)),
            _ => cards
        };

        if (!string.Equals(_activeGenre, "All genres", StringComparison.OrdinalIgnoreCase))
        {
            cards = cards.Where(card => card.Genres.Any(genre => string.Equals(genre, _activeGenre, StringComparison.OrdinalIgnoreCase)));
        }

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var term = _searchText.Trim();
            cards = cards.Where(card => MatchesSearch(card, term));
        }

        cards = _sortBy switch
        {
            "Title" => cards.OrderBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            "Year" => cards.OrderByDescending(card => card.SortYear).ThenBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            _ => cards.OrderByDescending(card => card.SortTimestamp).ThenBy(card => card.Title, StringComparer.OrdinalIgnoreCase)
        };

        _filteredCatalog = cards.ToList();
    }

    private static bool MatchesSearch(DiscoveryCardViewModel card, string term) =>
        card.Title.Contains(term, StringComparison.OrdinalIgnoreCase)
        || (card.Subtitle?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || (card.Creator?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || (card.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
        || card.Genres.Any(genre => genre.Contains(term, StringComparison.OrdinalIgnoreCase));

    private void SetTab(string tab)
    {
        _activeTab = tab;
        ApplyFilters();
    }

    private void SetGenre(string genre)
    {
        _activeGenre = genre;
        ApplyFilters();
    }

    private Task OnSearchChanged(string value)
    {
        _searchText = value;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private Task OnSortChanged(string value)
    {
        _sortBy = value;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private void OnStateChanged()
    {
        _ = InvokeAsync(LoadAsync);
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }
}

<style>
    .watch-discovery-page {
        display: flex;
        flex-direction: column;
        gap: 34px;
        padding: 0 1.5rem 5rem;
    }

    .watch-discovery-shelves {
        display: flex;
        flex-direction: column;
        gap: 36px;
    }

    .watch-discovery-catalog-shell {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .watch-discovery-catalog-title {
        margin: 0;
        font-family: Georgia, 'Times New Roman', serif;
        font-size: clamp(1.5rem, 2vw, 2.15rem);
        font-weight: 700;
        line-height: 1;
        color: rgba(248, 250, 252, 0.96);
    }

    .watch-discovery-catalog-copy {
        margin: 10px 0 0;
        max-width: 640px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.94rem;
        line-height: 1.6;
        color: rgba(148, 163, 184, 0.88);
    }

    .watch-discovery-toolbar {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-top: 18px;
    }

    .watch-discovery-tabs,
    .watch-discovery-genres {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .watch-discovery-tab,
    .watch-discovery-chip {
        min-height: 38px;
        padding: 0 16px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.03);
        color: rgba(226, 232, 240, 0.86);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        cursor: pointer;
        transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease;
    }

    .watch-discovery-tab:hover,
    .watch-discovery-chip:hover {
        transform: translateY(-1px);
        border-color: rgba(255, 255, 255, 0.14);
    }

    .watch-discovery-tab.is-active,
    .watch-discovery-chip.is-active {
        border-color: color-mix(in srgb, var(--tab-accent, var(--chip-accent)) 54%, rgba(255,255,255,0.12));
        background: color-mix(in srgb, var(--tab-accent, var(--chip-accent)) 18%, rgba(255,255,255,0.02));
        color: rgba(248, 250, 252, 0.96);
    }

    .watch-discovery-filters {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(260px, 420px) 160px;
        gap: 14px;
        align-items: start;
    }

    .watch-discovery-search,
    .watch-discovery-sort {
        width: 100%;
    }

    .watch-discovery-catalog {
        display: flex;
        flex-wrap: wrap;
        gap: 22px;
    }

    .watch-discovery-empty {
        min-height: 220px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        color: rgba(226, 232, 240, 0.7);
        font-family: 'Montserrat', sans-serif;
    }

    @@media (min-width: 768px) {
        .watch-discovery-page {
            padding: 0 4rem 5rem;
        }
    }

    @@media (max-width: 960px) {
        .watch-discovery-filters {
            grid-template-columns: 1fr;
        }
    }
</style>
