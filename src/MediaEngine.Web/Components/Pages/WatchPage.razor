@page "/watch"
@page "/watch/{Tab}"
@using MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Components.MediaHub
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.MediaTiles
@inject MediaTileComposerService MediaTiles

@namespace MediaEngine.Web.Components.Pages

<PageTitle>Watch - Tuvima</PageTitle>

<MediaSectionShell Title="Watch" NavigationGroups="@WatchNavigationGroups">
    <MediaLaneHeader Title="Watch"
                     Subtitle="Movies and shows from your local library"
                     Modes="@WatchModes"
                     ActiveMode="@ActiveWatchMode" />

    @if (string.IsNullOrWhiteSpace(Tab))
    {
        @if (_loading)
        {
            <div class="browse-shell__loading">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" Class="tl-u-color-tl-text-faint" />
            </div>
        }
        else if (_loadFailed)
        {
            <AppErrorState Title="Watch failed to load"
                           Message="The Dashboard could not load the Watch landing from the Engine."
                           Retry="LoadLandingAsync" />
        }
        else if (_landingPage is not null)
        {
            <MediaHubPage SectionType="MediaHubSectionType.Watch"
                          Title="Watch"
                          Subtitle="Movies and shows from your local library"
                          SelectedMode="all"
                          AvailableModes="@WatchModes"
                          Shelves="@WatchHubShelves"
                          SearchPlaceholder="Search movies and TV..."
                          RouteBase="/watch"
                          SupportsHero="false"
                          SupportsHeader="false"
                          SupportsNavigation="false" />
        }
    }
    else
    {
        <MediaBrowseShell Tab="@Tab"
                          Preset="@Preset"
                          ShowTitleBlock="false"
                          ShowTabNavigation="false" />
    }
</MediaSectionShell>

@code {
    [Parameter] public string? Tab { get; set; }

    private DiscoveryPageViewModel? _landingPage;
    private bool _loading = true;
    private bool _loadFailed;

    private string ActiveWatchMode => Tab?.Trim().ToLowerInvariant() switch
    {
        "movies" => "movies",
        "tv" => "tv",
        "series" => "series",
        _ => "all",
    };

    private static readonly IReadOnlyList<MediaHubModeViewModel> WatchModes =
    [
        new("all", "Discover", "/watch"),
        new("movies", "Movies", "/watch/movies"),
        new("tv", "TV Shows", "/watch/tv"),
        new("series", "Series", "/watch/series"),
    ];

    private static readonly IReadOnlyList<MediaSectionNavigationGroup> WatchNavigationGroups =
    [
        new("Library",
        [
            new("Discover", "/watch", Icons.Material.Outlined.Explore, Exact: true),
            new("Movies", "/watch/movies", Icons.Material.Outlined.LocalMovies),
            new("TV Shows", "/watch/tv", Icons.Material.Outlined.LiveTv),
            new("Movie Series", "/watch/series", Icons.Material.Outlined.Collections),
        ]),
        new("Watch next",
        [
            new("Continue Watching", "/watch/movies?status=in-progress", Icons.Material.Outlined.PlayCircle, Exact: true),
            new("Recently Added", "/watch/movies?sort=newest", Icons.Material.Outlined.Schedule, Exact: true),
        ]),
    ];

    private IReadOnlyList<MediaHubShelfViewModel> WatchHubShelves => _landingPage?.Shelves
        .Select(shelf => MediaHubShelfViewModel.FromShelf(shelf))
        .ToList() ?? [];

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(Tab) || _landingPage is not null)
        {
            _loading = false;
            return;
        }

        await LoadLandingAsync();
    }

    private async Task LoadLandingAsync()
    {
        _loading = true;
        _loadFailed = false;

        try
        {
            _landingPage = await MediaTiles.BuildWatchAsync();
        }
        catch
        {
            _loadFailed = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private static readonly LibraryBrowsePreset Preset = new()
    {
        RouteBase = "/watch",
        Title = "Watch",
        HeroVariant = BrowseHeroVariant.Watch,
        UseExplicitDefaultTabRoute = true,
        Tabs =
        [
            new BrowseTabPreset
            {
                Id = "movies",
                Label = "Movies",
                MediaType = "Movies",
                GroupingOptions =
                [new("all", "All Movies", Icons.Material.Outlined.LocalMovies)],
                DefaultGrouping = "all",
                DefaultLayout = LibraryLayoutMode.Card,
            },
            new BrowseTabPreset
            {
                Id = "tv",
                Label = "TV",
                MediaType = "TV",
                GroupingOptions = [new("shows", "Shows", Icons.Material.Outlined.LiveTv)],
                DefaultGrouping = "shows",
                DefaultLayout = LibraryLayoutMode.Card,
            },
            new BrowseTabPreset
            {
                Id = "series",
                Label = "Series",
                MediaType = "Movies",
                GroupingOptions = [new("series", "Movie Series", Icons.Material.Outlined.Collections)],
                DefaultGrouping = "series",
                DefaultLayout = LibraryLayoutMode.Card,
            },
        ],
    };
}
