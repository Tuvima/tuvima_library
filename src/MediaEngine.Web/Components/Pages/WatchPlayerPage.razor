@page "/watch/player/{AssetId:guid}"
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using MediaEngine.Contracts.Playback
@using MediaEngine.Web.Components.Watch
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration

@implements IAsyncDisposable

@namespace MediaEngine.Web.Components.Pages

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>@((_detail?.Title ?? "Player")) - Tuvima</PageTitle>

@if (_loading)
{
    <div class="watch-player-state">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Style="color: rgba(255,255,255,0.28);" />
    </div>
}
else
{
    <div class="watch-player-page">
        <div class="watch-player-page__topbar">
            <button type="button" class="watch-player-button watch-player-button--secondary" @onclick="GoBack">
                <MudIcon Icon="@Icons.Material.Outlined.ArrowBack" Style="font-size: 18px;" />
                <span>Back</span>
            </button>

            <div class="watch-player-page__meta">
                <div class="watch-player-page__eyebrow">@(_detail?.ShowName ?? _detail?.Series ?? "Now playing")</div>
                <h1>@(_detail?.Title ?? "Playback")</h1>
                <WatchPlaybackSpecs Summary="_detail?.PlaybackSummary" />
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_streamUrl))
        {
            @if (_manifest?.Warnings.Count > 0)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                    @string.Join(" ", _manifest.Warnings)
                </MudAlert>
            }
            <div class="watch-player-page__surface">
                <video @ref="_videoRef"
                       class="watch-player-page__video"
                       controls
                       autoplay
                       playsinline
                       poster="@PosterUrl"
                       src="@_streamUrl">
                    @foreach (var track in _subtitleTracks)
                    {
                        <track kind="subtitles"
                               @key="@($"{track.Language}-{track.Url}")"
                               src="@track.Url"
                               srclang="@track.Language"
                               label="@SubtitleLabel(track)"
                               default="@track.IsPreferred" />
                    }
                </video>
                @if (VisibleSkipSegments.Count > 0)
                {
                    <div class="watch-player-page__skipbar">
                        @foreach (var segment in VisibleSkipSegments)
                        {
                            <button type="button"
                                    @key="@($"{segment.Kind}-{segment.StartSeconds}-{segment.EndSeconds}")"
                                    class="watch-player-skip-chip"
                                    title="@SkipTitle(segment)"
                                    @onclick="() => SkipSegmentAsync(segment)">
                                <MudIcon Icon="@SkipIcon(segment.Kind)" Style="font-size: 16px;" />
                                <span>@SkipLabel(segment.Kind)</span>
                            </button>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="watch-player-state">
                <AppErrorState Title="Playable video not found"
                               Message="This asset could not be streamed from the Engine."
                               Details="@_loadError"
                               Retry="LoadPlayerAsync"
                               Icon="@Icons.Material.Outlined.Movie" />
            </div>
        }
    </div>
}

@code {
    [Parameter] public Guid AssetId { get; set; }
    [SupplyParameterFromQuery(Name = "workId")] public Guid? WorkId { get; set; }
    [SupplyParameterFromQuery(Name = "collectionId")] public Guid? CollectionId { get; set; }
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }

    private LibraryItemDetailViewModel? _detail;
    private PlaybackManifestDto? _manifest;
    private IReadOnlyList<TextTrackViewModel> _subtitleTracks = [];
    private string? _streamUrl;
    private string? _loadError;
    private ProgressStateDto? _progress;
    private Guid? _activeProfileId;
    private bool _loading = true;

    private ElementReference _videoRef;
    private IJSObjectReference? _module;
    private DotNetObjectReference<WatchPlayerPage>? _dotNetRef;
    private double _lastSavedPct = -1;
    private DateTimeOffset _lastSaveAt = DateTimeOffset.MinValue;

    private string? PosterUrl => _detail?.BackgroundUrl ?? _detail?.BannerUrl ?? _detail?.HeroUrl ?? _detail?.CoverUrl;
    private IReadOnlyList<PlaybackSegmentDto> VisibleSkipSegments =>
        (_manifest?.Segments ?? [])
            .Where(s => s.IsSkippable
                && !string.Equals(s.ReviewStatus, "hidden", StringComparison.OrdinalIgnoreCase)
                && s.EndSeconds.HasValue
                && s.EndSeconds.Value > s.StartSeconds)
            .OrderBy(s => s.StartSeconds)
            .Take(6)
            .ToList();

    protected override async Task OnParametersSetAsync()
        => await LoadPlayerAsync();

    private async Task LoadPlayerAsync()
    {
        _loading = true;
        _loadError = null;
        StateHasChanged();

        var detailTask = WorkId.HasValue
            ? ApiClient.GetLibraryItemDetailAsync(WorkId.Value)
            : Task.FromResult<LibraryItemDetailViewModel?>(null);
        var progressTask = Orchestrator.GetProgressAsync(AssetId);
        var profileTask = Orchestrator.GetActiveProfileAsync();
        var manifestTask = ApiClient.GetPlaybackManifestAsync(AssetId, "web");
        var tracksTask = ApiClient.GetTextTracksAsync(AssetId);

        await Task.WhenAll(detailTask, progressTask, profileTask, manifestTask, tracksTask);

        _detail = detailTask.Result;
        _progress = progressTask.Result;
        _activeProfileId = profileTask.Result?.Id;
        _manifest = manifestTask.Result;
        _subtitleTracks = tracksTask.Result
            .Where(t => string.Equals(t.Kind, "Subtitles", StringComparison.OrdinalIgnoreCase))
            .ToList();
        _streamUrl = _manifest is null
            ? null
            : ApiClient.ToAbsoluteEngineUrl(_manifest.DirectStreamUrl ?? $"/stream/{AssetId}");
        if (_streamUrl is null)
        {
            _loadError = ApiClient.LastError ?? Orchestrator.LastApiError;
        }
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loading || string.IsNullOrWhiteSpace(_streamUrl))
            return;

        if (_module is null)
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/watch-player.js");

        _dotNetRef ??= DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("attachPlayer", _videoRef, _dotNetRef);

        if (_progress?.ProgressPct is > 0 and < 99.5)
            await _module.InvokeVoidAsync("restoreProgress", _videoRef, _progress.ProgressPct);
    }

    [JSInvokable]
    public async Task OnPlayerProgress(double currentTime, double duration, bool ended)
    {
        if (duration <= 0)
            return;

        var progressPct = ended ? 100d : Math.Clamp((currentTime / duration) * 100d, 0d, 100d);
        var now = DateTimeOffset.UtcNow;
        var shouldSave = ended
            || _lastSavedPct < 0
            || Math.Abs(progressPct - _lastSavedPct) >= 2.5
            || now - _lastSaveAt >= TimeSpan.FromSeconds(20);

        if (!shouldSave)
            return;

        _lastSavedPct = progressPct;
        _lastSaveAt = now;
        await Orchestrator.SaveProgressAsync(
            AssetId,
            _activeProfileId,
            progressPct,
            new Dictionary<string, string>
            {
                ["position_seconds"] = Math.Max(0d, currentTime).ToString("F2"),
                ["duration_seconds"] = Math.Max(0d, duration).ToString("F2"),
                ["media_kind"] = "video",
                ["completed"] = ended ? "true" : "false",
            });
    }

    private void GoBack()
    {
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
        {
            Nav.NavigateTo(ReturnUrl!);
            return;
        }

        if (CollectionId.HasValue)
        {
            Nav.NavigateTo($"/watch/tv/show/{CollectionId.Value}");
            return;
        }

        Nav.NavigateTo("/watch/tv");
    }

    private async Task SkipSegmentAsync(PlaybackSegmentDto segment)
    {
        if (_module is null)
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/watch-player.js");

        var target = Math.Max(segment.StartSeconds, segment.EndSeconds ?? segment.StartSeconds);
        await _module.InvokeVoidAsync("seekTo", _videoRef, target);
    }

    private static string SkipLabel(string kind) => kind.ToLowerInvariant() switch
    {
        "intro" => "Skip Intro",
        "commercial" => "Skip Commercial",
        "credits" => "Skip Credits",
        "recap" => "Skip Recap",
        "post_credits" => "Skip Post-Credits",
        _ => "Skip Segment",
    };

    private static string SkipIcon(string kind) => kind.ToLowerInvariant() switch
    {
        "intro" => Icons.Material.Outlined.FastForward,
        "commercial" => Icons.Material.Outlined.LiveTv,
        "credits" => Icons.Material.Outlined.MovieFilter,
        "recap" => Icons.Material.Outlined.Replay,
        _ => Icons.Material.Outlined.SkipNext,
    };

    private static string SkipTitle(PlaybackSegmentDto segment) =>
        $"{SkipLabel(segment.Kind)} ({segment.StartSeconds:0}s to {segment.EndSeconds:0}s, {segment.Confidence:P0} confidence)";

    private static string SubtitleLabel(TextTrackViewModel track)
    {
        var language = string.IsNullOrWhiteSpace(track.Language) ? "Subtitles" : track.Language.ToUpperInvariant();
        return track.IsHearingImpaired ? $"{language} SDH" : language;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
                await _module.InvokeVoidAsync("detachPlayer", _videoRef);
        }
        catch
        {
        }

        if (_module is not null)
            await _module.DisposeAsync();

        _dotNetRef?.Dispose();
    }
}

<style>
    .watch-player-page {
        color: rgba(255, 255, 255, 0.92);
        padding-bottom: 36px;
    }

    .watch-player-page__topbar {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 18px;
        align-items: start;
        margin-bottom: 22px;
    }

    .watch-player-page__eyebrow {
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--tl-text-muted);
    }

    .watch-player-page h1 {
        margin: 6px 0 0;
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        line-height: 0.96;
        letter-spacing: -0.04em;
        color: #fff;
    }

    .watch-player-page__surface {
        position: relative;
        overflow: hidden;
        border-radius: 26px;
        border: 1px solid var(--tl-border-subtle);
        background: #020307;
        box-shadow: 0 26px 54px rgba(0, 0, 0, 0.32);
    }

    .watch-player-page__skipbar {
        position: absolute;
        right: 18px;
        bottom: 18px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: flex-end;
        pointer-events: none;
    }

    .watch-player-skip-chip {
        pointer-events: auto;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 36px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.22);
        background: rgba(5, 8, 16, 0.78);
        color: rgba(255, 255, 255, 0.94);
        font-size: 0.82rem;
        font-weight: 800;
        backdrop-filter: blur(12px);
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.32);
        cursor: pointer;
    }

    .watch-player-skip-chip:hover {
        border-color: rgba(255, 255, 255, 0.38);
        background: rgba(14, 20, 34, 0.9);
    }

    .watch-player-page__video {
        display: block;
        width: 100%;
        max-height: calc(100vh - 220px);
        background: #000;
    }

    .watch-player-state {
        min-height: 360px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        text-align: center;
    }

    .watch-player-state h3 {
        margin: 0;
    }

    .watch-player-state p {
        margin: 0;
        color: rgba(255, 255, 255, 0.58);
    }

    .watch-player-button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 42px;
        padding: 0 14px;
        border-radius: var(--app-radius-md);
        border: 1px solid var(--tl-border-default);
        background: var(--tl-border-subtle);
        color: rgba(255, 255, 255, 0.92);
        font-weight: 800;
        cursor: pointer;
    }

    @@media (max-width: 900px) {
        .watch-player-page__topbar {
            grid-template-columns: 1fr;
        }
    }
</style>
