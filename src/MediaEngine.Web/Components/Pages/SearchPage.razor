@page "/search"
@namespace MediaEngine.Web.Components.Pages
@using MediaEngine.Web.Services.Navigation
@inject UniverseStateContainer State
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L

@using MediaEngine.Web.Models.ViewDTOs

<PageTitle>Search - Tuvima Library</PageTitle>

<div class="search-page">
    <div class="search-page-header">
        <MudIcon Icon="@Icons.Material.Outlined.Search"
                 Class="search-page-header-icon" />
        <h2 class="search-page-title">@L["Search_Title"]</h2>
        <p class="search-page-subtitle">@L["Search_Subtitle"]</p>
    </div>

    @if (State.IsLoaded && VisibleCollections.Count > 0)
    {
        <section class="search-recent">
            <h3 class="search-recent-title">@L["Search_AllTitles"]</h3>
            <div class="search-recent-grid">
                @foreach (var collection in VisibleCollections)
                {
                    <MudLink Href="@MediaNavigation.ForCollection(collection)"
                             Underline="Underline.None"
                             Class="search-recent-link">
                        <MudPaper Elevation="0" Class="search-recent-item">
                            @if (!string.IsNullOrEmpty(collection.CoverUrl))
                            {
                                <img src="@collection.CoverUrl" alt="@collection.DisplayName" class="search-recent-cover" loading="lazy" />
                            }
                            else
                            {
                                <div class="search-recent-cover search-recent-cover-placeholder">
                                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Class="search-recent-placeholder-icon" />
                                </div>
                            }
                            <span class="search-recent-name">@collection.DisplayName</span>
                        </MudPaper>
                    </MudLink>
                }
            </div>
        </section>
    }
    else if (State.IsLoaded)
    {
        <MudPaper Elevation="0" Class="search-empty">
            <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Class="search-empty-icon" />
            <MudText Typo="Typo.h6">No titles matched</MudText>
            <MudText Typo="Typo.body2" Class="search-empty-copy">
                Try a different search term or return to the library browse page.
            </MudText>
        </MudPaper>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "q")] public string? Query { get; set; }

    private IReadOnlyList<CollectionViewModel> VisibleCollections =>
        State.FilteredCollections
            .Where(collection =>
                string.IsNullOrWhiteSpace(Query)
                || collection.DisplayName.Contains(Query, StringComparison.OrdinalIgnoreCase))
            .Take(24)
            .ToList();
}
