@page "/search"
@using MediaEngine.Contracts.Display
@using MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Components.Search
@using MediaEngine.Web.Services.Integration
@implements IDisposable
@namespace MediaEngine.Web.Components.Pages
@inject IEngineApiClient ApiClient
@inject NavigationManager Nav

<PageTitle>Search - Tuvima Library</PageTitle>

<div class="search-page">
    <header class="search-page__header">
        <div class="search-page__title-row">
            <h1>Search</h1>
            <span><MudIcon Icon="@Icons.Material.Outlined.Bolt" /> Results update instantly as you type</span>
        </div>

        <AppTextField T="string"
                      Value="@_query"
                      ValueChanged="OnQueryInputChanged"
                      Placeholder="Search titles, people, series, playlists, or collections…"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.Search"
                      Immediate="true"
                      DebounceInterval="220"
                      OnDebounceIntervalElapsed="OnSearchDebouncedAsync"
                      Class="search-page__input" />

        <div class="search-page__filters">
            <BrowseMultiSelect Label="Media"
                               ButtonLabel="@MediaButtonLabel"
                               Icon="@Icons.Material.Outlined.PermMedia"
                               Options="@MediaOptions"
                               SelectedValues="@_selectedMedia"
                               SelectedValuesChanged="OnMediaChanged"
                               Searchable="false"
                               AllLabel="All media"
                               AllHelpText="Search every media lane"
                               Class="search-page__media-filter" />

            <AppSelect T="string"
                       Value="@_resultType"
                       ValueChanged="OnResultTypeChanged"
                       Label="Result type"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Class="search-page__select">
                <MudSelectItem T="string" Value="@("all")">All result types</MudSelectItem>
                <MudSelectItem T="string" Value="@("title")">Titles</MudSelectItem>
                <MudSelectItem T="string" Value="@("person")">People</MudSelectItem>
                <MudSelectItem T="string" Value="@("group")">Series &amp; Collections</MudSelectItem>
                <MudSelectItem T="string" Value="@("playlist")">Playlists</MudSelectItem>
            </AppSelect>

            <div class="search-page__year-filter">
                <span>Release / Publication Year</span>
                <div>
                    <AppNativeInput Type="number"
                                    Value="@_yearFrom"
                                    Placeholder="From"
                                    AriaLabel="Year from"
                                    OnChange="OnYearFromChanged" />
                    <span>–</span>
                    <AppNativeInput Type="number"
                                    Value="@_yearTo"
                                    Placeholder="To"
                                    AriaLabel="Year to"
                                    OnChange="OnYearToChanged" />
                </div>
            </div>

            <AppSelect T="string"
                       Value="@_sort"
                       ValueChanged="OnSortChanged"
                       Label="Sort"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Class="search-page__select">
                <MudSelectItem T="string" Value="@("relevance")">Relevance</MudSelectItem>
                <MudSelectItem T="string" Value="@("title")">Title A-Z</MudSelectItem>
                <MudSelectItem T="string" Value="@("newest")">Newest first</MudSelectItem>
                <MudSelectItem T="string" Value="@("oldest")">Oldest first</MudSelectItem>
            </AppSelect>

            <AppNativeButton Type="button"
                             Class="search-page__more-filters"
                             Disabled="true"
                             Title="Contextual filters become available when one media type is selected">
                <MudIcon Icon="@Icons.Material.Outlined.FilterList" />
                <span>More filters</span>
            </AppNativeButton>
        </div>

        <AppActiveFilterSummary Items="@ActiveFilterChips"
                                Remove="RemoveFilterAsync"
                                ClearAll="ClearFiltersAsync" />
    </header>

    <main class="search-page__body" aria-live="polite">
        @if (string.IsNullOrWhiteSpace(_query))
        {
            <div class="search-page__empty">
                <MudIcon Icon="@Icons.Material.Outlined.Search" />
                <h2>Search your whole library</h2>
                <p>Find media, people, series, collections, and playlists without leaving this surface.</p>
            </div>
        }
        else if (_query.Trim().Length < MinimumQueryLength)
        {
            <div class="search-page__empty">
                <MudIcon Icon="@Icons.Material.Outlined.ManageSearch" />
                <h2>Keep typing</h2>
                <p>Use at least two characters to search.</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="search-page__empty">
                <MudIcon Icon="@Icons.Material.Outlined.CloudOff" />
                <h2>Search could not be completed</h2>
                <p>Try again. Your query and filters have been preserved.</p>
                <AppButton Variant="Variant.Outlined" Color="Color.Default" OnClick="SearchAsync">Try again</AppButton>
            </div>
        }
        else if (FilteredResponse is { TotalCount: 0 } && !_loading)
        {
            <div class="search-page__empty">
                <MudIcon Icon="@Icons.Material.Outlined.SearchOff" />
                <h2>No results match this search</h2>
                <p>Remove a filter or try another query.</p>
                @if (ActiveFilterChips.Count > 0)
                {
                    <AppButton Variant="Variant.Text" Color="Color.Default" OnClick="ClearFiltersAsync">Clear all filters</AppButton>
                }
            </div>
        }
        else if (FilteredResponse is not null)
        {
            <UniversalSearchResults Response="@FilteredResponse"
                                    SelectedResult="@_selected"
                                    SelectedResultChanged="OnSelectedChanged" />
        }

        @if (_loading)
        {
            <div class="search-page__loading" aria-label="Updating search results">
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            </div>
        }
    </main>
</div>

@code {
    private const int MinimumQueryLength = 2;
    private static readonly IReadOnlyList<string> MediaOptions = ["Book", "Comic", "Movie", "TV", "Music", "Audiobook"];

    [SupplyParameterFromQuery(Name = "q")] public string? Query { get; set; }
    [SupplyParameterFromQuery(Name = "media")] public string[]? Media { get; set; }
    [SupplyParameterFromQuery(Name = "type")] public string? ResultType { get; set; }
    [SupplyParameterFromQuery(Name = "yearFrom")] public int? YearFrom { get; set; }
    [SupplyParameterFromQuery(Name = "yearTo")] public int? YearTo { get; set; }
    [SupplyParameterFromQuery(Name = "sort")] public string? Sort { get; set; }

    private CancellationTokenSource? _searchCts;
    private UniversalSearchResponseDto? _response;
    private UniversalSearchResultDto? _selected;
    private string _query = string.Empty;
    private string _resultType = "all";
    private string _sort = "relevance";
    private string _yearFrom = string.Empty;
    private string _yearTo = string.Empty;
    private string? _error;
    private bool _loading;
    private IReadOnlyList<string> _selectedMedia = [];

    private string MediaButtonLabel => _selectedMedia.Count == 0 ? "All media" : $"Media · {_selectedMedia.Count}";

    private IReadOnlyList<ActiveFilterChip> ActiveFilterChips =>
        [
            .. _selectedMedia.Select(value => new ActiveFilterChip($"media:{value}", value)),
            .. _resultType == "all" ? [] : new[] { new ActiveFilterChip("type", ResultTypeLabel(_resultType)) },
            .. string.IsNullOrWhiteSpace(_yearFrom) && string.IsNullOrWhiteSpace(_yearTo)
                ? []
                : new[] { new ActiveFilterChip("year", $"{(_yearFrom.Length > 0 ? _yearFrom : "Any")}–{(_yearTo.Length > 0 ? _yearTo : "Any")}") },
        ];

    private UniversalSearchResponseDto? FilteredResponse
    {
        get
        {
            if (_response is null)
                return null;

            var all = _response.Sections
                .SelectMany(section => section.Results)
                .Prepend(_response.TopResult)
                .Where(result => result is not null)
                .Cast<UniversalSearchResultDto>()
                .DistinctBy(result => $"{result.EntityType}:{result.Id}", StringComparer.OrdinalIgnoreCase)
                .Where(MatchesFilters)
                .ToList();

            all = SortResults(all).ToList();
            var sections = _response.Sections
                .Select(section => section with
                {
                    Results = SortResults(section.Results.Where(MatchesFilters)).ToList(),
                    TotalCount = section.Results.Count(MatchesFilters),
                })
                .Where(section => section.Results.Count > 0)
                .ToList();

            if (_selectedMedia.Count == 1 && all.Count > 0)
            {
                sections =
                [
                    new UniversalSearchSectionDto(
                        _selectedMedia[0].ToLowerInvariant(),
                        MediaSectionTitle(_selectedMedia[0]),
                        all,
                        all.Count,
                        ScopedRoute(_selectedMedia[0])),
                ];
            }

            return new UniversalSearchResponseDto(_response.Query, all.FirstOrDefault(), sections, all.Count);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var incoming = Query?.Trim() ?? string.Empty;
        var queryChanged = !string.Equals(incoming, _query, StringComparison.Ordinal);
        _query = incoming;
        _selectedMedia = (Media ?? []).Where(MediaOptions.Contains).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        _resultType = ResultType is "title" or "person" or "group" or "playlist" ? ResultType : "all";
        _yearFrom = YearFrom?.ToString() ?? string.Empty;
        _yearTo = YearTo?.ToString() ?? string.Empty;
        _sort = Sort is "title" or "newest" or "oldest" ? Sort : "relevance";

        if (queryChanged || (_response is null && _query.Length >= MinimumQueryLength))
            await SearchAsync();
        else
            SyncSelectedResultToFilters();
    }

    private Task OnQueryInputChanged(string? value)
    {
        _query = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private async Task OnSearchDebouncedAsync(string value)
    {
        _query = value?.Trim() ?? string.Empty;
        UpdateUrl();
        await SearchAsync();
    }

    private async Task SearchAsync()
    {
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _searchCts = new CancellationTokenSource();
        var ct = _searchCts.Token;
        _error = null;

        if (_query.Trim().Length < MinimumQueryLength)
        {
            _response = null;
            _selected = null;
            _loading = false;
            return;
        }

        _loading = true;
        try
        {
            var response = await ApiClient.GetUniversalSearchAsync(_query.Trim(), 80, ct);
            if (ct.IsCancellationRequested)
                return;
            _response = response;
            SyncSelectedResultToFilters(forceFirstMatch: true);
            _error = response is null ? ApiClient.LastError ?? "Search unavailable" : null;
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            if (!ct.IsCancellationRequested)
                _loading = false;
        }
    }

    private Task OnMediaChanged(IReadOnlyList<string> values)
    {
        _selectedMedia = values;
        SyncSelectedResultToFilters();
        UpdateUrl();
        return Task.CompletedTask;
    }

    private Task OnResultTypeChanged(string value)
    {
        _resultType = value;
        SyncSelectedResultToFilters();
        UpdateUrl();
        return Task.CompletedTask;
    }

    private Task OnSortChanged(string value)
    {
        _sort = value;
        UpdateUrl();
        return Task.CompletedTask;
    }

    private Task OnYearFromChanged(ChangeEventArgs args)
    {
        _yearFrom = NormalizeYear(args.Value?.ToString());
        SyncSelectedResultToFilters();
        UpdateUrl();
        return Task.CompletedTask;
    }

    private Task OnYearToChanged(ChangeEventArgs args)
    {
        _yearTo = NormalizeYear(args.Value?.ToString());
        SyncSelectedResultToFilters();
        UpdateUrl();
        return Task.CompletedTask;
    }

    private Task OnSelectedChanged(UniversalSearchResultDto? result)
    {
        _selected = result;
        return Task.CompletedTask;
    }

    private Task RemoveFilterAsync(string key)
    {
        if (key.StartsWith("media:", StringComparison.Ordinal))
            _selectedMedia = _selectedMedia.Where(value => !string.Equals(value, key[6..], StringComparison.OrdinalIgnoreCase)).ToList();
        else if (key == "type")
            _resultType = "all";
        else if (key == "year")
            _yearFrom = _yearTo = string.Empty;
        SyncSelectedResultToFilters();
        UpdateUrl();
        return Task.CompletedTask;
    }

    private Task ClearFiltersAsync()
    {
        _selectedMedia = [];
        _resultType = "all";
        _yearFrom = _yearTo = string.Empty;
        _sort = "relevance";
        SyncSelectedResultToFilters();
        UpdateUrl();
        return Task.CompletedTask;
    }

    private bool MatchesFilters(UniversalSearchResultDto result)
    {
        if (_selectedMedia.Count > 0 && !_selectedMedia.Contains(result.MediaType ?? string.Empty, StringComparer.OrdinalIgnoreCase))
            return false;

        if (_resultType != "all" && !MatchesResultType(result, _resultType))
            return false;

        var year = int.TryParse(result.Year, out var parsed) ? parsed : (int?)null;
        if (int.TryParse(_yearFrom, out var from) && (year is null || year < from))
            return false;
        if (int.TryParse(_yearTo, out var to) && (year is null || year > to))
            return false;
        return true;
    }

    private void SyncSelectedResultToFilters(bool forceFirstMatch = false)
    {
        var matching = _response?.Sections
            .SelectMany(section => section.Results)
            .Where(MatchesFilters)
            .DistinctBy(result => $"{result.EntityType}:{result.Id}", StringComparer.OrdinalIgnoreCase)
            .ToList() ?? [];

        if (!forceFirstMatch && _selected is not null && matching.Any(result =>
                result.Id == _selected.Id &&
                string.Equals(result.EntityType, _selected.EntityType, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        _selected = SortResults(matching).FirstOrDefault();
    }

    private IEnumerable<UniversalSearchResultDto> SortResults(IEnumerable<UniversalSearchResultDto> results) => _sort switch
    {
        "title" => results.OrderBy(result => result.Title, StringComparer.OrdinalIgnoreCase),
        "newest" => results.OrderByDescending(result => ParseYear(result.Year)).ThenBy(result => result.Title, StringComparer.OrdinalIgnoreCase),
        "oldest" => results.OrderBy(result => ParseYear(result.Year) == 0 ? int.MaxValue : ParseYear(result.Year)).ThenBy(result => result.Title, StringComparer.OrdinalIgnoreCase),
        _ => results.OrderByDescending(result => result.Relevance).ThenBy(result => result.Title, StringComparer.OrdinalIgnoreCase),
    };

    private void UpdateUrl()
    {
        var values = new List<string>();
        if (!string.IsNullOrWhiteSpace(_query)) values.Add($"q={Uri.EscapeDataString(_query.Trim())}");
        values.AddRange(_selectedMedia.Select(value => $"media={Uri.EscapeDataString(value)}"));
        if (_resultType != "all") values.Add($"type={Uri.EscapeDataString(_resultType)}");
        if (_yearFrom.Length > 0) values.Add($"yearFrom={_yearFrom}");
        if (_yearTo.Length > 0) values.Add($"yearTo={_yearTo}");
        if (_sort != "relevance") values.Add($"sort={Uri.EscapeDataString(_sort)}");
        Nav.NavigateTo(values.Count == 0 ? "/search" : $"/search?{string.Join("&", values)}", replace: true);
    }

    private string ScopedRoute(string mediaType)
    {
        var baseRoute = mediaType switch
        {
            "Book" => "/read/books",
            "Comic" => "/read/comics",
            "Movie" => "/watch/movies",
            "TV" => "/watch/tv",
            "Music" => "/listen/music",
            "Audiobook" => "/listen/audiobooks",
            _ => "/search",
        };
        return $"{baseRoute}?q={Uri.EscapeDataString(_query)}";
    }

    private static bool MatchesResultType(UniversalSearchResultDto result, string type) => type switch
    {
        "title" => result.EntityType is "book" or "comic" or "movie" or "tv-show" or "album" or "song" or "audiobook",
        "person" => result.EntityType == "person",
        "group" => result.EntityType is "series" or "collection",
        "playlist" => result.EntityType == "playlist",
        _ => true,
    };

    private static int ParseYear(string? value) => int.TryParse(value, out var parsed) ? parsed : 0;
    private static string NormalizeYear(string? value) => int.TryParse(value, out var parsed) && parsed is >= 1000 and <= 9999 ? parsed.ToString() : string.Empty;
    private static string ResultTypeLabel(string value) => value switch { "title" => "Titles", "person" => "People", "group" => "Series & Collections", "playlist" => "Playlists", _ => value };
    private static string MediaSectionTitle(string mediaType) => mediaType switch { "TV" => "TV Shows", "Music" => "Music", "Audiobook" => "Audiobooks", _ => $"{mediaType}s" };

    public void Dispose()
    {
        _searchCts?.Cancel();
        _searchCts?.Dispose();
    }
}
