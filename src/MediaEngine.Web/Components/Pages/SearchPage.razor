@page "/search"
@namespace MediaEngine.Web.Components.Pages
@inject UniverseStateContainer State
@inject NavigationManager Nav

<PageTitle>Search — Tuvima Library</PageTitle>

<div class="search-page">
    <div class="search-page-header">
        <MudIcon Icon="@Icons.Material.Outlined.Search"
                 Style="font-size: 2.5rem; color: rgba(248,248,248,0.25); margin-bottom: 12px;" />
        <h2 class="search-page-title">Search your library</h2>
        <p class="search-page-subtitle">Use the search bar above to find books, audiobooks, and comics.</p>
    </div>

    @if (State.IsLoaded && State.FilteredHubs.Count > 0)
    {
        <div class="search-recent">
            <h3 class="search-recent-title">All titles</h3>
            <div class="search-recent-grid">
                @foreach (var hub in State.FilteredHubs.Take(24))
                {
                    <div class="search-recent-item" @onclick="@(() => Nav.NavigateTo($"/book/{hub.Works.FirstOrDefault()?.Id ?? hub.Id}"))">
                        @if (!string.IsNullOrEmpty(hub.CoverUrl))
                        {
                            <img src="@hub.CoverUrl" alt="@hub.DisplayName" class="search-recent-cover" loading="lazy" />
                        }
                        else
                        {
                            <div class="search-recent-cover search-recent-cover-placeholder">
                                <MudIcon Icon="@Icons.Material.Filled.MenuBook"
                                         Style="font-size: 28px; color: rgba(255,255,255,0.25);" />
                            </div>
                        }
                        <span class="search-recent-name">@hub.DisplayName</span>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .search-page {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        padding-left: 16px;
    }

    .search-page-header {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        padding-top: 1rem;
    }

    .search-page-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: rgba(248, 248, 248, 0.85);
        margin: 0 0 8px 0;
    }

    .search-page-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.95rem;
        color: rgba(248, 248, 248, 0.40);
        margin: 0;
    }

    .search-recent-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.60);
        margin: 0 0 16px 0;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .search-recent-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
    }

    .search-recent-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        width: 100px;
    }

    .search-recent-cover {
        width: 100px;
        height: 150px;
        object-fit: cover;
        border-radius: 8px;
    }

    .search-recent-cover-placeholder {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.06);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .search-recent-name {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.70);
        text-align: center;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        width: 100%;
    }
</style>
