@page "/watch/movie/{WorkId:guid}"
@page "/watch/movie/{WorkId:guid}/{Tab}"
@using MediaEngine.Contracts.Details
@using MediaEngine.Web.Components.Details
@using MediaEngine.Web.Services.Integration
@inject IEngineApiClient ApiClient
@inject NavigationManager Nav

@namespace MediaEngine.Web.Components.Pages

<PageTitle>@((_detail?.Title ?? "Movie")) - Tuvima</PageTitle>

@if (_loading)
{
    <div class="tl-detail-page">
        <div class="tl-glass-panel">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        </div>
    </div>
}
else if (_detail is null)
{
    <div class="tl-detail-page">
        <div class="tl-glass-panel">
            <MudText Typo="Typo.h5">Movie not found</MudText>
            <MudText Typo="Typo.body2">This title could not be loaded from your library.</MudText>
        </div>
    </div>
}
else
{
    <DetailPage Model="_detail" ActiveTab="@_activeTab" ActiveTabChanged="HandleTabChangedAsync" OnActionSelected="HandleActionAsync" />
}

@code {
    [Parameter] public Guid WorkId { get; set; }
    [Parameter] public string? Tab { get; set; }

    [SupplyParameterFromQuery(Name = "collectionId")]
    public Guid? CollectionId { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private DetailPageViewModel? _detail;
    private bool _loading = true;
    private string? _activeTab;
    private static readonly HashSet<string> PreservedQueryKeys = new(StringComparer.OrdinalIgnoreCase)
    {
        "collectionId",
        "returnUrl",
    };

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _detail = await ApiClient.GetDetailPageAsync(DetailEntityType.Movie, WorkId, DetailPresentationContext.Watch);
        ApplyDetailTabRoute();
        _loading = false;
    }

    private Task HandleActionAsync(DetailAction action)
    {
        if (!string.IsNullOrWhiteSpace(action.Route))
            Nav.NavigateTo(action.Route);

        return Task.CompletedTask;
    }

    private Task HandleTabChangedAsync(string tab)
    {
        Nav.NavigateTo(BuildTabUrl(tab));
        return Task.CompletedTask;
    }

    private void ApplyDetailTabRoute()
    {
        if (_detail is null)
            return;

        var resolution = DetailTabNavigation.Resolve(_detail, Tab);
        _activeTab = resolution.ActiveTab;

        if (resolution.ShouldRedirect)
        {
            Nav.NavigateTo(BuildTabUrl(resolution.ActiveTab), replace: true);
        }
    }

    private string BuildTabUrl(string? tab) =>
        DetailTabNavigation.BuildUrl($"/watch/movie/{WorkId:D}", tab, Nav.ToAbsoluteUri(Nav.Uri), PreservedQueryKeys);
}
