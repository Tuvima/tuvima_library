@page "/watch/movie/{WorkId:guid}"
@using MediaEngine.Contracts.Details
@using MediaEngine.Web.Components.Details
@using MediaEngine.Web.Services.Integration
@inject IEngineApiClient ApiClient
@inject NavigationManager Nav

@namespace MediaEngine.Web.Components.Pages

<PageTitle>@((_detail?.Title ?? "Movie")) - Tuvima</PageTitle>

@if (_loading)
{
    <div class="tl-detail-page">
        <div class="tl-glass-panel">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        </div>
    </div>
}
else if (_detail is null)
{
    <div class="tl-detail-page">
        <div class="tl-glass-panel">
            <MudText Typo="Typo.h5">Movie not found</MudText>
            <MudText Typo="Typo.body2">This title could not be loaded from your library.</MudText>
        </div>
    </div>
}
else
{
    <DetailPage Model="_detail" OnActionSelected="HandleActionAsync" />
}

@code {
    [Parameter] public Guid WorkId { get; set; }

    [SupplyParameterFromQuery(Name = "collectionId")]
    public Guid? CollectionId { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private DetailPageViewModel? _detail;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _detail = await ApiClient.GetDetailPageAsync(DetailEntityType.Movie, WorkId, DetailPresentationContext.Watch);
        _loading = false;
    }

    private Task HandleActionAsync(DetailAction action)
    {
        if (!string.IsNullOrWhiteSpace(action.Route))
            Nav.NavigateTo(action.Route);

        return Task.CompletedTask;
    }
}
