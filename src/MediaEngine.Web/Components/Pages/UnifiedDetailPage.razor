@page "/details/{EntityType}/{Id:guid}"
@using MediaEngine.Contracts.Details
@using MediaEngine.Web.Components.Details
@using MediaEngine.Web.Services.Integration
@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav
@inject IJSRuntime JS

@namespace MediaEngine.Web.Components.Pages

<PageTitle>@((_detail?.Title ?? "Details")) - Tuvima Library</PageTitle>

@if (_loading)
{
    <div class="tl-detail-page">
        <div class="tl-glass-panel">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        </div>
    </div>
}
else if (_detail is null)
{
    <div class="tl-detail-page">
        <div class="tl-glass-panel">
            <MudText Typo="Typo.h5">Detail page not found</MudText>
            <MudText Typo="Typo.body2">This item could not be loaded from your library.</MudText>
        </div>
    </div>
}
else
{
    <div class="tl-unified-detail-shell">
        <AppNativeButton Type="button"
                         Class="tl-detail-origin-back"
                         OnClick="NavigateBackAsync"
                         aria-label="@BackLabel">
            <MudIcon Icon="@Icons.Material.Outlined.ArrowBack" Size="Size.Small" />
            <span>@BackLabel</span>
        </AppNativeButton>
        <DetailPage Model="_detail"
                    ActiveTab="@_activeTab"
                    ActiveTabChanged="HandleTabChangedAsync"
                    OnActionSelected="HandleActionAsync" />
    </div>
}

@code {
    [Parameter] public string EntityType { get; set; } = string.Empty;
    [Parameter] public Guid Id { get; set; }

    [SupplyParameterFromQuery(Name = "context")]
    public string? Context { get; set; }

    private DetailPageViewModel? _detail;
    private bool _loading = true;
    private string? _activeTab;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("detailOrigin.initialize");
    }

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _detail = null;

        if (!TryParseEntityType(EntityType, out var entityType))
        {
            _loading = false;
            return;
        }

        var context = ParseContext(Context);
        var profile = await Orchestrator.GetActiveProfileAsync();
        _detail = await ApiClient.GetDetailPageAsync(entityType, Id, context, profileId: profile?.Id);
        ApplyDetailTabRoute();
        _loading = false;
    }

    private Task HandleActionAsync(DetailAction action)
    {
        if (!string.IsNullOrWhiteSpace(action.Route))
            Nav.NavigateTo(action.Route);

        return Task.CompletedTask;
    }

    private Task HandleTabChangedAsync(string tab)
    {
        _activeTab = tab;
        return Task.CompletedTask;
    }

    private async Task NavigateBackAsync()
        => await JS.InvokeVoidAsync("detailOrigin.back", FallbackRoute);

    private string BackLabel => ParseContext(Context) switch
    {
        DetailPresentationContext.Listen => "Back to Listen",
        DetailPresentationContext.Watch => "Back to Watch",
        DetailPresentationContext.Read or DetailPresentationContext.Comics => "Back to Read",
        _ => "Back",
    };

    private string FallbackRoute => ParseContext(Context) switch
    {
        DetailPresentationContext.Listen => "/listen",
        DetailPresentationContext.Watch => "/watch",
        DetailPresentationContext.Read or DetailPresentationContext.Comics => "/read",
        _ => "/",
    };

    private void ApplyDetailTabRoute()
    {
        if (_detail is null)
            return;

        var resolution = DetailTabNavigation.Resolve(_detail, _activeTab);
        _activeTab = resolution.ActiveTab;
    }

    private static bool TryParseEntityType(string value, out DetailEntityType entityType)
    {
        var normalized = value.Replace("-", string.Empty, StringComparison.Ordinal).Replace("_", string.Empty, StringComparison.Ordinal);
        if (normalized.Contains("podcast", StringComparison.OrdinalIgnoreCase))
        {
            entityType = default;
            return false;
        }

        return Enum.TryParse(normalized, ignoreCase: true, out entityType)
            && entityType != DetailEntityType.TvEpisode;
    }

    private static DetailPresentationContext ParseContext(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return DetailPresentationContext.Default;

        var normalized = value.Replace("-", string.Empty, StringComparison.Ordinal).Replace("_", string.Empty, StringComparison.Ordinal);
        return Enum.TryParse(normalized, ignoreCase: true, out DetailPresentationContext context)
            ? context
            : DetailPresentationContext.Default;
    }
}
