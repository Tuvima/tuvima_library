@* Routes have moved to LibraryBrowsePage.razor — this file is retained for reference. *@
@page "/books-legacy"
@page "/video-legacy"
@page "/music-legacy"
@page "/podcasts-legacy"
@page "/comics-legacy"
@inject UIOrchestratorService  Orchestrator
@inject UniverseStateContainer  State
@inject DeviceContextService    DeviceContext
@inject NavigationManager       Nav
@inject IPhraseTemplateService  Phrases
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

@using MediaEngine.Web.Models.ViewDTOs

<PageTitle>@(_lane?.Label ?? "Library") — Tuvima</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else if (_lane is null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">@L["MediaLane_UnknownLane"]</MudAlert>
}
else if (!IsImplementedLane)
{
    @* ── Coming Soon — lane not yet implemented ── *@
    <div class="lane-empty-state">
        <MudIcon Icon="@_lane.Icon" Size="Size.Large"
                 Style="@($"opacity: 0.3; font-size: 4rem; margin-bottom: 16px; color: {ContentLanes.AccentColor(_lane)};")" />
        <h2 class="lane-empty-title" style="@($"color: {ContentLanes.AccentColor(_lane)};")">@L["MediaLane_ComingSoon"]</h2>
        <p class="lane-empty-subtitle">
            @_lane.Label will be available in a future update. Stay tuned!
        </p>
    </div>
}
else if (_laneWorks.Count == 0 && _allHubs.Count == 0)
{
    @* ── Empty state — no content for this lane ── *@
    <div class="lane-empty-state">
        <MudIcon Icon="@_lane.Icon" Size="Size.Large"
                 Style="opacity: 0.3; font-size: 4rem; margin-bottom: 16px;" />
        <h2 class="lane-empty-title">No @_lane.Label yet</h2>
        <p class="lane-empty-subtitle">
            @EmptyStateMessage(_lane.Key)
        </p>
    </div>
}
else
{
    @* ── Hero banner ── *@
    @if (_heroHub is not null)
    {
        var heroWork = _heroHub.Works.FirstOrDefault();
        HeroData heroData;
        if (_heroJourney is not null && heroWork is not null)
        {
            heroData = HeroData.FromWork(heroWork, _heroHub) with
            {
                ActionLabel = _heroJourney.ActionLabel,
                ActionIcon  = HeroData.IconForMediaType(_heroJourney.MediaType),
                ProgressPct = _heroJourney.ProgressPct,
            };
        }
        else if (heroWork is not null)
        {
            heroData = HeroData.FromWork(heroWork, _heroHub);
        }
        else
        {
            heroData = HeroData.FromHub(_heroHub);
        }
        heroData = heroData with { Subtitle = ResolveHeroPhrase(heroData) };
        <HubHero Data="@heroData"
                 Visible="true"
                 OnClicked="@(() => Nav.NavigateTo($"/book/{_heroHub.Works.FirstOrDefault()?.Id ?? _heroHub.Id}"))"
                 OnCtaClicked="@(() => { if (_heroJourney is not null) HandleJourneyPlay(_heroJourney); })" />
    }

    @* ── Mobile filter bar (visible on mobile only) ── *@
    <MobileFilterBar CurrentLane="@_lane"
                     FilterState="@_filterState"
                     FilterStateChanged="OnFilterChanged"
                     Config="@_filterConfig"
                     AvailableGenres="@_availableGenres" />

    @* ── View mode toggle ── *@
    <div class="lane-view-toggle">
        <MudToggleGroup T="string" Value="@_viewMode" ValueChanged="OnViewModeChanged"
                        Color="Color.Warning" CheckMark="false"
                        Style="font-family: Montserrat, sans-serif;">
            <MudToggleItem T="string" Value="@("smart")" Text="@L["MediaLane_SmartSections"]" />
            <MudToggleItem T="string" Value="@("az")" Text="@L["MediaLane_BrowseAZ"]" />
        </MudToggleGroup>
    </div>

    @* ── Desktop filter bar (hidden on mobile) ── *@
    <LaneFilterBar FilterState="@_filterState"
                   FilterStateChanged="OnFilterChanged"
                   Config="@_filterConfig"
                   AvailableGenres="@_availableGenres"
                   AvailablePersons="@_availablePersons"
                   AvailableSeries="@_availableSeries" />

    @if (_viewMode == "az")
    {
        @* ── A-Z Browse mode ── *@
        <AlphabeticalGrid Items="@WorksToItems(_displayWorks)"
                          OnItemSelected="HandleItemSelected"
                          CardWidth="@_cardWidth" />
    }
    else
    {
        @* ── Smart Sections mode ── *@

        @* Continue Journey *@
        @if (_journeyHubs.Count > 0)
        {
            <PosterSwimlane Title="@ContinueLabel"
                            TotalCount="@_journeyHubs.Count"
                            Items="@FlattenToItems(_journeyHubs)"
                            OnItemSelected="HandleItemSelected"
                            CardWidth="@_cardWidth" />
        }

        @* Recently Added *@
        @if (_recentWorks.Count > 0 && !_filterState.HasActiveFilters)
        {
            <PosterSwimlane Title="@L["MediaLane_RecentlyAdded"]"
                            TotalCount="@_recentWorks.Count"
                            Items="@WorksToItems(_recentWorks.Take(12))"
                            OnItemSelected="HandleItemSelected"
                            CardWidth="@_cardWidth" />
        }

        @* Filtered results (when filters are active) *@
        @if (_filterState.HasActiveFilters)
        {
            <PosterSwimlane Title="@($"Results ({_displayWorks.Count})")"
                            TotalCount="@_displayWorks.Count"
                            Items="@WorksToItems(_displayWorks.Take(24))"
                            OnItemSelected="HandleItemSelected"
                            CardWidth="@_cardWidth" />
        }
        else
        {
            @* Featured Persons (Author, Director, Artist, etc.) *@
            @foreach (var personGroup in _personGroups.Take(5))
            {
                <PosterSwimlane Title="@personGroup.PersonName"
                                Items="@WorksToItems(personGroup.Works)"
                                OnItemSelected="HandleItemSelected"
                                CardWidth="@_cardWidth">
                    <HeaderContent>
                        <PersonSwimlaneHeader PersonName="@personGroup.PersonName"
                                              HeadshotUrl="@personGroup.HeadshotUrl"
                                              ItemCount="@personGroup.Works.Count"
                                              ItemNoun="@_filterConfig.ItemNoun" />
                    </HeaderContent>
                </PosterSwimlane>
            }

            @* By Series / Franchise *@
            @if (_filterConfig.SeriesLabel is not null)
            {
                @foreach (var seriesGroup in _seriesGroups.Take(5))
                {
                    <PosterSwimlane Title="@seriesGroup.Name"
                                    TotalCount="@seriesGroup.Works.Count"
                                    Items="@WorksToItems(seriesGroup.Works)"
                                    OnItemSelected="HandleItemSelected"
                                    CardWidth="@_cardWidth" />
                }
            }

            @* By Genre *@
            @foreach (var genreGroup in _genreGroups.Take(5))
            {
                <PosterSwimlane Title="@genreGroup.Name"
                                TotalCount="@genreGroup.Works.Count"
                                Items="@WorksToItems(genreGroup.Works)"
                                OnItemSelected="HandleItemSelected"
                                CardWidth="@_cardWidth" />
            }

            @* Media-type sub-groups (e.g. Books lane → "eBooks", "Audiobooks") *@
            @foreach (var group in _mediaTypeGroups)
            {
                <PosterSwimlane Title="@group.Name"
                                TotalCount="@group.Works.Count"
                                Items="@WorksToItems(group.Works)"
                                OnItemSelected="HandleItemSelected"
                                CardWidth="@_cardWidth" />
            }
        }
    }
}

@code {
    private bool               _loading = true;
    private string             _viewMode = "smart";
    private LaneDefinition?    _lane;
    private LaneFilterConfig   _filterConfig = LaneFilterConfig.ForLane("books");
    private LaneFilterState    _filterState = new();
    private HubViewModel?      _heroHub;
    private JourneyItemViewModel? _heroJourney;

    private List<HubViewModel> _allHubs = [];
    private List<HubViewModel> _displayHubs = [];
    private List<HubViewModel> _recentHubs = [];
    private List<HubViewModel> _journeyHubs = [];
    private List<PersonGroup>  _personGroups = [];
    private List<NamedGroup>   _seriesGroups = [];
    private List<NamedGroup>   _genreGroups = [];
    private List<NamedGroup>   _mediaTypeGroups = [];

    private List<WorkViewModel> _libraryWorks = [];
    private List<WorkViewModel> _laneWorks = [];
    private List<WorkViewModel> _displayWorks = [];
    private List<WorkViewModel> _recentWorks = [];

    private IReadOnlyList<string> _availableGenres = [];
    private IReadOnlyList<string> _availablePersons = [];
    private IReadOnlyList<string> _availableSeries = [];
    private Dictionary<string, PersonViewModel> _personLookup = new();

    private int _cardWidth => DeviceContext.Settings.Pages.Home.SwimlaneCardWidth;

    /// <summary>Only Books is fully implemented. Other lanes show "Coming Soon".</summary>
    private bool IsImplementedLane => _lane?.Key is "books";

    /// <summary>
    /// Flattens hubs into individual work items for the Books lane,
    /// or wraps as hub-level items for other lanes.
    /// </summary>
    private IReadOnlyList<PosterItemViewModel> FlattenToItems(IEnumerable<HubViewModel> hubs) =>
        hubs.SelectMany(h => h.Works.Select(w =>
                PosterItemViewModel.FromWork(w, h.CoverUrl, h.DominantHexColor)))
            .ToList();

    /// <summary>
    /// Builds poster items directly from works (work-first display).
    /// </summary>
    private static IReadOnlyList<PosterItemViewModel> WorksToItems(IEnumerable<WorkViewModel> works) =>
        works.Select(w => PosterItemViewModel.FromWork(w, null, null)).ToList();

    private string ContinueLabel => _lane?.Key switch
    {
        "books"    => L["MediaLane_ContinueReading"],
        "video"    => L["MediaLane_ContinueWatching"],
        "music"    => L["MediaLane_ContinueListening"],
        "podcasts" => L["MediaLane_ContinueListening"],
        "comics"   => L["MediaLane_ContinueReading"],
        _          => L["MediaLane_Continue"],
    };

    private sealed record PersonGroup(string PersonName, string? HeadshotUrl, IReadOnlyList<HubViewModel> Hubs, IReadOnlyList<WorkViewModel> Works);
    private sealed record NamedGroup(string Name, IReadOnlyList<HubViewModel> Hubs, IReadOnlyList<WorkViewModel> Works);

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        ResolveLane();
        await LoadAsync();
    }

    // Blazor reuses this component when navigating between /books, /video, /podcasts etc.
    // because they all map to MediaLanePage with no [Parameter] attributes — so
    // OnParametersSetAsync never fires again. LocationChanged is the reliable hook.
    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var path = new Uri(e.Location).AbsolutePath.Trim('/');
        if (ContentLanes.ByKey(path) is not null)
        {
            ResolveLane();
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ResolveLane()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Split('#')[0].Trim('/');
        _lane = ContentLanes.ByKey(path);
        _filterConfig = LaneFilterConfig.ForLane(_lane?.Key ?? "");
        _filterState = new LaneFilterState();

        // Set the lane filter on the state container.
        State.SetLaneFilter(_lane?.MediaTypes);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var allHubs = await Orchestrator.GetHubsAsync();
            _libraryWorks = await Orchestrator.GetLibraryWorksAsync();
            var journeyItems = await Orchestrator.GetJourneyAsync(limit: 5);

            // Filter works to this lane's media types (primary data source).
            if (_lane is not null)
            {
                _laneWorks = _libraryWorks
                    .Where(w => _lane.MediaTypes.Any(mt =>
                        (w.MediaType ?? "").Contains(mt, StringComparison.OrdinalIgnoreCase)))
                    .ToList();
            }
            else
            {
                _laneWorks = [];
            }

            // Keep hub filtering for backward compat (hero, journey).
            if (_lane is not null)
            {
                _allHubs = allHubs
                    .Where(h => _lane.MediaTypes.Any(mt =>
                        (h.PrimaryMediaType ?? "").Contains(mt, StringComparison.OrdinalIgnoreCase)))
                    .ToList();
            }
            else
            {
                _allHubs = [];
            }

            // Journey items for this lane.
            _journeyHubs = journeyItems
                .Where(j => j.HubId.HasValue && _allHubs.Any(h => h.Id == j.HubId))
                .Select(j => _allHubs.First(h => h.Id == j.HubId))
                .ToList();

            // Load person headshots for smart sections.
            try
            {
                var persons = await Orchestrator.GetPersonsByRoleAsync(_filterConfig.PersonLabel, 50);
                _personLookup = persons
                    .GroupBy(p => p.Name.ToLowerInvariant())
                    .ToDictionary(g => g.Key, g => g.First());
            }
            catch { _personLookup = new(); }

            BuildFilterOptions();
            ApplyFilters(journeyItems);
        }
        catch
        {
            _allHubs = [];
            _laneWorks = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildFilterOptions()
    {
        // Build filter options from works (primary data source).
        _availableGenres = _laneWorks
            .Where(w => w.Genres.Count > 0 || !string.IsNullOrEmpty(w.Genre))
            .SelectMany(w => w.Genres.Count > 0
                ? w.Genres
                : w.Genre!.Split(['|', ',', ';'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Where(g => g != "|"))
            .Where(g => g.Length > 0)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(g => g)
            .ToList();

        _availablePersons = _laneWorks
            .Where(w => !string.IsNullOrEmpty(w.Author))
            .Select(w => w.Author!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(a => a)
            .ToList();

        _availableSeries = _laneWorks
            .Where(w => !string.IsNullOrEmpty(w.Series))
            .Select(w => w.Series!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(s => s)
            .ToList();
    }

    private void ApplyFilters(IReadOnlyList<JourneyItemViewModel>? journeyItems = null)
    {
        // Apply filters to works (primary data source).
        var filteredWorks = _laneWorks.AsEnumerable();

        // Format filter.
        if (_filterState.Format != "All")
        {
            var fmt = _filterState.Format.ToLowerInvariant();
            filteredWorks = filteredWorks.Where(w =>
                (w.MediaType ?? "").Contains(fmt, StringComparison.OrdinalIgnoreCase));
        }

        // Genre filter.
        if (_filterState.SelectedGenres.Count > 0)
            filteredWorks = filteredWorks.Where(w => !string.IsNullOrEmpty(w.Genre)
                && _filterState.SelectedGenres.Any(g =>
                    w.Genre!.Contains(g, StringComparison.OrdinalIgnoreCase)));

        // Person filter.
        if (!string.IsNullOrEmpty(_filterState.PersonSearch))
            filteredWorks = filteredWorks.Where(w => !string.IsNullOrEmpty(w.Author)
                && w.Author!.Contains(_filterState.PersonSearch, StringComparison.OrdinalIgnoreCase));

        // Series filter.
        if (!string.IsNullOrEmpty(_filterState.SeriesFilter))
            filteredWorks = filteredWorks.Where(w => !string.IsNullOrEmpty(w.Series)
                && w.Series!.Equals(_filterState.SeriesFilter, StringComparison.OrdinalIgnoreCase));

        // Year range.
        if (!string.IsNullOrEmpty(_filterState.YearFrom) && int.TryParse(_filterState.YearFrom, out var from))
            filteredWorks = filteredWorks.Where(w => int.TryParse(w.Year, out var y) && y >= from);
        if (!string.IsNullOrEmpty(_filterState.YearTo) && int.TryParse(_filterState.YearTo, out var to))
            filteredWorks = filteredWorks.Where(w => int.TryParse(w.Year, out var y) && y <= to);

        // Sort.
        filteredWorks = _filterState.SortBy switch
        {
            "title-az"  => filteredWorks.OrderBy(w => w.Title),
            "title-za"  => filteredWorks.OrderByDescending(w => w.Title),
            "person-az" => filteredWorks.OrderBy(w => w.Author ?? "zzz"),
            "year-new"  => filteredWorks.OrderByDescending(w => w.Year ?? "0"),
            "year-old"  => filteredWorks.OrderBy(w => w.Year ?? "9999"),
            _           => filteredWorks.OrderByDescending(w =>
                               w.CanonicalValues.Select(cv => cv.LastScoredAt).DefaultIfEmpty(DateTimeOffset.MinValue).Max()),
        };

        _displayWorks = filteredWorks.ToList();

        // Recently added works (sorted by most recent canonical value timestamp).
        _recentWorks = _displayWorks
            .OrderByDescending(w =>
                w.CanonicalValues.Select(cv => cv.LastScoredAt).DefaultIfEmpty(DateTimeOffset.MinValue).Max())
            .Take(12)
            .ToList();

        // Keep hub filtering for backward compat (hero selection, journey).
        _displayHubs = _allHubs.OrderByDescending(h => h.CreatedAt).ToList();

        // Hero selection — prefer active journey item.
        var withCovers = _displayHubs.Where(h =>
            !string.IsNullOrEmpty(h.CoverUrl) || !string.IsNullOrEmpty(h.HeroUrl)).ToList();
        var heroPool = withCovers.Count > 0 ? withCovers : _displayHubs;

        if (journeyItems is { Count: > 0 })
        {
            var topJourney = journeyItems
                .Where(j => j.HubId.HasValue && heroPool.Any(h => h.Id == j.HubId))
                .OrderByDescending(j => j.LastAccessed)
                .FirstOrDefault();

            if (topJourney is not null)
            {
                _heroHub     = heroPool.First(h => h.Id == topJourney.HubId);
                _heroJourney = topJourney;
            }
            else
            {
                _heroHub     = heroPool.Count > 0 ? heroPool[Random.Shared.Next(heroPool.Count)] : null;
                _heroJourney = null;
            }
        }
        else
        {
            _heroHub     = heroPool.Count > 0 ? heroPool[Random.Shared.Next(heroPool.Count)] : null;
            _heroJourney = null;
        }

        // Keep hub-based recent for backward compat.
        _recentHubs = _displayHubs.Take(12).ToList();

        // Build smart section groups.
        BuildGroups();
    }

    private void BuildGroups()
    {
        // Person groups from works (primary data source).
        _personGroups = _displayWorks
            .Where(w => !string.IsNullOrEmpty(w.Author))
            .GroupBy(w => w.Author!, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 2)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g =>
            {
                _personLookup.TryGetValue(g.Key.ToLowerInvariant(), out var person);
                var headshot = person?.LocalHeadshotUrl ?? person?.HeadshotUrl;
                return new PersonGroup(g.Key, headshot, [], g.ToList());
            })
            .ToList();

        // Series groups from works.
        _seriesGroups = _displayWorks
            .Where(w => !string.IsNullOrEmpty(w.Series))
            .GroupBy(w => w.Series!, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 2)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g => new NamedGroup(g.Key, [],
                g.OrderBy(w => w.Year ?? "9999").ToList()))
            .ToList();

        // Genre groups from works.
        _genreGroups = _displayWorks
            .Where(w => w.Genres.Count > 0 || !string.IsNullOrEmpty(w.Genre))
            .SelectMany(w => (w.Genres.Count > 0
                    ? w.Genres
                    : w.Genre!.Split(['|', ',', ';'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .Where(g => g != "|"))
                .Where(g => g.Length > 0)
                .Select(g => (Genre: g, Work: w)))
            .GroupBy(x => x.Genre, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 2)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g => new NamedGroup(g.Key, [],
                g.Select(x => x.Work).Distinct().ToList()))
            .ToList();

        // Media-type sub-groups from works (e.g. Books lane → "eBooks", "Audiobooks").
        _mediaTypeGroups = _laneWorks
            .Where(w => !string.IsNullOrEmpty(w.MediaType))
            .GroupBy(w => FormatMediaType(w.MediaType!))
            .Where(g => g.Count() >= 2)
            .Select(g => new NamedGroup(g.Key, [], g.ToList()))
            .ToList();
    }

    private Task OnFilterChanged(LaneFilterState newState)
    {
        _filterState = newState;
        ApplyFilters();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void OnViewModeChanged(string value)
    {
        _viewMode = value ?? "smart";
    }

    private void HandleHubSelected(HubViewModel hub) =>
        Nav.NavigateTo($"/book/{hub.Works.FirstOrDefault()?.Id ?? hub.Id}");

    private void HandleItemSelected(PosterItemViewModel item) =>
        Nav.NavigateTo(item.NavigationUrl);

    private void HandleJourneyPlay(JourneyItemViewModel item)
    {
        var t = item.MediaType.ToLowerInvariant();
        if (t.Contains("epub") || t.Contains("book"))
        {
            var url = $"/read/{item.AssetId}";
            if (item.HubId.HasValue) url += $"?returnHubId={item.HubId.Value}";
            Nav.NavigateTo(url);
        }
        else if (item.HubId.HasValue)
        {
            Nav.NavigateTo($"/book/{item.HubId.Value}?lastAssetId={item.AssetId}");
        }
    }

    private void OnStateChanged()
    {
        InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });
    }

    private string FormatMediaType(string mediaType)
    {
        var t = mediaType.ToLowerInvariant();
        if (t.Contains("epub") || t.Contains("book"))   return L["MediaLane_FormatEBooks"];
        if (t.Contains("video") || t.Contains("movie")) return L["MediaLane_FormatMovies"];
        if (t.Contains("audio") || t.Contains("m4b"))   return L["MediaLane_FormatAudiobooks"];
        if (t.Contains("comic") || t.Contains("cbz"))   return L["MediaLane_FormatComics"];
        if (t.Contains("tv"))                            return L["MediaLane_FormatTVShows"];
        return mediaType;
    }

    private string EmptyStateMessage(string laneKey) => laneKey switch
    {
        "books"    => L["MediaLane_EmptyBooks"],
        "video"    => L["MediaLane_EmptyVideo"],
        "music"    => L["MediaLane_EmptyMusic"],
        "podcasts" => L["MediaLane_EmptyPodcasts"],
        "comics"   => L["MediaLane_EmptyComics"],
        _          => L["MediaLane_EmptyDefault"],
    };

    private string? ResolveHeroPhrase(HeroData data)
    {
        var hasProgress = data.ProgressPct is > 0;
        var isCompleted = data.ProgressPct is >= 99.5;

        var slot = isCompleted
            ? PhraseSlot.HeroCompleted
            : hasProgress
                ? (!string.IsNullOrEmpty(data.Series) ? PhraseSlot.HeroJourneySeries : PhraseSlot.HeroJourneyStandalone)
                : !string.IsNullOrEmpty(data.Series)
                    ? PhraseSlot.HeroDiscoverSeries
                    : !string.IsNullOrEmpty(data.Author)
                        ? PhraseSlot.HeroDiscoverAuthor
                        : PhraseSlot.HeroDiscoverStandalone;

        var ctx = new PhraseContext
        {
            EntityId = data.EntityId,
            Title = data.Title,
            Author = data.Author,
            Series = data.Series,
            Genre = data.Genre,
            MediaType = data.MediaTypeLabel,
            ProgressPct = data.ProgressPct,
        };

        var phrase = Phrases.Resolve(slot, ctx);
        return string.IsNullOrEmpty(phrase.Text) ? null : phrase.Text;
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        State.OnStateChanged -= OnStateChanged;
    }
}

<style>
    .lane-view-toggle {
        padding: 0.75rem 0 0.5rem 88px;
    }

    .lane-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 50vh;
        gap: 8px;
        text-align: center;
        padding: 2rem;
    }

    .lane-empty-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: rgba(248, 248, 248, 0.85);
        margin: 0;
    }

    .lane-empty-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
        font-weight: 400;
        color: rgba(248, 248, 248, 0.45);
        max-width: 420px;
        line-height: 1.5;
        margin: 0;
    }

    @@media (max-width: 768px) {
        .lane-view-toggle {
            padding-left: 1rem;
        }
    }
</style>
