@page "/books"
@page "/video"
@page "/music"
@page "/podcasts"
@page "/comics"
@inject UIOrchestratorService  Orchestrator
@inject UniverseStateContainer  State
@inject DeviceContextService    DeviceContext
@inject NavigationManager       Nav
@inject IPhraseTemplateService  Phrases
@implements IDisposable

@using MediaEngine.Web.Models.ViewDTOs

<PageTitle>@(_lane?.Label ?? "Library") — Tuvima</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else if (_lane is null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">Unknown content lane.</MudAlert>
}
else if (_allHubs.Count == 0)
{
    @* ── Empty state — no content for this lane ── *@
    <div class="lane-empty-state">
        <MudIcon Icon="@_lane.Icon" Size="Size.Large"
                 Style="opacity: 0.3; font-size: 4rem; margin-bottom: 16px;" />
        <h2 class="lane-empty-title">No @_lane.Label yet</h2>
        <p class="lane-empty-subtitle">
            @EmptyStateMessage(_lane.Key)
        </p>
    </div>
}
else
{
    @* ── Hero banner ── *@
    @if (_heroHub is not null)
    {
        var heroData = _heroJourney is not null
            ? HeroData.FromHubWithJourney(_heroHub, _heroJourney)
            : HeroData.FromHub(_heroHub);
        heroData = heroData with { Subtitle = ResolveHeroPhrase(heroData) };
        <HubHero Data="@heroData"
                 Visible="true"
                 OnClicked="@(() => Nav.NavigateTo($"/hub/{_heroHub.Id}"))"
                 OnCtaClicked="@(() => { if (_heroJourney is not null) HandleJourneyPlay(_heroJourney); })" />
    }

    @* ── Mobile filter bar (visible on mobile only) ── *@
    <MobileFilterBar CurrentLane="@_lane"
                     FilterState="@_filterState"
                     FilterStateChanged="OnFilterChanged"
                     Config="@_filterConfig"
                     AvailableGenres="@_availableGenres" />

    @* ── View mode toggle ── *@
    <div class="lane-view-toggle">
        <MudToggleGroup T="string" Value="@_viewMode" ValueChanged="OnViewModeChanged"
                        Color="Color.Warning" CheckMark="false"
                        Style="font-family: Montserrat, sans-serif;">
            <MudToggleItem T="string" Value="@("smart")" Text="Smart Sections" />
            <MudToggleItem T="string" Value="@("az")" Text="Browse A-Z" />
        </MudToggleGroup>
    </div>

    @* ── Desktop filter bar (hidden on mobile) ── *@
    <LaneFilterBar FilterState="@_filterState"
                   FilterStateChanged="OnFilterChanged"
                   Config="@_filterConfig"
                   AvailableGenres="@_availableGenres"
                   AvailablePersons="@_availablePersons"
                   AvailableSeries="@_availableSeries" />

    @if (_viewMode == "az")
    {
        @* ── A-Z Browse mode ── *@
        <AlphabeticalGrid Hubs="@_displayHubs"
                          OnHubSelected="HandleHubSelected"
                          CardWidth="@_cardWidth" />
    }
    else
    {
        @* ── Smart Sections mode ── *@

        @* Continue Journey *@
        @if (_journeyHubs.Count > 0)
        {
            <PosterSwimlane Title="@ContinueLabel"
                            TotalCount="@_journeyHubs.Count"
                            Hubs="@_journeyHubs"
                            OnHubSelected="HandleHubSelected"
                            CardWidth="@_cardWidth" />
        }

        @* Recently Added *@
        @if (_recentHubs.Count > 0 && !_filterState.HasActiveFilters)
        {
            <PosterSwimlane Title="Recently Added"
                            TotalCount="@_recentHubs.Count"
                            Hubs="@_recentHubs.Take(12).ToList()"
                            OnHubSelected="HandleHubSelected"
                            CardWidth="@_cardWidth" />
        }

        @* Filtered results (when filters are active) *@
        @if (_filterState.HasActiveFilters)
        {
            <PosterSwimlane Title="@($"Results ({_displayHubs.Count})")"
                            TotalCount="@_displayHubs.Count"
                            Hubs="@_displayHubs.Take(24).ToList()"
                            OnHubSelected="HandleHubSelected"
                            CardWidth="@_cardWidth" />
        }
        else
        {
            @* Featured Persons (Author, Director, Artist, etc.) *@
            @foreach (var personGroup in _personGroups.Take(5))
            {
                <PosterSwimlane Title="@personGroup.PersonName"
                                Hubs="@personGroup.Hubs"
                                OnHubSelected="HandleHubSelected"
                                CardWidth="@_cardWidth">
                    <HeaderContent>
                        <PersonSwimlaneHeader PersonName="@personGroup.PersonName"
                                              HeadshotUrl="@personGroup.HeadshotUrl"
                                              ItemCount="@personGroup.Hubs.Count"
                                              ItemNoun="@_filterConfig.ItemNoun" />
                    </HeaderContent>
                </PosterSwimlane>
            }

            @* By Series / Franchise *@
            @if (_filterConfig.SeriesLabel is not null)
            {
                @foreach (var seriesGroup in _seriesGroups.Take(5))
                {
                    <PosterSwimlane Title="@seriesGroup.Name"
                                    TotalCount="@seriesGroup.Hubs.Count"
                                    Hubs="@seriesGroup.Hubs"
                                    OnHubSelected="HandleHubSelected"
                                    CardWidth="@_cardWidth" />
                }
            }

            @* By Genre *@
            @foreach (var genreGroup in _genreGroups.Take(5))
            {
                <PosterSwimlane Title="@genreGroup.Name"
                                TotalCount="@genreGroup.Hubs.Count"
                                Hubs="@genreGroup.Hubs"
                                OnHubSelected="HandleHubSelected"
                                CardWidth="@_cardWidth" />
            }

            @* Media-type sub-groups (e.g. Books lane → "eBooks", "Audiobooks") *@
            @foreach (var group in _mediaTypeGroups)
            {
                <PosterSwimlane Title="@group.Name"
                                TotalCount="@group.Hubs.Count"
                                Hubs="@group.Hubs"
                                OnHubSelected="HandleHubSelected"
                                CardWidth="@_cardWidth" />
            }
        }
    }
}

@code {
    private bool               _loading = true;
    private string             _viewMode = "smart";
    private LaneDefinition?    _lane;
    private LaneFilterConfig   _filterConfig = LaneFilterConfig.ForLane("books");
    private LaneFilterState    _filterState = new();
    private HubViewModel?      _heroHub;
    private JourneyItemViewModel? _heroJourney;

    private List<HubViewModel> _allHubs = [];
    private List<HubViewModel> _displayHubs = [];
    private List<HubViewModel> _recentHubs = [];
    private List<HubViewModel> _journeyHubs = [];
    private List<PersonGroup>  _personGroups = [];
    private List<NamedGroup>   _seriesGroups = [];
    private List<NamedGroup>   _genreGroups = [];
    private List<NamedGroup>   _mediaTypeGroups = [];

    private IReadOnlyList<string> _availableGenres = [];
    private IReadOnlyList<string> _availablePersons = [];
    private IReadOnlyList<string> _availableSeries = [];
    private Dictionary<string, PersonViewModel> _personLookup = new();

    private int _cardWidth => DeviceContext.Settings.Pages.Home.SwimlaneCardWidth;

    private string ContinueLabel => _lane?.Key switch
    {
        "books"    => "Continue Reading",
        "video"    => "Continue Watching",
        "music"    => "Continue Listening",
        "podcasts" => "Continue Listening",
        "comics"   => "Continue Reading",
        _          => "Continue",
    };

    private sealed record PersonGroup(string PersonName, string? HeadshotUrl, IReadOnlyList<HubViewModel> Hubs);
    private sealed record NamedGroup(string Name, IReadOnlyList<HubViewModel> Hubs);

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        ResolveLane();
        await LoadAsync();
    }

    // Blazor reuses this component when navigating between /books, /video, /podcasts etc.
    // because they all map to MediaLanePage with no [Parameter] attributes — so
    // OnParametersSetAsync never fires again. LocationChanged is the reliable hook.
    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var path = new Uri(e.Location).AbsolutePath.Trim('/');
        if (ContentLanes.ByKey(path) is not null)
        {
            ResolveLane();
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ResolveLane()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Split('#')[0].Trim('/');
        _lane = ContentLanes.ByKey(path);
        _filterConfig = LaneFilterConfig.ForLane(_lane?.Key ?? "");
        _filterState = new LaneFilterState();

        // Set the lane filter on the state container.
        State.SetLaneFilter(_lane?.MediaTypes);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var allHubs = await Orchestrator.GetHubsAsync();
            var journeyItems = await Orchestrator.GetJourneyAsync(limit: 5);

            // Filter to this lane's media types.
            if (_lane is not null)
            {
                _allHubs = allHubs
                    .Where(h => _lane.MediaTypes.Any(mt =>
                        (h.PrimaryMediaType ?? "").Contains(mt, StringComparison.OrdinalIgnoreCase)))
                    .ToList();
            }
            else
            {
                _allHubs = [];
            }

            // Journey items for this lane.
            _journeyHubs = journeyItems
                .Where(j => j.HubId.HasValue && _allHubs.Any(h => h.Id == j.HubId))
                .Select(j => _allHubs.First(h => h.Id == j.HubId))
                .ToList();

            // Load person headshots for smart sections.
            try
            {
                var persons = await Orchestrator.GetPersonsByRoleAsync(_filterConfig.PersonLabel, 50);
                _personLookup = persons
                    .GroupBy(p => p.Name.ToLowerInvariant())
                    .ToDictionary(g => g.Key, g => g.First());
            }
            catch { _personLookup = new(); }

            BuildFilterOptions();
            ApplyFilters(journeyItems);
        }
        catch
        {
            _allHubs = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildFilterOptions()
    {
        _availableGenres = _allHubs
            .Where(h => h.Genres.Count > 0 || !string.IsNullOrEmpty(h.Genre))
            .SelectMany(h => h.Genres.Count > 0
                ? h.Genres
                : h.Genre!.Split(['|', ',', ';'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Where(g => g != "|"))
            .Where(g => g.Length > 0)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(g => g)
            .ToList();

        _availablePersons = _allHubs
            .Where(h => !string.IsNullOrEmpty(h.Author))
            .Select(h => h.Author!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(a => a)
            .ToList();

        _availableSeries = _allHubs
            .Where(h => !string.IsNullOrEmpty(h.Series))
            .Select(h => h.Series!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(s => s)
            .ToList();
    }

    private void ApplyFilters(IReadOnlyList<JourneyItemViewModel>? journeyItems = null)
    {
        var filtered = _allHubs.AsEnumerable();

        // Format filter.
        if (_filterState.Format != "All")
        {
            var fmt = _filterState.Format.ToLowerInvariant();
            filtered = filtered.Where(h =>
                (h.PrimaryMediaType ?? "").Contains(fmt, StringComparison.OrdinalIgnoreCase));
        }

        // Genre filter.
        if (_filterState.SelectedGenres.Count > 0)
            filtered = filtered.Where(h => !string.IsNullOrEmpty(h.Genre)
                && _filterState.SelectedGenres.Any(g =>
                    h.Genre!.Contains(g, StringComparison.OrdinalIgnoreCase)));

        // Person filter.
        if (!string.IsNullOrEmpty(_filterState.PersonSearch))
            filtered = filtered.Where(h => !string.IsNullOrEmpty(h.Author)
                && h.Author!.Contains(_filterState.PersonSearch, StringComparison.OrdinalIgnoreCase));

        // Series filter.
        if (!string.IsNullOrEmpty(_filterState.SeriesFilter))
            filtered = filtered.Where(h => !string.IsNullOrEmpty(h.Series)
                && h.Series!.Equals(_filterState.SeriesFilter, StringComparison.OrdinalIgnoreCase));

        // Year range.
        if (!string.IsNullOrEmpty(_filterState.YearFrom) && int.TryParse(_filterState.YearFrom, out var from))
            filtered = filtered.Where(h => int.TryParse(h.Year, out var y) && y >= from);
        if (!string.IsNullOrEmpty(_filterState.YearTo) && int.TryParse(_filterState.YearTo, out var to))
            filtered = filtered.Where(h => int.TryParse(h.Year, out var y) && y <= to);

        // Sort.
        filtered = _filterState.SortBy switch
        {
            "title-az"  => filtered.OrderBy(h => h.DisplayName),
            "title-za"  => filtered.OrderByDescending(h => h.DisplayName),
            "person-az" => filtered.OrderBy(h => h.Author ?? "zzz"),
            "year-new"  => filtered.OrderByDescending(h => h.Year ?? "0"),
            "year-old"  => filtered.OrderBy(h => h.Year ?? "9999"),
            _           => filtered.OrderByDescending(h => h.CreatedAt),
        };

        _displayHubs = filtered.ToList();

        // Hero selection — prefer active journey item.
        var withCovers = _displayHubs.Where(h =>
            !string.IsNullOrEmpty(h.CoverUrl) || !string.IsNullOrEmpty(h.HeroUrl)).ToList();
        var heroPool = withCovers.Count > 0 ? withCovers : _displayHubs;

        if (journeyItems is { Count: > 0 })
        {
            var topJourney = journeyItems
                .Where(j => j.HubId.HasValue && heroPool.Any(h => h.Id == j.HubId))
                .OrderByDescending(j => j.LastAccessed)
                .FirstOrDefault();

            if (topJourney is not null)
            {
                _heroHub     = heroPool.First(h => h.Id == topJourney.HubId);
                _heroJourney = topJourney;
            }
            else
            {
                _heroHub     = heroPool.Count > 0 ? heroPool[Random.Shared.Next(heroPool.Count)] : null;
                _heroJourney = null;
            }
        }
        else
        {
            _heroHub     = heroPool.Count > 0 ? heroPool[Random.Shared.Next(heroPool.Count)] : null;
            _heroJourney = null;
        }

        // Recently added.
        _recentHubs = _displayHubs.OrderByDescending(h => h.CreatedAt).Take(12).ToList();

        // Build smart section groups.
        BuildGroups();
    }

    private void BuildGroups()
    {
        // Person groups (Author, Director, Artist, etc.).
        _personGroups = _displayHubs
            .Where(h => !string.IsNullOrEmpty(h.Author))
            .GroupBy(h => h.Author!, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 2)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g =>
            {
                _personLookup.TryGetValue(g.Key.ToLowerInvariant(), out var person);
                var headshot = person?.LocalHeadshotUrl ?? person?.HeadshotUrl;
                return new PersonGroup(g.Key, headshot, g.ToList());
            })
            .ToList();

        // Series groups.
        _seriesGroups = _displayHubs
            .Where(h => !string.IsNullOrEmpty(h.Series))
            .GroupBy(h => h.Series!, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 2)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g => new NamedGroup(g.Key,
                g.OrderBy(h => h.Year ?? "9999").ToList()))
            .ToList();

        // Genre groups.
        _genreGroups = _displayHubs
            .Where(h => h.Genres.Count > 0 || !string.IsNullOrEmpty(h.Genre))
            .SelectMany(h => (h.Genres.Count > 0
                    ? h.Genres
                    : h.Genre!.Split(['|', ',', ';'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .Where(g => g != "|"))
                .Where(g => g.Length > 0)
                .Select(g => (Genre: g, Hub: h)))
            .GroupBy(x => x.Genre, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 2)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g => new NamedGroup(g.Key,
                g.Select(x => x.Hub).Distinct().ToList()))
            .ToList();

        // Media-type sub-groups (e.g. Books lane → "eBooks", "Audiobooks").
        _mediaTypeGroups = _allHubs
            .Where(h => !string.IsNullOrEmpty(h.PrimaryMediaType))
            .GroupBy(h => FormatMediaType(h.PrimaryMediaType!))
            .Where(g => g.Count() >= 2)
            .Select(g => new NamedGroup(g.Key, g.ToList()))
            .ToList();
    }

    private Task OnFilterChanged(LaneFilterState newState)
    {
        _filterState = newState;
        ApplyFilters();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void OnViewModeChanged(string value)
    {
        _viewMode = value ?? "smart";
    }

    private void HandleHubSelected(HubViewModel hub) =>
        Nav.NavigateTo($"/hub/{hub.Id}");

    private void HandleJourneyPlay(JourneyItemViewModel item)
    {
        var t = item.MediaType.ToLowerInvariant();
        if (t.Contains("epub") || t.Contains("book"))
        {
            var url = $"/read/{item.AssetId}";
            if (item.HubId.HasValue) url += $"?returnHubId={item.HubId.Value}";
            Nav.NavigateTo(url);
        }
        else if (item.HubId.HasValue)
        {
            Nav.NavigateTo($"/hub/{item.HubId.Value}?lastAssetId={item.AssetId}");
        }
    }

    private void OnStateChanged()
    {
        InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });
    }

    private static string FormatMediaType(string mediaType)
    {
        var t = mediaType.ToLowerInvariant();
        if (t.Contains("epub") || t.Contains("book"))  return "eBooks";
        if (t.Contains("video") || t.Contains("movie")) return "Movies";
        if (t.Contains("audio") || t.Contains("m4b"))   return "Audiobooks";
        if (t.Contains("comic") || t.Contains("cbz"))   return "Comics";
        if (t.Contains("tv"))                            return "TV Shows";
        return mediaType;
    }

    private static string EmptyStateMessage(string laneKey) => laneKey switch
    {
        "books"    => "Your book and audiobook collection will appear here. Drop EPUB or M4B files into your Watch Folder to get started.",
        "video"    => "Your movies and TV shows will appear here. Drop MP4, MKV, or AVI files into your Watch Folder.",
        "music"    => "Your music collection will appear here once music support is available.",
        "podcasts" => "Your podcast subscriptions will appear here once podcast support is available.",
        "comics"   => "Your comics and manga will appear here. Drop CBZ or CBR files into your Watch Folder.",
        _          => "Content will appear here once it's been added to your library.",
    };

    private string? ResolveHeroPhrase(HeroData data)
    {
        var hasProgress = data.ProgressPct is > 0;
        var isCompleted = data.ProgressPct is >= 99.5;

        var slot = isCompleted
            ? PhraseSlot.HeroCompleted
            : hasProgress
                ? (!string.IsNullOrEmpty(data.Series) ? PhraseSlot.HeroJourneySeries : PhraseSlot.HeroJourneyStandalone)
                : !string.IsNullOrEmpty(data.Series)
                    ? PhraseSlot.HeroDiscoverSeries
                    : !string.IsNullOrEmpty(data.Author)
                        ? PhraseSlot.HeroDiscoverAuthor
                        : PhraseSlot.HeroDiscoverStandalone;

        var ctx = new PhraseContext
        {
            EntityId = data.EntityId,
            Title = data.Title,
            Author = data.Author,
            Series = data.Series,
            Genre = data.Genre,
            MediaType = data.MediaTypeLabel,
            ProgressPct = data.ProgressPct,
        };

        var phrase = Phrases.Resolve(slot, ctx);
        return string.IsNullOrEmpty(phrase.Text) ? null : phrase.Text;
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        State.OnStateChanged -= OnStateChanged;
    }
}

<style>
    .lane-view-toggle {
        padding: 0.75rem 0 0.5rem 88px;
    }

    .lane-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 50vh;
        gap: 8px;
        text-align: center;
        padding: 2rem;
    }

    .lane-empty-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: rgba(248, 248, 248, 0.85);
        margin: 0;
    }

    .lane-empty-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
        font-weight: 400;
        color: rgba(248, 248, 248, 0.45);
        max-width: 420px;
        line-height: 1.5;
        margin: 0;
    }

    @@media (max-width: 768px) {
        .lane-view-toggle {
            padding-left: 1rem;
        }
    }
</style>
