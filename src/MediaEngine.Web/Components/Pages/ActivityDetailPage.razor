@page "/registry/activity"

@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject NavigationManager Nav
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IDisposable

@if (!EmbeddedMode)
{
    <PageTitle>Library Overview — Tuvima Library</PageTitle>
}

<div class="adp-root @(EmbeddedMode ? "adp-root--embedded" : "")">

    @if (!EmbeddedMode)
    {
        @* ── Back nav ── *@
        <div class="adp-breadcrumb">
            <button class="adp-back-btn" @onclick='() => Nav.NavigateTo("/registry")' type="button">
                <MudIcon Icon="@Icons.Material.Outlined.ArrowBack" Style="font-size: 15px;" />
                <span>Registry</span>
            </button>
            <span class="adp-breadcrumb-sep">/</span>
            <span class="adp-breadcrumb-current">Library Overview</span>
        </div>

        @* ── Page title ── *@
        <h1 class="adp-page-title">Library Overview</h1>
    }

    @* ── Main content (two-column — filters inside left panel) ── *@
    <div class="adp-content">

        @* ── Left panel: search + filters + item list ── *@
        <div class="adp-left-panel" style="@(_selectedItem is not null ? "" : "flex: 1;")">

            @* ── Inline search (embedded mode) ── *@
            @if (EmbeddedMode)
            {
                <div class="adp-inline-search">
                    <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 14px; color: rgba(255,255,255,0.30);" />
                    <input class="adp-inline-search-input"
                           type="text"
                           placeholder="Filter items..."
                           value="@SearchTerm"
                           @oninput="HandleInlineSearch" />
                </div>
            }

            @* ── Type filter chips (mutually exclusive: Media / People / Universes) ── *@
            <div class="adp-type-chips">
                <button class="adp-type-chip @(_activeTypeChip == "Media" ? "adp-type-chip--active" : "") @(_activeTypeChip == "Media" && _disabledSubcategories.Count > 0 ? "adp-type-chip--partial" : "")"
                        @onclick="HandleMediaChipClick" type="button">
                    <MudIcon Icon="@Icons.Material.Outlined.VideoLibrary" Style="font-size: 14px;" />
                    <span>Media</span>
                    @if (_activeTypeChip == "Media")
                    {
                        <span class="adp-type-chip-count">@(_items.Count)</span>
                    }
                </button>
                <button class="adp-type-chip @(_activeTypeChip == "People" ? "adp-type-chip--active" : "")"
                        @onclick="HandlePeopleChipClick" type="button">
                    <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 14px;" />
                    <span>People</span>
                    @if (_activeTypeChip == "People")
                    {
                        <span class="adp-type-chip-count">@(_items.Count)</span>
                    }
                </button>
                <button class="adp-type-chip @(_activeTypeChip == "Universes" ? "adp-type-chip--active" : "")"
                        @onclick="HandleUniversesChipClick" type="button">
                    <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Style="font-size: 14px;" />
                    <span>Universes</span>
                    @if (_activeTypeChip == "Universes")
                    {
                        <span class="adp-type-chip-count">@(_items.Count)</span>
                    }
                </button>
            </div>

            @* ── Media subcategory chips (only when Media is active) ── *@
            @if (_activeTypeChip == "Media")
            {
                <div class="adp-sub-chips">
                    @foreach (var sub in _allSubcategories)
                    {
                        var isOff = _disabledSubcategories.Contains(sub.Key);
                        <button class="adp-sub-chip @(isOff ? "" : "adp-sub-chip--active")"
                                @onclick="() => ToggleSubcategory(sub.Key)" type="button">
                            <MudIcon Icon="@sub.Icon" Style="font-size: 13px;" />
                            <span>@sub.Label</span>
                        </button>
                    }
                </div>
            }

            @* ── Filter row: Status (Media only) ── *@
            @if (_activeTypeChip == "Media")
            {
                <div class="adp-filter-row">
                    <div class="adp-filter-group">
                        <span class="adp-filter-label">STATUS</span>
                        <div class="adp-filter-select-wrap">
                            <select class="adp-filter-select" value="@_activeTab" @onchange="HandleStatusChange">
                                <option value="all">All (@(_counts?.All ?? 0))</option>
                                <option value="review">In Review (@(_counts?.InReview ?? 0))</option>
                                <option value="identified">Identified (@(_counts?.Identified ?? 0))</option>
                                <option value="provisional">Provisional (@(_counts?.Provisional ?? 0))</option>
                                <option value="rejected">Rejected (@(_counts?.Rejected ?? 0))</option>
                            </select>
                        </div>
                    </div>
                </div>
            }

            <div class="adp-results-header">
                <span class="adp-results-count">@_items.Count items</span>
            </div>

            @if (_loading)
            {
                <div class="adp-loading">
                    <MudProgressCircular Indeterminate="true" Size="MudBlazor.Size.Small"
                                         Style="color: rgba(200,190,220,0.3);" />
                    <span class="adp-loading-text">Loading…</span>
                </div>
            }
            else if (_items.Count == 0)
            {
                <div class="adp-empty">
                    <MudIcon Icon="@GetEmptyIcon()" Style="font-size: 36px; color: rgba(140,120,180,0.18); margin-bottom: 10px;" />
                    <span class="adp-empty-title">@GetEmptyTitle()</span>
                    <span class="adp-empty-sub">@GetEmptySubtitle()</span>
                </div>
            }
            else if (_activeTab == "review" && _activeTypeChip == "Media")
            {
                @* ── Trigger-grouped view for In Review (with A-Z within each trigger group) ── *@
                @foreach (var group in _groupedItems)
                {
                    var (trigLabel, trigColor, trigIcon) = RegistryHelpers.FormatReviewTrigger(group.Key);
                    var isCollapsed = _collapsedGroups.Contains(group.Key);
                    var groupSelectedCount = group.Value.Count(i => _selectedIds.Contains(i.EntityId));
                    var hasSelection = groupSelectedCount > 0;
                    <div class="adp-group">
                        @* ── Group label row ── *@
                        <div class="adp-group-label-row" @onclick="() => ToggleGroup(group.Key)">
                            <MudIcon Icon="@(isCollapsed ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ExpandMore)"
                                     Style="font-size: 16px; color: rgba(200,190,220,0.35); flex-shrink: 0; cursor: pointer;" />
                            <MudIcon Icon="@trigIcon"
                                     Style="@($"font-size: 13px; color: {trigColor}; flex-shrink: 0;")" />
                            <span class="adp-group-name" style="color: @trigColor;">@trigLabel</span>
                            <span class="adp-group-count">@group.Value.Count</span>
                        </div>

                        @* ── Separator ── *@
                        <div class="adp-group-separator"></div>

                        @* ── Action buttons row ── *@
                        @if (group.Value.Count > 0 && !isCollapsed)
                        {
                            <div class="adp-group-action-row" @onclick:stopPropagation="true">
                                <div class="adp-select-all-checkbox" @onclick="() => ToggleSelectAll(group.Key, group.Value, !IsGroupFullySelected(group.Key, group.Value))"
                                     title="Select all in this group">
                                    <MudIcon Icon="@(IsGroupFullySelected(group.Key, group.Value) ? Icons.Material.Filled.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)"
                                             Style="@($"font-size: 18px; color: {(IsGroupFullySelected(group.Key, group.Value) ? "#C9922E" : "rgba(200,190,220,0.25)")};")" />
                                </div>
                                <div class="adp-action-spacer"></div>
                                @{
                                    var pendingItems = group.Value.Where(i => _selectedIds.Contains(i.EntityId)).ToList();
                                    var isConfirming = _pendingBatchReject is not null && _pendingBatchReject.SequenceEqual(pendingItems);
                                }
                                <button class="adp-toolbar-btn adp-toolbar-btn--reject @(isConfirming ? "adp-toolbar-btn--confirming" : "")"
                                        disabled="@(!hasSelection)"
                                        @onclick="() => HandleBatchReject(pendingItems)"
                                        title="@(isConfirming ? "Click again to confirm" : hasSelection ? $"Reject {groupSelectedCount} selected items" : "Select items to reject")">
                                    <MudIcon Icon="@(isConfirming ? Icons.Material.Outlined.Warning : Icons.Material.Outlined.Block)" Style="font-size: 13px;" />
                                    <span>@(isConfirming ? $"Sure? ({groupSelectedCount})" : $"Reject{(hasSelection ? $" ({groupSelectedCount})" : "")}")</span>
                                </button>
                            </div>
                        }

                        @if (!isCollapsed)
                        {
                            <div class="adp-group-items">
                                @foreach (var item in group.Value)
                                {
                                    <ActivityItemCard Item="@item"
                                                      IsSelected="@(_selectedItem?.EntityId == item.EntityId)"
                                                      IsChecked="@(_selectedIds.Contains(item.EntityId))"
                                                      ShowCheckbox="true"
                                                      OnSelect="HandleItemSelect"
                                                      OnUnreject="HandleUnreject"
                                                      OnCheckedChanged="HandleCheckToggle"
                                                      OnQuickReject="HandleQuickReject"

                                                      ShowTriggerChip="false" />
                                }
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                @* ── A-Z grouped view (default for all non-review views) ── *@
                @foreach (var group in _letterGroups)
                {
                    var isCollapsed = _collapsedGroups.Contains(group.Key);
                    <div class="adp-group">
                        <div class="adp-group-label-row" @onclick="() => ToggleGroup(group.Key)">
                            <MudIcon Icon="@(isCollapsed ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ExpandMore)"
                                     Style="font-size: 16px; color: rgba(200,190,220,0.35); flex-shrink: 0; cursor: pointer;" />
                            <span class="adp-group-letter">@group.Key</span>
                            <span class="adp-group-count">@group.Value.Count</span>
                        </div>
                        <div class="adp-group-separator"></div>
                        @if (!isCollapsed)
                        {
                            <div class="adp-group-items">
                                @foreach (var item in group.Value)
                                {
                                    var isEntity = item.MediaType is "Person" or "Universe";
                                    <ActivityItemCard Item="@item"
                                                      IsSelected="@(_selectedItem?.EntityId == item.EntityId)"
                                                      OnSelect="HandleItemSelect"
                                                      OnUnreject="HandleUnreject"
                                                      OnQuickReject="HandleQuickReject"
                                                      ShowTriggerChip="@(_activeTypeChip == "Media")" />
                                }
                            </div>
                        }
                    </div>
                }
            }

        </div>

        @* ── Right panel: inspector ── *@
        @if (_selectedItem is not null)
        {
            <div class="adp-right-panel">
                <RegistryInspector Item="@_selectedItem"
                                   OnClose="HandleInspectorClose"
                                   OnItemChanged="HandleItemChanged" />
            </div>
        }

    </div>

    @* ── Mobile bottom drawer (stub — content defined in a future session) ── *@
    <div class="adp-mobile-drawer" style="display: none;">
        <!-- Bottom drawer with thumb-friendly placement. Components to be defined. -->
    </div>

</div>

@code {
    // ── Parameters ──────────────────────────────────────────────────────────

    [Parameter] public bool EmbeddedMode { get; set; }
    [Parameter] public string? InitialTab { get; set; }
    [Parameter] public string? InitialTypeFilter { get; set; }
    [Parameter] public string? InitialDateFrom { get; set; }
    [Parameter] public string? InitialDateTo { get; set; }
    [Parameter] public string? SearchTerm { get; set; }
    [Parameter] public EventCallback OnCountsChanged { get; set; }
    [Parameter] public EventCallback<string> SearchTermChanged { get; set; }

    // ── State ─────────────────────────────────────────────────────────────────

    private string _activeTab = "review";
    private string? _previousTab;
    private string? _reasonFilter;
    private string? _sourceFilter;
    private string? _previousSearchTerm;

    /// <summary>Top-level type chip: Media, People, or Universes.</summary>
    private string _activeTypeChip = "Media";

    /// <summary>Subcategories toggled OFF within Media view.</summary>
    private HashSet<string> _disabledSubcategories = [];



    /// <summary>All available media subcategories with icons.</summary>
    private static readonly SubcategoryDef[] _allSubcategories =
    [
        new("Books",      "Books",      Icons.Material.Outlined.MenuBook),
        new("Audiobooks", "Audiobooks", Icons.Material.Outlined.Headphones),
        new("Movies",     "Movies",     Icons.Material.Outlined.Movie),
        new("TV",         "TV",         Icons.Material.Outlined.Tv),
        new("Music",      "Music",      Icons.Material.Outlined.MusicNote),
        new("Comics",     "Comics",     Icons.Material.Outlined.PhotoLibrary),
    ];

    private record SubcategoryDef(string Key, string Label, string Icon);

    private List<RegistryItemViewModel> _items = [];
    private Dictionary<string, List<RegistryItemViewModel>> _groupedItems = [];
    private Dictionary<string, List<RegistryItemViewModel>> _letterGroups = [];
    private RegistryItemViewModel? _selectedItem;

    private RegistryFourStateCountsDto? _counts;
    private bool _loading = true;

    private HashSet<string> _collapsedGroups = [];
    private HashSet<Guid> _selectedIds = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        // Parse query params from current URL
        string? entityParam = null;
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var stateParam = query["state"];
        if (!string.IsNullOrEmpty(stateParam))
            _activeTab = stateParam.ToLowerInvariant();
        else if (EmbeddedMode && !string.IsNullOrEmpty(InitialTab))
            _activeTab = InitialTab;

        _reasonFilter = query["reason"];
        _sourceFilter = query["source"];
        entityParam = EmbeddedMode ? null : query["entity"];

        // Map legacy type param to new chip model
        var typeParam = query["type"];
        if (!string.IsNullOrEmpty(typeParam))
        {
            if (string.Equals(typeParam, "Person", StringComparison.OrdinalIgnoreCase))
                _activeTypeChip = "People";
            else if (string.Equals(typeParam, "Universe", StringComparison.OrdinalIgnoreCase))
                _activeTypeChip = "Universes";
            else
                _activeTypeChip = "Media";
        }
        else if (EmbeddedMode && !string.IsNullOrEmpty(InitialTypeFilter))
        {
            if (string.Equals(InitialTypeFilter, "Person", StringComparison.OrdinalIgnoreCase))
                _activeTypeChip = "People";
            else if (string.Equals(InitialTypeFilter, "Universe", StringComparison.OrdinalIgnoreCase))
                _activeTypeChip = "Universes";
            else
                _activeTypeChip = "Media";
        }

        // Subscribe to live review count changes
        Orchestrator.OnReviewCountChanged += HandleReviewCountChanged;

        // Load counts then items
        await LoadCountsAsync();

        // Default to "review" if there are items in review, otherwise "identified"
        if (string.IsNullOrEmpty(stateParam) && string.IsNullOrEmpty(InitialTab))
        {
            _activeTab = (_counts?.InReview ?? 0) > 0 ? "review" : "identified";
        }

        // Non-media types always use "all" tab
        if (_activeTypeChip != "Media")
            _activeTab = "all";

        await LoadItemsAsync();

        // Auto-select entity if specified in query params
        if (Guid.TryParse(entityParam, out var entityId))
        {
            _selectedItem = _items.FirstOrDefault(i => i.EntityId == entityId);

            // If not found in current tab, search across all tabs
            if (_selectedItem is null)
            {
                foreach (var tab in new[] { "review", "identified", "rejected", "provisional" })
                {
                    if (tab == _activeTab) continue;
                    try
                    {
                        var response = await Orchestrator.GetRegistryItemsAsync(
                            offset: 0, limit: 200, status: MapTabToApiStatus(tab));
                        var found = response?.Items?.FirstOrDefault(i => i.EntityId == entityId);
                        if (found is not null)
                        {
                            _activeTab = tab;
                            _items = response!.Items!;
                            BuildGroupedItems();
                            BuildLetterGroups();
                            _selectedItem = found;
                            break;
                        }
                    }
                    catch { /* continue to next tab */ }
                }
            }
        }

        // Track the initial tab to avoid double-loading in OnParametersSetAsync
        _previousTab = _activeTab;
    }

    protected override async Task OnParametersSetAsync()
    {
        var tabChanged = EmbeddedMode && !string.IsNullOrWhiteSpace(InitialTab) && InitialTab != _previousTab;
        var searchChanged = SearchTerm != _previousSearchTerm;

        if (tabChanged)
        {
            _previousTab = InitialTab;
            _activeTab = InitialTab!;
            if (!string.IsNullOrEmpty(InitialTypeFilter))
            {
                if (string.Equals(InitialTypeFilter, "Person", StringComparison.OrdinalIgnoreCase))
                    _activeTypeChip = "People";
                else if (string.Equals(InitialTypeFilter, "Universe", StringComparison.OrdinalIgnoreCase))
                    _activeTypeChip = "Universes";
                else
                    _activeTypeChip = "Media";
            }
        }

        if (tabChanged || searchChanged)
        {
            _previousSearchTerm = SearchTerm;
            await LoadCountsAsync();
            await LoadItemsAsync();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        Orchestrator.OnReviewCountChanged -= HandleReviewCountChanged;
    }

    // ── Data loading ──────────────────────────────────────────────────────────

    private async Task LoadCountsAsync()
    {
        try
        {
            _counts = await Orchestrator.GetRegistryFourStateCountsAsync();
        }
        catch
        {
            _counts = new RegistryFourStateCountsDto();
        }
    }

    private async Task LoadItemsAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            if (_activeTypeChip == "People")
            {
                _items = await FetchPersonsAsRegistryItemsAsync();
            }
            else if (_activeTypeChip == "Universes")
            {
                // Universes not yet implemented — empty list
                _items = [];
            }
            else
            {
                // Media: load from registry with status filter
                var apiStatus = MapTabToApiStatus(_activeTab);
                var response  = await Orchestrator.GetRegistryItemsAsync(
                    offset: 0,
                    limit: 200,
                    status: apiStatus);

                _items = response?.Items ?? [];

                // Apply reason filter if present
                if (!string.IsNullOrEmpty(_reasonFilter))
                    _items = _items.Where(i => i.ReviewTrigger == _reasonFilter).ToList();

                // Apply subcategory filter (exclude disabled subcategories)
                if (_disabledSubcategories.Count > 0)
                {
                    _items = _items.Where(i =>
                        !string.IsNullOrEmpty(i.MediaType) &&
                        !_disabledSubcategories.Contains(i.MediaType)
                    ).ToList();
                }
            }

            // Apply search filter
            if (!string.IsNullOrEmpty(SearchTerm))
            {
                var term = SearchTerm.Trim();
                _items = _items.Where(i =>
                    (i.Title?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (i.Author?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (i.WikidataQid?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
                ).ToList();
            }

            // Always sort A-Z
            _items = _items.OrderBy(i => i.Title, StringComparer.OrdinalIgnoreCase).ToList();

            // Build grouped views
            BuildGroupedItems();
            BuildLetterGroups();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load items: {ex.Message}", Severity.Warning);
            _items = [];
            _groupedItems = [];
            _letterGroups = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<List<RegistryItemViewModel>> FetchPersonsAsRegistryItemsAsync()
    {
        try
        {
            var persons = await ApiClient.GetPersonsAsync();
            if (persons is null) return [];

            return persons.Select(p => new RegistryItemViewModel
            {
                EntityId    = p.Id,
                Title       = p.Name,
                MediaType   = "Person",
                Status      = "Identified",
                Confidence  = 1.0,
                MatchSource = "wikidata",
                WikidataQid = p.WikidataQid,
                CoverUrl    = p.HeadshotUrl,  // Already absolute from EngineApiClient
                Author      = string.Join(", ", p.Roles),
                CreatedAt   = DateTimeOffset.UtcNow,
            }).ToList();
        }
        catch
        {
            return [];
        }
    }

    private void BuildGroupedItems()
    {
        if (_activeTab != "review" || _activeTypeChip != "Media")
        {
            _groupedItems = [];
            return;
        }

        // Group by ReviewTrigger, sort groups by fixed priority order, A-Z within each group
        var priorityOrder = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
        {
            ["AuthorityMatchFailed"] = 0,
            ["RetailMatchFailed"] = 0,
            ["LowConfidence"] = 1,
            ["MultipleQidMatches"] = 2,
            ["AmbiguousMediaType"] = 3,
            ["LanguageMismatch"] = 4,
            ["ArbiterNeedsReview"] = 5,
            ["UserFixMatch"] = 6,
            ["Unknown"] = 99,
        };

        _groupedItems = _items
            .GroupBy(i => i.ReviewTrigger ?? "Unknown")
            .OrderBy(g => priorityOrder.GetValueOrDefault(g.Key, 50))
            .ToDictionary(g => g.Key, g =>
                g.OrderBy(i => i.Title, StringComparer.OrdinalIgnoreCase).ToList());
    }

    private void BuildLetterGroups()
    {
        // A-Z letter grouping — used for all non-review views
        _letterGroups = _items
            .GroupBy(i =>
            {
                var first = i.Title?.TrimStart();
                if (string.IsNullOrEmpty(first)) return "#";
                var c = char.ToUpperInvariant(first[0]);
                return char.IsLetter(c) ? c.ToString() : "#";
            })
            .OrderBy(g => g.Key == "#" ? "ZZZ" : g.Key) // # sorts last
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    // ── Tab helpers ───────────────────────────────────────────────────────────

    private static string MapTabToApiStatus(string tab) => tab switch
    {
        "review"      => "InReview",
        "rejected"    => "Rejected",
        "identified"  => "Identified",
        "provisional" => "Provisional",
        "all"         => "",
        _             => "InReview",
    };

    private async Task SetActiveTab(string tab)
    {
        _activeTab    = tab;
        _reasonFilter = null;  // clear reason filter on explicit tab switch
        _selectedItem = null;
        _selectedIds.Clear();
        if (!EmbeddedMode)
        {
            var newUrl = $"/registry/activity?state={tab}";
            Nav.NavigateTo(newUrl, forceLoad: false, replace: true);
        }
        else
        {
            var newUrl = $"/registry/library?state={tab}";
            Nav.NavigateTo(newUrl, forceLoad: false, replace: true);
        }
        await LoadItemsAsync();
    }

    // ── Type chip handlers ──────────────────────────────────────────────────

    private async Task HandleMediaChipClick()
    {
        if (_activeTypeChip == "Media")
        {
            // Already active — toggle: nothing (stay on Media)
            return;
        }
        _activeTypeChip = "Media";
        _activeTab = (_counts?.InReview ?? 0) > 0 ? "review" : "identified";
        _selectedItem = null;
        _selectedIds.Clear();
        _disabledSubcategories.Clear();
        await LoadItemsAsync();
    }

    private Task HandlePeopleChipClick() => HandleTopLevelChipClick("People");
    private Task HandleUniversesChipClick() => HandleTopLevelChipClick("Universes");

    private async Task HandleTopLevelChipClick(string chip)
    {
        if (_activeTypeChip == chip) return;
        _activeTypeChip = chip;
        _activeTab = "all";
        _selectedItem = null;
        _selectedIds.Clear();
        await LoadItemsAsync();
    }

    private async Task ToggleSubcategory(string key)
    {
        if (!_disabledSubcategories.Remove(key))
            _disabledSubcategories.Add(key);
        await LoadItemsAsync();
    }

    // ── Filter handlers ───────────────────────────────────────────────────────

    private async Task HandleStatusChange(ChangeEventArgs e)
    {
        var newTab = e.Value?.ToString() ?? "review";
        await SetActiveTab(newTab);
    }

    private async Task HandleInlineSearch(ChangeEventArgs e)
    {
        var term = e.Value?.ToString() ?? "";
        await SearchTermChanged.InvokeAsync(term);
    }

    // ── Event handlers ────────────────────────────────────────────────────────

    private void HandleItemSelect(RegistryItemViewModel item)
    {
        _selectedItem = _selectedItem?.EntityId == item.EntityId ? null : item;
    }

    private void HandleInspectorClose()
    {
        _selectedItem = null;
    }

    private async Task HandleItemChanged()
    {
        // Reload counts and items after an action (resolve, approve, etc.)
        await LoadCountsAsync();
        await LoadItemsAsync();

        // Re-select the same item from the refreshed list so the inspector
        // updates with the latest data (e.g. new cover, status, QID).
        if (_selectedItem is not null)
        {
            _selectedItem = _items.FirstOrDefault(i => i.EntityId == _selectedItem.EntityId);
        }

        await OnCountsChanged.InvokeAsync();
        StateHasChanged();
    }

    private async Task HandleUnreject(Guid entityId)
    {
        try
        {
            var ok = await ApiClient.RecoverRegistryItemAsync(entityId);
            if (ok)
            {
                Snackbar.Add("Item recovered and returned to review queue.", Severity.Success);
                await HandleItemChanged();
            }
            else
            {
                Snackbar.Add("Could not recover item.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleQuickReject(Guid entityId)
    {
        try
        {
            await ApiClient.RejectRegistryItemAsync(entityId);
            Snackbar.Add("Item rejected.", Severity.Info);
            await HandleItemChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Reject failed: {ex.Message}", Severity.Error);
        }
    }

    private void ToggleGroup(string groupKey)
    {
        if (!_collapsedGroups.Remove(groupKey))
            _collapsedGroups.Add(groupKey);
    }

    private void HandleCheckToggle(Guid entityId)
    {
        if (!_selectedIds.Remove(entityId))
            _selectedIds.Add(entityId);
    }

    private void ClearGroupSelection(List<RegistryItemViewModel> groupItems)
    {
        foreach (var item in groupItems)
            _selectedIds.Remove(item.EntityId);
    }

    private List<RegistryItemViewModel>? _pendingBatchReject;

    private void HandleBatchReject(List<RegistryItemViewModel> items)
    {
        if (items.Count == 0) return;

        // First click: show confirmation state on the button.
        if (_pendingBatchReject is null || !_pendingBatchReject.SequenceEqual(items))
        {
            _pendingBatchReject = items;
            // Auto-reset after 3 seconds if not confirmed.
            _ = Task.Delay(3000).ContinueWith(_ =>
                InvokeAsync(() => { _pendingBatchReject = null; StateHasChanged(); }));
            return;
        }

        // Second click: confirmed — execute the rejection.
        _pendingBatchReject = null;
        _ = ExecuteBatchRejectAsync(items);
    }

    private async Task ExecuteBatchRejectAsync(List<RegistryItemViewModel> items)
    {
        try
        {
            foreach (var item in items.ToList())
            {
                try
                {
                    await ApiClient.RejectRegistryItemAsync(item.EntityId);
                }
                catch
                {
                    // Continue with remaining items
                }
            }

            Snackbar.Add($"Rejected {items.Count} items.", Severity.Success);
            await LoadCountsAsync();
            await LoadItemsAsync();
            await OnCountsChanged.InvokeAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Batch reject failed: {ex.Message}", Severity.Error);
        }
    }

    private bool IsGroupFullySelected(string groupKey, List<RegistryItemViewModel> items)
    {
        return items.Count > 0 && items.All(i => _selectedIds.Contains(i.EntityId));
    }

    private void ToggleSelectAll(string groupKey, List<RegistryItemViewModel> items, bool selected)
    {
        if (selected)
        {
            foreach (var item in items)
                _selectedIds.Add(item.EntityId);
        }
        else
        {
            foreach (var item in items)
                _selectedIds.Remove(item.EntityId);
        }
        StateHasChanged();
    }

    private void HandleReviewCountChanged()
    {
        InvokeAsync(async () =>
        {
            await LoadCountsAsync();
            StateHasChanged();
        });
    }

    // ── Empty state helpers ───────────────────────────────────────────────────

    private string GetEmptyIcon() => _activeTab switch
    {
        "review"      => Icons.Material.Outlined.RateReview,
        "rejected"    => Icons.Material.Outlined.Block,
        "identified"  => Icons.Material.Outlined.CheckCircle,
        "provisional" => Icons.Material.Outlined.HelpOutline,
        _             => Icons.Material.Outlined.Inbox,
    };

    private string GetEmptyTitle() => _activeTab switch
    {
        "review"      => "Nothing needs review",
        "rejected"    => "No rejected items",
        "identified"  => "No identified items",
        "provisional" => "No provisional items",
        _             => "No items",
    };

    private string GetEmptySubtitle() => _activeTab switch
    {
        "review"      => "All items are either identified or provisional.",
        "rejected"    => "Items rejected here can be recovered at any time.",
        "identified"  => "Items confirmed against a Wikidata identity will appear here.",
        "provisional" => "Items awaiting better metadata appear here.",
        _             => "",
    };

    // ── Trigger description map ───────────────────────────────────────────────

    private static string GetTriggerDescription(string? trigger) => trigger switch
    {
        "MultipleQidMatches"   => "Pick the correct entity",
        "LowConfidence"        => "Below confidence threshold",
        "AuthorityMatchFailed" => "No Wikidata match found",
        "RetailMatchFailed"    => "No retail match found",
        "ContentMatchFailed"   => "No cover art found",
        "AmbiguousMediaType"   => "Unclear media type",
        "MissingQid"           => "Needs manual match",
        "PlaceholderTitle"     => "Missing title",
        "StagedUnidentifiable" => "Cannot identify",
        "ArtworkUnconfirmed"   => "Verify cover art",
        "MetadataConflict"     => "Conflicting metadata",
        "UserFixMatch"         => "User requested correction",
        "ArbiterNeedsReview"   => "Review grouping",
        "LanguageMismatch"     => "Foreign language",
        "UserReport"           => "Users flagged a problem",
        _                      => "",
    };
}

