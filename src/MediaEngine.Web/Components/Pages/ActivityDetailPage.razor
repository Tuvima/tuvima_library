@page "/registry/activity"

@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject NavigationManager Nav
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IDisposable

<PageTitle>Library Overview — Tuvima Library</PageTitle>

<div class="adp-root">

    @* ── Back nav ── *@
    <div class="adp-breadcrumb">
        <button class="adp-back-btn" @onclick='() => Nav.NavigateTo("/registry")' type="button">
            <MudIcon Icon="@Icons.Material.Outlined.ArrowBack" Style="font-size: 15px;" />
            <span>Registry</span>
        </button>
        <span class="adp-breadcrumb-sep">/</span>
        <span class="adp-breadcrumb-current">Library Overview</span>
    </div>

    @* ── Page title ── *@
    <h1 class="adp-page-title">Library Overview</h1>

    @* ── Filter tabs ── *@
    <div class="adp-tab-row">
        @foreach (var tab in _tabs)
        {
            var isActive = tab.Key == _activeTab;
            <button class="adp-tab @(isActive ? "adp-tab--active" : "")"
                    style="@(isActive ? $"--tab-color: {tab.Color};" : "")"
                    @onclick="() => SetActiveTab(tab.Key)"
                    type="button">
                <MudIcon Icon="@tab.Icon" Style="font-size: 14px;" />
                <span class="adp-tab-label">@tab.Label</span>
                <span class="adp-tab-badge" style="@(isActive ? $"background: {tab.Color}20; color: {tab.Color};" : "")">
                    @tab.Count
                </span>
            </button>
        }
    </div>

    @* ── Bulk actions bar (In Review tab only) ── *@
    @if (_activeTab == "review" && _items.Count > 0)
    {
        <div class="adp-bulk-bar">
            <span class="adp-bulk-label">Bulk:</span>
            <button class="adp-bulk-btn adp-bulk-btn--register" @onclick="HandleBulkAutoRegister"
                    disabled="@_bulkProcessing" type="button">
                Auto-register above
            </button>
            <input type="range" min="50" max="99" step="1"
                   class="adp-bulk-slider"
                   value="@_bulkThreshold"
                   @oninput="HandleSliderInput" />
            <span class="adp-bulk-value">@((_bulkThreshold / 100.0).ToString("0.00"))</span>
        </div>
    }

    @* ── Main content ── *@
    <div class="adp-content">

        @* ── Left panel: item list ── *@
        <div class="adp-left-panel" style="@(_selectedItem is not null ? "" : "flex: 1;")">

            @if (_loading)
            {
                <div class="adp-loading">
                    <MudProgressCircular Indeterminate="true" Size="MudBlazor.Size.Small"
                                         Style="color: rgba(200,190,220,0.3);" />
                    <span class="adp-loading-text">Loading…</span>
                </div>
            }
            else if (_items.Count == 0)
            {
                <div class="adp-empty">
                    <MudIcon Icon="@GetEmptyIcon()" Style="font-size: 36px; color: rgba(140,120,180,0.18); margin-bottom: 10px;" />
                    <span class="adp-empty-title">@GetEmptyTitle()</span>
                    <span class="adp-empty-sub">@GetEmptySubtitle()</span>
                </div>
            }
            else if (_activeTab == "review")
            {
                @* ── Grouped view for In Review tab ── *@
                @foreach (var group in _groupedItems)
                {
                    var (trigLabel, trigColor, trigIcon) = RegistryHelpers.FormatReviewTrigger(group.Key);
                    var description = GetTriggerDescription(group.Key);
                    var isCollapsed = _collapsedGroups.Contains(group.Key);
                    <div class="adp-group">
                        <div class="adp-group-header" @onclick="() => ToggleGroup(group.Key)">
                            <MudIcon Icon="@(isCollapsed ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ExpandMore)"
                                     Style="font-size: 16px; color: rgba(200,190,220,0.35); flex-shrink: 0; cursor: pointer;" />
                            <MudIcon Icon="@trigIcon"
                                     Style="@($"font-size: 13px; color: {trigColor}; flex-shrink: 0;")" />
                            <span class="adp-group-name" style="color: @trigColor;">@trigLabel</span>
                            <span class="adp-group-count">@group.Value.Count</span>
                            @if (!string.IsNullOrEmpty(description))
                            {
                                <span class="adp-group-desc">— @description</span>
                            }

                            @* Batch actions *@
                            @if (group.Value.Count > 0)
                            {
                                <div class="adp-group-actions" @onclick:stopPropagation="true">
                                    <button class="adp-group-action adp-group-action--approve"
                                            @onclick="() => HandleBatchApprove(group.Value)"
                                            title="Approve all in this group">
                                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 12px;" />
                                        <span>Approve All</span>
                                    </button>
                                    <button class="adp-group-action adp-group-action--reject"
                                            @onclick="() => HandleBatchReject(group.Value)"
                                            title="Reject all in this group">
                                        <MudIcon Icon="@Icons.Material.Outlined.Block" Style="font-size: 12px;" />
                                        <span>Reject All</span>
                                    </button>
                                </div>
                            }
                        </div>

                        @if (!isCollapsed)
                        {
                            <div class="adp-group-items">
                                @foreach (var item in group.Value)
                                {
                                    <ActivityItemCard Item="@item"
                                                      IsSelected="@(_selectedItem?.EntityId == item.EntityId)"
                                                      OnSelect="HandleItemSelect"
                                                      OnUnreject="HandleUnreject"
                                                      ShowTriggerChip="false" />
                                }
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                @* ── Flat list for other tabs ── *@
                <div class="adp-flat-list">
                    @foreach (var item in _items)
                    {
                        <ActivityItemCard Item="@item"
                                          IsSelected="@(_selectedItem?.EntityId == item.EntityId)"
                                          OnSelect="HandleItemSelect"
                                          OnUnreject="HandleUnreject"
                                          ShowTriggerChip="true" />
                    }
                </div>
            }

        </div>

        @* ── Right panel: inspector ── *@
        @if (_selectedItem is not null)
        {
            <div class="adp-right-panel">
                <RegistryInspector Item="@_selectedItem"
                                   OnClose="HandleInspectorClose"
                                   OnItemChanged="HandleItemChanged" />
            </div>
        }

    </div>

    @* ── Mobile bottom drawer (stub — content defined in a future session) ── *@
    <div class="adp-mobile-drawer" style="display: none;">
        <!-- Bottom drawer with thumb-friendly placement. Components to be defined. -->
    </div>

</div>

@code {
    // ── Tab model ─────────────────────────────────────────────────────────────

    private sealed record TabDef(string Key, string Label, string Color, string Icon, int Count);

    // ── State ─────────────────────────────────────────────────────────────────

    private string _activeTab = "review";
    private string? _reasonFilter;
    private string? _sourceFilter;

    private List<RegistryItemViewModel> _items = [];
    private Dictionary<string, List<RegistryItemViewModel>> _groupedItems = [];
    private RegistryItemViewModel? _selectedItem;

    private RegistryFourStateCountsDto? _counts;
    private bool _loading = true;

    private int _bulkThreshold = 90;
    private bool _bulkProcessing;
    private HashSet<string> _collapsedGroups = [];

    // ── Tab definitions (computed after counts load) ───────────────────────────

    private List<TabDef> _tabs = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        // Parse query params
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var stateParam = query["state"];
        if (!string.IsNullOrEmpty(stateParam))
            _activeTab = stateParam.ToLowerInvariant();

        _reasonFilter = query["reason"];
        _sourceFilter = query["source"];
        var entityParam = query["entity"];

        // Subscribe to live review count changes
        Orchestrator.OnReviewCountChanged += HandleReviewCountChanged;

        // Load counts then items
        await LoadCountsAsync();
        await LoadItemsAsync();

        // Auto-select entity if specified in query params
        if (Guid.TryParse(entityParam, out var entityId))
        {
            _selectedItem = _items.FirstOrDefault(i => i.EntityId == entityId);

            // If not found in current tab, search across all tabs
            if (_selectedItem is null)
            {
                foreach (var tab in new[] { "review", "registered", "rejected", "provisional" })
                {
                    if (tab == _activeTab) continue;
                    try
                    {
                        var response = await Orchestrator.GetRegistryItemsAsync(
                            offset: 0, limit: 200, status: MapTabToApiStatus(tab));
                        var found = response?.Items?.FirstOrDefault(i => i.EntityId == entityId);
                        if (found is not null)
                        {
                            _activeTab = tab;
                            _items = response!.Items!;
                            BuildGroupedItems();
                            _selectedItem = found;
                            RebuildTabs();
                            break;
                        }
                    }
                    catch { /* continue to next tab */ }
                }
            }
        }
    }

    public void Dispose()
    {
        Orchestrator.OnReviewCountChanged -= HandleReviewCountChanged;
    }

    // ── Data loading ──────────────────────────────────────────────────────────

    private async Task LoadCountsAsync()
    {
        try
        {
            _counts = await Orchestrator.GetRegistryFourStateCountsAsync();
        }
        catch
        {
            _counts = new RegistryFourStateCountsDto();
        }
        RebuildTabs();
    }

    private async Task LoadItemsAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var apiStatus = MapTabToApiStatus(_activeTab);
            var response  = await Orchestrator.GetRegistryItemsAsync(
                offset: 0,
                limit: 200,
                status: apiStatus);

            _items = response?.Items ?? [];

            // Apply reason filter if present
            if (!string.IsNullOrEmpty(_reasonFilter))
                _items = _items.Where(i => i.ReviewTrigger == _reasonFilter).ToList();

            // Rebuild grouped view for In Review tab
            BuildGroupedItems();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load items: {ex.Message}", Severity.Warning);
            _items = [];
            _groupedItems = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildGroupedItems()
    {
        if (_activeTab != "review")
        {
            _groupedItems = [];
            return;
        }

        // Group by ReviewTrigger, sort groups by size descending
        _groupedItems = _items
            .GroupBy(i => i.ReviewTrigger ?? "Unknown")
            .OrderByDescending(g => g.Count())
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private void RebuildTabs()
    {
        var registered  = _counts?.Registered  ?? 0;
        var inReview    = _counts?.InReview     ?? 0;
        var provisional = _counts?.Provisional  ?? 0;
        var rejected    = _counts?.Rejected     ?? 0;

        _tabs =
        [
            new TabDef("review",      "In Review",    "#EF9F27", Icons.Material.Outlined.RateReview,   inReview),
            new TabDef("rejected",    "Rejected",     "#E24B4A", Icons.Material.Outlined.Block,         rejected),
            new TabDef("registered",  "Registered",   "#5DCAA5", Icons.Material.Outlined.CheckCircle,   registered),
            new TabDef("provisional", "Provisional",  "#B4B2A9", Icons.Material.Outlined.EditNote,      provisional),
        ];
    }

    // ── Tab helpers ───────────────────────────────────────────────────────────

    private static string MapTabToApiStatus(string tab) => tab switch
    {
        "review"      => "InReview",
        "rejected"    => "Rejected",
        "registered"  => "Registered",
        "provisional" => "Provisional",
        _             => "InReview",
    };

    private async Task SetActiveTab(string tab)
    {
        _activeTab    = tab;
        _reasonFilter = null;  // clear reason filter on explicit tab switch
        _selectedItem = null;
        var newUrl = $"/registry/activity?state={tab}";
        Nav.NavigateTo(newUrl, forceLoad: false, replace: true);
        await LoadItemsAsync();
    }

    // ── Event handlers ────────────────────────────────────────────────────────

    private void HandleItemSelect(RegistryItemViewModel item)
    {
        _selectedItem = _selectedItem?.EntityId == item.EntityId ? null : item;
    }

    private void HandleInspectorClose()
    {
        _selectedItem = null;
    }

    private async Task HandleItemChanged()
    {
        // Reload counts and items after an action (resolve, approve, etc.)
        await LoadCountsAsync();
        await LoadItemsAsync();

        // Clear selection if the item is no longer in the current list (e.g. moved to Registered)
        if (_selectedItem is not null)
        {
            _selectedItem = _items.FirstOrDefault(i => i.EntityId == _selectedItem.EntityId);
        }
    }

    private void HandleSliderInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            _bulkThreshold = val;
    }

    private async Task HandleBulkAutoRegister()
    {
        _bulkProcessing = true;
        StateHasChanged();

        try
        {
            var threshold = _bulkThreshold / 100.0;
            var eligible = _items.Where(i => i.Confidence >= threshold).ToList();

            if (eligible.Count == 0)
            {
                Snackbar.Add("No items above the selected confidence threshold.", Severity.Info);
                _bulkProcessing = false;
                return;
            }

            var confirmed = await DialogService.ShowMessageBoxAsync(
                "Auto-register items?",
                $"This will register {eligible.Count} items with confidence above {threshold:P0}.",
                yesText: "Register all", cancelText: "Cancel");

            if (confirmed == true)
            {
                int registered = 0;
                foreach (var item in eligible)
                {
                    try
                    {
                        // Auto-register using the top candidate (if available)
                        var result = await ApiClient.AutoRegisterItemAsync(item.EntityId);
                        if (result is not null) registered++;
                    }
                    catch { /* skip failures silently */ }
                }

                Snackbar.Add($"Registered {registered} of {eligible.Count} items.",
                             registered > 0 ? Severity.Success : Severity.Warning);
                await HandleItemChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Bulk operation failed: {ex.Message}", Severity.Error);
        }

        _bulkProcessing = false;
    }

    private async Task HandleUnreject(Guid entityId)
    {
        try
        {
            var ok = await ApiClient.RecoverRegistryItemAsync(entityId);
            if (ok)
            {
                Snackbar.Add("Item recovered and returned to review queue.", Severity.Success);
                await HandleItemChanged();
            }
            else
            {
                Snackbar.Add("Could not recover item.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void ToggleGroup(string groupKey)
    {
        if (!_collapsedGroups.Remove(groupKey))
            _collapsedGroups.Add(groupKey);
    }

    private async Task HandleBatchApprove(List<RegistryItemViewModel> items)
    {
        _bulkProcessing = true;
        StateHasChanged();

        try
        {
            foreach (var item in items.ToList())
            {
                try
                {
                    await ApiClient.AutoRegisterItemAsync(item.EntityId);
                }
                catch
                {
                    // Continue with remaining items
                }
            }

            Snackbar.Add($"Approved {items.Count} items.", Severity.Success);
            await LoadCountsAsync();
            await LoadItemsAsync();
        }
        finally
        {
            _bulkProcessing = false;
            StateHasChanged();
        }
    }

    private async Task HandleBatchReject(List<RegistryItemViewModel> items)
    {
        _bulkProcessing = true;
        StateHasChanged();

        try
        {
            foreach (var item in items.ToList())
            {
                try
                {
                    await ApiClient.RejectRegistryItemAsync(item.EntityId);
                }
                catch
                {
                    // Continue with remaining items
                }
            }

            Snackbar.Add($"Rejected {items.Count} items.", Severity.Success);
            await LoadCountsAsync();
            await LoadItemsAsync();
        }
        finally
        {
            _bulkProcessing = false;
            StateHasChanged();
        }
    }

    private void HandleReviewCountChanged()
    {
        InvokeAsync(async () =>
        {
            await LoadCountsAsync();
            StateHasChanged();
        });
    }

    // ── Empty state helpers ───────────────────────────────────────────────────

    private string GetEmptyIcon() => _activeTab switch
    {
        "review"      => Icons.Material.Outlined.RateReview,
        "rejected"    => Icons.Material.Outlined.Block,
        "registered"  => Icons.Material.Outlined.CheckCircle,
        "provisional" => Icons.Material.Outlined.HelpOutline,
        _             => Icons.Material.Outlined.Inbox,
    };

    private string GetEmptyTitle() => _activeTab switch
    {
        "review"      => "Nothing needs review",
        "rejected"    => "No rejected items",
        "registered"  => "No registered items",
        "provisional" => "No provisional items",
        _             => "No items",
    };

    private string GetEmptySubtitle() => _activeTab switch
    {
        "review"      => "All items are either registered or provisional.",
        "rejected"    => "Items rejected here can be recovered at any time.",
        "registered"  => "Items confirmed against a Wikidata identity will appear here.",
        "provisional" => "Items awaiting better metadata appear here.",
        _             => "",
    };

    // ── Trigger description map ───────────────────────────────────────────────

    private static string GetTriggerDescription(string? trigger) => trigger switch
    {
        "MultipleQidMatches"   => "Pick the correct entity",
        "LowConfidence"        => "Below confidence threshold",
        "AuthorityMatchFailed" => "No Wikidata match found",
        "ContentMatchFailed"   => "No cover art found",
        "AmbiguousMediaType"   => "Unclear media type",
        "MissingQid"           => "Needs manual match",
        "PlaceholderTitle"     => "Missing title",
        "StagedUnidentifiable" => "Cannot identify",
        "ArtworkUnconfirmed"   => "Verify cover art",
        "MetadataConflict"     => "Conflicting metadata",
        "UserFixMatch"         => "User requested correction",
        "ArbiterNeedsReview"   => "Review grouping",
        "LanguageMismatch"     => "Foreign language",
        "UserReport"           => "Users flagged a problem",
        _                      => "",
    };
}

@* ── ActivityItemCard — inline component ─────────────────────────────────── *@

@* Defined below as a separate file in the Registry folder per spec *@

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap');

    /* ── Root container ── */
    .adp-root {
        min-height: 100vh;
        background: transparent;
        font-family: 'Montserrat', sans-serif;
        padding: 24px 32px 40px 84px; /* 84px left for dock clearance */
        box-sizing: border-box;
        color: #e0dce8;
    }

    @@media (max-width: 768px) {
        .adp-root {
            padding: 20px 16px 40px 16px;
        }
    }

    /* ── Breadcrumb / back nav ── */
    .adp-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 14px;
    }

    .adp-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: transparent;
        border: none;
        cursor: pointer;
        color: rgba(200, 190, 220, 0.45);
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        font-weight: 500;
        padding: 4px 6px;
        border-radius: 4px;
        transition: color 0.15s ease, background 0.15s ease;
    }

    .adp-back-btn:hover {
        color: rgba(200, 190, 220, 0.75);
        background: rgba(140, 120, 180, 0.1);
    }

    .adp-breadcrumb-sep {
        font-size: 12px;
        color: rgba(200, 190, 220, 0.18);
    }

    .adp-breadcrumb-current {
        font-size: 12px;
        font-weight: 500;
        color: rgba(200, 190, 220, 0.40);
    }

    /* ── Page title ── */
    .adp-page-title {
        font-size: 22px;
        font-weight: 700;
        color: #e0dce8;
        margin: 0 0 22px 0;
        letter-spacing: -0.3px;
    }

    /* ── Filter tabs ── */
    .adp-tab-row {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .adp-tab {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 7px 14px;
        border-radius: 20px;
        border: 1px solid rgba(140, 120, 180, 0.12);
        background: rgba(140, 120, 180, 0.06);
        cursor: pointer;
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        font-weight: 500;
        color: rgba(200, 190, 220, 0.55);
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }

    .adp-tab:hover {
        background: rgba(140, 120, 180, 0.1);
        color: rgba(200, 190, 220, 0.85);
        border-color: rgba(140, 120, 180, 0.22);
    }

    .adp-tab--active {
        background: color-mix(in srgb, var(--tab-color, #EF9F27) 15%, transparent);
        border-color: color-mix(in srgb, var(--tab-color, #EF9F27) 40%, transparent);
        color: var(--tab-color, #EF9F27);
    }

    .adp-tab-label {
        /* no extra styling needed */
    }

    .adp-tab-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 20px;
        height: 18px;
        padding: 0 5px;
        border-radius: 9px;
        background: rgba(140, 120, 180, 0.10);
        color: rgba(200, 190, 220, 0.45);
        font-size: 10px;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        transition: background 0.15s ease, color 0.15s ease;
    }

    /* ── Bulk actions bar ── */
    .adp-bulk-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        margin-bottom: 8px;
        border-bottom: 1px solid rgba(140, 120, 180, 0.1);
        background: rgba(20, 16, 42, 0.5);
    }

    .adp-bulk-label {
        font-size: 11px;
        font-weight: 400;
        color: rgba(200, 190, 220, 0.35);
    }

    .adp-bulk-btn {
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s ease;
    }

    .adp-bulk-btn--register {
        background: rgba(93, 202, 165, 0.12);
        color: #5DCAA5;
        border: 1px solid rgba(93, 202, 165, 0.18);
    }

    .adp-bulk-btn--register:hover:not(:disabled) {
        background: rgba(93, 202, 165, 0.2);
    }

    .adp-bulk-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .adp-bulk-slider {
        width: 70px;
        height: 4px;
        accent-color: #EF9F27;
        cursor: pointer;
    }

    .adp-bulk-value {
        font-size: 11px;
        font-weight: 500;
        color: rgba(200, 190, 220, 0.6);
        min-width: 28px;
        font-variant-numeric: tabular-nums;
    }

    /* ── Two-column layout ── */
    .adp-content {
        display: flex;
        gap: 24px;
        align-items: flex-start;
        min-height: calc(100vh - 200px);
    }

    /* ── Left panel (narrow item list) ── */
    .adp-left-panel {
        flex: 0 0 340px;
        max-width: 380px;
        min-width: 0;
        padding-right: 0;
    }

    /* ── Right panel (inspector — 2× list width) ── */
    .adp-right-panel {
        flex: 0 0 680px;
        max-width: 720px;
        flex-shrink: 0;
        position: sticky;
        top: 72px;
        max-height: calc(100vh - 80px);
        overflow-y: auto;
        background: transparent;
        border: none;
        border-radius: 0;
    }

    /* ── Loading state ── */
    .adp-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 60px 20px;
