        "MetadataConflict"     => "Conflicting metadata",
        "UserFixMatch"         => "User requested correction",
        "ArbiterNeedsReview"   => "Review grouping",
        "LanguageMismatch"     => "Foreign language",
        "UserReport"           => "Users flagged a problem",
        _                      => "",
    };
}

