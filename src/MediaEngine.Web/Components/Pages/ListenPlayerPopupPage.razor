@page "/listen/player-popup"
@layout MediaEngine.Web.Shared.PopupLayout
@using System.Globalization
@using System.Text.Json
@using Microsoft.JSInterop
@using MediaEngine.Contracts.Playback
@using MediaEngine.Web.Components.Listen
@using MediaEngine.Web.Components.Shared
@using MediaEngine.Web.Services.Playback
@inject IJSRuntime JS
@inject IStringLocalizer<SharedStrings> L
@inject ILogger<ListenPlayerPopupPage> Logger
@inject ListenPlaybackClientSettings PlaybackClientSettings
@implements IAsyncDisposable

<PageTitle>@L["Listen_MiniPlayerTitle"]</PageTitle>

<PlaybackPopoutShell Experience="@CurrentExperience"
                     Class="@PopupClass"
                     Css="@BackdropStyle"
                     IsSheetOpen="@(_activeSheet is not null || _showOverflowMenu)"
                     OnKeyDown="HandlePopupKeyDown"
                     tabindex="-1">
    @if (CurrentItem is null)
    {
        <div class="listen-popup__empty">
            <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Class="tl-u-font-size-42px tl-u-opacity-0-34" />
            <p>@L["Listen_NothingPlaying"]</p>
        </div>
    }
    else
    {
        var current = CurrentItem;
        <div class="listen-popup__topbar">
            <AppNativeButton Type="button" Class="listen-popup__top-icon" OnClick="ClosePopupWindowAsync" AriaLabel="Collapse player" title="Collapse player">
                <MudIcon Icon="@Icons.Material.Outlined.KeyboardArrowDown" Class="tl-u-font-size-34px" />
            </AppNativeButton>
            <div class="listen-popup__top-actions">
                <AppNativeButton Type="button" Class="listen-popup__top-icon" Disabled="true" AriaLabel="Playback device" title="Playback device">
                    <MudIcon Icon="@Icons.Material.Outlined.Cast" Class="tl-u-font-size-28px" />
                </AppNativeButton>
                <AppNativeButton Type="button" Class="@($"listen-popup__top-icon {(_showOverflowMenu ? "is-active" : null)}")" OnClick="ToggleOverflowMenu" AriaLabel="More options" title="More options">
                    <MudIcon Icon="@Icons.Material.Outlined.MoreVert" Class="tl-u-font-size-30px" />
                </AppNativeButton>
            </div>
        </div>

        <main class="listen-popup__stage" aria-label="@PopoutAriaLabel">
            <div class="listen-popup__cover">
                @if (!string.IsNullOrWhiteSpace(current.CoverUrl))
                {
                    <img src="@current.CoverUrl" alt="@current.Title" />
                }
                else
                {
                    <MudIcon Icon="@(IsAudiobookMode ? Icons.Material.Outlined.Headphones : Icons.Material.Outlined.Album)" Class="tl-u-font-size-72px" />
                }
            </div>

            <section class="listen-popup__identity">
                <h1>@current.Title</h1>
                @if (!IsAudiobookMode)
                {
                    <p>@PlayerSubtitle(current)</p>
                }
            </section>

            <section class="listen-popup__timeline" aria-label="Playback progress">
                @if (IsAudiobookMode && !string.IsNullOrWhiteSpace(CurrentChapterProgressLabel))
                {
                    <PlaybackTimelineMetaRow Icon="@Icons.Material.Outlined.MenuBook"
                                             Label="@CurrentChapterProgressLabel"
                                             TrailingText="@ProgressPercentLabel"
                                             Size="large"
                                             Class="listen-popup__chapter-row" />
                }
                <AppNativeInput Type="range"
                                Min="0"
                                Max="@ProgressMax"
                                Step="1"
                                Value="@Math.Min(_snapshot.CurrentTimeSeconds, ProgressMax)"
                                Class="listen-popup__progress-slider"
                                OnChange="SeekAsync"
                                AriaLabel="Playback position"
                                aria-valuetext="@ProgressValueText" />
                <div class="listen-popup__time-row">
                    <span>@FormatTimestamp(_snapshot.CurrentTimeSeconds)</span>
                    <span>@RemainingLabel</span>
                    <span>@FormatTimestamp(ProgressMax)</span>
                </div>
            </section>

            <ListenTransportControls Variant="popup"
                                     IsAudiobookMode="@IsAudiobookMode"
                                     IsPlaying="@_snapshot.IsPlaying"
                                     NeedsUserGestureToStart="@_snapshot.NeedsUserGestureToStart"
                                     IsMuted="@_snapshot.IsMuted"
                                     HasChapters="@HasChapters"
                                     CanPreviousTrack="@(_snapshot.CurrentIndex > 0)"
                                     CanNextTrack="@(_snapshot.CurrentIndex < _snapshot.Queue.Count - 1)"
                                     SkipBackSeconds="@_snapshot.SkipBackSeconds"
                                     SkipForwardSeconds="@_snapshot.SkipForwardSeconds"
                                     CurrentBrowserStreamUrl="@CurrentBrowserStreamUrl"
                                     CurrentTimeSeconds="@_snapshot.CurrentTimeSeconds"
                                     PlaybackRate="@_snapshot.PlaybackRate"
                                     Volume="@_snapshot.Volume"
                                     OnTogglePlay="TogglePlayAsync"
                                     OnPreviousTrack="PreviousAsync"
                                     OnNextTrack="NextAsync"
                                     OnPreviousChapter="PlayPreviousChapterAsync"
                                     OnNextChapter="PlayNextChapterAsync"
                                     OnSkipBack="SkipBackAsync"
                                     OnSkipForward="SkipForwardAsync" />

            @if (IsAudiobookMode)
            {
                <PlaybackControlStrip Controls="@AudiobookToolControls"
                                      Size="standard"
                                      Class="listen-popup__actions"
                                      AriaLabel="Audiobook tools"
                                      OnControl="HandleAudiobookToolControl" />
            }
            else
            {
                <section class="listen-popup__music-actions" aria-label="Music controls">
                    <AppNativeButton Type="button" Class="listen-popup__sheet-action" OnClick="ToggleMuteAsync" AriaLabel="Mute or unmute" title="Mute or unmute">
                        <MudIcon Icon="@(_snapshot.IsMuted || _snapshot.Volume <= 0 ? Icons.Material.Outlined.VolumeOff : Icons.Material.Outlined.VolumeUp)" Class="tl-u-font-size-24px" />
                        <span>Volume</span>
                    </AppNativeButton>
                    <AppNativeInput Type="range" Min="0" Max="1" Step="@VolumeStep" Value="@_snapshot.Volume" Class="listen-popup__volume-slider" OnChange="SetVolumeAsync" AriaLabel="Volume" aria-valuetext="@VolumeValueText" />
                </section>
            }
        </main>

        @if (IsAudiobookMode && _activeSheet is not null)
        {
            <div class="listen-popup-sheet__backdrop" @onclick="CloseSheet"></div>
            <PlaybackToolSheet Title="@SheetTitle"
                               Subtitle="@SheetSubtitle"
                               Surface="popup"
                               Presentation="full-overlay"
                               Class="listen-popup-sheet"
                               OnClose="CloseSheet">
                @switch (_activeSheet)
                {
                    case "speed":
                        <PlaybackSpeedControl Value="@_snapshot.PlaybackRate"
                                              ValueChanged="SetSpeedAsync"
                                              Class="listen-popup-sheet__speed-control" />
                        break;
                    case "chapters":
                        <PlaybackSheetList Class="listen-popup-sheet__list">
                            @if (CurrentChapters.Count == 0)
                            {
                                <div class="listen-popup-sheet__empty">No timed chapters were found for this audiobook.</div>
                            }
                            else
                            {
                                @for (var index = 0; index < CurrentChapters.Count; index++)
                                {
                                    var chapter = CurrentChapters[index];
                                    var isActive = IsCurrentChapter(chapter);
                                    <PlaybackSheetRow Variant="chapter" Class="listen-popup-sheet__row listen-popup-sheet__row--chapter" IsActive="@isActive" OnClick="@(() => PlayChapterAsync(chapter.Index))" AriaLabel="@($"Play {chapter.Title}")">
                                        <span class="playback-sheet-row__copy listen-popup-sheet__copy">
                                            <strong>@chapter.Title</strong>
                                        </span>
                                        <span class="playback-sheet-row__duration listen-popup-sheet__duration">@ChapterDuration(chapter)</span>
                                    </PlaybackSheetRow>
                                }
                            }
                        </PlaybackSheetList>
                        break;
                    case "history":
                        <PlaybackSheetList Class="listen-popup-sheet__list">
                            @if (_snapshot.AudiobookHistory.Count == 0)
                            {
                                <div class="listen-popup-sheet__empty">Recent listening positions will appear here.</div>
                            }
                            else
                            {
                                <PlaybackPositionList Class="listen-popup-sheet__position-list">
                                    @foreach (var item in _snapshot.AudiobookHistory)
                                    {
                                        <PlaybackPositionRow Class="listen-popup-sheet__history-row"
                                                             Presentation="list"
                                                             Title="@HistoryTitle(item)"
                                                             PositionText="@HistoryPositionText(item)"
                                                             TimestampText="@HistorySubtitle(item)"
                                                             OnClick="@(() => PlayAudiobookHistoryAsync(item))"
                                                             AriaLabel="@($"Resume {HistoryTitle(item)} from {HistoryPositionText(item)}")" />
                                    }
                                </PlaybackPositionList>
                            }
                        </PlaybackSheetList>
                        break;
                    case "bookmarks":
                        <div class="listen-popup-sheet__toolbar">
                            <PlaybackPositionRow Class="listen-popup-sheet__bookmark-add"
                                                 Kind="add"
                                                 Size="compact"
                                                 Title="@($"Add bookmark at {FormatTimestamp(_snapshot.CurrentTimeSeconds)}")"
                                                 LeadingIcon="@Icons.Material.Outlined.BookmarkAdd"
                                                 ActionIcon="@Icons.Material.Outlined.ChevronRight"
                                                 ActionLabel=""
                                                 ActionVariant="plain"
                                                 OnClick="AddBookmarkAsync"
                                                 AriaLabel="Add bookmark at current position" />
                        </div>
                        <PlaybackSheetList Class="listen-popup-sheet__list">
                            @if (_snapshot.AudiobookBookmarks.Count == 0)
                            {
                                <div class="listen-popup-sheet__empty">No bookmarks yet.</div>
                            }
                            else
                            {
                                <PlaybackPositionList Class="listen-popup-sheet__position-list">
                                    @foreach (var bookmark in _snapshot.AudiobookBookmarks)
                                    {
                                        <PlaybackPositionRow Class="listen-popup-sheet__bookmark-row"
                                                             Presentation="list"
                                                             Title="@BookmarkTitle(bookmark)"
                                                             PositionText="@BookmarkPositionText(bookmark)"
                                                             TimestampText="@BookmarkSubtitle(bookmark)"
                                                             LeadingIcon="@Icons.Material.Outlined.BookmarkBorder"
                                                             ActionLabel="Go to"
                                                             OnClick="@(() => PlayBookmarkAsync(bookmark))"
                                                             AriaLabel="@($"Go to bookmark {BookmarkTitle(bookmark)} at {BookmarkPositionText(bookmark)}")" />
                                    }
                                </PlaybackPositionList>
                            }
                        </PlaybackSheetList>
                        break;
                    case "sleep":
                        <PlaybackSleepTimerControl OptionsMinutes="@_snapshot.SleepTimerOptionsMinutes"
                                                   Mode="@_snapshot.SleepTimerMode"
                                                   TimerMode="@ListenSleepTimerModes.Timer"
                                                   OffMode="@ListenSleepTimerModes.Off"
                                                   EndOfSectionMode="@ListenSleepTimerModes.EndOfChapter"
                                                   EndsAtUtc="@_snapshot.SleepTimerEndsAtUtc"
                                                   AllowEndOfSection="@_snapshot.AllowEndOfChapterSleepTimer"
                                                   TimerMinutesChanged="SetTimerMinutesAsync"
                                                   EndOfSectionChanged="SetTimerEndOfChapterAsync"
                                                   Class="listen-popup-sheet__sleep-control" />
                        break;
                }
            </PlaybackToolSheet>
        }

        @if (_showOverflowMenu)
        {
            <div class="listen-popup-menu__backdrop" @onclick="CloseOverflowMenu"></div>
            <section class="listen-popup-menu" aria-label="More options" aria-modal="true">
                <div class="listen-popup-menu__grabber"></div>
                <AppNativeButton Type="button" Class="listen-popup-menu__row" OnClick="CloseOverflowMenu" AriaLabel="Title details" title="Title details">
                    <MudIcon Icon="@Icons.Material.Outlined.Article" Class="tl-u-font-size-26px" />
                    <span>Title Details</span>
                </AppNativeButton>
                <AppNativeButton Type="button" Class="listen-popup-menu__row" OnClick="CloseOverflowMenu" AriaLabel="Manage in Library" title="Manage in Library">
                    <MudIcon Icon="@Icons.Material.Outlined.LibraryBooks" Class="tl-u-font-size-26px" />
                    <span>Manage in Library</span>
                </AppNativeButton>
                <AppNativeButton Type="button" Class="listen-popup-menu__row" OnClick="ShowBookmarksFromMenu" AriaLabel="Bookmarks" title="Bookmarks">
                    <MudIcon Icon="@Icons.Material.Outlined.BookmarkBorder" Class="tl-u-font-size-26px" />
                    <span>Bookmarks</span>
                </AppNativeButton>
                <AppNativeButton Type="button" Class="listen-popup-menu__cancel" OnClick="CloseOverflowMenu" AriaLabel="Cancel" title="Cancel">Cancel</AppNativeButton>
            </section>
        }
    }
</PlaybackPopoutShell>

@code {
    private readonly JsonSerializerOptions _jsonOptions = new(JsonSerializerDefaults.Web);
    private ListenPlaybackSnapshot _snapshot = new();
    private DotNetObjectReference<ListenPlayerPopupPage>? _selfReference;
    private string? _activeSheet;
    private bool _showOverflowMenu;

    private ListenQueueItem? CurrentItem =>
        _snapshot.CurrentIndex >= 0 && _snapshot.CurrentIndex < _snapshot.Queue.Count
            ? _snapshot.Queue[_snapshot.CurrentIndex]
            : null;

    private bool IsAudiobookMode => string.Equals(_snapshot.Experience, PlayerExperienceModes.Audiobook, StringComparison.OrdinalIgnoreCase);
    private double ProgressMax => _snapshot.DurationSeconds > 0 ? _snapshot.DurationSeconds : TryParseDurationSeconds(CurrentItem?.Duration) ?? 1;
    private string VolumeStep => PlaybackClientSettings.VolumeStep.ToString("0.###", CultureInfo.InvariantCulture);
    private string ProgressValueText => $"{FormatTimestamp(_snapshot.CurrentTimeSeconds)} of {FormatTimestamp(ProgressMax)}";
    private string VolumeValueText => $"{Math.Clamp((int)Math.Round(_snapshot.Volume * 100d), 0, 100)}%";
    private IReadOnlyList<PlaybackChapterDto> CurrentChapters =>
        CurrentItem is { Chapters.Count: > 1 } item ? item.Chapters : [];
    private bool HasChapters => CurrentChapters.Count > 0;
    private string? CurrentBrowserStreamUrl =>
        !string.IsNullOrWhiteSpace(_snapshot.CurrentBrowserStreamUrl)
            ? _snapshot.CurrentBrowserStreamUrl
            : CurrentItem?.StreamUrl;
    private PlaybackExperience CurrentExperience => IsAudiobookMode ? PlaybackExperience.Audiobook : PlaybackExperience.Music;
    private string PopoutAriaLabel => IsAudiobookMode ? "Audiobook player" : "Music player";
    private string PopupClass => IsAudiobookMode ? "listen-popup listen-popup--audiobook" : "listen-popup listen-popup--music";
    private string BackdropStyle => string.IsNullOrWhiteSpace(CurrentItem?.CoverUrl)
        ? string.Empty
        : $"--listen-popup-cover:url('{CurrentItem.CoverUrl.Replace("'", "%27", StringComparison.Ordinal)}');";
    private string RemainingLabel => $"{FormatTimestamp(Math.Max(0, ProgressMax - _snapshot.CurrentTimeSeconds))} left";
    private string CurrentChapterProgressLabel =>
        CurrentChapters.LastOrDefault(chapter =>
            chapter.StartSeconds <= _snapshot.CurrentTimeSeconds
            && (!chapter.EndSeconds.HasValue || _snapshot.CurrentTimeSeconds < chapter.EndSeconds.Value)) is { } chapter
                ? $"{chapter.Title} of {CurrentChapters.Count}"
                : string.Empty;
    private string ProgressPercentLabel =>
        $"{Math.Clamp((int)Math.Round(_snapshot.CurrentTimeSeconds / ProgressMax * 100d, MidpointRounding.AwayFromZero), 0, 100)}%";
    private string SheetTitle => _activeSheet switch
    {
        "speed" => "Speed",
        "chapters" => "Chapters",
        "history" => "History",
        "bookmarks" => "Bookmarks",
        "sleep" => "Sleep Timer",
        _ => string.Empty,
    };
    private string SheetSubtitle => _activeSheet switch
    {
        "speed" => "Adjust playback speed",
        "chapters" => string.Empty,
        "history" => "Recent listening positions",
        "bookmarks" => "Saved audiobook positions",
        "sleep" => "Stop playback automatically",
        _ => string.Empty,
    };
    private IReadOnlyList<PlaybackControlDefinition> AudiobookToolControls =>
        PlaybackControlCatalog.BuildToolStrip(
            PlaybackExperience.Audiobook,
            PlaybackControlSurface.Popup,
            new PlaybackControlState(
                ActiveSheet: _activeSheet,
                PlaybackRate: _snapshot.PlaybackRate,
                HasChapters: HasChapters,
                IsSleepTimerActive: _snapshot.SleepTimerMode != ListenSleepTimerModes.Off,
                HistoryCount: _snapshot.AudiobookHistory.Count,
                BookmarkCount: _snapshot.AudiobookBookmarks.Count));
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _selfReference = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("listenPlayback.configure", PlaybackClientSettings);
        await JS.InvokeVoidAsync("listenPlayback.registerStateHandler", _selfReference);
        await JS.InvokeVoidAsync("listenPlayback.registerPopupWindow");
        await JS.InvokeVoidAsync("listenPlayback.focusPopup");

        try
        {
            var json = await JS.InvokeAsync<string?>("listenPlayback.getState");
            if (!string.IsNullOrWhiteSpace(json))
            {
                var snapshot = JsonSerializer.Deserialize<ListenPlaybackSnapshot>(json, _jsonOptions);
                if (snapshot is not null)
                {
                    _snapshot = snapshot;
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not restore listen popup playback state from browser storage.");
        }
    }

    [JSInvokable]
    public Task HandlePlaybackState(string json)
    {
        _snapshot = string.IsNullOrWhiteSpace(json)
            ? new ListenPlaybackSnapshot()
            : JsonSerializer.Deserialize<ListenPlaybackSnapshot>(json, _jsonOptions) ?? new ListenPlaybackSnapshot();

        StateHasChanged();
        return Task.CompletedTask;
    }

    private void HandleAudiobookToolControl(PlaybackControlDefinition control)
    {
        if (control.IsDisabled || string.IsNullOrWhiteSpace(control.Sheet))
        {
            return;
        }

        ToggleSheet(control.Sheet);
    }

    private void ToggleSheet(string sheet)
    {
        _showOverflowMenu = false;
        _activeSheet = _activeSheet == sheet ? null : sheet;
    }

    private void ToggleOverflowMenu()
    {
        _activeSheet = null;
        _showOverflowMenu = !_showOverflowMenu;
    }

    private void CloseSheet() => _activeSheet = null;

    private Task HandlePopupKeyDown(KeyboardEventArgs args)
    {
        if (!string.Equals(args.Key, "Escape", StringComparison.Ordinal))
        {
            return Task.CompletedTask;
        }

        if (_activeSheet is not null)
        {
            CloseSheet();
            return Task.CompletedTask;
        }

        return _showOverflowMenu ? CloseOverflowMenu() : Task.CompletedTask;
    }

    private Task CloseOverflowMenu()
    {
        _showOverflowMenu = false;
        return Task.CompletedTask;
    }

    private Task ShowBookmarksFromMenu()
    {
        _showOverflowMenu = false;
        _activeSheet = "bookmarks";
        return Task.CompletedTask;
    }
    private async Task TogglePlayAsync()
    {
        if (await ConsumeImmediateToggleAsync())
        {
            return;
        }

        await SendCommandAsync(new PopupCommand { Action = "toggle-play" });
    }

    private Task SkipForwardAsync() => SkipRelativeAsync("skip-forward");
    private Task SkipBackAsync() => SkipRelativeAsync("skip-back");

    private async Task SkipRelativeAsync(string command)
    {
        if (await ConsumeImmediateSeekAsync())
        {
            return;
        }

        await SendCommandAsync(new PopupCommand { Action = command });
    }

    private async Task<bool> ConsumeImmediateToggleAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("listenPlayback.consumeImmediateToggleHandled");
        }
        catch
        {
            return false;
        }
    }

    private async Task<bool> ConsumeImmediateSeekAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("listenPlayback.consumeImmediateSeekHandled");
        }
        catch
        {
            return false;
        }
    }

    private Task PlayNextChapterAsync() => SendCommandAsync(new PopupCommand { Action = IsAudiobookMode ? "play-next-chapter" : "play-next" });
    private Task PlayPreviousChapterAsync() => SendCommandAsync(new PopupCommand { Action = IsAudiobookMode ? "play-previous-chapter" : "play-previous" });
    private Task NextAsync() => SendCommandAsync(new PopupCommand { Action = "play-next" });
    private Task PreviousAsync() => SendCommandAsync(new PopupCommand { Action = "play-previous" });

    private async Task PlayChapterAsync(int chapterIndex)
    {
        await SendCommandAsync(new PopupCommand { Action = "play-chapter", ChapterIndex = chapterIndex });
        CloseSheet();
    }

    private async Task PlayAudiobookHistoryAsync(AudiobookListenHistoryItemDto item)
    {
        await SendCommandAsync(new PopupCommand { Action = "play-audiobook-history", AudiobookHistoryItem = item });
        CloseSheet();
    }

    private async Task PlayBookmarkAsync(AudiobookBookmarkDto bookmark)
    {
        await SendCommandAsync(new PopupCommand { Action = "play-audiobook-bookmark", AudiobookBookmark = bookmark });
        CloseSheet();
    }

    private async Task AddBookmarkAsync()
    {
        await SendCommandAsync(new PopupCommand { Action = "add-audiobook-bookmark" });
        CloseSheet();
    }
    private Task DeleteBookmarkAsync(Guid bookmarkId) => SendCommandAsync(new PopupCommand { Action = "delete-audiobook-bookmark", BookmarkId = bookmarkId });
    private Task ToggleMuteAsync() => SendCommandAsync(new PopupCommand { Action = "toggle-mute" });
    private async Task SetSpeedAsync(double rate)
    {
        _snapshot = _snapshot with { PlaybackRate = Math.Clamp(rate, 0.5d, 2.5d) };
        await SendCommandAsync(new PopupCommand { Action = "set-speed", Value = rate });
    }

    private Task SetTimerMinutesAsync(int? minutes) =>
        SetTimerAsync(minutes, null);

    private Task SetTimerEndOfChapterAsync() =>
        SetTimerAsync(null, ListenSleepTimerModes.EndOfChapter);

    private async Task SetTimerAsync(int? minutes, string? mode)
    {
        if (string.Equals(mode, ListenSleepTimerModes.EndOfChapter, StringComparison.Ordinal))
        {
            _snapshot = _snapshot with { SleepTimerMode = ListenSleepTimerModes.EndOfChapter, SleepTimerEndsAtUtc = null };
            await SendCommandAsync(new PopupCommand { Action = "set-sleep-timer", TimerMode = mode });
            return;
        }

        if (minutes.HasValue)
        {
            _snapshot = _snapshot with { SleepTimerMode = ListenSleepTimerModes.Timer, SleepTimerEndsAtUtc = DateTimeOffset.UtcNow.AddMinutes(minutes.Value) };
            await SendCommandAsync(new PopupCommand { Action = "set-sleep-timer", TimerMinutes = minutes });
        }
        else
        {
            _snapshot = _snapshot with { SleepTimerMode = ListenSleepTimerModes.Off, SleepTimerEndsAtUtc = null };
            await SendCommandAsync(new PopupCommand { Action = "cancel-sleep-timer" });
        }
    }

    private async Task ClosePopupWindowAsync()
    {
        await SendCommandAsync(new PopupCommand { Action = "popup-closed" });
        try
        {
            await JS.InvokeVoidAsync("window.close");
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not close listen popup window.");
        }
    }

    private async Task SeekAsync(ChangeEventArgs args)
    {
        if (double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var seconds))
        {
            await SendCommandAsync(new PopupCommand { Action = "seek", Value = seconds });
        }
    }

    private async Task SetVolumeAsync(ChangeEventArgs args)
    {
        if (double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var volume))
        {
            await SendCommandAsync(new PopupCommand { Action = "set-volume", Value = volume });
        }
    }

    private Task SendCommandAsync(PopupCommand command)
        => JS.InvokeVoidAsync("listenPlayback.sendCommand", JsonSerializer.Serialize(command, _jsonOptions)).AsTask();

    private bool IsCurrentChapter(PlaybackChapterDto chapter) =>
        _snapshot.CurrentTimeSeconds >= chapter.StartSeconds - 0.5d
        && (!chapter.EndSeconds.HasValue || _snapshot.CurrentTimeSeconds < chapter.EndSeconds.Value - 0.5d);

    private string PlayerSubtitle(ListenQueueItem item)
    {
        if (IsAudiobookMode)
        {
            return FirstDistinctFrom(item.Title, item.Subtitle, item.Album, _snapshot.SourceLabel, "Audiobook");
        }

        return FirstNonBlank(item.Subtitle, item.Album, _snapshot.SourceLabel, "Library audio");
    }

    private static string ChapterDuration(PlaybackChapterDto chapter) =>
        chapter.EndSeconds is > 0 && chapter.EndSeconds.Value > chapter.StartSeconds
            ? FormatTimestamp(chapter.EndSeconds.Value - chapter.StartSeconds)
            : string.Empty;

    private static string HistoryTitle(AudiobookListenHistoryItemDto item)
        => FirstNonBlank(item.ChapterTitle, $"Position {FormatTimestamp(item.PositionSeconds)}");

    private static string HistoryPositionText(AudiobookListenHistoryItemDto item) =>
        $"Left off at {FormatTimestamp(item.PositionSeconds)}";

    private static string HistorySubtitle(AudiobookListenHistoryItemDto item) =>
        $"{item.EndedAt.LocalDateTime.ToString("MMM d, yyyy", CultureInfo.CurrentCulture)} - {item.EndedAt.LocalDateTime.ToString("h:mm tt", CultureInfo.CurrentCulture)}";

    private static string BookmarkTitle(AudiobookBookmarkDto item) =>
        FirstNonBlank(item.Label, item.ChapterTitle, $"Bookmark at {FormatTimestamp(item.PositionSeconds)}");

    private static string BookmarkPositionText(AudiobookBookmarkDto item) =>
        $"Position {FormatTimestamp(item.PositionSeconds)}";

    private static string BookmarkSubtitle(AudiobookBookmarkDto item) =>
        $"{item.CreatedAt.LocalDateTime.ToString("MMM d, yyyy", CultureInfo.CurrentCulture)} - {item.CreatedAt.LocalDateTime.ToString("h:mm tt", CultureInfo.CurrentCulture)}";

    private static string FormatTimestamp(double seconds)
    {
        var safe = Math.Max(0, seconds);
        var span = TimeSpan.FromSeconds(safe);
        return span.TotalHours >= 1
            ? span.ToString(@"h\:mm\:ss", CultureInfo.InvariantCulture)
            : span.ToString(@"m\:ss", CultureInfo.InvariantCulture);
    }

    private static string FormatSpeed(double rate) =>
        $"{Math.Clamp(rate, 0.5d, 3d).ToString("0.0", CultureInfo.InvariantCulture)}x";

    private static double? TryParseDurationSeconds(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var parts = value.Split(':', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length is not (2 or 3))
        {
            return null;
        }

        var total = 0d;
        var multiplier = 1d;
        for (var index = parts.Length - 1; index >= 0; index--)
        {
            if (!double.TryParse(parts[index], NumberStyles.Float, CultureInfo.InvariantCulture, out var parsed))
            {
                return null;
            }

            total += parsed * multiplier;
            multiplier *= 60d;
        }

        return total;
    }

    private static string FirstNonBlank(params string?[] values)
        => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? "Library audio";

    private static string FirstDistinctFrom(string? primary, params string?[] values)
        => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)
            && !string.Equals(value, primary, StringComparison.OrdinalIgnoreCase)) ?? "Audiobook";

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("listenPlayback.unregisterStateHandler", _selfReference);
            await JS.InvokeVoidAsync("listenPlayback.unregisterPopupWindow");
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogDebug(ex, "Failed to unregister listen popup JavaScript handlers.");
        }

        _selfReference?.Dispose();
    }

    private sealed class PopupCommand
    {
        public string Action { get; set; } = string.Empty;
        public int? ChapterIndex { get; set; }
        public double? Value { get; set; }
        public int? TimerMinutes { get; set; }
        public string? TimerMode { get; set; }
        public Guid? BookmarkId { get; set; }
        public AudiobookListenHistoryItemDto? AudiobookHistoryItem { get; set; }
        public AudiobookBookmarkDto? AudiobookBookmark { get; set; }
    }
}
