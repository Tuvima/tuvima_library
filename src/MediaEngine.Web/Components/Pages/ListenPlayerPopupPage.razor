@page "/listen/player-popup"
@layout MediaEngine.Web.Shared.PopupLayout
@using System.Globalization
@using System.Text.Json
@using Microsoft.JSInterop
@using MediaEngine.Web.Services.Playback
@inject IJSRuntime JS
@inject IStringLocalizer<SharedStrings> L
@inject ILogger<ListenPlayerPopupPage> Logger
@implements IAsyncDisposable

<PageTitle>@L["Listen_MiniPlayerTitle"]</PageTitle>

<div class="listen-popup">
    @if (CurrentItem is null)
    {
        <div class="listen-popup__empty">
            <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 42px; opacity: 0.34;" />
            <p>@L["Listen_NothingPlaying"]</p>
        </div>
    }
    else
    {
        <div class="listen-popup__header">
            <div class="listen-popup__thumb">
                @if (!string.IsNullOrWhiteSpace(CurrentItem.CoverUrl))
                {
                    <img src="@CurrentItem.CoverUrl" alt="@CurrentItem.Title" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 18px;" />
                }
            </div>
            <div class="listen-popup__copy">
                <div class="listen-popup__title">@CurrentItem.Title</div>
                <div class="listen-popup__subtitle">@FirstNonBlank(CurrentItem.Subtitle, CurrentItem.Album, _snapshot.SourceLabel)</div>
            </div>
        </div>

        <div class="listen-popup__tabs">
            <button type="button"
                    class="listen-popup__tab @(_snapshot.ActiveTab == ListenPlaybackTabs.Queue ? "is-active" : null)"
                    @onclick="@(() => SetTabAsync(ListenPlaybackTabs.Queue))">
                @L["Listen_PlayingNext"]
            </button>
            <button type="button"
                    class="listen-popup__tab @(_snapshot.ActiveTab == ListenPlaybackTabs.History ? "is-active" : null)"
                    @onclick="@(() => SetTabAsync(ListenPlaybackTabs.History))">
                @L["Listen_History"]
            </button>
        </div>

        @if (_snapshot.ActiveTab == ListenPlaybackTabs.Queue)
        {
            <div class="listen-popup__subheader">
                <span>@L["Listen_PlayingNext"]</span>
                <button type="button" class="listen-popup__text-action" @onclick="ClearUpcomingAsync">@L["Common_Clear"]</button>
            </div>

            @if (UpcomingItems.Count == 0)
            {
                <div class="listen-popup__empty-state">@L["Listen_QueueEndsWithCurrent"]</div>
            }
            else
            {
                <div class="listen-popup__list">
                    @for (var index = _snapshot.CurrentIndex + 1; index < _snapshot.Queue.Count; index++)
                    {
                        var item = _snapshot.Queue[index];
                        <div class="listen-popup__row">
                            <button type="button" class="listen-popup__row-main" @onclick="@(() => PlayIndexAsync(index))">
                                <div class="listen-popup__row-thumb">
                                    @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                                    {
                                        <img src="@item.CoverUrl" alt="@item.Title" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Style="font-size: 16px;" />
                                    }
                                </div>
                                <div class="listen-popup__row-copy">
                                    <div class="listen-popup__row-title">@item.Title</div>
                                    <div class="listen-popup__row-subtitle">@FirstNonBlank(item.Subtitle, item.Album)</div>
                                </div>
                                <div class="listen-popup__row-duration">@item.Duration</div>
                            </button>
                            <button type="button" class="listen-popup__row-action" @onclick="@(() => RemoveUpcomingAsync(index))">
                                <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 16px;" />
                            </button>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="listen-popup__subheader">
                <span>@L["Listen_History"]</span>
            </div>

            @if (_snapshot.History.Count == 0)
            {
                <div class="listen-popup__empty-state">@L["Listen_HistoryEmpty"]</div>
            }
            else
            {
                <div class="listen-popup__list">
                    @foreach (var item in _snapshot.History)
                    {
                        <button type="button" class="listen-popup__row-main" @onclick="@(() => PlayHistoryAsync(item))">
                            <div class="listen-popup__row-thumb">
                                @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                                {
                                    <img src="@item.CoverUrl" alt="@item.Title" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Style="font-size: 16px;" />
                                }
                            </div>
                            <div class="listen-popup__row-copy">
                                <div class="listen-popup__row-title">@item.Title</div>
                                <div class="listen-popup__row-subtitle">@FirstNonBlank(item.Subtitle, item.Album, FormatHistoryStamp(item.PlayedAt))</div>
                            </div>
                            <div class="listen-popup__row-duration">@item.Duration</div>
                        </button>
                    }
                </div>
            }
        }

        <div class="listen-popup__progress">
            <span>@FormatTimestamp(_snapshot.CurrentTimeSeconds)</span>
            <input type="range"
                   min="0"
                   max="@ProgressMax"
                   step="1"
                   value="@Math.Min(_snapshot.CurrentTimeSeconds, ProgressMax)"
                   @oninput="SeekAsync" />
            <span>@FormatTimestamp(Math.Max(0, _snapshot.DurationSeconds - _snapshot.CurrentTimeSeconds))</span>
        </div>

        <div class="listen-popup__controls">
            <button type="button" class="listen-popup__icon" @onclick="ToggleMuteAsync">
                <MudIcon Icon="@(_snapshot.IsMuted || _snapshot.Volume <= 0 ? Icons.Material.Outlined.VolumeOff : Icons.Material.Outlined.VolumeUp)" Style="font-size: 18px;" />
            </button>
            <input type="range"
                   min="0"
                   max="1"
                   step="0.05"
                   value="@_snapshot.Volume"
                   class="listen-popup__volume"
                   @oninput="SetVolumeAsync" />
            <button type="button" class="listen-popup__icon" @onclick="PlayPreviousAsync">
                <MudIcon Icon="@Icons.Material.Outlined.SkipPrevious" Style="font-size: 20px;" />
            </button>
            <button type="button" class="listen-popup__play" @onclick="TogglePlayAsync">
                <MudIcon Icon="@(_snapshot.IsPlaying ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)" Style="font-size: 22px;" />
            </button>
            <button type="button" class="listen-popup__icon" @onclick="PlayNextAsync">
                <MudIcon Icon="@Icons.Material.Outlined.SkipNext" Style="font-size: 20px;" />
            </button>
            <button type="button" class="listen-popup__icon" @onclick="ClosePlayerAsync">
                <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 18px;" />
            </button>
        </div>
    }
</div>

@code {
    private readonly JsonSerializerOptions _jsonOptions = new(JsonSerializerDefaults.Web);
    private ListenPlaybackSnapshot _snapshot = new();
    private DotNetObjectReference<ListenPlayerPopupPage>? _selfReference;

    private ListenQueueItem? CurrentItem =>
        _snapshot.CurrentIndex >= 0 && _snapshot.CurrentIndex < _snapshot.Queue.Count
            ? _snapshot.Queue[_snapshot.CurrentIndex]
            : null;

    private IReadOnlyList<ListenQueueItem> UpcomingItems =>
        _snapshot.CurrentIndex < 0 || _snapshot.CurrentIndex >= _snapshot.Queue.Count
            ? _snapshot.Queue
            : _snapshot.Queue.Skip(_snapshot.CurrentIndex + 1).ToList();

    private double ProgressMax => _snapshot.DurationSeconds > 0 ? _snapshot.DurationSeconds : 1;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _selfReference = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("listenPlayback.registerStateHandler", _selfReference);
        await JS.InvokeVoidAsync("listenPlayback.registerPopupWindow");

        try
        {
            var json = await JS.InvokeAsync<string?>("listenPlayback.getState");
            if (!string.IsNullOrWhiteSpace(json))
            {
                var snapshot = JsonSerializer.Deserialize<ListenPlaybackSnapshot>(json, _jsonOptions);
                if (snapshot is not null)
                {
                    _snapshot = snapshot;
                    StateHasChanged();
                }
            }
        }
        catch
        {
        }
    }

    [JSInvokable]
    public Task HandlePlaybackState(string json)
    {
        _snapshot = string.IsNullOrWhiteSpace(json)
            ? new ListenPlaybackSnapshot()
            : JsonSerializer.Deserialize<ListenPlaybackSnapshot>(json, _jsonOptions) ?? new ListenPlaybackSnapshot();

        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task SetTabAsync(string tab) => SendCommandAsync(new PopupCommand { Action = "set-tab", Tab = tab });
    private Task TogglePlayAsync() => SendCommandAsync(new PopupCommand { Action = "toggle-play" });
    private Task PlayNextAsync() => SendCommandAsync(new PopupCommand { Action = "play-next" });
    private Task PlayPreviousAsync() => SendCommandAsync(new PopupCommand { Action = "play-previous" });
    private Task ClearUpcomingAsync() => SendCommandAsync(new PopupCommand { Action = "clear-upcoming" });
    private Task RemoveUpcomingAsync(int index) => SendCommandAsync(new PopupCommand { Action = "remove-upcoming", Index = index });
    private Task PlayIndexAsync(int index) => SendCommandAsync(new PopupCommand { Action = "play-index", Index = index });
    private Task PlayHistoryAsync(ListenQueueItem item) => SendCommandAsync(new PopupCommand { Action = "play-history", Item = item });
    private Task ToggleMuteAsync() => SendCommandAsync(new PopupCommand { Action = "toggle-mute" });
    private Task ClosePlayerAsync() => SendCommandAsync(new PopupCommand { Action = "close-player" });

    private async Task SeekAsync(ChangeEventArgs args)
    {
        if (double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var seconds))
        {
            await SendCommandAsync(new PopupCommand { Action = "seek", Value = seconds });
        }
    }

    private async Task SetVolumeAsync(ChangeEventArgs args)
    {
        if (double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var volume))
        {
            await SendCommandAsync(new PopupCommand { Action = "set-volume", Value = volume });
        }
    }

    private Task SendCommandAsync(PopupCommand command)
        => JS.InvokeVoidAsync("listenPlayback.sendCommand", JsonSerializer.Serialize(command, _jsonOptions)).AsTask();

    private static string FormatTimestamp(double seconds)
    {
        var safe = Math.Max(0, seconds);
        var span = TimeSpan.FromSeconds(safe);
        return span.TotalHours >= 1
            ? span.ToString(@"h\:mm\:ss", CultureInfo.InvariantCulture)
            : span.ToString(@"m\:ss", CultureInfo.InvariantCulture);
    }

    private string FormatHistoryStamp(DateTimeOffset? playedAt)
        => playedAt.HasValue
            ? playedAt.Value.LocalDateTime.ToString("M/d h:mm tt", CultureInfo.CurrentCulture)
            : L["Listen_PlayedEarlier"];

    private string FirstNonBlank(params string?[] values)
        => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? L["Listen_LibraryAudio"];

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("listenPlayback.unregisterStateHandler", _selfReference);
            await JS.InvokeVoidAsync("listenPlayback.unregisterPopupWindow");
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogDebug(ex, "Failed to unregister listen popup JavaScript handlers.");
        }

        _selfReference?.Dispose();
    }

    private sealed class PopupCommand
    {
        public string Action { get; set; } = string.Empty;
        public int? Index { get; set; }
        public double? Value { get; set; }
        public string? Tab { get; set; }
        public ListenQueueItem? Item { get; set; }
    }
}
