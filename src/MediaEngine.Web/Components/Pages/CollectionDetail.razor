@page "/collection/{Id:guid}"
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@using MediaEngine.Web.Services.Editing
@using MediaEngine.Web.Components.Collections
@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav
@inject CollectionEditorLauncherService CollectionEditorLauncher

@namespace MediaEngine.Web.Components.Pages

<PageTitle>@((_collection?.Name ?? "Collection")) - Tuvima</PageTitle>

@if (_loading)
{
    <div class="collection-detail-page collection-detail-page--state">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (_collection is null)
{
    <div class="collection-detail-page collection-detail-page--state">
        <div class="collection-detail-empty">
            <MudIcon Icon="@Icons.Material.Outlined.CollectionsBookmark" />
            <h1>Collection unavailable</h1>
            <p>This collection could not be loaded from your library.</p>
        </div>
    </div>
}
else if (_editorSession is not null)
{
    <article class="tl-detail-page collection-detail-page collection-detail-page--editing">
        <CollectionEditorShell Request="_editorSession.Request"
                               Inline="true"
                               Closed="HandleEditorClosedAsync" />
    </article>
}
else
{
    <article class="tl-detail-page collection-detail-page">
        <AppCssElement Tag="section" Class="@HeroClass" Css="@HeroStyle">
            <div class="collection-detail-hero__wash"></div>
            <div class="collection-detail-hero__content">
                <div class="collection-detail-eyebrow">
                    <MudIcon Icon="@Icons.Material.Outlined.CollectionsBookmark" Size="Size.Small" />
                    <span>@CollectionLabel</span>
                </div>

                <h1>@_collection.Name</h1>
                <p>@DescriptionText</p>

                <div class="collection-detail-meta" aria-label="Collection summary">
                    <span>@ItemCountLabel</span>
                    @foreach (var count in MediaCounts)
                    {
                        <span class="collection-detail-meta__chip" title="@count.Label">
                            <MudIcon Icon="@count.Icon" Size="Size.Small" />
                            <strong>@count.Count</strong>
                        </span>
                    }
                </div>

                @if (CanEditCollection)
                {
                    <AppButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.Edit"
                               Class="collection-detail-edit-action"
                               OnClick="OpenEditorAsync">
                        Edit collection
                    </AppButton>
                }
            </div>

            <div class="collection-detail-hero__cascade">
                <TuvimaArtworkStack Items="@HeroArtworkStackItems"
                                    Seed="@Id.ToString("D")"
                                    Variant="ArtworkStackVariant.Hero"
                                    MaxVisible="5"
                                    IsDecorative="true"
                                    Palette="@_collection.ArtworkPalette"
                                    Class="collection-detail-artwork-stack" />
            </div>
        </AppCssElement>

        <main class="collection-detail-overview">
            <div class="collection-detail-overview__main">
                <div class="collection-detail-section-heading">
                    <div>
                        <div class="collection-detail-eyebrow collection-detail-eyebrow--small">
                            <MudIcon Icon="@Icons.Material.Outlined.ViewComfyAlt" Size="Size.Small" />
                            <span>OVERVIEW</span>
                        </div>
                        <h2>Included Items</h2>
                    </div>
                </div>

                @if (_loadingItems)
                {
                    <div class="collection-detail-loading">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                        <span>Loading collection items...</span>
                    </div>
                }
                else if (_items.Count == 0)
                {
                    <div class="collection-detail-empty collection-detail-empty--inline">
                        <MudIcon Icon="@Icons.Material.Outlined.LibraryAdd" />
                        <h3>No items yet</h3>
                        <p>This collection does not contain any visible library items.</p>
                    </div>
                }
                else
                {
                    @foreach (var group in ItemGroups)
                    {
                        <section class="collection-detail-item-group">
                            <div class="collection-detail-item-group__heading">
                                <span>@group.Label</span>
                                <small>@($"{group.Items.Count} {Pluralize("item", group.Items.Count)}")</small>
                            </div>

                            <div class="collection-detail-item-grid">
                                @foreach (var item in group.Items)
                                {
                                    <article class="collection-detail-item-card">
                                        <AppNativeButton Type="button" Class="collection-detail-item-card__art" OnClick="() => OpenItem(item)">
                                            @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                                            {
                                                <img src="@item.CoverUrl" alt="" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@IconForMediaType(item.MediaType)" />
                                            }
                                        </AppNativeButton>
                                        <div class="collection-detail-item-card__copy">
                                            <AppNativeButton Type="button" OnClick="() => OpenItem(item)">@DisplayTitle(item)</AppNativeButton>
                                            <span>@FormatItemMeta(item)</span>
                                        </div>
                                    </article>
                                }
                            </div>
                        </section>
                    }
                }
            </div>

        </main>
    </article>
}

@code {
    private sealed record ItemGroup(string Label, IReadOnlyList<CollectionItemViewModel> Items);
    private sealed record MediaCountChip(string Label, string Icon, int Count);
    private sealed record PaletteColors(string PrimaryRgb, string SecondaryRgb);

    [Parameter] public Guid Id { get; set; }

    private readonly List<CollectionItemViewModel> _items = [];
    private CollectionManagementCatalogViewModel? _collection;
    private ProfileViewModel? _activeProfile;
    private Guid? _loadedCollectionId;
    private bool _loading = true;
    private bool _loadingItems;
    private CollectionEditorInlineSession? _editorSession;

    private bool CanEditCollection => _collection?.CanEdit == true && !_collection.IsSystem;

    private string CollectionLabel
    {
        get
        {
            if (_collection?.IsSystem == true)
                return "SYSTEM COLLECTION";

            return _collection?.IsManual == true ? "CUSTOM COLLECTION" : "GENERATED COLLECTION";
        }
    }

    private string HeroClass => $"collection-detail-hero collection-detail-hero--{(_collection?.PrimaryLane ?? "CrossMedia").ToLowerInvariant()}";

    private string HeroStyle
    {
        get
        {
            var palette = ResolveHeroPalette();
            if (palette is not null)
            {
                return $"--collection-accent-rgb: {palette.PrimaryRgb}; --collection-warm-rgb: {palette.SecondaryRgb}; {_collection?.ArtworkPalette.CssVariableStyle}";
            }

            return _collection?.PrimaryLane switch
            {
                "Read" => "--collection-accent-rgb: 177, 130, 255; --collection-warm-rgb: 199, 147, 88;",
                "Listen" => "--collection-accent-rgb: 142, 105, 255; --collection-warm-rgb: 76, 190, 214;",
                "Watch" => "--collection-accent-rgb: 166, 126, 255; --collection-warm-rgb: 226, 132, 62;",
                _ => "--collection-accent-rgb: 168, 116, 255; --collection-warm-rgb: 226, 171, 75;",
            };
        }
    }

    private string DescriptionText =>
        !string.IsNullOrWhiteSpace(_collection?.Description)
            ? _collection.Description!
            : _collection?.IsManual == true
                ? "A custom collection from your Tuvima Library."
                : "A generated collection from your Tuvima Library.";

    private string ItemCountLabel => $"{_items.Count} {Pluralize("item", _items.Count)}";

    private IReadOnlyList<MediaCountChip> MediaCounts =>
        _items
            .GroupBy(item => MediaCountKey(item.MediaType))
            .Select(group => new MediaCountChip(group.Key.Label, group.Key.Icon, group.Count()))
            .OrderBy(chip => MediaCountSort(chip.Label))
            .ToList();

    private IReadOnlyList<ArtworkStackItem> HeroArtworkStackItems
    {
        get
        {
            var fromCatalog = (_collection?.ArtworkItems ?? [])
                .Select(ToArtworkStackItem)
                .Where(item => !string.IsNullOrWhiteSpace(item.ImageUrl))
                .ToList();

            if (fromCatalog.Count > 0)
                return fromCatalog;

            return _items
                .Where(item => !string.IsNullOrWhiteSpace(item.CoverUrl))
                .Select(item => new ArtworkStackItem
                {
                    Id = item.WorkId.ToString("D"),
                    Title = DisplayTitle(item),
                    ImageUrl = item.CoverUrl ?? string.Empty,
                    MediaType = item.MediaType,
                    Shape = ToArtworkShape(null, item.MediaType),
                })
                .ToList();
        }
    }

    private IReadOnlyList<ItemGroup> ItemGroups
    {
        get
        {
            var groups = new[]
            {
                new ItemGroup("Watch", _items.Where(item => LaneForMediaType(item.MediaType) == "Watch").OrderBy(item => item.SortOrder).ToList()),
                new ItemGroup("Listen", _items.Where(item => LaneForMediaType(item.MediaType) == "Listen").OrderBy(item => item.SortOrder).ToList()),
                new ItemGroup("Read", _items.Where(item => LaneForMediaType(item.MediaType) == "Read").OrderBy(item => item.SortOrder).ToList()),
                new ItemGroup("Other", _items.Where(item => LaneForMediaType(item.MediaType) == "Other").OrderBy(item => item.SortOrder).ToList()),
            };

            return groups.Where(group => group.Items.Count > 0).ToList();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedCollectionId == Id)
            return;

        _loadedCollectionId = Id;
        _loading = true;
        _collection = null;
        _items.Clear();

        try
        {
            _activeProfile ??= await Orchestrator.GetActiveProfileAsync();
            _collection = await ApiClient.GetCollectionSummaryAsync(Id, _activeProfile?.Id);

            if (_collection is not null)
                await LoadItemsAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadItemsAsync()
    {
        _loadingItems = true;
        try
        {
            _items.Clear();
            _items.AddRange(await ApiClient.GetCollectionItemsAsync(Id, 500, _activeProfile?.Id));
        }
        finally
        {
            _loadingItems = false;
        }
    }

    private Task OpenEditorAsync()
    {
        if (_collection is null || !CanEditCollection)
            return Task.CompletedTask;

        _editorSession = CollectionEditorLauncher.BeginInline(new CollectionEditorLaunchRequest
        {
            EditingCollection = ToCollectionListItem(_collection),
            ActiveProfileId = _activeProfile?.Id ?? _collection.ProfileId,
            CanManageSharedCollections = _collection.CanShare,
            Mode = "Collection",
        });
        return InvokeAsync(StateHasChanged);
    }

    private async Task HandleEditorClosedAsync(bool applied)
    {
        _editorSession = null;
        if (applied)
        {
            _collection = await ApiClient.GetCollectionSummaryAsync(Id, _activeProfile?.Id);
            if (_collection is not null)
                await LoadItemsAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private static CollectionListItemViewModel ToCollectionListItem(CollectionManagementCatalogViewModel collection) => new()
    {
        Id = collection.Id,
        Name = collection.Name,
        Description = collection.Description,
        IconName = collection.IconName,
        CollectionType = collection.CollectionType,
        Resolution = collection.Resolution,
        Scope = collection.Scope,
        ProfileId = collection.ProfileId,
        Visibility = collection.Visibility,
        IsEnabled = collection.IsEnabled,
        IsFeatured = collection.IsFeatured,
        ItemCount = collection.ItemCount,
        RuleJson = collection.RuleJson,
        MatchMode = collection.MatchMode,
        SortField = collection.SortField,
        SortDirection = collection.SortDirection,
        LiveUpdating = collection.LiveUpdating,
        CoverUrl = collection.SquareArtworkUrl,
        CreatedAt = collection.CreatedAt,
        CanEdit = collection.CanEdit,
        CanShare = collection.CanShare,
    };

    private void OpenItem(CollectionItemViewModel item)
    {
        if (item.WorkId != Guid.Empty)
            Nav.NavigateTo($"/details/Work/{item.WorkId:D}");
    }

    private static string DisplayTitle(CollectionItemViewModel item) =>
        string.IsNullOrWhiteSpace(item.Title) ? "Untitled item" : item.Title;

    private static string FormatItemMeta(CollectionItemViewModel item) =>
        string.Join("  -  ", new[] { item.Creator, NormalizeMediaType(item.MediaType) }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private static string NormalizeMediaType(string? mediaType) => mediaType switch
    {
        "Audiobooks" => "Audiobook",
        "Books" => "Book",
        "Comics" => "Comic",
        "Movies" => "Movie",
        _ => mediaType ?? string.Empty,
    };

    private static string LaneForMediaType(string? mediaType)
    {
        if (string.Equals(mediaType, "Music", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Audio", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Audiobooks", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Audiobook", StringComparison.OrdinalIgnoreCase))
            return "Listen";

        if (string.Equals(mediaType, "Books", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Book", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Comics", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Comic", StringComparison.OrdinalIgnoreCase))
            return "Read";

        if (string.Equals(mediaType, "Movies", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Movie", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "TV", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Video", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Shows", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Show", StringComparison.OrdinalIgnoreCase))
            return "Watch";

        return "Other";
    }

    private static (string Label, string Icon) MediaCountKey(string? mediaType)
    {
        if (string.Equals(mediaType, "Movies", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Movie", StringComparison.OrdinalIgnoreCase))
            return ("Movies", Icons.Material.Outlined.Movie);

        if (string.Equals(mediaType, "TV", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Shows", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Show", StringComparison.OrdinalIgnoreCase))
            return ("TV", Icons.Material.Outlined.Tv);

        if (string.Equals(mediaType, "Books", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Book", StringComparison.OrdinalIgnoreCase))
            return ("Books", Icons.Material.Outlined.MenuBook);

        if (string.Equals(mediaType, "Comics", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Comic", StringComparison.OrdinalIgnoreCase))
            return ("Comics", Icons.Material.Outlined.AutoStories);

        if (string.Equals(mediaType, "Audiobooks", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Audiobook", StringComparison.OrdinalIgnoreCase))
            return ("Audiobooks", Icons.Material.Outlined.Headphones);

        if (string.Equals(mediaType, "Music", StringComparison.OrdinalIgnoreCase)
            || string.Equals(mediaType, "Audio", StringComparison.OrdinalIgnoreCase))
            return ("Music", Icons.Material.Outlined.Album);

        if (string.Equals(mediaType, "Video", StringComparison.OrdinalIgnoreCase))
            return ("Video", Icons.Material.Outlined.SmartDisplay);

        return ("Other", Icons.Material.Outlined.CollectionsBookmark);
    }

    private static int MediaCountSort(string label) => label switch
    {
        "Movies" => 0,
        "TV" => 1,
        "Books" => 2,
        "Comics" => 3,
        "Audiobooks" => 4,
        "Music" => 5,
        "Video" => 6,
        _ => 7,
    };

    private static string IconForMediaType(string? mediaType) => LaneForMediaType(mediaType) switch
    {
        "Read" => Icons.Material.Outlined.MenuBook,
        "Listen" => Icons.Material.Outlined.Album,
        "Watch" => Icons.Material.Outlined.Movie,
        _ => Icons.Material.Outlined.CollectionsBookmark,
    };

    private static string Pluralize(string noun, int count) => count == 1 ? noun : $"{noun}s";

    private static int StableHash(Guid collectionId, Guid workId)
    {
        var bytes = collectionId.ToByteArray().Concat(workId.ToByteArray()).ToArray();
        unchecked
        {
            var hash = 17;
            foreach (var value in bytes)
                hash = (hash * 31) + value;
            return hash;
        }
    }

    private static ArtworkStackItem ToArtworkStackItem(CollectionArtworkItemViewModel item) => new()
    {
        Id = item.WorkId.ToString("D"),
        Title = item.Title,
        ImageUrl = item.CoverUrl ?? string.Empty,
        MediaType = item.MediaType,
        Shape = ToArtworkShape(item.ArtworkShape, item.MediaType),
    };

    private static ArtworkShape ToArtworkShape(string? shape, string? mediaType)
    {
        if (string.Equals(shape, "square", StringComparison.OrdinalIgnoreCase))
            return ArtworkShape.Square;

        if (string.Equals(shape, "wide", StringComparison.OrdinalIgnoreCase)
            || string.Equals(shape, "landscape", StringComparison.OrdinalIgnoreCase))
            return ArtworkShape.Wide;

        if (string.Equals(shape, "portrait", StringComparison.OrdinalIgnoreCase))
            return ArtworkShape.Portrait;

        return LaneForMediaType(mediaType) == "Listen"
            ? ArtworkShape.Square
            : ArtworkShape.Portrait;
    }

    private PaletteColors? ResolveHeroPalette()
    {
        if (_collection is null)
        {
            return null;
        }

        var candidates = _collection.ArtworkItems
            .Where(item => !string.IsNullOrWhiteSpace(item.PrimaryColor)
                || !string.IsNullOrWhiteSpace(item.SecondaryColor)
                || !string.IsNullOrWhiteSpace(item.AccentColor))
            .OrderBy(item => StableHash(_collection.Id, item.WorkId))
            .ToList();

        if (candidates.Count == 0)
        {
            return null;
        }

        var index = (StableHash(_collection.Id, _collection.Id) & int.MaxValue) % candidates.Count;
        var selected = candidates[index];
        var primary = FirstNonBlank(selected.PrimaryColor, selected.AccentColor, selected.SecondaryColor);
        var secondary = FirstNonBlank(selected.SecondaryColor, selected.AccentColor, selected.PrimaryColor);
        var primaryRgb = ToRgbCss(primary);
        var secondaryRgb = ToRgbCss(secondary);

        return primaryRgb is null || secondaryRgb is null
            ? null
            : new PaletteColors(primaryRgb, secondaryRgb);
    }

    private static string? ToRgbCss(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
        {
            return null;
        }

        var value = color.Trim();
        if (value.StartsWith("rgb(", StringComparison.OrdinalIgnoreCase) && value.EndsWith(')'))
        {
            return value[4..^1];
        }

        if (!value.StartsWith('#'))
        {
            return null;
        }

        var hex = value[1..];
        if (hex.Length == 3)
        {
            hex = string.Concat(hex.Select(character => $"{character}{character}"));
        }

        if (hex.Length != 6)
        {
            return null;
        }

        try
        {
            var red = Convert.ToInt32(hex[..2], 16);
            var green = Convert.ToInt32(hex[2..4], 16);
            var blue = Convert.ToInt32(hex[4..], 16);
            return $"{red}, {green}, {blue}";
        }
        catch (FormatException)
        {
            return null;
        }
    }

    private static string? FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));
}
