@page "/collection/{Id:guid}"
@using MediaEngine.Web.Components.Registry
@inject UIOrchestratorService  Orchestrator
@inject UniverseStateContainer  State
@inject NavigationManager       Nav
@inject IDialogService          DialogService

<PageTitle>@(_collection?.DisplayName ?? "Collection") — Tuvima Library</PageTitle>

@* â”€â”€ Edit-metadata panel â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
<CollectionEditPanel @bind-IsOpen="_editDrawerOpen"
              CollectionId="Id"
              EntityId="@(_collection?.Works.FirstOrDefault()?.Id ?? Guid.Empty)"
              MediaType="@_collection?.PrimaryMediaType"
              CurrentCoverUrl="@_collection?.CoverUrl"
              OnApplied="@OnEditApplied" />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else if (_collection is null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">Collection not found.</MudAlert>
    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Nav.NavigateTo("/"))">
        Back to Home
    </MudButton>
}
else
{
    @* ── Fixed hero background ── *@
    @if (!string.IsNullOrEmpty(_collection.HeroUrl))
    {
        <div class="detail-hero-fixed">
            <img src="@_collection.HeroUrl" alt="" />
        </div>
        <div class="detail-hero-fade"></div>
    }
    else if (!string.IsNullOrEmpty(_collection.CoverUrl))
    {
        <div class="detail-hero-fixed detail-hero-cover-blur">
            <img src="@_collection.CoverUrl" alt="" />
        </div>
        <div class="detail-hero-fade"></div>
    }

    @* ── Scrollable content layer ── *@
    <div class="detail-content-layer collection-detail-page">

        @* ── Work in Progress banner ── *@
        <MudAlert Severity="Severity.Warning"
                  Icon="@Icons.Material.Filled.Construction"
                  Class="mb-3"
                  Style="margin: 0 88px 12px; font-family: 'Montserrat', sans-serif; font-size: 0.85rem;">
            This page is a work in progress. Full Collection detail view is coming soon.
        </MudAlert>

        @* ── Breadcrumb ── *@
        <div class="collection-detail-breadcrumb-outer">
            <nav class="collection-detail-breadcrumb">
                <button class="collection-detail-bc-link" @onclick="@(() => Nav.NavigateTo("/"))">Home</button>
                <span class="collection-detail-bc-sep">/</span>
                <button class="collection-detail-bc-link" @onclick="@(() => Nav.NavigateTo(GetLane().Route))">@GetLane().Label</button>
                @* ── Parent Collection crumb (franchise level) ── *@
                @if (_parentCollection is not null)
                {
                    <span class="collection-detail-bc-sep">/</span>
                    <button class="collection-detail-bc-link collection-detail-bc-parent"
                            @onclick="@(() => Nav.NavigateTo($"/collection/{_parentCollection.Id}"))">
                        @_parentCollection.DisplayName
                    </button>
                }
                @if (!string.IsNullOrEmpty(_collection.Author))
                {
                    <span class="collection-detail-bc-sep">/</span>
                    @if (_authorPerson is not null)
                    {
                        <button class="collection-detail-bc-link collection-detail-bc-author"
                                @onclick="@(() => Nav.NavigateTo($"/person/{_authorPerson.Id}"))">
                            @_collection.Author
                        </button>
                    }
                    else
                    {
                        <span class="collection-detail-bc-current">@_collection.Author</span>
                    }
                }
            </nav>
        </div>

        @* ── Main 3-column panel ── *@
        <div class="collection-detail-main-outer">
            <div class="collection-detail-main-panel">

                @* ── Left sidebar ── *@
                <aside class="collection-detail-sidebar">

                    @if (!string.IsNullOrEmpty(_collection.Author))
                    {
                        <div class="collection-detail-sidebar-item">
                            <span class="collection-detail-sidebar-label">Author</span>
                            @if (_authorPerson is not null)
                            {
                                <div class="collection-detail-sidebar-author-wrap"
                                     @onclick="@(() => Nav.NavigateTo($"/person/{_authorPerson.Id}"))">
                                    @if (!string.IsNullOrEmpty(_authorPerson.LocalHeadshotUrl))
                                    {
                                        <img src="@_authorPerson.LocalHeadshotUrl" alt="@_authorPerson.Name"
                                             class="collection-detail-sidebar-avatar" />
                                    }
                                    else if (!string.IsNullOrEmpty(_authorPerson.HeadshotUrl))
                                    {
                                        <img src="@_authorPerson.HeadshotUrl" alt="@_authorPerson.Name"
                                             class="collection-detail-sidebar-avatar" />
                                    }
                                    else
                                    {
                                        <div class="collection-detail-sidebar-avatar collection-detail-sidebar-avatar-initials">
                                            @_authorPerson.Initials
                                        </div>
                                    }
                                    <span class="collection-detail-sidebar-author">@_collection.Author</span>
                                </div>
                            }
                            else
                            {
                                <span class="collection-detail-sidebar-value">@_collection.Author</span>
                            }
                        </div>
                    }

                    @{
                        var genres        = GenreTags;
                        var visibleGenres = _showAllGenres ? genres : genres.Take(3).ToList();
                        var hiddenCount   = genres.Count - 3;
                    }
                    @if (genres.Count > 0)
                    {
                        <div class="collection-detail-sidebar-item">
                            <span class="collection-detail-sidebar-label">Genre(s)</span>
                            <div class="collection-detail-genre-row">
                                @foreach (var tag in visibleGenres)
                                {
                                    <span class="collection-detail-genre-chip">@tag</span>
                                }
                                @if (!_showAllGenres && hiddenCount > 0)
                                {
                                    <button class="collection-detail-genre-more"
                                            @onclick="@(() => _showAllGenres = true)">
                                        +@hiddenCount more
                                    </button>
                                }
                                @if (_showAllGenres && genres.Count > 3)
                                {
                                    <button class="collection-detail-genre-more"
                                            @onclick="@(() => _showAllGenres = false)">
                                        Less
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_collection.FictionalUniverseQid))
                    {
                        <div class="collection-detail-sidebar-item">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth
                                       StartIcon="@Icons.Material.Filled.AccountTree"
                                       OnClick="@(() => Nav.NavigateTo($"/universe/{_collection.FictionalUniverseQid}/explore"))">
                                Explore Universe
                            </MudButton>
                        </div>
                    }

                </aside>

                @* ── Shared variables (used in both center column and cover panel) ── *@
                @{
                    var activeCoverUrl = ActiveWork?.CoverUrl ?? _collection.CoverUrl;
                    var coverIsAudio   = ActiveFormatKey == "audiobook";
                    var progressPct    = _activeJourney?.ProgressPct ?? 0;
                    var hasProgress    = progressPct is > 0 and < 99.5;
                    var _fmts          = AvailableFormats();
                    var ratingStars    = GetRatingStars();
                    var hasRating      = !string.IsNullOrEmpty(ratingStars);
                    var hasTime        = _readingTimeDisplay is not null;
                    var hasYear        = !string.IsNullOrEmpty(_collection.Year);
                    var metaCount      = (hasRating ? 1 : 0) + (hasTime ? 1 : 0) + (hasYear ? 1 : 0);
                }

                @* ── Center content (title + format slider + metadata + CTA + description) ── *@
                <div class="collection-detail-content">

                    @* Title — desktop: center column; mobile: cover panel *@
                    <h1 class="collection-detail-title collection-desktop-only">@_collection.DisplayName</h1>

                    @* Format slider — desktop only *@
                    @if (_fmts.Count > 1)
                    {
                        <div class="collection-format-slider collection-desktop-only">
                            @foreach (var fmt in _fmts)
                            {
                                var isSliderActive = ActiveFormatKey == fmt.Key;
                                <button class="collection-format-slider-btn @(isSliderActive ? "active" : "")"
                                        @onclick="@(() => _selectedFormatKey = fmt.Key)">
                                    <span class="collection-format-slider-content">
                                        <MudIcon Icon="@fmt.Icon" Style="font-size: 1rem; flex-shrink:0;" />
                                        @fmt.Label
                                    </span>
                                </button>
                            }
                        </div>
                    }

                    @* Metadata: line 1 = rating + year; line 2 = reading time *@
                    @if (metaCount > 0)
                    {
                        <div class="collection-detail-meta-rows">
                            @if (hasRating || hasYear)
                            {
                                <div class="collection-detail-meta-row">
                                    @if (hasRating)
                                    {
                                        <span class="collection-detail-meta-segment">
                                            <span class="collection-detail-meta-stars">@ratingStars</span>
                                            <span class="collection-detail-meta-rating-val">@_collection.Rating</span>
                                        </span>
                                    }
                                    @if (hasRating && hasYear)
                                    {
                                        <span class="collection-detail-meta-divider">|</span>
                                    }
                                    @if (hasYear)
                                    {
                                        <span class="collection-detail-meta-segment">@_collection.Year</span>
                                    }
                                </div>
                            }
                            @if (hasTime)
                            {
                                <div class="collection-detail-meta-row">
                                    <span class="collection-detail-meta-segment">@_readingTimeDisplay</span>
                                </div>
                            }
                        </div>
                    }

                    @* Genre chips — shown in center column so they're always visible *@
                    @if (GenreTags.Count > 0)
                    {
                        <div class="collection-detail-genre-badges">
                            @foreach (var tag in GenreTags.Take(4))
                            {
                                <span class="collection-detail-center-genre-chip">@tag</span>
                            }
                        </div>
                    }

                    @* Primary CTA — desktop only (above action circles) *@
                    <button class="collection-primary-cta collection-desktop-only" @onclick="@OnPrimaryAction">
                        <div class="collection-primary-cta-inner">
                            <MudIcon Icon="@GetPrimaryActionIcon()"
                                     Style="font-size: 1.2rem; color: #1a1208; flex-shrink:0;" />
                            <span class="collection-primary-cta-label">@PrimaryActionLabel()</span>
                        </div>
                        @if (hasProgress)
                        {
                            <div class="collection-primary-cta-progress"
                                 style="width: @(progressPct.ToString("F0"))%">
                            </div>
                        }
                    </button>

                    @* Secondary action circles — desktop only *@
                    <div class="collection-detail-actions collection-desktop-only">

                        @* Add To *@
                        <button class="collection-detail-action-btn" @onclick="@OnAddTo">
                            <div class="collection-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.PlaylistAdd"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.4rem;" />
                            </div>
                            <span class="collection-detail-action-label">Add To</span>
                        </button>

                        @* Share *@
                        <button class="collection-detail-action-btn" @onclick="@OnShare">
                            <div class="collection-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.IosShare"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.3rem;" />
                            </div>
                            <span class="collection-detail-action-label">Share</span>
                        </button>

                        @* Edit *@
                        <button class="collection-detail-action-btn" @onclick="@(() => _editDrawerOpen = true)">
                            <div class="collection-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.Edit"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.3rem;" />
                            </div>
                            <span class="collection-detail-action-label">Edit</span>
                        </button>

                        @* ⋯ More *@
                        <MudMenu Dense="true"
                                 AnchorOrigin="Origin.BottomLeft"
                                 TransformOrigin="Origin.TopLeft">
                            <ActivatorContent>
                                <button class="collection-detail-action-btn">
                                    <div class="collection-detail-action-circle">
                                        <MudIcon Icon="@Icons.Material.Filled.MoreHoriz"
                                                 Style="color: rgba(248,248,248,0.65); font-size: 1.4rem;" />
                                    </div>
                                    <span class="collection-detail-action-label">More</span>
                                </button>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenuItem OnClick="@OnUpdateMetadata"
                                             Icon="@Icons.Material.Filled.Sync">
                                    Update Metadata
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(async () => await OnMarkFinished())"
                                             Icon="@Icons.Material.Filled.CheckCircle">
                                    Mark as Finished
                                </MudMenuItem>
                                <MudMenuItem OnClick="@OnReportIssue"
                                             Icon="@Icons.Material.Filled.Flag">
                                    Report Issue
                                </MudMenuItem>
                                <MudDivider />
                                <MudMenuItem Disabled="true"
                                             Icon="@Icons.Material.Filled.DeleteForever">
                                    Delete
                                </MudMenuItem>
                            </ChildContent>
                        </MudMenu>

                    </div>

                    @* Narrator line — shown when audiobook format is active *@
                    @if (ActiveFormatKey == "audiobook" && !string.IsNullOrEmpty(ActiveWork?.Narrator))
                    {
                        <div class="collection-detail-narrator-row">
                            <MudIcon Icon="@Icons.Material.Filled.Headphones"
                                     Style="font-size: 0.9rem; color: rgba(201,146,46,0.7); margin-right: 5px;" />
                            <span class="collection-detail-narrator-label">Narrated by</span>
                            <span class="collection-detail-narrator-name">@ActiveWork!.Narrator</span>
                        </div>
                    }

                    @* Description *@
                    @if (!string.IsNullOrEmpty(_collection.Description))
                    {
                        <div class="collection-detail-description-wrap">
                            <p class="collection-detail-description">
                                @(_showFullDescription ? _collection.Description : Truncate(_collection.Description, 400))
                            </p>
                            @if (_collection.Description.Length > 400)
                            {
                                <button class="collection-detail-expand-btn"
                                        @onclick="@(() => _showFullDescription = !_showFullDescription)">
                                    @(_showFullDescription ? "Show less" : "Show more")
                                </button>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_collection.DescriptionSource))
                        {
                            <p class="collection-detail-attribution">
                                @_collection.DescriptionSource
                            </p>
                        }
                    }

                    @* Progress label *@
                    @if (_activeJourney is not null && _activeJourney.ProgressPct is > 0 and < 99.5)
                    {
                        <div class="collection-detail-progress-wrap">
                            <div class="collection-detail-progress-bar-track">
                                <div class="collection-detail-progress-bar-fill"
                                     style="width: @(_activeJourney.ProgressPct.ToString("F0"))%">
                                </div>
                            </div>
                            <span class="collection-detail-progress-label">@_activeJourney.ProgressDisplay</span>
                        </div>
                    }

                </div>

                @* ── Right panel: cover art (desktop); full stack (mobile) ── *@
                <div class="collection-detail-cover-panel">

                    @* Title — mobile only: above cover art *@
                    <h1 class="collection-detail-title collection-mobile-only">@_collection.DisplayName</h1>

                    @* Format slider — mobile only *@
                    @if (_fmts.Count > 1)
                    {
                        <div class="collection-format-slider collection-mobile-only">
                            @foreach (var fmt in _fmts)
                            {
                                var isSliderActive = ActiveFormatKey == fmt.Key;
                                <button class="collection-format-slider-btn @(isSliderActive ? "active" : "")"
                                        @onclick="@(() => _selectedFormatKey = fmt.Key)">
                                    <span class="collection-format-slider-content">
                                        <MudIcon Icon="@fmt.Icon" Style="font-size: 1rem; flex-shrink:0;" />
                                        @fmt.Label
                                    </span>
                                </button>
                            }
                        </div>
                    }

                    @* Cover art (always visible) *@
                    <div class="collection-detail-cover-wrap" @onclick="@(() => _lightboxOpen = !string.IsNullOrEmpty(activeCoverUrl))">
                        @if (!string.IsNullOrEmpty(activeCoverUrl))
                        {
                            <img src="@activeCoverUrl" alt="@_collection.DisplayName"
                                 class="collection-detail-cover @(coverIsAudio ? "collection-detail-cover-audio" : "")" />
                        }
                        else
                        {
                            <div class="collection-detail-cover @(coverIsAudio ? "collection-detail-cover-audio" : "") collection-detail-cover-placeholder">
                                <MudIcon Icon="@GetCollectionIcon()" Style="font-size: 64px; color: rgba(255,255,255,0.18);" />
                            </div>
                        }
                    </div>

                    @* Primary CTA — mobile only *@
                    <button class="collection-primary-cta collection-mobile-only" @onclick="@OnPrimaryAction">
                        <div class="collection-primary-cta-inner">
                            <MudIcon Icon="@GetPrimaryActionIcon()"
                                     Style="font-size: 1.2rem; color: #1a1208; flex-shrink:0;" />
                            <span class="collection-primary-cta-label">@PrimaryActionLabel()</span>
                        </div>
                        @if (hasProgress)
                        {
                            <div class="collection-primary-cta-progress"
                                 style="width: @(progressPct.ToString("F0"))%">
                            </div>
                        }
                    </button>

                    @* Secondary action circles — mobile only *@
                    <div class="collection-detail-actions collection-mobile-only">

                        @* Add To *@
                        <button class="collection-detail-action-btn" @onclick="@OnAddTo">
                            <div class="collection-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.PlaylistAdd"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.4rem;" />
                            </div>
                            <span class="collection-detail-action-label">Add To</span>
                        </button>

                        @* Share *@
                        <button class="collection-detail-action-btn" @onclick="@OnShare">
                            <div class="collection-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.IosShare"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.3rem;" />
                            </div>
                            <span class="collection-detail-action-label">Share</span>
                        </button>

                        @* Edit *@
                        <button class="collection-detail-action-btn" @onclick="@(() => _editDrawerOpen = true)">
                            <div class="collection-detail-action-circle">
                                <MudIcon Icon="@Icons.Material.Filled.Edit"
                                         Style="color: rgba(248,248,248,0.65); font-size: 1.3rem;" />
                            </div>
                            <span class="collection-detail-action-label">Edit</span>
                        </button>

                        @* ⋯ More *@
                        <MudMenu Dense="true"
                                 AnchorOrigin="Origin.BottomLeft"
                                 TransformOrigin="Origin.TopLeft">
                            <ActivatorContent>
                                <button class="collection-detail-action-btn">
                                    <div class="collection-detail-action-circle">
                                        <MudIcon Icon="@Icons.Material.Filled.MoreHoriz"
                                                 Style="color: rgba(248,248,248,0.65); font-size: 1.4rem;" />
                                    </div>
                                    <span class="collection-detail-action-label">More</span>
                                </button>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenuItem OnClick="@OnUpdateMetadata"
                                             Icon="@Icons.Material.Filled.Sync">
                                    Update Metadata
                                </MudMenuItem>
                                <MudMenuItem OnClick="@(async () => await OnMarkFinished())"
                                             Icon="@Icons.Material.Filled.CheckCircle">
                                    Mark as Finished
                                </MudMenuItem>
                                <MudMenuItem OnClick="@OnReportIssue"
                                             Icon="@Icons.Material.Filled.Flag">
                                    Report Issue
                                </MudMenuItem>
                                <MudDivider />
                                <MudMenuItem Disabled="true"
                                             Icon="@Icons.Material.Filled.DeleteForever">
                                    Delete
                                </MudMenuItem>
                            </ChildContent>
                        </MudMenu>

                    </div>

                </div>

            </div>
        </div>

        @* ── Child Collections swimlane (when this Collection is a franchise/Parent Collection) ── *@
        @if (_childCollections.Count > 0)
        {
            <div class="collection-detail-related-section">
                <PosterSwimlane Title="Collections"
                                Items="@_childCollections.Select(PosterItemViewModel.FromCollection).ToList()"
                                OnItemSelected="@(item => Nav.NavigateTo(item.NavigationUrl))" />
            </div>
        }

        @* ── Related content swimlane ── *@
        @if (_related is not null && _related.Collections.Count > 0)
        {
            <div class="collection-detail-related-section">
                <PosterSwimlane Title="@_related.SectionTitle"
                                Items="@_related.Collections.Select(PosterItemViewModel.FromCollection).ToList()"
                                OnItemSelected="@(item => Nav.NavigateTo(item.NavigationUrl))" />
            </div>
        }


    </div>
}

@* ── Cover art lightbox ── *@
@{
    var _lbCoverUrl = _collection is not null ? (ActiveWork?.CoverUrl ?? _collection.CoverUrl) : null;
}
@if (_lightboxOpen && _collection is not null)
{
    <div class="collection-cover-lightbox" @onclick="@(() => _lightboxOpen = false)">
        @if (!string.IsNullOrEmpty(_lbCoverUrl))
        {
            <img src="@_lbCoverUrl" alt="@_collection.DisplayName"
                 class="collection-cover-lightbox-img"
                 @onclick:stopPropagation="true" />
        }
        <button class="collection-cover-lightbox-close" @onclick="@(() => _lightboxOpen = false)">
            <MudIcon Icon="@Icons.Material.Filled.Close" />
        </button>
    </div>
}

@* ── Toast ── *@
@if (_toastMessage is not null)
{
    <div class="collection-detail-toast">@_toastMessage</div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    [SupplyParameterFromQuery] public Guid? LastAssetId { get; set; }

    private bool                    _loading            = true;
    private CollectionViewModel?           _collection;
    private PersonViewModel?        _authorPerson;
    private JourneyItemViewModel?   _activeJourney;
    private RelatedCollectionsViewModel?   _related;
    private CollectionViewModel?           _parentCollection;
    private List<CollectionViewModel>      _childCollections          = [];
    private string?                 _readingTimeDisplay;
    private string?                 _toastMessage;
    private bool                    _showFullDescription;
    private bool                    _showAllGenres;
    private bool                    _editDrawerOpen;
    private bool                    _lightboxOpen;
    private System.Threading.Timer? _toastTimer;
    /// <summary>Currently selected format key ("epub", "audiobook", "video", "comic").
    /// Null means default (primary media type).</summary>
    private string?                 _selectedFormatKey;

    // ── Lifecycle ───────────────────────────────────────────────────────────

    protected override async Task OnParametersSetAsync()
    {
        _loading             = true;
        _showFullDescription = false;
        _showAllGenres       = false;
        _editDrawerOpen      = false;
        _lightboxOpen        = false;
        _selectedFormatKey   = null;
        _parentCollection           = null;
        _childCollections           = [];

        if (!State.IsLoaded)
            await Orchestrator.GetCollectionsAsync();

        _collection = State.Collections.FirstOrDefault(h => h.Id == Id);

        if (_collection is not null)
        {
            var personsTask    = Orchestrator.GetPersonsByCollectionAsync(Id);
            var journeyTask    = Orchestrator.GetJourneyAsync(limit: 50, collectionId: Id);
            var relatedTask    = Orchestrator.GetRelatedCollectionsAsync(Id);
            var childCollectionsTask  = Orchestrator.GetChildCollectionsAsync(Id);
            var parentCollectionTask  = _collection.ParentCollectionId.HasValue
                ? Orchestrator.GetParentCollectionAsync(Id)
                : Task.FromResult<CollectionViewModel?>(null);

            await Task.WhenAll(personsTask, journeyTask, relatedTask, childCollectionsTask, parentCollectionTask);

            var persons = personsTask.Result;
            var journey = journeyTask.Result;
            _related    = relatedTask.Result;
            _childCollections  = childCollectionsTask.Result;
            _parentCollection  = parentCollectionTask.Result;

            _authorPerson = ResolveAuthorPerson(persons, _collection.AuthorQid, _collection.Author);

            // ── Three-tier progress resolution ──────────────────────────────
            //
            // Tier 1: Direct asset ID from the reader (passed via ?lastAssetId=).
            //         Bypasses all JOINs — guaranteed to match what the reader saved.
            //
            // Tier 2: Journey SQL endpoint (INNER JOINs across 4 tables).
            //         Comprehensive but fragile if any link is missing.
            //
            // Tier 3: Resolve-chain fallback (work → asset → progress).
            //         Last resort with diagnostic logging.

            // Tier 1 — direct asset ID from the reader
            if (LastAssetId.HasValue)
            {
                var directProgress = await Orchestrator.GetProgressAsync(LastAssetId.Value);
                if (directProgress is not null && directProgress.ProgressPct > 0)
                {
                    var matchingWork = _collection.Works.FirstOrDefault();
                    _activeJourney = new JourneyItemViewModel
                    {
                        AssetId            = LastAssetId.Value,
                        WorkId             = matchingWork?.Id ?? Guid.Empty,
                        CollectionId              = Id,
                        Title              = matchingWork?.Title ?? _collection.DisplayName,
                        Author             = _collection.Author,
                        CoverUrl           = matchingWork?.CoverUrl ?? _collection.CoverUrl,
                        MediaType          = matchingWork?.MediaType ?? string.Empty,
                        ProgressPct        = directProgress.ProgressPct,
                        LastAccessed       = directProgress.LastAccessed.HasValue
                            ? new DateTimeOffset(directProgress.LastAccessed.Value)
                            : DateTimeOffset.UtcNow,
                        CollectionDisplayName     = _collection.DisplayName,
                        ExtendedProperties = directProgress.ExtendedProperties,
                    };
                }
            }

            // Tier 2 — journey SQL endpoint (collection-filtered)
            if (_activeJourney is null)
            {
                _activeJourney = journey
                    .OrderByDescending(j => j.LastAccessed)
                    .FirstOrDefault();
            }

            // Tier 3 — resolve-chain fallback with diagnostic logging
            if (_activeJourney is null && _collection.Works.Count > 0)
            {
                foreach (var work in _collection.Works)
                {
                    var assetId = await Orchestrator.ResolveWorkToAssetAsync(work.Id);
                    if (!assetId.HasValue)
                    {
                        Console.WriteLine($"[CollectionDetail] Resolve failed: work {work.Id} ({work.Title}) → no asset");
                        continue;
                    }

                    var progress = await Orchestrator.GetProgressAsync(assetId.Value);
                    if (progress is null)
                    {
                        Console.WriteLine($"[CollectionDetail] No progress record for asset {assetId.Value} (work: {work.Title})");
                        continue;
                    }
                    if (progress.ProgressPct <= 0)
                    {
                        Console.WriteLine($"[CollectionDetail] Progress is {progress.ProgressPct}% for asset {assetId.Value} (work: {work.Title})");
                        continue;
                    }

                    _activeJourney = new JourneyItemViewModel
                    {
                        AssetId            = assetId.Value,
                        WorkId             = work.Id,
                        CollectionId              = Id,
                        Title              = work.Title,
                        Author             = _collection.Author,
                        CoverUrl           = work.CoverUrl ?? _collection.CoverUrl,
                        MediaType          = work.MediaType ?? string.Empty,
                        ProgressPct        = progress.ProgressPct,
                        LastAccessed       = progress.LastAccessed.HasValue
                            ? new DateTimeOffset(progress.LastAccessed.Value)
                            : DateTimeOffset.UtcNow,
                        CollectionDisplayName     = _collection.DisplayName,
                        ExtendedProperties = progress.ExtendedProperties,
                    };
                    break;
                }
            }

            _readingTimeDisplay = _collection.Works
                .Select(w => w.ReadingTimeDisplay)
                .FirstOrDefault(s => !string.IsNullOrEmpty(s));
        }

        _loading = false;
    }

    // ── Action handlers ──────────────────────────────────────────────────────

    private async Task OnPrimaryAction()
    {
        if (_collection is null) return;
        var work = ActiveWork ?? _collection.Works.FirstOrDefault();
        if (work is null) { ShowToast("No media asset found"); return; }

        var formatKey = GetFormatKey(work.MediaType);
        if (formatKey is "epub" or "audiobook")
        {
            // Resolve work ID to asset ID, then navigate to EPUB reader
            var assetId = await Orchestrator.ResolveWorkToAssetAsync(work.Id);
            if (assetId.HasValue)
            {
                Nav.NavigateTo($"/read/{assetId.Value}?returnCollectionId={Id}");
            }
            else
            {
                ShowToast("Could not find a readable file for this title");
            }
        }
        else
        {
            ShowToast("Playback for this format is coming soon");
        }
    }

    private void OnAddTo()       => ShowToast("Reading list coming soon");

    private void OnShare()       => ShowToast("Share link copied");

    private async Task OnReportIssue()
    {
        if (_collection is null) return;
        var parameters = new DialogParameters
        {
            { nameof(ReportProblemDialog.EntityId), _collection.Id },
            { nameof(ReportProblemDialog.ItemTitle), _collection.DisplayName }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = false,
            BackdropClick = true
        };
        var dialog = await DialogService.ShowAsync<ReportProblemDialog>("Report a problem", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            ShowToast("Report submitted — thank you");
    }

    private async Task OnMarkFinished()
    {
        if (_collection is null) return;
        var work = _collection.Works.FirstOrDefault();
        if (work is null) { ShowToast("No media asset found"); return; }
        await Orchestrator.SaveProgressAsync(work.Id, null, 100.0);
        ShowToast("Marked as finished \u2713");
    }

    private async Task OnUpdateMetadata()
    {
        var workId = _collection?.Works.FirstOrDefault()?.Id;
        if (workId is null) { ShowToast("No content found to update"); return; }
        ShowToast("Updating metadata\u2026");
        var result = await Orchestrator.TriggerHydrationAsync(workId.Value);
        ShowToast(result is not null
            ? "Metadata updated successfully"
            : "Metadata update failed \u2014 check Engine logs");
    }

    private async Task OnEditApplied()
    {
        // Reload collection data after edit panel applies changes
        _loading = true;
        StateHasChanged();
        State.Invalidate();
        await OnParametersSetAsync();
    }

    private void ShowToast(string message)
    {
        _toastMessage = message;
        _toastTimer?.Dispose();
        _toastTimer = new System.Threading.Timer(_ =>
        {
            _toastMessage = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, System.Threading.Timeout.Infinite);
        StateHasChanged();
    }

