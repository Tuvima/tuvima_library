@page "/"
@inject UIOrchestratorService  Orchestrator
@inject UniverseStateContainer  State
@inject DeviceContextService    DeviceContext
@inject NavigationManager       Nav
@inject IWebHostEnvironment     Env
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

@using MediaEngine.Web.Models.ViewDTOs

<PageTitle>Tuvima Library</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       Style="border-radius: 4px;" />
}
else if (_libraryWorks.Count == 0)
{
    @* ── Empty state ── *@
    <div class="browse-empty-state">
        <img src="/images/tuvima-icon.svg" alt="Tuvima" class="browse-empty-icon" />
        <h2 class="browse-empty-title">@L["Home_EmptyTitle"]</h2>
        <p class="browse-empty-subtitle">@L["Home_EmptySubtitle"]</p>

        @if (Env.IsDevelopment())
        {
            <MudButton Variant="Variant.Filled" Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.AutoStories"
                       Size="MudBlazor.Size.Large"
                       OnClick="HandleSeedLibrary" Disabled="@_seeding"
                       Style="font-family: 'Montserrat', sans-serif; font-weight: 600; text-transform: none; border-radius: 8px;">
                @if (_seeding)
                {
                    <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="mr-2" />
                    <text>@L["Home_Seeding"]</text>
                }
                else
                {
                    <text>@L["Home_SeedLibrary"]</text>
                }
            </MudButton>
        }
    </div>
}
else
{
    <GlobalBackground ImageUrl="@_ambientImage" Color="@_ambientColor" />

    @if (_heroItems.Count > 0)
    {
        <HeroCarousel Items="@_heroItems"
                      OnItemSelected="HandleHeroClick"
                      OnCtaClicked="HandleHeroCta"
                      OnActiveItemChanged="OnHeroChanged" />
    }

    @* Type-specific swimlanes *@
    <div class="home-swimlanes">
        @if (_continueItems.Count > 0)
        {
            <PosterSwimlane Title="Pick Up Where You Left Off"
                            Items="@_continueItems"
                            OnItemSelected="HandleItemSelected" />
        }

        @if (_newBooks.Count > 0)
        {
            <PosterSwimlane Title="New Books"
                            Items="@_newBooks"
                            OnItemSelected="HandleItemSelected"
                            SeeAllRoute="/read" />
        }

        @if (_newMovies.Count > 0)
        {
            <PosterSwimlane Title="New Movies"
                            Items="@_newMovies"
                            OnItemSelected="HandleItemSelected"
                            SeeAllRoute="/watch" />
        }

        @if (_newTV.Count > 0)
        {
            <PosterSwimlane Title="New TV Shows"
                            Items="@_newTV"
                            OnItemSelected="HandleItemSelected"
                            SeeAllRoute="/watch" />
        }

        @if (_newMusic.Count > 0)
        {
            <PosterSwimlane Title="New Music"
                            Items="@_newMusic"
                            OnItemSelected="HandleItemSelected"
                            SeeAllRoute="/listen" />
        }
    </div>
}

@code {
    private bool _loading = true;
    private bool _seeding;

    // ── Data ──────────────────────────────────────────────────────────────
    private List<HubViewModel> _hubs = [];
    private List<WorkViewModel> _libraryWorks = [];
    private List<JourneyItemViewModel> _journeyItems = [];

    // ── Hero ─────────────────────────────────────────────────────────────
    private List<HeroData> _heroItems = [];
    private HeroData? _activeHero;
    private string? _ambientImage;
    private string _ambientColor = "#C9922E";

    // ── Swimlanes ─────────────────────────────────────────────────────────
    private List<PosterItemViewModel> _continueItems = [];
    private List<PosterItemViewModel> _newBooks = [];
    private List<PosterItemViewModel> _newMovies = [];
    private List<PosterItemViewModel> _newMusic = [];
    private List<PosterItemViewModel> _newTV = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _hubs = await Orchestrator.GetHubsAsync();
            _libraryWorks = await Orchestrator.GetLibraryWorksAsync();
            _journeyItems = await Orchestrator.GetJourneyAsync(limit: 10);
            BuildHeroItems();
            BuildSwimlanes();
        }
        catch { /* Engine unreachable — show empty */ }
        finally { _loading = false; }
    }

    private void BuildHeroItems()
    {
        var heroes = new List<HeroData>();

        // Priority: in-progress items
        foreach (var journey in _journeyItems.OrderByDescending(j => j.LastAccessed).Take(3))
        {
            heroes.Add(HeroData.FromJourney(journey));
        }

        // Fill remaining slots with newest items that have cover art
        if (heroes.Count < 3)
        {
            var existingIds = heroes.Select(h => h.EntityId).ToHashSet();
            var newest = _libraryWorks
                .Where(w => !string.IsNullOrEmpty(w.CoverUrl) && !existingIds.Contains(w.Id))
                .OrderByDescending(w => w.Year ?? "0000")
                .Take(3 - heroes.Count);
            foreach (var w in newest)
            {
                heroes.Add(HeroData.FromWork(w, null));
            }
        }

        _heroItems = heroes;
        _activeHero = _heroItems.FirstOrDefault();
        UpdateAmbient();
    }

    private void UpdateAmbient()
    {
        _ambientImage = _activeHero?.CoverUrl;
        _ambientColor = _activeHero?.DominantColor ?? "#C9922E";
    }

    private void OnHeroChanged(HeroData hero)
    {
        _activeHero = hero;
        UpdateAmbient();
        StateHasChanged();
    }

    private void BuildSwimlanes()
    {
        _continueItems = _journeyItems
            .OrderByDescending(j => j.LastAccessed)
            .Take(10)
            .Select(PosterItemViewModel.FromJourney)
            .ToList();

        _newBooks = _libraryWorks
            .Where(w => IsMediaType(w, "book", "epub"))
            .OrderByDescending(w => w.Year ?? "0000")
            .Take(20)
            .Select(w => PosterItemViewModel.FromWork(w))
            .ToList();

        _newMovies = _libraryWorks
            .Where(w => IsMediaType(w, "movie"))
            .OrderByDescending(w => w.Year ?? "0000")
            .Take(20)
            .Select(w => PosterItemViewModel.FromWork(w))
            .ToList();

        _newTV = _libraryWorks
            .Where(w => IsMediaType(w, "tv"))
            .OrderByDescending(w => w.Year ?? "0000")
            .Take(20)
            .Select(w => PosterItemViewModel.FromWork(w))
            .ToList();

        _newMusic = _libraryWorks
            .Where(w => IsMediaType(w, "music"))
            .OrderByDescending(w => w.Year ?? "0000")
            .Take(20)
            .Select(w => PosterItemViewModel.FromWork(w))
            .ToList();
    }

    private static bool IsMediaType(WorkViewModel w, params string[] terms)
    {
        var mt = (w.MediaType ?? "").ToLowerInvariant();
        return terms.Any(t => mt.Contains(t));
    }

    // ── Navigation handlers ──────────────────────────────────────────────

    private void HandleItemSelected(PosterItemViewModel item) =>
        Nav.NavigateTo(item.NavigationUrl);

    private void HandleHeroClick(HeroData hero)
    {
        Nav.NavigateTo($"/book/{hero.EntityId}");
    }

    private void HandleHeroCta(HeroData hero)
    {
        Nav.NavigateTo($"/book/{hero.EntityId}");
    }

    // ── Seed library (dev only) ──────────────────────────────────────────

    private async Task HandleSeedLibrary()
    {
        _seeding = true;
        StateHasChanged();
        await Orchestrator.SeedLibraryAsync();
        _seeding = false;
        await LoadAsync();
        StateHasChanged();
    }

    // ── SignalR live refresh ──────────────────────────────────────────────

    private void OnStateChanged()
    {
        InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }
}

<style>
    .browse-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        gap: 16px;
        text-align: center;
        padding: 2rem;
    }

    .browse-empty-icon {
        width: 80px;
        height: 80px;
        opacity: 0.4;
        margin-bottom: 8px;
    }

    .browse-empty-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: rgba(248, 248, 248, 0.85);
        margin: 0;
    }

    .browse-empty-subtitle {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.95rem;
        font-weight: 400;
        color: rgba(248, 248, 248, 0.50);
        max-width: 420px;
        line-height: 1.5;
        margin: 0;
    }

    .home-swimlanes {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        padding: 0 1.5rem;
        padding-bottom: 5rem;
    }

    @@media (min-width: 768px) {
        .home-swimlanes {
            padding: 0 4rem;
            padding-bottom: 5rem;
        }
    }
</style>
