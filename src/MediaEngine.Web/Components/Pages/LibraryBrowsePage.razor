@page "/"
@inject DiscoveryComposerService Discovery
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer State
@inject IWebHostEnvironment Env
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

<PageTitle>Tuvima Library</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" Style="border-radius: 4px;" />
}
else if (IsEmpty)
{
    <div class="home-discovery-empty">
        <img src="/images/tuvima-icon.svg" alt="Tuvima" class="home-discovery-empty-icon" />
        <h2 class="home-discovery-empty-title">@L["Home_EmptyTitle"]</h2>
        <p class="home-discovery-empty-subtitle">@L["Home_EmptySubtitle"]</p>

        @if (Env.IsDevelopment())
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.AutoStories"
                       Size="MudBlazor.Size.Large"
                       OnClick="HandleSeedLibraryAsync"
                       Disabled="@_seeding"
                       Style="font-family: 'Montserrat', sans-serif; font-weight: 600; text-transform: none; border-radius: 999px;">
                @if (_seeding)
                {
                    <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="mr-2" />
                    <text>@L["Home_Seeding"]</text>
                }
                else
                {
                    <text>@L["Home_SeedLibrary"]</text>
                }
            </MudButton>
        }
    </div>
}
else
{
    <GlobalBackground ImageUrl="@_page.Hero?.BackgroundImageUrl" Color="@_page.AccentColor" />

    <div class="home-discovery-page">
        @if (_page.Hero is not null)
        {
            <DiscoveryHero Hero="@_page.Hero" />
        }

        @if (_page.Hubs.Count > 0)
        {
            <DiscoveryHubStrip Hubs="@_page.Hubs"
                               Title="Library hubs"
                               Subtitle="Collections, franchises, albums, and series assembled automatically from your library." />
        }

        <div class="home-discovery-shelves">
            @foreach (var shelf in _page.Shelves)
            {
                <DiscoveryShelf Shelf="@shelf" />
            }
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _seeding;
    private DiscoveryPageViewModel _page = new() { Key = "home" };

    private bool IsEmpty =>
        _page.Hero is null
        && _page.Hubs.Count == 0
        && _page.Shelves.Count == 0
        && _page.Catalog.Count == 0;

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        try
        {
            _page = await Discovery.BuildHomeAsync();
        }
        catch
        {
            _page = new DiscoveryPageViewModel
            {
                Key = "home",
                EmptyTitle = "Your home screen is waiting for its first story.",
                EmptySubtitle = "Once media lands in the library, home becomes the personalized view across everything you own."
            };
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleSeedLibraryAsync()
    {
        _seeding = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Orchestrator.SeedLibraryAsync();
            await LoadAsync();
        }
        finally
        {
            _seeding = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnStateChanged()
    {
        _ = InvokeAsync(LoadAsync);
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }
}

<style>
    .home-discovery-page {
        display: flex;
        flex-direction: column;
        gap: clamp(28px, 4vw, 42px);
        padding: 0 1.5rem 5rem;
    }

    .home-discovery-shelves {
        display: flex;
        flex-direction: column;
        gap: 36px;
    }

    .home-discovery-empty {
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        padding: 2rem;
        text-align: center;
    }

    .home-discovery-empty-icon {
        width: 80px;
        height: 80px;
        opacity: 0.4;
    }

    .home-discovery-empty-title {
        margin: 0;
        font-family: 'Montserrat', sans-serif;
        font-size: 1.7rem;
        font-weight: 700;
        color: rgba(248, 248, 248, 0.88);
    }

    .home-discovery-empty-subtitle {
        margin: 0;
        max-width: 460px;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.96rem;
        line-height: 1.6;
        color: rgba(248, 248, 248, 0.56);
    }

    @@media (min-width: 768px) {
        .home-discovery-page {
            padding: 0 4rem 5rem;
        }
    }
</style>
