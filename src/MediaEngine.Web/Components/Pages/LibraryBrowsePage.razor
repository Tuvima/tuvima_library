@page "/"
@inject MediaTileComposerService MediaTiles
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient
@inject UniverseStateContainer State
@inject IWebHostEnvironment Env
@inject IStringLocalizer<SharedStrings> L
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Tuvima Library</PageTitle>

@if (_loading && _hasLoadedOnce)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="home-discovery-loading mb-4" Rounded="false" />
}

@if (_loading && !_hasLoadedOnce)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="home-discovery-loading mb-4" Rounded="false" />
}
else if (IsEmpty)
{
    <div class="home-discovery-empty">
        <img src="/images/tuvima-icon.svg" alt="Tuvima" class="home-discovery-empty-icon" />
        <h2 class="home-discovery-empty-title">Set up your first library</h2>
        <p class="home-discovery-empty-subtitle">
            Tuvima needs a Library Root, a Watch Folder, and a scan before Home can show your media.
        </p>

        <div class="home-discovery-empty-actions">
            <AppButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       Size="MudBlazor.Size.Large"
                       StartIcon="@Icons.Material.Outlined.FolderOpen"
                       Href="/settings/libraries">
                Configure folders
            </AppButton>
            @if (_canScan)
            {
                <AppButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="MudBlazor.Size.Large"
                           StartIcon="@Icons.Material.Outlined.PlayArrow"
                           Disabled="@_scanStarting"
                           OnClick="HandleScanNowAsync">
                    @if (_scanStarting)
                    {
                        <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="mr-2" />
                        <text>Starting scan...</text>
                    }
                    else
                    {
                        <text>Scan now</text>
                    }
                </AppButton>
            }
            <AppButton Variant="Variant.Text"
                       Color="Color.Default"
                       Size="MudBlazor.Size.Large"
                       StartIcon="@Icons.Material.Outlined.PendingActions"
                       Href="/settings/ingestion">
                Open Ingestion
            </AppButton>
        </div>

        @if (Env.IsDevelopment())
        {
            <div class="home-discovery-dev-tools">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Development tools</MudText>
                <AppButton Variant="Variant.Outlined"
                           Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.AutoStories"
                           Size="MudBlazor.Size.Medium"
                           OnClick="HandleSeedLibraryAsync"
                           Disabled="@_seeding"
                           Class="home-discovery-seed-button">
                    @if (_seeding)
                    {
                        <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="mr-2" />
                        <text>@L["Home_Seeding"]</text>
                    }
                    else
                    {
                        <text>@L["Home_SeedLibrary"]</text>
                    }
                </AppButton>
            </div>
        }
    </div>
}
else
{
    <GlobalBackground Color="#05070C" />

    <div class="home-discovery-page @(_page.Hero is not null ? "home-discovery-page--with-hero" : null)">
        @if (_page.Hero is not null)
        {
            <DiscoveryHero Hero="@_page.Hero" />
        }

        <div class="home-discovery-content-shell">
            @if (_page.Hubs.Count > 0)
            {
                <DiscoveryHubStrip Hubs="@_page.Hubs"
                                   Title="Library hubs"
                                   Subtitle="Collections, franchises, albums, and series assembled automatically from your library." />
            }

            <div class="home-discovery-shelves">
                @foreach (var shelf in _page.Shelves)
                {
                    <MediaTileShelf Shelf="@shelf" />
                }
            </div>
        </div>
    </div>
}

@code {
    private static readonly TimeSpan StateReloadDebounce = TimeSpan.FromMilliseconds(750);

    private CancellationTokenSource? _stateReloadCts;
    private bool _loading = true;
    private bool _hasLoadedOnce;
    private bool _loadInProgress;
    private bool _loadAgainRequested;
    private bool _disposed;
    private bool _seeding;
    private bool _scanStarting;
    private bool _canScan;
    private DiscoveryPageViewModel _page = new() { Key = "home" };

    private bool IsEmpty =>
        _page.Hero is null
        && _page.Hubs.Count == 0
        && _page.Shelves.Count == 0
        && _page.Catalog.Count == 0;

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        State.MediaAddedReceived += OnMediaAdded;
        await Orchestrator.StartSignalRAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (_loadInProgress)
        {
            _loadAgainRequested = true;
            return;
        }

        _loadInProgress = true;
        try
        {
            do
            {
                _loadAgainRequested = false;
                _loading = true;
                await InvokeAsync(StateHasChanged);

                try
                {
                    _page = await MediaTiles.BuildHomeAsync();
                    if (IsEmpty)
                    {
                        _canScan = await CanStartScanAsync();
                    }
                    else
                    {
                        _canScan = false;
                    }
                }
                catch
                {
                    if (!_hasLoadedOnce)
                    {
                        _page = new DiscoveryPageViewModel
                        {
                            Key = "home",
                            EmptyTitle = "Your home screen is waiting for its first story.",
                            EmptySubtitle = "Once media lands in the library, home becomes the personalized view across everything you own."
                        };
                    }

                    _canScan = await CanStartScanAsync();
                }
                finally
                {
                    _loading = false;
                    _hasLoadedOnce = true;
                    await InvokeAsync(StateHasChanged);
                }
            }
            while (_loadAgainRequested && !_disposed);
        }
        finally
        {
            _loadInProgress = false;
        }
    }

    private async Task HandleScanNowAsync()
    {
        _scanStarting = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var started = await Orchestrator.TriggerRescanAsync();
            if (started)
            {
                Snackbar.Add("Scan started. Open Ingestion to watch progress.", Severity.Success);
                _canScan = false;
            }
            else
            {
                Snackbar.Add(Orchestrator.LastApiError ?? "Scan could not be started.", Severity.Error);
            }
        }
        finally
        {
            _scanStarting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<bool> CanStartScanAsync()
    {
        try
        {
            var status = await Orchestrator.GetSystemStatusAsync();
            if (status?.IsHealthy != true)
            {
                return false;
            }

            var folders = await Orchestrator.GetFolderSettingsAsync();
            var importFolders = folders?.EffectiveWatchDirectories ?? [];
            if (importFolders.Count == 0)
                return false;

            foreach (var importFolder in importFolders)
            {
                if (!await IsReadyFolderAsync(importFolder))
                    return false;
            }

            var operations = await ApiClient.GetIngestionOperationsSnapshotAsync();
            return (operations?.ActiveJobs.Count ?? 0) == 0;
        }
        catch
        {
            // Empty-state scan eligibility is best-effort; Libraries and Ingestion remain visible when the Engine cannot answer.
            return false;
        }
    }

    private async Task<bool> IsReadyFolderAsync(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return false;
        }

        var result = await Orchestrator.TestPathAsync(path);
        return result is { Exists: true, HasRead: true, HasWrite: true };
    }

    private async Task HandleSeedLibraryAsync()
    {
        _seeding = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Orchestrator.SeedLibraryAsync();
            await LoadAsync();
        }
        finally
        {
            _seeding = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnStateChanged()
    {
        if (_disposed)
            return;

        if (State.IsLoaded && !State.LastStateChangeRequiresSnapshotRefresh)
            return;

        DebounceStateReload();
    }

    private void OnMediaAdded(MediaAddedEvent ev)
    {
        if (_disposed)
            return;

        _ = InvokeAsync(() =>
        {
            Snackbar.Add($"Added to library: {ev.Title}", Severity.Success);
            return Task.CompletedTask;
        });
    }

    private void DebounceStateReload()
    {
        _stateReloadCts?.Cancel();
        _stateReloadCts?.Dispose();
        _stateReloadCts = new CancellationTokenSource();
        var token = _stateReloadCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(StateReloadDebounce, token);
                await InvokeAsync(LoadAsync);
            }
            catch (OperationCanceledException)
            {
            }
        }, CancellationToken.None);
    }

    public void Dispose()
    {
        _disposed = true;
        State.OnStateChanged -= OnStateChanged;
        State.MediaAddedReceived -= OnMediaAdded;
        _stateReloadCts?.Cancel();
        _stateReloadCts?.Dispose();
    }
}
