@page "/"
@inject DiscoveryComposerService Discovery
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer State
@inject IWebHostEnvironment Env
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

<PageTitle>Tuvima Library</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="home-discovery-loading mb-4" Rounded="false" />
}
else if (IsEmpty)
{
    <div class="home-discovery-empty">
        <img src="/images/tuvima-icon.svg" alt="Tuvima" class="home-discovery-empty-icon" />
        <h2 class="home-discovery-empty-title">@L["Home_EmptyTitle"]</h2>
        <p class="home-discovery-empty-subtitle">@L["Home_EmptySubtitle"]</p>

        @if (Env.IsDevelopment())
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.AutoStories"
                       Size="MudBlazor.Size.Large"
                       OnClick="HandleSeedLibraryAsync"
                       Disabled="@_seeding"
                       Class="home-discovery-seed-button">
                @if (_seeding)
                {
                    <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="mr-2" />
                    <text>@L["Home_Seeding"]</text>
                }
                else
                {
                    <text>@L["Home_SeedLibrary"]</text>
                }
            </MudButton>
        }
    </div>
}
else
{
    <GlobalBackground Color="#05070C" />

    <div class="home-discovery-page @(_page.Hero is not null ? "home-discovery-page--with-hero" : null)">
        @if (_page.Hero is not null)
        {
            <DiscoveryHero Hero="@_page.Hero" />
        }

        <div class="home-discovery-content-shell">
            @if (_page.Hubs.Count > 0)
            {
                <DiscoveryHubStrip Hubs="@_page.Hubs"
                                   Title="Library hubs"
                                   Subtitle="Collections, franchises, albums, and series assembled automatically from your library." />
            }

            <div class="home-discovery-shelves">
                @foreach (var shelf in _page.Shelves)
                {
                    <DiscoveryShelf Shelf="@shelf" />
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _seeding;
    private DiscoveryPageViewModel _page = new() { Key = "home" };

    private bool IsEmpty =>
        _page.Hero is null
        && _page.Hubs.Count == 0
        && _page.Shelves.Count == 0
        && _page.Catalog.Count == 0;

    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += OnStateChanged;
        await Orchestrator.StartSignalRAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        try
        {
            _page = await Discovery.BuildHomeAsync();
        }
        catch
        {
            _page = new DiscoveryPageViewModel
            {
                Key = "home",
                EmptyTitle = "Your home screen is waiting for its first story.",
                EmptySubtitle = "Once media lands in the library, home becomes the personalized view across everything you own."
            };
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleSeedLibraryAsync()
    {
        _seeding = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Orchestrator.SeedLibraryAsync();
            await LoadAsync();
        }
        finally
        {
            _seeding = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnStateChanged()
    {
        _ = InvokeAsync(LoadAsync);
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }
}
