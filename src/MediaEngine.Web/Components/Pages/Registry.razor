@page "/registry"
@inject UIOrchestratorService Orchestrator
@inject DeviceContextService DeviceContext
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Registry — Tuvima Library</PageTitle>

<div class="registry-page">
    @* ── Page Header ── *@
    <div class="registry-header">
        <div class="registry-header-left">
            <MudIcon Icon="@Icons.Material.Outlined.FactCheck" Size="Size.Large"
                     Style="color: var(--mud-palette-primary);" />
            <div>
                <h1 class="registry-title">Registry</h1>
                <p class="registry-subtitle">Manage newly acquired media and review matches</p>
            </div>
        </div>
    </div>

    @* ── Status Tabs ── *@
    <div class="registry-tabs">
        <button class="registry-tab @(_statusFilter == null ? "registry-tab-active" : "")"
                @onclick="@(() => SetStatusFilter(null))">
            All
            @if (_counts is not null)
            {
                <span class="registry-tab-count">@_counts.Total</span>
            }
        </button>
        <button class="registry-tab @(_statusFilter == "Review" ? "registry-tab-active" : "")"
                @onclick="@(() => SetStatusFilter("Review"))">
            Needs Review
            @if (_counts is not null && _counts.NeedsReview > 0)
            {
                <span class="registry-tab-count registry-tab-count-warn">@_counts.NeedsReview</span>
            }
        </button>
        <button class="registry-tab @(_statusFilter == "Auto" ? "registry-tab-active" : "")"
                @onclick="@(() => SetStatusFilter("Auto"))">
            Auto-Approved
            @if (_counts is not null)
            {
                <span class="registry-tab-count">@_counts.AutoApproved</span>
            }
        </button>
        <button class="registry-tab @(_statusFilter == "Edited" ? "registry-tab-active" : "")"
                @onclick="@(() => SetStatusFilter("Edited"))">
            Edited
            @if (_counts is not null && _counts.Edited > 0)
            {
                <span class="registry-tab-count">@_counts.Edited</span>
            }
        </button>
    </div>

    @* ── Filter Bar ── *@
    <div class="registry-filters">
        <MudTextField @bind-Value="_searchText" Placeholder="Search titles, authors, ISBN, ID..."
                      Variant="Variant.Outlined" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="400"
                      OnDebounceIntervalElapsed="OnSearchChanged"
                      Class="registry-search-field"
                      Style="max-width: 400px;" />

        <MudSelect T="string" Value="@_typeFilter" Label="Type" Variant="Variant.Outlined"
                   Dense="true" Style="max-width: 140px;" AnchorOrigin="Origin.BottomCenter"
                   ValueChanged="@OnTypeFilterChanged">
            <MudSelectItem T="string" Value="@((string?)null)">All</MudSelectItem>
            <MudSelectItem T="string" Value="@("Epub")">Books</MudSelectItem>
            <MudSelectItem T="string" Value="@("Audiobook")">Audiobooks</MudSelectItem>
            <MudSelectItem T="string" Value="@("Movies")">Movies</MudSelectItem>
            <MudSelectItem T="string" Value="@("TV")">TV</MudSelectItem>
            <MudSelectItem T="string" Value="@("Music")">Music</MudSelectItem>
            <MudSelectItem T="string" Value="@("Comics")">Comics</MudSelectItem>
            <MudSelectItem T="string" Value="@("Podcasts")">Podcasts</MudSelectItem>
        </MudSelect>

        <div class="registry-confidence-filter">
            <span class="registry-filter-label">Confidence</span>
            <MudSlider T="double" Value="@_minConfidence"
                       Min="0" Max="100" Step="5"
                       Color="Color.Warning"
                       Style="width: 120px;"
                       ValueChanged="@OnConfidenceChanged" />
            <span class="registry-confidence-value">@(_minConfidence)%</span>
        </div>

        <MudSwitch T="bool" Value="@_duplicatesOnly" Label="Duplicates only"
                   Color="Color.Warning" Class="ml-2"
                   ValueChanged="@OnDuplicatesToggled" />

        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                   OnClick="ResetFilters" Class="ml-auto">
            Reset
        </MudButton>
    </div>

    @* ── Review Alert Banner ── *@
    @if (_counts is not null && _counts.NeedsReview > 0 && _statusFilter != "Review")
    {
        <div class="registry-alert-banner">
            <MudIcon Icon="@Icons.Material.Outlined.Warning" Size="Size.Small"
                     Style="color: #EAB308;" />
            <span>
                <strong style="color: #EAB308;">@_counts.NeedsReview</strong>
                matches require review &lt; 95% confidence
            </span>
        </div>
    }

    @* ── Bulk Action Bar ── *@
    @if (_selectedIds.Count > 0)
    {
        <div class="registry-bulk-bar">
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                @_selectedIds.Count selected
            </MudChip>
            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Check" OnClick="BulkApprove"
                       Disabled="@_bulkProcessing">
                Approve
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Edit" OnClick="BulkEditMatch"
                       Disabled="@_bulkProcessing">
                Edit matches
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Delete" OnClick="BulkRemove"
                       Disabled="@_bulkProcessing">
                Remove
            </MudButton>
        </div>
    }

    @* ── Loading State ── *@
    @if (_loading && _items.Count == 0)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                           Style="border-radius: 4px;" />
    }

    @* ── Item List ── *@
    <div class="registry-list">
        @* ── Column Headers ── *@
        <div class="registry-row registry-row-header">
            <div class="registry-col-check">
                <MudCheckBox T="bool" Value="@_allSelected" Dense="true"
                             ValueChanged="ToggleSelectAll" Size="Size.Small" />
            </div>
            <div class="registry-col-title">
                <span class="registry-header-text">@_items.Count items</span>
            </div>
            <div class="registry-col-type">TYPE</div>
            <div class="registry-col-match">MATCH</div>
            <div class="registry-col-confidence">CONFIDENCE</div>
            <div class="registry-col-status">STATUS</div>
            <div class="registry-col-expand"></div>
        </div>

        @foreach (var item in _items)
        {
            var isExpanded = _expandedEntityId == item.EntityId;
            var isSelected = _selectedIds.Contains(item.EntityId);

            @* ── Item Row ── *@
            <div class="registry-row @(isExpanded ? "registry-row-expanded" : "") @(isSelected ? "registry-row-selected" : "")"
                 @onclick="@(() => ToggleExpand(item.EntityId))">
                <div class="registry-col-check" @onclick:stopPropagation="true">
                    <MudCheckBox T="bool" Value="@isSelected" Dense="true"
                                 ValueChanged="@((bool v) => ToggleSelect(item.EntityId, v))"
                                 Size="Size.Small" />
                </div>
                <div class="registry-col-title">
                    <div class="registry-item-info">
                        @if (!string.IsNullOrEmpty(item.CoverUrl))
                        {
                            <img src="@item.CoverUrl" alt="" class="registry-cover-thumb" loading="lazy" />
                        }
                        else
                        {
                            <div class="registry-cover-placeholder">
                                <MudIcon Icon="@GetMediaTypeIcon(item.MediaType)" Size="Size.Small"
                                         Style="opacity: 0.4;" />
                            </div>
                        }
                        <div class="registry-item-text">
                            <span class="registry-item-title">@item.Title</span>
                            <span class="registry-item-meta">
                                @if (!string.IsNullOrEmpty(item.Year))
                                {
                                    @item.Year
                                }
                                @if (!string.IsNullOrEmpty(item.Author))
                                {
                                    <text> · @item.Author</text>
                                }
                            </span>
                        </div>
                    </div>
                </div>
                <div class="registry-col-type">
                    <MudIcon Icon="@GetMediaTypeIcon(item.MediaType)" Size="Size.Small"
                             Style="opacity: 0.6;" />
                    <span class="registry-type-label">@FormatMediaType(item.MediaType)</span>
                </div>
                <div class="registry-col-match">
                    @if (!string.IsNullOrEmpty(item.MatchSource))
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                 Style="@GetMatchBadgeStyle(item.MatchSource)">
                            @FormatMatchSource(item.MatchSource)
                        </MudChip>
                    }
                </div>
                <div class="registry-col-confidence">
                    <div class="registry-confidence-bar-container">
                        <MudProgressLinear Value="@(item.Confidence * 100)" Max="100"
                                           Color="@GetConfidenceColor(item.Confidence)"
                                           Rounded="true" Size="Size.Small"
                                           Style="width: 80px; height: 6px;" />
                        <span class="registry-confidence-text"
                              style="color: @GetConfidenceHexColor(item.Confidence);">
                            @((int)(item.Confidence * 100))%
                        </span>
                    </div>
                </div>
                <div class="registry-col-status">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                             Style="@GetStatusChipStyle(item.Status)">
                        @if (item.Status == "Duplicate")
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Warning" Size="Size.Small"
                                     Class="mr-1" />
                        }
                        @item.Status
                    </MudChip>
                </div>
                <div class="registry-col-expand">
                    <MudIconButton Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   Size="Size.Small" />
                </div>
            </div>

            @* ── Expanded Detail Panel ── *@
            @if (isExpanded)
            {
                <div class="registry-detail-panel">
                    @if (_loadingDetail)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary"
                                           Style="border-radius: 4px;" />
                    }
                    else if (_expandedDetail is not null)
                    {
                        <div class="registry-detail-columns">
                            @* ── Left: Cover + Match Info ── *@
                            <div class="registry-detail-left">
                                @if (!string.IsNullOrEmpty(_expandedDetail.CoverUrl))
                                {
                                    <img src="@_expandedDetail.CoverUrl" alt=""
                                         class="registry-detail-cover" />
                                }
                                else
                                {
                                    <div class="registry-detail-cover-placeholder">
                                        <MudIcon Icon="@GetMediaTypeIcon(_expandedDetail.MediaType)"
                                                 Size="Size.Large" Style="opacity: 0.3;" />
                                    </div>
                                }
                                <div class="registry-match-info">
                                    @if (!string.IsNullOrEmpty(_expandedDetail.MatchSource))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                                 Style="@GetMatchBadgeStyle(_expandedDetail.MatchSource)">
                                            @FormatMatchSource(_expandedDetail.MatchSource)
                                        </MudChip>
                                    }
                                    <span class="registry-match-confidence"
                                          style="color: @GetConfidenceHexColor(_expandedDetail.Confidence);">
                                        @((int)(_expandedDetail.Confidence * 100))%
                                        <span class="registry-match-label">@GetConfidenceLabel(_expandedDetail.Confidence)</span>
                                    </span>
                                </div>
                            </div>

                            @* ── Center: Metadata ── *@
                            <div class="registry-detail-center">
                                <h3 class="registry-detail-section-title">Metadata</h3>
                                @if (!string.IsNullOrEmpty(_expandedDetail.Author))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Author:</span>
                                        <span class="registry-field-value">@_expandedDetail.Author</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_expandedDetail.Director))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Director:</span>
                                        <span class="registry-field-value">@_expandedDetail.Director</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_expandedDetail.Cast))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Cast:</span>
                                        <span class="registry-field-value">@_expandedDetail.Cast</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_expandedDetail.Narrator))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Narrator:</span>
                                        <span class="registry-field-value">@_expandedDetail.Narrator</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_expandedDetail.Language))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Language:</span>
                                        <span class="registry-field-value">@_expandedDetail.Language</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_expandedDetail.Year))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Release:</span>
                                        <span class="registry-field-value">@_expandedDetail.Year</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_expandedDetail.Runtime))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Runtime:</span>
                                        <span class="registry-field-value">@_expandedDetail.Runtime</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_expandedDetail.Genre))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Genre:</span>
                                        <span class="registry-field-value">@_expandedDetail.Genre</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_expandedDetail.Series))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Series:</span>
                                        <span class="registry-field-value">
                                            @_expandedDetail.Series
                                            @if (!string.IsNullOrEmpty(_expandedDetail.SeriesPosition))
                                            {
                                                <text> #@_expandedDetail.SeriesPosition</text>
                                            }
                                        </span>
                                    </div>
                                }
                            </div>

                            @* ── Right: Actions + Possible Matches ── *@
                            <div class="registry-detail-right">
                                <h3 class="registry-detail-section-title">Actions</h3>
                                <div class="registry-detail-actions">
                                    @if (item.ReviewItemId.HasValue)
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Success"
                                                   StartIcon="@Icons.Material.Filled.Check"
                                                   OnClick="@(() => ApproveMatch(item))"
                                                   FullWidth="true" Size="Size.Small">
                                            Approve Match
                                        </MudButton>
                                    }
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.Edit"
                                               OnClick="@(() => EditMatch(item))"
                                               FullWidth="true" Size="Size.Small">
                                        Edit Match
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                               StartIcon="@Icons.Material.Filled.Delete"
                                               OnClick="@(() => RemoveItem(item))"
                                               FullWidth="true" Size="Size.Small">
                                        Remove
                                    </MudButton>
                                </div>

                                @if (!string.IsNullOrEmpty(_expandedDetail.CandidatesJson))
                                {
                                    <h3 class="registry-detail-section-title mt-4">Possible Matches</h3>
                                    <p class="registry-detail-hint">
                                        Alternative matches found during identification
                                    </p>
                                }
                            </div>
                        </div>

                        @* ── Original Input Section ── *@
                        <div class="registry-original-input">
                            <h3 class="registry-detail-section-title">Original Input</h3>
                            <div class="registry-original-fields">
                                @if (!string.IsNullOrEmpty(_expandedDetail.FileName))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Filename:</span>
                                        <span class="registry-field-value registry-filename">@_expandedDetail.FileName</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_expandedDetail.FilePath))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Path:</span>
                                        <span class="registry-field-value registry-filename">@_expandedDetail.FilePath</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_expandedDetail.ContentHash))
                                {
                                    <div class="registry-detail-field">
                                        <span class="registry-field-label">Content Hash:</span>
                                        <span class="registry-field-value registry-filename">@(_expandedDetail.ContentHash[..Math.Min(16, _expandedDetail.ContentHash.Length)])...</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }

        @* ── Infinite Scroll Sentinel ── *@
        @if (_hasMore)
        {
            <div class="registry-sentinel">
                @if (_loadingMore)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                    <span class="registry-loading-text">Loading more...</span>
                }
            </div>
        }

        @* ── Footer Count ── *@
        <div class="registry-footer">
            <span class="registry-footer-text">
                Showing @_items.Count of @_totalCount
            </span>
        </div>
    </div>
</div>

@code {
    // ── State ──────────────────────────────────────────────────────────────
    private List<RegistryItemViewModel> _items = [];
    private HashSet<Guid> _selectedIds = [];
    private Guid? _expandedEntityId;
    private RegistryItemDetailViewModel? _expandedDetail;
    private RegistryStatusCountsDto? _counts;

    private bool _loading;
    private bool _loadingMore;
    private bool _loadingDetail;
    private bool _bulkProcessing;
    private int _totalCount;
    private bool _hasMore;
    private bool _allSelected;

    // Filters
    private string? _searchText;
    private string? _typeFilter;
    private string? _statusFilter;
    private double _minConfidence;
    private bool _duplicatesOnly;

    // Scroll observer
    private DotNetObjectReference<Registry>? _selfRef;

    // ── Lifecycle ──────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        await LoadItemsAsync(reset: true);
        await LoadCountsAsync();
        _loading = false;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
        }
        return Task.CompletedTask;
    }

    // ── Data Loading ───────────────────────────────────────────────────────

    private async Task LoadItemsAsync(bool reset = false)
    {
        if (reset)
        {
            _items.Clear();
            _selectedIds.Clear();
            _expandedEntityId = null;
            _expandedDetail = null;
        }

        var offset = reset ? 0 : _items.Count;
        var result = await Orchestrator.GetRegistryItemsAsync(
            offset: offset,
            limit: 50,
            search: _searchText,
            type: _typeFilter,
            status: _statusFilter,
            minConfidence: _minConfidence > 0 ? _minConfidence / 100.0 : null,
            matchSource: null,
            duplicatesOnly: _duplicatesOnly);

        if (result is not null)
        {
            _items.AddRange(result.Items);
            _totalCount = result.TotalCount;
            _hasMore = result.HasMore;
        }
    }

    private async Task LoadCountsAsync()
    {
        _counts = await Orchestrator.GetRegistryStatusCountsAsync();
    }

    private async Task LoadMoreAsync()
    {
        if (_loadingMore || !_hasMore) return;
        _loadingMore = true;
        StateHasChanged();

        await LoadItemsAsync(reset: false);

        _loadingMore = false;
        StateHasChanged();
    }

    // ── JS Interop for Infinite Scroll ─────────────────────────────────────

    [JSInvokable]
    public async Task OnScrollSentinelVisible()
    {
        await LoadMoreAsync();
    }

    // ── Filters ────────────────────────────────────────────────────────────

    private async Task SetStatusFilter(string? status)
    {
        _statusFilter = status;
        _loading = true;
        StateHasChanged();
        await LoadItemsAsync(reset: true);
        _loading = false;
        StateHasChanged();
    }

    private async Task OnSearchChanged()
    {
        await OnFilterChanged();
    }

    private async Task OnTypeFilterChanged(string? value)
    {
        _typeFilter = value;
        await OnFilterChanged();
    }

    private async Task OnConfidenceChanged(double value)
    {
        _minConfidence = value;
        await OnFilterChanged();
    }

    private async Task OnDuplicatesToggled(bool value)
    {
        _duplicatesOnly = value;
        await OnFilterChanged();
    }

    private async Task OnFilterChanged()
    {
        _loading = true;
        StateHasChanged();
        await LoadItemsAsync(reset: true);
        _loading = false;
        StateHasChanged();
    }

    private async Task ResetFilters()
    {
        _searchText = null;
        _typeFilter = null;
        _statusFilter = null;
        _minConfidence = 0;
        _duplicatesOnly = false;
        await OnFilterChanged();
    }

    // ── Selection ──────────────────────────────────────────────────────────

    private void ToggleSelect(Guid entityId, bool selected)
    {
        if (selected)
            _selectedIds.Add(entityId);
        else
            _selectedIds.Remove(entityId);
        _allSelected = _selectedIds.Count == _items.Count && _items.Count > 0;
    }

    private void ToggleSelectAll(bool selectAll)
    {
        _allSelected = selectAll;
        if (selectAll)
            _selectedIds = new HashSet<Guid>(_items.Select(i => i.EntityId));
        else
            _selectedIds.Clear();
    }

    // ── Expand/Collapse ────────────────────────────────────────────────────

    private async Task ToggleExpand(Guid entityId)
    {
        if (_expandedEntityId == entityId)
        {
            _expandedEntityId = null;
            _expandedDetail = null;
            return;
        }

        _expandedEntityId = entityId;
        _loadingDetail = true;
        StateHasChanged();

        _expandedDetail = await Orchestrator.GetRegistryItemDetailAsync(entityId);

        _loadingDetail = false;
        StateHasChanged();
    }

    // ── Actions ────────────────────────────────────────────────────────────

    private async Task ApproveMatch(RegistryItemViewModel item)
    {
        if (!item.ReviewItemId.HasValue) return;
        var request = new ReviewResolveRequestDto();
        var ok = await Orchestrator.ResolveReviewAsync(item.ReviewItemId.Value, request);
        if (ok)
        {
            item.Status = "Auto";
            item.ReviewItemId = null;
            _expandedEntityId = null;
            _expandedDetail = null;
            await LoadCountsAsync();
            StateHasChanged();
        }
    }

    private Task EditMatch(RegistryItemViewModel item)
    {
        // Navigate to settings for editing (future: inline edit dialog)
        return Task.CompletedTask;
    }

    private async Task RemoveItem(RegistryItemViewModel item)
    {
        if (item.ReviewItemId.HasValue)
        {
            await Orchestrator.DismissReviewAsync(item.ReviewItemId.Value);
        }
        _items.Remove(item);
        _selectedIds.Remove(item.EntityId);
        _expandedEntityId = null;
        _expandedDetail = null;
        _totalCount = Math.Max(0, _totalCount - 1);
        await LoadCountsAsync();
        StateHasChanged();
    }

    private async Task BulkApprove()
    {
        _bulkProcessing = true;
        StateHasChanged();

        foreach (var id in _selectedIds.ToList())
        {
            var item = _items.FirstOrDefault(i => i.EntityId == id);
            if (item?.ReviewItemId is not null)
            {
                var ok = await Orchestrator.ResolveReviewAsync(item.ReviewItemId.Value, new ReviewResolveRequestDto());
                if (ok)
                {
                    item.Status = "Auto";
                    item.ReviewItemId = null;
                }
            }
        }

        _selectedIds.Clear();
        _allSelected = false;
        _bulkProcessing = false;
        await LoadCountsAsync();
        StateHasChanged();
    }

    private Task BulkEditMatch()
    {
        // Future: open bulk edit dialog
        return Task.CompletedTask;
    }

    private async Task BulkRemove()
    {
        _bulkProcessing = true;
        StateHasChanged();

        var countToRemove = _selectedIds.Count;
        foreach (var id in _selectedIds.ToList())
        {
            var item = _items.FirstOrDefault(i => i.EntityId == id);
            if (item?.ReviewItemId is not null)
            {
                await Orchestrator.DismissReviewAsync(item.ReviewItemId.Value);
            }
            if (item is not null)
                _items.Remove(item);
        }

        _totalCount = Math.Max(0, _totalCount - countToRemove);
        _selectedIds.Clear();
        _allSelected = false;
        _bulkProcessing = false;
        await LoadCountsAsync();
        StateHasChanged();
    }

    // ── Helper Methods ─────────────────────────────────────────────────────

    private static string GetMediaTypeIcon(string? mediaType) => mediaType?.ToUpperInvariant() switch
    {
        "EPUB" or "BOOK" or "BOOKS" => Icons.Material.Outlined.MenuBook,
        "AUDIOBOOK" or "AUDIOBOOKS" => Icons.Material.Outlined.Headphones,
        "MOVIES" or "MOVIE" => Icons.Material.Outlined.Movie,
        "TV" => Icons.Material.Outlined.Tv,
        "MUSIC" => Icons.Material.Outlined.MusicNote,
        "COMICS" or "COMIC" => Icons.Material.Outlined.AutoStories,
        "PODCASTS" or "PODCAST" => Icons.Material.Outlined.Podcasts,
        _ => Icons.Material.Outlined.InsertDriveFile,
    };

    private static string FormatMediaType(string? mediaType) => mediaType?.ToUpperInvariant() switch
    {
        "EPUB" => "Book",
        "AUDIOBOOK" => "Audio",
        "MOVIES" => "Movie",
        "TV" => "TV",
        "MUSIC" => "Music",
        "COMICS" => "Comic",
        "PODCASTS" => "Podcast",
        _ => mediaType ?? "—",
    };

    private static string FormatMatchSource(string? source)
    {
        if (string.IsNullOrEmpty(source)) return "—";
        // Provider GUIDs → display names
        return source.Length > 10 ? "Provider" : source;
    }

    private static string GetMatchBadgeStyle(string? source)
    {
        // Default badge style
        return "background: rgba(201,146,46,0.2); color: #C9922E; font-size: 0.7rem; height: 22px;";
    }

    private static Color GetConfidenceColor(double conf) => conf switch
    {
        >= 0.95 => Color.Success,
        >= 0.85 => Color.Info,
        >= 0.70 => Color.Warning,
        _ => Color.Error,
    };

    private static string GetConfidenceHexColor(double conf) => conf switch
    {
        >= 0.95 => "#4CAF50",
        >= 0.85 => "#26A69A",
        >= 0.70 => "#EAB308",
        _ => "#EF5350",
    };

    private static string GetConfidenceLabel(double conf) => conf switch
    {
        >= 0.95 => "Excellent",
        >= 0.85 => "Good",
        >= 0.70 => "Fair",
        _ => "Weak",
    };

    private static string GetStatusChipStyle(string status) => status switch
    {
        "Auto" => "background: rgba(76,175,80,0.15); color: #4CAF50; font-size: 0.7rem; height: 22px;",
        "Review" => "background: rgba(234,179,8,0.15); color: #EAB308; font-size: 0.7rem; height: 22px;",
        "Edited" => "background: rgba(66,165,245,0.15); color: #42A5F5; font-size: 0.7rem; height: 22px;",
        "Duplicate" => "background: rgba(239,83,80,0.15); color: #EF5350; font-size: 0.7rem; height: 22px;",
        _ => "background: rgba(255,255,255,0.05); color: #888; font-size: 0.7rem; height: 22px;",
    };

    // ── Dispose ─────────────────────────────────────────────────────────────

    public void Dispose()
    {
        _selfRef?.Dispose();
    }
}

