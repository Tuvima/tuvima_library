@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator

<div class="tl-page">
    <AppPageHeader Title="Schedule">
        <Actions>
            <AppButton Label="Save schedules"
                       ButtonStyle="AppButtonStyle.Filled"
                       Tone="AppUiTone.Primary"
                       OnClick="SaveAsync"
                       Disabled="@(_config is null || _saving)" />
        </Actions>
    </AppPageHeader>

    <AppAlert Tone="AppUiTone.Info" Class="mb-3">
        These values are persisted in AI config. Last-run and next-run times are not shown because the Engine does not provide job-run metadata here. Schedule changes can require Engine restart or scheduler reload.
    </AppAlert>

    @if (_progress is not null)
    {
        <AppCard Title="Enrichment progress"
                 Description="@($"{_progress.PendingCount} pending, {_progress.CompletedCount} completed, {_progress.Total} total.")"
                 Class="mb-3">
            <AppProgressBar Value="@ProgressPercent" ShowValue="true" />
        </AppCard>
    }

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <AppAlert Tone="@MessageTone" Class="mb-3">@_message</AppAlert>
    }

    @if (_config is null)
    {
        <AppAlert Tone="AppUiTone.Warning">AI config unavailable. Schedule settings cannot be edited.</AppAlert>
    }
    else
    {
        <AppTable Class="ai-schedule-table">
            <thead>
                <tr>
                    <th>Job</th>
                    <th>Config key</th>
                    <th>Value</th>
                    <th>Validation</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in Jobs)
                {
                    <tr>
                        <td>
                            <strong class="ai-schedule-table__name">@job.Name</strong>
                            <span class="ai-schedule-table__description">@job.Description</span>
                        </td>
                        <td><AppChip Text="@job.Key" /></td>
                        <td>
                            @if (job.IsNumber)
                            {
                                <AppNumericField Value="@GetScheduleInt(job.Key)"
                                                 ValueChanged="@((int value) => SetSchedule(job.Key, value))"
                                                 Min="1"
                                                 Size="AppControlSize.Compact" />
                            }
                            else
                            {
                                <AppTextField Value="@GetScheduleString(job.Key)"
                                              ValueChanged="@((string? value) => SetSchedule(job.Key, value ?? string.Empty))"
                                              Size="AppControlSize.Compact" />
                            }
                        </td>
                        <td><span class="ai-schedule-table__description">@ValidationLabel(job)</span></td>
                    </tr>
                }
            </tbody>
        </AppTable>
    }
</div>

@code {
    private AiConfigDto? _config;
    private EnrichmentProgressDto? _progress;
    private bool _saving;
    private string? _message;
    private Severity _messageSeverity = Severity.Info;
    private AppUiTone MessageTone => ToTone(_messageSeverity);

    private double ProgressPercent => _progress is { Total: > 0 } ? (double)_progress.CompletedCount / _progress.Total * 100 : 0;

    protected override async Task OnInitializedAsync()
    {
        _config = await Orchestrator.GetAiConfigAsync();
        _progress = await Orchestrator.GetEnrichmentProgressAsync();
    }

    private string GetScheduleString(string key)
    {
        var value = _config?.Scheduling.GetValueOrDefault(key);
        return value switch
        {
            System.Text.Json.JsonElement e when e.ValueKind == System.Text.Json.JsonValueKind.String => e.GetString() ?? "",
            string s => s,
            null => "",
            _ => value.ToString() ?? "",
        };
    }

    private int GetScheduleInt(string key)
    {
        var value = _config?.Scheduling.GetValueOrDefault(key);
        return value switch
        {
            System.Text.Json.JsonElement e when e.TryGetInt32(out var n) => n,
            int n => n,
            long n => (int)n,
            string s when int.TryParse(s, out var n) => n,
            _ => 1,
        };
    }

    private void SetSchedule(string key, object value)
    {
        if (_config is not null)
            _config.Scheduling[key] = value;
    }

    private async Task SaveAsync()
    {
        if (_config is null)
            return;

        foreach (var job in Jobs.Where(j => !j.IsNumber))
        {
            if (!LooksLikeCron(GetScheduleString(job.Key)))
            {
                SetMessage($"{job.Name} does not look like a five-field cron expression.", Severity.Error);
                return;
            }
        }

        _saving = true;
        var ok = await Orchestrator.SaveAiConfigAsync(_config);
        _saving = false;
        SetMessage(ok ? "AI schedules saved." : "AI schedules could not be saved.", ok ? Severity.Success : Severity.Error);
    }

    private string ValidationLabel(ScheduleJob job)
    {
        if (job.IsNumber)
            return GetScheduleInt(job.Key) > 0 ? "Positive number" : "Must be positive";

        return LooksLikeCron(GetScheduleString(job.Key)) ? "Five-field cron shape" : "Not validated by UI";
    }

    private static bool LooksLikeCron(string value) =>
        value.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length == 5;

    private void SetMessage(string message, Severity severity)
    {
        _message = message;
        _messageSeverity = severity;
    }

    private static AppUiTone ToTone(Severity severity) => severity switch
    {
        Severity.Success => AppUiTone.Success,
        Severity.Warning => AppUiTone.Warning,
        Severity.Error => AppUiTone.Error,
        _ => AppUiTone.Info,
    };

    private sealed record ScheduleJob(string Key, string Name, string Description, bool IsNumber = false);

    private static IReadOnlyList<ScheduleJob> Jobs =>
    [
        new("vibe_batch_cron", "Vibe batch", "Generates vibe tags for eligible items."),
        new("series_check_cron", "Series check", "Runs series alignment checks."),
        new("whisper_bake_cron", "Whisper bake", "Runs transcript/audio alignment work."),
        new("whisper_bake_window_hours", "Whisper bake window", "Hours after the scheduled time where a Whisper bake can still run.", true),
        new("taste_profile_update_cron", "Taste profile update", "Refreshes local taste profile signals."),
        new("description_intelligence", "Description intelligence", "Runs description intelligence enrichment."),
    ];
}
