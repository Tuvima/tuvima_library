@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@inject DeviceContextService DeviceContext

@* Metadata tab — library-centric provider assignment.
   Providers are dragged from a vertical palette into library cards (one per media type).
   Each library has 3 priority slots. Mobile shows a read-only summary. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Hub" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">Metadata</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Assign providers to each library. All assigned providers run concurrently —
        the Weighted Voter resolves any disagreements between their results.
    </MudText>

    @* ── Loading / error ──────────────────────────────────────────────────── *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_engineDown)
    {
        <MudAlert Severity="Severity.Error" Class="mt-2">
            Cannot reach the Engine — please make sure it is running.
        </MudAlert>
    }
    else
    {
        @* ── Universe Provider — Wikidata (pinned, editable) ──────────────── *@
        @if (WikidataProvider is { } wdProvider)
        {
            <MudPaper Elevation="0" Class="pa-4 mb-4"
                      Style="background: var(--app-glass-inner-bg);
                             border: 1px solid var(--app-glass-inner-border);
                             border-radius: 8px;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                    <div class="provider-health-dot @(_wikidataReachable ? "health-online" : "health-offline")"
                         style="width: 12px; height: 12px;"></div>
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">Universe</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                        Wikidata
                    </MudChip>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex: 1;">
                        Cross-media identification, series data, and creator profiles.
                    </MudText>
                    <MudIconButton Icon="@(_wdExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   Size="Size.Small"
                                   title="@(_wdExpanded ? "Collapse" : "Expand")"
                                   OnClick="@(() => _wdExpanded = !_wdExpanded)" />
                </MudStack>

                @if (_wdExpanded)
                {
                    <WikidataVaultPanel Provider="@wdProvider"
                                        IsAdmin="@HasAdminAccess"
                                        OnTestClicked="@TestWikidataAsync"
                                        OnSaveClicked="@SaveWikidataAsync"
                                        TestResult="@_wdTestResult"
                                        IsTesting="@_wdTesting"
                                        IsSaving="@_wdSaving" />
                }
            </MudPaper>
        }

        @* ── Main content: desktop = providers + libraries side-by-side; mobile = read-only summary *@
        @if (_isMobile)
        {
            @* ── Mobile: read-only summary ────────────────────────────────── *@
            <MudStack Spacing="3">
                @foreach (var def in _mediaTypeDefinitions)
                {
                    var slot = GetSlot(def.DisplayName);
                    var assignedNames = new[] { slot.Primary, slot.Secondary, slot.Tertiary }
                        .Where(n => !string.IsNullOrWhiteSpace(n))
                        .ToList();

                    <MudPaper Elevation="0" Class="pa-3"
                              Style="background: var(--app-glass-inner-bg);
                                     border: 1px solid var(--app-glass-inner-border);
                                     border-radius: 8px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                            <MudIcon Icon="@ResolveIcon(def.Icon)" Size="Size.Small"
                                     Style="color: var(--mud-palette-primary);" />
                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">
                                @def.DisplayName
                            </MudText>
                        </MudStack>

                        @if (assignedNames.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-style: italic;">
                                No providers assigned
                            </MudText>
                        }
                        else
                        {
                            @for (int i = 0; i < assignedNames.Count; i++)
                            {
                                var providerName = assignedNames[i];
                                var provider = _providers.FirstOrDefault(p =>
                                    string.Equals(p.Name, providerName, StringComparison.OrdinalIgnoreCase));
                                var accent = ProviderAccentMap.GetAccent(providerName!);

                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                                          Class="@(i > 0 ? "mt-1" : "")">
                                    <MudText Typo="Typo.caption" Style="color: var(--app-text-muted); width: 16px;">
                                        @(i + 1).
                                    </MudText>
                                    <MudIcon Icon="@accent.Icon" Size="Size.Small"
                                             Style="@($"color: {accent.Color};")" />
                                    <MudText Typo="Typo.body2" Style="flex: 1;">
                                        @ProviderAccentMap.GetDisplayName(providerName!)
                                    </MudText>
                                    <div class="provider-health-dot @(provider?.IsReachable == true ? "health-online" : "health-offline")"></div>
                                    @if (provider?.RequiresApiKey == true && provider.HasApiKey == false)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                                 Variant="Variant.Outlined" Style="font-size: 0.65rem;">
                                            needs key
                                        </MudChip>
                                    }
                                </MudStack>
                            }
                        }
                    </MudPaper>
                }
            </MudStack>

            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                <MudIcon Icon="@Icons.Material.Filled.DesktopWindows" Size="Size.Small"
                         Style="vertical-align: middle; margin-right: 4px;" />
                Edit provider assignments on a desktop device.
            </MudText>
        }
        else
        {
            @* ── Desktop: single MudDropContainer wrapping palette + library grid ──
               Palette is a MudDropZone (drag sources). Each slot is a MudDropZone.
               This is required for cross-boundary drag-drop to work in MudBlazor. ── *@
            <MudDropContainer T="ProviderDragItem"
                              Items="@_dragItems"
                              ItemsSelector="@((item, zone) => item.Zone == zone)"
                              ItemDropped="@OnGlobalItemDropped"
                              Class="vault-layout">
                <ChildContent>
                    @* ── Left: provider palette zone ──────────────────────────── *@
                    <div class="vault-provider-list">
                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: var(--app-text-muted);">
                            Providers
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                            Drag into library slots.
                        </MudText>

                        @* Palette drop zone — all available providers live here as drag sources *@
                        <MudDropZone T="ProviderDragItem"
                                     Identifier="palette"
                                     Class="vault-palette-zone"
                                     AllowReorder="false" />

                        @if (GetUnavailableProviders() is { Count: > 0 } unavailable)
                        {
                            <MudDivider Class="my-3" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                                Unavailable
                            </MudText>
                            <MudStack Spacing="1">
                                @foreach (var p in unavailable)
                                {
                                    @* Unavailable providers are outside the drop container —
                                       not draggable, but config button stays interactive. *@
                                    <ProviderCard Provider="@p"
                                                  IsSlotted="false"
                                                  IsUnavailable="true"
                                                  OnConfigSaved="@RefreshProvidersAsync" />
                                }
                            </MudStack>
                        }
                    </div>

                    @* ── Right: library cards grid (visually grouped) ────────── *@
                    @{
                        var booksGroupDefs  = _mediaTypeDefinitions.Where(d => d.Key is "books" or "audiobooks").ToList();
                        var videoGroupDefs  = _mediaTypeDefinitions.Where(d => d.Key is "movies" or "tv_shows").ToList();
                        var standaloneDefs  = _mediaTypeDefinitions
                            .Where(d => d.Key is not ("books" or "audiobooks" or "movies" or "tv_shows"))
                            .ToList();
                    }
                    <div class="vault-libraries-grid">

                        @* ── Books & Audiobooks (share Apple Books as primary provider) ── *@
                        @if (booksGroupDefs.Count > 0)
                        {
                            <div class="vault-library-group">
                                <div class="vault-group-label">
                                    <MudIcon Icon="@Icons.Material.Outlined.LibraryBooks" Size="Size.Small"
                                             Style="vertical-align: middle; margin-right: 5px;" />
                                    Books &amp; Audiobooks
                                </div>
                                <div class="vault-group-cards">
                                    @foreach (var def in booksGroupDefs)
                                    {
                                        var slot = GetSlot(def.DisplayName);
                                        <MudPaper Elevation="0" Class="vault-library-card"
                                                  Style="background: var(--app-glass-bg);
                                                         border: 1px solid var(--app-glass-inner-border);
                                                         border-radius: 8px;">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-3 pb-2">
                                                <MudIcon Icon="@ResolveIcon(def.Icon)" Size="Size.Small"
                                                         Style="color: var(--mud-palette-primary);" />
                                                <MudText Typo="Typo.subtitle2" Style="font-weight: 600; flex: 1;">@def.DisplayName</MudText>
                                                <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                                                               Color="Color.Default" title="Configure library"
                                                               OnClick="@(() => OpenLibraryConfig(def))" Style="flex-shrink: 0;" />
                                            </MudStack>
                                            <div class="vault-drop-container">
                                                @foreach (var (slotName, label, currentName) in new[]
                                                {
                                                    ("primary",   "1", slot.Primary),
                                                    ("secondary", "2", slot.Secondary),
                                                    ("tertiary",  "3", slot.Tertiary),
                                                })
                                                {
                                                    var zoneId    = $"{def.Key}:{slotName}";
                                                    var isFilled  = !string.IsNullOrWhiteSpace(currentName);
                                                    var isPrimary = slotName == "primary";
                                                    <MudDropZone T="ProviderDragItem" Identifier="@zoneId" AllowReorder="false"
                                                                 Class="@($"vault-slot {(isPrimary ? "vault-slot-primary" : "")} {(isFilled ? "vault-slot-filled" : "")}")">
                                                        <MudText Typo="Typo.caption"
                                                                 Style="@($"color: {(isPrimary ? "var(--mud-palette-primary)" : "var(--app-text-muted)")}; font-weight: 600; min-width: 14px;")">
                                                            @label
                                                        </MudText>
                                                    </MudDropZone>
                                                }
                                            </div>
                                        </MudPaper>
                                    }
                                </div>
                            </div>
                        }

                        @* ── Movies & TV Shows (share TMDB as primary provider) ────── *@
                        @if (videoGroupDefs.Count > 0)
                        {
                            <div class="vault-library-group">
                                <div class="vault-group-label">
                                    <MudIcon Icon="@Icons.Material.Outlined.VideoLibrary" Size="Size.Small"
                                             Style="vertical-align: middle; margin-right: 5px;" />
                                    Movies &amp; TV Shows
                                </div>
                                <div class="vault-group-cards">
                                    @foreach (var def in videoGroupDefs)
                                    {
                                        var slot = GetSlot(def.DisplayName);
                                        <MudPaper Elevation="0" Class="vault-library-card"
                                                  Style="background: var(--app-glass-bg);
                                                         border: 1px solid var(--app-glass-inner-border);
                                                         border-radius: 8px;">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-3 pb-2">
                                                <MudIcon Icon="@ResolveIcon(def.Icon)" Size="Size.Small"
                                                         Style="color: var(--mud-palette-primary);" />
                                                <MudText Typo="Typo.subtitle2" Style="font-weight: 600; flex: 1;">@def.DisplayName</MudText>
                                                <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                                                               Color="Color.Default" title="Configure library"
                                                               OnClick="@(() => OpenLibraryConfig(def))" Style="flex-shrink: 0;" />
                                            </MudStack>
                                            <div class="vault-drop-container">
                                                @foreach (var (slotName, label, currentName) in new[]
                                                {
                                                    ("primary",   "1", slot.Primary),
                                                    ("secondary", "2", slot.Secondary),
                                                    ("tertiary",  "3", slot.Tertiary),
                                                })
                                                {
                                                    var zoneId    = $"{def.Key}:{slotName}";
                                                    var isFilled  = !string.IsNullOrWhiteSpace(currentName);
                                                    var isPrimary = slotName == "primary";
                                                    <MudDropZone T="ProviderDragItem" Identifier="@zoneId" AllowReorder="false"
                                                                 Class="@($"vault-slot {(isPrimary ? "vault-slot-primary" : "")} {(isFilled ? "vault-slot-filled" : "")}")">
                                                        <MudText Typo="Typo.caption"
                                                                 Style="@($"color: {(isPrimary ? "var(--mud-palette-primary)" : "var(--app-text-muted)")}; font-weight: 600; min-width: 14px;")">
                                                            @label
                                                        </MudText>
                                                    </MudDropZone>
                                                }
                                            </div>
                                        </MudPaper>
                                    }
                                </div>
                            </div>
                        }

                        @* ── Standalone libraries (Comics, Music, Podcasts, etc.) ──── *@
                        @if (standaloneDefs.Count > 0)
                        {
                            <div class="vault-standalone-row">
                                @foreach (var def in standaloneDefs)
                                {
                                    var slot = GetSlot(def.DisplayName);
                                    <MudPaper Elevation="0" Class="vault-library-card"
                                              Style="background: var(--app-glass-inner-bg);
                                                     border: 1px solid var(--app-glass-inner-border);
                                                     border-radius: 8px;">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-3 pb-2">
                                            <MudIcon Icon="@ResolveIcon(def.Icon)" Size="Size.Small"
                                                     Style="color: var(--mud-palette-primary);" />
                                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600; flex: 1;">@def.DisplayName</MudText>
                                            <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                                                           Color="Color.Default" title="Configure library"
                                                           OnClick="@(() => OpenLibraryConfig(def))" Style="flex-shrink: 0;" />
                                        </MudStack>
                                        <div class="vault-drop-container">
                                            @foreach (var (slotName, label, currentName) in new[]
                                            {
                                                ("primary",   "1", slot.Primary),
                                                ("secondary", "2", slot.Secondary),
                                                ("tertiary",  "3", slot.Tertiary),
                                            })
                                            {
                                                var zoneId    = $"{def.Key}:{slotName}";
                                                var isFilled  = !string.IsNullOrWhiteSpace(currentName);
                                                var isPrimary = slotName == "primary";
                                                <MudDropZone T="ProviderDragItem" Identifier="@zoneId" AllowReorder="false"
                                                             Class="@($"vault-slot {(isPrimary ? "vault-slot-primary" : "")} {(isFilled ? "vault-slot-filled" : "")}")">
                                                    <MudText Typo="Typo.caption"
                                                             Style="@($"color: {(isPrimary ? "var(--mud-palette-primary)" : "var(--app-text-muted)")}; font-weight: 600; min-width: 14px;")">
                                                        @label
                                                    </MudText>
                                                </MudDropZone>
                                            }
                                        </div>
                                    </MudPaper>
                                }
                            </div>
                        }

                    </div>
                </ChildContent>

                <ItemRenderer>
                    @{
                        var renderProvider = _providers.FirstOrDefault(p => p.Name == context.ProviderName);
                        if (renderProvider is not null)
                        {
                            var isPaletteItem = context.Zone == "palette";
                            var ctxCapture = context;
                            <ProviderCard Provider="@renderProvider"
                                          IsSlotted="@(!isPaletteItem)"
                                          ShowConfig="@isPaletteItem"
                                          OnRemove="@(isPaletteItem
                                              ? default(EventCallback)
                                              : EventCallback.Factory.Create(this, () => RemoveSlottedItemAsync(ctxCapture)))"
                                          OnConfigSaved="@RefreshProvidersAsync" />
                        }
                    }
                </ItemRenderer>
            </MudDropContainer>
        }
    }

</MudPaper>

@* ── Library config dialog ───────────────────────────────────────────────── *@
<MudDialog @bind-Visible="_libConfigOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@ResolveIcon(_libEditIcon)" Size="Size.Small"
                     Style="color: var(--mud-palette-primary);" />
            <MudText Typo="Typo.h6" Style="font-weight: 600;">
                @_libEditDisplayName Configuration
            </MudText>
            @if (_libEditBuiltIn)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                    Built-in
                </MudChip>
            }
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            @* Icon picker *@
            <MudSelect T="string" @bind-Value="_libEditIcon"
                       Label="Icon" Variant="Variant.Outlined" Margin="Margin.Dense"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@ResolveIcon(_libEditIcon)">
                @foreach (var (name, icon) in IconMap)
                {
                    <MudSelectItem T="string" Value="@name">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@icon" Size="Size.Small" />
                            <MudText>@name</MudText>
                        </MudStack>
                    </MudSelectItem>
                }
            </MudSelect>

            @* File extensions *@
            <MudText Typo="Typo.body2" Style="font-weight: 500;">File Extensions</MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="flex-wrap: wrap;">
                @foreach (var ext in _libEditExtensions)
                {
                    var localExt = ext;
                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                             Variant="Variant.Outlined"
                             OnClose="@(() => _libEditExtensions.Remove(localExt))">
                        @localExt
                    </MudChip>
                }
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudTextField T="string" @bind-Value="_libNewExtension"
                              Placeholder="e.g. .epub"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Style="max-width: 160px;"
                              OnKeyDown="@OnExtensionKeyDown" />
                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                               Color="Color.Primary"
                               OnClick="@AddExtension" />
            </MudStack>

            @* Category folder *@
            <MudTextField T="string" @bind-Value="_libEditCategoryFolder"
                          Label="Category Folder"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          HelperText="Folder name under the library root"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Folder" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                   OnClick="@CloseLibraryConfig">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   OnClick="@SaveLibraryConfigAsync" Disabled="@_libSaving">
            @if (_libSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public string CurrentRole { get; set; } = "Administrator";

    private bool _loading = true;
    private bool _engineDown;
    private bool _wikidataReachable;

    private IReadOnlyList<ProviderStatusDto> _providers = [];
    private Dictionary<string, ProviderSlotDto> _slots = new();
    private List<MediaTypeDefinitionDto> _mediaTypeDefinitions = [];

    // ── Mobile state ──────────────────────────────────────────────────────
    private bool _isMobile => DeviceContext.IsMobile;

    // ── Wikidata panel state ──────────────────────────────────────────────
    private bool _wdExpanded;
    private bool _wdTesting;
    private bool _wdSaving;
    private ProviderTestResultDto? _wdTestResult;

    private ProviderStatusDto? WikidataProvider =>
        _providers.FirstOrDefault(p =>
            string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase));

    private bool HasAdminAccess =>
        string.Equals(CurrentRole, "Administrator", StringComparison.OrdinalIgnoreCase)
        || string.Equals(CurrentRole, "Curator", StringComparison.OrdinalIgnoreCase);

    // ── Material icon lookup ─────────────────────────────────────────────
    private static readonly Dictionary<string, string> IconMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["MenuBook"]     = Icons.Material.Filled.MenuBook,
        ["Headphones"]   = Icons.Material.Filled.Headphones,
        ["AutoStories"]  = Icons.Material.Filled.AutoStories,
        ["Movie"]        = Icons.Material.Filled.Movie,
        ["Tv"]           = Icons.Material.Filled.Tv,
        ["MusicNote"]    = Icons.Material.Filled.MusicNote,
        ["Podcasts"]     = Icons.Material.Filled.Podcasts,
        ["Description"]  = Icons.Material.Filled.Description,
        ["Folder"]       = Icons.Material.Filled.Folder,
        ["Photo"]        = Icons.Material.Filled.Photo,
        ["VideoLibrary"] = Icons.Material.Filled.VideoLibrary,
        ["AudioFile"]    = Icons.Material.Filled.AudioFile,
        ["Article"]      = Icons.Material.Filled.Article,
        ["Book"]         = Icons.Material.Filled.Book,
        ["LibraryBooks"] = Icons.Material.Filled.LibraryBooks,
        ["LocalLibrary"] = Icons.Material.Filled.LocalLibrary,
        ["Hearing"]      = Icons.Material.Filled.Hearing,
        ["Mic"]          = Icons.Material.Filled.Mic,
        ["Album"]        = Icons.Material.Filled.Album,
        ["Camera"]       = Icons.Material.Filled.Camera,
        ["Image"]        = Icons.Material.Filled.Image,
        ["PictureAsPdf"] = Icons.Material.Filled.PictureAsPdf,
        ["Code"]         = Icons.Material.Filled.Code,
        ["Science"]      = Icons.Material.Filled.Science,
        ["School"]       = Icons.Material.Filled.School,
        ["SportsEsports"]= Icons.Material.Filled.SportsEsports,
        ["Newspaper"]    = Icons.Material.Filled.Newspaper,
        ["Dashboard"]    = Icons.Material.Filled.Dashboard,
        ["Star"]         = Icons.Material.Filled.Star,
        ["Cloud"]        = Icons.Material.Filled.Cloud,
    };

    private static string ResolveIcon(string iconName)
    {
        if (string.IsNullOrWhiteSpace(iconName)) return Icons.Material.Filled.Description;
        return IconMap.TryGetValue(iconName, out var resolved) ? resolved : Icons.Material.Filled.Description;
    }

    // ── Lifecycle ──────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _providers = await Orchestrator.GetProviderStatusAsync();
            if (_providers.Count == 0)
            {
                _engineDown = true;
                return;
            }

            var slots = await Orchestrator.GetProviderSlotsAsync();
            _slots = slots ?? new Dictionary<string, ProviderSlotDto>();

            var mediaTypesConfig = await Orchestrator.GetMediaTypesAsync();
            _mediaTypeDefinitions = mediaTypesConfig?.Types ?? MediaTypeConfigurationDto.Defaults();

            // Check Wikidata reachability.
            var wikidata = _providers.FirstOrDefault(p =>
                string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase));
            _wikidataReachable = wikidata?.IsReachable ?? false;

            // Build the global drag items list from current slots.
            RebuildDragItems();
        }
        catch
        {
            _engineDown = true;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Provider helpers ─────────────────────────────────────────────────

    /// <summary>Returns Stage 3 providers (enabled + reachable) for the provider palette.</summary>
    private List<ProviderStatusDto> GetAllStage3Providers()
    {
        return _providers
            .Where(p => ProviderAccentMap.IsVisibleProvider(p.Name))
            .Where(p => !string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase))
            .Where(p => !string.Equals(p.Name, "wikipedia", StringComparison.OrdinalIgnoreCase))
            .Where(p => p.Enabled && p.IsReachable)
            .ToList();
    }

    /// <summary>Returns providers that are disabled or offline.</summary>
    private List<ProviderStatusDto> GetUnavailableProviders()
    {
        return _providers
            .Where(p => ProviderAccentMap.IsVisibleProvider(p.Name))
            .Where(p => !string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase))
            .Where(p => !string.Equals(p.Name, "wikipedia", StringComparison.OrdinalIgnoreCase))
            .Where(p => !p.Enabled || !p.IsReachable)
            .ToList();
    }

    // ── Library config state ────────────────────────────────────────────
    private bool _libConfigOpen;
    private bool _libSaving;
    private string _libEditKey = string.Empty;
    private string _libEditDisplayName = string.Empty;
    private string _libEditIcon = string.Empty;
    private List<string> _libEditExtensions = [];
    private string _libEditCategoryFolder = string.Empty;
    private bool _libEditBuiltIn;
    private string _libNewExtension = string.Empty;

    private void OpenLibraryConfig(MediaTypeDefinitionDto def)
    {
        _libEditKey = def.Key;
        _libEditDisplayName = def.DisplayName;
        _libEditIcon = def.Icon;
        _libEditExtensions = def.Extensions?.ToList() ?? [];
        _libEditCategoryFolder = def.CategoryFolder ?? string.Empty;
        _libEditBuiltIn = def.BuiltIn;
        _libNewExtension = string.Empty;
        _libConfigOpen = true;
    }

    private void CloseLibraryConfig() => _libConfigOpen = false;

    private void AddExtension()
    {
        var ext = _libNewExtension?.Trim();
        if (string.IsNullOrWhiteSpace(ext)) return;
        if (!ext.StartsWith('.')) ext = "." + ext;
        if (!_libEditExtensions.Contains(ext, StringComparer.OrdinalIgnoreCase))
            _libEditExtensions.Add(ext.ToLowerInvariant());
        _libNewExtension = string.Empty;
    }

    private void OnExtensionKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddExtension();
    }

    private async Task SaveLibraryConfigAsync()
    {
        _libSaving = true;
        try
        {
            var target = _mediaTypeDefinitions.FirstOrDefault(d => d.Key == _libEditKey);
            if (target is null) return;

            target.Icon = _libEditIcon;
            target.Extensions = _libEditExtensions;
            target.CategoryFolder = _libEditCategoryFolder;

            var config = new MediaTypeConfigurationDto { Types = _mediaTypeDefinitions };
            var ok = await Orchestrator.SaveMediaTypesAsync(config);

            if (ok)
            {
                Snackbar.Add($"{_libEditDisplayName} configuration saved.", Severity.Success);
                _libConfigOpen = false;
            }
            else
            {
                Snackbar.Add("Failed to save library configuration.", Severity.Error);
            }
        }
        finally
        {
            _libSaving = false;
        }
    }

    // ── Shared provider detection ────────────────────────────────────────

    /// <summary>Returns display names of other libraries that share at least one
    /// slotted provider with the given media type.</summary>
    private List<string> GetSharedProviderLibraries(string mediaType)
    {
        var mySlot = GetSlot(mediaType);
        var myProviders = new[] { mySlot.Primary, mySlot.Secondary, mySlot.Tertiary }
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (myProviders.Count == 0) return [];

        var shared = new List<string>();
        foreach (var def in _mediaTypeDefinitions)
        {
            if (string.Equals(def.DisplayName, mediaType, StringComparison.OrdinalIgnoreCase))
                continue;

            var otherSlot = GetSlot(def.DisplayName);
            var otherProviders = new[] { otherSlot.Primary, otherSlot.Secondary, otherSlot.Tertiary }
                .Where(n => !string.IsNullOrWhiteSpace(n));

            if (otherProviders.Any(p => myProviders.Contains(p!)))
                shared.Add(def.DisplayName);
        }

        return shared;
    }

    // ── Drag-drop model (single global container) ─────────────────────────
    //
    // Zone naming:
    //   "palette"             — provider palette (drag sources, copy semantics)
    //   "{def.Key}:{slot}"    — library slot, e.g. "books:primary", "tv_shows:tertiary"
    //
    // RebuildDragItems() is the single source of truth for what is in each zone.
    // It is called after every state change so the container always reflects _slots.
    // ──────────────────────────────────────────────────────────────────────

    private List<ProviderDragItem> _dragItems = [];

    private void RebuildDragItems()
    {
        var items = new List<ProviderDragItem>();

        // Available providers populate the palette zone (drag sources).
        foreach (var p in GetAllStage3Providers())
            items.Add(new ProviderDragItem { ProviderName = p.Name, Zone = "palette" });

        // Slotted providers — one item per assigned slot per library.
        foreach (var def in _mediaTypeDefinitions)
        {
            var slot = GetSlot(def.DisplayName);
            if (!string.IsNullOrWhiteSpace(slot.Primary))
                items.Add(new ProviderDragItem { ProviderName = slot.Primary,   Zone = $"{def.Key}:primary" });
            if (!string.IsNullOrWhiteSpace(slot.Secondary))
                items.Add(new ProviderDragItem { ProviderName = slot.Secondary, Zone = $"{def.Key}:secondary" });
            if (!string.IsNullOrWhiteSpace(slot.Tertiary))
                items.Add(new ProviderDragItem { ProviderName = slot.Tertiary,  Zone = $"{def.Key}:tertiary" });
        }

        _dragItems = items;
    }

    private ProviderSlotDto GetSlot(string mediaType)
    {
        return _slots.TryGetValue(mediaType, out var slot) ? slot : new ProviderSlotDto();
    }

    /// <summary>Parses a slot zone id like "tv_shows:primary" into (DisplayName, slotName).</summary>
    private (string? DisplayName, string SlotName) ParseZone(string zone)
    {
        var colonIdx = zone.IndexOf(':');
        if (colonIdx < 0) return (null, zone);
        var defKey   = zone[..colonIdx];
        var slotName = zone[(colonIdx + 1)..];
        var def = _mediaTypeDefinitions.FirstOrDefault(d => d.Key == defKey);
        return (def?.DisplayName, slotName);
    }

    private async Task OnGlobalItemDropped(MudItemDropInfo<ProviderDragItem> drop)
    {
        if (drop.Item is null) return;

        var providerName = drop.Item.ProviderName;
        var sourceZone   = drop.Item.Zone;
        var targetZone   = drop.DropzoneIdentifier;

        // No-op: same zone drop
        if (sourceZone == targetZone) { RebuildDragItems(); return; }

        // Remove from source slot (if source was a slot, not palette)
        if (sourceZone != "palette")
        {
            var (srcDisplay, srcSlot) = ParseZone(sourceZone);
            if (srcDisplay is not null)
            {
                var slot = GetSlot(srcDisplay);
                slot = srcSlot switch
                {
                    "primary"   => slot with { Primary   = null },
                    "secondary" => slot with { Secondary = null },
                    "tertiary"  => slot with { Tertiary  = null },
                    _           => slot,
                };
                _slots[srcDisplay] = slot;
            }
        }

        // Assign to target slot (if target is a slot)
        if (targetZone != "palette")
        {
            var (tgtDisplay, tgtSlot) = ParseZone(targetZone);
            if (tgtDisplay is not null)
            {
                var slot = GetSlot(tgtDisplay);

                // Clear this provider from other slots in the same library first.
                if (string.Equals(slot.Primary,   providerName, StringComparison.OrdinalIgnoreCase))
                    slot = slot with { Primary   = null };
                if (string.Equals(slot.Secondary, providerName, StringComparison.OrdinalIgnoreCase))
                    slot = slot with { Secondary = null };
                if (string.Equals(slot.Tertiary,  providerName, StringComparison.OrdinalIgnoreCase))
                    slot = slot with { Tertiary  = null };

                slot = tgtSlot switch
                {
                    "primary"   => slot with { Primary   = providerName },
                    "secondary" => slot with { Secondary = providerName },
                    "tertiary"  => slot with { Tertiary  = providerName },
                    _           => slot,
                };
                _slots[tgtDisplay] = slot;
            }
        }

        RebuildDragItems();
        await SaveSlotsAsync();
    }

    /// <summary>Removes a slotted provider card via the × button.</summary>
    private async Task RemoveSlottedItemAsync(ProviderDragItem item)
    {
        if (item.Zone == "palette") return;

        var (displayName, slotName) = ParseZone(item.Zone);
        if (displayName is null) return;

        var slot = GetSlot(displayName);
        slot = slotName switch
        {
            "primary"   => slot with { Primary   = null },
            "secondary" => slot with { Secondary = null },
            "tertiary"  => slot with { Tertiary  = null },
            _           => slot,
        };
        _slots[displayName] = slot;

        RebuildDragItems();
        await SaveSlotsAsync();
    }

    private async Task SaveSlotsAsync()
    {
        var ok = await Orchestrator.UpdateProviderSlotsAsync(_slots);
        if (ok)
            Snackbar.Add("Provider slots saved.", Severity.Success);
        else
            Snackbar.Add("Failed to save provider slots.", Severity.Error);

        StateHasChanged();
    }

    private async Task RefreshProvidersAsync()
    {
        try
        {
            _providers = await Orchestrator.GetProviderStatusAsync();
            var wikidata = _providers.FirstOrDefault(p =>
                string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase));
            _wikidataReachable = wikidata?.IsReachable ?? false;
            RebuildDragItems();
            StateHasChanged();
        }
        catch
        {
            // Non-fatal: provider list will be stale but usable.
        }
    }

    // ── Wikidata handlers ───────────────────────────────────────────────

    private async Task TestWikidataAsync()
    {
        _wdTesting = true;
        _wdTestResult = null;
        StateHasChanged();
        try
        {
            _wdTestResult = await Orchestrator.TestProviderAsync("wikidata");
        }
        catch
        {
            _wdTestResult = new ProviderTestResultDto(false, 0, [], "Connection test failed.");
        }
        finally
        {
            _wdTesting = false;
            StateHasChanged();
        }
    }

    private async Task SaveWikidataAsync(ProviderConfigUpdateDto config)
    {
        _wdSaving = true;
        StateHasChanged();
        try
        {
            var ok = await Orchestrator.SaveProviderConfigAsync("wikidata", config);
            if (ok)
            {
                Snackbar.Add("Wikidata settings saved.", Severity.Success);
                await RefreshProvidersAsync();
            }
            else
                Snackbar.Add("Failed to save Wikidata settings.", Severity.Error);
        }
        catch
        {
            Snackbar.Add("Error saving Wikidata settings.", Severity.Error);
        }
        finally
        {
            _wdSaving = false;
            StateHasChanged();
        }
    }

    // ── Drag item model ──────────────────────────────────────────────────

    private sealed class ProviderDragItem
    {
        public string ProviderName { get; set; } = string.Empty;
        public string Zone         { get; set; } = "palette";
    }

