@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@* Metadata tab — simplified provider slot assignment.
   Users pick a Primary + up to 2 secondary providers per media type
   via drag-drop. Media type tabs are loaded from config. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Hub" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">Metadata</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Select providers for each media type. Drag a provider into a slot to set priority.
    </MudText>

    @* ── Loading / error ──────────────────────────────────────────────────── *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_engineDown)
    {
        <MudAlert Severity="Severity.Error" Class="mt-2">
            Cannot reach the Engine — please make sure it is running.
        </MudAlert>
    }
    else
    {
        @* ── Universe indicator ────────────────────────────────────────────── *@
        <MudPaper Elevation="0" Class="pa-3 mb-4"
                  Style="background: var(--app-glass-bg); border: 1px solid var(--app-glass-border); border-radius: 12px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <div class="provider-health-dot @(_wikidataReachable ? "health-online" : "health-offline")"
                     style="width: 12px; height: 12px;"></div>
                <MudText Typo="Typo.body1" Style="font-weight: 500;">
                    Universe
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex: 1;">
                    Wikidata provides cross-media identification, series data, and creator profiles.
                </MudText>
            </MudStack>
        </MudPaper>

        @* ── Media type selector cards ─────────────────────────────────────── *@
        <div class="media-type-cards-row">
            @foreach (var def in _mediaTypeDefinitions)
            {
                var isActive = string.Equals(def.DisplayName, _activeMediaType, StringComparison.Ordinal);
                <div class="media-type-card @(isActive ? "media-type-card-active" : "")"
                     @onclick="@(() => _activeMediaType = def.DisplayName)">
                    <MudIcon Icon="@ResolveIcon(def.Icon)" Size="Size.Large"
                             Style="@($"color: {(isActive ? "var(--mud-palette-primary)" : "var(--app-text-muted)")};")"/>
                    <MudText Typo="Typo.caption" Style="@($"font-weight: {(isActive ? "600" : "400")}; color: {(isActive ? "var(--mud-palette-primary-text)" : "var(--app-text-muted)")};")">
                        @def.DisplayName
                    </MudText>
                    <span class="media-type-card-menu" @onclick:stopPropagation="true">
                        <MudIconButton Icon="@Icons.Material.Filled.MoreVert"
                                       Size="Size.Small"
                                       Color="@(isActive ? Color.Primary : Color.Default)"
                                       title="Configure media type"
                                       OnClick="@(() => OpenMediaTypeConfigDialog(def))" />
                    </span>
                </div>
            }
            @* Add media type *@
            <MudTooltip Text="Add custom media type" Arrow="true" Placement="Placement.Top">
                <div class="media-type-card media-type-card-add" @onclick="@OpenAddMediaTypeDialog">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Large"
                             Style="color: var(--app-text-muted);"/>
                    <MudText Typo="Typo.caption" Style="color: var(--app-text-muted);">Add</MudText>
                </div>
            </MudTooltip>
        </div>

        @* ── Active media type content ──────────────────────────────────────── *@
        @if ((_mediaTypeDefinitions.FirstOrDefault(d => d.DisplayName == _activeMediaType)
              ?? _mediaTypeDefinitions.FirstOrDefault()) is { } activeDef)
        {
            @* Extension chips *@
            @if (activeDef.Extensions.Count > 0)
            {
                <MudStack Row="true" Spacing="1" Class="mb-3" Style="flex-wrap: wrap;">
                    @foreach (var ext in activeDef.Extensions)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Color="Color.Default" Style="font-size: 0.7rem;">@ext</MudChip>
                    }
                </MudStack>
            }

            @* Slot layout *@
            <div class="slot-layout">
                <div class="slot-available-providers">
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: var(--app-text-muted);">
                        Available Providers
                    </MudText>
                    <MudDropContainer T="ProviderDragItem"
                                      Items="@GetDragItems(activeDef.DisplayName)"
                                      ItemsSelector="@((item, zone) => item.Zone == zone)"
                                      ItemDropped="@(args => OnItemDropped(args, activeDef.DisplayName))"
                                      Class="slot-drop-container">
                        <ChildContent>
                            <MudDropZone T="ProviderDragItem"
                                         Identifier="available"
                                         Class="slot-available-zone"
                                         AllowReorder="false"
                                         CanDrop="@(_ => true)">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                                    Drag providers to the slots on the right.
                                </MudText>
                            </MudDropZone>

                            <div class="slot-zones-column">
                                <MudDropZone T="ProviderDragItem"
                                             Identifier="primary"
                                             Class="slot-zone slot-zone-primary"
                                             AllowReorder="false"
                                             CanDrop="@(_ => true)">
                                    <MudText Typo="Typo.subtitle2" Style="color: var(--mud-palette-primary); font-weight: 600;">
                                        Primary — Automatic Match
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        This provider runs automatically when files are added.
                                    </MudText>
                                </MudDropZone>

                                <MudDropZone T="ProviderDragItem"
                                             Identifier="secondary"
                                             Class="slot-zone"
                                             AllowReorder="false"
                                             CanDrop="@(_ => true)">
                                    <MudText Typo="Typo.subtitle2" Style="color: var(--app-text-muted);">
                                        Secondary — Manual Fallback 1
                                    </MudText>
                                </MudDropZone>

                                <MudDropZone T="ProviderDragItem"
                                             Identifier="tertiary"
                                             Class="slot-zone"
                                             AllowReorder="false"
                                             CanDrop="@(_ => true)">
                                    <MudText Typo="Typo.subtitle2" Style="color: var(--app-text-muted);">
                                        Tertiary — Manual Fallback 2
                                    </MudText>
                                </MudDropZone>
                            </div>
                        </ChildContent>

                        <ItemRenderer>
                            @{
                                var provider = _providers.FirstOrDefault(p => p.Name == context.ProviderName);
                                if (provider is not null)
                                {
                                    <ProviderCard Provider="@provider"
                                                  IsSlotted="@(context.Zone != "available")"
                                                  OnRemove="@(() => RemoveFromSlot(context, activeDef.DisplayName))"
                                                  OnConfigSaved="@RefreshProvidersAsync" />
                                }
                            }
                        </ItemRenderer>
                    </MudDropContainer>

                    @* ── Unavailable providers (disabled or offline) ─────────────── *@
                    @if (GetUnavailableProviders() is { Count: > 0 } unavailableProviders)
                    {
                        <MudDivider Class="my-4" />
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.PowerOff" Size="Size.Small"
                                     Style="color: var(--app-text-muted);" />
                            <MudText Typo="Typo.subtitle2" Style="color: var(--app-text-muted);">
                                Unavailable Providers
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                — disabled or offline, cannot be assigned to slots
                            </MudText>
                        </MudStack>
                        <MudStack Spacing="1">
                            @foreach (var p in unavailableProviders)
                            {
                                <div class="provider-unavailable-wrapper">
                                    <ProviderCard Provider="@p"
                                                  IsSlotted="false"
                                                  OnConfigSaved="@RefreshProvidersAsync" />
                                </div>
                            }
                        </MudStack>
                    }
                </div>
            </div>
        }
    }

</MudPaper>

@* ── Media type config dialog ─────────────────────────────────────────── *@
<MudDialog @bind-Visible="_configOpen" Options="_configDialogOptions">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            @if (_editingType is not null)
            {
                <MudIcon Icon="@ResolveIcon(_editingType.Icon)" Color="Color.Primary" />
            }
            <MudText Typo="Typo.h6">
                @(_editingType is null ? "Configure" : (_editingType.BuiltIn ? _editingType.DisplayName : "Edit Media Type"))
            </MudText>
            @if (_editingType?.BuiltIn == true)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Built-in</MudChip>
            }
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_editingType is not null)
        {
            <MudStack Spacing="3">
                @* Display name *@
                <MudTextField T="string"
                              @bind-Value="_editDisplayName"
                              Label="Display Name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              ReadOnly="@_editingType.BuiltIn"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Label" />

                @* Icon *@
                <MudSelect T="string" @bind-Value="_editIcon"
                           Label="Icon"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           AnchorOrigin="Origin.BottomCenter"
                           TransformOrigin="Origin.TopCenter"
                           AdornmentIcon="@ResolveIcon(_editIcon)">
                    @foreach (var (name, icon) in IconMap)
                    {
                        <MudSelectItem Value="@name">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@icon" Size="Size.Small" />
                                <MudText>@name</MudText>
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>

                @* Category folder *@
                <MudTextField T="string"
                              @bind-Value="_editCategoryFolder"
                              Label="Category Folder"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Folder" />

                @* Extensions *@
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">File Extensions</MudText>
                    <MudStack Row="true" Spacing="1" Style="flex-wrap: wrap;" Class="mb-2">
                        @foreach (var ext in _editExtensions)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                     Variant="Variant.Outlined"
                                     OnClose="@(() => _editExtensions.Remove(ext))">@ext</MudChip>
                        }
                    </MudStack>
                    <MudStack Row="true" Spacing="1">
                        <MudTextField T="string"
                                      @bind-Value="_newExtension"
                                      Label="Add extension"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder=".pdf"
                                      Style="flex: 1;" />
                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       Size="Size.Medium"
                                       Color="Color.Primary"
                                       OnClick="@AddExtension" />
                    </MudStack>
                </div>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        @if (_editingType?.BuiltIn == false)
        {
            <MudButton Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="@RequestDeleteMediaType">Delete</MudButton>
        }
        <MudSpacer />
        <MudButton OnClick="@CloseMediaTypeConfig">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="@SaveMediaTypeConfigAsync"
                   Disabled="@_savingType">Save</MudButton>
    </DialogActions>
</MudDialog>

@* ── Delete confirmation dialog ────────────────────────────────── *@
<MudDialog @bind-Visible="_confirmDeleteOpen">
    <TitleContent>
        <MudText Typo="Typo.h6">Delete Media Type</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            Are you sure you want to delete "@(_editingType?.DisplayName)"? This cannot be undone.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelDelete">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ConfirmDeleteMediaTypeAsync">Delete</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public string CurrentRole { get; set; } = "Administrator";

    private bool _loading = true;
    private bool _engineDown;
    private bool _wikidataReachable;

    private IReadOnlyList<ProviderStatusDto> _providers = [];
    private Dictionary<string, ProviderSlotDto> _slots = new();
    private List<MediaTypeDefinitionDto> _mediaTypeDefinitions = [];
    private string _activeMediaType = string.Empty;

    private readonly DialogOptions _configDialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true,
        CloseButton = true,
    };

    // ── Media type config editing state ──────────────────────────────────
    private bool _configOpen;
    private bool _savingType;
    private MediaTypeDefinitionDto? _editingType;
    private string _editDisplayName = string.Empty;
    private string _editIcon = string.Empty;
    private string _editCategoryFolder = string.Empty;
    private List<string> _editExtensions = [];
    private string _newExtension = string.Empty;

    // ── Material icon lookup ─────────────────────────────────────────────
    private static readonly Dictionary<string, string> IconMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["MenuBook"]     = Icons.Material.Filled.MenuBook,
        ["Headphones"]   = Icons.Material.Filled.Headphones,
        ["AutoStories"]  = Icons.Material.Filled.AutoStories,
        ["Movie"]        = Icons.Material.Filled.Movie,
        ["Tv"]           = Icons.Material.Filled.Tv,
        ["MusicNote"]    = Icons.Material.Filled.MusicNote,
        ["Podcasts"]     = Icons.Material.Filled.Podcasts,
        ["Description"]  = Icons.Material.Filled.Description,
        ["Folder"]       = Icons.Material.Filled.Folder,
        ["Photo"]        = Icons.Material.Filled.Photo,
        ["VideoLibrary"] = Icons.Material.Filled.VideoLibrary,
        ["AudioFile"]    = Icons.Material.Filled.AudioFile,
        ["Article"]      = Icons.Material.Filled.Article,
        ["Book"]         = Icons.Material.Filled.Book,
        ["LibraryBooks"] = Icons.Material.Filled.LibraryBooks,
        ["LocalLibrary"] = Icons.Material.Filled.LocalLibrary,
        ["Hearing"]      = Icons.Material.Filled.Hearing,
        ["Mic"]          = Icons.Material.Filled.Mic,
        ["Album"]        = Icons.Material.Filled.Album,
        ["Camera"]       = Icons.Material.Filled.Camera,
        ["Image"]        = Icons.Material.Filled.Image,
        ["PictureAsPdf"] = Icons.Material.Filled.PictureAsPdf,
        ["Code"]         = Icons.Material.Filled.Code,
        ["Science"]      = Icons.Material.Filled.Science,
        ["School"]       = Icons.Material.Filled.School,
        ["SportsEsports"]= Icons.Material.Filled.SportsEsports,
        ["Newspaper"]    = Icons.Material.Filled.Newspaper,
        ["Dashboard"]    = Icons.Material.Filled.Dashboard,
        ["Star"]         = Icons.Material.Filled.Star,
        ["Cloud"]        = Icons.Material.Filled.Cloud,
    };

    private static string ResolveIcon(string iconName)
    {
        if (string.IsNullOrWhiteSpace(iconName)) return Icons.Material.Filled.Description;
        return IconMap.TryGetValue(iconName, out var resolved) ? resolved : Icons.Material.Filled.Description;
    }

    // ── Lifecycle ──────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _providers = await Orchestrator.GetProviderStatusAsync();
            if (_providers.Count == 0)
            {
                _engineDown = true;
                return;
            }

            var slots = await Orchestrator.GetProviderSlotsAsync();
            _slots = slots ?? new Dictionary<string, ProviderSlotDto>();

            var mediaTypesConfig = await Orchestrator.GetMediaTypesAsync();
            _mediaTypeDefinitions = mediaTypesConfig?.Types ?? MediaTypeConfigurationDto.Defaults();
            _activeMediaType = _mediaTypeDefinitions.FirstOrDefault()?.DisplayName ?? string.Empty;

            // Check Wikidata reachability.
            var wikidata = _providers.FirstOrDefault(p =>
                string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase));
            _wikidataReachable = wikidata?.IsReachable ?? false;
        }
        catch
        {
            _engineDown = true;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Provider helpers ─────────────────────────────────────────────────

    /// <summary>Returns available providers (enabled + reachable) for drag-drop slots.</summary>
    private List<ProviderStatusDto> GetAllVisibleProviders()
    {
        return _providers
            .Where(p => ProviderAccentMap.IsVisibleProvider(p.Name))
            .Where(p => !string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase))
            .Where(p => p.Enabled && p.IsReachable)
            .ToList();
    }

    /// <summary>Returns providers that are disabled or offline — shown in the non-interactive section.</summary>
    private List<ProviderStatusDto> GetUnavailableProviders()
    {
        return _providers
            .Where(p => ProviderAccentMap.IsVisibleProvider(p.Name))
            .Where(p => !string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase))
            .Where(p => !p.Enabled || !p.IsReachable)
            .ToList();
    }

    // ── Drag-drop model ──────────────────────────────────────────────────

    private List<ProviderDragItem> GetDragItems(string mediaType)
    {
        var allProviders = GetAllVisibleProviders();
        var slot = GetSlot(mediaType);
        var items = new List<ProviderDragItem>();

        foreach (var provider in allProviders)
        {
            items.Add(new ProviderDragItem { ProviderName = provider.Name, Zone = "available" });
        }

        if (!string.IsNullOrWhiteSpace(slot.Primary))
            items.Add(new ProviderDragItem { ProviderName = slot.Primary, Zone = "primary" });
        if (!string.IsNullOrWhiteSpace(slot.Secondary))
            items.Add(new ProviderDragItem { ProviderName = slot.Secondary, Zone = "secondary" });
        if (!string.IsNullOrWhiteSpace(slot.Tertiary))
            items.Add(new ProviderDragItem { ProviderName = slot.Tertiary, Zone = "tertiary" });

        return items;
    }

    private ProviderSlotDto GetSlot(string mediaType)
    {
        return _slots.TryGetValue(mediaType, out var slot) ? slot : new ProviderSlotDto();
    }

    private async Task OnItemDropped(MudItemDropInfo<ProviderDragItem> dropInfo, string mediaType)
    {
        if (dropInfo.Item is null) return;

        var providerName = dropInfo.Item.ProviderName;
        var targetZone = dropInfo.DropzoneIdentifier;
        var slot = GetSlot(mediaType);

        // Move semantics: clear the provider from any existing slot before assigning.
        if (targetZone is "primary" or "secondary" or "tertiary")
        {
            if (string.Equals(slot.Primary, providerName, StringComparison.OrdinalIgnoreCase))
                slot = slot with { Primary = null };
            if (string.Equals(slot.Secondary, providerName, StringComparison.OrdinalIgnoreCase))
                slot = slot with { Secondary = null };
            if (string.Equals(slot.Tertiary, providerName, StringComparison.OrdinalIgnoreCase))
                slot = slot with { Tertiary = null };
        }

        switch (targetZone)
        {
            case "primary":
                slot = slot with { Primary = providerName };
                break;
            case "secondary":
                slot = slot with { Secondary = providerName };
                break;
            case "tertiary":
                slot = slot with { Tertiary = providerName };
                break;
            case "available":
                if (string.Equals(slot.Primary, providerName, StringComparison.OrdinalIgnoreCase))
                    slot = slot with { Primary = null };
                if (string.Equals(slot.Secondary, providerName, StringComparison.OrdinalIgnoreCase))
                    slot = slot with { Secondary = null };
                if (string.Equals(slot.Tertiary, providerName, StringComparison.OrdinalIgnoreCase))
                    slot = slot with { Tertiary = null };
                break;
        }

        _slots[mediaType] = slot;
        await SaveSlotsAsync();
    }

    private async Task RemoveFromSlot(ProviderDragItem item, string mediaType)
    {
        var slot = GetSlot(mediaType);
        var name = item.ProviderName;

        if (string.Equals(slot.Primary, name, StringComparison.OrdinalIgnoreCase))
            slot = slot with { Primary = null };
        if (string.Equals(slot.Secondary, name, StringComparison.OrdinalIgnoreCase))
            slot = slot with { Secondary = null };
        if (string.Equals(slot.Tertiary, name, StringComparison.OrdinalIgnoreCase))
            slot = slot with { Tertiary = null };

        _slots[mediaType] = slot;
        await SaveSlotsAsync();
    }

    private async Task SaveSlotsAsync()
    {
        var ok = await Orchestrator.UpdateProviderSlotsAsync(_slots);
        if (ok)
            Snackbar.Add("Provider slots saved.", Severity.Success);
        else
            Snackbar.Add("Failed to save provider slots.", Severity.Error);

        StateHasChanged();
    }

    private void OnTabChanged(int _) { /* Re-render with new tab's data */ }

    private async Task RefreshProvidersAsync()
    {
        try
        {
            _providers = await Orchestrator.GetProviderStatusAsync();
            var wikidata = _providers.FirstOrDefault(p =>
                string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase));
            _wikidataReachable = wikidata?.IsReachable ?? false;
            StateHasChanged();
        }
        catch
        {
            // Non-fatal: provider list will be stale but usable.
        }
    }

    // ── Media type config ────────────────────────────────────────────────

    private void OpenMediaTypeConfigDialog(MediaTypeDefinitionDto def) => OpenMediaTypeConfig(def);

    private void OpenMediaTypeConfig(MediaTypeDefinitionDto def)
    {
        _editingType = def;
        _editDisplayName = def.DisplayName;
        _editIcon = def.Icon;
        _editCategoryFolder = def.CategoryFolder;
        _editExtensions = new List<string>(def.Extensions);
        _newExtension = string.Empty;
        _configOpen = true;
    }

    private void CloseMediaTypeConfig()
    {
        _configOpen = false;
        _editingType = null;
    }

    private void AddExtension()
    {
        var ext = _newExtension.Trim();
        if (string.IsNullOrWhiteSpace(ext)) return;
        if (!ext.StartsWith('.')) ext = "." + ext;
        ext = ext.ToLowerInvariant();
        if (!_editExtensions.Contains(ext))
            _editExtensions.Add(ext);
        _newExtension = string.Empty;
    }

    private async Task SaveMediaTypeConfigAsync()
    {
        if (_editingType is null) return;
        _savingType = true;
        try
        {
            var oldDisplayName = _editingType.DisplayName;

            _editingType.DisplayName = _editDisplayName;
            _editingType.Icon = _editIcon;
            _editingType.CategoryFolder = _editCategoryFolder;
            _editingType.Extensions = new List<string>(_editExtensions);

            var config = new MediaTypeConfigurationDto
            {
                Version = "1.0",
                Types = _mediaTypeDefinitions,
            };
            var ok = await Orchestrator.SaveMediaTypesAsync(config);
            if (ok)
            {
                // If display name changed, migrate the slot key.
                if (!string.Equals(oldDisplayName, _editDisplayName, StringComparison.Ordinal)
                    && _slots.Remove(oldDisplayName, out var slotValue))
                {
                    _slots[_editDisplayName] = slotValue;
                    await Orchestrator.UpdateProviderSlotsAsync(_slots);
                }

                Snackbar.Add($"{_editDisplayName} saved.", Severity.Success);
                CloseMediaTypeConfig();
            }
            else
            {
                Snackbar.Add("Failed to save media type.", Severity.Error);
            }
        }
        finally
        {
            _savingType = false;
            StateHasChanged();
        }
    }

    private bool _confirmDeleteOpen;

    private void RequestDeleteMediaType()
    {
        if (_editingType is null || _editingType.BuiltIn) return;
        _confirmDeleteOpen = true;
    }

    private void CancelDelete() => _confirmDeleteOpen = false;

    private async Task ConfirmDeleteMediaTypeAsync()
    {
        _confirmDeleteOpen = false;
        if (_editingType is null) return;

        var ok = await Orchestrator.DeleteMediaTypeAsync(_editingType.Key);
        if (ok)
        {
            _mediaTypeDefinitions.Remove(_editingType);
            _slots.Remove(_editingType.DisplayName);
            Snackbar.Add($"{_editingType.DisplayName} deleted.", Severity.Success);
            CloseMediaTypeConfig();
        }
        else
        {
            Snackbar.Add("Failed to delete media type.", Severity.Error);
        }
    }

    private async Task OpenAddMediaTypeDialog()
    {
        var parameters = new DialogParameters<AddMediaTypeDialog>();
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
        };
        var dialog = await DialogService.ShowAsync<AddMediaTypeDialog>("Add Media Type", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is MediaTypeDefinitionDto newType)
        {
            var config = await Orchestrator.AddMediaTypeAsync(newType);
            if (config is not null)
            {
                _mediaTypeDefinitions = config.Types;
                Snackbar.Add($"{newType.DisplayName} added.", Severity.Success);
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("Failed to add media type.", Severity.Error);
            }
        }
    }

