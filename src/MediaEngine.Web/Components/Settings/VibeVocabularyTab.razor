@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator

<div class="tl-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">Vibe vocabulary</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@(_config is null || _saving)">Save vocabulary</MudButton>
    </MudStack>

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3">
        Vocabulary is loaded from AI config and affects AI tagging only when the vibe tags feature is enabled. Existing items are not retagged immediately because no Local AI retag endpoint exists.
    </MudAlert>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <MudAlert Severity="@_messageSeverity" Variant="Variant.Outlined" Class="mb-3">@_message</MudAlert>
    }

    @if (_config is null)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">AI config unavailable. Vocabulary cannot be edited.</MudAlert>
    }
    else
    {
        <MudExpansionPanels MultiExpansion="true">
            @foreach (var category in _config.VibeVocabulary.Keys.OrderBy(k => k).ToList())
            {
                var key = category;
                var tags = _config.VibeVocabulary[key];
                <MudExpansionPanel Expanded="true">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.subtitle2">@key</MudText>
                            <MudChip T="string" Size="Size.Small">@tags.Count tags</MudChip>
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Row="true" Style="flex-wrap: wrap; gap: 8px;" Class="mb-4">
                            @foreach (var tag in tags.ToList())
                            {
                                var captured = tag;
                                <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" OnClose="@(() => RemoveTag(key, captured))">@captured</MudChip>
                            }
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudTextField @bind-Value="_newTags[key]" Placeholder="New tag" Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => AddTag(key))">Add</MudButton>
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    }
</div>

@code {
    private AiConfigDto? _config;
    private Dictionary<string, string> _newTags = new(StringComparer.OrdinalIgnoreCase);
    private bool _saving;
    private string? _message;
    private Severity _messageSeverity = Severity.Info;

    protected override async Task OnInitializedAsync()
    {
        _config = await Orchestrator.GetAiConfigAsync();
        if (_config is not null)
            _newTags = _config.VibeVocabulary.Keys.ToDictionary(k => k, _ => "", StringComparer.OrdinalIgnoreCase);
    }

    private void AddTag(string category)
    {
        if (_config is null)
            return;

        var raw = _newTags.GetValueOrDefault(category)?.Trim().ToLowerInvariant() ?? "";
        if (string.IsNullOrWhiteSpace(raw))
        {
            SetMessage("Empty tags are not allowed.", Severity.Warning);
            return;
        }

        var tags = _config.VibeVocabulary[category];
        if (tags.Any(t => t.Equals(raw, StringComparison.OrdinalIgnoreCase)))
        {
            SetMessage($"Duplicate tag '{raw}' was not added.", Severity.Warning);
            return;
        }

        tags.Add(raw);
        _newTags[category] = "";
    }

    private void RemoveTag(string category, string tag)
    {
        _config?.VibeVocabulary[category].RemoveAll(t => t.Equals(tag, StringComparison.OrdinalIgnoreCase));
    }

    private async Task SaveAsync()
    {
        if (_config is null)
            return;

        foreach (var (category, tags) in _config.VibeVocabulary)
        {
            if (tags.Any(string.IsNullOrWhiteSpace) || tags.Count != tags.Distinct(StringComparer.OrdinalIgnoreCase).Count())
            {
                SetMessage($"Fix empty or duplicate tags in {category}.", Severity.Error);
                return;
            }
        }

        _saving = true;
        var ok = await Orchestrator.SaveAiConfigAsync(_config);
        _saving = false;
        SetMessage(ok ? "Vocabulary saved." : "Vocabulary could not be saved.", ok ? Severity.Success : Severity.Error);
    }

    private void SetMessage(string message, Severity severity)
    {
        _message = message;
        _messageSeverity = severity;
    }
}
