@namespace MediaEngine.Web.Components.Settings
@inject IStringLocalizer<SharedStrings> L

@* Vibe Vocabulary — Editable mood and atmosphere tag lists per media type.
   The AI uses these lists as preferred candidates when generating vibe tags
   during enrichment, but is not constrained to them. *@

<div class="st-page">

    @* ── Section Header ──────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Style" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">@L["Vibes_PageTitle"]</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
        @L["Vibes_PageDescription"]
    </MudText>
    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true" Class="mb-6">
        @L["Vibes_InfoAlert"]
    </MudAlert>

    @* ── Expansion Panels ────────────────────────────────────────────────── *@
    <MudExpansionPanels MultiExpansion="true">

        @foreach (var category in _vocabulary.Keys)
        {
            var tags      = _vocabulary[category];
            var tagCount  = tags.Count;
            var key       = category; // capture for closures

            <MudExpansionPanel>
                <TitleContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@key</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                 Style="opacity: 0.75;">
                            @tagCount @(tagCount == 1 ? L["Vibes_TagSingular"] : L["Vibes_TagPlural"])
                        </MudChip>
                    </MudStack>
                </TitleContent>
                <ChildContent>
                    @* Current tags rendered as closeable chips *@
                    <MudStack Row="true" Style="flex-wrap: wrap; gap: 8px;" Class="mb-4">
                        @foreach (var tag in tags.ToList())
                        {
                            var capturedTag = tag;
                            <MudChip T="string"
                                     Variant="Variant.Outlined"
                                     Size="Size.Small"
                                     OnClose="@(() => RemoveTag(key, capturedTag))"
                                     Style="margin: 0;">
                                @capturedTag
                            </MudChip>
                        }
                        @if (tags.Count == 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @L["Vibes_NoTags"]
                            </MudText>
                        }
                    </MudStack>

                    @* Add new tag row *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudTextField @bind-Value="_newTagInputs[key]"
                                      Placeholder="@L["Vibes_NewTagPlaceholder"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="40"
                                      Style="max-width: 260px;"
                                      OnKeyDown="@(e => OnTagInputKeyDown(e, key))"
                                      Immediate="true" />
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="@(() => AddTag(key))"
                                   Disabled="@string.IsNullOrWhiteSpace(_newTagInputs[key])">
                            @L["Vibes_Add"]
                        </MudButton>
                    </MudStack>
                </ChildContent>
            </MudExpansionPanel>
        }

    </MudExpansionPanels>

    @* ── Reset footer ─────────────────────────────────────────────────────── *@
    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-6">
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   Size="Size.Small"
                   OnClick="@ResetToDefaults">
            @L["Vibes_ResetToDefaults"]
        </MudButton>
    </MudStack>

</div>

@code {

    // ── Default vocabulary ───────────────────────────────────────────────────────

    private static Dictionary<string, List<string>> BuildDefaults() => new()
    {
        ["Books"] =
        [
            "atmospheric", "page-turner", "philosophical", "lyrical",
            "haunting", "whimsical", "dense", "accessible", "experimental", "cozy"
        ],
        ["Movies & TV"] =
        [
            "cinematic", "slow-burn", "ensemble", "gritty", "stylized", "dialogue-driven"
        ],
        ["Music"] =
        [
            "ambient", "energetic", "melancholic", "groovy", "ethereal", "raw"
        ],
        ["Comics"] =
        [
            "noir", "dynamic", "minimalist", "splash-heavy"
        ],
        ["Podcasts"] =
        [
            "conversational", "investigative", "narrative", "interview"
        ],
    };

    // ── State ────────────────────────────────────────────────────────────────────

    private Dictionary<string, List<string>> _vocabulary = BuildDefaults();

    // One input buffer per category
    private Dictionary<string, string> _newTagInputs = [];

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        // Initialise one input buffer per category
        foreach (var key in _vocabulary.Keys)
            _newTagInputs[key] = string.Empty;
    }

    // ── Tag operations ───────────────────────────────────────────────────────────

    private void AddTag(string category)
    {
        var raw = _newTagInputs[category]?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(raw)) return;

        var tag = raw.ToLowerInvariant();
        if (!_vocabulary[category].Contains(tag, StringComparer.OrdinalIgnoreCase))
            _vocabulary[category].Add(tag);

        _newTagInputs[category] = string.Empty;
    }

    private void RemoveTag(string category, string tag)
    {
        _vocabulary[category].RemoveAll(t =>
            t.Equals(tag, StringComparison.OrdinalIgnoreCase));
    }

    private async Task OnTagInputKeyDown(KeyboardEventArgs e, string category)
    {
        if (e.Key == "Enter")
        {
            AddTag(category);
            await Task.CompletedTask;
        }
    }

    private void ResetToDefaults()
    {
        _vocabulary    = BuildDefaults();
        _newTagInputs  = _vocabulary.Keys.ToDictionary(k => k, _ => string.Empty);
    }
}
