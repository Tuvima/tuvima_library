@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator

<AppHostedDialog Title="Browse Folders"
                 Icon="@Icons.Material.Outlined.FolderOpen"
                 OnClose="Cancel">
    <ChildContent>
        <div class="folder-browser-toolbar">
            <AppIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                           Size="AppControlSize.Compact"
                           Disabled="@(string.IsNullOrEmpty(_currentPath) || _loading)"
                           OnClick="@NavigateUpAsync"
                           Tooltip="Up one level"
                           AriaLabel="Up one level" />
            <AppIconButton Icon="@Icons.Material.Filled.Home"
                           Size="AppControlSize.Compact"
                           Disabled="@(string.IsNullOrEmpty(_currentPath) || _loading)"
                           OnClick="@NavigateToRootAsync"
                           Tooltip="Drive roots"
                           AriaLabel="Drive roots" />
            <code class="folder-browser-path">
                @(string.IsNullOrEmpty(_currentPath) ? "My Computer" : _currentPath)
            </code>
        </div>

        <div class="folder-browser-list">
            @if (_loading)
            {
                <div class="folder-browser-state">
                    <AppProgressBar Indeterminate="true" />
                </div>
            }
            else if (_directories.Count == 0)
            {
                <div class="folder-browser-state">
                    <MudIcon Icon="@Icons.Material.Outlined.FolderOff" />
                    <span>No accessible folders</span>
                </div>
            }
            else
            {
                @foreach (var dir in _directories)
                {
                    <div class="folder-browser-row" @onclick="@(() => NavigateIntoAsync(dir))">
                        <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" />
                        <span>@dir</span>
                    </div>
                }
            }
        </div>
    </ChildContent>

    <FooterContent>
        <AppActionBar Align="AppHorizontalAlignment.End">
            <AppButton Label="Cancel" ButtonStyle="AppButtonStyle.Text" OnClick="Cancel" />
            <AppButton Label="Select Folder"
                       ButtonStyle="AppButtonStyle.Filled"
                       Tone="AppUiTone.Primary"
                       Disabled="@string.IsNullOrEmpty(_currentPath)"
                       OnClick="Select" />
        </AppActionBar>
    </FooterContent>
</AppHostedDialog>

@code {
    [CascadingParameter]
    private dynamic DialogInstance { get; set; } = null!;
    [Parameter]
    public string? InitialPath { get; set; }

    private string        _currentPath = string.Empty;
    private string?       _parentPath;
    private List<string>  _directories = [];
    private bool          _loading;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(InitialPath) && Directory.Exists(InitialPath))
            await LoadAsync(InitialPath);
        else
            await LoadAsync(null);
    }

    private async Task LoadAsync(string? path)
    {
        _loading = true;
        StateHasChanged();

        var result = await Orchestrator.BrowseDirectoryAsync(path);

        if (result is not null)
        {
            _currentPath = result.CurrentPath;
            _parentPath  = result.ParentPath;
            _directories = result.Directories;
        }
        else
        {
            _directories = [];
        }

        _loading = false;
        StateHasChanged();
    }

    private Task NavigateIntoAsync(string dirName)
    {
        var target = string.IsNullOrEmpty(_currentPath)
            ? dirName
            : Path.Combine(_currentPath, dirName);
        return LoadAsync(target);
    }

    private Task NavigateUpAsync()
        => LoadAsync(_parentPath);

    private Task NavigateToRootAsync()
        => LoadAsync(null);

    private void Select()
        => DialogInstance.Close(DialogResult.Ok(_currentPath));

    private void Cancel()
        => DialogInstance.Cancel();
}
