@namespace MediaEngine.Web.Components.Settings
@using System.Globalization
@using System.Text.RegularExpressions
@using MediaEngine.Domain.Enums
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@inject IStringLocalizer<SharedStrings> L

<details class="ingestion-activity-shell">
    <summary class="ingestion-activity-shell__summary">
        <span class="ingestion-activity-shell__icon">
            <MudIcon Icon="@Icons.Material.Outlined.Engineering" />
        </span>
        <span class="ingestion-activity-shell__copy">
            <strong>Workers</strong>
            <span>Background enrichment workers and the latest items they touched.</span>
        </span>
        <span class="ingestion-activity-shell__meta">
            <span>@RunningWorkerSummary</span>
            <span>@IdleWorkerSummary</span>
        </span>
        <MudIcon Icon="@Icons.Material.Outlined.ExpandMore" Class="ingestion-activity-shell__chevron" />
    </summary>

    <section class="ingestion-activity-grid">
        <div class="ingestion-current">
            <div class="ingestion-current__header">
                <div>
                    <MudText Typo="Typo.subtitle2">@L["Ingestion_CurrentActivity"]</MudText>
                    <span>Worker status with current and recently completed items.</span>
                </div>
                <div class="ingestion-current__actions">
                    <span class="ingestion-current__live">Live updates</span>
                    <AppButton Href="/settings/activity" Size="AppControlSize.Compact" Label="View activity history" />
                </div>
            </div>

            @if (CurrentRows.Count == 0)
            {
                <div class="ingestion-current__empty">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" />
                    <div>
                        <strong>No workers are running</strong>
                        <span>The Engine is monitoring watched folders and waiting for new work.</span>
                    </div>
                </div>
            }
            else
            {
                @foreach (var row in CurrentRows)
                {
                    <article class="ingestion-current-row @row.StageClass">
                        <AppButton ButtonStyle="AppButtonStyle.Ghost"
                                   FullWidth="true"
                                   Class="@CurrentRowButtonClass(row)"
                                   OnClick="@(() => SelectRow(row.Key))">
                            <span class="@ProgressIconClass(row.Percent)">
                                <MudIcon Icon="@row.Icon" />
                            </span>
                            <span class="ingestion-current-row__copy">
                                <strong>@row.Message</strong>
                                <span>@row.DetailLine</span>
                                <small>@row.QueueSummary</small>
                            </span>
                            <span class="ingestion-current-row__work">
                                <span class="ingestion-current-row__counts">@row.Counts</span>
                                @if (row.ShowProgress)
                                {
                                    <span class="ingestion-current-row__bar">
                                        <AppProgressBar Value="@row.Percent" Class="ingestion-current-row__progress" />
                                        <span>@row.Percent.ToString("0", CultureInfo.CurrentCulture)%</span>
                                    </span>
                                }
                                else
                                {
                                    <span class="ingestion-current-row__status @row.StatusCss">@row.StatusLabel</span>
                                }
                            </span>
                            <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" />
                        </AppButton>
                    </article>
                }
            }
        </div>

        <aside class="ingestion-activity-detail">
            @if (SelectedRow is null)
            {
                <div class="ingestion-activity-detail__empty">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" />
                    <div>
                        <strong>No worker selected</strong>
                        <span>Select a worker to see what it is working on and what it finished recently.</span>
                    </div>
                </div>
            }
            else
            {
                var detail = BuildDetail(SelectedRow);
                <div class="ingestion-activity-detail__header">
                    <div>
                        <MudText Typo="Typo.subtitle2">@detail.Title</MudText>
                        <span>@detail.Subtitle</span>
                    </div>
                    <AppButton Href="@detail.ActivityHref"
                               Size="AppControlSize.Compact"
                               ButtonStyle="AppButtonStyle.Outlined"
                               StartIcon="@Icons.Material.Outlined.History"
                               Label="Full activity" />
                </div>

                @if (detail.WorkingItems.Count == 0 && detail.CompletedItems.Count == 0)
                {
                    <div class="ingestion-worker-list-empty">
                        <MudIcon Icon="@Icons.Material.Outlined.HourglassEmpty" />
                        <span>No item-level worker history has been reported yet.</span>
                    </div>
                }
                else
                {
                    @if (detail.WorkingItems.Count > 0)
                    {
                        <div class="ingestion-activity-detail__section">
                            <strong>Working now</strong>
                            <ol class="ingestion-worker-items">
                                @foreach (var item in detail.WorkingItems)
                                {
                                    <li>
                                        <span>@item.Label</span>
                                        <small>@item.Meta</small>
                                    </li>
                                }
                            </ol>
                        </div>
                    }

                    @if (detail.CompletedItems.Count > 0)
                    {
                        <div class="ingestion-activity-detail__section">
                            <strong>Recently completed</strong>
                            <ol class="ingestion-worker-items">
                                @foreach (var item in detail.CompletedItems)
                                {
                                    <li>
                                        <span>@item.Label</span>
                                        <small>@item.Meta</small>
                                    </li>
                                }
                            </ol>
                        </div>
                    }
                }
            }
        </aside>
    </section>
</details>

@code {
    private static readonly TimeSpan CompletedWorkerFreshness = TimeSpan.FromMinutes(2);

    [Parameter] public IReadOnlyList<IngestionOperationsJobViewModel> Jobs { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionCurrentActivityViewModel> CurrentActivities { get; set; } = [];
    [Parameter] public IReadOnlyList<ActivityEntryViewModel> Activities { get; set; } = [];
    [Parameter] public IReadOnlyList<ReviewItemViewModel> PendingReviews { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionReviewReasonViewModel> ReviewReasons { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionDashboardStage> Stages { get; set; } = [];
    [Parameter] public int ReviewTotal { get; set; }

    private string? _selectedRowKey;

    private string RunningWorkerSummary
    {
        get
        {
            var count = CurrentRows.Count(row => row.IsRunning);
            return count == 1
                ? "1 running"
                : $"{count.ToString("N0", CultureInfo.CurrentCulture)} running";
        }
    }

    private string IdleWorkerSummary
    {
        get
        {
            var count = CurrentRows.Count(row => !row.IsRunning);
            return count == 1
                ? "1 idle"
                : $"{count.ToString("N0", CultureInfo.CurrentCulture)} idle";
        }
    }

    protected override void OnParametersSet()
    {
        var rows = CurrentRows;
        if (rows.Count == 0)
        {
            _selectedRowKey = null;
            return;
        }

        if (string.IsNullOrWhiteSpace(_selectedRowKey) || rows.All(row => !row.Key.Equals(_selectedRowKey, StringComparison.OrdinalIgnoreCase)))
        {
            _selectedRowKey = rows
                .FirstOrDefault(row => row.IsRunning)?.Key
                ?? rows[0].Key;
        }
    }

    private IReadOnlyList<CurrentRow> CurrentRows
    {
        get
        {
            var rows = CurrentActivities
                .Where(activity => !string.IsNullOrWhiteSpace(activity.Message))
                .Where(activity => !activity.StageKey.Equals("validation", StringComparison.OrdinalIgnoreCase))
                .Where(activity => !activity.StageKey.Equals("summary", StringComparison.OrdinalIgnoreCase))
                .Select(CurrentRow.FromActivity)
                .ToList();

            if (rows.Count > 0)
            {
                return rows;
            }

            return Jobs
                .Where(job => job.Status.Equals("running", StringComparison.OrdinalIgnoreCase)
                    || job.Status.Equals("processing", StringComparison.OrdinalIgnoreCase)
                    || job.Status.Equals("active", StringComparison.OrdinalIgnoreCase))
                .Select(job => CurrentRow.FromJob(job, Stages))
                .ToList();
        }
    }

    private CurrentRow? SelectedRow =>
        CurrentRows.FirstOrDefault(row => row.Key.Equals(_selectedRowKey, StringComparison.OrdinalIgnoreCase))
        ?? CurrentRows.FirstOrDefault();

    private WorkerDetail BuildDetail(CurrentRow row)
    {
        var key = DetailStageKey(row.Key);
        var workingItems = BuildWorkingItems(row);
        var completedItems = BuildCompletedItems(row, key);
        var subtitle = row.IsRunning
            ? $"{row.ActiveCount.ToString("N0", CultureInfo.CurrentCulture)} active - {row.Counts}"
            : $"Idle - last update {row.Updated}";

        return new WorkerDetail(
            WorkerTitle(key),
            subtitle,
            ActivityHref(key),
            workingItems,
            completedItems);
    }

    private IReadOnlyList<WorkerItem> BuildWorkingItems(CurrentRow row)
    {
        if (!row.IsRunning)
        {
            return [];
        }

        return DistinctWorkerItems(
            EnumerateLabels(row.Batch?.ActiveItems, "Active item")
                .Concat(EnumerateLabels(row.SampleItems, "Current item")))
            .Take(10)
            .ToList();
    }

    private IReadOnlyList<WorkerItem> BuildCompletedItems(CurrentRow row, string key)
    {
        var activityItems = RecentActivityItemsForWorker(key);
        var batchItems = EnumerateLabels(row.Batch?.CompletedPreview, "Completed");
        var idleSamples = row.IsRunning
            ? []
            : EnumerateLabels(row.SampleItems, row.Percent >= 100 ? "Completed" : "Last seen");

        var ordered = key.Equals("artwork", StringComparison.OrdinalIgnoreCase)
            ? activityItems.Concat(batchItems).Concat(idleSamples)
            : batchItems.Concat(activityItems).Concat(idleSamples);

        return DistinctWorkerItems(ordered)
            .Take(10)
            .ToList();
    }

    private IReadOnlyList<WorkerItem> RecentActivityItemsForWorker(string workerKey) =>
        Activities
            .Where(activity => ActivityMatchesWorker(workerKey, activity.ActionType))
            .Select(activity => new WorkerItem(
                FirstNonBlank(
                    activity.RichData?.Title,
                    activity.ReviewData?.Title,
                    activity.CollectionName,
                    ExtractTitleFromDetail(activity.Detail),
                    FormatTrigger(activity.ActionType)),
                activity.RelativeTime))
            .Where(item => !string.IsNullOrWhiteSpace(item.Label))
            .Take(10)
            .ToList();

    private static IEnumerable<WorkerItem> EnumerateLabels(IReadOnlyList<string>? labels, string meta)
    {
        if (labels is null)
        {
            yield break;
        }

        foreach (var label in labels)
        {
            if (!string.IsNullOrWhiteSpace(label))
            {
                yield return new WorkerItem(label, meta);
            }
        }
    }

    private static IReadOnlyList<WorkerItem> DistinctWorkerItems(IEnumerable<WorkerItem> items)
    {
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var result = new List<WorkerItem>();
        foreach (var item in items)
        {
            var label = item.Label.Trim();
            if (label.Length == 0 || !seen.Add(label))
            {
                continue;
            }

            result.Add(item with { Label = label });
        }

        return result;
    }

    private static bool ActivityMatchesWorker(string workerKey, string? actionType) =>
        workerKey switch
        {
            "artwork" => IsAction(actionType, SystemActionType.CoverArtSaved, SystemActionType.HeroBannerGenerated),
            "wikidata" => IsAction(
                actionType,
                SystemActionType.BridgeSyncUpdated,
                SystemActionType.HydrationStage1Completed,
                SystemActionType.HydrationStage2Completed,
                SystemActionType.MetadataHydrated,
                SystemActionType.UniverseMatchRecovered),
            "relationships" => IsAction(
                actionType,
                SystemActionType.CollectionAssigned,
                SystemActionType.CollectionCreated,
                SystemActionType.CollectionMerged,
                SystemActionType.NarrativeRootResolved,
                SystemActionType.RelationshipDiscovered,
                SystemActionType.UniverseXmlUpdated),
            "people" => IsAction(
                actionType,
                SystemActionType.PersonHydrated,
                SystemActionType.PersonMerged,
                SystemActionType.CharacterEnriched,
                SystemActionType.LocationEnriched,
                SystemActionType.OrganizationEnriched),
            _ => false,
        };

    private static bool IsAction(string? actionType, params string[] allowed) =>
        !string.IsNullOrWhiteSpace(actionType)
        && allowed.Contains(actionType, StringComparer.OrdinalIgnoreCase);

    private static string? ExtractTitleFromDetail(string? detail)
    {
        if (string.IsNullOrWhiteSpace(detail))
        {
            return null;
        }

        var cleaned = detail.Trim();
        var quotedTitle = Regex.Match(cleaned, "\"([^\"]+)\"");
        if (quotedTitle.Success)
        {
            return quotedTitle.Groups[1].Value.Trim();
        }

        var match = Regex.Match(cleaned, @"(?:for|to|from)\s+(.+?)(?:[.]$|$)", RegexOptions.IgnoreCase);
        if (match.Success)
        {
            return match.Groups[1].Value.Trim();
        }

        return cleaned.Length <= 80 ? cleaned : null;
    }

    private static string WorkerTitle(string key) => key switch
    {
        "artwork" => "Artwork worker",
        "wikidata" => "Wikidata QID worker",
        "relationships" => "Series and relationships worker",
        "people" => "People and cast worker",
        _ => "Library worker",
    };

    private static string ActivityHref(string key) => "/settings/activity";

    private static string DetailStageKey(string? stageKey) => stageKey?.ToLowerInvariant() switch
    {
        "artwork" => "artwork",
        "wikidata" => "wikidata",
        "relationships" => "relationships",
        "people" or "enrichment" => "people",
        _ => "scanning",
    };

    private sealed record WorkerItem(string Label, string? Meta);

    private sealed record WorkerDetail(
        string Title,
        string Subtitle,
        string ActivityHref,
        IReadOnlyList<WorkerItem> WorkingItems,
        IReadOnlyList<WorkerItem> CompletedItems);

    private sealed record CurrentRow(
        string Key,
        string Message,
        string Detail,
        string Source,
        string Counts,
        string Updated,
        DateTimeOffset? LastUpdatedTime,
        string Icon,
        double Percent,
        Color Color,
        string QueueSummary,
        IReadOnlyList<string> SampleItems,
        int ActiveCount,
        int QueuedCount,
        string MetricLabel,
        string MetricValue,
        string MetricToneCss,
        string StageClass,
        IngestionActivityBatchViewModel? Batch)
    {
        public bool IsRunning => ActiveCount > 0;

        public bool IsQueued => !IsRunning && QueuedCount > 0;

        public bool IsRecentlyComplete =>
            !IsRunning
            && !IsQueued
            && Percent >= 100
            && LastUpdatedTime.HasValue
            && DateTimeOffset.UtcNow - LastUpdatedTime.Value.ToUniversalTime() <= CompletedWorkerFreshness;

        public bool ShowProgress => (IsRunning && Percent < 100) || IsRecentlyComplete;

        public string StatusLabel => IsRunning ? "Running" : IsQueued ? "Queued" : IsRecentlyComplete ? "Complete" : "Idle";

        public string StatusCss => IsRunning ? "is-running" : IsQueued ? "is-running" : IsRecentlyComplete ? "is-complete" : "is-idle";

        public string DetailLine => IsRunning
            ? FirstNonBlank(Detail, "Working")
            : IsQueued ? FirstNonBlank(Detail, "Waiting for the worker to pick up queued work")
            : $"Idle - last update {Updated}";

        public static CurrentRow FromActivity(IngestionCurrentActivityViewModel activity)
        {
            var percent = Math.Clamp(activity.PercentComplete, 0, 100);
            var activeCount = Math.Max(0, activity.ActiveCount);
            var queuedCount = Math.Max(0, activity.QueuedCount);
            return new CurrentRow(
                FirstNonBlank(activity.StageKey, activity.Message),
                FirstNonBlank(activity.Message, "Processing files"),
                FirstNonBlank(activity.Detail, activity.CurrentItem, "Working on the current item"),
                ShortPath(activity.Source),
                FormatCounts(activity.ProcessedCount, activity.TotalCount, activity.CountUnit),
                FormatUpdated(activity.LastUpdatedTime),
                activity.LastUpdatedTime,
                StageIcon(activity.StageKey),
                percent,
                StageColor(activity.StageKey),
                FormatQueue(queuedCount, activeCount),
                activity.SampleItems,
                activeCount,
                queuedCount,
                FirstNonBlank(activity.MetricLabel, "Active"),
                FirstNonBlank(activity.MetricValue, activeCount.ToString("N0", CultureInfo.CurrentCulture)),
                ToMetricToneCss(activity.MetricTone),
                $"is-{NormalizeStageClass(activity.StageKey)}",
                activity.CurrentBatch);
        }

        public static CurrentRow FromJob(IngestionOperationsJobViewModel job, IReadOnlyList<IngestionDashboardStage> stages)
        {
            var stage = stages.FirstOrDefault(value => value.Key == ResolveStageKey(job.CurrentStage));
            var count = stage?.Count ?? job.ProcessedCount;
            var total = stage?.Total ?? job.TotalCount;
            var percent = total > 0
                ? Math.Clamp(count * 100d / total, 0, 100)
                : Math.Clamp(job.PercentComplete, 0, 100);
            var stageKey = stage?.Key ?? ResolveStageKey(job.CurrentStage);
            var isRunning = job.Status.Equals("running", StringComparison.OrdinalIgnoreCase)
                || job.Status.Equals("processing", StringComparison.OrdinalIgnoreCase)
                || job.Status.Equals("active", StringComparison.OrdinalIgnoreCase);
            var activeCount = isRunning ? 1 : 0;
            var queuedCount = isRunning ? Math.Max(0, total - count) : 0;
            return new CurrentRow(
                stageKey,
                StageMessage(stageKey),
                FirstNonBlank(job.CurrentItem, job.CurrentStage, "Ingestion is running"),
                ShortPath(job.SourceFolder),
                FormatCounts(count, total, "files"),
                FormatUpdated(job.LastUpdatedTime),
                job.LastUpdatedTime,
                StageIcon(stageKey),
                percent,
                StageColor(stageKey),
                FormatQueue(queuedCount, activeCount),
                [FirstNonBlank(job.CurrentItem, job.CurrentStage, "Ingestion is running")],
                activeCount,
                queuedCount,
                "Active",
                activeCount.ToString("N0", CultureInfo.CurrentCulture),
                "is-info",
                $"is-{NormalizeStageClass(stageKey)}",
                null);
        }

        private static string ResolveStageKey(string? stage) => (stage ?? string.Empty).ToLowerInvariant() switch
        {
            var s when s.Contains("bridge") || s.Contains("qid") || s.Contains("wikidata") || s.Contains("canonical") => "wikidata",
            var s when s.Contains("enrich") || s.Contains("hydrate") || s.Contains("metadata") || s.Contains("universe") => "enrichment",
            var s when s.Contains("identify") || s.Contains("match") || s.Contains("retail") => "retail",
            _ => "scanning",
        };

        private static string StageMessage(string stageKey) => stageKey switch
        {
            "retail" => "Matching metadata",
            "wikidata" => "Checking Wikidata identity",
            "enrichment" => "Enriching relationships",
            _ => "Scanning files",
        };

        private static string StageIcon(string stageKey) => stageKey switch
        {
            "retail" => Icons.Material.Outlined.Extension,
            "wikidata" => Icons.Material.Outlined.TravelExplore,
            "enrichment" => Icons.Material.Outlined.DataObject,
            "artwork" => Icons.Material.Outlined.Collections,
            "relationships" => Icons.Material.Outlined.Hub,
            "people" => Icons.Material.Outlined.Groups,
            _ => Icons.Material.Outlined.Radar,
        };

        private static Color StageColor(string stageKey) => stageKey switch
        {
            "enrichment" => Color.Warning,
            "relationships" => Color.Success,
            "people" => Color.Warning,
            _ => Color.Info,
        };

        private static string FormatQueue(int queued, int active)
        {
            if (active <= 0)
            {
                return queued > 0
                    ? $"{queued.ToString("N0", CultureInfo.CurrentCulture)} queued"
                    : "No active item";
            }

            return queued > 0
                ? $"{active.ToString("N0", CultureInfo.CurrentCulture)} active - {queued.ToString("N0", CultureInfo.CurrentCulture)} queued"
                : $"{active.ToString("N0", CultureInfo.CurrentCulture)} active";
        }

        private static string ToMetricToneCss(string? tone) => tone?.ToLowerInvariant() switch
        {
            "success" => "is-success",
            "warning" => "is-warning",
            "danger" => "is-danger",
            _ => "is-info",
        };

        private static string NormalizeStageClass(string? stageKey) => stageKey?.ToLowerInvariant() switch
        {
            "artwork" => "artwork",
            "wikidata" => "wikidata",
            "relationships" => "relationships",
            "people" => "people",
            "enrichment" => "people",
            _ => "scanning",
        };
    }

    private static string FormatTrigger(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var spaced = Regex.Replace(value.Replace('_', ' '), "([a-z])([A-Z])", "$1 $2");
        return CultureInfo.CurrentCulture.TextInfo.ToTitleCase(spaced.ToLowerInvariant());
    }

    private static string FormatCounts(int count, int total, string? unit) =>
        total > 0
            ? $"{count.ToString("N0", CultureInfo.CurrentCulture)} / {total.ToString("N0", CultureInfo.CurrentCulture)} {NormalizeUnit(unit)}"
            : "Working";

    private static string NormalizeUnit(string? unit) =>
        string.IsNullOrWhiteSpace(unit) ? "items" : unit.Trim();

    private static string FormatUpdated(DateTimeOffset? value)
    {
        if (value is null)
        {
            return "now";
        }

        var elapsed = DateTimeOffset.UtcNow - value.Value.ToUniversalTime();
        return elapsed.TotalMinutes switch
        {
            < 1 => "now",
            < 60 => $"{(int)elapsed.TotalMinutes}m ago",
            < 1440 => $"{(int)elapsed.TotalHours}h ago",
            _ => value.Value.ToLocalTime().ToString("MMM d, h:mm tt", CultureInfo.CurrentCulture),
        };
    }

    private static string ShortPath(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return string.Empty;
        }

        var trimmed = path.TrimEnd('\\', '/');
        var index = Math.Max(trimmed.LastIndexOf('\\'), trimmed.LastIndexOf('/'));
        return index >= 0 ? trimmed[(index + 1)..] : trimmed;
    }

    private static string FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? string.Empty;

    private string CurrentRowButtonClass(CurrentRow row) =>
        $"ingestion-current-row__main {(IsSelected(row.Key) ? "is-selected" : null)}";

    private static string ProgressIconClass(double percent) =>
        $"ingestion-current-row__icon ingestion-current-row__icon--progress-{ProgressBucket(percent)}";

    private static int ProgressBucket(double percent) =>
        (int)(Math.Round(Math.Clamp(percent, 0, 100) / 5d, MidpointRounding.AwayFromZero) * 5);

    private bool IsSelected(string key) => key.Equals(_selectedRowKey, StringComparison.OrdinalIgnoreCase);

    private void SelectRow(string key) => _selectedRowKey = key;
}
