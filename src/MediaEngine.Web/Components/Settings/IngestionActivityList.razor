@namespace MediaEngine.Web.Components.Settings
@using System.Globalization
@using System.Text.RegularExpressions
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@inject IStringLocalizer<SharedStrings> L

<section class="ingestion-activity-grid">
    <div class="ingestion-current">
        <div class="ingestion-current__header">
            <div>
                <MudText Typo="Typo.subtitle2">@L["Ingestion_CurrentActivity"]</MudText>
                <span>What the engine is working on right now</span>
            </div>
            <div class="ingestion-current__actions">
                <span class="ingestion-current__live">Live updates</span>
                <MudButton Href="/settings/activity" Variant="Variant.Outlined" Size="Size.Small">View all activity</MudButton>
            </div>
        </div>

        @if (CurrentRows.Count == 0)
        {
            <div class="ingestion-current__empty">
                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" />
                <div>
                    <strong>@L["Ingestion_NoActiveWork"]</strong>
                    <span>@L["Ingestion_WatchedFoldersMonitored"]</span>
                </div>
            </div>
        }
        else
        {
            @foreach (var row in CurrentRows)
            {
                <article class="ingestion-current-row @row.StageClass">
                    <button type="button"
                            class="ingestion-current-row__main @(IsSelected(row.Key) ? "is-selected" : null)"
                            @onclick="() => SelectRow(row.Key)">
                        <span class="ingestion-current-row__icon" style="@RingStyle(row.Percent)">
                            <MudIcon Icon="@row.Icon" />
                        </span>
                        <span class="ingestion-current-row__copy">
                            <strong>@row.Message</strong>
                            <span>@row.Detail</span>
                            <small>@row.QueueSummary</small>
                        </span>
                        <span class="ingestion-current-row__work">
                            <span class="ingestion-current-row__counts">@row.Counts</span>
                            <span class="ingestion-current-row__bar">
                                <MudProgressLinear Value="@row.Percent" Color="@row.Color" Rounded="true" Size="Size.Small" />
                                <span>@row.Percent.ToString("0", CultureInfo.CurrentCulture)%</span>
                            </span>
                            @if (row.Percent < 100 && row.SampleItems.Count > 0)
                            {
                                <span class="ingestion-current-row__chips">
                                    @foreach (var item in row.SampleItems.Take(3))
                                    {
                                        <span>@item</span>
                                    }
                                    @if (row.SampleItems.Count > 3)
                                    {
                                        <span>+@((row.SampleItems.Count - 3).ToString("N0", CultureInfo.CurrentCulture)) more</span>
                                    }
                                </span>
                            }
                        </span>
                        <span class="ingestion-current-row__metric @row.MetricToneCss">
                            <small>@row.MetricLabel</small>
                            <strong>@row.MetricValue</strong>
                        </span>
                        <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" />
                    </button>
                </article>
            }
        }
    </div>

    <aside class="ingestion-activity-detail">
        @if (SelectedRow is null)
        {
            <div class="ingestion-activity-detail__empty">
                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" />
                <div>
                    <strong>No active library work</strong>
                    <span>The Engine is monitoring watched folders and waiting for new activity.</span>
                </div>
            </div>
        }
        else
        {
            var detail = BuildDetail(SelectedRow);
            <div class="ingestion-activity-detail__header">
                <div>
                    <MudText Typo="Typo.subtitle2">@detail.Title</MudText>
                    <span>@detail.Subtitle</span>
                </div>
                <strong>@SelectedRow.Percent.ToString("0", CultureInfo.CurrentCulture)% complete</strong>
            </div>

            <div class="ingestion-activity-detail__metrics">
                @foreach (var metric in detail.Metrics)
                {
                    <div class="@metric.CssClass">
                        <MudIcon Icon="@metric.Icon" />
                        <span>@metric.Label</span>
                        <strong>@metric.Value</strong>
                    </div>
                }
            </div>

            @if (detail.Breakdown.Count > 0)
            {
                <div class="ingestion-activity-detail__section">
                    <strong>@detail.BreakdownTitle</strong>
                    <div class="ingestion-activity-detail__breakdown">
                        @foreach (var item in detail.Breakdown)
                        {
                            <div>
                                <span>@item.Label</span>
                                <strong>@item.Value</strong>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (detail.WorkGroups.Count > 0)
            {
                <div class="ingestion-activity-detail__section">
                    <strong>@detail.WorkTitle</strong>
                    <div class="ingestion-activity-detail__work-groups">
                        @foreach (var group in detail.WorkGroups)
                        {
                            <div class="ingestion-activity-detail__work-group">
                                <strong>@group.Label</strong>
                                @if (group.Items.Count == 0)
                                {
                                    <span>None right now</span>
                                }
                                else
                                {
                                    @foreach (var item in group.Items.Take(5))
                                    {
                                        <span>@item</span>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @if (detail.Problems.Count > 0)
            {
                <div class="ingestion-activity-detail__section">
                    <strong>Problem buckets</strong>
                    <div class="ingestion-activity-detail__problems">
                        @foreach (var problem in detail.Problems)
                        {
                            <a href="/settings/review" class="@problem.CssClass">
                                <MudIcon Icon="@problem.Icon" />
                                <span>@problem.Label</span>
                                <strong>@problem.Count.ToString("N0", CultureInfo.CurrentCulture)</strong>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (RecentActivityItems.Count > 0)
            {
                <div class="ingestion-activity-detail__section">
                    <strong>Recent engine activity</strong>
                    <div class="ingestion-activity-detail__events">
                        @foreach (var item in RecentActivityItems.Take(5))
                        {
                            <span>@DisplayRecentActivity(item)</span>
                        }
                    </div>
                </div>
            }
        }
    </aside>
</section>

@code {
    [Parameter] public IReadOnlyList<IngestionOperationsJobViewModel> Jobs { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionCurrentActivityViewModel> CurrentActivities { get; set; } = [];
    [Parameter] public IReadOnlyList<ActivityEntryViewModel> Activities { get; set; } = [];
    [Parameter] public IReadOnlyList<ReviewItemViewModel> PendingReviews { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionReviewReasonViewModel> ReviewReasons { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionDashboardStage> Stages { get; set; } = [];
    [Parameter] public int ReviewTotal { get; set; }

    private string? _selectedRowKey;

    protected override void OnParametersSet()
    {
        var rows = CurrentRows;
        if (rows.Count == 0)
        {
            _selectedRowKey = null;
            return;
        }

        if (string.IsNullOrWhiteSpace(_selectedRowKey) || rows.All(row => !row.Key.Equals(_selectedRowKey, StringComparison.OrdinalIgnoreCase)))
        {
            _selectedRowKey = rows
                .FirstOrDefault(row => row.Percent < 100)?.Key
                ?? rows[0].Key;
        }
    }

    private IReadOnlyList<CurrentRow> CurrentRows
    {
        get
        {
            var rows = CurrentActivities
                .Where(activity => !string.IsNullOrWhiteSpace(activity.Message))
                .Where(activity => !activity.StageKey.Equals("validation", StringComparison.OrdinalIgnoreCase))
                .Where(activity => !activity.StageKey.Equals("summary", StringComparison.OrdinalIgnoreCase))
                .Select(CurrentRow.FromActivity)
                .ToList();

            if (rows.Count > 0)
            {
                return rows;
            }

            return Jobs
                .Where(job => job.Status.Equals("running", StringComparison.OrdinalIgnoreCase)
                    || job.Status.Equals("processing", StringComparison.OrdinalIgnoreCase)
                    || job.Status.Equals("active", StringComparison.OrdinalIgnoreCase))
                .Select(job => CurrentRow.FromJob(job, Stages))
                .ToList();
        }
    }

    private IReadOnlyList<IngestionReviewReasonViewModel> TopReasons =>
        ReviewReasons
            .Where(reason => reason.Count > 0)
            .OrderByDescending(reason => reason.Count)
            .Take(3)
            .ToList();

    private CurrentRow? SelectedRow =>
        CurrentRows.FirstOrDefault(row => row.Key.Equals(_selectedRowKey, StringComparison.OrdinalIgnoreCase))
        ?? CurrentRows.FirstOrDefault();

    private IReadOnlyList<ActivityEntryViewModel> RecentActivityItems =>
        Activities
            .Where(activity => !string.IsNullOrWhiteSpace(DisplayRecentActivity(activity)))
            .Take(5)
            .ToList();

    private ActivityDetail BuildDetail(CurrentRow row)
    {
        var activeValue = row.Percent >= 100
            ? "Complete"
            : row.Batch is null
                ? row.MetricValue
                : row.Batch.ActiveCount.ToString("N0", CultureInfo.CurrentCulture);
        var metrics = new List<DetailMetric>
        {
            new("Processed", row.Counts, Icons.Material.Outlined.TaskAlt, "is-info"),
            new(row.Percent >= 100 ? "State" : "Active", activeValue, row.Percent >= 100 ? Icons.Material.Outlined.CheckCircle : Icons.Material.Outlined.Autorenew, row.Percent >= 100 ? "is-success" : "is-warning"),
            new(row.MetricLabel, row.MetricValue, row.Icon, row.MetricToneCss),
        };

        var breakdown = row.Batch is null
            ? new List<DetailItem>
            {
                new("Queued", row.QueueSummary),
                new("Updated", row.Updated),
            }
            : new List<DetailItem>
            {
                new("Current batch", $"{row.Batch.BatchNumber.ToString("N0", CultureInfo.CurrentCulture)} of {row.Batch.TotalBatches.ToString("N0", CultureInfo.CurrentCulture)}"),
                new("Completed", row.Batch.CompletedCount.ToString("N0", CultureInfo.CurrentCulture)),
                new("Pending", row.Batch.PendingCount.ToString("N0", CultureInfo.CurrentCulture)),
                new("Needs attention", row.Batch.ReviewCount.ToString("N0", CultureInfo.CurrentCulture)),
            };

        return DetailStageKey(row.Key) switch
        {
            "artwork" => new(
                "Artwork retrieval",
                "Covers, posters, thumbnails, and provider image checks for this batch.",
                "Artwork breakdown",
                "Items being checked",
                metrics,
                breakdown,
                WorkGroups(row),
                ProblemBuckets(["missing_artwork", "provider_failures", "metadata_conflicts"])),
            "wikidata" => new(
                "Wikidata identity linking",
                "Canonical QID matching, ambiguous identity checks, and unresolved bridge IDs.",
                "Identity breakdown",
                "Works in identity matching",
                metrics,
                breakdown,
                WorkGroups(row),
                ProblemBuckets(["missing_wikidata", "low_confidence", "metadata_conflicts"])),
            "relationships" => new(
                "Series and relationships",
                "Series links, collection relationships, and universe graph updates.",
                "Relationship breakdown",
                "Works affecting relationships",
                metrics,
                breakdown,
                WorkGroups(row),
                ProblemBuckets(["duplicates", "metadata_conflicts", "missing_wikidata"])),
            "people" => new(
                "People and cast enrichment",
                "Authors, narrators, cast, crew, and character links for active works.",
                "People breakdown",
                "Active works",
                metrics,
                breakdown,
                WorkGroups(row),
                ProblemBuckets(["metadata_conflicts", "missing_wikidata", "provider_failures"])),
            _ => new(
                "Library updates",
                "Current Engine work, recent events, and issues scoped to this activity.",
                "Batch breakdown",
                "Active items",
                metrics,
                breakdown,
                WorkGroups(row),
                ProblemBuckets(["metadata_conflicts", "provider_failures", "low_confidence"])),
        };
    }

    private static IReadOnlyList<DetailWorkGroup> WorkGroups(CurrentRow row)
    {
        if (row.Batch is null)
        {
            return row.SampleItems.Count == 0
                ? []
                : [new DetailWorkGroup(row.Percent >= 100 ? "Recent items" : "Current focus", row.SampleItems)];
        }

        if (row.Percent >= 100)
        {
            return
            [
                new DetailWorkGroup("Completed", row.Batch.CompletedPreview),
                new DetailWorkGroup("Needs attention", row.Batch.ReviewPreview),
            ];
        }

        return
        [
            new DetailWorkGroup("Working now", row.Batch.ActiveItems),
            new DetailWorkGroup("Pending", row.Batch.PendingPreview),
            new DetailWorkGroup("Needs attention", row.Batch.ReviewPreview),
        ];
    }

    private static string DetailStageKey(string? stageKey) => stageKey?.ToLowerInvariant() switch
    {
        "artwork" => "artwork",
        "wikidata" => "wikidata",
        "relationships" => "relationships",
        "people" or "enrichment" => "people",
        _ => "scanning",
    };

    private IReadOnlyList<ProblemBucket> ProblemBuckets(IReadOnlyList<string> keys)
    {
        var selected = ReviewReasons
            .Where(reason => reason.Count > 0 && keys.Contains(reason.Key, StringComparer.OrdinalIgnoreCase))
            .OrderByDescending(reason => reason.Count)
            .Select(reason => new ProblemBucket(
                reason.Label,
                reason.Count,
                ProblemIcon(reason.Key),
                $"is-{ProblemTone(reason.Key)}"))
            .ToList();

        return selected.Count > 0
            ? selected
            : TopReasons.Select(reason => new ProblemBucket(reason.Label, reason.Count, ProblemIcon(reason.Key), $"is-{ProblemTone(reason.Key)}")).ToList();
    }

    private static string ProblemIcon(string key) => key.ToLowerInvariant() switch
    {
        "missing_artwork" => Icons.Material.Outlined.ImageNotSupported,
        "missing_wikidata" => Icons.Material.Outlined.TravelExplore,
        "provider_failures" => Icons.Material.Outlined.SyncProblem,
        "metadata_conflicts" => Icons.Material.Outlined.Rule,
        "duplicates" => Icons.Material.Outlined.ContentCopy,
        "low_confidence" => Icons.Material.Outlined.ReportProblem,
        _ => Icons.Material.Outlined.Info,
    };

    private static string ProblemTone(string key) => key.ToLowerInvariant() switch
    {
        "provider_failures" => "danger",
        "missing_artwork" or "metadata_conflicts" => "warning",
        _ => "info",
    };

    private static string DisplayRecentActivity(ActivityEntryViewModel item) =>
        FirstNonBlank(item.Detail, item.RichData?.Title, item.ReviewData?.Title, FormatTrigger(item.ActionType));

    private sealed record DetailMetric(string Label, string Value, string Icon, string ToneCss)
    {
        public string CssClass => $"ingestion-activity-detail__metric {ToneCss}";
    }

    private sealed record DetailItem(string Label, string Value);

    private sealed record DetailWorkGroup(string Label, IReadOnlyList<string> Items);

    private sealed record ProblemBucket(string Label, int Count, string Icon, string CssClass);

    private sealed record ActivityDetail(
        string Title,
        string Subtitle,
        string BreakdownTitle,
        string WorkTitle,
        IReadOnlyList<DetailMetric> Metrics,
        IReadOnlyList<DetailItem> Breakdown,
        IReadOnlyList<DetailWorkGroup> WorkGroups,
        IReadOnlyList<ProblemBucket> Problems);

    private sealed record CurrentRow(
        string Key,
        string Message,
        string Detail,
        string Source,
        string Counts,
        string Updated,
        string Icon,
        double Percent,
        Color Color,
        string QueueSummary,
        IReadOnlyList<string> SampleItems,
        string MetricLabel,
        string MetricValue,
        string MetricToneCss,
        string StageClass,
        IngestionActivityBatchViewModel? Batch)
    {
        public static CurrentRow FromActivity(IngestionCurrentActivityViewModel activity)
        {
            var percent = Math.Clamp(activity.PercentComplete, 0, 100);
            var activeCount = percent >= 100 ? 0 : activity.ActiveCount;
            var queuedCount = percent >= 100 ? 0 : activity.QueuedCount;
            return new CurrentRow(
                FirstNonBlank(activity.StageKey, activity.Message),
                FirstNonBlank(activity.Message, "Processing files"),
                FirstNonBlank(activity.Detail, activity.CurrentItem, "Working on the current item"),
                ShortPath(activity.Source),
                FormatCounts(activity.ProcessedCount, activity.TotalCount),
                FormatUpdated(activity.LastUpdatedTime),
                StageIcon(activity.StageKey),
                percent,
                StageColor(activity.StageKey),
                FormatQueue(queuedCount, activeCount),
                activity.SampleItems,
                FirstNonBlank(activity.MetricLabel, "Active"),
                FirstNonBlank(activity.MetricValue, activeCount.ToString("N0", CultureInfo.CurrentCulture)),
                ToMetricToneCss(activity.MetricTone),
                $"is-{NormalizeStageClass(activity.StageKey)}",
                activity.CurrentBatch);
        }

        public static CurrentRow FromJob(IngestionOperationsJobViewModel job, IReadOnlyList<IngestionDashboardStage> stages)
        {
            var stage = stages.FirstOrDefault(value => value.Key == ResolveStageKey(job.CurrentStage));
            var count = stage?.Count ?? job.ProcessedCount;
            var total = stage?.Total ?? job.TotalCount;
            var percent = total > 0
                ? Math.Clamp(count * 100d / total, 0, 100)
                : Math.Clamp(job.PercentComplete, 0, 100);
            var stageKey = stage?.Key ?? ResolveStageKey(job.CurrentStage);
            return new CurrentRow(
                stageKey,
                StageMessage(stageKey),
                FirstNonBlank(job.CurrentItem, job.CurrentStage, "Ingestion is running"),
                ShortPath(job.SourceFolder),
                FormatCounts(count, total),
                FormatUpdated(job.LastUpdatedTime),
                StageIcon(stageKey),
                percent,
                StageColor(stageKey),
                FormatQueue(Math.Max(0, total - count), 1),
                [FirstNonBlank(job.CurrentItem, job.CurrentStage, "Ingestion is running")],
                "Active",
                "1",
                "is-info",
                $"is-{NormalizeStageClass(stageKey)}",
                null);
        }

        private static string ResolveStageKey(string? stage) => (stage ?? string.Empty).ToLowerInvariant() switch
        {
            var s when s.Contains("bridge") || s.Contains("qid") || s.Contains("wikidata") || s.Contains("canonical") => "wikidata",
            var s when s.Contains("enrich") || s.Contains("hydrate") || s.Contains("metadata") || s.Contains("universe") => "enrichment",
            var s when s.Contains("identify") || s.Contains("match") || s.Contains("retail") => "retail",
            _ => "scanning",
        };

        private static string StageMessage(string stageKey) => stageKey switch
        {
            "retail" => "Matching metadata",
            "wikidata" => "Checking Wikidata identity",
            "enrichment" => "Enriching relationships",
            _ => "Scanning files",
        };

        private static string StageIcon(string stageKey) => stageKey switch
        {
            "retail" => Icons.Material.Outlined.Extension,
            "wikidata" => Icons.Material.Outlined.TravelExplore,
            "enrichment" => Icons.Material.Outlined.DataObject,
            "artwork" => Icons.Material.Outlined.Collections,
            "relationships" => Icons.Material.Outlined.Hub,
            "people" => Icons.Material.Outlined.Groups,
            _ => Icons.Material.Outlined.Radar,
        };

        private static Color StageColor(string stageKey) => stageKey switch
        {
            "enrichment" => Color.Warning,
            "relationships" => Color.Success,
            "people" => Color.Warning,
            _ => Color.Info,
        };

        private static string FormatQueue(int queued, int active)
        {
            if (queued <= 0 && active <= 0)
            {
                return "No files currently waiting in this task";
            }

            return $"{queued.ToString("N0", CultureInfo.CurrentCulture)} queued · {active.ToString("N0", CultureInfo.CurrentCulture)} active";
        }

        private static string ToMetricToneCss(string? tone) => tone?.ToLowerInvariant() switch
        {
            "success" => "is-success",
            "warning" => "is-warning",
            "danger" => "is-danger",
            _ => "is-info",
        };

        private static string NormalizeStageClass(string? stageKey) => stageKey?.ToLowerInvariant() switch
        {
            "artwork" => "artwork",
            "wikidata" => "wikidata",
            "relationships" => "relationships",
            "people" => "people",
            "enrichment" => "people",
            _ => "scanning",
        };
    }

    private static string DisplayReviewTitle(ReviewItemViewModel item) =>
        FirstNonBlank(item.EntityTitle, item.Detail, item.MediaType, "Review item");

    private static string ReviewDetail(ReviewItemViewModel item) =>
        FirstNonBlank(FormatTrigger(item.Trigger), item.Detail, "Needs review");

    private static string FormatTrigger(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var spaced = Regex.Replace(value.Replace('_', ' '), "([a-z])([A-Z])", "$1 $2");
        return CultureInfo.CurrentCulture.TextInfo.ToTitleCase(spaced.ToLowerInvariant());
    }

    private static string FormatCounts(int count, int total) =>
        total > 0
            ? $"{count.ToString("N0", CultureInfo.CurrentCulture)} / {total.ToString("N0", CultureInfo.CurrentCulture)} files"
            : "Working";

    private static string FormatUpdated(DateTimeOffset? value)
    {
        if (value is null)
        {
            return "now";
        }

        var elapsed = DateTimeOffset.UtcNow - value.Value.ToUniversalTime();
        return elapsed.TotalMinutes switch
        {
            < 1 => "now",
            < 60 => $"{(int)elapsed.TotalMinutes}m ago",
            < 1440 => $"{(int)elapsed.TotalHours}h ago",
            _ => value.Value.ToLocalTime().ToString("MMM d, h:mm tt", CultureInfo.CurrentCulture),
        };
    }

    private static string ShortPath(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return string.Empty;
        }

        var trimmed = path.TrimEnd('\\', '/');
        var index = Math.Max(trimmed.LastIndexOf('\\'), trimmed.LastIndexOf('/'));
        return index >= 0 ? trimmed[(index + 1)..] : trimmed;
    }

    private static string FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? string.Empty;

    private static string RingStyle(double percent) =>
        $"--stage-progress: {Math.Clamp(percent, 0, 100).ToString("0.##", CultureInfo.InvariantCulture)}%;";

    private bool IsSelected(string key) => key.Equals(_selectedRowKey, StringComparison.OrdinalIgnoreCase);

    private void SelectRow(string key) => _selectedRowKey = key;
}
