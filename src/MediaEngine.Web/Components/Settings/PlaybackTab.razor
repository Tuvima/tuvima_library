@namespace MediaEngine.Web.Components.Settings
@using System.Text.Json
@using MediaEngine.Contracts.Playback
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@using MediaEngine.Web.Services.Playback
@inject UIOrchestratorService Orchestrator
@inject IUserPlaybackPreferencesAccessor PreferencesAccessor
@inject ISnackbar Snackbar

@if (_loading)
{
    <MudStack Spacing="3">
        <MudSkeleton Height="72px" />
        <MudSkeleton Height="56px" />
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6"><MudSkeleton Height="220px" /></MudItem>
            <MudItem xs="12" md="6"><MudSkeleton Height="220px" /></MudItem>
        </MudGrid>
    </MudStack>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_loadError</MudAlert>
}
else if (_settings is not null)
{
    <MudStack Spacing="4" Class="settings-playback-page">
        @if (!string.IsNullOrWhiteSpace(_saveError))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_saveError</MudAlert>
        }

        <MudTabs Rounded="true"
                 Elevation="0"
                 Color="Color.Primary"
                 Class="settings-tab-strip settings-playback-tabs"
                 @bind-ActivePanelIndex="_activeTab">
            <MudTabPanel Text="General" Icon="@Icons.Material.Outlined.Settings">
                <MudStack Spacing="3" Class="settings-tab-panel">
                <MudPaper Elevation="0" Class="tl-card settings-summary-strip settings-experience-card">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="settings-experience-grid">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="settings-experience-profile">
                            <MudAvatar Size="Size.Large" Color="Color.Primary">@Initials</MudAvatar>
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.overline" Color="Color.Primary">Default Experience</MudText>
                                <MudText Typo="Typo.h6">@ProfileName</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@ProfileRole personal playback and reading defaults.</MudText>
                            </MudStack>
                        </MudStack>
                        @SummaryMetric(Icons.Material.Outlined.History, "Resume", OnOff(_settings.General.ResumePlayback), Color.Success)
                        @SummaryMetric(Icons.Material.Outlined.Speed, "Video Speed", FormatSpeed(_settings.Watching.DefaultPlaybackSpeed), Color.Secondary)
                        @SummaryMetric(Icons.Material.Outlined.Headphones, "Audiobook Speed", FormatSpeed(_settings.Listening.AudiobookDefaultSpeed), Color.Secondary)
                        @SummaryMetric(Icons.Material.Outlined.ClosedCaption, "Subtitle Language", _settings.Subtitles.DefaultSubtitleLanguage, Color.Warning)
                        @SummaryMetric(Icons.Material.Outlined.MenuBook, "Reading Theme", Display(_settings.Reading.Theme), Color.Warning)
                    </MudStack>
                </MudPaper>

                <MudGrid Spacing="3">
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Resume & Progress" Icon="@Icons.Material.Outlined.Update" Class="tl-card settings-section-card settings-section-card--dense settings-section-card--progress">
                            @BoolRow(Icons.Material.Outlined.PlayCircle, "Resume playback", "Automatically continue where you left off.", _settings.General.ResumePlayback, v => UpdateAndSaveAsync(() => _settings.General.ResumePlayback = v))
                            @BoolRow(Icons.Material.Outlined.LiveHelp, "Ask before resuming", "Confirm before resuming playback.", _settings.General.AskBeforeResuming, v => UpdateAndSaveAsync(() => _settings.General.AskBeforeResuming = v))
                            @IntSelectRow(Icons.Material.Outlined.DoneAll, "Mark complete threshold", "Mark as complete after reaching.", _settings.General.MarkCompleteThresholdPercent, ThresholdOptions, v => UpdateAndSaveAsync(() => _settings.General.MarkCompleteThresholdPercent = v), "%")
                            @BoolRow(Icons.Material.Outlined.Timeline, "Track partially played items", "Show in-progress items across library surfaces.", _settings.General.TrackPartiallyPlayedItems, v => UpdateAndSaveAsync(() => _settings.General.TrackPartiallyPlayedItems = v))
                            @BoolRow(Icons.Material.Outlined.Sync, "Sync book and audiobook progress", "Keep progress in sync across formats.", _settings.General.SyncProgressBetweenBookAndAudiobook, v => UpdateAndSaveAsync(() => _settings.General.SyncProgressBetweenBookAndAudiobook = v))
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Quick Preferences" Icon="@Icons.Material.Outlined.FlashOn" Class="tl-card settings-section-card settings-section-card--dense settings-section-card--quick">
                            @BoolRow(Icons.Material.Outlined.PlayArrow, "Resume playback", "Continue where you left off.", _settings.General.ResumePlayback, v => UpdateAndSaveAsync(() => _settings.General.ResumePlayback = v))
                            @BoolRow(Icons.Material.Outlined.Security, "Spoiler-safe progress", "Hide future details and progress.", _settings.General.SpoilerSafeProgress, v => UpdateAndSaveAsync(() => _settings.General.SpoilerSafeProgress = v))
                            @BoolRow(Icons.Material.Outlined.Sync, "Sync book / audiobook progress", "Keep progress aligned across formats.", _settings.General.SyncProgressBetweenBookAndAudiobook, v => UpdateAndSaveAsync(() => _settings.General.SyncProgressBetweenBookAndAudiobook = v))
                            @BoolRow(Icons.Material.Outlined.Image, "Use banner art when available", "Show large banners on detail pages.", _settings.General.UseBannerArtWhenAvailable, v => UpdateAndSaveAsync(() => _settings.General.UseBannerArtWhenAvailable = v))
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12">
                        <SettingsSectionPanel Title="Defaults at a Glance" Icon="@Icons.Material.Outlined.Visibility">
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="4">@Glance("Watching", Icons.Material.Outlined.LiveTv, $"Default speed {FormatSpeed(_settings.Watching.DefaultPlaybackSpeed)} - Skip forward {_settings.Watching.SkipForwardSeconds}s - Skip back {_settings.Watching.SkipBackSeconds}s")</MudItem>
                                <MudItem xs="12" md="4">@Glance("Listening", Icons.Material.Outlined.Headphones, $"Default speed {FormatSpeed(_settings.Listening.AudiobookDefaultSpeed)} - Sleep timer {SleepLabel(_settings.Listening.DefaultSleepTimer)}")</MudItem>
                                <MudItem xs="12" md="4">@Glance("Reading", Icons.Material.Outlined.MenuBook, $"Theme {Display(_settings.Reading.Theme)} - Font size {_settings.Reading.FontSizePercent}% - Margins {Display(_settings.Reading.Margins)}")</MudItem>
                            </MudGrid>
                        </SettingsSectionPanel>
                    </MudItem>
                </MudGrid>
                </MudStack>
            </MudTabPanel>

            <MudTabPanel Text="Watching" Icon="@Icons.Material.Outlined.LiveTv">
                <MudGrid Spacing="3" Class="settings-tab-panel">
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Video Speed" Icon="@Icons.Material.Outlined.Speed">
                            <div class="settings-slider-block">
                                @SliderHeader("Default playback speed", FormatSpeed(_settings.Watching.DefaultPlaybackSpeed))
                                <MudSlider T="double" Class="settings-slider" Value="@((double)_settings.Watching.DefaultPlaybackSpeed)" ValueChanged="@(v => UpdateAndSaveAsync(() => _settings.Watching.DefaultPlaybackSpeed = (decimal)v))" Min="0.5" Max="2.0" Step="0.05" Color="Color.Primary" />
                                @SliderLabels(["0.5x", "1.0x", "1.5x", "2.0x"])
                            </div>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Outlined.Restore" OnClick="@(() => UpdateAndSaveAsync(() => _settings.Watching.DefaultPlaybackSpeed = 1.0m))">Reset to 1.0x</MudButton>
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Skip Controls" Icon="@Icons.Material.Outlined.Replay10">
                            @IntSelect("Skip back", _settings.Watching.SkipBackSeconds, WatchingSkipBackOptions, v => UpdateAndSaveAsync(() => _settings.Watching.SkipBackSeconds = v), " seconds")
                            @IntSelect("Skip forward", _settings.Watching.SkipForwardSeconds, WatchingSkipForwardOptions, v => UpdateAndSaveAsync(() => _settings.Watching.SkipForwardSeconds = v), " seconds")
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Episode Behavior" Icon="@Icons.Material.Outlined.PlaylistPlay">
                            @BoolRow(Icons.Material.Outlined.PlaylistPlay, "Autoplay next episode", "Start the next episode automatically.", _settings.Watching.AutoplayNextEpisode, v => UpdateAndSaveAsync(() => _settings.Watching.AutoplayNextEpisode = v))
                            @BoolRow(Icons.Material.Outlined.FastForward, "Continue from credits", "Resume near the credit point when available.", _settings.Watching.ContinueFromCredits, v => UpdateAndSaveAsync(() => _settings.Watching.ContinueFromCredits = v))
                            @BoolRow(Icons.Material.Outlined.Speed, "Remember per-title playback speed", "Keep custom speeds for individual titles.", _settings.Watching.RememberPerTitlePlaybackSpeed, v => UpdateAndSaveAsync(() => _settings.Watching.RememberPerTitlePlaybackSpeed = v))
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Quality & Artwork" Icon="@Icons.Material.Outlined.HighQuality">
                            @StringSelect("Preferred video quality", _settings.Watching.PreferredVideoQuality, VideoQualityOptions, v => UpdateAndSaveAsync(() => _settings.Watching.PreferredVideoQuality = v))
                            @BoolRow(Icons.Material.Outlined.Panorama, "Prefer hero banners", "Use wide artwork when available.", _settings.Watching.PreferHeroBanners, v => UpdateAndSaveAsync(() => _settings.Watching.PreferHeroBanners = v))
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Server delivery and transcoding settings are managed by administrators under Playback & Delivery.</MudAlert>
                        </SettingsSectionPanel>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Listening" Icon="@Icons.Material.Outlined.Headphones">
                <MudGrid Spacing="3" Class="settings-tab-panel">
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Audiobook Speed" Icon="@Icons.Material.Outlined.Speed">
                            <div class="settings-slider-block">
                                @SliderHeader("Audiobook default speed", FormatSpeed(_settings.Listening.AudiobookDefaultSpeed))
                                <MudSlider T="double" Class="settings-slider" Value="@((double)_settings.Listening.AudiobookDefaultSpeed)" ValueChanged="@(v => UpdateAndSaveAsync(() => _settings.Listening.AudiobookDefaultSpeed = (decimal)v))" Min="0.5" Max="3.0" Step="0.05" Color="Color.Primary" />
                                @SliderLabels(["0.5x", "1.0x", "1.5x", "2.0x", "3.0x"])
                            </div>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Outlined.Restore" OnClick="@(() => UpdateAndSaveAsync(() => _settings.Listening.AudiobookDefaultSpeed = 1.25m))">Reset to 1.25x</MudButton>
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Skip & Silence" Icon="@Icons.Material.Outlined.Forward30">
                            @IntSelect("Skip back", _settings.Listening.SkipBackSeconds, ListeningSkipBackOptions, v => UpdateAndSaveAsync(() => _settings.Listening.SkipBackSeconds = v), " seconds")
                            @IntSelect("Skip forward", _settings.Listening.SkipForwardSeconds, ListeningSkipForwardOptions, v => UpdateAndSaveAsync(() => _settings.Listening.SkipForwardSeconds = v), " seconds")
                            @BoolRow(Icons.Material.Outlined.VolumeOff, "Skip silence", "Reduce long silent gaps when supported.", _settings.Listening.SkipSilence, v => UpdateAndSaveAsync(() => _settings.Listening.SkipSilence = v))
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Music Behavior" Icon="@Icons.Material.Outlined.GraphicEq">
                            @BoolRow(Icons.Material.Outlined.GraphicEq, "Music crossfade", "Blend between tracks.", _settings.Listening.MusicCrossfade, v => UpdateAndSaveAsync(() => _settings.Listening.MusicCrossfade = v))
                            <div class="settings-slider-block">
                                @SliderHeader("Crossfade length", $"{_settings.Listening.CrossfadeSeconds}s")
                                <MudSlider T="int" Class="settings-slider" Value="_settings.Listening.CrossfadeSeconds" ValueChanged="@(v => UpdateAndSaveAsync(() => _settings.Listening.CrossfadeSeconds = v))" Min="1" Max="15" Step="1" Disabled="@(!_settings.Listening.MusicCrossfade)" Color="Color.Primary" />
                                @SliderLabels(["1s", "5s", "10s", "15s"])
                            </div>
                            @BoolRow(Icons.Material.Outlined.Speed, "Remember per-title playback speed", "Keep custom speeds for individual titles.", _settings.Listening.RememberPerTitlePlaybackSpeed, v => UpdateAndSaveAsync(() => _settings.Listening.RememberPerTitlePlaybackSpeed = v))
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Sleep & Output" Icon="@Icons.Material.Outlined.Bedtime">
                            @StringSelect("Sleep timer", _settings.Listening.DefaultSleepTimer, SleepTimerOptions, v => UpdateAndSaveAsync(() => _settings.Listening.DefaultSleepTimer = v), SleepLabel)
                            @StringSelect("Output preference", _settings.Listening.OutputPreference, OutputOptions, v => UpdateAndSaveAsync(() => _settings.Listening.OutputPreference = v))
                        </SettingsSectionPanel>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Reading" Icon="@Icons.Material.Outlined.MenuBook">
                <MudGrid Spacing="3" Class="settings-tab-panel">
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Reading Mode" Icon="@Icons.Material.Outlined.ChromeReaderMode">
                            @StringSelect("Reading mode", _settings.Reading.ReadingMode, ReadingModeOptions, v => UpdateAndSaveAsync(() => _settings.Reading.ReadingMode = v))
                            @StringSelect("Comic mode", _settings.Reading.DefaultComicMode, ComicOptions, v => UpdateAndSaveAsync(() => _settings.Reading.DefaultComicMode = v))
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Typography" Icon="@Icons.Material.Outlined.FormatSize">
                            <div class="settings-slider-block">
                                @SliderHeader("Font size", $"{_settings.Reading.FontSizePercent}%")
                                <MudSlider T="int" Class="settings-slider" Value="_settings.Reading.FontSizePercent" ValueChanged="@(v => UpdateAndSaveAsync(() => _settings.Reading.FontSizePercent = v))" Min="80" Max="160" Step="5" Color="Color.Primary" />
                                @SliderLabels(["80%", "100%", "120%", "140%", "160%"])
                            </div>
                            @StringSelect("Theme", _settings.Reading.Theme, ThemeOptions, v => UpdateAndSaveAsync(() => _settings.Reading.Theme = v))
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Page Layout" Icon="@Icons.Material.Outlined.ViewAgenda">
                            @StringSelect("Line spacing", _settings.Reading.LineSpacing, SpacingOptions, v => UpdateAndSaveAsync(() => _settings.Reading.LineSpacing = v))
                            @StringSelect("Margins", _settings.Reading.Margins, MarginOptions, v => UpdateAndSaveAsync(() => _settings.Reading.Margins = v))
                            @BoolRow(Icons.Material.Outlined.WbSunny, "Keep screen awake", "Prevent dimming while reading.", _settings.Reading.KeepScreenAwake, v => UpdateAndSaveAsync(() => _settings.Reading.KeepScreenAwake = v))
                            @BoolRow(Icons.Material.Outlined.Timeline, "Show chapter progress", "Show progress inside each chapter.", _settings.Reading.ShowChapterProgress, v => UpdateAndSaveAsync(() => _settings.Reading.ShowChapterProgress = v))
                            @BoolRow(Icons.Material.Outlined.Numbers, "Show page numbers", "Show page numbers where available.", _settings.Reading.ShowPageNumbers, v => UpdateAndSaveAsync(() => _settings.Reading.ShowPageNumbers = v))
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Preview" Icon="@Icons.Material.Outlined.Preview">
                            <MudPaper Elevation="0" Class="tl-card tl-card--flush settings-reading-preview">
                                <MudText Typo="Typo.subtitle1">@Display(_settings.Reading.Theme) reader preview</MudText>
                                <MudText Typo="Typo.body2">A short passage shows the selected font scale, spacing, and page layout preferences without changing your actual reader.</MudText>
                            </MudPaper>
                        </SettingsSectionPanel>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Subtitles" Icon="@Icons.Material.Outlined.ClosedCaption">
                <MudGrid Spacing="3" Class="settings-tab-panel">
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Language Defaults" Icon="@Icons.Material.Outlined.Translate">
                            @StringSelect("Default subtitle language", _settings.Subtitles.DefaultSubtitleLanguage, LanguageOptions, v => UpdateAndSaveAsync(() => _settings.Subtitles.DefaultSubtitleLanguage = v))
                            @StringSelect("Forced subtitles mode", _settings.Subtitles.ForcedSubtitlesMode, ForcedSubtitleOptions, v => UpdateAndSaveAsync(() => _settings.Subtitles.ForcedSubtitlesMode = v))
                            @StringSelect("Audio language", _settings.Subtitles.AudioLanguage, LanguageOptions, v => UpdateAndSaveAsync(() => _settings.Subtitles.AudioLanguage = v))
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <SettingsSectionPanel Title="Subtitle Appearance" Icon="@Icons.Material.Outlined.Subtitles">
                            @StringSelect("Subtitle size", _settings.Subtitles.SubtitleSize, SubtitleSizeOptions, v => UpdateAndSaveAsync(() => _settings.Subtitles.SubtitleSize = v), Display)
                            @BoolRow(Icons.Material.Outlined.Subtitles, "Subtitle background", "Add a readable background behind subtitles.", _settings.Subtitles.SubtitleBackground, v => UpdateAndSaveAsync(() => _settings.Subtitles.SubtitleBackground = v))
                            @StringSelect("Subtitle position", _settings.Subtitles.SubtitlePosition, SubtitlePositionOptions, v => UpdateAndSaveAsync(() => _settings.Subtitles.SubtitlePosition = v))
                            @StringSelect("Subtitle style", _settings.Subtitles.SubtitleStyle, SubtitleStyleOptions, v => UpdateAndSaveAsync(() => _settings.Subtitles.SubtitleStyle = v), Display)
                        </SettingsSectionPanel>
                    </MudItem>
                    <MudItem xs="12">
                        <SettingsSectionPanel Title="Preview" Icon="@Icons.Material.Outlined.Visibility">
                            <MudPaper Elevation="0" Class="tl-card tl-card--flush settings-subtitle-preview">
                                <MudText Typo="@SubtitlePreviewTypo" Color="@SubtitlePreviewColor">The quick brown fox jumps over the lazy dog.</MudText>
                                <MudChip T="string" Variant="Variant.Outlined">@Display(_settings.Subtitles.SubtitleStyle) - @Display(_settings.Subtitles.SubtitlePosition)</MudChip>
                            </MudPaper>
                        </SettingsSectionPanel>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </MudStack>
}
@code {
    private readonly JsonSerializerOptions _jsonOptions = new(JsonSerializerDefaults.Web);
    private UserPlaybackSettingsDto? _settings;
    private UserPlaybackSettingsDto? _savedSettings;
    private ProfileViewModel? _activeProfile;
    private int _activeTab;
    private bool _loading = true;
    private string? _loadError;
    private string? _saveError;

    private static readonly int[] WatchingSkipBackOptions = [5, 10, 15, 30];
    private static readonly int[] WatchingSkipForwardOptions = [10, 30, 60, 90];
    private static readonly int[] ListeningSkipBackOptions = [10, 15, 30];
    private static readonly int[] ListeningSkipForwardOptions = [15, 30, 60];
    private static readonly int[] ThresholdOptions = [50, 60, 70, 80, 90, 95, 100];
    private static readonly string[] LanguageOptions = ["English", "Spanish", "French", "German", "Japanese", "Original"];
    private static readonly string[] VideoQualityOptions = [PlaybackPreferenceValues.Auto, PlaybackPreferenceValues.Original, PlaybackPreferenceValues.High, PlaybackPreferenceValues.Balanced, PlaybackPreferenceValues.DataSaver];
    private static readonly string[] SleepTimerOptions = [PlaybackPreferenceValues.Off, "15", "30", "45", "60", PlaybackPreferenceValues.EndOfChapter, PlaybackPreferenceValues.EndOfEpisode];
    private static readonly string[] OutputOptions = [PlaybackPreferenceValues.Auto, PlaybackPreferenceValues.Headphones, PlaybackPreferenceValues.Speakers, PlaybackPreferenceValues.Bluetooth];
    private static readonly string[] ReadingModeOptions = [PlaybackPreferenceValues.Paginated, PlaybackPreferenceValues.Scroll];
    private static readonly string[] ThemeOptions = [PlaybackPreferenceValues.Dark, PlaybackPreferenceValues.Sepia, PlaybackPreferenceValues.Light, PlaybackPreferenceValues.System];
    private static readonly string[] SpacingOptions = [PlaybackPreferenceValues.Compact, PlaybackPreferenceValues.Comfortable, PlaybackPreferenceValues.Spacious];
    private static readonly string[] MarginOptions = [PlaybackPreferenceValues.Narrow, PlaybackPreferenceValues.Medium, PlaybackPreferenceValues.Wide];
    private static readonly string[] ComicOptions = [PlaybackPreferenceValues.Page, PlaybackPreferenceValues.Webtoon, PlaybackPreferenceValues.DoublePage, PlaybackPreferenceValues.FitWidth];
    private static readonly string[] ForcedSubtitleOptions = [PlaybackPreferenceValues.Auto, PlaybackPreferenceValues.Always, PlaybackPreferenceValues.Never];
    private static readonly string[] SubtitleSizeOptions = [PlaybackPreferenceValues.Small, PlaybackPreferenceValues.Medium, PlaybackPreferenceValues.Large, PlaybackPreferenceValues.ExtraLarge];
    private static readonly string[] SubtitlePositionOptions = [PlaybackPreferenceValues.Bottom, PlaybackPreferenceValues.Top];
    private static readonly string[] SubtitleStyleOptions = [PlaybackPreferenceValues.Clean, PlaybackPreferenceValues.HighContrast, PlaybackPreferenceValues.Shadowed];

    private string ProfileName => string.IsNullOrWhiteSpace(_activeProfile?.DisplayName) ? "Current profile" : _activeProfile.DisplayName;
    private string ProfileRole => string.IsNullOrWhiteSpace(_activeProfile?.Role) ? "User" : _activeProfile.Role;
    private string Initials => GetInitials(ProfileName);
    private Typo SubtitlePreviewTypo => _settings?.Subtitles.SubtitleSize switch
    {
        PlaybackPreferenceValues.Small => Typo.caption,
        PlaybackPreferenceValues.Large => Typo.h6,
        PlaybackPreferenceValues.ExtraLarge => Typo.h5,
        _ => Typo.subtitle1,
    };

    private Color SubtitlePreviewColor => _settings?.Subtitles.SubtitleStyle == PlaybackPreferenceValues.HighContrast
        ? Color.Warning
        : Color.Default;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _activeProfile = await Orchestrator.GetActiveProfileAsync();
            var loaded = await PreferencesAccessor.GetAsync();
            _settings = Clone(loaded ?? UserPlaybackSettingsDto.CreateDefaults(_activeProfile?.Id ?? Guid.Empty));
            _savedSettings = Clone(_settings);
        }
        catch
        {
            _loadError = "Playback and reading settings could not be loaded.";
        }
        finally
        {
            _loading = false;
        }
    }

    private RenderFragment BoolRow(string title, string description, bool value, Func<bool, Task> changed) =>
        BoolRow(Icons.Material.Outlined.Tune, title, description, value, changed);

    private RenderFragment BoolRow(string icon, string title, string description, bool value, Func<bool, Task> changed) => @<div class="settings-preference-row">
        <span class="settings-preference-row__icon">
            <MudIcon Icon="@icon" Size="Size.Small" Color="Color.Primary" />
        </span>
        <MudStack Spacing="0" Class="settings-preference-row__text">
            <MudText Typo="Typo.body1">@title</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@description</MudText>
        </MudStack>
        <MudSwitch T="bool" Value="@value" ValueChanged="@changed" Color="Color.Primary" />
    </div>;

    private RenderFragment IntSelectRow(string icon, string title, string description, int value, IReadOnlyList<int> options, Func<int, Task> changed, string suffix) => @<div class="settings-preference-row">
        <span class="settings-preference-row__icon">
            <MudIcon Icon="@icon" Size="Size.Small" Color="Color.Primary" />
        </span>
        <MudStack Spacing="0" Class="settings-preference-row__text">
            <MudText Typo="Typo.body1">@title</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@description</MudText>
        </MudStack>
        <MudSelect T="int" Value="@value" ValueChanged="@changed" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Class="settings-field--compact settings-field--row-control" PopoverClass="settings-select-menu">
            @foreach (var option in options)
            {
                <MudSelectItem T="int" Value="@option">@($"{option}{suffix}")</MudSelectItem>
            }
        </MudSelect>
    </div>;

    private RenderFragment IntSelect(string label, int value, IReadOnlyList<int> options, Func<int, Task> changed, string suffix) => @<MudSelect T="int" Label="@label" Value="@value" ValueChanged="@changed" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" FullWidth="true" Class="settings-field--compact" PopoverClass="settings-select-menu">
        @foreach (var option in options)
        {
            <MudSelectItem T="int" Value="@option">@($"{option}{suffix}")</MudSelectItem>
        }
    </MudSelect>;

    private RenderFragment StringSelect(string label, string value, IReadOnlyList<string> options, Func<string, Task> changed, Func<string, string>? formatter = null) => @<MudSelect T="string" Label="@label" Value="@value" ValueChanged="@changed" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" FullWidth="true" Class="settings-field--compact" PopoverClass="settings-select-menu">
        @foreach (var option in options)
        {
            <MudSelectItem T="string" Value="@option">@((formatter ?? Display)(option))</MudSelectItem>
        }
    </MudSelect>;

    private RenderFragment Glance(string title, string icon, string value) => @<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="settings-glance-item">
        <MudIcon Icon="@icon" Color="Color.Primary" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.subtitle2">@title</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@value</MudText>
        </MudStack>
    </MudStack>;

    private RenderFragment SummaryMetric(string icon, string label, string value, Color color) => @<MudStack Spacing="1" Class="settings-summary-metric">
        <MudIcon Icon="@icon" Color="@color" />
        <MudText Typo="Typo.caption" Color="Color.Secondary">@label</MudText>
        <MudText Typo="Typo.subtitle1">@value</MudText>
    </MudStack>;

    private RenderFragment SliderHeader(string label, string value) => @<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="settings-slider-header">
        <MudText Typo="Typo.body2">@label</MudText>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@($"Current: {value}")</MudChip>
    </MudStack>;

    private static RenderFragment SliderLabels(IReadOnlyList<string> labels) => @<MudStack Row="true" Justify="Justify.SpaceBetween" Class="settings-slider-scale">
        @foreach (var label in labels)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@label</MudText>
        }
    </MudStack>;

    private async Task UpdateAndSaveAsync(Action action)
    {
        action();
        _saveError = null;
        await SaveAsync();
    }

    private async Task SaveAsync()
    {
        if (_settings is null)
            return;

        _saveError = null;

        try
        {
            var saved = await Orchestrator.SavePlaybackSettingsAsync(_settings);
            if (saved is not null)
            {
                _settings = Clone(saved);
                _savedSettings = Clone(saved);
                PreferencesAccessor.UpdateCache(saved);
            }

            StateHasChanged();
        }
        catch
        {
            _saveError = "Playback and reading settings could not be saved.";
            Snackbar.Add(_saveError, Severity.Error);
        }
        finally
        {
            StateHasChanged();
        }
    }

    private UserPlaybackSettingsDto Clone(UserPlaybackSettingsDto source) =>
        JsonSerializer.Deserialize<UserPlaybackSettingsDto>(
            JsonSerializer.Serialize(source, _jsonOptions),
            _jsonOptions) ?? UserPlaybackSettingsDto.CreateDefaults(source.ProfileId);

    private static string FormatSpeed(decimal value) => $"{value:0.##}x";
    private static string OnOff(bool value) => value ? "On" : "Off";
    private static string GetInitials(string value)
    {
        var words = value.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return words.Length switch
        {
            0 => "U",
            1 => words[0][0].ToString().ToUpperInvariant(),
            _ => string.Concat(words.Take(2).Select(word => char.ToUpperInvariant(word[0]))),
        };
    }

    private static string SleepLabel(string value) => value switch
    {
        PlaybackPreferenceValues.Off => "Off",
        PlaybackPreferenceValues.EndOfChapter => "End of chapter",
        PlaybackPreferenceValues.EndOfEpisode => "End of episode",
        _ => $"{value} minutes",
    };

    private static string Display(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "Not set";

        return string.Concat(value.Select((character, index) =>
            index > 0 && char.IsUpper(character) && !char.IsUpper(value[index - 1])
                ? $" {character}"
                : character.ToString()));
    }
}
