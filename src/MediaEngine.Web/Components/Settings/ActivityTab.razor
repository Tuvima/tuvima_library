@namespace MediaEngine.Web.Components.Settings
@using System.Globalization
@using System.Text
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedStrings> L

<div class="tl-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Timeline" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">@L["Activity_PageTitle"]</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        @L["Activity_PageDescription"]
    </MudText>

    <MudPaper Elevation="0" Class="tl-card mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Outlined.Schedule"
                     Color="Color.Secondary" Size="Size.Small" Class="mr-1" />
            <MudText Typo="Typo.subtitle1" Class="activity-section-title">@L["Activity_RetentionPolicy"]</MudText>
        </MudStack>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Class="activity-retention-row">
            <MudStack Class="activity-retention-control" Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @L["Activity_KeepEntriesFor"]
                    </MudText>
                    <MudText Typo="Typo.body2" Class="activity-section-title">
                        @_retentionDays @L["Activity_Days"]
                    </MudText>
                </MudStack>
                <MudSlider @bind-Value="_retentionDays"
                           Min="7" Max="365" Step="7"
                           Color="Color.Primary"
                           Size="Size.Small" />
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Activity_SevenDays"]</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Activity_OneYear"]</MudText>
                </MudStack>
            </MudStack>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Outlined.DeleteSweep"
                       OnClick="@PruneNowAsync"
                       Disabled="@(_pruning || _loading)">
                @(_pruning ? L["Activity_Pruning"] : L["Activity_PruneNow"])
            </MudButton>
        </MudStack>

        @if (_stats is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3">
                @($"{_stats.TotalEntries:N0} activity entries retained")
            </MudText>
        }
    </MudPaper>

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="activity-filter-row mb-4">
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="activity-filter-label">
            @L["Activity_Filter"]
        </MudText>
        @foreach (var filter in _filters)
        {
            <MudChip T="string"
                     Color="@(_activeFilters.Contains(filter.Key) ? Color.Primary : Color.Default)"
                     Size="Size.Small"
                     OnClick="@(() => ToggleFilterAsync(filter.Key))"
                     Class="activity-filter-chip">
                @filter.Label
            </MudChip>
        }
        @if (_activeFilters.Count > 0)
        {
            <MudChip T="string" Color="Color.Error" Size="Size.Small"
                     OnClick="@ClearFiltersAsync"
                     Class="activity-filter-chip">
                @L["Activity_Clear"]
            </MudChip>
        }
    </MudStack>

    @if (_loading && _entries.Count == 0)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else
    {
        <MudStack Spacing="0">
            @{
                var visible = _entries.Take(_visibleCount).ToList();
                string? lastDate = null;
            }

            @foreach (var entry in visible)
            {
                var dateGroup = DateGroup(entry);
                if (dateGroup != lastDate)
                {
                    lastDate = dateGroup;
                    <div class="activity-date-header">
                        <MudText Typo="Typo.overline" Color="Color.Secondary" Class="activity-date-label">
                            @dateGroup
                        </MudText>
                    </div>
                }

                <div class="activity-entry">
                    <div class="activity-entry-dot" style="@($"background: {ActionColor(entry.ActionType)};")">
                        <MudIcon Icon="@ActionIcon(entry.ActionType)" Class="activity-entry-icon" />
                    </div>
                    <div class="activity-entry-connector" />
                    <div class="activity-entry-content">
                        <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2" Class="activity-entry-header">
                            <MudText Class="activity-entry-title">
                                @ActionLabel(entry.ActionType)
                            </MudText>
                            @if (!string.IsNullOrEmpty(entry.CollectionName))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="activity-entry-chip">
                                    @entry.CollectionName
                                </MudChip>
                            }
                            @if (!string.IsNullOrEmpty(entry.EntityType))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="activity-entry-chip">
                                    @entry.EntityType
                                </MudChip>
                            }
                            <MudSpacer />
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="activity-entry-time">
                                @entry.RelativeTime
                            </MudText>
                        </MudStack>
                        @if (!string.IsNullOrEmpty(entry.Detail))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="activity-entry-detail">
                                @entry.Detail
                            </MudText>
                        }
                    </div>
                </div>
            }

            @if (visible.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="mt-2">
                    @L["Activity_NoEntries"]
                </MudAlert>
            }
        </MudStack>

        @if (_entries.Count > _visibleCount)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       FullWidth="true"
                       Class="mt-4"
                       StartIcon="@Icons.Material.Outlined.ExpandMore"
                       OnClick="@LoadMore">
                @L["Activity_LoadMore"] (@(_entries.Count - _visibleCount) @L["Activity_Remaining"])
            </MudButton>
        }
    }
</div>

@code {
    private sealed record FilterDef(string Key, string Label);

    private static readonly FilterDef[] _filters =
    [
        new("FileIngested", "File Ingested"),
        new("MediaAdded", "Media Added"),
        new("MetadataHydrated", "Metadata Hydrated"),
        new("PersonHydrated", "Person Hydrated"),
        new("ReviewItemResolved", "Review Resolved"),
        new("HashVerified", "Hash Verified"),
        new("PathUpdated", "Path Updated"),
        new("ActivityPruned", "Pruned"),
    ];

    private int _retentionDays = 60;
    private bool _loading;
    private bool _pruning;
    private int _visibleCount = 10;
    private ActivityStatsViewModel? _stats;
    private List<ActivityEntryViewModel> _entries = [];
    private readonly HashSet<string> _activeFilters = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadActivityAsync();
    }

    private async Task LoadActivityAsync()
    {
        _loading = true;
        try
        {
            _stats = await Orchestrator.GetActivityStatsAsync();
            if (_stats is not null)
            {
                _retentionDays = Math.Clamp(_stats.RetentionDays, 7, 365);
            }

            _entries = _activeFilters.Count == 0
                ? await Orchestrator.GetRecentActivityAsync(100)
                : await Orchestrator.GetActivityByTypesAsync(_activeFilters.ToArray(), 100);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ToggleFilterAsync(string key)
    {
        if (!_activeFilters.Remove(key))
        {
            _activeFilters.Add(key);
        }

        _visibleCount = 10;
        await LoadActivityAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _activeFilters.Clear();
        _visibleCount = 10;
        await LoadActivityAsync();
    }

    private void LoadMore() => _visibleCount += 10;

    private async Task PruneNowAsync()
    {
        _pruning = true;
        try
        {
            var retentionSaved = await Orchestrator.UpdateRetentionAsync(_retentionDays);
            if (!retentionSaved)
            {
                Snackbar.Add(Orchestrator.LastApiError ?? L["Activity_PruneError"], Severity.Error);
                return;
            }

            var result = await Orchestrator.TriggerPruneAsync();
            if (result is null)
            {
                Snackbar.Add(Orchestrator.LastApiError ?? L["Activity_PruneError"], Severity.Error);
                return;
            }

            Snackbar.Add($"Pruned {result.Deleted:N0} entries older than {result.RetentionDays} days", Severity.Success);
            await LoadActivityAsync();
        }
        catch
        {
            Snackbar.Add(L["Activity_PruneError"], Severity.Error);
        }
        finally
        {
            _pruning = false;
        }
    }

    private static string DateGroup(ActivityEntryViewModel entry)
    {
        if (!DateTimeOffset.TryParse(entry.OccurredAt, out var occurredAt))
        {
            return "Unknown";
        }

        var localDate = occurredAt.LocalDateTime.Date;
        var today = DateTime.Today;
        if (localDate == today)
        {
            return "Today";
        }

        if (localDate == today.AddDays(-1))
        {
            return "Yesterday";
        }

        return localDate.ToString("MMM d, yyyy", CultureInfo.CurrentCulture);
    }

    private static string ActionColor(string actionType) => actionType switch
    {
        "FileIngested" or "MediaAdded" or "BatchCompleted" => "var(--tl-status-success)",
        "MetadataHydrated" or "MetadataRefreshed" or "HydrationStage1Completed" or "HydrationStage2Completed" or "HydrationStage3Completed" => "var(--tl-accent-primary)",
        "PersonHydrated" or "CharacterEnriched" or "LocationEnriched" or "OrganizationEnriched" => "var(--tl-accent-primary)",
        "ReviewItemResolved" or "HashVerified" or "SyncCompleted" => "var(--tl-status-info)",
        "PathUpdated" or "SidecarUpdated" or "MetadataWrittenToFile" or "MetadataTagsWritten" => "var(--tl-status-warning)",
        "ActivityPruned" or "MediaFailed" or "BatchFailed" or "FileQuarantined" => "var(--tl-status-danger)",
        _ => "var(--tl-status-idle)",
    };

    private static string ActionIcon(string actionType) => actionType switch
    {
        "FileIngested" or "FileDetected" or "MediaAdded" => Icons.Material.Outlined.FileDownloadDone,
        "MetadataHydrated" or "MetadataRefreshed" or "HydrationStage1Completed" or "HydrationStage2Completed" or "HydrationStage3Completed" => Icons.Material.Outlined.AutoFixHigh,
        "PersonHydrated" => Icons.Material.Outlined.Person,
        "ReviewItemResolved" => Icons.Material.Outlined.CheckCircle,
        "HashVerified" => Icons.Material.Outlined.Verified,
        "PathUpdated" => Icons.Material.Outlined.DriveFileMove,
        "ActivityPruned" => Icons.Material.Outlined.DeleteSweep,
        "MediaFailed" or "BatchFailed" or "FileQuarantined" => Icons.Material.Outlined.Warning,
        _ => Icons.Material.Outlined.Circle,
    };

    private static string ActionLabel(string actionType)
    {
        if (string.IsNullOrWhiteSpace(actionType))
        {
            return "Activity";
        }

        var builder = new StringBuilder(actionType.Length + 8);
        for (var i = 0; i < actionType.Length; i++)
        {
            var ch = actionType[i];
            if (i > 0 && char.IsUpper(ch) && !char.IsWhiteSpace(actionType[i - 1]))
            {
                builder.Append(' ');
            }

            builder.Append(ch);
        }

        return builder.ToString();
    }
}
