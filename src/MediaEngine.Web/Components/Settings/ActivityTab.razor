    // ── Startup cluster helper ────────────────────────────────────────────────────

    private sealed record StartupClusterData(
        bool HasAbsorbed, bool HasRecon, bool HasDetails, bool ReconWarning,
        List<ActivityEntryViewModel> AbsorbedList, ActivityEntryViewModel? ReconEntry);

    private StartupClusterData GetStartupClusterData(long entryId)
    {
        var hasAbsorbed = _startupAbsorbed.TryGetValue(entryId, out var absorbedList) && absorbedList!.Count > 0;
        var hasRecon    = _startupRecon.TryGetValue(entryId, out var recon);
        var hasDetails  = hasAbsorbed || hasRecon;
        var reconWarning = hasRecon && recon is not null
                        && ParseReconciliationData(recon.ChangesJson ?? "") is { Missing: > 0 };
        return new(hasAbsorbed, hasRecon, hasDetails, reconWarning, absorbedList ?? [], recon);
    }

    // ── Crawl pair helper ─────────────────────────────────────────────────────────

    private sealed record CrawlPairData(string Duration, ActivityEntryViewModel? StartEntry);

    private CrawlPairData GetCrawlPairData(long entryId, string finishedAt)
    {
        var start = _crawlStartPair.TryGetValue(entryId, out var s) ? s : null;
        return new(CalcCrawlDuration(start?.OccurredAt, finishedAt), start);
    }

