    private static bool IsHydrationStageSuccess(ActivityEntryViewModel stage)
    {
        if (string.IsNullOrWhiteSpace(stage.ChangesJson)) return true;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(stage.ChangesJson);
            if (doc.RootElement.TryGetProperty("success", out var s))
                return s.GetBoolean();
        }
        catch { }
        return true;
    }

    private static string StartupAbsorbedLabel(ActivityEntryViewModel entry) => entry.ActionType switch
    {
        "ActivityPruned"          => "Old activity entries cleaned up",
        "DuplicateSkipped"        => "Duplicate file skipped",
        "OrphanCleaned"           => "Orphaned catalogue entry removed",
        "ReconciliationCompleted" =>
            ParseReconciliationData(entry.ChangesJson ?? "") is { Total: var n }
                ? $"Library check: all {n:N0} files present"
                : "Library check completed",
        _                         => ActionLabel(entry.ActionType),
    };

    private static string CalcCrawlDuration(string? startedAt, string? finishedAt)
    {
        if (ParseTs(startedAt) is not { } s || ParseTs(finishedAt) is not { } f) return string.Empty;
        var span = f - s;
        if (span.TotalSeconds < 1)  return $"{span.TotalMilliseconds:F0}ms";
        if (span.TotalMinutes  < 1) return $"{span.TotalSeconds:F1}s";
        return $"{(int)span.TotalMinutes}m {span.Seconds}s";
    }

