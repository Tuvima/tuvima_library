@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models
@using MediaEngine.Web.Models.ViewDTOs
@using System.IO
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@inject IConfiguration Configuration

@* Activity — Date-grouped timeline of all Engine actions: ingestion, metadata,
   organization, review resolution. Configurable retention at the top. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Section Header ──────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Timeline" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6" Style="flex: 1;">Activity</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                       Size="Size.Small"
                       Color="Color.Default"
                       title="Refresh"
                       OnClick="@RefreshAsync" />
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Timeline of every action the Engine has performed on your library.
    </MudText>

    @* ── Retention config ────────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Outlined.DateRange"
                     Size="Size.Small" Color="Color.Default" />
            <MudText Typo="Typo.body2" Style="white-space: nowrap;">
                Keep activity for
            </MudText>
            <MudNumericField @bind-Value="_retentionDays"
                             Min="1" Max="365"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Style="max-width: 90px;"
                             Immediate="false" />
            <MudText Typo="Typo.body2">days</MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       OnClick="@SaveRetentionAsync"
                       Disabled="@(_savingRetention || _retentionDays == _savedRetentionDays)">
                @(_savingRetention ? "Saving..." : "Save")
            </MudButton>
            <MudSpacer />
            @if (_stats is not null)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                         Style="opacity: 0.7;">
                    @_stats.TotalEntries.ToString("N0") entries
                </MudChip>
            }
            <MudButton Variant="Variant.Text"
                       Color="Color.Warning"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.CleaningServices"
                       OnClick="@TriggerPruneAsync"
                       Disabled="@_pruning">
                @(_pruning ? "Pruning..." : "Prune Now")
            </MudButton>
        </MudStack>
    </MudPaper>

    @* ── Filter bar ────────────────────────────────────────────────────── *@
    <div class="activity-filter-bar mb-4">
        @foreach (var filter in FilterOptions)
        {
            <MudButton Variant="@(_activityFilter == filter.Key ? Variant.Filled : Variant.Outlined)"
                       Color="@(_activityFilter == filter.Key ? Color.Secondary : Color.Default)"
                       Size="Size.Small"
                       Style="text-transform: none; border-radius: 12px; min-width: auto; padding: 4px 14px;"
                       OnClick="@(() => SetFilter(filter.Key))">
                @filter.Label
            </MudButton>
        }
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else if (_filteredGroupedEntries.Count == 0)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
            <MudIcon Icon="@Icons.Material.Filled.EventNote"
                     Size="Size.Large"
                     Style="font-size: 3rem; opacity: 0.3;" />
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                @if (_activityFilter == "All")
                {
                    @:No activity recorded yet. Events will appear here as the Engine
                    @:ingests files, enriches metadata, and manages your library.
                }
                else
                {
                    @:No @_activityFilter.ToLowerInvariant() activity found.
                }
            </MudText>
        </MudStack>
    }
    else
    {
        @* ── Date-grouped timeline ───────────────────────────────────────── *@
        @foreach (var group in _filteredGroupedEntries)
        {
            @* Date header *@
            <div class="activity-date-header">
                <MudIcon Icon="@Icons.Material.Filled.CalendarToday"
                         Size="Size.Small"
                         Style="opacity: 0.8;" />
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">
                    @group.DateLabel
                </MudText>
            </div>

            <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-4">
                <MudStack Spacing="0">
                    @foreach (var entry in group.Entries)
                    {
                        if (_absorbedEntryIds.Contains(entry.Id)) continue;
                        var tier = GetDisplayTier(entry.ActionType);
                        var isMissing = tier == DisplayTier.RichMedia
                                     && _missingEntityIds.Contains(entry.RichData?.EntityId ?? "");
                        var sc = GetStartupClusterData(entry.Id);
                        var crawlData = GetCrawlPairData(entry.Id, entry.OccurredAt);

                        <div class="activity-timeline-row">
                            @* Timeline icon + connector line *@
                            <div class="activity-timeline-dot">
                                <div class="activity-icon-circle" style="@IconCircleStyle(entry.ActionType)">
                                    <MudIcon Icon="@ActionIcon(entry.ActionType)"
                                             Size="Size.Small"
                                             Style="font-size: 0.85rem; color: white;" />
                                </div>
                                <div class="activity-timeline-line" />
                            </div>

                            @* Entry content *@
                            <div class="activity-entry-content">
                                @if (tier == DisplayTier.Simple)
                                {
                                    @* ── Simple — icon + label + time only ── *@
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                            @ActionLabel(entry.ActionType)
                                        </MudText>
                                        <MudSpacer />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                 Style="white-space: nowrap;">
                                            @FormatTime(entry.OccurredAt)
                                        </MudText>
                                    </MudStack>
                                }
                                else if (tier == DisplayTier.Startup)
                                {
                                    @* ── Startup cluster — ServerStarted + absorbed noise/recon ── *@
                                    <div class="activity-expandable-row"
                                         @onclick="@(() => { if (sc.HasDetails) ToggleExpanded(entry.Id); })">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                                                   Style="@(sc.HasDetails ? "cursor: pointer;" : "")">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                                Server Started
                                            </MudText>
                                            @if (sc.ReconWarning)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                                         Style="font-size: 0.7rem; height: 20px;">
                                                    Library issues found
                                                </MudChip>
                                            }
                                            <MudSpacer />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                     Style="white-space: nowrap;">
                                                @FormatTime(entry.OccurredAt)
                                            </MudText>
                                            @if (sc.HasDetails)
                                            {
                                                <MudIcon Icon="@(_expandedEntryIds.Contains(entry.Id)
                                                                  ? Icons.Material.Filled.ExpandLess
                                                                  : Icons.Material.Filled.ExpandMore)"
                                                         Size="Size.Small" Style="opacity: 0.5;" />
                                            }
                                        </MudStack>
                                    </div>

                                    @if (_expandedEntryIds.Contains(entry.Id) && sc.HasDetails)
                                    {
                                        <div class="activity-startup-details">
                                            @foreach (var absorbed in sc.AbsorbedList)
                                            {
                                                <div class="activity-startup-row">
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline"
                                                             Size="Size.Small"
                                                             Style="font-size: 0.8rem; color: #4caf50; flex-shrink: 0;" />
                                                    <MudText Typo="Typo.caption" Style="color: var(--app-text-soft);">
                                                        @StartupAbsorbedLabel(absorbed)
                                                    </MudText>
                                                </div>
                                            }
                                            @if (sc.HasRecon && sc.ReconEntry is not null && ParseReconciliationData(sc.ReconEntry.ChangesJson ?? "") is { } sRecon)
                                            {
                                                <div class="activity-recon-summary" style="margin-top: 8px;">
                                                    <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center">
                                                        <div>
                                                            <MudText Typo="Typo.h5" Style="font-weight: 700;">@sRecon.Total.ToString("N0")</MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">scanned</MudText>
                                                        </div>
                                                        <div>
                                                            <MudText Typo="Typo.h5"
                                                                     Style="@($"font-weight: 700; color: {(sRecon.Missing > 0 ? "var(--mud-palette-warning)" : "var(--mud-palette-success)")};")">
                                                                @sRecon.Missing.ToString("N0")
                                                            </MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">missing</MudText>
                                                        </div>
                                                        <div>
                                                            <MudText Typo="Typo.h5" Style="font-weight: 700;">@FormatElapsed(sRecon.Elapsed)</MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">elapsed</MudText>
                                                        </div>
                                                    </MudStack>
                                                    @if (sRecon.MissingFiles.Count > 0)
                                                    {
                                                        <div style="margin-top: 10px; border-top: 1px solid var(--app-glass-inner-border); padding-top: 8px;">
                                                            @foreach (var mf in sRecon.MissingFiles)
                                                            {
                                                                <div class="activity-recon-missing-row">
                                                                    <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile"
                                                                             Size="Size.Small"
                                                                             Style="font-size: 0.85rem; opacity: 0.5;" />
                                                                    <MudText Typo="Typo.caption" Style="flex: 1; min-width: 0;">@mf.Filename</MudText>
                                                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                                             Style="font-size: 0.7rem; white-space: nowrap;">
                                                                        @mf.Action
                                                                    </MudText>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                                else if (tier == DisplayTier.RichMedia)
                                {
                                    var batchSiblings = _mediaAddedBatches.TryGetValue(entry.Id, out var bs2) ? bs2 : null;
                                    var isBatch = entry.ActionType == "MediaAdded" && batchSiblings is { Count: > 0 };
                                    @if (isBatch)
                                    {
                                        var allBatch = new List<ActivityEntryViewModel> { entry };
                                        allBatch.AddRange(batchSiblings!);
                                        @* ── BATCH: Multiple items added within 2-minute window ── *@
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                                @allBatch.Count Items Added
                                            </MudText>
                                            <MudSpacer />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                     Style="white-space: nowrap;">
                                                @FormatTime(entry.OccurredAt)
                                            </MudText>
                                        </MudStack>
                                        <div class="activity-pipeline-toggle"
                                             @onclick="@(() => TogglePipeline(entry.Id))">
                                            <MudIcon Icon="@(_pipelineExpandedIds.Contains(entry.Id)
                                                              ? Icons.Material.Filled.ExpandLess
                                                              : Icons.Material.Filled.ExpandMore)"
                                                     Size="Size.Small"
                                                     Style="font-size: 0.8rem; opacity: 0.45;" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                     Style="font-size: 0.72rem;">
                                                @allBatch.Count items
                                            </MudText>
                                        </div>
                                        @if (_pipelineExpandedIds.Contains(entry.Id))
                                        {
                                            <div style="margin-top: 8px;">
                                                @foreach (var bEntry in allBatch)
                                                {
                                                    var bRich = bEntry.RichData;
                                                    <div class="activity-rich-card" style="margin-bottom: 10px;">
                                                        <div class="activity-rich-thumb">
                                                            @if (!string.IsNullOrWhiteSpace(bRich?.ResolvedCoverUrl ?? (bRich?.EntityId is not null ? CoverUrl(bRich.EntityId) : null)))
                                                            {
                                                                <img src="@(bRich!.ResolvedCoverUrl is not null ? AbsoluteStreamUrl(bRich.ResolvedCoverUrl) : CoverUrl(bRich!.EntityId!))"
                                                                     alt="@bRich!.Title"
                                                                     style="width: 100%; height: 100%; object-fit: cover;"
                                                                     loading="lazy"
                                                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                                                <div style="display: none; width: 100%; height: 100%; align-items: center; justify-content: center;">
                                                                    <MudIcon Icon="@MediaTypeIcon(bRich?.MediaType)" Size="Size.Medium" Color="Color.Secondary" />
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <MudIcon Icon="@MediaTypeIcon(bRich?.MediaType)" Size="Size.Medium" Color="Color.Secondary" />
                                                            }
                                                        </div>
                                                        <div class="activity-rich-details">
                                                            <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                                                @(bRich?.Title ?? bEntry.Detail ?? "—")
                                                            </MudText>
                                                            @if (!string.IsNullOrWhiteSpace(bRich?.Author))
                                                            {
                                                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                                    by @bRich!.Author
                                                                </MudText>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                    @if (!isBatch)
                                    {
                                    @* ── TIER 2: Rich media card — always visible ── *@
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                            @ActionLabel(entry.ActionType)
                                        </MudText>
                                        <MudSpacer />
                                        @if (isMissing)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error"
                                                     Icon="@Icons.Material.Filled.LinkOff"
                                                     Style="font-size: 0.7rem; height: 20px;">
                                                File removed
                                            </MudChip>
                                        }
                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                 Style="white-space: nowrap;">
                                            @FormatTime(entry.OccurredAt)
                                        </MudText>
                                    </MudStack>

                                    @if (entry.RichData is { } rich)
                                    {
                                        @* Hero banner strip — shown above the card when available *@
                                        @if (!string.IsNullOrWhiteSpace(rich.HeroUrl))
                                        {
                                            <div class="activity-hero-strip">
                                                <img src="@AbsoluteStreamUrl(rich.HeroUrl)" alt="" loading="lazy"
                                                     onerror="this.parentElement.style.display='none';" />
                                            </div>
                                        }
                                        <div class="activity-rich-card">
                                            @* Thumbnail — 120x180px *@
                                            <div class="activity-rich-thumb">
                                                @if (!string.IsNullOrWhiteSpace(rich.ResolvedCoverUrl ?? (rich.EntityId is not null ? CoverUrl(rich.EntityId) : null)))
                                                {
                                                    <img src="@(rich.ResolvedCoverUrl is not null ? AbsoluteStreamUrl(rich.ResolvedCoverUrl) : CoverUrl(rich.EntityId!))"
                                                         alt="@rich.Title"
                                                         style="width: 100%; height: 100%; object-fit: cover;"
                                                         loading="lazy"
                                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                                    <div style="display: none; width: 100%; height: 100%; align-items: center; justify-content: center;">
                                                        <MudIcon Icon="@MediaTypeIcon(rich.MediaType)"
                                                                 Size="Size.Medium" Color="Color.Secondary" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@MediaTypeIcon(rich.MediaType)"
                                                             Size="Size.Medium" Color="Color.Secondary" />
                                                }
                                            </div>

                                            @* Details *@
                                            <div class="activity-rich-details">
                                                <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                                    @rich.Title
                                                </MudText>
                                                @if (!string.IsNullOrWhiteSpace(rich.Author))
                                                {
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                        by @rich.Author
                                                    </MudText>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(rich.Description))
                                                {
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary"
                                                             Style="display: -webkit-box; -webkit-line-clamp: 3;
                                                                    -webkit-box-orient: vertical; overflow: hidden;
                                                                    text-overflow: ellipsis; margin-top: 4px;
                                                                    font-size: 0.8rem; line-height: 1.5;">
                                                        @TruncateDescription(rich.Description, 200)
                                                    </MudText>
                                                }

                                                @* Confidence bar + year + media type *@
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                                                           Style="margin-top: 6px;">
                                                    <MudProgressLinear Value="@(rich.Confidence * 100)"
                                                                       Color="@ConfidenceColor(rich.Confidence)"
                                                                       Size="Size.Small" Rounded="true"
                                                                       Style="width: 100px;" />
                                                    <MudText Typo="Typo.caption" Style="font-size: 0.75rem;">
                                                        @($"{rich.Confidence:P0}")
                                                    </MudText>
                                                    @if (!string.IsNullOrWhiteSpace(rich.Year))
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                                 Style="font-size: 0.75rem;">
                                                            @FormatFriendlyDate(rich.Year)
                                                        </MudText>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(rich.MediaType))
                                                    {
                                                        <MudIcon Icon="@MediaTypeIcon(rich.MediaType)"
                                                                 Size="Size.Small"
                                                                 Style="font-size: 0.9rem; opacity: 0.7;" />
                                                    }
                                                </MudStack>

                                                @* Organization status (folded from PathUpdated) *@
                                                @if (!string.IsNullOrWhiteSpace(rich.ResolvedOrganizedTo) && rich.ResolvedOrganizedTo != "staging")
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Success"
                                                             Style="margin-top: 4px; font-size: 0.75rem;">
                                                        <MudIcon Icon="@Icons.Material.Filled.DriveFileMove"
                                                                 Size="Size.Small"
                                                                 Style="font-size: 0.85rem; vertical-align: middle; margin-right: 2px;" />
                                                        Organized into library
                                                    </MudText>
                                                }
                                                else if (rich.ResolvedOrganizedTo == "staging")
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Warning"
                                                             Style="margin-top: 4px; font-size: 0.75rem;">
                                                        <MudIcon Icon="@Icons.Material.Filled.MoveToInbox"
                                                                 Size="Size.Small"
                                                                 Style="font-size: 0.85rem; vertical-align: middle; margin-right: 2px;" />
                                                        Moved to staging
                                                    </MudText>
                                                }

                                                @* Match method chip *@
                                                @if (!string.IsNullOrWhiteSpace(rich.MatchMethod))
                                                {
                                                    <MudChip T="string" Size="Size.Small"
                                                             Variant="Variant.Outlined"
                                                             Color="Color.Default"
                                                             Style="font-size: 0.7rem; height: 20px; margin-top: 4px;">
                                                        @rich.MatchMethodLabel
                                                    </MudChip>
                                                }

                                                @* Expandable details — file journey, tags written, match sources *@
                                                @{
                                                    var ingestRich      = GetIngestionSubStepRich(entry.Id);
                                                    var effectiveSources = rich.FieldSources ?? ingestRich?.FieldSources;
                                                    var hasDetails      = (effectiveSources is { Count: > 0 })
                                                                       || (ingestRich?.SourcePath is not null)
                                                                       || (ingestRich?.TagsWritten is { Count: > 0 })
                                                                       || (ingestRich?.CoverWritten == true);
                                                }
                                                @if (hasDetails)
                                                {
                                                    <div class="activity-field-toggle"
                                                         @onclick="@(() => ToggleFieldDetail(entry.Id))"
                                                         @onclick:stopPropagation="true">
                                                        <MudIcon Icon="@(_fieldDetailExpandedIds.Contains(entry.Id)
                                                                          ? Icons.Material.Filled.ExpandLess
                                                                          : Icons.Material.Filled.ExpandMore)"
                                                                 Size="Size.Small"
                                                                 Style="font-size: 0.75rem; opacity: 0.45;" />
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                                 Style="font-size: 0.72rem;">
                                                            Details@(effectiveSources is { Count: > 0 } ? $" ({effectiveSources.Count} fields)" : "")
                                                        </MudText>
                                                    </div>
                                                    @if (_fieldDetailExpandedIds.Contains(entry.Id))
                                                    {
                                                        <div class="activity-field-detail">

                                                            @* ── File journey ── *@
                                                            @if (ingestRich?.SourcePath is { } srcPath)
                                                            {
                                                                var destPath = rich.ResolvedOrganizedTo ?? ingestRich.OrganizedTo ?? string.Empty;
                                                                var srcFile  = Path.GetFileName(srcPath);
                                                                var destFile = Path.GetFileName(destPath);
                                                                var renamed  = !string.IsNullOrEmpty(srcFile)
                                                                            && !string.IsNullOrEmpty(destFile)
                                                                            && !string.Equals(srcFile, destFile,
                                                                                    StringComparison.OrdinalIgnoreCase);
                                                                <div class="activity-detail-section">
                                                                    <MudText Typo="Typo.caption"
                                                                             Style="font-weight: 700; font-size: 0.68rem; opacity: 0.55;
                                                                                    text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px;">
                                                                        File journey
                                                                    </MudText>
                                                                    <div class="activity-detail-path-row">
                                                                        <MudText Typo="Typo.caption"
                                                                                 Style="font-size: 0.7rem; color: var(--app-text-soft); word-break: break-all;">
                                                                            @srcPath
                                                                        </MudText>
                                                                        <MudIcon Icon="@Icons.Material.Filled.ArrowDownward"
                                                                                 Size="Size.Small"
                                                                                 Style="font-size: 0.8rem; opacity: 0.45; flex-shrink: 0; margin: 2px 0;" />
                                                                        <div style="display: flex; align-items: center; gap: 4px; flex-wrap: wrap;">
                                                                            <MudText Typo="Typo.caption"
                                                                                     Style="font-size: 0.7rem; word-break: break-all;">
                                                                                @(string.IsNullOrEmpty(destPath) ? "staging" : destPath)
                                                                            </MudText>
                                                                            @if (renamed)
                                                                            {
                                                                                <MudChip T="string" Size="Size.Small"
                                                                                         Style="background: #C9922E20; color: #C9922E; font-size: 0.65rem; height: 18px; padding: 0 6px; font-weight: 600;">
                                                                                    renamed
                                                                                </MudChip>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            }

                                                            @* ── Tags written to file ── *@
                                                            @{
                                                                var tagsW = ingestRich?.TagsWritten;
                                                                var covW  = ingestRich?.CoverWritten ?? false;
                                                            }
                                                            @if (tagsW is { Count: > 0 } || covW)
                                                            {
                                                                <div class="activity-detail-section">
                                                                    <MudText Typo="Typo.caption"
                                                                             Style="font-weight: 700; font-size: 0.68rem; opacity: 0.55;
                                                                                    text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px;">
                                                                        Written to file
                                                                    </MudText>
                                                                    <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                                                                        @if (tagsW is not null)
                                                                        {
                                                                            @foreach (var tag in tagsW)
                                                                            {
                                                                                <MudChip T="string" Size="Size.Small"
                                                                                         Variant="Variant.Outlined"
                                                                                         Color="Color.Default"
                                                                                         Style="font-size: 0.65rem; height: 18px; padding: 0 6px;">
                                                                                    @FormatFieldName(tag)
                                                                                </MudChip>
                                                                            }
                                                                        }
                                                                        @if (covW)
                                                                        {
                                                                            <MudChip T="string" Size="Size.Small"
                                                                                     Variant="Variant.Outlined"
                                                                                     Color="Color.Info"
                                                                                     Style="font-size: 0.65rem; height: 18px; padding: 0 6px;">
                                                                                <MudIcon Icon="@Icons.Material.Filled.Image"
                                                                                         Size="Size.Small"
                                                                                         Style="font-size: 0.7rem; margin-right: 2px;" />
                                                                                cover art
                                                                            </MudChip>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            }

                                                            @* ── Match sources ── *@
                                                            @if (effectiveSources is { Count: > 0 })
                                                            {
                                                                <div class="activity-detail-section">
                                                                    <MudText Typo="Typo.caption"
                                                                             Style="font-weight: 700; font-size: 0.68rem; opacity: 0.55;
                                                                                    text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px;">
                                                                        Match sources
                                                                    </MudText>
                                                                    @foreach (var fs in effectiveSources)
                                                                    {
                                                                        <div class="activity-field-row">
                                                                            <MudText Typo="Typo.caption"
                                                                                     Style="font-weight: 600; width: 80px; flex-shrink: 0; font-size: 0.72rem;">
                                                                                @FormatFieldName(fs.Field)
                                                                            </MudText>
                                                                            <MudText Typo="Typo.caption"
                                                                                     Style="flex: 1; min-width: 0; overflow: hidden;
                                                                                            text-overflow: ellipsis; white-space: nowrap;
                                                                                            font-size: 0.72rem;">
                                                                                @(fs.Value ?? "—")
                                                                            </MudText>
                                                                            <MudChip T="string" Size="Size.Small"
                                                                                     Color="@(fs.Source == "embedded" ? Color.Info : Color.Default)"
                                                                                     Variant="Variant.Outlined"
                                                                                     Style="font-size: 0.65rem; height: 18px; padding: 0 6px;">
                                                                                @(fs.Source ?? "unknown")
                                                                            </MudChip>
                                                                            @if (fs.Conflicted)
                                                                            {
                                                                                <MudIcon Icon="@Icons.Material.Filled.Warning"
                                                                                         Size="Size.Small"
                                                                                         Color="Color.Warning"
                                                                                         Style="font-size: 0.8rem;"
                                                                                         title="Conflicted — competing values" />
                                                                            }
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }

                                                        </div>
                                                    }
                                                }
                                            </div>

                                            @* Reprocess button — hidden if file was removed *@
                                            @if (!isMissing)
                                            {
                                                <div style="flex-shrink: 0; align-self: center;">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                                   Size="Size.Small"
                                                                   Color="Color.Default"
                                                                   title="Reprocess"
                                                                   OnClick="@(() => OpenReprocessPanel(entry))" />
                                                </div>
                                            }
                                        </div>

                                        @* Related events — collapsible ─────────── *@
                                        @if (_ingestionSubSteps.TryGetValue(entry.Id, out var pipelineSteps) && pipelineSteps.Count > 0)
                                        {
                                            <div class="activity-pipeline-toggle"
                                                 @onclick="@(() => TogglePipeline(entry.Id))">
                                                <MudIcon Icon="@(_pipelineExpandedIds.Contains(entry.Id)
                                                                  ? Icons.Material.Filled.ExpandLess
                                                                  : Icons.Material.Filled.ExpandMore)"
                                                         Size="Size.Small"
                                                         Style="font-size: 0.8rem; opacity: 0.45;" />
                                                <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                         Style="font-size: 0.72rem;">
                                                    Related events
                                                </MudText>
                                            </div>
                                            @if (_pipelineExpandedIds.Contains(entry.Id))
                                            {
                                                <div class="activity-pipeline-steps">
                                                    @foreach (var step in pipelineSteps.OrderBy(s => s.OccurredAt))
                                                    {
                                                        <div class="activity-pipeline-row">
                                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline"
                                                                     Style="font-size: 0.75rem; color: #4caf50; flex-shrink: 0;" />
                                                            <MudText Typo="Typo.caption"
                                                                     Style="flex: 1; color: var(--app-text-soft);">
                                                                @PipelineStepLabel(step.ActionType)
                                                            </MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                                     Style="white-space: nowrap; font-size: 0.7rem;">
                                                                @FormatTime(step.OccurredAt)
                                                            </MudText>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    }
                                    else if (!string.IsNullOrWhiteSpace(entry.Detail))
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary"
                                                 Style="margin-top: 2px; line-height: 1.4;">
                                            @entry.Detail
                                        </MudText>
                                    }
                                    } @* end @if (!isBatch) *@
                                }
                                else if (tier == DisplayTier.ReviewResolved)
                                {
                                    @* ── TIER 3: Review resolved — full media card ── *@
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                            @ActionLabel(entry.ActionType)
                                        </MudText>
                                        @if (entry.ReviewData?.Action is { } rvAction)
                                        {
                                            <MudChip T="string" Size="Size.Small"
                                                     Style="@($"background: {ReviewActionColor(rvAction)}20; color: {ReviewActionColor(rvAction)}; font-size: 0.7rem; height: 20px; font-weight: 600;")">
                                                @ReviewActionLabel(rvAction)
                                            </MudChip>
                                        }
                                        <MudSpacer />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                 Style="white-space: nowrap;">
                                            @FormatTime(entry.OccurredAt)
                                        </MudText>
                                    </MudStack>

                                    @if (entry.ReviewData is { } reviewRich)
                                    {
                                        <div class="activity-rich-card">
                                            @* Thumbnail — always 120x180 (placeholder if no cover) *@
                                            <div class="activity-rich-thumb">
                                                @if (!string.IsNullOrWhiteSpace(reviewRich.EntityId))
                                                {
                                                    <img src="@CoverUrl(reviewRich.EntityId)"
                                                         alt="@reviewRich.Title"
                                                         style="width: 100%; height: 100%; object-fit: cover;"
                                                         loading="lazy"
                                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                                    <div style="display: none; width: 100%; height: 100%; align-items: center; justify-content: center;">
                                                        <MudIcon Icon="@MediaTypeIcon(reviewRich.MediaType)"
                                                                 Size="Size.Medium" Color="Color.Secondary" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@MediaTypeIcon(reviewRich.MediaType)"
                                                             Size="Size.Medium" Color="Color.Secondary" />
                                                }
                                            </div>

                                            @* Details *@
                                            <div class="activity-rich-details">
                                                <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                                    @(reviewRich.Title ?? entry.Detail ?? "Unknown")
                                                </MudText>
                                                @if (!string.IsNullOrWhiteSpace(reviewRich.Author))
                                                {
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                        by @reviewRich.Author
                                                    </MudText>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(reviewRich.Year))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @reviewRich.Year
                                                    </MudText>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(reviewRich.Description))
                                                {
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary"
                                                             Style="display: -webkit-box; -webkit-line-clamp: 4;
                                                                    -webkit-box-orient: vertical; overflow: hidden;
                                                                    text-overflow: ellipsis; margin-top: 4px;
                                                                    font-size: 0.8rem; line-height: 1.5;">
                                                        @TruncateDescription(reviewRich.Description, 280)
                                                    </MudText>
                                                }
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                                                           Style="margin-top: 6px; flex-wrap: wrap;">
                                                    @if (!string.IsNullOrWhiteSpace(reviewRich.MediaType))
                                                    {
                                                        <MudIcon Icon="@MediaTypeIcon(reviewRich.MediaType)"
                                                                 Size="Size.Small"
                                                                 Style="font-size: 0.9rem; opacity: 0.7;" />
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(reviewRich.Qid))
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                                 Style="font-size: 0.72rem;">
                                                            QID: @reviewRich.Qid
                                                        </MudText>
                                                    }
                                                    @if (reviewRich.FieldOverrides > 0)
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                                 Style="font-size: 0.72rem;">
                                                            @reviewRich.FieldOverrides override@(reviewRich.FieldOverrides == 1 ? "" : "s")
                                                        </MudText>
                                                    }
                                                </MudStack>
                                            </div>
                                        </div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(entry.Detail))
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary"
                                                 Style="margin-top: 2px; line-height: 1.4;">
                                            @entry.Detail
                                        </MudText>
                                    }
                                }
                                else if (tier == DisplayTier.Reconciliation)
                                {
                                    @* ── TIER 4: Reconciliation — always-visible stats + missing file list ── *@
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                            @ActionLabel(entry.ActionType)
                                        </MudText>
                                        <MudSpacer />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                 Style="white-space: nowrap;">
                                            @ReconTimeLabel(entry)
                                        </MudText>
                                    </MudStack>

                                    @if (!string.IsNullOrWhiteSpace(entry.ChangesJson)
                                         && ParseReconciliationData(entry.ChangesJson) is { } reconData)
                                    {
                                        <div class="activity-recon-summary">
                                            <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center">
                                                <div>
                                                    <MudText Typo="Typo.h5" Style="font-weight: 700;">
                                                        @reconData.Total.ToString("N0")
                                                    </MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        scanned
                                                    </MudText>
                                                </div>
                                                <div>
                                                    <MudText Typo="Typo.h5"
                                                             Style="@($"font-weight: 700; color: {(reconData.Missing > 0 ? "var(--mud-palette-warning)" : "var(--mud-palette-success)")};")">
                                                        @reconData.Missing.ToString("N0")
                                                    </MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        missing
                                                    </MudText>
                                                </div>
                                                <div>
                                                    <MudText Typo="Typo.h5" Style="font-weight: 700;">
                                                        @FormatElapsed(reconData.Elapsed)
                                                    </MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        elapsed
                                                    </MudText>
                                                </div>
                                            </MudStack>

                                            @if (reconData.MissingFiles.Count > 0)
                                            {
                                                <div style="margin-top: 12px; border-top: 1px solid var(--app-glass-inner-border); padding-top: 10px;">
                                                    @foreach (var mf in reconData.MissingFiles)
                                                    {
                                                        <div class="activity-recon-missing-row">
                                                            <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile"
                                                                     Size="Size.Small"
                                                                     Style="font-size: 0.85rem; opacity: 0.5;" />
                                                            <MudText Typo="Typo.caption" Style="flex: 1; min-width: 0;">
                                                                @mf.Filename
                                                            </MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                                     Style="font-size: 0.7rem; opacity: 0.7; white-space: nowrap;">
                                                                @mf.Action
                                                            </MudText>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                                else if (tier == DisplayTier.Crawl)
                                {
                                    @* ── TIER 4b: Crawl — CrawlStarted merged into CrawlFinished ── *@
                                    <div class="activity-expandable-row"
                                         @onclick="@(() => ToggleExpanded(entry.Id))">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                                                   Style="cursor: pointer;">
                                            <MudIcon Icon="@Icons.Material.Filled.ManageSearch"
                                                     Size="Size.Small"
                                                     Style="opacity: 0.9;" />
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                                Library Crawl
                                            </MudText>
                                            @if (!string.IsNullOrWhiteSpace(crawlData.Duration))
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                         Style="height: 18px; font-size: 0.68rem; opacity: 0.8;">
                                                    @crawlData.Duration
                                                </MudChip>
                                            }
                                            <MudSpacer />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                     Style="white-space: nowrap;">
                                                @FormatTime(entry.OccurredAt)
                                            </MudText>
                                            <MudIcon Icon="@(_expandedEntryIds.Contains(entry.Id)
                                                              ? Icons.Material.Filled.ExpandLess
                                                              : Icons.Material.Filled.ExpandMore)"
                                                     Size="Size.Small"
                                                     Style="opacity: 0.5;" />
                                        </MudStack>
                                    </div>
                                    @if (_expandedEntryIds.Contains(entry.Id))
                                    {
                                        <div class="activity-expanded-content">
                                            @if (!string.IsNullOrWhiteSpace(entry.Detail))
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary"
                                                         Style="line-height: 1.5;">
                                                    @entry.Detail
                                                </MudText>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    @* ── TIER 5: Expandable — collapsed by default ── *@
                                    <div class="activity-expandable-row"
                                         @onclick="@(() => ToggleExpanded(entry.Id))">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                                                   Style="cursor: pointer;">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                                @ActionLabel(entry.ActionType)
                                            </MudText>
                                            @if (!string.IsNullOrWhiteSpace(entry.HubName))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                         Style="opacity: 0.7;">
                                                    — @entry.HubName
                                                </MudText>
                                            }
                                            <MudSpacer />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                     Style="white-space: nowrap;">
                                                @FormatTime(entry.OccurredAt)
                                            </MudText>
                                            <MudIcon Icon="@(_expandedEntryIds.Contains(entry.Id)
                                                              ? Icons.Material.Filled.ExpandLess
                                                              : Icons.Material.Filled.ExpandMore)"
                                                     Size="Size.Small"
                                                     Style="opacity: 0.5;" />
                                        </MudStack>
                                    </div>

                                    @if (_expandedEntryIds.Contains(entry.Id))
                                    {
                                        <div class="activity-expanded-content">
                                            @if (!string.IsNullOrWhiteSpace(entry.Detail))
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary"
                                                         Style="line-height: 1.5;">
                                                    @entry.Detail
                                                </MudText>
                                            }
                                            @if (_hydrationStages.TryGetValue(entry.Id, out var hStages) && hStages.Count > 0)
                                            {
                                                <div style="margin-top: 10px; border-top: 1px solid var(--app-glass-inner-border); padding-top: 8px;">
                                                    @foreach (var stage in hStages.OrderBy(s => s.OccurredAt))
                                                    {
                                                        var success = IsHydrationStageSuccess(stage);
                                                        <div class="activity-pipeline-row">
                                                            <MudIcon Icon="@(success ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                                                     Size="Size.Small"
                                                                     Style="@($"font-size: 0.85rem; color: {(success ? "var(--mud-palette-success)" : "var(--mud-palette-error)")}")" />
                                                            <MudText Typo="Typo.caption" Style="flex: 1;">
                                                                @HydrationStageLabel(stage.ActionType)
                                                            </MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                                     Style="font-size: 0.7rem; white-space: nowrap; opacity: 0.7;">
                                                                @FormatTime(stage.OccurredAt)
                                                            </MudText>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </MudStack>
            </MudPaper>
        }

        @* Load more *@
        @if (_entries.Count >= _limit)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mt-2 mb-4">
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           OnClick="@LoadMoreAsync"
                           Disabled="@_loadingMore">
                    @(_loadingMore ? "Loading..." : "Load More")
                </MudButton>
            </MudStack>
        }
    }

</MudPaper>

@* ── Reprocess dialog ──────────────────────────────────────────────────── *@
<MudDialog @bind-Visible="_reprocessOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Reprocess — @(_reprocessEntry?.RichData?.Title ?? "Unknown")</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
            <MudSelect T="string" @bind-Value="_reprocessProvider" Dense="true"
                       Variant="Variant.Outlined" Label="Provider"
                       Style="max-width: 200px;" Margin="Margin.Dense">
                @foreach (var p in GetReprocessProviders())
                {
                    <MudSelectItem Value="@p.Name">@p.DisplayName</MudSelectItem>
                }
            </MudSelect>
            <MudTextField T="string" @bind-Value="_reprocessQuery" Variant="Variant.Outlined"
                          Label="Search Term" Margin="Margin.Dense"
                          Style="flex: 1;"
                          OnKeyUp="@OnReprocessKeyUp" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(string.IsNullOrWhiteSpace(_reprocessProvider) || string.IsNullOrWhiteSpace(_reprocessQuery))"
                       OnClick="@ReprocessSearchAsync">
                Search
            </MudButton>
        </MudStack>

        @if (_reprocessSearching)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        }

        @if (_reprocessResults.Count > 0)
        {
            <div style="max-height: 420px; overflow-y: auto; border: 1px solid var(--mud-palette-lines-default);
                        border-radius: 4px; background: var(--mud-palette-surface);">
                @foreach (var result in _reprocessResults)
                {
                    <SearchResultCard Result="@result"
                                     IsSelected="@(result == _reprocessSelectedResult)"
                                     OnSelected="@(r => { _reprocessSelectedResult = r == _reprocessSelectedResult ? null : r; StateHasChanged(); })" />
                }
            </div>

            @if (_reprocessSelectedResult is not null)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Class="mt-3"
                           OnClick="@(() => ReprocessSelectAsync(_reprocessSelectedResult))">
                    Confirm Selection
                </MudButton>
            }
        }
        else if (_reprocessSearchExecuted && !_reprocessSearching)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                No results found. Try a different search term or provider.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@CloseReprocessDialog">
            Cancel
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    // ── Style constants ──────────────────────────────────────────────────────────

    private const string GlassStyle =
        "background: var(--app-glass-bg); " +
        "border: 1px solid var(--app-glass-border); " +
        "backdrop-filter: blur(10px); " +
        "-webkit-backdrop-filter: blur(10px); " +
        "border-radius: 12px; " +
        "padding: 32px;";

    private const string InnerCardStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 8px; " +
        "padding: 24px;";

    // ── Display tier enum ─────────────────────────────────────────────────────────

    private enum DisplayTier { Simple, Startup, RichMedia, ReviewResolved, Reconciliation, Crawl, Expandable }

    // ── Filter options ────────────────────────────────────────────────────────────

    private sealed record FilterOption(string Key, string Label);

    private static readonly FilterOption[] FilterOptions =
    [
        new("All",          "All"),
        new("Media",        "Media"),
        new("Metadata",     "Metadata"),
        new("Organization", "Organization"),
        new("Review",       "Review"),
        new("System",       "System"),
    ];

    // ── State ────────────────────────────────────────────────────────────────────

    private bool _loading = true;
    private bool _loadingMore;
    private bool _pruning;
    private bool _savingRetention;
    private int  _limit = 100;
    private int  _retentionDays = 60;
    private int  _savedRetentionDays = 60;
    private string _activityFilter = "All";

    private List<ActivityEntryViewModel> _entries = [];
    private ActivityStatsViewModel?      _stats;
    private List<DateGroup>              _groupedEntries = [];
    private List<DateGroup>              _filteredGroupedEntries = [];

    // Expand/collapse state for expandable entries.
    private readonly HashSet<long> _expandedEntryIds = [];

    // Absorbed entry IDs — entries that are rolled up into a parent entry.
    private readonly HashSet<long> _absorbedEntryIds = [];

    // Entity IDs of files confirmed deleted (hides the reprocess button on FileIngested cards).
    private readonly HashSet<string> _missingEntityIds = new(StringComparer.OrdinalIgnoreCase);

    // Pipeline sub-steps (FileDetected → MovedToStaging) grouped by parent FileIngested entry ID.
    private readonly Dictionary<long, List<ActivityEntryViewModel>> _ingestionSubSteps = new();

    // Hydration stage events grouped by parent MetadataHydrated entry ID.
    private readonly Dictionary<long, List<ActivityEntryViewModel>> _hydrationStages = new();

    // CrawlStarted entries indexed by their paired CrawlFinished entry ID.
    private readonly Dictionary<long, ActivityEntryViewModel> _crawlStartPair = new();

    // Noise / routine events absorbed into the nearest ServerStarted startup cluster.
    private readonly Dictionary<long, List<ActivityEntryViewModel>> _startupAbsorbed = new();

    // ReconciliationCompleted (with missing files) linked to the enclosing ServerStarted entry.
    private readonly Dictionary<long, ActivityEntryViewModel> _startupRecon = new();

    // FileIngested cards whose pipeline step section is currently expanded.
    private readonly HashSet<long> _pipelineExpandedIds = [];

    // FileIngested cards whose field provenance detail is currently expanded.
    private readonly HashSet<long> _fieldDetailExpandedIds = [];

    // MediaAdded batch grouping: maps the batch-leader entry ID → sibling entries within 2-minute window.
    private readonly Dictionary<long, List<ActivityEntryViewModel>> _mediaAddedBatches = new();

    // ── Reprocess dialog state ────────────────────────────────────────────────
    private bool                          _reprocessOpen;
    private ActivityEntryViewModel?       _reprocessEntry;
    private string                        _reprocessProvider = string.Empty;
    private string                        _reprocessQuery = string.Empty;
    private List<MetadataSearchResultDto> _reprocessResults = [];
    private MetadataSearchResultDto?      _reprocessSelectedResult;
    private bool                          _reprocessSearching;
    private bool                          _reprocessSearchExecuted;
    private IReadOnlyList<ProviderStatusDto> _providers = [];
    private Dictionary<string, ProviderSlotDto> _slots = new();

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var refreshTask   = RefreshAsync();
        var slotsTask     = Orchestrator.GetProviderSlotsAsync();
        var providersTask = Orchestrator.GetProviderStatusAsync();
        await Task.WhenAll(refreshTask, slotsTask, providersTask);
        _slots     = slotsTask.Result ?? new();
        _providers = providersTask.Result;
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();

        var entriesTask = Orchestrator.GetRecentActivityAsync(_limit);
        var statsTask   = Orchestrator.GetActivityStatsAsync();
        await Task.WhenAll(entriesTask, statsTask);

        _entries = entriesTask.Result;
        _stats   = statsTask.Result;

        if (_stats is not null)
        {
            _retentionDays      = _stats.RetentionDays;
            _savedRetentionDays = _stats.RetentionDays;
        }

        RebuildGroups();
        _loading = false;
    }

    private async Task LoadMoreAsync()
    {
        _loadingMore = true;
        StateHasChanged();

        _limit += 100;
        var entries = await Orchestrator.GetRecentActivityAsync(_limit);
        _entries = entries;
        RebuildGroups();

        _loadingMore = false;
    }

    // ── Filter ──────────────────────────────────────────────────────────────────

    private void SetFilter(string filter)
    {
        _activityFilter = filter;
        ApplyFilter();
        StateHasChanged();
    }

    private static string GetFilterCategory(string actionType) => actionType switch
    {
        "FileIngested"              => "Media",
        "DuplicateSkipped"          => "Media",
        "MovedToStaging"            => "Media",
        "FileQuarantined"           => "Media",
        "FileDetected"              => "Media",
        "FileHashed"                => "Media",
        "FileProcessed"             => "Media",
        "FileScored"                => "Media",

        "MetadataHydrated"          => "Metadata",
        "MetadataRefreshed"         => "Metadata",
        "MetadataManualOverride"    => "Metadata",
        "MetadataWrittenToFile"     => "Metadata",
        "MetadataTagsWritten"       => "Metadata",
        "PersonHydrated"            => "Metadata",
        "BridgeSyncUpdated"         => "Metadata",
        "HydrationStage1Completed"  => "Metadata",
        "HydrationStage2Completed"  => "Metadata",
        "HydrationStage3Completed"  => "Metadata",
        "HydrationEnqueued"         => "Metadata",

        "PathUpdated"               => "Organization",
        "SidecarUpdated"            => "Organization",
        "EntityChainCreated"        => "Organization",
        "CoverArtSaved"             => "Organization",
        "HashVerified"              => "Organization",

        "ReviewItemCreated"         => "Review",
        "ReviewItemResolved"        => "Review",

        "ServerStarted"             => "System",
        "ServerStopped"             => "System",
        "ReconciliationCompleted"   => "System",
        "ReconciliationMissing"     => "System",
        "OrphanCleaned"             => "System",
        "ActivityPruned"            => "System",
        "CrawlStarted"             => "System",
        "CrawlFinished"            => "System",
        "SyncCompleted"             => "System",
        "WeeklySyncStarted"         => "System",

        _ => "System",
    };

    private void ApplyFilter()
    {
        if (_activityFilter == "All")
        {
            _filteredGroupedEntries = _groupedEntries;
            return;
        }

        _filteredGroupedEntries = _groupedEntries
            .Select(g => new DateGroup
            {
                Date      = g.Date,
                DateLabel = g.DateLabel,
                Entries   = g.Entries
                    .Where(e => GetFilterCategory(e.ActionType) == _activityFilter)
                    .ToList(),
            })
            .Where(g => g.Entries.Count > 0)
            .ToList();
    }

    // ── Retention ────────────────────────────────────────────────────────────────

    private async Task SaveRetentionAsync()
    {
        _savingRetention = true;
        StateHasChanged();

        var success = await Orchestrator.UpdateRetentionAsync(_retentionDays);
        _savingRetention = false;

        if (success)
        {
            _savedRetentionDays = _retentionDays;
            Snackbar.Add($"Retention updated to {_retentionDays} days", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to update retention — is the Engine running?", Severity.Error);
        }
    }

    private async Task TriggerPruneAsync()
    {
        _pruning = true;
        StateHasChanged();

        var result = await Orchestrator.TriggerPruneAsync();
        _pruning = false;

        if (result is not null)
        {
            Snackbar.Add($"Pruned {result.Deleted} entries", Severity.Success);
            await RefreshAsync();
        }
        else
        {
            Snackbar.Add("Prune failed — is the Engine running?", Severity.Error);
        }
    }

    // ── Date grouping ────────────────────────────────────────────────────────────

    private void RebuildGroups()
    {
        _absorbedEntryIds.Clear();
        _missingEntityIds.Clear();
        _ingestionSubSteps.Clear();
        _hydrationStages.Clear();
        _crawlStartPair.Clear();
        _startupAbsorbed.Clear();
        _startupRecon.Clear();
        _mediaAddedBatches.Clear();

        // ── Missing entity IDs (for reprocess button guard) ─────────────────────
        foreach (var e in _entries.Where(e => e.ActionType == "ReconciliationMissing"))
            if (e.EntityId is not null) _missingEntityIds.Add(e.EntityId);

        // ── ReconciliationMissing → ReconciliationCompleted (within 5 min) ──────
        var reconCompletedTs = _entries
            .Where(e => e.ActionType == "ReconciliationCompleted")
            .Select(e => ParseTs(e.OccurredAt))
            .Where(t => t is not null)
            .Select(t => t!.Value)
            .ToList();
        foreach (var missing in _entries.Where(e => e.ActionType == "ReconciliationMissing"))
        {
            var ts = ParseTs(missing.OccurredAt);
            if (ts is null) continue;
            if (reconCompletedTs.Any(ct => ct >= ts.Value && (ct - ts.Value).TotalMinutes <= 5))
                _absorbedEntryIds.Add(missing.Id);
        }

        // ── Ingestion sub-steps and post-ingestion events → FileIngested ────────
        // Strategy 1: group by IngestionRunId (precise, new entries).
        // Strategy 2: fallback to timestamp + EntityId correlation (legacy entries).
        var ingSubTypes = new HashSet<string>
        {
            "FileDetected", "FileHashed", "FileProcessed", "FileScored",
            "EntityChainCreated", "CoverArtSaved", "MetadataTagsWritten",
            "HydrationEnqueued", "MovedToStaging",
        };
        var postIngestionTypes = new HashSet<string>
        {
            "PathUpdated", "MetadataHydrated", "PersonHydrated", "PersonEnriched",
            "SidecarUpdated", "BridgeSyncUpdated", "MetadataRefreshed", "HashVerified",
            "HydrationStage1Completed", "HydrationStage2Completed", "HydrationStage3Completed",
            "ReviewItemCreated", "ReviewItemResolved", "DuplicateSkipped", "MediaFailed",
            "MetadataWrittenToFile",
        };
        var allSubTypes = new HashSet<string>(ingSubTypes.Concat(postIngestionTypes));

        var ingestedIndex = _entries
            .Where(e => e.ActionType == "FileIngested")
            .Select(e => (Entry: e, Ts: ParseTs(e.OccurredAt)))
            .Where(x => x.Ts is not null)
            .ToList();

        // Build RunId → FileIngested parent lookup for precise grouping.
        var runIdToParent = ingestedIndex
            .Where(x => !string.IsNullOrEmpty(x.Entry.IngestionRunId))
            .GroupBy(x => x.Entry.IngestionRunId!)
            .ToDictionary(g => g.Key, g => g.First().Entry);

        foreach (var sub in _entries.Where(e => allSubTypes.Contains(e.ActionType)))
        {
            ActivityEntryViewModel? parent = null;

            // Strategy 1: match by IngestionRunId.
            if (!string.IsNullOrEmpty(sub.IngestionRunId)
                && runIdToParent.TryGetValue(sub.IngestionRunId, out var runParent))
            {
                parent = runParent;
            }
            else
            {
                // Strategy 2: fallback — timestamp + EntityId correlation.
                var subTs = ParseTs(sub.OccurredAt);
                if (subTs is not null)
                {
                    var maxWindow = ingSubTypes.Contains(sub.ActionType) ? 5 : 30;
                    parent = ingestedIndex
                        .Where(x =>
                            (sub.EntityId is null ||
                             string.Equals(x.Entry.EntityId, sub.EntityId, StringComparison.OrdinalIgnoreCase))
                            && (ingSubTypes.Contains(sub.ActionType)
                                ? (x.Ts!.Value >= subTs.Value && (x.Ts.Value - subTs.Value).TotalMinutes <= maxWindow)
                                : (subTs.Value >= x.Ts!.Value && (subTs.Value - x.Ts.Value).TotalMinutes <= maxWindow)))
                        .OrderBy(x => Math.Abs((x.Ts!.Value - subTs.Value).TotalSeconds))
                        .Select(x => x.Entry)
                        .FirstOrDefault();
                }
            }

            if (parent is null) continue;
            if (!_ingestionSubSteps.TryGetValue(parent.Id, out var subList))
                _ingestionSubSteps[parent.Id] = subList = [];
            subList.Add(sub);
            _absorbedEntryIds.Add(sub.Id);
        }

        // ── FileIngested → MediaAdded (promoted parent) ──────────────────────────
        // MediaAdded is the consolidated end-of-pipeline card.  FileIngested fires during
        // IngestionEngine and carries the initial local score — it should be a sub-step
        // inside MediaAdded, not a second standalone "Media Added" card.
        var mediaAddedIndex = _entries
            .Where(e => e.ActionType == "MediaAdded")
            .Select(e => (Entry: e, Ts: ParseTs(e.OccurredAt)))
            .Where(x => x.Ts is not null)
            .ToList();

        foreach (var ingested in ingestedIndex)
        {
            if (_absorbedEntryIds.Contains(ingested.Entry.Id)) continue;

            ActivityEntryViewModel? mediaParent = null;

            // Strategy 1: match by IngestionRunId (fast, precise).
            if (!string.IsNullOrEmpty(ingested.Entry.IngestionRunId))
            {
                mediaParent = mediaAddedIndex
                    .FirstOrDefault(x => string.Equals(
                        x.Entry.IngestionRunId, ingested.Entry.IngestionRunId,
                        StringComparison.OrdinalIgnoreCase))
                    .Entry;
            }

            // Strategy 2: match by EntityId — MediaAdded fires after FileIngested (up to 60 min).
            if (mediaParent is null && ingested.Ts is not null && !string.IsNullOrEmpty(ingested.Entry.EntityId))
            {
                mediaParent = mediaAddedIndex
                    .Where(x =>
                        string.Equals(x.Entry.EntityId, ingested.Entry.EntityId,
                            StringComparison.OrdinalIgnoreCase)
                        && x.Ts!.Value >= ingested.Ts.Value
                        && (x.Ts.Value - ingested.Ts.Value).TotalMinutes <= 60)
                    .OrderBy(x => (x.Ts!.Value - ingested.Ts.Value).TotalMinutes)
                    .Select(x => x.Entry)
                    .FirstOrDefault();
            }

            if (mediaParent is null) continue;

            // Absorb FileIngested into MediaAdded's sub-step list as the first step.
            if (!_ingestionSubSteps.TryGetValue(mediaParent.Id, out var mediaSubList))
                _ingestionSubSteps[mediaParent.Id] = mediaSubList = [];

            // Migrate any sub-steps already collected under the FileIngested parent.
            if (_ingestionSubSteps.TryGetValue(ingested.Entry.Id, out var existingSubList))
            {
                mediaSubList.AddRange(existingSubList);
                _ingestionSubSteps.Remove(ingested.Entry.Id);
            }

            mediaSubList.Insert(0, ingested.Entry);
            _absorbedEntryIds.Add(ingested.Entry.Id);
        }

        // ── Hydration stages → standalone MetadataHydrated (within 5 min) ──────
        // Only for MetadataHydrated entries that were NOT absorbed into a FileIngested parent.
        var hydStageTypes = new HashSet<string>
        {
            "HydrationStage1Completed", "HydrationStage2Completed", "HydrationStage3Completed",
        };
        var hydratedIndex = _entries
            .Where(e => e.ActionType == "MetadataHydrated" && !_absorbedEntryIds.Contains(e.Id))
            .Select(e => (Entry: e, Ts: ParseTs(e.OccurredAt)))
            .Where(x => x.Ts is not null)
            .ToList();
        foreach (var stage in _entries.Where(e =>
            hydStageTypes.Contains(e.ActionType) && !_absorbedEntryIds.Contains(e.Id)))
        {
            var stageTs = ParseTs(stage.OccurredAt);
            if (stageTs is null) continue;
            var parent = hydratedIndex
                .Where(x =>
                    (stage.EntityId is null ||
                     string.Equals(x.Entry.EntityId, stage.EntityId, StringComparison.OrdinalIgnoreCase))
                    && x.Ts!.Value >= stageTs.Value
                    && (x.Ts.Value - stageTs.Value).TotalMinutes <= 5)
                .OrderBy(x => x.Ts)
                .Select(x => x.Entry)
                .FirstOrDefault();
            if (parent is null) continue;
            if (!_hydrationStages.TryGetValue(parent.Id, out var stageList))
                _hydrationStages[parent.Id] = stageList = [];
            stageList.Add(stage);
            _absorbedEntryIds.Add(stage.Id);
        }

        // ── CrawlStarted + CrawlFinished → pair ─────────────────────────────────
        var crawlStartIndex = _entries
            .Where(e => e.ActionType == "CrawlStarted")
            .Select(e => (Entry: e, Ts: ParseTs(e.OccurredAt)))
            .Where(x => x.Ts is not null)
            .ToList();
        foreach (var crawlEnd in _entries.Where(e => e.ActionType == "CrawlFinished"))
        {
            var endTs = ParseTs(crawlEnd.OccurredAt);
            if (endTs is null) continue;
            var matchedStart = crawlStartIndex
                .Where(x => endTs.Value >= x.Ts!.Value && (endTs.Value - x.Ts.Value).TotalHours <= 2)
                .OrderByDescending(x => x.Ts)
                .Select(x => x.Entry)
                .FirstOrDefault();
            if (matchedStart is null) continue;
            _crawlStartPair[crawlEnd.Id] = matchedStart;
            _absorbedEntryIds.Add(matchedStart.Id);
        }

        // ── Startup cluster: noise + recon → ServerStarted ───────────────────────
        var noiseTypes = new HashSet<string> { "ActivityPruned", "DuplicateSkipped", "OrphanCleaned" };
        var serverStartIndex = _entries
            .Where(e => e.ActionType == "ServerStarted")
            .Select(e => (Entry: e, Ts: ParseTs(e.OccurredAt)))
            .Where(x => x.Ts is not null)
            .ToList();

        foreach (var noise in _entries.Where(e => noiseTypes.Contains(e.ActionType)))
        {
            var noiseTs = ParseTs(noise.OccurredAt);
            if (noiseTs is null) continue;
            var match = serverStartIndex
                .Where(x => Math.Abs((x.Ts!.Value - noiseTs.Value).TotalMinutes) <= 2)
                .OrderBy(x => Math.Abs((x.Ts!.Value - noiseTs.Value).TotalMinutes))
                .Select(x => x.Entry)
                .FirstOrDefault();
            if (match is null) continue;
            if (!_startupAbsorbed.TryGetValue(match.Id, out var noiseList))
                _startupAbsorbed[match.Id] = noiseList = [];
            noiseList.Add(noise);
            _absorbedEntryIds.Add(noise.Id);
        }

        foreach (var recon in _entries.Where(e => e.ActionType == "ReconciliationCompleted"))
        {
            var reconTs = ParseTs(recon.OccurredAt);
            if (reconTs is null) continue;
            var match = serverStartIndex
                .Where(x => reconTs.Value >= x.Ts!.Value && (reconTs.Value - x.Ts.Value).TotalMinutes <= 5)
                .OrderByDescending(x => x.Ts)
                .Select(x => x.Entry)
                .FirstOrDefault();
            if (match is null) continue;
            var reconData = string.IsNullOrWhiteSpace(recon.ChangesJson)
                ? null : ParseReconciliationData(recon.ChangesJson);
            if (reconData is { Missing: > 0 })
                _startupRecon[match.Id] = recon;          // has issues — show as expanded sub-card
            else
            {
                if (!_startupAbsorbed.TryGetValue(match.Id, out var reconList))
                    _startupAbsorbed[match.Id] = reconList = [];
                reconList.Add(recon);
            }
            _absorbedEntryIds.Add(recon.Id);
        }

        // ── MediaAdded batch grouping (multi-item add within 2-minute window) ─────
        // Group non-absorbed MediaAdded entries that occur within 2 minutes of each other.
        // The first in each cluster becomes the batch leader; the rest are absorbed as siblings.
        var nonAbsorbedMediaAdded = _entries
            .Where(e => e.ActionType == "MediaAdded" && !_absorbedEntryIds.Contains(e.Id))
            .Select(e => (Entry: e, Ts: ParseTs(e.OccurredAt)))
            .Where(x => x.Ts is not null)
            .OrderBy(x => x.Ts)
            .ToList();

        if (nonAbsorbedMediaAdded.Count > 1)
        {
            ActivityEntryViewModel? batchLeader = null;
            DateTimeOffset? batchStart = null;
            foreach (var (bEntry, bTs) in nonAbsorbedMediaAdded)
            {
                if (batchLeader is null || (bTs!.Value - batchStart!.Value).TotalMinutes > 2)
                {
                    batchLeader = bEntry;
                    batchStart  = bTs;
                }
                else
                {
                    if (!_mediaAddedBatches.TryGetValue(batchLeader.Id, out var sibList))
                        _mediaAddedBatches[batchLeader.Id] = sibList = [];
                    sibList.Add(bEntry);
                    _absorbedEntryIds.Add(bEntry.Id);
                }
            }
        }

        _groupedEntries = _entries
            .GroupBy(e =>
            {
                if (DateTimeOffset.TryParse(e.OccurredAt, out var ts))
                    return ts.LocalDateTime.Date;
                return DateTime.Today;
            })
            .OrderByDescending(g => g.Key)
            .Select(g => new DateGroup
            {
                Date      = g.Key,
                DateLabel = FormatDateLabel(g.Key),
                Entries   = g.ToList(),
            })
            .ToList();

        ApplyFilter();
    }

    private static string FormatDateLabel(DateTime date)
    {
        var today = DateTime.Today;
        if (date == today) return "Today";
        if (date == today.AddDays(-1)) return "Yesterday";
        if (date >= today.AddDays(-6)) return date.ToString("dddd");  // e.g. "Monday"
        return date.ToString("MMMM d, yyyy");                        // e.g. "February 28, 2026"
    }

    private static string FormatTime(string occurredAt)
    {
        if (DateTimeOffset.TryParse(occurredAt, out var ts))
            return ts.LocalDateTime.ToString("h:mm tt");  // e.g. "4:23 PM"
        return "\u2014";
    }

