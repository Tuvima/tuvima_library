@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar

@* Activity — Date-grouped timeline of all Engine actions: ingestion, metadata,
   organization, review resolution. Configurable retention at the top. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Section Header ──────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Timeline" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6" Style="flex: 1;">Activity</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                       Size="Size.Small"
                       Color="Color.Default"
                       title="Refresh"
                       OnClick="@RefreshAsync" />
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Timeline of every action the Engine has performed on your library.
    </MudText>

    @* ── Retention config ────────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Outlined.DateRange"
                     Size="Size.Small" Color="Color.Primary" />
            <MudText Typo="Typo.body2" Style="white-space: nowrap;">
                Keep activity for
            </MudText>
            <MudNumericField @bind-Value="_retentionDays"
                             Min="1" Max="365"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Style="max-width: 90px;"
                             Immediate="false" />
            <MudText Typo="Typo.body2">days</MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       OnClick="@SaveRetentionAsync"
                       Disabled="@(_savingRetention || _retentionDays == _savedRetentionDays)">
                @(_savingRetention ? "Saving..." : "Save")
            </MudButton>
            <MudSpacer />
            @if (_stats is not null)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                         Style="opacity: 0.7;">
                    @_stats.TotalEntries.ToString("N0") entries
                </MudChip>
            }
            <MudButton Variant="Variant.Text"
                       Color="Color.Warning"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.CleaningServices"
                       OnClick="@TriggerPruneAsync"
                       Disabled="@_pruning">
                @(_pruning ? "Pruning..." : "Prune Now")
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else if (_entries.Count == 0)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
            <MudIcon Icon="@Icons.Material.Filled.EventNote"
                     Size="Size.Large"
                     Style="font-size: 3rem; opacity: 0.3;" />
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                No activity recorded yet. Events will appear here as the Engine
                ingests files, enriches metadata, and manages your library.
            </MudText>
        </MudStack>
    }
    else
    {
        @* ── Date-grouped timeline ───────────────────────────────────────── *@
        @foreach (var group in _groupedEntries)
        {
            @* Date header *@
            <div class="activity-date-header">
                <MudIcon Icon="@Icons.Material.Filled.CalendarToday"
                         Size="Size.Small"
                         Style="color: var(--mud-palette-primary); opacity: 0.8;" />
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600; color: var(--mud-palette-primary);">
                    @group.DateLabel
                </MudText>
            </div>

            <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-4">
                <MudStack Spacing="0">
                    @foreach (var entry in group.Entries)
                    {
                        <div class="activity-timeline-row">
                            @* Timeline icon + connector line *@
                            <div class="activity-timeline-dot">
                                <div class="activity-icon-circle" style="@IconCircleStyle(entry.ActionType)">
                                    <MudIcon Icon="@ActionIcon(entry.ActionType)"
                                             Size="Size.Small"
                                             Style="font-size: 0.85rem; color: white;" />
                                </div>
                                <div class="activity-timeline-line" />
                            </div>

                            @* Entry content *@
                            <div class="activity-entry-content">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                        @ActionLabel(entry.ActionType)
                                    </MudText>
                                    @if (!string.IsNullOrEmpty(entry.HubName))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                                 Style="font-size: 0.7rem; height: 20px;">
                                            @entry.HubName
                                        </MudChip>
                                    }
                                    @if (!string.IsNullOrEmpty(entry.EntityType))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                                 Variant="Variant.Outlined"
                                                 Style="font-size: 0.65rem; height: 18px; opacity: 0.7;">
                                            @entry.EntityType
                                        </MudChip>
                                    }
                                    <MudSpacer />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                             Style="white-space: nowrap;">
                                        @FormatTime(entry.OccurredAt)
                                    </MudText>
                                </MudStack>

                                @if (!string.IsNullOrEmpty(entry.Detail))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary"
                                             Style="margin-top: 2px; line-height: 1.4;">
                                        @entry.Detail
                                    </MudText>
                                }

                                @* ── Rich match card for FileIngested entries ──── *@
                                @if (entry.RichData is { } rich)
                                {
                                    <div class="activity-rich-card">
                                        @* Thumbnail *@
                                        <div class="activity-rich-thumb">
                                            @if (!string.IsNullOrWhiteSpace(rich.EntityId))
                                            {
                                                <img src="@CoverUrl(rich.EntityId)"
                                                     alt="@rich.Title"
                                                     style="width: 100%; height: 100%; object-fit: cover;"
                                                     loading="lazy"
                                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                                <div style="display: none; width: 100%; height: 100%; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@Icons.Material.Filled.MenuBook"
                                                             Size="Size.Small" Color="Color.Secondary" />
                                                </div>
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.MenuBook"
                                                         Size="Size.Small" Color="Color.Secondary" />
                                            }
                                        </div>

                                        @* Details *@
                                        <div class="activity-rich-details">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                                @rich.Title
                                            </MudText>
                                            @if (!string.IsNullOrWhiteSpace(rich.Author))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    by @rich.Author
                                                </MudText>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(rich.Description))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                         Style="display: -webkit-box; -webkit-line-clamp: 2;
                                                                -webkit-box-orient: vertical; overflow: hidden;
                                                                text-overflow: ellipsis; margin-top: 2px;
                                                                font-size: 0.75rem; line-height: 1.4;">
                                                    @TruncateDescription(rich.Description, 120)
                                                </MudText>
                                            }

                                            @* Confidence bar *@
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                                                       Style="margin-top: 4px;">
                                                <MudProgressLinear Value="@(rich.Confidence * 100)"
                                                                   Color="@ConfidenceColor(rich.Confidence)"
                                                                   Size="Size.Small" Rounded="true"
                                                                   Style="width: 80px;" />
                                                <MudText Typo="Typo.caption" Style="font-size: 0.7rem;">
                                                    @($"{rich.Confidence:P0}")
                                                </MudText>
                                                @if (!string.IsNullOrWhiteSpace(rich.Year))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                             Style="font-size: 0.7rem;">
                                                        @rich.Year
                                                    </MudText>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(rich.MediaType))
                                                {
                                                    <MudIcon Icon="@MediaTypeIcon(rich.MediaType)"
                                                             Size="Size.Small"
                                                             Style="font-size: 0.85rem; opacity: 0.7;" />
                                                }
                                            </MudStack>
                                        </div>

                                        @* Reprocess button *@
                                        <div style="flex-shrink: 0; align-self: center;">
                                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                           Size="Size.Small"
                                                           Color="Color.Default"
                                                           title="Reprocess"
                                                           OnClick="@(() => OpenReprocessPanel(entry))" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </MudStack>
            </MudPaper>
        }

        @* Load more *@
        @if (_entries.Count >= _limit)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mt-2 mb-4">
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           OnClick="@LoadMoreAsync"
                           Disabled="@_loadingMore">
                    @(_loadingMore ? "Loading..." : "Load More")
                </MudButton>
            </MudStack>
        }
    }

</MudPaper>

@* ── Reprocess dialog ──────────────────────────────────────────────────── *@
<MudDialog @bind-Visible="_reprocessOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Reprocess — @(_reprocessEntry?.RichData?.Title ?? "Unknown")</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
            <MudSelect T="string" @bind-Value="_reprocessProvider" Dense="true"
                       Variant="Variant.Outlined" Label="Provider"
                       Style="max-width: 200px;" Margin="Margin.Dense">
                @foreach (var p in GetReprocessProviders())
                {
                    <MudSelectItem Value="@p.Name">@p.DisplayName</MudSelectItem>
                }
            </MudSelect>
            <MudTextField T="string" @bind-Value="_reprocessQuery" Variant="Variant.Outlined"
                          Label="Search Term" Margin="Margin.Dense"
                          Style="flex: 1;"
                          OnKeyUp="@OnReprocessKeyUp" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(string.IsNullOrWhiteSpace(_reprocessProvider) || string.IsNullOrWhiteSpace(_reprocessQuery))"
                       OnClick="@ReprocessSearchAsync">
                Search
            </MudButton>
        </MudStack>

        @if (_reprocessSearching)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        }

        @if (_reprocessResults.Count > 0)
        {
            <div style="max-height: 420px; overflow-y: auto; border: 1px solid var(--mud-palette-lines-default);
                        border-radius: 8px; background: var(--mud-palette-surface);">
                @foreach (var result in _reprocessResults)
                {
                    <SearchResultCard Result="@result"
                                     OnSelected="@(r => ReprocessSelectAsync(r))" />
                }
            </div>
        }
        else if (_reprocessSearchExecuted && !_reprocessSearching)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                No results found. Try a different search term or provider.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@CloseReprocessDialog">
            Cancel
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    // ── Style constants ──────────────────────────────────────────────────────────

    private const string GlassStyle =
        "background: var(--app-glass-bg); " +
        "border: 1px solid var(--app-glass-border); " +
        "backdrop-filter: blur(10px); " +
        "-webkit-backdrop-filter: blur(10px); " +
        "border-radius: 32px; " +
        "padding: 32px;";

    private const string InnerCardStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 16px; " +
        "padding: 24px;";

    // ── State ────────────────────────────────────────────────────────────────────

    private bool _loading = true;
    private bool _loadingMore;
    private bool _pruning;
    private bool _savingRetention;
    private int  _limit = 100;
    private int  _retentionDays = 60;
    private int  _savedRetentionDays = 60;

    private List<ActivityEntryViewModel> _entries = [];
    private ActivityStatsViewModel?      _stats;
    private List<DateGroup>              _groupedEntries = [];

    // ── Reprocess dialog state ────────────────────────────────────────────────
    private bool                          _reprocessOpen;
    private ActivityEntryViewModel?       _reprocessEntry;
    private string                        _reprocessProvider = string.Empty;
    private string                        _reprocessQuery = string.Empty;
    private List<MetadataSearchResultDto> _reprocessResults = [];
    private bool                          _reprocessSearching;
    private bool                          _reprocessSearchExecuted;
    private IReadOnlyList<ProviderStatusDto> _providers = [];
    private Dictionary<string, ProviderSlotDto> _slots = new();

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var refreshTask   = RefreshAsync();
        var slotsTask     = Orchestrator.GetProviderSlotsAsync();
        var providersTask = Orchestrator.GetProviderStatusAsync();
        await Task.WhenAll(refreshTask, slotsTask, providersTask);
        _slots     = slotsTask.Result ?? new();
        _providers = providersTask.Result;
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();

        var entriesTask = Orchestrator.GetRecentActivityAsync(_limit);
        var statsTask   = Orchestrator.GetActivityStatsAsync();
        await Task.WhenAll(entriesTask, statsTask);

        _entries = entriesTask.Result;
        _stats   = statsTask.Result;

        if (_stats is not null)
        {
            _retentionDays      = _stats.RetentionDays;
            _savedRetentionDays = _stats.RetentionDays;
        }

        RebuildGroups();
        _loading = false;
    }

    private async Task LoadMoreAsync()
    {
        _loadingMore = true;
        StateHasChanged();

        _limit += 100;
        var entries = await Orchestrator.GetRecentActivityAsync(_limit);
        _entries = entries;
        RebuildGroups();

        _loadingMore = false;
    }

    // ── Retention ────────────────────────────────────────────────────────────────

    private async Task SaveRetentionAsync()
    {
        _savingRetention = true;
        StateHasChanged();

        var success = await Orchestrator.UpdateRetentionAsync(_retentionDays);
        _savingRetention = false;

        if (success)
        {
            _savedRetentionDays = _retentionDays;
            Snackbar.Add($"Retention updated to {_retentionDays} days", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to update retention — is the Engine running?", Severity.Error);
        }
    }

    private async Task TriggerPruneAsync()
    {
        _pruning = true;
        StateHasChanged();

        var result = await Orchestrator.TriggerPruneAsync();
        _pruning = false;

        if (result is not null)
        {
            Snackbar.Add($"Pruned {result.Deleted} entries", Severity.Success);
            await RefreshAsync();
        }
        else
        {
            Snackbar.Add("Prune failed — is the Engine running?", Severity.Error);
        }
    }

    // ── Date grouping ────────────────────────────────────────────────────────────

    private void RebuildGroups()
    {
        _groupedEntries = _entries
            .GroupBy(e =>
            {
                if (DateTimeOffset.TryParse(e.OccurredAt, out var ts))
                    return ts.LocalDateTime.Date;
                return DateTime.Today;
            })
            .OrderByDescending(g => g.Key)
            .Select(g => new DateGroup
            {
                Date      = g.Key,
                DateLabel = FormatDateLabel(g.Key),
                Entries   = g.ToList(),
            })
            .ToList();
    }

    private static string FormatDateLabel(DateTime date)
    {
        var today = DateTime.Today;
        if (date == today) return "Today";
        if (date == today.AddDays(-1)) return "Yesterday";
        if (date >= today.AddDays(-6)) return date.ToString("dddd");  // e.g. "Monday"
        return date.ToString("MMMM d, yyyy");                        // e.g. "February 28, 2026"
    }

    private static string FormatTime(string occurredAt)
    {
        if (DateTimeOffset.TryParse(occurredAt, out var ts))
            return ts.LocalDateTime.ToString("h:mm tt");  // e.g. "4:23 PM"
        return "—";
    }

    // ── Reprocess dialog ─────────────────────────────────────────────────────────

    private void OpenReprocessPanel(ActivityEntryViewModel entry)
    {
        _reprocessEntry    = entry;
        _reprocessQuery    = entry.RichData?.Title ?? string.Empty;
        _reprocessResults  = [];
        _reprocessSearching    = false;
        _reprocessSearchExecuted = false;

        // Pre-select primary provider.
        var providers = GetReprocessProviders();
        _reprocessProvider = providers.FirstOrDefault()?.Name ?? string.Empty;
        _reprocessOpen = true;
    }

    private void CloseReprocessDialog()
    {
        _reprocessOpen = false;
        _reprocessEntry = null;
        _reprocessResults = [];
    }

    private sealed record ReprocessProviderInfo(string Name, string DisplayName);

    private List<ReprocessProviderInfo> GetReprocessProviders()
    {
        var result = new List<ReprocessProviderInfo>();
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        // Add slotted providers first based on the media type.
        var mediaType = _reprocessEntry?.RichData?.MediaType;
        var slotKey = mediaType?.ToLowerInvariant() switch
        {
            "epub"      => "Books",
            "audiobook" => "Audiobooks",
            "comic"     => "Comics",
            "movie"     => "Movies",
            "tv"        => "TV Shows",
            _           => null,
        };

        if (slotKey is not null && _slots.TryGetValue(slotKey, out var slot))
        {
            TryAdd(slot.Primary);
            TryAdd(slot.Secondary);
            TryAdd(slot.Tertiary);
        }

        // Add remaining enabled providers.
        foreach (var p in _providers.Where(p => p.Enabled))
        {
            if (string.Equals(p.Name, "local_filesystem", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(p.Name, "local_processor", StringComparison.OrdinalIgnoreCase))
                continue;
            if (string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase))
                continue;
            if (!seen.Add(p.Name)) continue;
            result.Add(new(p.Name, p.DisplayName ?? p.Name));
        }

        // Wikidata last.
        var wd = _providers.FirstOrDefault(p =>
            string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase));
        if (wd is { Enabled: true })
            result.Add(new(wd.Name, "Wikidata (Universe)"));

        return result;

        void TryAdd(string? name)
        {
            if (string.IsNullOrWhiteSpace(name)) return;
            if (!seen.Add(name)) return;
            var p = _providers.FirstOrDefault(x =>
                string.Equals(x.Name, name, StringComparison.OrdinalIgnoreCase));
            result.Add(new(name, p?.DisplayName ?? name));
        }
    }

    private async Task ReprocessSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_reprocessProvider) || string.IsNullOrWhiteSpace(_reprocessQuery))
            return;

        _reprocessSearching = true;
        _reprocessSearchExecuted = false;
        StateHasChanged();

        _reprocessResults = await Orchestrator.SearchMetadataAsync(
            _reprocessProvider, _reprocessQuery,
            mediaType: _reprocessEntry?.RichData?.MediaType, limit: 25);
        _reprocessSearching = false;
        _reprocessSearchExecuted = true;
        StateHasChanged();
    }

    private async Task OnReprocessKeyUp(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ReprocessSearchAsync();
    }

    private async Task ReprocessSelectAsync(MetadataSearchResultDto result)
    {
        if (_reprocessEntry?.RichData?.EntityId is not { } entityIdStr ||
            !Guid.TryParse(entityIdStr, out var entityId))
        {
            Snackbar.Add("Missing entity reference — cannot reprocess.", Severity.Error);
            return;
        }

        // Override with selected match fields.
        var fields = new Dictionary<string, string>();
        if (!string.IsNullOrWhiteSpace(result.Title))
            fields["title"] = result.Title;
        if (!string.IsNullOrWhiteSpace(result.Author))
            fields["author"] = result.Author;
        if (!string.IsNullOrWhiteSpace(result.Year))
            fields["year"] = result.Year;
        if (!string.IsNullOrWhiteSpace(result.Description))
            fields["description"] = result.Description;

        if (fields.Count > 0)
        {
            var ok = await Orchestrator.OverrideMetadataAsync(entityId, fields);
            if (!ok)
            {
                Snackbar.Add("Failed to override metadata.", Severity.Error);
                return;
            }
        }

        // Re-trigger hydration.
        await Orchestrator.TriggerHydrationAsync(entityId);

        Snackbar.Add($"Reprocessed — \"{result.Title}\" selected", Severity.Success);
        CloseReprocessDialog();
        await RefreshAsync();
    }

    // ── Rich card helpers ─────────────────────────────────────────────────────

    private static string CoverUrl(string entityId)
        => $"/stream/{entityId}/cover";

    private static string MediaTypeIcon(string? mediaType) => mediaType?.ToLowerInvariant() switch
    {
        "epub"      => Icons.Material.Filled.MenuBook,
        "audiobook" => Icons.Material.Filled.Headphones,
        "comic"     => Icons.Material.Filled.CollectionsBookmark,
        "movie"     => Icons.Material.Filled.Movie,
        "tv"        => Icons.Material.Filled.Tv,
        "music"     => Icons.Material.Filled.MusicNote,
        _           => Icons.Material.Filled.InsertDriveFile,
    };

    private static Color ConfidenceColor(double confidence) => confidence switch
    {
        >= 0.70 => Color.Success,
        >= 0.40 => Color.Warning,
        _       => Color.Error,
    };

    private static string TruncateDescription(string? desc, int max)
    {
        if (string.IsNullOrWhiteSpace(desc)) return string.Empty;
        return desc.Length <= max ? desc : desc[..max] + "...";
    }

    // ── Action type display helpers ──────────────────────────────────────────────

    private static readonly Dictionary<string, (string Icon, string Label, string Bg)> ActionMeta = new()
    {
        ["FileIngested"]              = (Icons.Material.Filled.FilePresent,       "File Ingested",              "#4caf50"),
        ["MetadataHydrated"]          = (Icons.Material.Filled.Science,           "Metadata Hydrated",          "#2196f3"),
        ["HashVerified"]              = (Icons.Material.Filled.Fingerprint,       "Hash Verified",              "#2196f3"),
        ["PathUpdated"]               = (Icons.Material.Filled.DriveFileMove,     "Path Updated",               "#ff9800"),
        ["SyncCompleted"]             = (Icons.Material.Filled.CloudDone,         "Sync Completed",             "#4caf50"),
        ["CrawlStarted"]             = (Icons.Material.Filled.Search,            "Crawl Started",              "#2196f3"),
        ["CrawlFinished"]            = (Icons.Material.Filled.SearchOff,         "Crawl Finished",             "#4caf50"),
        ["MetadataRefreshed"]         = (Icons.Material.Filled.Autorenew,         "Metadata Refreshed",         "#2196f3"),
        ["SidecarUpdated"]            = (Icons.Material.Filled.Description,       "Sidecar Updated",            "#78909c"),
        ["ActivityPruned"]            = (Icons.Material.Filled.CleaningServices,  "Activity Pruned",            "#ff9800"),
        ["BridgeSyncUpdated"]         = (Icons.Material.Filled.Link,             "Bridge Sync Updated",        "#2196f3"),
        ["PersonHydrated"]            = (Icons.Material.Filled.Person,           "Person Hydrated",            "#4caf50"),
        ["WeeklySyncStarted"]         = (Icons.Material.Filled.Sync,             "Weekly Sync Started",        "#2196f3"),
        ["AffiliateGenerated"]        = (Icons.Material.Filled.LocalOffer,       "Affiliate Generated",        "#4caf50"),
        ["HydrationStage1Completed"]  = (Icons.Material.Filled.LooksOne,         "Content Match Complete",     "#26a69a"),
        ["HydrationStage2Completed"]  = (Icons.Material.Filled.LooksTwo,         "Universe Match Complete",    "#26a69a"),
        ["HydrationStage3Completed"]  = (Icons.Material.Filled.Looks3,           "Person Enrichment Complete", "#26a69a"),
        ["ReviewItemCreated"]         = (Icons.Material.Filled.RateReview,        "Sent to Review",            "#ff9800"),
