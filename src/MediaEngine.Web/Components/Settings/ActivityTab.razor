    private List<DateGroup>              _filteredGroupedEntries = [];

    // Expand/collapse state for expandable entries.
    private readonly HashSet<long> _expandedEntryIds = [];

    // Absorbed entry IDs (ReconciliationMissing absorbed into ReconciliationCompleted).
    private readonly HashSet<long> _absorbedEntryIds = [];

    // Entity IDs of files confirmed deleted (hides the reprocess button on FileIngested cards).
    private readonly HashSet<string> _missingEntityIds = new(StringComparer.OrdinalIgnoreCase);

    // ── Reprocess dialog state ────────────────────────────────────────────────
    private bool                          _reprocessOpen;
    private ActivityEntryViewModel?       _reprocessEntry;
    private string                        _reprocessProvider = string.Empty;
    private string                        _reprocessQuery = string.Empty;
    private List<MetadataSearchResultDto> _reprocessResults = [];
    private MetadataSearchResultDto?      _reprocessSelectedResult;
    private bool                          _reprocessSearching;
    private bool                          _reprocessSearchExecuted;
    private IReadOnlyList<ProviderStatusDto> _providers = [];
    private Dictionary<string, ProviderSlotDto> _slots = new();

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var refreshTask   = RefreshAsync();
        var slotsTask     = Orchestrator.GetProviderSlotsAsync();
        var providersTask = Orchestrator.GetProviderStatusAsync();
        await Task.WhenAll(refreshTask, slotsTask, providersTask);
        _slots     = slotsTask.Result ?? new();
        _providers = providersTask.Result;
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();

        var entriesTask = Orchestrator.GetRecentActivityAsync(_limit);
        var statsTask   = Orchestrator.GetActivityStatsAsync();
        await Task.WhenAll(entriesTask, statsTask);

        _entries = entriesTask.Result;
        _stats   = statsTask.Result;

        if (_stats is not null)
        {
            _retentionDays      = _stats.RetentionDays;
            _savedRetentionDays = _stats.RetentionDays;
        }

        RebuildGroups();
        _loading = false;
    }

    private async Task LoadMoreAsync()
    {
        _loadingMore = true;
        StateHasChanged();

        _limit += 100;
        var entries = await Orchestrator.GetRecentActivityAsync(_limit);
        _entries = entries;
        RebuildGroups();

        _loadingMore = false;
    }

