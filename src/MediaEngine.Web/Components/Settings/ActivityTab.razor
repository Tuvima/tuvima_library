    // ── Reconciliation data parsing ─────────────────────────────────────────────

    private sealed record MissingFileInfo(string Filename, string Action);
    private sealed record ReconData(int Total, int Missing, long Elapsed, string? StartedAt, List<MissingFileInfo> MissingFiles);

    private static ReconData? ParseReconciliationData(string json)
    {
        try
        {
            using var doc   = System.Text.Json.JsonDocument.Parse(json);
            var root        = doc.RootElement;
            var total       = root.TryGetProperty("total_scanned", out var t)  ? t.GetInt32()  : 0;
            var missing     = root.TryGetProperty("missing_count", out var m)  ? m.GetInt32()  : 0;
            var elapsed     = root.TryGetProperty("elapsed_ms",    out var e)  ? e.GetInt64()  : 0L;
            var startedAt   = root.TryGetProperty("started_at",    out var sa) ? sa.GetString() : null;

            var missingFiles = new List<MissingFileInfo>();
            if (root.TryGetProperty("missing_files", out var mfArr)
                && mfArr.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var mf in mfArr.EnumerateArray())
                {
                    var fn = mf.TryGetProperty("filename", out var fnEl) ? fnEl.GetString() ?? "" : "";
                    var ac = mf.TryGetProperty("action",   out var acEl) ? acEl.GetString() ?? "" : "";
                    missingFiles.Add(new(fn, ac));
                }
            }

            return new ReconData(total, missing, elapsed, startedAt, missingFiles);
        }
        catch
        {
            return null;
        }
    }

    private static string FormatElapsed(long ms)
    {
        if (ms < 1000) return $"{ms}ms";
        return $"{ms / 1000.0:F1}s";
    }

    private static string ReconTimeLabel(ActivityEntryViewModel entry)
    {
        var endLabel = FormatTime(entry.OccurredAt);
        if (string.IsNullOrWhiteSpace(entry.ChangesJson)) return endLabel;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(entry.ChangesJson);
            if (doc.RootElement.TryGetProperty("started_at", out var sa)
                && DateTimeOffset.TryParse(sa.GetString(), out var startTs))
            {
                var startLabel = startTs.LocalDateTime.ToString("h:mm tt");
                return $"{startLabel} – {endLabel}";
            }
        }
        catch { /* ignore */ }
        return endLabel;
    }

