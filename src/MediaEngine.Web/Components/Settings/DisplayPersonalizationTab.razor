@namespace MediaEngine.Web.Components.Settings
@inject ISnackbar Snackbar

<div class="tl-page">
    <MudGrid Spacing="4">
        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Start Page</MudText>
                <MudSelect T="string" @bind-Value="_defaultLandingArea" Label="Default landing area" Variant="Variant.Outlined" FullWidth="true" Class="mt-3">
                    <MudSelectItem T="string" Value="@("new")">What's New</MudSelectItem>
                    <MudSelectItem T="string" Value="@("watch")">Watch</MudSelectItem>
                    <MudSelectItem T="string" Value="@("read")">Read</MudSelectItem>
                    <MudSelectItem T="string" Value="@("listen")">Listen</MudSelectItem>
                </MudSelect>
                <MudSwitch T="bool" @bind-Value="_resumeLastArea" Color="Color.Primary" Label="Resume last area" Class="mt-3" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Home Layout</MudText>
                <MudSwitch T="bool" @bind-Value="_showHeroBanner" Color="Color.Primary" Label="Show hero banner" />
                <MudSwitch T="bool" @bind-Value="_showContinueRow" Color="Color.Primary" Label="Show continue row" />
                <MudSwitch T="bool" @bind-Value="_showRecentlyAddedRow" Color="Color.Primary" Label="Show recently added row" />
                <MudSwitch T="bool" @bind-Value="_showRecommendations" Color="Color.Primary" Label="Show personalized recommendations" />
                <MudToggleGroup T="string" @bind-Value="_rowDensity" SelectionMode="SelectionMode.SingleSelection" Color="Color.Primary" Outlined="true" Class="mt-3">
                    <MudToggleItem T="string" Value="@("comfortable")">Comfortable</MudToggleItem>
                    <MudToggleItem T="string" Value="@("compact")">Compact</MudToggleItem>
                </MudToggleGroup>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Media Cards</MudText>
                <MudToggleGroup T="string" @bind-Value="_cardDensity" SelectionMode="SelectionMode.SingleSelection" Color="Color.Primary" Outlined="true" Class="my-3">
                    <MudToggleItem T="string" Value="@("comfortable")">Comfortable</MudToggleItem>
                    <MudToggleItem T="string" Value="@("compact")">Compact</MudToggleItem>
                </MudToggleGroup>
                <MudSwitch T="bool" @bind-Value="_showProgressBadge" Color="Color.Primary" Label="Show progress badge" />
                <MudSwitch T="bool" @bind-Value="_showSourceBadge" Color="Color.Primary" Label="Show source/provider badge" />
                <MudSwitch T="bool" @bind-Value="_showMediaTypeChip" Color="Color.Primary" Label="Show media type chip" />
                <MudSwitch T="bool" @bind-Value="_preferBannerArt" Color="Color.Primary" Label="Prefer banner art when available" />
                <MudSwitch T="bool" @bind-Value="_useGeneratedFallback" Color="Color.Primary" Label="Use cover-art generated fallback when no backdrop is available" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Spoilers</MudText>
                <MudSwitch T="bool" @bind-Value="_hideEpisodeTitles" Color="Color.Primary" Label="Hide unwatched episode titles" />
                <MudSwitch T="bool" @bind-Value="_hideBookSummaries" Color="Color.Primary" Label="Hide unread book summaries" />
                <MudSwitch T="bool" @bind-Value="_hideFinaleDescriptions" Color="Color.Primary" Label="Hide season/book finale descriptions" />
                <MudSwitch T="bool" @bind-Value="_blurUnrevealedArt" Color="Color.Primary" Label="Blur art for unrevealed content if needed" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Recommendations</MudText>
                <MudGrid Spacing="2" Class="mt-1">
                    <MudItem xs="12" md="4">
                        <MudSwitch T="bool" @bind-Value="_useHistoryForPersonalization" Color="Color.Primary" Label="Use watch/read/listen history for personalization" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSwitch T="bool" @bind-Value="_useLocalAiRecommendations" Color="Color.Primary" Label="Use local AI for recommendations" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSwitch T="bool" @bind-Value="_showBecauseYouLiked" Color="Color.Primary" Label="Show Because you liked explanations" />
                    </MudItem>
                </MudGrid>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Save" OnClick="@SaveAsync" Class="mt-4">
                    Save Display Settings
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@code {
    private string _defaultLandingArea = "new";
    private bool _resumeLastArea = true;
    private bool _showHeroBanner = true;
    private bool _showContinueRow = true;
    private bool _showRecentlyAddedRow = true;
    private bool _showRecommendations = true;
    private string _rowDensity = "comfortable";
    private string _cardDensity = "comfortable";
    private bool _showProgressBadge = true;
    private bool _showSourceBadge;
    private bool _showMediaTypeChip = true;
    private bool _preferBannerArt = true;
    private bool _useGeneratedFallback = true;
    private bool _hideEpisodeTitles = true;
    private bool _hideBookSummaries = true;
    private bool _hideFinaleDescriptions = true;
    private bool _blurUnrevealedArt;
    private bool _useHistoryForPersonalization = true;
    private bool _useLocalAiRecommendations = true;
    private bool _showBecauseYouLiked = true;

    private async Task SaveAsync()
    {
        // TODO: Persist display and personalization preferences when user settings APIs exist.
        await Task.CompletedTask;
        Snackbar.Add("Display settings are staged locally until preference persistence is wired.", Severity.Info);
    }
}
