@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@implements IDisposable

@* Needs Review — items grouped by reason so users understand why each item is here. *@

<MudText Typo="Typo.h5" Class="mb-1">Needs Review</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Items that need your attention, grouped by reason.
</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_items.Count == 0)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined"
              Icon="@Icons.Material.Filled.CheckCircle">
        No items pending review.
    </MudAlert>
}
else
{
    @foreach (var entry in BuildDisplayList())
    {
        @if (entry.IsSectionHeader)
        {
            @* ── Section header ─────────────────────────────────────────── *@
            <div class="review-section-header @(entry.SectionCssClass)">
                <MudIcon Icon="@entry.SectionIcon" Class="review-section-icon" />
                <div>
                    <div class="review-section-title-row">
                        <span class="review-section-title">@entry.SectionTitle</span>
                        <span class="review-section-count">@entry.SectionCount</span>
                    </div>
                    <span class="review-section-desc">@entry.SectionDesc</span>
                </div>
            </div>
        }
        else if (entry.Item is { } item)
        {
            @* ── Review item card ────────────────────────────────────────── *@
            <MudPaper Class="pa-3 mb-2 review-item-card" Elevation="0">

                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <div>
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                @(item.EntityTitle ?? item.Detail ?? item.EntityId.ToString()[..8] + "...")
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @FormatMediaType(item.MediaType)@(!string.IsNullOrWhiteSpace(item.MediaType) ? " \u2022 " : "")@FormatTriggerDetail(item.Trigger)
                            </MudText>
                        </div>
                    </MudStack>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@(() => ToggleReviewPanel(item))">
                            @(_expandedItemId == item.Id ? "Close" : "Review")
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                                   OnClick="@(() => DismissItemAsync(item.Id))">
                            Dismiss
                        </MudButton>
                    </MudStack>
                </MudStack>

                @* ── Expanded panel ──────────────────────────────────────── *@
                @if (_expandedItemId == item.Id)
                {
                    <MudDivider Class="my-3" />

                    @if (item.Trigger == "AmbiguousMediaType")
                    {
                        <MudText Typo="Typo.body2" Class="mb-2">
                            Select the correct media type for this file:
                        </MudText>
                        <MudStack Row="true" Spacing="2" Class="mb-2" Wrap="Wrap.Wrap">
                            @foreach (var candidate in ParseMediaTypeCandidates(item.CandidatesJson))
                            {
                                <MudPaper Class="pa-3" Elevation="0"
                                          Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 6px;
                                                 min-width: 180px; cursor: pointer;"
                                          @onclick="@(() => ReclassifyAsync(item, candidate.Type))">
                                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                            @candidate.Type
                                        </MudText>
                                        <MudProgressLinear Value="@(candidate.Confidence * 100)"
                                                           Color="@ConfidenceColor(candidate.Confidence)"
                                                           Size="Size.Small" Rounded="true"
                                                           Style="width: 120px;" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                            @($"{candidate.Confidence:P0}")
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center"
                                                 Style="font-size: 0.7rem; max-width: 200px; word-break: break-word;">
                                            @candidate.Reason
                                        </MudText>
                                    </MudStack>
                                </MudPaper>
                            }
                        </MudStack>
                    }
                    else
                    {
                        @* ── Provider + search bar ─────────────────────────── *@
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudSelect T="string" @bind-Value="_selectedProvider" Dense="true"
                                       Variant="Variant.Outlined" Label="Provider"
                                       Style="max-width: 200px;" Margin="Margin.Dense">
                                @foreach (var p in GetSlottedProviders(item.MediaType))
                                {
                                    <MudSelectItem Value="@p.Name">@p.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                            <MudTextField T="string" @bind-Value="_searchQuery" Variant="Variant.Outlined"
                                          Label="Search Term" Margin="Margin.Dense"
                                          Style="flex: 1;"
                                          OnKeyUp="@OnSearchKeyUp" />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       Disabled="@(string.IsNullOrWhiteSpace(_selectedProvider) || string.IsNullOrWhiteSpace(_searchQuery))"
                                       OnClick="@ExecuteSearchAsync">
                                Search
                            </MudButton>
                        </MudStack>

                        @if (_searching)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
                        }

                        @if (_searchResults.Count > 0)
                        {
                            <div style="max-height: 520px; overflow-y: auto;
                                        border: 1px solid var(--mud-palette-lines-default);
                                        border-radius: 4px; background: var(--mud-palette-surface);">
                                @foreach (var result in _searchResults)
                                {
                                    <SearchResultCard Result="@result"
                                                     IsSelected="@(result == _selectedSearchResult)"
                                                     OnSelected="@(r => { _selectedSearchResult = r == _selectedSearchResult ? null : r; StateHasChanged(); })" />
                                }
                            </div>

                            @if (_selectedSearchResult is not null)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           FullWidth="true" Class="mt-3"
                                           StartIcon="@Icons.Material.Filled.CheckCircle"
                                           OnClick="@(() => SelectMatchAsync(item, _selectedSearchResult))">
                                    Confirm: "@(_selectedSearchResult.Title)"
                                </MudButton>
                            }
                        }
                        else if (_searchExecuted && !_searching)
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                No results found. Try a different search term or provider.
                            </MudAlert>
                        }

                        <MudStack Row="true" Spacing="2" Class="mt-2">
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => OpenEditDialog(item))">
                                Edit Manually
                            </MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Info"
                                       StartIcon="@Icons.Material.Filled.ManageSearch"
                                       Disabled="@(_rehydrating)"
                                       OnClick="@(() => SearchAgainAsync(item))">
                                @(_rehydrating ? "Searching..." : "Search Again")
                            </MudButton>
                        </MudStack>
                    }
                }
            </MudPaper>
        }
    }
}

@* ── Edit Metadata dialog ─────────────────────────────────────────────── *@
<MetadataEditDialog @bind-Visible="_editDialogOpen"
                    EntityId="@_editEntityId"
                    MediaType="@_editMediaType"
                    CurrentValues="@_editCurrentValues"
                    OnSaved="@OnEditSaved" />

<style>
    .review-section-header {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 16px;
        margin: 20px 0 8px;
        border-radius: 8px;
    }

    .review-section-header:first-child {
        margin-top: 0;
    }

    .review-section-header.universe {
        background: rgba(33, 150, 243, 0.08);
        border-left: 3px solid var(--mud-palette-info);
    }

    .review-section-header.content {
        background: rgba(255, 152, 0, 0.08);
        border-left: 3px solid var(--mud-palette-warning);
    }

    .review-section-header.mediatype {
        background: rgba(156, 39, 176, 0.08);
        border-left: 3px solid var(--mud-palette-tertiary);
    }

    .review-section-icon {
        flex-shrink: 0;
        margin-top: 2px;
    }

    .review-section-title-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .review-section-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .review-section-count {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 1px 7px;
        border-radius: 10px;
        background: rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.7);
    }

    .review-section-desc {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.78rem;
        color: rgba(255,255,255,0.5);
    }

    .review-item-card {
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 6px;
    }
</style>

@code {
    private List<ReviewItemViewModel> _items = [];
    private bool _loading = true;

    // ── Section grouping ──────────────────────────────────────────────────

    private static readonly HashSet<string> UniverseMatchTriggers =
    [
        "UniverseMatchFailed",
        "MultipleQidMatches",
    ];

    private static readonly HashSet<string> ContentMatchTriggers =
    [
        "ContentMatchFailed",
        "LowConfidence",
        "ArbiterNeedsReview",
        "MetadataConflict",
    ];

    private static readonly HashSet<string> MediaTypeTriggers =
    [
        "AmbiguousMediaType",
    ];

    private List<ReviewItemViewModel> UniverseMatchItems =>
        _items.Where(i => UniverseMatchTriggers.Contains(i.Trigger)).ToList();

    private List<ReviewItemViewModel> ContentMatchItems =>
        _items.Where(i => ContentMatchTriggers.Contains(i.Trigger)).ToList();

    private List<ReviewItemViewModel> MediaTypeItems =>
        _items.Where(i => MediaTypeTriggers.Contains(i.Trigger)).ToList();

    private sealed record DisplayItem(
        bool IsSectionHeader,
        string SectionTitle = "",
        string SectionDesc = "",
        string SectionIcon = "",
        string SectionCssClass = "",
        int SectionCount = 0,
        ReviewItemViewModel? Item = null);

    private IReadOnlyList<DisplayItem> BuildDisplayList()
    {
        var list = new List<DisplayItem>();

        var universe = UniverseMatchItems;
        if (universe.Count > 0)
        {
            list.Add(new DisplayItem(
                IsSectionHeader: true,
                SectionTitle: "Universe Match",
                SectionDesc: "Wikidata couldn't find a match for " +
                             (universe.Count == 1 ? "this item" : "these items") +
                             ". Search for the correct Wikidata entry to link it.",
                SectionIcon: Icons.Material.Outlined.PublicOff,
                SectionCssClass: "universe",
                SectionCount: universe.Count));
            list.AddRange(universe.Select(i => new DisplayItem(false, Item: i)));
        }

        var content = ContentMatchItems;
        if (content.Count > 0)
        {
            list.Add(new DisplayItem(
                IsSectionHeader: true,
                SectionTitle: "Content Match",
                SectionDesc: "No metadata provider returned results for " +
                             (content.Count == 1 ? "this item" : "these items") +
                             ". Search and select the correct match to resolve.",
                SectionIcon: Icons.Material.Outlined.SearchOff,
                SectionCssClass: "content",
                SectionCount: content.Count));
            list.AddRange(content.Select(i => new DisplayItem(false, Item: i)));
        }

        var mediaType = MediaTypeItems;
        if (mediaType.Count > 0)
        {
            list.Add(new DisplayItem(
                IsSectionHeader: true,
                SectionTitle: "Media Type",
                SectionDesc: "The media type couldn't be determined automatically for " +
                             (mediaType.Count == 1 ? "this item" : "these items") +
                             ". Select the correct type to proceed.",
                SectionIcon: Icons.Material.Outlined.HelpOutline,
                SectionCssClass: "mediatype",
                SectionCount: mediaType.Count));
            list.AddRange(mediaType.Select(i => new DisplayItem(false, Item: i)));
        }

        return list;
    }

    // ── Expanded review panel state ───────────────────────────────────────
    private Guid? _expandedItemId;
    private string _selectedProvider = string.Empty;
    private string _searchQuery = string.Empty;
    private string? _currentMediaType;
    private List<MetadataSearchResultDto> _searchResults = [];
    private MetadataSearchResultDto? _selectedSearchResult;
    private bool _searching;
    private bool _searchExecuted;
    private bool _rehydrating;

    // ── Provider slots (loaded once) ──────────────────────────────────────
    private Dictionary<string, ProviderSlotDto> _slots = new();
    private IReadOnlyList<ProviderStatusDto> _providers = [];

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _items = await Orchestrator.GetPendingReviewsAsync();

        _slots = await Orchestrator.GetProviderSlotsAsync() ?? new();
        _providers = await Orchestrator.GetProviderStatusAsync();

        _loading = false;

        Orchestrator.OnReviewCountChanged += OnReviewCountChanged;
    }

    // ── Review panel toggle ──────────────────────────────────────────────

    private async Task ToggleReviewPanel(ReviewItemViewModel item)
    {
        if (_expandedItemId == item.Id)
        {
            CollapseReviewPanel();
            return;
        }

        _expandedItemId = item.Id;
        _currentMediaType = item.MediaType;
        _searchResults = [];
        _searchExecuted = false;
        _searching = false;

        _searchQuery = item.EntityTitle ?? string.Empty;

        var slottedProviders = GetSlottedProviders(item.MediaType);
        if (item.Trigger is "UniverseMatchFailed" or "MultipleQidMatches")
        {
            var wd = slottedProviders.FirstOrDefault(p => IsWikidataProvider(p.Name));
            _selectedProvider = wd?.Name ?? slottedProviders.FirstOrDefault()?.Name ?? string.Empty;
        }
        else
        {
            _selectedProvider = slottedProviders.FirstOrDefault()?.Name ?? string.Empty;
        }

        if (!string.IsNullOrWhiteSpace(_searchQuery) && !string.IsNullOrWhiteSpace(_selectedProvider))
        {
            await ExecuteSearchAsync();
        }
    }

    private void CollapseReviewPanel()
    {
        _expandedItemId = null;
        _searchResults = [];
        _selectedSearchResult = null;
        _searchExecuted = false;
        _searching = false;
    }

    // ── Provider dropdown helpers ─────────────────────────────────────────

    private List<SlottedProviderInfo> GetSlottedProviders(string? mediaType)
    {
        var result = new List<SlottedProviderInfo>();
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        var mediaTypeName = MapMediaTypeToSlotKey(mediaType);
        if (!string.IsNullOrWhiteSpace(mediaTypeName) && _slots.TryGetValue(mediaTypeName, out var slot))
        {
            TryAddSlotted(slot.Primary);
            TryAddSlotted(slot.Secondary);
            TryAddSlotted(slot.Tertiary);
        }

        foreach (var p in _providers.Where(p => p.Enabled))
        {
            if (IsExcludedProvider(p.Name)) continue;
            if (IsWikidataProvider(p.Name)) continue;
            if (!seen.Add(p.Name)) continue;

            if (!string.IsNullOrEmpty(mediaType) && p.MediaTypes is { Count: > 0 })
            {
                if (!p.MediaTypes.Any(mt =>
                    string.Equals(mt, mediaType, StringComparison.OrdinalIgnoreCase)))
                    continue;
            }

            result.Add(new(p.Name, p.DisplayName ?? ProviderAccentMap.GetDisplayName(p.Name)));
        }

        var wikidata = _providers.FirstOrDefault(p => IsWikidataProvider(p.Name));
        if (wikidata is { Enabled: true })
            result.Add(new(wikidata.Name, "Wikidata (Universe)"));

        return result;

        void TryAddSlotted(string? name)
        {
            if (string.IsNullOrWhiteSpace(name)) return;
            if (IsExcludedProvider(name)) return;
            if (!seen.Add(name)) return;
            var provider = _providers.FirstOrDefault(p =>
                string.Equals(p.Name, name, StringComparison.OrdinalIgnoreCase));
            result.Add(new(name, provider?.DisplayName ?? ProviderAccentMap.GetDisplayName(name)));
        }
    }

    private sealed record SlottedProviderInfo(string Name, string DisplayName);

    private static bool IsExcludedProvider(string name) =>
        string.Equals(name, "local_filesystem", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(name, "local_processor", StringComparison.OrdinalIgnoreCase);

    private static bool IsWikidataProvider(string name) =>
        string.Equals(name, "wikidata", StringComparison.OrdinalIgnoreCase);

    private static string? MapMediaTypeToSlotKey(string? mediaType) => mediaType?.ToLowerInvariant() switch
    {
        "books"      => "Books",
        "audiobooks" => "Audiobooks",
        "comic"      => "Comics",
        "movies"     => "Movies",
        "tv"         => "TV Shows",
        _            => null,
    };

    // ── Search ───────────────────────────────────────────────────────────

    private async Task ExecuteSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedProvider) || string.IsNullOrWhiteSpace(_searchQuery))
            return;

        _searching = true;
        _searchExecuted = false;
        _selectedSearchResult = null;
        StateHasChanged();

        _searchResults = await Orchestrator.SearchMetadataAsync(
            _selectedProvider, _searchQuery, mediaType: _currentMediaType, limit: 25);
        _searching = false;
        _searchExecuted = true;
        StateHasChanged();
    }

    private async Task OnSearchKeyUp(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ExecuteSearchAsync();
    }

    // ── Select a match ───────────────────────────────────────────────────

    private async Task SelectMatchAsync(ReviewItemViewModel item, MetadataSearchResultDto result)
    {
        var request = new ReviewResolveRequestDto
        {
            ProviderName   = _selectedProvider,
            ProviderItemId = result.ProviderItemId,
        };
        var ok = await Orchestrator.ResolveReviewAsync(item.Id, request);
        if (ok)
        {
            _items.RemoveAll(i => i.Id == item.Id);
            CollapseReviewPanel();
            Snackbar.Add($"Resolved: matched to \"{result.Title}\".", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to resolve item. Check the Engine connection.", Severity.Error);
        }
    }

    // ── Dismiss ──────────────────────────────────────────────────────────

    private async Task DismissItemAsync(Guid id)
    {
        var ok = await Orchestrator.DismissReviewAsync(id);
        if (ok)
        {
            _items.RemoveAll(i => i.Id == id);
            if (_expandedItemId == id)
                CollapseReviewPanel();
            StateHasChanged();
        }
    }

    // ── Search Again (re-hydration) ──────────────────────────────────────

    private async Task SearchAgainAsync(ReviewItemViewModel item)
    {
        _rehydrating = true;
        StateHasChanged();
        try
        {
            var result = await Orchestrator.TriggerHydrationAsync(item.EntityId);
            if (result is not null)
            {
                Snackbar.Add(
                    $"Re-searched \"{item.EntityTitle ?? "item"}\" — {result.ClaimsAdded} new claims found.",
                    Severity.Success);
                // Refresh the review list — item may have been auto-resolved.
                _items = await Orchestrator.GetPendingReviewsAsync();
            }
            else
            {
                Snackbar.Add("Search returned no new results. Try editing manually.", Severity.Warning);
            }
        }
        catch
        {
            Snackbar.Add("Search failed — the Engine may be unavailable.", Severity.Error);
        }
        finally
        {
            _rehydrating = false;
            StateHasChanged();
        }
    }

    // ── Edit Manually dialog ─────────────────────────────────────────────

    private bool _editDialogOpen;
    private Guid _editEntityId;
    private string? _editMediaType;
    private Dictionary<string, string>? _editCurrentValues;
    private Guid? _editReviewItemId;

    private async Task OpenEditDialog(ReviewItemViewModel item)
    {
        _editEntityId     = item.EntityId;
        _editMediaType    = item.MediaType;
        _editReviewItemId = item.Id;

        var claims = await Orchestrator.GetClaimHistoryAsync(item.EntityId);
        _editCurrentValues = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var claim in claims.OrderByDescending(c => c.ClaimedAt))
        {
            _editCurrentValues.TryAdd(claim.ClaimKey, claim.ClaimValue);
        }

        if (!string.IsNullOrWhiteSpace(item.EntityTitle))
            _editCurrentValues.TryAdd("title", item.EntityTitle);

        _editDialogOpen = true;
        StateHasChanged();
    }

    private async Task OnEditSaved(Dictionary<string, string> changes)
    {
        if (_editReviewItemId.HasValue)
        {
            var request = new ReviewResolveRequestDto
            {
                FieldOverrides = changes.Select(kv => new FieldOverrideDto
                {
                    Key   = kv.Key,
                    Value = kv.Value,
                }).ToList(),
            };
            await Orchestrator.ResolveReviewAsync(_editReviewItemId.Value, request);
            _items.RemoveAll(i => i.Id == _editReviewItemId.Value);
            CollapseReviewPanel();
        }

        _editReviewItemId = null;
        StateHasChanged();
    }

    // ── SignalR refresh ──────────────────────────────────────────────────

    private void OnReviewCountChanged()
    {
        InvokeAsync(async () =>
        {
            _items = await Orchestrator.GetPendingReviewsAsync();
            StateHasChanged();
        });
    }

    // ── Helpers ──────────────────────────────────────────────────────────

    private static string FormatMediaType(string? mediaType) => mediaType switch
    {
        "Books"      => "Books",
        "Audiobooks" => "Audiobooks",
        "Comic"      => "Comic",
        "Movies"     => "Movies",
        "TV"         => "TV",
        _            => mediaType ?? "",
    };

    /// <summary>Returns a concise per-item detail string within its section context.</summary>
    private static string FormatTriggerDetail(string trigger) => trigger switch
    {
        "LowConfidence"       => "Low confidence",
        "MultipleQidMatches"  => "Multiple Wikidata candidates",
        "UserFixMatch"        => "User re-review",
        "ArbiterNeedsReview"  => "Arbiter flagged",
        "ContentMatchFailed"  => "No provider match",
        "UniverseMatchFailed" => "No Wikidata match",
        "AmbiguousMediaType"  => "Ambiguous media type",
        "MetadataConflict"    => "Metadata conflict",
        _                     => trigger,
    };

    // ── Media type disambiguation helpers ─────────────────────────────

    private sealed record MediaTypeCandidateView(string Type, double Confidence, string Reason);

    private static List<MediaTypeCandidateView> ParseMediaTypeCandidates(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return [];

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var result = new List<MediaTypeCandidateView>();
            foreach (var element in doc.RootElement.EnumerateArray())
            {
                var type = element.GetProperty("type").GetString() ?? "Unknown";
                var conf = element.GetProperty("confidence").GetDouble();
                var reason = element.TryGetProperty("reason", out var r) ? r.GetString() ?? "" : "";
                result.Add(new MediaTypeCandidateView(type, conf, reason));
            }
            return result;
        }
        catch
        {
            return [];
        }
    }

    private static Color ConfidenceColor(double confidence) => confidence switch
    {
        >= 0.70 => Color.Success,
        >= 0.40 => Color.Warning,
        _       => Color.Error,
    };

    private async Task ReclassifyAsync(ReviewItemViewModel item, string mediaType)
    {
        var ok = await Orchestrator.ReclassifyMediaTypeAsync(item.EntityId, mediaType);
        if (ok)
        {
            _items.RemoveAll(i => i.Id == item.Id);
            CollapseReviewPanel();
            Snackbar.Add($"Reclassified as {mediaType}.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to reclassify. Check the Engine connection.", Severity.Error);
        }
    }

    public void Dispose()
    {
        Orchestrator.OnReviewCountChanged -= OnReviewCountChanged;
    }
}
