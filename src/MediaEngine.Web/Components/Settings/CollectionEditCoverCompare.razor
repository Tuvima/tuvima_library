@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs
<div class="cover-compare-wrap">
    <div class="cover-compare-section">
        <span class="cover-compare-label">Current</span>
        @if (!string.IsNullOrEmpty(CurrentCoverUrl))
        {
            <img src="@CurrentCoverUrl" alt="Current cover" class="cover-compare-img" />
        }
        else
        {
            <div class="cover-compare-placeholder">
                <MudIcon Icon="@Icons.Material.Filled.HideImage" Size="Size.Large" />
            </div>
        }
        <AppRadioGroup Value="@_selection"
                       ValueChanged="@OnSelectionChanged"
                       Options="@CurrentOptions"
                       Class="cover-compare-radio" />
    </div>

    <div class="cover-compare-divider">
        <MudIcon Icon="@Icons.Material.Filled.CompareArrows" />
    </div>

    <div class="cover-compare-section">
        <span class="cover-compare-label">Provider</span>
        @if (!string.IsNullOrEmpty(ProviderCoverUrl))
        {
            <img src="@ProviderCoverUrl" alt="Provider cover" class="cover-compare-img" />
        }
        else
        {
            <div class="cover-compare-placeholder">
                <MudIcon Icon="@Icons.Material.Filled.HideImage" Size="Size.Large" />
            </div>
        }
        <AppRadioGroup Value="@_selection"
                       ValueChanged="@OnSelectionChanged"
                       Options="@ProviderOptions"
                       Class="cover-compare-radio" />
    </div>
</div>

@code {
    [Parameter] public string? CurrentCoverUrl { get; set; }
    [Parameter] public string? ProviderCoverUrl { get; set; }
    [Parameter] public string? SelectedCoverUrl { get; set; }
    [Parameter] public EventCallback<string?> SelectedCoverUrlChanged { get; set; }

    private string _selection = "current";
    private static readonly IReadOnlyList<AppSelectOption> CurrentOptions = [new("current", "Keep Current")];
    private static readonly IReadOnlyList<AppSelectOption> ProviderOptions = [new("provider", "Use Provider")];

    protected override void OnParametersSet()
    {
        _selection = SelectedCoverUrl is not null ? "provider" : "current";
    }

    private async Task OnSelectionChanged(string value)
    {
        _selection = value;
        SelectedCoverUrl = value == "provider" ? ProviderCoverUrl : null;
        await SelectedCoverUrlChanged.InvokeAsync(SelectedCoverUrl);
    }
}
