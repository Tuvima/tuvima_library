@namespace MediaEngine.Web.Components.Settings

@* Temporary placeholder for settings screens not yet implemented. *@

<div class="st-page">
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 2rem; text-align: center;">
        <MudIcon Icon="@Icons.Material.Outlined.Construction"
                 Size="Size.Large"
                 Style="color: rgba(248,248,248,0.15); margin-bottom: 1.5rem;" />
        <MudText Typo="Typo.h6" Style="color: rgba(248,248,248,0.50); margin-bottom: 0.5rem;">
            @Title
        </MudText>
        <MudText Typo="Typo.body2" Style="color: rgba(248,248,248,0.30); max-width: 400px;">
            @Description
        </MudText>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Coming Soon";
    [Parameter] public string Description { get; set; } = "This settings screen is under construction.";

}
