@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Services.Integration
@inject IngestionLiveDashboardState Dashboard
@implements IDisposable

<div class="tl-page library-operations">
    <IngestionLiveDashboard Snapshot="Dashboard.Snapshot"
                            Metrics="Dashboard.Metrics"
                            Stages="Dashboard.Stages"
                            Jobs="Dashboard.ActiveJobs"
                            Activities="Dashboard.RecentActivity"
                            LiveMode="Dashboard.LiveMode"
                            ConnectionState="Dashboard.ConnectionState"
                            LastUpdated="Dashboard.LastUpdated"
                            Loading="Dashboard.IsLoading"
                            ScanStarting="Dashboard.IsScanStarting"
                            Error="@Dashboard.Error"
                            OnRefresh="RefreshAsync"
                            OnScanNow="ScanNowAsync" />

    <IngestionDiagnosticsPanels Snapshot="Dashboard.Snapshot" />
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        Dashboard.OnChanged += OnDashboardChanged;
        await Dashboard.InitializeAsync();
    }

    private Task RefreshAsync() => Dashboard.LoadAsync();

    private Task ScanNowAsync() => Dashboard.ScanNowAsync();

    private void OnDashboardChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Dashboard.OnChanged -= OnDashboardChanged;
        Dashboard.Stop();
    }
}
