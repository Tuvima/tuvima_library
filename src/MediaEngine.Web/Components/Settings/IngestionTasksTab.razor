    private readonly TaskRow[] _activeTasks = [new("provider lookup", "Dune Messiah.epub", "Matching editions", 62, "10:41", "worker-2", true), new("artwork download", "Foundation.epub", "Fetching cover", 38, "10:44", "worker-4", true)];
    private readonly QueueRow[] _queueGroups = [new("scans", 1, "Normal", "Movies root"), new("provider lookups", 12, "High", "Foundation.epub"), new("artwork downloads", 7, "Normal", "Children of Dune.epub"), new("AI enrichment", 3, "Low", "The Expanse"), new("transcodes", 0, "None", "None"), new("cleanup jobs", 2, "Low", "Temp files")];
    private readonly AttentionRow[] _attentionItems = [new("Failed tasks", 4), new("Unmatched items", 8), new("Low-confidence matches", 6), new("Duplicate candidates", 2), new("Missing artwork", 5), new("Provider timeouts", 3)];
    private readonly string[] _maintenanceActions = ["Retry failed tasks", "Rescan library", "Recheck missing files", "Cleanup temp files", "Prune orphan artwork", "Rebuild search/index"];
}
