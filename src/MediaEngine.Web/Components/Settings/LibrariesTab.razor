    private async Task SaveAllAsync()
    {
        _savingFolders = true;
        _templateValidationError = null;

        try
        {
            if (!await ValidatePathForSaveAsync(_libraryRoot, requireWrite: true, "Library root"))
                return;

            var watchFolders = CleanPaths(_watchFolders);
            foreach (var watchFolder in watchFolders)
            {
                if (!await ValidatePathForSaveAsync(watchFolder, requireWrite: true, "Watch folder"))
                    return;
            }

            foreach (var library in _libraryTabs)
            {
                library.SourcePaths = CleanPaths(library.SourcePaths);
                foreach (var sourcePath in library.SourcePaths)
                {
                    if (!await ValidatePathForSaveAsync(sourcePath, requireWrite: !library.ReadOnly, $"{library.Label} folder"))
                        return;
                }

                if (library.StructureMode == StructureModeRecommended)
                    _organizationTemplates[library.TemplateKey] = RecommendedTemplate(library);
                else if (library.StructureMode == StructureModeNone)
                {
                    library.ReadOnly = true;
                    library.WritebackOverride = false;
                }
            }

            var previewResult = await ApiClient.PreviewOrganizationTemplateAsync(_defaultTemplate, _organizationTemplates);
            if (previewResult is null)
            {
                _templateValidationError = ApiClient.LastError ?? L["Libraries_InvalidTemplate"];
                Snackbar.Add(_templateValidationError, Severity.Warning);
                return;
            }

            var folderSettings = new FolderSettingsDto(
                watchFolders.FirstOrDefault() ?? string.Empty,
                _libraryRoot,
                watchFolders);
            var folderSuccess = await Orchestrator.UpdateFolderSettingsAsync(folderSettings);
            if (!folderSuccess)
            {
                Snackbar.Add(Orchestrator.LastApiError ?? L["Libraries_CouldNotSaveFolderSettings"], Severity.Error);
                return;
            }

            var savedLibraries = await Orchestrator.UpdateLibrariesAsync(BuildSavePayload());
            if (savedLibraries is null)
            {
                Snackbar.Add(Orchestrator.LastApiError ?? "Library folder settings could not be saved.", Severity.Error);
                return;
            }

            var templateResult = await Orchestrator.UpdateOrganizationTemplateAsync(_defaultTemplate, _organizationTemplates);
            if (templateResult is null)
            {
                Snackbar.Add(Orchestrator.LastApiError ?? L["Libraries_InvalidTemplate"], Severity.Warning);
                return;
            }

            _watchFolders = watchFolders.Count == 0 ? [string.Empty] : watchFolders;
            _libraryTabs = BuildLibraryTabs(savedLibraries);
            _organizationTemplates = new Dictionary<string, string>(
                templateResult.Templates ?? _organizationTemplates,
                StringComparer.OrdinalIgnoreCase);
            SnapSavedValues();
            Snackbar.Add($"{L["Libraries_SettingsSaved"]} Watcher hot-swap was requested. A rescan is recommended if files already exist in the watch folders.", Severity.Success);
        }
        finally
        {
            _savingFolders = false;
        }
    }

    private List<LibraryFolderDto> BuildSavePayload() =>
        _libraryTabs
            .Where(library => library.IsExisting || library.SourcePaths.Any(path => !string.IsNullOrWhiteSpace(path)))
            .Select(library => new LibraryFolderDto
            {
                Name = library.ConfigCategory,
                MediaTypes = [.. library.MediaTypes],
                SourcePath = library.SourcePaths.FirstOrDefault(),
                SourcePaths = [.. library.SourcePaths],
                LibraryRoot = _libraryRoot,
                IntakeMode = library.IntakeMode,
                IncludeSubdirectories = library.IncludeSubdirectories,
                ReadOnly = library.ReadOnly,
                WritebackOverride = library.WritebackOverride,
                Notes = library.Notes,
            })
            .ToList();

    private async Task<bool> ValidatePathForSaveAsync(string path, bool requireWrite, string label)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            Snackbar.Add($"{label} cannot be empty.", Severity.Error);
            return false;
        }

        var result = await Orchestrator.TestPathAsync(path);
        _pathResults[path] = result;
        if (result is null)
        {
            _engineUnavailable = true;
            Snackbar.Add(L["Libraries_CannotReachEngine"], Severity.Error);
            return false;
        }

        var valid = result.Exists && result.HasRead && (!requireWrite || result.HasWrite);
        _pathHealthy[path] = valid;
        if (!valid)
        {
            Snackbar.Add($"{label} is not accessible with the required permissions: {path}", Severity.Error);
            return false;
        }

        return true;
    }

    private async Task ResetAllChangesAsync()
    {
        await LoadAsync();
    }

    private async Task ScanLibraryAsync(LibraryEditorState library)
    {
        var paths = CleanPaths(library.SourcePaths);
        if (paths.Count == 0)
        {
            Snackbar.Add($"No folders are configured for {library.Label}.", Severity.Warning);
            return;
        }

        var started = 0;
        foreach (var path in paths)
        {
            if (await ApiClient.TriggerRescanAsync(path, library.IncludeSubdirectories))
                started++;
        }

        Snackbar.Add(
            started == 0
                ? $"Scan could not be started for {library.Label}."
                : $"Scan started for {started} {library.Label} folder(s).",
            started == 0 ? Severity.Error : Severity.Success);
    }

    private async Task ScanImportFoldersAsync()
    {
        var paths = CleanPaths(_watchFolders);
        if (paths.Count == 0)
        {
            Snackbar.Add("No import folders are configured.", Severity.Warning);
            return;
        }

        var started = 0;
        foreach (var path in paths)
        {
            if (await ApiClient.TriggerRescanAsync(path, includeSubdirectories: true))
                started++;
        }

        Snackbar.Add(
            started == 0
                ? "Import folder scan could not be started."
                : $"Scan started for {started} import folder(s).",
            started == 0 ? Severity.Error : Severity.Success);
    }

    private static List<string> CleanPaths(IEnumerable<string> paths) =>
        paths
            .Where(path => !string.IsNullOrWhiteSpace(path))
            .Select(path => path.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

    private static string StatusTextClass(string? path) =>
        string.Join(" ", new[]
        {
            "folder-path-status",
            string.IsNullOrWhiteSpace(path) ? "folder-path-status--empty" : null,
        }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private string StatusLabel(string? path)
    {
        if (string.IsNullOrWhiteSpace(path)) return " ";
        if (!_pathResults.TryGetValue(path, out var result)) return "Path will be checked before save.";
        if (result is null) return "Engine unavailable - path could not be checked.";
        if (!result.Exists) return $"{L["Libraries_FolderNotFound"]} Create the folder or choose an existing path.";
        if (result.HasRead && result.HasWrite) return $"{L["Libraries_ReadWriteConfirmed"]} Live after save; rescan may be needed.";
        if (result.HasRead) return $"{L["Libraries_ReadOnly"]} Tuvima can read this path but organization/writeback will be limited.";
        return $"{L["Libraries_AccessDenied"]} Grant the Engine service account read access.";
    }

    private sealed record BuiltInLibraryTab(
        string TemplateKey,
        string Label,
        string ConfigCategory,
        string Icon,
        string[] MediaTypes);

    private sealed class LibraryEditorState
    {
        public string Key { get; init; } = string.Empty;
        public string TemplateKey { get; init; } = string.Empty;
        public string Label { get; init; } = string.Empty;
        public string ConfigCategory { get; init; } = string.Empty;
        public string Icon { get; init; } = Icons.Material.Outlined.Folder;
        public List<string> MediaTypes { get; init; } = [];
        public List<string> SourcePaths { get; set; } = [];
        public string? LibraryRoot { get; init; }
        public string IntakeMode { get; set; } = "watch";
        public bool IncludeSubdirectories { get; set; } = true;
        public bool ReadOnly { get; set; }
        public bool? WritebackOverride { get; set; }
        public string? Notes { get; init; }
        public bool IsExisting { get; set; }
        public string StructureMode { get; set; } = StructureModeRecommended;

        public static LibraryEditorState From(BuiltInLibraryTab tab, LibraryFolderDto? source)
        {
            var state = new LibraryEditorState
            {
                Key = tab.TemplateKey,
                TemplateKey = tab.TemplateKey,
                Label = tab.Label,
                ConfigCategory = tab.ConfigCategory,
                Icon = tab.Icon,
                MediaTypes = source?.MediaTypes.Count > 0 ? [.. source.MediaTypes] : [.. tab.MediaTypes],
                SourcePaths = [.. (source?.EffectiveSourcePaths ?? [])],
                LibraryRoot = source?.LibraryRoot,
                IntakeMode = string.IsNullOrWhiteSpace(source?.IntakeMode) ? "watch" : source.IntakeMode,
                IncludeSubdirectories = source?.IncludeSubdirectories ?? true,
                ReadOnly = source?.ReadOnly ?? false,
                WritebackOverride = source?.WritebackOverride,
                Notes = source?.Notes,
                IsExisting = source is not null,
            };
            state.StructureMode = state.ReadOnly ? StructureModeNone : StructureModeRecommended;
            if (state.StructureMode == StructureModeNone)
                state.WritebackOverride = false;
            return state;
        }

        public static LibraryEditorState FromCustom(LibraryFolderDto source)
        {
            var label = string.IsNullOrWhiteSpace(source.Name) ? "Custom" : source.Name;
            var state = new LibraryEditorState
            {
                Key = label,
                TemplateKey = label,
                Label = label,
                ConfigCategory = label,
                Icon = Icons.Material.Outlined.Folder,
                MediaTypes = [.. source.MediaTypes],
                SourcePaths = [.. source.EffectiveSourcePaths],
                LibraryRoot = source.LibraryRoot,
                IntakeMode = string.IsNullOrWhiteSpace(source.IntakeMode) ? "watch" : source.IntakeMode,
                IncludeSubdirectories = source.IncludeSubdirectories,
                ReadOnly = source.ReadOnly,
                WritebackOverride = source.WritebackOverride,
                Notes = source.Notes,
                IsExisting = true,
            };
            state.StructureMode = state.ReadOnly ? StructureModeNone : StructureModeRecommended;
            if (state.StructureMode == StructureModeNone)
                state.WritebackOverride = false;
            return state;
        }
    }
}
