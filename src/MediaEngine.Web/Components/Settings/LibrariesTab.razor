@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient
@inject DeviceContextService DeviceContext
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable
@{
    var readOnly    = DeviceContext.IsMobile;
    var unavailable = DeviceContext.IsTelevision || DeviceContext.IsAutomotive;
}

@if (unavailable)
{
    <div class="tl-page">
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="py-8">
            <MudIcon Icon="@Icons.Material.Outlined.DesktopAccessDisabled"
                     Color="Color.Secondary"
                     Class="tl-icon-xl" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">@L["Libraries_NotAvailable"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="tl-text-center">
                @L["Libraries_NotAvailableDescription"]
            </MudText>
        </MudStack>
    </div>
}
else
{
<div class="tl-page">

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
        <MudText Typo="Typo.h6">@L["Libraries_LibraryPaths"]</MudText>
        @if (readOnly)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Default"
                     Icon="@Icons.Material.Outlined.Visibility"
                     Class="tl-ml-auto">
                @L["Libraries_ViewOnly"]
            </MudChip>
        }
    </MudStack>
<div class="folder-path-row mb-5">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
            <div class="health-dot @HealthClass(_libraryHealthy, _libValidating, _libraryRoot)" />
            <MudText Typo="Typo.subtitle2" Class="tl-font-semibold">@L["Libraries_LibraryFolder"]</MudText>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudTextField @bind-Value="_libraryRoot"
                          @bind-Value:after="@(() => OnPathChanged(nameof(_libraryRoot)))"
                          Placeholder="/path/to/library"
                          Variant="Variant.Text"
                          FullWidth="true"
                          Immediate="true"
                          ReadOnly="@readOnly"
                          Margin="Margin.Dense" />
            <MudIconButton Icon="@Icons.Material.Outlined.FolderOpen"
                           Size="Size.Medium"
                           Color="Color.Default"
                           Disabled="@readOnly"
                           OnClick="@(() => BrowseAsync(nameof(_libraryRoot)))"
                           title="@L["Libraries_BrowseFolders"]" />
        </MudStack>
        <MudText Typo="Typo.caption" Style="@StatusStyle(_libraryHealthy, _libValidating, _libraryRoot)" Class="mt-1">
            @StatusLabel(_libTestResult, _libValidating, _libraryRoot)
        </MudText>
    </div>
<div class="folder-path-row mb-5">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
            <div class="health-dot @HealthClass(_watchHealthy, _watchValidating, _watchDir)" />
            <MudText Typo="Typo.subtitle2" Class="tl-font-semibold">@L["Libraries_WatchFolder"]</MudText>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudTextField @bind-Value="_watchDir"
                          @bind-Value:after="@(() => OnPathChanged(nameof(_watchDir)))"
                          Placeholder="/path/to/watch"
                          Variant="Variant.Text"
                          FullWidth="true"
                          Immediate="true"
                          ReadOnly="@readOnly"
                          Margin="Margin.Dense" />
            <MudIconButton Icon="@Icons.Material.Outlined.FolderOpen"
                           Size="Size.Medium"
                           Color="Color.Default"
                           Disabled="@readOnly"
                           OnClick="@(() => BrowseAsync(nameof(_watchDir)))"
                           title="@L["Libraries_BrowseFolders"]" />
        </MudStack>
        <MudText Typo="Typo.caption" Style="@StatusStyle(_watchHealthy, _watchValidating, _watchDir)" Class="mt-1">
            @StatusLabel(_watchTestResult, _watchValidating, _watchDir)
        </MudText>
    </div>
<MudDivider Class="my-6" />
@if (_libraries is { Count: > 0 })
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Outlined.Storage" Color="Color.Default" />
            <MudText Typo="Typo.subtitle2" Class="tl-section-title">@L["Libraries_ConfiguredLibraries"]</MudText>
        </MudStack>
        <MudText Typo="Typo.caption" Class="tl-section-hint">
            @L["Libraries_ConfiguredLibrariesHint"]
        </MudText>

        @foreach (var lib in _libraries)
        {
            <MudPaper Elevation="0" Class="tl-card tl-card--compact mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                    <MudText Typo="Typo.subtitle2" Class="tl-section-title">@lib.Name</MudText>
                    @foreach (var mt in lib.MediaTypes)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                 Class="tl-chip-muted">@mt</MudChip>
                    }
                    @if (lib.ReadOnly)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                  Icon="@Icons.Material.Outlined.Lock"
                                  Class="tl-chip-muted">Read-only</MudChip>
                    }
                    @{
                        var wbLabel = lib.WritebackOverride switch
                        {
                            true  => "Writeback: On",
                            false => "Writeback: Off",
                            null  => "Writeback: Global default",
                        };
                        var wbColor = lib.WritebackOverride switch
                        {
                            true  => Color.Success,
                            false => Color.Error,
                            null  => Color.Default,
                        };
                    }
                    <MudChip T="string" Size="Size.Small" Color="@wbColor"
                             Class="tl-chip-muted">@wbLabel</MudChip>
                </MudStack>

                @foreach (var path in lib.EffectiveSourcePaths)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="ml-2 mb-1">
                        <MudIcon Icon="@Icons.Material.Outlined.Folder" Size="Size.Small"
                                 Class="tl-muted-icon" />
                        <MudText Typo="Typo.body2"
                                 Class="tl-mono-muted">
                            @path
                        </MudText>
                    </MudStack>
                }
            </MudPaper>
        }

        <MudDivider Class="my-6" />
    }
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
        <MudText Typo="Typo.subtitle2" Class="tl-section-title">@L["Libraries_FileOrganization"]</MudText>
    </MudStack>
    <MudText Typo="Typo.caption" Class="tl-section-hint">
        @L["Libraries_FileOrganizationHint"]
    </MudText>

    @* Token chip strip *@
    @if (!readOnly)
    {
        <div class="org-token-strip mb-3">
            @foreach (var token in AvailableTokens)
            {
                <button class="org-token-chip" @onclick="@(() => AppendToken(token))">
                    <span class="org-token-brace">{</span>@token<span class="org-token-brace">}</span>
                </button>
            }
        </div>
    }

    @* Template text field + Reset to default *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
        <MudTextField @bind-Value="_organizationTemplate"
                      Placeholder="@DefaultOrganizationTemplate"
                      Variant="Variant.Text"
                      FullWidth="true"
                      Immediate="true"
                      ReadOnly="@readOnly"
                      Margin="Margin.Dense" />
        @if (!readOnly)
        {
            <MudIconButton Icon="@Icons.Material.Outlined.RestartAlt"
                           Size="Size.Small"
                           Color="Color.Default"
                           OnClick="@ResetTemplateToDefault"
                           title="@L["Libraries_ResetPathToDefault"]" />
        }
    </MudStack>

    @* Live folder-structure preview *@
    @{
        var previewParts = LivePreviewParts();
    }
    @if (previewParts.Count > 0)
    {
        <MudPaper Elevation="0" Class="tl-panel tl-panel--compact mb-5 mt-2">
            <MudText Typo="Typo.caption" Class="tl-section-hint tl-section-hint--tight">
                @L["Libraries_PreviewExampleOutput"]
            </MudText>
            <div class="org-preview-tree">
                @for (int i = 0; i < previewParts.Count - 1; i++)
                {
                    var depth = i;
                    <div class="org-preview-folder" style="padding-left: @(depth * 16)px;">
                        <span class="org-preview-icon">ðŸ“</span>
                        <span class="org-preview-name">@previewParts[i]</span>
                    </div>
                }
                @{
                    var fileName = previewParts[^1];
                    var fileDepth = previewParts.Count - 1;
                }
                <div class="org-preview-file" style="padding-left: @(fileDepth * 16)px;">
                    <span class="org-preview-icon">ðŸ“„</span>
                    <span class="org-preview-name">@fileName</span>
                </div>
            </div>
        </MudPaper>
    }
    else
    {
        <div class="mb-5" />
    }

    @if (!readOnly)
    {
        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       OnClick="@ResetAllChanges"
                       StartIcon="@Icons.Material.Outlined.Undo"
                       Disabled="@(!HasUnsavedChanges)">
                @L["Libraries_Reset"]
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="@SaveFoldersAsync"
                       Disabled="@_savingFolders">
                @(_savingFolders ? L["Libraries_Saving"] : L["Libraries_SaveChanges"])
            </MudButton>
        </MudStack>
    }

</div>
}

<style>
    .folder-path-row {
        position: relative;
    }
    .health-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        transition: background 0.2s ease;
    }
    .health-dot.health-ok     { background: var(--tl-status-success); }
    .health-dot.health-error  { background: var(--tl-status-danger); }
    .health-dot.health-idle   { background: var(--tl-text-faint); }
    .health-dot.health-busy   { background: #ff9800; animation: health-pulse 1s ease-in-out infinite; }

    @@keyframes health-pulse {
        0%, 100% { opacity: 1; }
        50%      { opacity: 0.3; }
    }

    @@media (max-width: 768px) {
        .folder-path-row .mud-stack {
            flex-wrap: wrap;
        }
    }


    .org-token-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .org-token-chip {
        background: var(--app-glass-inner-bg, rgba(255,255,255,0.05));
        border: 1px solid rgba(201, 146, 46, 0.35);
        border-radius: 6px;
        padding: 4px 10px;
        cursor: pointer;
        font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
        font-size: 0.78rem;
        font-weight: 500;
        color: rgba(248, 248, 248, 0.80);
        transition: background 0.15s ease, border-color 0.15s ease;
    }

    .org-token-chip:hover {
        background: rgba(201, 146, 46, 0.15);
        border-color: var(--tl-status-warning);
        color: var(--tl-accent-primary);
    }

    .org-token-brace {
        color: var(--tl-status-warning);
        font-weight: 700;
    }


    .org-preview-tree {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .org-preview-folder,
    .org-preview-file {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
        font-size: 0.80rem;
    }

    .org-preview-folder { color: rgba(248, 248, 248, 0.65); }
    .org-preview-file   { color: rgba(201, 146, 46, 0.80); }

    .org-preview-icon {
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .org-preview-name {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>

@code {

    private const string DefaultOrganizationTemplate = "{Category}/{Author}/{Title} ({Edition}){Ext}";
    private static readonly string[] AvailableTokens =
        ["Category", "Author", "Title", "Series", "Year", "MediaType", "Edition", "Ext"];
    private static readonly Dictionary<string, string> PreviewValues = new(StringComparer.OrdinalIgnoreCase)
    {
        ["{Category}"]  = "Books",
        ["{Author}"]    = "Frank Herbert",
        ["{Title}"]     = "Dune",
        ["{Series}"]    = "Dune Saga",
        ["{Year}"]      = "1965",
        ["{MediaType}"] = "Epub",
        ["{Edition}"]   = "First Edition",
        ["{Ext}"]       = ".epub",
    };

    private string              _watchDir              = string.Empty;
    private string              _libraryRoot           = string.Empty;
    private PathTestResultDto?  _watchTestResult;
    private PathTestResultDto?  _libTestResult;
    private bool                _watchValidating;
    private bool                _libValidating;
    private bool                _savingFolders;
    private bool                _watchHealthy;
    private bool                _libraryHealthy;
    private string              _organizationTemplate  = string.Empty;
    private List<LibraryFolderDto>? _libraries;
    private string              _savedWatchDir         = string.Empty;
    private string              _savedLibraryRoot      = string.Empty;
    private string              _savedOrganizationTemplate = string.Empty;
    private Timer? _watchTimer;
    private Timer? _libTimer;

    private bool HasUnsavedChanges =>
        _watchDir             != _savedWatchDir             ||
        _libraryRoot          != _savedLibraryRoot          ||
        _organizationTemplate != _savedOrganizationTemplate;

    private IReadOnlyList<string> LivePreviewParts()
    {
        if (string.IsNullOrWhiteSpace(_organizationTemplate))
            return [];
        var result = _organizationTemplate;
        foreach (var (token, value) in PreviewValues)
            result = result.Replace(token, value, StringComparison.OrdinalIgnoreCase);
        return result.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    }

    private void AppendToken(string token)
    {
        _organizationTemplate += $"{{{token}}}";
    }

    protected override async Task OnInitializedAsync()
    {
        DeviceContext.OnChanged += OnDeviceChanged;

        var settings = await Orchestrator.GetFolderSettingsAsync();
        if (settings is not null)
        {
            _watchDir    = settings.WatchDirectory;
            _libraryRoot = settings.LibraryRoot;
        }
        var tmpl = await Orchestrator.GetOrganizationTemplateAsync();
        _organizationTemplate = tmpl?.Template ?? DefaultOrganizationTemplate;
        _libraries = await Orchestrator.GetLibrariesAsync();
        SnapSavedValues();
        await CheckInitialHealthAsync();

        Orchestrator.OnFolderHealthChanged += HandleFolderHealthChanged;
    }

    public void Dispose()
    {
        Orchestrator.OnFolderHealthChanged -= HandleFolderHealthChanged;
        DeviceContext.OnChanged            -= OnDeviceChanged;
        _watchTimer?.Dispose();
        _libTimer?.Dispose();
    }

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    private void SnapSavedValues()
    {
        _savedWatchDir              = _watchDir;
        _savedLibraryRoot           = _libraryRoot;
        _savedOrganizationTemplate  = _organizationTemplate;
    }

    private void ResetAllChanges()
    {
        _watchDir             = _savedWatchDir;
        _libraryRoot          = _savedLibraryRoot;
        _organizationTemplate = _savedOrganizationTemplate;
        _watchTestResult  = null;
        _libTestResult    = null;
        _watchHealthy   = false;
        _libraryHealthy = false;
        _ = CheckInitialHealthAsync();
    }

    private void HandleFolderHealthChanged(string path, bool healthy)
    {
        if (!string.IsNullOrWhiteSpace(_watchDir)
            && string.Equals(path, _watchDir, StringComparison.OrdinalIgnoreCase))
            _watchHealthy = healthy;
        else if (!string.IsNullOrWhiteSpace(_libraryRoot)
            && string.Equals(path, _libraryRoot, StringComparison.OrdinalIgnoreCase))
            _libraryHealthy = healthy;

        InvokeAsync(StateHasChanged);
    }

    private async Task CheckInitialHealthAsync()
    {
        if (!string.IsNullOrWhiteSpace(_watchDir))
        {
            var r = await Orchestrator.TestPathAsync(_watchDir);
            _watchTestResult = r;
            _watchHealthy    = r is { Exists: true, HasRead: true, HasWrite: true };
        }

        if (!string.IsNullOrWhiteSpace(_libraryRoot))
        {
            var r = await Orchestrator.TestPathAsync(_libraryRoot);
            _libTestResult  = r;
            _libraryHealthy = r is { Exists: true, HasRead: true, HasWrite: true };
        }

    }

    private void OnPathChanged(string field)
    {
        switch (field)
        {
            case nameof(_libraryRoot):
                _libTestResult = null;
                _libValidating = false;
                _libTimer?.Dispose();
                if (!string.IsNullOrWhiteSpace(_libraryRoot))
                    _libTimer = new Timer(_ => InvokeAsync(ValidateLibraryAsync), null, 800, Timeout.Infinite);
                else
                    _libraryHealthy = false;
                break;

            case nameof(_watchDir):
                _watchTestResult = null;
                _watchValidating = false;
                _watchTimer?.Dispose();
                if (!string.IsNullOrWhiteSpace(_watchDir))
                    _watchTimer = new Timer(_ => InvokeAsync(ValidateWatchAsync), null, 800, Timeout.Infinite);
                else
                    _watchHealthy = false;
                break;

        }
    }

    private async Task ValidateLibraryAsync()
    {
        _libValidating = true;
        StateHasChanged();
        _libTestResult  = await Orchestrator.TestPathAsync(_libraryRoot);
        _libraryHealthy = _libTestResult is { Exists: true, HasRead: true, HasWrite: true };
        _libValidating  = false;
        StateHasChanged();
    }

    private async Task ValidateWatchAsync()
    {
        _watchValidating = true;
        StateHasChanged();
        _watchTestResult = await Orchestrator.TestPathAsync(_watchDir);
        _watchHealthy    = _watchTestResult is { Exists: true, HasRead: true, HasWrite: true };
        _watchValidating = false;
        StateHasChanged();
    }

    private async Task BrowseAsync(string field)
    {
        var currentPath = field switch
        {
            nameof(_libraryRoot) => _libraryRoot,
            nameof(_watchDir)    => _watchDir,
            _                    => string.Empty,
        };

        var parameters = new DialogParameters<FolderBrowserDialog>
        {
            { x => x.InitialPath, currentPath },
        };

        var options = new DialogOptions
        {
            MaxWidth    = MaxWidth.Small,
            FullWidth   = true,
            CloseButton = true,
            CloseOnEscapeKey = true,
        };

        var dialog = await DialogService.ShowAsync<FolderBrowserDialog>(L["Libraries_BrowseFolders"], parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string selectedPath })
        {
            switch (field)
            {
                case nameof(_libraryRoot):
                    _libraryRoot = selectedPath;
                    await ValidateLibraryAsync();
                    break;
                case nameof(_watchDir):
                    _watchDir = selectedPath;
                    await ValidateWatchAsync();
                    break;
            }
        }
    }

    private void ResetTemplateToDefault()
    {
        _organizationTemplate = DefaultOrganizationTemplate;
    }

    private async Task SaveFoldersAsync()
    {
        _savingFolders = true;
        var engineStatus = await Orchestrator.GetSystemStatusAsync();
        if (engineStatus is null)
        {
            Snackbar.Add(L["Libraries_CannotReachEngine"], Severity.Error);
            _savingFolders = false;
            return;
        }
        if (!string.IsNullOrWhiteSpace(_watchDir))
        {
            var r = await Orchestrator.TestPathAsync(_watchDir);
            _watchTestResult = r;
            if (r is null)
            {
                Snackbar.Add(L["Libraries_CannotReachEngine"], Severity.Error);
                _savingFolders = false;
                return;
            }
            if (r is not { HasRead: true, HasWrite: true })
            {
                Snackbar.Add(L["Libraries_WatchFolderNotAccessible"], Severity.Error);
                _watchHealthy  = false;
                _savingFolders = false;
                return;
            }
            _watchHealthy = true;
        }
        if (!string.IsNullOrWhiteSpace(_libraryRoot))
        {
            var r = await Orchestrator.TestPathAsync(_libraryRoot);
            _libTestResult = r;
            if (r is null)
            {
                Snackbar.Add(L["Libraries_CannotReachEngine"], Severity.Error);
                _savingFolders = false;
                return;
            }
            if (r is not { HasRead: true, HasWrite: true })
            {
                Snackbar.Add(L["Libraries_LibraryFolderNotAccessible"], Severity.Error);
                _libraryHealthy = false;
                _savingFolders  = false;
                return;
            }
            _libraryHealthy = true;
        }
        var dto     = new FolderSettingsDto(_watchDir, _libraryRoot);
        var success = await Orchestrator.UpdateFolderSettingsAsync(dto);
        if (success && !string.IsNullOrWhiteSpace(_organizationTemplate))
        {
            var previewResult = await ApiClient.PreviewOrganizationTemplateAsync(_organizationTemplate);
            if (previewResult is null)
            {
                Snackbar.Add(
                    ApiClient.LastError ?? L["Libraries_InvalidTemplate"],
                    Severity.Warning);
                _savingFolders = false;
                return;
            }

            var tmplResult = await Orchestrator.UpdateOrganizationTemplateAsync(_organizationTemplate);
            if (tmplResult is null)
            {
                Snackbar.Add(
                    Orchestrator.LastApiError ?? L["Libraries_InvalidTemplate"],
                    Severity.Warning);
            }
        }

        if (success)
        {
            Snackbar.Add($"{L["Libraries_SettingsSaved"]} {_watchDir}", Severity.Success);
            SnapSavedValues();
        }
        else
        {
            var detail = Orchestrator.LastApiError;
            Snackbar.Add(
                string.IsNullOrEmpty(detail)
                    ? L["Libraries_CouldNotSaveFolderSettings"]
                    : $"{L["Libraries_CouldNotSave"]} {detail}",
                Severity.Error);
        }

        _savingFolders = false;
    }

    private static string HealthClass(bool healthy, bool validating, string path) =>
        validating                        ? "health-busy"  :
        string.IsNullOrWhiteSpace(path)   ? "health-idle"  :
        healthy                           ? "health-ok"    :
                                            "health-error";

    private static string StatusStyle(bool healthy, bool validating, string path)
    {
        var color = validating                      ? "var(--mud-palette-warning)" :
                    string.IsNullOrWhiteSpace(path) ? "var(--app-text-soft)"       :
                    healthy                         ? "var(--mud-palette-success)"  :
                                                      "var(--mud-palette-error)";
        return $"color: {color}; font-size: 0.75rem;";
    }

    private string StatusLabel(PathTestResultDto? result, bool validating, string path)
    {
        if (string.IsNullOrWhiteSpace(path))   return " ";
        if (validating)                        return L["Libraries_Checking"];
        if (result is null)                    return " ";
        if (!result.Exists)                    return L["Libraries_FolderNotFound"];
        if (result.HasRead && result.HasWrite) return L["Libraries_ReadWriteConfirmed"];
        if (result.HasRead)                    return L["Libraries_ReadOnly"];
        return L["Libraries_AccessDenied"];
    }
}
