@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient
@inject DeviceContextService DeviceContext
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

@{
    var readOnly = DeviceContext.IsMobile;
    var unavailable = DeviceContext.IsTelevision || DeviceContext.IsAutomotive;
    var activeLibrary = ActiveLibrary;
}

@if (unavailable)
{
    <div class="tl-page file-organization-page">
        <AppPageState Kind="AppPageStateKind.Unavailable"
                      Icon="@Icons.Material.Outlined.DesktopAccessDisabled"
                      Title="@L["Libraries_NotAvailable"].Value"
                      Message="@L["Libraries_NotAvailableDescription"].Value" />
    </div>
}
else
{
    <div class="tl-page file-organization-page">
        <AppPageHeader Title="File Organization"
                       Subtitle="Manage global library paths and the folders used by each media type."
                       Class="file-organization-page__header">
            <Stats>
                <AppStatusBadge Text="@(_engineUnavailable ? "Engine unavailable" : "Live")"
                                Tone="@(_engineUnavailable ? AppStatusTone.Error : AppStatusTone.Success)" />
            </Stats>
            <Actions>
                <AppButton Label="Folder health"
                           StartIcon="@Icons.Material.Outlined.Refresh"
                           ButtonStyle="AppButtonStyle.Text"
                           OnClick="@CheckInitialHealthAsync" />
                <AppButton Label="Ingestion"
                           StartIcon="@Icons.Material.Outlined.PendingActions"
                           ButtonStyle="AppButtonStyle.Text"
                           Href="/settings/ingestion" />
                @if (readOnly)
                {
                    <AppChip Text="@L["Libraries_ViewOnly"].Value"
                             Icon="@Icons.Material.Outlined.Visibility" />
                }
            </Actions>
        </AppPageHeader>

        @if (_engineUnavailable)
        {
            <AppAlert Tone="AppUiTone.Error">
                The Engine is unavailable, so folder settings cannot be validated or saved. Existing values are not replaced with defaults.
            </AppAlert>
        }
        else if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <AppAlert Tone="AppUiTone.Warning">@_loadError</AppAlert>
        }

        @if (_libraryTabs.Count > 0)
        {
            <AppCard Class="file-org-media-card">
                <AppTabs ActivePanelIndex="@_activeTabIndex"
                         ActivePanelIndexChanged="@OnTabChanged"
                         Class="settings-tab-strip settings-file-org-tabs"
                         Rounded="true"
                         Elevation="0"
                         Color="Color.Primary">
                    <MudTabPanel Text="Global" Icon="@Icons.Material.Outlined.Public" />
                    <MudTabPanel Text="Import Folders" Icon="@Icons.Material.Outlined.MoveToInbox" />
                    @foreach (var tab in _libraryTabs)
                    {
                        <MudTabPanel @key="tab.Key" Text="@tab.Label" Icon="@tab.Icon" />
                    }
                </AppTabs>

                @if (IsGlobalTab)
                {
                    <div class="file-org-media-grid file-org-media-grid--global">
                        <section class="file-org-media-panel file-org-media-panel--global" aria-label="Global library root">
                            <div class="file-org-panel-title">
                                <MudIcon Icon="@Icons.Material.Outlined.Public" Size="Size.Small" />
                                <div>
                                    <h3>Global Library Root</h3>
                                    <p>The root folder for your entire Tuvima Library.</p>
                                </div>
                            </div>

                            <div class="folder-path-input-row">
                                <AppTextField Value="@_libraryRoot"
                                              ValueChanged="@((string? value) => OnLibraryRootChanged(value))"
                                              Placeholder="/path/to/library"
                                              ReadOnly="@(readOnly || _engineUnavailable)" />
                                <AppButton Label="Browse"
                                           StartIcon="@Icons.Material.Outlined.FolderOpen"
                                           Disabled="@(readOnly || _engineUnavailable)"
                                           OnClick="@(() => BrowseLibraryRootAsync())" />
                            </div>
                            <div class="@StatusTextClass(_libraryRoot)">
                                @StatusLabel(_libraryRoot)
                            </div>
                        </section>

                        <section class="file-org-media-panel file-org-media-panel--global-info" aria-label="Global root behavior">
                            <div class="file-org-panel-title">
                                <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" />
                                <div>
                                    <h3>Applies Everywhere</h3>
                                    <p>Media-type folders can override this root only when their saved library entry has a different root.</p>
                                </div>
                            </div>
                            <AppPanel Density="AppSurfaceDensity.Compact" Class="file-org-preview">
                                <div class="file-org-preview__none">
                                    <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Size="Size.Small" />
                                    <span>Recommended and custom structures place organized files underneath this root.</span>
                                </div>
                            </AppPanel>
                        </section>
                    </div>
                }
                else if (IsImportFoldersTab)
                {
                    <div class="file-org-media-grid file-org-media-grid--import">
                        <section class="file-org-media-panel file-org-media-panel--folders" aria-label="Import folders">
                            <div class="file-org-panel-title">
                                <MudIcon Icon="@Icons.Material.Outlined.MoveToInbox" Size="Size.Small" />
                                <div>
                                    <h3>Import Folders</h3>
                                    <p>Incoming files land here before Tuvima routes them to a media type.</p>
                                </div>
                            </div>

                            <div class="file-org-path-list">
                                @for (var i = 0; i < _watchFolders.Count; i++)
                                {
                                    var index = i;
                                    <div class="file-org-path-row">
                                        <MudIcon Icon="@Icons.Material.Outlined.Folder" Size="Size.Small" />
                                        <AppTextField Value="@_watchFolders[index]"
                                                      ValueChanged="@((string? value) => OnWatchFolderChanged(index, value))"
                                                      Placeholder="/path/to/import"
                                                      ReadOnly="@(readOnly || _engineUnavailable)" />
                                        <AppIconButton Icon="@Icons.Material.Outlined.FolderOpen"
                                                       Tooltip="@L["Libraries_BrowseFolders"].Value"
                                                       AriaLabel="@L["Libraries_BrowseFolders"].Value"
                                                       Disabled="@(readOnly || _engineUnavailable)"
                                                       OnClick="@(() => BrowseWatchFolderAsync(index))" />
                                        <AppIconButton Icon="@Icons.Material.Outlined.Delete"
                                                       Tooltip="Remove import folder"
                                                       AriaLabel="Remove import folder"
                                                       Tone="AppUiTone.Error"
                                                       Disabled="@(readOnly || _engineUnavailable)"
                                                       OnClick="@(() => RemoveWatchFolder(index))" />
                                    </div>
                                    <div class="@StatusTextClass(_watchFolders[index])">
                                        @StatusLabel(_watchFolders[index])
                                    </div>
                                }
                            </div>
                            <AppButton Label="Add Import Folder"
                                       StartIcon="@Icons.Material.Outlined.Add"
                                       ButtonStyle="AppButtonStyle.Outlined"
                                       Tone="AppUiTone.Primary"
                                       FullWidth="true"
                                       Disabled="@(readOnly || _engineUnavailable)"
                                       OnClick="@AddWatchFolder" />
                        </section>

                        <section class="file-org-media-panel file-org-media-panel--import-info" aria-label="Import folder behavior">
                            <div class="file-org-panel-title">
                                <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" />
                                <div>
                                    <h3>No Folder Structure</h3>
                                    <p>Import folders are intake locations only.</p>
                                </div>
                            </div>
                            <AppPanel Density="AppSurfaceDensity.Compact" Class="file-org-preview">
                                <div class="file-org-preview__none">
                                    <MudIcon Icon="@Icons.Material.Outlined.MoveToInbox" Size="Size.Small" />
                                    <span>Tuvima detects files here and imports them. These folders do not get a media-type folder structure.</span>
                                </div>
                            </AppPanel>
                            <AppButton Label="Scan Import Folders"
                                       StartIcon="@Icons.Material.Outlined.ManageSearch"
                                       ButtonStyle="AppButtonStyle.Text"
                                       Disabled="@(_engineUnavailable || CleanPaths(_watchFolders).Count == 0)"
                                       OnClick="@ScanImportFoldersAsync" />
                        </section>
                    </div>
                }
                else if (activeLibrary is not null)
                {
                    <div class="file-org-media-grid">
                        <section class="file-org-media-panel file-org-media-panel--folders" aria-label="@($"Folders for {activeLibrary.Label}")">
                            <div class="file-org-panel-title">
                                <MudIcon Icon="@Icons.Material.Outlined.Folder" Size="Size.Small" />
                                <div>
                                    <h3>Folders for @activeLibrary.Label</h3>
                                    <p>Add one or more folders that belong to this media type.</p>
                                </div>
                            </div>

                            <div class="file-org-path-list">
                                @for (var i = 0; i < activeLibrary.SourcePaths.Count; i++)
                                {
                                    var index = i;
                                    <div class="file-org-source-row">
                                        <MudIcon Icon="@Icons.Material.Outlined.Folder" Size="Size.Small" />
                                        <AppTextField Value="@activeLibrary.SourcePaths[index]"
                                                      ValueChanged="@((string? value) => OnSourcePathChanged(activeLibrary, index, value))"
                                                      Placeholder="@($"/media/{activeLibrary.Label}")"
                                                      ReadOnly="@(readOnly || _engineUnavailable)" />
                                        <AppChip Text="@(activeLibrary.IncludeSubdirectories ? "Recursive" : "Top level")"
                                                 Tone="@(activeLibrary.IncludeSubdirectories ? AppUiTone.Primary : AppUiTone.Neutral)" />
                                        <AppChip Text="@(activeLibrary.ReadOnly ? "Read only" : "Writable")"
                                                 Tone="@(activeLibrary.ReadOnly ? AppUiTone.Warning : AppUiTone.Success)" />
                                        <AppIconButton Icon="@Icons.Material.Outlined.FolderOpen"
                                                       Tooltip="@L["Libraries_BrowseFolders"].Value"
                                                       AriaLabel="@L["Libraries_BrowseFolders"].Value"
                                                       Disabled="@(readOnly || _engineUnavailable)"
                                                       OnClick="@(() => BrowseSourceFolderAsync(activeLibrary, index))" />
                                        <AppIconButton Icon="@Icons.Material.Outlined.Delete"
                                                       Tooltip="Remove folder"
                                                       AriaLabel="Remove folder"
                                                       Tone="AppUiTone.Error"
                                                       Disabled="@(readOnly || _engineUnavailable)"
                                                       OnClick="@(() => RemoveSourceFolder(activeLibrary, index))" />
                                    </div>
                                }
                            </div>

                            <AppButton Label="@($"Add {activeLibrary.Label} Folder")"
                                       StartIcon="@Icons.Material.Outlined.Add"
                                       ButtonStyle="AppButtonStyle.Outlined"
                                       Tone="AppUiTone.Primary"
                                       FullWidth="true"
                                       Disabled="@(readOnly || _engineUnavailable)"
                                       OnClick="@(() => AddSourceFolder(activeLibrary))" />
                        </section>

                        <section class="file-org-media-panel file-org-media-panel--structure" aria-label="Folder structure">
                            <div class="file-org-panel-title">
                                <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Size="Size.Small" />
                                <div>
                                    <h3>Folder Structure</h3>
                                    <p>Choose how @activeLibrary.Label.ToLowerInvariant() files are organized on disk.</p>
                                </div>
                            </div>

                            <AppSegmentedControl Options="@StructureModeOptions"
                                                 Value="@activeLibrary.StructureMode"
                                                 ValueChanged="@((string value) => SetStructureMode(activeLibrary, value))"
                                                 AriaLabel="Folder structure mode"
                                                 Class="file-org-structure-mode" />

                            @if (activeLibrary.StructureMode == StructureModeCustom)
                            {
                                <div class="file-org-token-strip">
                                    @foreach (var token in AvailableTokens)
                                    {
                                        <AppChip OnClick="@(() => AppendToken(activeLibrary, token))"
                                                 Class="file-org-token-chip">
                                            <span class="file-org-token-brace">{</span>@token<span class="file-org-token-brace">}</span>
                                        </AppChip>
                                    }
                                </div>
                                <AppTextField Value="@GetEditableTemplate(activeLibrary)"
                                              ValueChanged="@((string? value) => SetTemplate(activeLibrary, value))"
                                              Placeholder="@RecommendedTemplate(activeLibrary)"
                                              ReadOnly="@(readOnly || _engineUnavailable)" />
                            }

                            <AppPanel Density="AppSurfaceDensity.Compact" Class="file-org-preview">
                                <div class="file-org-preview__label">Preview - example output</div>
                                @if (activeLibrary.StructureMode == StructureModeNone)
                                {
                                    <div class="file-org-preview__none">
                                        <MudIcon Icon="@Icons.Material.Outlined.Lock" Size="Size.Small" />
                                        <span>Tuvima will index these files in place and will not move, rename, or write back metadata for this media type.</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="file-org-preview-tree">
                                        @foreach (var part in PreviewParts(activeLibrary).Select((value, index) => (value, index)))
                                        {
                                            var isFile = part.index == PreviewParts(activeLibrary).Count - 1;
                                            <div class="@PreviewRowClass(isFile, part.index)">
                                                <MudIcon Icon="@(isFile ? Icons.Material.Outlined.Description : Icons.Material.Outlined.Folder)" Size="Size.Small" />
                                                <span>@part.value</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </AppPanel>
                        </section>

                        <section class="file-org-media-panel file-org-media-panel--options" aria-label="Scanning and import options">
                            <div class="file-org-panel-title">
                                <MudIcon Icon="@Icons.Material.Outlined.Tune" Size="Size.Small" />
                                <div>
                                    <h3>Scanning &amp; Import Options</h3>
                                    <p>Settings saved for this media type.</p>
                                </div>
                            </div>

                            <AppSwitchRow Label="Scan recursively"
                                          Description="Include all subfolders"
                                          Value="@activeLibrary.IncludeSubdirectories"
                                          ValueChanged="@((bool value) => SetRecursive(activeLibrary, value))"
                                          Disabled="@(readOnly || _engineUnavailable || activeLibrary.StructureMode == StructureModeNone)"
                                          Tone="AppUiTone.Primary" />

                            <AppSegmentedControl Options="@IntakeModeOptions"
                                                 Value="@activeLibrary.IntakeMode"
                                                 ValueChanged="@((string value) => SetIntakeMode(activeLibrary, value))"
                                                 AriaLabel="Intake mode"
                                                 Disabled="@(readOnly || _engineUnavailable || activeLibrary.StructureMode == StructureModeNone)"
                                                 Class="file-org-option-segments" />

                            <AppSegmentedControl Options="@WritebackOptions"
                                                 Value="@WritebackValue(activeLibrary)"
                                                 ValueChanged="@((string value) => SetWriteback(activeLibrary, value))"
                                                 AriaLabel="Writeback override"
                                                 Disabled="@(readOnly || _engineUnavailable || activeLibrary.StructureMode == StructureModeNone)"
                                                 Class="file-org-option-segments" />

                            <AppButton Label="Scan This Media Type"
                                       StartIcon="@Icons.Material.Outlined.ManageSearch"
                                       ButtonStyle="AppButtonStyle.Text"
                                       Disabled="@(_engineUnavailable || activeLibrary.SourcePaths.Count == 0)"
                                       OnClick="@(() => ScanLibraryAsync(activeLibrary))" />
                        </section>
                    </div>
                }
            </AppCard>
        }

        @if (!string.IsNullOrWhiteSpace(_templateValidationError))
        {
            <AppAlert Tone="AppUiTone.Warning">@_templateValidationError</AppAlert>
        }

        <AppPanel Class="file-org-save-bar" Density="AppSurfaceDensity.Compact">
            <div class="file-org-save-bar__note">
                <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" />
                <span>The Library Root applies to all libraries. Import folders collect incoming files; media-type folders are configured in their own tabs.</span>
            </div>
            @if (!readOnly)
            {
                <div class="file-org-save-bar__actions">
                    <AppButton Label="Discard Changes"
                               StartIcon="@Icons.Material.Outlined.Undo"
                               Disabled="@(!HasUnsavedChanges)"
                               OnClick="@ResetAllChangesAsync" />
                    <AppButton Label="@(_savingFolders ? L["Libraries_Saving"].Value : L["Libraries_SaveChanges"].Value)"
                               StartIcon="@Icons.Material.Outlined.Save"
                               ButtonStyle="AppButtonStyle.Filled"
                               Tone="AppUiTone.Primary"
                               Disabled="@(_savingFolders || _engineUnavailable || !HasUnsavedChanges)"
                               OnClick="@SaveAllAsync" />
                </div>
            }
        </AppPanel>
    </div>
}

@code {
    private const string DefaultOrganizationTemplate = "{Category}/{Title} ({Year})/{Title}{Ext}";
    private const string StructureModeRecommended = "recommended";
    private const string StructureModeCustom = "custom";
    private const string StructureModeNone = "none";

    private static readonly string[] AvailableTokens =
        ["Category", "Author", "Artist", "Album", "Title", "Series", "Year", "Season", "Episode", "EpisodeTitle", "IssueNumber", "Edition", "TrackNumber", "Ext"];

    private static readonly IReadOnlyList<AppSelectOption> StructureModeOptions =
    [
        new(StructureModeRecommended, "Recommended", Icons.Material.Outlined.AutoAwesome),
        new(StructureModeCustom, "Custom", Icons.Material.Outlined.Tune),
        new(StructureModeNone, "None", Icons.Material.Outlined.Lock),
    ];

    private static readonly IReadOnlyList<AppSelectOption> IntakeModeOptions =
    [
        new("watch", "Watch", Icons.Material.Outlined.Visibility),
        new("import", "Import", Icons.Material.Outlined.FileDownload),
    ];

    private static readonly IReadOnlyList<AppSelectOption> WritebackOptions =
    [
        new("default", "Writeback: Default", Icons.Material.Outlined.Settings),
        new("on", "Writeback: On", Icons.Material.Outlined.Edit),
        new("off", "Writeback: Off", Icons.Material.Outlined.Block),
    ];

    private static readonly BuiltInLibraryTab[] BuiltInTabs =
    [
        new("Books", "Books", "Books", Icons.Material.Outlined.MenuBook, ["Books"]),
        new("Movies", "Movies", "Movies", Icons.Material.Outlined.Movie, ["Movies"]),
        new("TV", "TV Shows", "TV", Icons.Material.Outlined.Tv, ["TV"]),
        new("Music", "Music", "Music", Icons.Material.Outlined.LibraryMusic, ["Music"]),
        new("Audiobooks", "Audiobooks", "Audiobooks", Icons.Material.Outlined.Headphones, ["Audiobooks"]),
        new("Comic", "Comics", "Comics", Icons.Material.Outlined.AutoStories, ["Comics", "Comic"]),
    ];

    private string _libraryRoot = string.Empty;
    private string _defaultTemplate = DefaultOrganizationTemplate;
    private Dictionary<string, string> _organizationTemplates = new(StringComparer.OrdinalIgnoreCase);
    private List<string> _watchFolders = [];
    private List<LibraryEditorState> _libraryTabs = [];
    private readonly Dictionary<string, PathTestResultDto?> _pathResults = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, bool> _pathHealthy = new(StringComparer.OrdinalIgnoreCase);
    private bool _engineUnavailable;
    private bool _savingFolders;
    private int _activeTabIndex;
    private string? _loadError;
    private string? _templateValidationError;
    private string _savedSnapshot = string.Empty;

    private bool IsGlobalTab => _activeTabIndex == 0;
    private bool IsImportFoldersTab => _activeTabIndex == 1;

    private LibraryEditorState? ActiveLibrary =>
        _activeTabIndex > 1 && _activeTabIndex - 2 < _libraryTabs.Count
            ? _libraryTabs[_activeTabIndex - 2]
            : null;

    private bool HasUnsavedChanges => SerializeSnapshot() != _savedSnapshot;

    protected override async Task OnInitializedAsync()
    {
        DeviceContext.OnChanged += OnDeviceChanged;
        Orchestrator.OnFolderHealthChanged += HandleFolderHealthChanged;
        await LoadAsync();
    }

    public void Dispose()
    {
        Orchestrator.OnFolderHealthChanged -= HandleFolderHealthChanged;
        DeviceContext.OnChanged -= OnDeviceChanged;
    }

    private async Task LoadAsync()
    {
        _loadError = null;
        _templateValidationError = null;

        var settings = await Orchestrator.GetFolderSettingsAsync();
        if (settings is not null)
        {
            _libraryRoot = settings.LibraryRoot;
            _watchFolders = settings.EffectiveWatchDirectories.ToList();
        }
        else
        {
            _engineUnavailable = true;
            _loadError = Orchestrator.LastApiError ?? "Folder settings could not be loaded from the Engine.";
            _watchFolders = [];
        }

        if (_watchFolders.Count == 0)
            _watchFolders.Add(string.Empty);

        var template = await Orchestrator.GetOrganizationTemplateAsync();
        _defaultTemplate = string.IsNullOrWhiteSpace(template?.Template)
            ? DefaultOrganizationTemplate
            : template.Template;
        _organizationTemplates = new Dictionary<string, string>(
            template?.Templates ?? new Dictionary<string, string>(),
            StringComparer.OrdinalIgnoreCase);
        if (!_organizationTemplates.ContainsKey("default"))
            _organizationTemplates["default"] = _defaultTemplate;

        var libraries = await Orchestrator.GetLibrariesAsync();
        _libraryTabs = BuildLibraryTabs(libraries ?? []);
        _activeTabIndex = Math.Clamp(_activeTabIndex, 0, _libraryTabs.Count + 1);

        await CheckInitialHealthAsync();
        SnapSavedValues();
    }

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    private void SnapSavedValues() => _savedSnapshot = SerializeSnapshot();

    private string SerializeSnapshot() => System.Text.Json.JsonSerializer.Serialize(new
    {
        _libraryRoot,
        WatchFolders = _watchFolders.Where(path => !string.IsNullOrWhiteSpace(path)).ToArray(),
        Libraries = _libraryTabs.Select(tab => new
        {
            tab.Key,
            tab.Label,
            tab.SourcePaths,
            tab.IncludeSubdirectories,
            tab.ReadOnly,
            tab.IntakeMode,
            tab.WritebackOverride,
            tab.StructureMode,
            Template = GetEditableTemplate(tab),
        }).ToArray(),
        Templates = _organizationTemplates.OrderBy(kvp => kvp.Key).ToArray(),
    });

    private static List<LibraryEditorState> BuildLibraryTabs(IReadOnlyList<LibraryFolderDto> libraries)
    {
        var used = new HashSet<LibraryFolderDto>();
        var result = new List<LibraryEditorState>();

        foreach (var builtIn in BuiltInTabs)
        {
            var match = libraries.FirstOrDefault(library =>
                string.Equals(library.Name, builtIn.ConfigCategory, StringComparison.OrdinalIgnoreCase)
                || string.Equals(library.Name, builtIn.Label, StringComparison.OrdinalIgnoreCase));

            if (match is not null)
                used.Add(match);

            result.Add(LibraryEditorState.From(builtIn, match));
        }

        foreach (var custom in libraries.Where(library => !used.Contains(library)))
        {
            result.Add(LibraryEditorState.FromCustom(custom));
        }

        return result;
    }

    private async Task CheckInitialHealthAsync()
    {
        await TestAndRecordPathAsync(_libraryRoot);
        foreach (var path in _watchFolders)
            await TestAndRecordPathAsync(path);
    }

    private async Task TestAndRecordPathAsync(string? path)
    {
        if (string.IsNullOrWhiteSpace(path) || _engineUnavailable)
            return;

        var result = await Orchestrator.TestPathAsync(path);
        _pathResults[path] = result;
        _pathHealthy[path] = result is { Exists: true, HasRead: true, HasWrite: true };
        _engineUnavailable = result is null;
    }

    private void HandleFolderHealthChanged(string path, bool healthy)
    {
        _pathHealthy[path] = healthy;
        InvokeAsync(StateHasChanged);
    }

    private Task OnTabChanged(int index)
    {
        _activeTabIndex = index;
        return Task.CompletedTask;
    }

    private void OnLibraryRootChanged(string? value)
    {
        _libraryRoot = value ?? string.Empty;
        ClearPathStatus(_libraryRoot);
    }

    private void OnWatchFolderChanged(int index, string? value)
    {
        if (index < 0 || index >= _watchFolders.Count) return;
        _watchFolders[index] = value ?? string.Empty;
        ClearPathStatus(_watchFolders[index]);
    }

    private void OnSourcePathChanged(LibraryEditorState library, int index, string? value)
    {
        if (index < 0 || index >= library.SourcePaths.Count) return;
        library.SourcePaths[index] = value ?? string.Empty;
        ClearPathStatus(library.SourcePaths[index]);
    }

    private void ClearPathStatus(string? path)
    {
        if (string.IsNullOrWhiteSpace(path)) return;
        _pathResults.Remove(path);
        _pathHealthy.Remove(path);
    }

    private void AddWatchFolder() => _watchFolders.Add(string.Empty);

    private void RemoveWatchFolder(int index)
    {
        if (index < 0 || index >= _watchFolders.Count) return;
        _watchFolders.RemoveAt(index);
        if (_watchFolders.Count == 0)
            _watchFolders.Add(string.Empty);
    }

    private void AddSourceFolder(LibraryEditorState library)
    {
        library.SourcePaths.Add(string.Empty);
        library.IsExisting = true;
    }

    private void RemoveSourceFolder(LibraryEditorState library, int index)
    {
        if (index < 0 || index >= library.SourcePaths.Count) return;
        library.SourcePaths.RemoveAt(index);
        library.IsExisting = true;
    }

    private async Task BrowseLibraryRootAsync()
    {
        var selected = await BrowseForPathAsync(_libraryRoot);
        if (selected is null) return;
        _libraryRoot = selected;
        await TestAndRecordPathAsync(selected);
    }

    private async Task BrowseWatchFolderAsync(int index)
    {
        if (index < 0 || index >= _watchFolders.Count) return;
        var selected = await BrowseForPathAsync(_watchFolders[index]);
        if (selected is null) return;
        _watchFolders[index] = selected;
        await TestAndRecordPathAsync(selected);
    }

    private async Task BrowseSourceFolderAsync(LibraryEditorState library, int index)
    {
        if (index < 0 || index >= library.SourcePaths.Count) return;
        var selected = await BrowseForPathAsync(library.SourcePaths[index]);
        if (selected is null) return;
        library.SourcePaths[index] = selected;
        library.IsExisting = true;
        await TestAndRecordPathAsync(selected);
    }

    private async Task<string?> BrowseForPathAsync(string currentPath)
    {
        var parameters = new DialogParameters<FolderBrowserDialog>
        {
            { x => x.InitialPath, currentPath },
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true,
        };

        var dialog = await DialogService.ShowAsync<FolderBrowserDialog>(L["Libraries_BrowseFolders"], parameters, options);
        var result = await dialog.Result;
        return result is { Canceled: false, Data: string selectedPath } ? selectedPath : null;
    }

    private void SetStructureMode(LibraryEditorState library, string value)
    {
        var wasNoneMode = library.StructureMode == StructureModeNone;
        library.StructureMode = value;
        library.IsExisting = true;

        if (value == StructureModeRecommended)
        {
            library.ReadOnly = false;
            if (wasNoneMode && library.WritebackOverride == false)
                library.WritebackOverride = null;
            _organizationTemplates[library.TemplateKey] = RecommendedTemplate(library);
        }
        else if (value == StructureModeNone)
        {
            library.ReadOnly = true;
            library.WritebackOverride = false;
        }
        else if (value == StructureModeCustom)
        {
            library.ReadOnly = false;
            if (wasNoneMode && library.WritebackOverride == false)
                library.WritebackOverride = null;
            if (string.IsNullOrWhiteSpace(GetEditableTemplate(library)))
                _organizationTemplates[library.TemplateKey] = RecommendedTemplate(library);
        }
    }

    private void SetRecursive(LibraryEditorState library, bool value)
    {
        library.IncludeSubdirectories = value;
        library.IsExisting = true;
    }

    private void SetIntakeMode(LibraryEditorState library, string value)
    {
        library.IntakeMode = string.IsNullOrWhiteSpace(value) ? "watch" : value;
        library.IsExisting = true;
    }

    private void SetWriteback(LibraryEditorState library, string value)
    {
        library.WritebackOverride = value switch
        {
            "on" => true,
            "off" => false,
            _ => null,
        };
        library.IsExisting = true;
    }

    private static string WritebackValue(LibraryEditorState library) => library.WritebackOverride switch
    {
        true => "on",
        false => "off",
        _ => "default",
    };

    private void AppendToken(LibraryEditorState library, string token)
    {
        SetTemplate(library, GetEditableTemplate(library) + $"{{{token}}}");
    }

    private void SetTemplate(LibraryEditorState library, string? template)
    {
        var wasNoneMode = library.StructureMode == StructureModeNone;
        _organizationTemplates[library.TemplateKey] = template ?? string.Empty;
        library.StructureMode = StructureModeCustom;
        library.ReadOnly = false;
        if (wasNoneMode && library.WritebackOverride == false)
            library.WritebackOverride = null;
        library.IsExisting = true;
    }

    private string GetEditableTemplate(LibraryEditorState library) =>
        _organizationTemplates.TryGetValue(library.TemplateKey, out var template)
            ? template
            : RecommendedTemplate(library);

    private string ActiveTemplate(LibraryEditorState library) =>
        library.StructureMode == StructureModeRecommended
            ? RecommendedTemplate(library)
            : GetEditableTemplate(library);

    private static string RecommendedTemplate(LibraryEditorState library) => library.TemplateKey switch
    {
        "Books" => "Books/{Author}/{Title} ({Year})/{Title} ({Year}){Ext}",
        "Audiobooks" => "Audiobooks/{Author}/{Title} ({Year})/{Title}{Ext}",
        "Movies" => "Movies/{Title} ({Year})/{Title} ({Year}){Ext}",
        "TV" => "TV/{Series} ({Year})/Season {Season}/{Series} - s{Season}e{Episode} - {EpisodeTitle}{Ext}",
        "Music" => "Music/{Artist}/{Album} ({Year})/{TrackNumber} - {Title}{Ext}",
        "Comic" => "Comics/{Series}/{Series} - {IssueNumber} ({Year}){Ext}",
        _ => DefaultOrganizationTemplate,
    };

    private IReadOnlyList<string> PreviewParts(LibraryEditorState library)
    {
        var template = ActiveTemplate(library);
        var values = PreviewValues(library);
        foreach (var (token, value) in values)
            template = template.Replace(token, value, StringComparison.OrdinalIgnoreCase);
        return template.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    }

