@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject DeviceContextService DeviceContext
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IDisposable

@* Folder configuration — Library Folder (primary), Watch Folder, Staging Folder, and file naming template.
   Read-only on mobile. Not available on television / automotive. *@

@{
    var readOnly    = DeviceContext.IsMobile;
    var unavailable = DeviceContext.IsTelevision || DeviceContext.IsAutomotive;
}

@if (unavailable)
{
    <MudPaper Elevation="0" Style="@GlassStyle">
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="py-8">
            <MudIcon Icon="@Icons.Material.Outlined.DesktopAccessDisabled"
                     Color="Color.Secondary"
                     Style="font-size: 3rem;" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">Not Available</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="text-align: center;">
                Library folder settings are not available on this device.
                Please use the web or mobile interface to configure your library.
            </MudText>
        </MudStack>
    </MudPaper>
}
else
{
<MudPaper Elevation="0" Style="@GlassStyle">

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
        <MudText Typo="Typo.h6">Library Paths</MudText>
        @if (readOnly)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Default"
                     Icon="@Icons.Material.Outlined.Visibility"
                     Style="margin-left: auto;">
                View Only
            </MudChip>
        }
    </MudStack>

    @* ── Library Folder ─────────────────────────────────────────────────────── *@
    <div class="folder-path-row mb-5">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
            <div class="health-dot @HealthClass(_libraryHealthy, _libValidating, _libraryRoot)" />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Library Folder</MudText>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudTextField @bind-Value="_libraryRoot"
                          @bind-Value:after="@(() => OnPathChanged(nameof(_libraryRoot)))"
                          Placeholder="/path/to/library"
                          Variant="Variant.Text"
                          FullWidth="true"
                          Immediate="true"
                          ReadOnly="@readOnly"
                          Margin="Margin.Dense" />
            <MudIconButton Icon="@Icons.Material.Outlined.FolderOpen"
                           Size="Size.Medium"
                           Color="Color.Default"
                           Disabled="@readOnly"
                           OnClick="@(() => BrowseAsync(nameof(_libraryRoot)))"
                           title="Browse folders" />
        </MudStack>
        <MudText Typo="Typo.caption" Style="@StatusStyle(_libraryHealthy, _libValidating, _libraryRoot)" Class="mt-1">
            @StatusLabel(_libTestResult, _libValidating, _libraryRoot)
        </MudText>
    </div>

    @* ── Watch Folder ───────────────────────────────────────────────────────── *@
    <div class="folder-path-row mb-5">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
            <div class="health-dot @HealthClass(_watchHealthy, _watchValidating, _watchDir)" />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Watch Folder</MudText>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudTextField @bind-Value="_watchDir"
                          @bind-Value:after="@(() => OnPathChanged(nameof(_watchDir)))"
                          Placeholder="/path/to/watch"
                          Variant="Variant.Text"
                          FullWidth="true"
                          Immediate="true"
                          ReadOnly="@readOnly"
                          Margin="Margin.Dense" />
            <MudIconButton Icon="@Icons.Material.Outlined.FolderOpen"
                           Size="Size.Medium"
                           Color="Color.Default"
                           Disabled="@readOnly"
                           OnClick="@(() => BrowseAsync(nameof(_watchDir)))"
                           title="Browse folders" />
        </MudStack>
        <MudText Typo="Typo.caption" Style="@StatusStyle(_watchHealthy, _watchValidating, _watchDir)" Class="mt-1">
            @StatusLabel(_watchTestResult, _watchValidating, _watchDir)
        </MudText>
    </div>

    @* ── Staging Folder ─────────────────────────────────────────────────────── *@
    <div class="folder-path-row mb-5">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
            <div class="health-dot @HealthClass(_stagingHealthy, _stagingValidating, _stagingDir)" />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Staging Folder</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Default"
                     Style="font-size: 0.65rem; height: 18px;">Optional</MudChip>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudTextField @bind-Value="_stagingDir"
                          @bind-Value:after="@(() => OnPathChanged(nameof(_stagingDir)))"
                          Placeholder="/path/to/staging"
                          Variant="Variant.Text"
                          FullWidth="true"
                          Immediate="true"
                          ReadOnly="@readOnly"
                          Margin="Margin.Dense" />
            <MudIconButton Icon="@Icons.Material.Outlined.FolderOpen"
                           Size="Size.Medium"
                           Color="Color.Default"
                           Disabled="@readOnly"
                           OnClick="@(() => BrowseAsync(nameof(_stagingDir)))"
                           title="Browse folders" />
        </MudStack>
        <MudText Typo="Typo.caption" Style="@StatusStyle(_stagingHealthy, _stagingValidating, _stagingDir)" Class="mt-1">
            @StatusLabel(_stagingTestResult, _stagingValidating, _stagingDir)
        </MudText>
    </div>

    <MudDivider Class="my-6" />

    @* ── Folder and File Naming ─────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Folder and File Naming</MudText>
    </MudStack>
    <MudTextField @bind-Value="_organizationTemplate"
                  Placeholder="@DefaultOrganizationTemplate"
                  Variant="Variant.Text"
                  FullWidth="true"
                  Immediate="true"
                  ReadOnly="@readOnly"
                  Margin="Margin.Dense"
                  Class="mb-4" />

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   OnClick="@PreviewTemplateAsync"
                   Disabled="@(string.IsNullOrWhiteSpace(_organizationTemplate) || _previewingTemplate || readOnly)"
                   Style="white-space: nowrap; min-width: 110px;">
            @(_previewingTemplate ? "Checking..." : "Preview")
        </MudButton>
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   OnClick="@ResetTemplateToDefault"
                   Disabled="@readOnly"
                   StartIcon="@Icons.Material.Outlined.RestartAlt"
                   Style="white-space: nowrap;">
            Reset to Default
        </MudButton>
    </MudStack>

    @if (_templatePreview is not null)
    {
        <MudPaper Elevation="0" Style="@PreviewStyle" Class="mb-5 pa-3">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Sample output:</MudText>
            <MudText Typo="Typo.body2" Style="font-family: monospace; word-break: break-all;">
                @_templatePreview
            </MudText>
        </MudPaper>
    }
    else if (_templateError is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-5">@_templateError</MudAlert>
    }
    else
    {
        <div class="mb-5" />
    }

    @if (!readOnly)
    {
        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="@SaveFoldersAsync"
                       Disabled="@_savingFolders">
                @(_savingFolders ? "Saving..." : "Save Changes")
            </MudButton>
        </MudStack>
    }

</MudPaper>
}

<style>
    .folder-path-row {
        position: relative;
    }
    .health-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        transition: background 0.2s ease;
    }
    .health-dot.health-ok     { background: #4caf50; }
    .health-dot.health-error  { background: #f44336; }
    .health-dot.health-idle   { background: rgba(255, 255, 255, 0.2); }
    .health-dot.health-busy   { background: #ff9800; animation: health-pulse 1s ease-in-out infinite; }

    @@keyframes health-pulse {
        0%, 100% { opacity: 1; }
        50%      { opacity: 0.3; }
    }

    @@media (max-width: 768px) {
        .folder-path-row .mud-stack {
            flex-wrap: wrap;
        }
    }
</style>

@code {

    private const string DefaultOrganizationTemplate = "{Category}/{Author}/{Title} ({Edition}){Ext}";

    private const string GlassStyle =
        "background: var(--app-glass-bg); " +
        "border: 1px solid var(--app-glass-border); " +
        "backdrop-filter: blur(10px); " +
        "-webkit-backdrop-filter: blur(10px); " +
        "border-radius: 12px; " +
        "padding: 32px;";

    private const string PreviewStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 6px;";

    // ── State ────────────────────────────────────────────────────────────────────

    private string              _watchDir              = string.Empty;
    private string              _libraryRoot           = string.Empty;
    private string              _stagingDir            = string.Empty;
    private PathTestResultDto?  _watchTestResult;
    private PathTestResultDto?  _libTestResult;
    private PathTestResultDto?  _stagingTestResult;
    private bool                _watchValidating;
    private bool                _libValidating;
    private bool                _stagingValidating;
    private bool                _savingFolders;
    private bool                _watchHealthy;
    private bool                _libraryHealthy;
    private bool                _stagingHealthy;

    // Template state
    private string              _organizationTemplate  = string.Empty;
    private string?             _templatePreview;
    private string?             _templateError;
    private bool                _previewingTemplate;

    // Debounce timers for auto-validation
    private Timer? _watchTimer;
    private Timer? _libTimer;
    private Timer? _stagingTimer;

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        DeviceContext.OnChanged += OnDeviceChanged;

        var settings = await Orchestrator.GetFolderSettingsAsync();
        if (settings is not null)
        {
            _watchDir    = settings.WatchDirectory;
            _libraryRoot = settings.LibraryRoot;
            _stagingDir  = settings.StagingDirectory;
        }

        // Load organization template.
        var tmpl = await Orchestrator.GetOrganizationTemplateAsync();
        if (tmpl is not null)
        {
            _organizationTemplate = tmpl.Template;
            _templatePreview      = tmpl.Preview;
        }
        else
        {
            _organizationTemplate = DefaultOrganizationTemplate;
        }

        // Run initial health checks based on current folder settings.
        await CheckInitialHealthAsync();

        Orchestrator.OnFolderHealthChanged += HandleFolderHealthChanged;
    }

    public void Dispose()
    {
        Orchestrator.OnFolderHealthChanged -= HandleFolderHealthChanged;
        DeviceContext.OnChanged            -= OnDeviceChanged;
        _watchTimer?.Dispose();
        _libTimer?.Dispose();
        _stagingTimer?.Dispose();
    }

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    // ── Folder health event ─────────────────────────────────────────────────────

    private void HandleFolderHealthChanged(string path, bool healthy)
    {
        if (!string.IsNullOrWhiteSpace(_watchDir)
            && string.Equals(path, _watchDir, StringComparison.OrdinalIgnoreCase))
            _watchHealthy = healthy;
        else if (!string.IsNullOrWhiteSpace(_libraryRoot)
            && string.Equals(path, _libraryRoot, StringComparison.OrdinalIgnoreCase))
            _libraryHealthy = healthy;
        else if (!string.IsNullOrWhiteSpace(_stagingDir)
            && string.Equals(path, _stagingDir, StringComparison.OrdinalIgnoreCase))
            _stagingHealthy = healthy;

        InvokeAsync(StateHasChanged);
    }

    private async Task CheckInitialHealthAsync()
    {
        if (!string.IsNullOrWhiteSpace(_watchDir))
        {
            var r = await Orchestrator.TestPathAsync(_watchDir);
            _watchTestResult = r;
            _watchHealthy    = r is { Exists: true, HasRead: true, HasWrite: true };
        }

        if (!string.IsNullOrWhiteSpace(_libraryRoot))
        {
            var r = await Orchestrator.TestPathAsync(_libraryRoot);
            _libTestResult  = r;
            _libraryHealthy = r is { Exists: true, HasRead: true, HasWrite: true };
        }

        if (!string.IsNullOrWhiteSpace(_stagingDir))
        {
            var r = await Orchestrator.TestPathAsync(_stagingDir);
            _stagingTestResult = r;
            _stagingHealthy    = r is { Exists: true, HasRead: true, HasWrite: true };
        }
    }

    // ── Debounced auto-validation ───────────────────────────────────────────────

    private void OnPathChanged(string field)
    {
        switch (field)
        {
            case nameof(_libraryRoot):
                _libTestResult = null;
                _libValidating = false;
                _libTimer?.Dispose();
                if (!string.IsNullOrWhiteSpace(_libraryRoot))
                    _libTimer = new Timer(_ => InvokeAsync(ValidateLibraryAsync), null, 800, Timeout.Infinite);
                else
                    _libraryHealthy = false;
                break;

            case nameof(_watchDir):
                _watchTestResult = null;
                _watchValidating = false;
                _watchTimer?.Dispose();
                if (!string.IsNullOrWhiteSpace(_watchDir))
                    _watchTimer = new Timer(_ => InvokeAsync(ValidateWatchAsync), null, 800, Timeout.Infinite);
                else
                    _watchHealthy = false;
                break;

            case nameof(_stagingDir):
                _stagingTestResult = null;
                _stagingValidating = false;
                _stagingTimer?.Dispose();
                if (!string.IsNullOrWhiteSpace(_stagingDir))
                    _stagingTimer = new Timer(_ => InvokeAsync(ValidateStagingAsync), null, 800, Timeout.Infinite);
                else
                    _stagingHealthy = false;
                break;
        }
    }

    private async Task ValidateLibraryAsync()
    {
        _libValidating = true;
        StateHasChanged();
        _libTestResult  = await Orchestrator.TestPathAsync(_libraryRoot);
        _libraryHealthy = _libTestResult is { Exists: true, HasRead: true, HasWrite: true };
        _libValidating  = false;
        StateHasChanged();
    }

    private async Task ValidateWatchAsync()
    {
        _watchValidating = true;
        StateHasChanged();
        _watchTestResult = await Orchestrator.TestPathAsync(_watchDir);
        _watchHealthy    = _watchTestResult is { Exists: true, HasRead: true, HasWrite: true };
        _watchValidating = false;
        StateHasChanged();
    }

    private async Task ValidateStagingAsync()
    {
        _stagingValidating = true;
        StateHasChanged();
        _stagingTestResult = await Orchestrator.TestPathAsync(_stagingDir);
        _stagingHealthy    = _stagingTestResult is { Exists: true, HasRead: true, HasWrite: true };
        _stagingValidating = false;
        StateHasChanged();
    }

    // ── Browse dialog ───────────────────────────────────────────────────────────

    private async Task BrowseAsync(string field)
    {
        var currentPath = field switch
        {
            nameof(_libraryRoot) => _libraryRoot,
            nameof(_watchDir)    => _watchDir,
            nameof(_stagingDir)  => _stagingDir,
            _                    => string.Empty,
        };

        var parameters = new DialogParameters<FolderBrowserDialog>
        {
            { x => x.InitialPath, currentPath },
        };

        var options = new DialogOptions
        {
            MaxWidth    = MaxWidth.Small,
            FullWidth   = true,
            CloseButton = true,
        };

        var dialog = await DialogService.ShowAsync<FolderBrowserDialog>("Browse Folders", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string selectedPath })
        {
            switch (field)
            {
                case nameof(_libraryRoot):
                    _libraryRoot = selectedPath;
                    await ValidateLibraryAsync();
                    break;
                case nameof(_watchDir):
                    _watchDir = selectedPath;
                    await ValidateWatchAsync();
                    break;
                case nameof(_stagingDir):
                    _stagingDir = selectedPath;
                    await ValidateStagingAsync();
                    break;
            }
        }
    }

    // ── Template handlers ───────────────────────────────────────────────────────

    private async Task PreviewTemplateAsync()
    {
        if (string.IsNullOrWhiteSpace(_organizationTemplate)) return;
        _previewingTemplate = true;
        _templatePreview    = null;
        _templateError      = null;

        var result = await Orchestrator.UpdateOrganizationTemplateAsync(_organizationTemplate);

        if (result is not null)
        {
            _templatePreview = result.Preview;
        }
        else
        {
            _templateError = Orchestrator.LastApiError ?? "Invalid template — please check your tokens.";
        }

        _previewingTemplate = false;
    }

    private void ResetTemplateToDefault()
    {
        _organizationTemplate = DefaultOrganizationTemplate;
        _templatePreview      = null;
        _templateError        = null;
    }

    // ── Save ────────────────────────────────────────────────────────────────────

    private async Task SaveFoldersAsync()
    {
        _savingFolders = true;

        // Pre-flight: check that the Engine is reachable before validating paths.
        var engineStatus = await Orchestrator.GetSystemStatusAsync();
        if (engineStatus is null)
        {
            Snackbar.Add("Cannot reach the Engine — please make sure it is running.", Severity.Error);
            _savingFolders = false;
            return;
        }

        // Validate Watch Folder (required — must have read + write).
        if (!string.IsNullOrWhiteSpace(_watchDir))
        {
            var r = await Orchestrator.TestPathAsync(_watchDir);
            _watchTestResult = r;
            if (r is null)
            {
                Snackbar.Add("Cannot reach the Engine — please make sure it is running.", Severity.Error);
                _savingFolders = false;
                return;
            }
            if (r is not { HasRead: true, HasWrite: true })
            {
                Snackbar.Add("Watch Folder is not accessible — please check the path and permissions.",
                    Severity.Error);
                _watchHealthy  = false;
                _savingFolders = false;
                return;
            }
            _watchHealthy = true;
        }

        // Validate Library Folder (optional — if provided, must have read + write).
        if (!string.IsNullOrWhiteSpace(_libraryRoot))
        {
            var r = await Orchestrator.TestPathAsync(_libraryRoot);
            _libTestResult = r;
            if (r is null)
            {
                Snackbar.Add("Cannot reach the Engine — please make sure it is running.", Severity.Error);
                _savingFolders = false;
                return;
            }
            if (r is not { HasRead: true, HasWrite: true })
            {
                Snackbar.Add("Library Folder is not accessible — please check the path and permissions.",
                    Severity.Error);
                _libraryHealthy = false;
                _savingFolders  = false;
                return;
            }
            _libraryHealthy = true;
        }

        // Validate Staging Folder (optional — if provided, must have read + write).
        if (!string.IsNullOrWhiteSpace(_stagingDir))
        {
            var r = await Orchestrator.TestPathAsync(_stagingDir);
            _stagingTestResult = r;
            if (r is null)
            {
                Snackbar.Add("Cannot reach the Engine — please make sure it is running.", Severity.Error);
                _savingFolders = false;
                return;
            }
            if (r is not { HasRead: true, HasWrite: true })
            {
                Snackbar.Add("Staging Folder is not accessible — please check the path and permissions.",
                    Severity.Error);
                _stagingHealthy = false;
                _savingFolders  = false;
                return;
            }
            _stagingHealthy = true;
        }

        // Save folder settings.
        var dto     = new FolderSettingsDto(_watchDir, _libraryRoot, _stagingDir);
        var success = await Orchestrator.UpdateFolderSettingsAsync(dto);

        // Save organization template (if provided).
        if (success && !string.IsNullOrWhiteSpace(_organizationTemplate))
        {
            var tmplResult = await Orchestrator.UpdateOrganizationTemplateAsync(_organizationTemplate);
            if (tmplResult is null)
            {
                Snackbar.Add(
                    Orchestrator.LastApiError ?? "Invalid template — please check your tokens.",
                    Severity.Warning);
            }
            else
            {
                _templatePreview = tmplResult.Preview;
            }
        }

        if (success)
        {
            Snackbar.Add($"Settings saved — now watching {_watchDir}", Severity.Success);
        }
        else
        {
            var detail = Orchestrator.LastApiError;
            Snackbar.Add(
                string.IsNullOrEmpty(detail)
                    ? "Could not save folder settings — please make sure the Engine is running."
                    : $"Could not save: {detail}",
                Severity.Error);
        }

        _savingFolders = false;
    }

    // ── Display helpers ─────────────────────────────────────────────────────────

    private static string HealthClass(bool healthy, bool validating, string path) =>
        validating                        ? "health-busy"  :
        string.IsNullOrWhiteSpace(path)   ? "health-idle"  :
        healthy                           ? "health-ok"    :
                                            "health-error";

    private static string StatusStyle(bool healthy, bool validating, string path)
    {
        var color = validating                      ? "var(--mud-palette-warning)" :
                    string.IsNullOrWhiteSpace(path) ? "var(--app-text-soft)"       :
                    healthy                         ? "var(--mud-palette-success)"  :
                                                      "var(--mud-palette-error)";
        return $"color: {color}; font-size: 0.75rem;";
    }

    private static string StatusLabel(PathTestResultDto? result, bool validating, string path)
    {
        if (string.IsNullOrWhiteSpace(path))   return " ";
        if (validating)                        return "Checking...";
        if (result is null)                    return " ";
        if (!result.Exists)                    return "Folder not found";
        if (result.HasRead && result.HasWrite) return "Read & Write access confirmed";
        if (result.HasRead)                    return "Read only — cannot write";
        return "Access denied";
    }
}
