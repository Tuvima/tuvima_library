@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient
@inject DeviceContextService DeviceContext
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable
@{
    var readOnly    = DeviceContext.IsMobile;
    var unavailable = DeviceContext.IsTelevision || DeviceContext.IsAutomotive;
}

@if (unavailable)
{
    <div class="tl-page libraries-page">
        <AppPageState Kind="AppPageStateKind.Unavailable"
                      Icon="@Icons.Material.Outlined.DesktopAccessDisabled"
                      Title="@L["Libraries_NotAvailable"].Value"
                      Message="@L["Libraries_NotAvailableDescription"].Value" />
    </div>
}
else
{
    <div class="tl-page libraries-page">
        <AppPageHeader Title="@L["Libraries_LibraryPaths"].Value"
                       Class="libraries-page__header">
            <Stats>
                <AppStatusBadge Text="@(_engineUnavailable ? "Engine unavailable" : "Live")"
                                Tone="@(_engineUnavailable ? AppStatusTone.Error : AppStatusTone.Success)" />
            </Stats>
            <Actions>
                <AppButton Label="Folder health"
                           StartIcon="@Icons.Material.Outlined.Refresh"
                           ButtonStyle="AppButtonStyle.Text"
                           OnClick="@CheckInitialHealthAsync" />
                <AppButton Label="Setup checklist"
                           StartIcon="@Icons.Material.Outlined.RocketLaunch"
                           ButtonStyle="AppButtonStyle.Text"
                           Href="/settings/setup" />
                <AppButton Label="Ingestion"
                           StartIcon="@Icons.Material.Outlined.PendingActions"
                           ButtonStyle="AppButtonStyle.Text"
                           Href="/settings/ingestion" />
                @if (readOnly)
                {
                    <AppChip Text="@L["Libraries_ViewOnly"].Value"
                             Icon="@Icons.Material.Outlined.Visibility" />
                }
            </Actions>
        </AppPageHeader>

        @if (_engineUnavailable)
        {
            <AppAlert Tone="AppUiTone.Error">
                The Engine is unavailable, so folder settings cannot be validated or saved. Existing values are not replaced with defaults.
            </AppAlert>
        }
        else if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <AppAlert Tone="AppUiTone.Warning">
                @_loadError
            </AppAlert>
        }

        <AppCard Class="libraries-paths">
            <div class="folder-path-row">
                <div class="folder-path-heading">
                    <span class="health-dot @HealthClass(_libraryHealthy, _libValidating, _libraryRoot)"></span>
                    <span>@L["Libraries_LibraryFolder"]</span>
                </div>
                <div class="folder-path-help">
                    The Library Root is where Tuvima keeps organized media after files are accepted.
                </div>
                <div class="folder-path-input-row">
                    <AppTextField Value="@_libraryRoot"
                                  ValueChanged="@((string? value) => OnPathValueChanged(nameof(_libraryRoot), value))"
                                  Placeholder="/path/to/library"
                                  ReadOnly="@(readOnly || _engineUnavailable)" />
                    <AppIconButton Icon="@Icons.Material.Outlined.FolderOpen"
                                   Tooltip="@L["Libraries_BrowseFolders"].Value"
                                   AriaLabel="@L["Libraries_BrowseFolders"].Value"
                                   Disabled="@(readOnly || _engineUnavailable)"
                                   OnClick="@(() => BrowseAsync(nameof(_libraryRoot)))" />
                </div>
                <div class="@StatusTextClass(_libraryHealthy, _libValidating, _libraryRoot)">
                    @StatusLabel(_libTestResult, _libValidating, _libraryRoot)
                </div>
            </div>

            <div class="folder-path-row">
                <div class="folder-path-heading">
                    <span class="health-dot @HealthClass(_watchHealthy, _watchValidating, _watchDir)"></span>
                    <span>@L["Libraries_WatchFolder"]</span>
                </div>
                <div class="folder-path-help">
                    The Watch Folder is where new files are detected when you scan or drop media in.
                </div>
                <div class="folder-path-input-row">
                    <AppTextField Value="@_watchDir"
                                  ValueChanged="@((string? value) => OnPathValueChanged(nameof(_watchDir), value))"
                                  Placeholder="/path/to/watch"
                                  ReadOnly="@(readOnly || _engineUnavailable)" />
                    <AppIconButton Icon="@Icons.Material.Outlined.FolderOpen"
                                   Tooltip="@L["Libraries_BrowseFolders"].Value"
                                   AriaLabel="@L["Libraries_BrowseFolders"].Value"
                                   Disabled="@(readOnly || _engineUnavailable)"
                                   OnClick="@(() => BrowseAsync(nameof(_watchDir)))" />
                </div>
                <div class="@StatusTextClass(_watchHealthy, _watchValidating, _watchDir)">
                    @StatusLabel(_watchTestResult, _watchValidating, _watchDir)
                </div>
            </div>
        </AppCard>

        @if (_libraries is { Count: > 0 })
        {
            <section class="libraries-section">
                <div class="libraries-section__title">
                    <MudIcon Icon="@Icons.Material.Outlined.Storage" />
                    <span>@L["Libraries_ConfiguredLibraries"]</span>
                </div>
                <p class="libraries-section__hint">
                    @L["Libraries_ConfiguredLibrariesHint"]
                </p>

                <div class="libraries-configured-list">
                    @foreach (var lib in _libraries)
                    {
                        <AppCard Density="AppSurfaceDensity.Compact" Class="library-config-card">
                            <div class="library-config-card__header">
                                <span class="library-config-card__name">@lib.Name</span>
                                <div class="library-config-card__chips">
                                    @foreach (var mt in lib.MediaTypes)
                                    {
                                        <AppChip Text="@mt" />
                                    }
                                    @if (lib.ReadOnly)
                                    {
                                        <AppChip Text="Read-only"
                                                 Icon="@Icons.Material.Outlined.Lock"
                                                 Tone="AppUiTone.Warning" />
                                    }
                                    <AppChip Text="@WritebackLabel(lib.WritebackOverride)"
                                             Tone="@WritebackTone(lib.WritebackOverride)" />
                                </div>
                            </div>

                            <div class="library-config-card__paths">
                                @foreach (var path in lib.EffectiveSourcePaths)
                                {
                                    <div class="library-path">
                                        <MudIcon Icon="@Icons.Material.Outlined.Folder" Size="Size.Small" />
                                        <span>@path</span>
                                    </div>
                                }
                            </div>
                        </AppCard>
                    }
                </div>
            </section>
        }

        <section class="libraries-section">
            <div class="libraries-section__title">
                <span>@L["Libraries_FileOrganization"]</span>
            </div>
            <p class="libraries-section__hint">
                @L["Libraries_FileOrganizationHint"]
            </p>

            @if (!readOnly)
            {
                <div class="org-token-strip">
                    @foreach (var token in AvailableTokens)
                    {
                        <AppChip OnClick="@(() => AppendToken(token))"
                                 Class="org-token-chip">
                            <span class="org-token-brace">{</span>@token<span class="org-token-brace">}</span>
                        </AppChip>
                    }
                </div>
            }

            <div class="organization-template-row">
                <AppTextField @bind-Value="_organizationTemplate"
                              Placeholder="@DefaultOrganizationTemplate"
                              ReadOnly="@(readOnly || _engineUnavailable)" />
                @if (!readOnly)
                {
                    <AppIconButton Icon="@Icons.Material.Outlined.RestartAlt"
                                   Tooltip="@L["Libraries_ResetPathToDefault"].Value"
                                   AriaLabel="@L["Libraries_ResetPathToDefault"].Value"
                                   Size="AppControlSize.Compact"
                                   Disabled="@_engineUnavailable"
                                   OnClick="@ResetTemplateToDefault" />
                }
            </div>

            @{
                var previewParts = LivePreviewParts();
            }
            @if (previewParts.Count > 0)
            {
                <AppPanel Density="AppSurfaceDensity.Compact" Class="org-preview-panel">
                    <div class="libraries-section__hint libraries-section__hint--tight">
                        @L["Libraries_PreviewExampleOutput"]
                    </div>
                    <div class="org-preview-tree">
                        @for (int i = 0; i < previewParts.Count - 1; i++)
                        {
                            var depth = i;
                            <div class="@PreviewRowClass("org-preview-folder", depth)">
                                <MudIcon Icon="@Icons.Material.Outlined.Folder" Size="Size.Small" />
                                <span class="org-preview-name">@previewParts[i]</span>
                            </div>
                        }
                        @{
                            var fileName = previewParts[^1];
                            var fileDepth = previewParts.Count - 1;
                        }
                        <div class="@PreviewRowClass("org-preview-file", fileDepth)">
                            <MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" />
                            <span class="org-preview-name">@fileName</span>
                        </div>
                    </div>
                </AppPanel>
            }

            @if (!readOnly)
            {
                @if (!string.IsNullOrWhiteSpace(_templateValidationError))
                {
                    <AppAlert Tone="AppUiTone.Warning">
                        @_templateValidationError
                    </AppAlert>
                }
                <AppActionBar>
                    <AppButton Label="Open Ingestion"
                               StartIcon="@Icons.Material.Outlined.PendingActions"
                               ButtonStyle="AppButtonStyle.Text"
                               Href="/settings/ingestion" />
                    <AppButton Label="Scan saved watch folder"
                               StartIcon="@Icons.Material.Outlined.ManageSearch"
                               Tone="AppUiTone.Primary"
                               Disabled="@(_engineUnavailable || HasUnsavedChanges || string.IsNullOrWhiteSpace(_watchDir))"
                               OnClick="@ScanAfterSaveAsync" />
                    <AppButton Label="@L["Libraries_Reset"].Value"
                               StartIcon="@Icons.Material.Outlined.Undo"
                               ButtonStyle="AppButtonStyle.Text"
                               Disabled="@(!HasUnsavedChanges)"
                               OnClick="@ResetAllChanges" />
                    <AppButton Label="@(_savingFolders ? L["Libraries_Saving"].Value : L["Libraries_SaveChanges"].Value)"
                               ButtonStyle="AppButtonStyle.Filled"
                               Tone="AppUiTone.Primary"
                               Disabled="@(_savingFolders || _engineUnavailable || !HasUnsavedChanges)"
                               OnClick="@SaveFoldersAsync" />
                </AppActionBar>
            }
        </section>
    </div>
}

@code {
    private const string DefaultOrganizationTemplate = "{Category}/{Author}/{Title} ({Edition}){Ext}";
    private static readonly string[] AvailableTokens =
        ["Category", "Author", "Title", "Series", "Year", "MediaType", "Edition", "Ext"];
    private static readonly Dictionary<string, string> PreviewValues = new(StringComparer.OrdinalIgnoreCase)
    {
        ["{Category}"]  = "Books",
        ["{Author}"]    = "Frank Herbert",
        ["{Title}"]     = "Dune",
        ["{Series}"]    = "Dune Saga",
        ["{Year}"]      = "1965",
        ["{MediaType}"] = "Epub",
        ["{Edition}"]   = "First Edition",
        ["{Ext}"]       = ".epub",
    };

    private string              _watchDir              = string.Empty;
    private string              _libraryRoot           = string.Empty;
    private PathTestResultDto?  _watchTestResult;
    private PathTestResultDto?  _libTestResult;
    private bool                _watchValidating;
    private bool                _libValidating;
    private bool                _savingFolders;
    private bool                _watchHealthy;
    private bool                _libraryHealthy;
    private string              _organizationTemplate  = string.Empty;
    private List<LibraryFolderDto>? _libraries;
    private bool                _engineUnavailable;
    private string?             _loadError;
    private string?             _templateValidationError;
    private string              _savedWatchDir         = string.Empty;
    private string              _savedLibraryRoot      = string.Empty;
    private string              _savedOrganizationTemplate = string.Empty;
    private Timer? _watchTimer;
    private Timer? _libTimer;

    private bool HasUnsavedChanges =>
        _watchDir             != _savedWatchDir             ||
        _libraryRoot          != _savedLibraryRoot          ||
        _organizationTemplate != _savedOrganizationTemplate;

    private IReadOnlyList<string> LivePreviewParts()
    {
        if (string.IsNullOrWhiteSpace(_organizationTemplate))
            return [];
        var result = _organizationTemplate;
        foreach (var (token, value) in PreviewValues)
            result = result.Replace(token, value, StringComparison.OrdinalIgnoreCase);
        return result.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    }

    private void AppendToken(string token)
    {
        _organizationTemplate += $"{{{token}}}";
    }

    protected override async Task OnInitializedAsync()
    {
        DeviceContext.OnChanged += OnDeviceChanged;

        var settings = await Orchestrator.GetFolderSettingsAsync();
        if (settings is not null)
        {
            _watchDir    = settings.WatchDirectory;
            _libraryRoot = settings.LibraryRoot;
        }
        else
        {
            _engineUnavailable = true;
            _loadError = Orchestrator.LastApiError ?? "Folder settings could not be loaded from the Engine.";
        }
        var tmpl = await Orchestrator.GetOrganizationTemplateAsync();
        _organizationTemplate = tmpl?.Template ?? DefaultOrganizationTemplate;
        _libraries = await Orchestrator.GetLibrariesAsync();
        SnapSavedValues();
        await CheckInitialHealthAsync();

        Orchestrator.OnFolderHealthChanged += HandleFolderHealthChanged;
    }

    public void Dispose()
    {
        Orchestrator.OnFolderHealthChanged -= HandleFolderHealthChanged;
        DeviceContext.OnChanged            -= OnDeviceChanged;
        _watchTimer?.Dispose();
        _libTimer?.Dispose();
    }

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    private void SnapSavedValues()
    {
        _savedWatchDir              = _watchDir;
        _savedLibraryRoot           = _libraryRoot;
        _savedOrganizationTemplate  = _organizationTemplate;
    }

    private void ResetAllChanges()
    {
        _watchDir             = _savedWatchDir;
        _libraryRoot          = _savedLibraryRoot;
        _organizationTemplate = _savedOrganizationTemplate;
        _watchTestResult  = null;
        _libTestResult    = null;
        _templateValidationError = null;
        _watchHealthy   = false;
        _libraryHealthy = false;
        _ = CheckInitialHealthAsync();
    }

    private void HandleFolderHealthChanged(string path, bool healthy)
    {
        if (!string.IsNullOrWhiteSpace(_watchDir)
            && string.Equals(path, _watchDir, StringComparison.OrdinalIgnoreCase))
            _watchHealthy = healthy;
        else if (!string.IsNullOrWhiteSpace(_libraryRoot)
            && string.Equals(path, _libraryRoot, StringComparison.OrdinalIgnoreCase))
            _libraryHealthy = healthy;

        InvokeAsync(StateHasChanged);
    }

    private async Task CheckInitialHealthAsync()
    {
        if (!string.IsNullOrWhiteSpace(_watchDir))
        {
            var r = await Orchestrator.TestPathAsync(_watchDir);
            _watchTestResult = r;
            _watchHealthy    = r is { Exists: true, HasRead: true, HasWrite: true };
            _engineUnavailable = r is null;
        }

        if (!string.IsNullOrWhiteSpace(_libraryRoot))
        {
            var r = await Orchestrator.TestPathAsync(_libraryRoot);
            _libTestResult  = r;
            _libraryHealthy = r is { Exists: true, HasRead: true, HasWrite: true };
            _engineUnavailable = _engineUnavailable || r is null;
        }
    }

    private void OnPathValueChanged(string field, string? value)
    {
        switch (field)
        {
            case nameof(_libraryRoot):
                _libraryRoot = value ?? string.Empty;
                break;
            case nameof(_watchDir):
                _watchDir = value ?? string.Empty;
                break;
        }

        OnPathChanged(field);
    }

    private void OnPathChanged(string field)
    {
        switch (field)
        {
            case nameof(_libraryRoot):
                _libTestResult = null;
                _libValidating = false;
                _libTimer?.Dispose();
                if (!string.IsNullOrWhiteSpace(_libraryRoot))
                    _libTimer = new Timer(_ => InvokeAsync(ValidateLibraryAsync), null, 800, Timeout.Infinite);
                else
                    _libraryHealthy = false;
                break;

            case nameof(_watchDir):
                _watchTestResult = null;
                _watchValidating = false;
                _watchTimer?.Dispose();
                if (!string.IsNullOrWhiteSpace(_watchDir))
                    _watchTimer = new Timer(_ => InvokeAsync(ValidateWatchAsync), null, 800, Timeout.Infinite);
                else
                    _watchHealthy = false;
                break;
        }
    }

    private async Task ValidateLibraryAsync()
    {
        _libValidating = true;
        StateHasChanged();
        _libTestResult  = await Orchestrator.TestPathAsync(_libraryRoot);
        _engineUnavailable = _libTestResult is null;
        _libraryHealthy = _libTestResult is { Exists: true, HasRead: true, HasWrite: true };
        _libValidating  = false;
        StateHasChanged();
    }

    private async Task ValidateWatchAsync()
    {
        _watchValidating = true;
        StateHasChanged();
        _watchTestResult = await Orchestrator.TestPathAsync(_watchDir);
        _engineUnavailable = _watchTestResult is null;
        _watchHealthy    = _watchTestResult is { Exists: true, HasRead: true, HasWrite: true };
        _watchValidating = false;
        StateHasChanged();
    }

    private async Task BrowseAsync(string field)
    {
        var currentPath = field switch
        {
            nameof(_libraryRoot) => _libraryRoot,
            nameof(_watchDir)    => _watchDir,
            _                    => string.Empty,
        };

        var parameters = new DialogParameters<FolderBrowserDialog>
        {
            { x => x.InitialPath, currentPath },
        };

        var options = new DialogOptions
        {
            MaxWidth    = MaxWidth.Small,
            FullWidth   = true,
            CloseButton = true,
            CloseOnEscapeKey = true,
        };

        var dialog = await DialogService.ShowAsync<FolderBrowserDialog>(L["Libraries_BrowseFolders"], parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string selectedPath })
        {
            switch (field)
            {
                case nameof(_libraryRoot):
                    _libraryRoot = selectedPath;
                    await ValidateLibraryAsync();
                    break;
                case nameof(_watchDir):
                    _watchDir = selectedPath;
                    await ValidateWatchAsync();
                    break;
            }
        }
    }

    private void ResetTemplateToDefault()
    {
        _organizationTemplate = DefaultOrganizationTemplate;
        _templateValidationError = null;
    }

    private async Task SaveFoldersAsync()
    {
        _savingFolders = true;
        _templateValidationError = null;
        var engineStatus = await Orchestrator.GetSystemStatusAsync();
        if (engineStatus is null)
        {
            _engineUnavailable = true;
            Snackbar.Add(L["Libraries_CannotReachEngine"], Severity.Error);
            _savingFolders = false;
            return;
        }
        if (!string.IsNullOrWhiteSpace(_watchDir))
        {
            var r = await Orchestrator.TestPathAsync(_watchDir);
            _watchTestResult = r;
            if (r is null)
            {
                Snackbar.Add(L["Libraries_CannotReachEngine"], Severity.Error);
                _savingFolders = false;
                return;
            }
            if (r is not { HasRead: true, HasWrite: true })
            {
                Snackbar.Add(L["Libraries_WatchFolderNotAccessible"], Severity.Error);
                _watchHealthy  = false;
                _savingFolders = false;
                return;
            }
            _watchHealthy = true;
        }
        if (!string.IsNullOrWhiteSpace(_libraryRoot))
        {
            var r = await Orchestrator.TestPathAsync(_libraryRoot);
            _libTestResult = r;
            if (r is null)
            {
                Snackbar.Add(L["Libraries_CannotReachEngine"], Severity.Error);
                _savingFolders = false;
                return;
            }
            if (r is not { HasRead: true, HasWrite: true })
            {
                Snackbar.Add(L["Libraries_LibraryFolderNotAccessible"], Severity.Error);
                _libraryHealthy = false;
                _savingFolders  = false;
                return;
            }
            _libraryHealthy = true;
        }
        var dto     = new FolderSettingsDto(_watchDir, _libraryRoot);
        var success = await Orchestrator.UpdateFolderSettingsAsync(dto);
        if (success && !string.IsNullOrWhiteSpace(_organizationTemplate))
        {
            var previewResult = await ApiClient.PreviewOrganizationTemplateAsync(_organizationTemplate);
            if (previewResult is null)
            {
                _templateValidationError = ApiClient.LastError ?? L["Libraries_InvalidTemplate"];
                Snackbar.Add(
                    _templateValidationError,
                    Severity.Warning);
                _savingFolders = false;
                return;
            }

            var tmplResult = await Orchestrator.UpdateOrganizationTemplateAsync(_organizationTemplate);
            if (tmplResult is null)
            {
                Snackbar.Add(
                    Orchestrator.LastApiError ?? L["Libraries_InvalidTemplate"],
                    Severity.Warning);
            }
        }

        if (success)
        {
            Snackbar.Add($"{L["Libraries_SettingsSaved"]} Watcher hot-swap was requested. A rescan is recommended if files already exist in the watch folder.", Severity.Success);
            SnapSavedValues();
        }
        else
        {
            var detail = Orchestrator.LastApiError;
            Snackbar.Add(
                string.IsNullOrEmpty(detail)
                    ? L["Libraries_CouldNotSaveFolderSettings"]
                    : $"{L["Libraries_CouldNotSave"]} {detail}",
                Severity.Error);
        }

        _savingFolders = false;
    }

    private async Task ScanAfterSaveAsync()
    {
        var result = await Orchestrator.ScanAndRefreshAsync(_watchDir);
        Snackbar.Add(
            result is null
                ? "Scan could not be started. Check Engine status in Ingestion."
                : "Scan started for the saved watch folder.",
            result is null ? Severity.Error : Severity.Success);
    }

    private static string HealthClass(bool healthy, bool validating, string path) =>
        validating                        ? "health-busy"  :
        string.IsNullOrWhiteSpace(path)   ? "health-idle"  :
        healthy                           ? "health-ok"    :
                                            "health-error";

    private static string StatusTextClass(bool healthy, bool validating, string path) =>
        string.Join(" ", new[]
        {
            "folder-path-status",
            validating                      ? "folder-path-status--validating" :
            string.IsNullOrWhiteSpace(path) ? "folder-path-status--empty" :
            healthy                         ? "folder-path-status--healthy" :
                                              "folder-path-status--error",
        });

    private static string WritebackLabel(bool? enabled) => enabled switch
    {
        true => "Writeback: On",
        false => "Writeback: Off",
        _ => "Writeback: Global default",
    };

    private static AppUiTone WritebackTone(bool? enabled) => enabled switch
    {
        true => AppUiTone.Success,
        false => AppUiTone.Error,
        _ => AppUiTone.Neutral,
    };

    private static string PreviewRowClass(string baseClass, int depth) =>
        $"{baseClass} org-preview-depth-{Math.Clamp(depth, 0, 8)}";

    private string StatusLabel(PathTestResultDto? result, bool validating, string path)
    {
        if (string.IsNullOrWhiteSpace(path))   return " ";
        if (validating)                        return L["Libraries_Checking"];
        if (result is null)                    return "Engine unavailable - path could not be checked.";
        if (!result.Exists)                    return $"{L["Libraries_FolderNotFound"]} Create the folder or choose an existing path.";
        if (result.HasRead && result.HasWrite) return $"{L["Libraries_ReadWriteConfirmed"]} Live after save; rescan may be needed.";
        if (result.HasRead)                    return $"{L["Libraries_ReadOnly"]} Tuvima can read this path but organization/writeback will be limited.";
        return $"{L["Libraries_AccessDenied"]} Grant the Engine service account read access.";
    }
}
