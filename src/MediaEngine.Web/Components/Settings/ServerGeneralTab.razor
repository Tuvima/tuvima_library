@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L
<MudStack Spacing="4">
<div class="tl-page">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Outlined.Dns" Color="Color.Primary" />
                <MudText Typo="Typo.h6">@L["ServerGeneral_ServerIdentityTitle"]</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Style="color: var(--app-text-muted);">
                @L["ServerGeneral_ServerIdentityDescription"]
            </MudText>

            <MudTextField @bind-Value="_serverName"
                          Label="@L["ServerGeneral_ServerNameLabel"]"
                          Variant="Variant.Outlined"
                          HelperText="@L["ServerGeneral_ServerNameHelper"]"
                          MaxLength="64"
                          Immediate="true"
                          Disabled="@_saving" />
        </MudStack>
    </div>
<div class="tl-page">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Outlined.Language" Color="Color.Primary" />
                <MudText Typo="Typo.h6">@L["ServerGeneral_RegionalSettingsTitle"]</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Style="color: var(--app-text-muted);">
                @L["ServerGeneral_RegionalSettingsDescription"]
            </MudText>

            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_displayLanguage"
                               Label="@L["Profile_DisplayLanguage"]"
                               Variant="Variant.Outlined"
                               HelperText="@L["Profile_DisplayLanguageHelper"]"
                               Disabled="@_saving">
                        @foreach (var lang in Languages)
                        {
                            <MudSelectItem Value="@lang.Code">@lang.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_metadataLanguage"
                               Label="@L["Profile_MetadataLanguage"]"
                               Variant="Variant.Outlined"
                               HelperText="@L["Profile_MetadataLanguageHelper"]"
                               Disabled="@_saving">
                        @foreach (var lang in Languages)
                        {
                            <MudSelectItem Value="@lang.Code">@lang.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="string"
                               @bind-SelectedValues="_additionalLanguages"
                               Label="@L["Profile_AdditionalContentLanguages"]"
                               Variant="Variant.Outlined"
                               HelperText="@L["Profile_AdditionalContentLanguagesHelper"]"
                               MultiSelection="true"
                               Disabled="@_saving">
                        @foreach (var lang in Languages)
                        {
                            <MudSelectItem Value="@lang.Code">@lang.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_country"
                               Label="@L["ServerGeneral_CountryLabel"]"
                               Variant="Variant.Outlined"
                               HelperText="@L["ServerGeneral_CountryHelper"]"
                               Disabled="@_saving">
                        @foreach (var c in Countries)
                        {
                            <MudSelectItem Value="@c.Code">@c.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_dateFormat"
                               Label="@L["ServerGeneral_DateFormatLabel"]"
                               Variant="Variant.Outlined"
                               Disabled="@_saving">
                        <MudSelectItem Value="@("system")">@L["ServerGeneral_DateFormatSystem"] (@SystemDateExample)</MudSelectItem>
                        <MudSelectItem Value="@("short")">@L["ServerGeneral_DateFormatShort"] (e.g. @ShortDateExample)</MudSelectItem>
                        <MudSelectItem Value="@("long")">@L["ServerGeneral_DateFormatLong"] (e.g. @LongDateExample)</MudSelectItem>
                        <MudSelectItem Value="@("iso")">@L["ServerGeneral_DateFormatIso"] (@IsoDateExample)</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_timeFormat"
                               Label="@L["ServerGeneral_TimeFormatLabel"]"
                               Variant="Variant.Outlined"
                               Disabled="@_saving">
                        <MudSelectItem Value="@("system")">@L["ServerGeneral_TimeFormatSystem"] (@SystemTimeExample)</MudSelectItem>
                        <MudSelectItem Value="@("12h")">@L["ServerGeneral_TimeFormat12h"] (e.g. @TwelveHourExample)</MudSelectItem>
                        <MudSelectItem Value="@("24h")">@L["ServerGeneral_TimeFormat24h"] (e.g. @TwentyFourHourExample)</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudSwitch T="bool"
                       @bind-Value="_acceptAnyLanguage"
                       Label="@L["Profile_AcceptAnyLanguage"]"
                       Color="Color.Primary"
                       Disabled="@_saving" />
            <MudText Typo="Typo.caption" Style="color: var(--app-text-muted);">
                @L["Profile_AcceptAnyLanguageHint"]
            </MudText>

            @if (_languageChanged)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    @L["ServerGeneral_LanguageChangeNotice"]
                </MudAlert>
            }
        </MudStack>
    </div>
<MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   OnClick="@ResetAsync"
                   Disabled="@(_saving || _loading || !_isDirty)">
            @L["ServerGeneral_Reset"]
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Outlined.Save"
                   OnClick="@SaveAsync"
                   Disabled="@(_saving || _loading || !_isDirty)">
            @(_saving ? L["ServerGeneral_Saving"] : L["ServerGeneral_SaveChanges"])
        </MudButton>
    </MudStack>

</MudStack>

@code {

    private bool _loading = true;
    private bool _saving  = false;

    private string _serverName  = string.Empty;
    private string _displayLanguage = "en";
    private string _metadataLanguage = "en";
    private IReadOnlyCollection<string> _additionalLanguages = Array.Empty<string>();
    private bool _acceptAnyLanguage = true;
    private string _country     = "US";
    private string _dateFormat  = "system";
    private string _timeFormat  = "system";

    private string _originalDisplayLanguage = "en";
    private string _originalMetadataLanguage = "en";
    private IReadOnlyCollection<string> _originalAdditionalLanguages = Array.Empty<string>();
    private bool _originalAcceptAnyLanguage = true;

    private bool _languageChanged =>
        !string.Equals(_displayLanguage, _originalDisplayLanguage, StringComparison.OrdinalIgnoreCase);

    private bool _isDirty =>
        _serverName != _originalServerName ||
        !string.Equals(_displayLanguage, _originalDisplayLanguage, StringComparison.OrdinalIgnoreCase) ||
        !string.Equals(_metadataLanguage, _originalMetadataLanguage, StringComparison.OrdinalIgnoreCase) ||
        _acceptAnyLanguage != _originalAcceptAnyLanguage ||
        !SameLanguages(_additionalLanguages, _originalAdditionalLanguages) ||
        _country    != _originalCountry    ||
        _dateFormat != _originalDateFormat ||
        _timeFormat != _originalTimeFormat;

    private string _originalServerName = string.Empty;
    private string _originalCountry    = "US";
    private string _originalDateFormat = "system";
    private string _originalTimeFormat = "system";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var dto = await Orchestrator.GetServerGeneralAsync();
        if (dto is not null)
        {
            _serverName  = _originalServerName  = dto.ServerName;
            _displayLanguage = _originalDisplayLanguage =
                string.IsNullOrWhiteSpace(dto.DisplayLanguage) ? dto.Language : dto.DisplayLanguage;
            _metadataLanguage = _originalMetadataLanguage =
                string.IsNullOrWhiteSpace(dto.MetadataLanguage) ? dto.Language : dto.MetadataLanguage;
            _additionalLanguages = (dto.AdditionalLanguages ?? []).ToArray();
            _originalAdditionalLanguages = _additionalLanguages.ToArray();
            _acceptAnyLanguage = _originalAcceptAnyLanguage = dto.AcceptAnyLanguage;
            _country     = _originalCountry     = dto.Country;
            _dateFormat  = _originalDateFormat  = dto.DateFormat;
            _timeFormat  = _originalTimeFormat  = dto.TimeFormat;
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_serverName))
        {
            Snackbar.Add(L["ServerGeneral_ServerNameEmpty"], Severity.Warning);
            return;
        }

        _saving = true;
        var dto = new ServerGeneralSettingsDto(
            ServerName: _serverName.Trim(),
            Language:   _metadataLanguage,
            DisplayLanguage: _displayLanguage,
            MetadataLanguage: _metadataLanguage,
            AdditionalLanguages: _additionalLanguages.OrderBy(x => x, StringComparer.OrdinalIgnoreCase).ToList(),
            AcceptAnyLanguage: _acceptAnyLanguage,
            Country:    _country,
            DateFormat: _dateFormat,
            TimeFormat: _timeFormat);

        var ok = await Orchestrator.UpdateServerGeneralAsync(dto);

        if (ok)
        {
            Snackbar.Add(L["ServerGeneral_SavedSuccess"], Severity.Success);
            _originalServerName  = _serverName;
            _originalDisplayLanguage = _displayLanguage;
            _originalMetadataLanguage = _metadataLanguage;
            _originalAdditionalLanguages = _additionalLanguages.ToArray();
            _originalAcceptAnyLanguage = _acceptAnyLanguage;
            _originalCountry     = _country;
            _originalDateFormat  = _dateFormat;
            _originalTimeFormat  = _timeFormat;

            if (_languageChanged)
            {
                var redirectBack = Uri.EscapeDataString(Nav.Uri);
                Nav.NavigateTo($"/culture/set?culture={Uri.EscapeDataString(_displayLanguage)}&redirectUri={redirectBack}", forceLoad: true);
            }
        }
        else
        {
            Snackbar.Add(L["ServerGeneral_SaveError"], Severity.Error);
        }

        _saving = false;
    }

    private async Task ResetAsync()
    {
        await LoadAsync();
    }

    private static readonly DateTime _now = DateTime.Now;

    private string SystemDateExample  => _now.ToString("d");
    private string ShortDateExample   => _now.ToString("MM/dd/yyyy");
    private string LongDateExample    => _now.ToString("MMMM d, yyyy");
    private string IsoDateExample     => _now.ToString("yyyy-MM-dd");
    private string SystemTimeExample  => _now.ToString("t");
    private string TwelveHourExample  => _now.ToString("h:mm tt");
    private string TwentyFourHourExample => _now.ToString("HH:mm");

    private static bool SameLanguages(
        IEnumerable<string> left,
        IEnumerable<string> right)
    {
        return new HashSet<string>(left, StringComparer.OrdinalIgnoreCase)
            .SetEquals(right);
    }

    private static readonly (string Code, string Label)[] Languages =
    [
        ("ar", "Arabic"),
        ("zh", "Chinese (Simplified)"),
        ("zh-tw", "Chinese (Traditional)"),
        ("cs", "Czech"),
        ("da", "Danish"),
        ("nl", "Dutch"),
        ("en", "English"),
        ("fi", "Finnish"),
        ("fr", "French"),
        ("de", "German"),
        ("el", "Greek"),
        ("he", "Hebrew"),
        ("hi", "Hindi"),
        ("hu", "Hungarian"),
        ("id", "Indonesian"),
        ("it", "Italian"),
        ("ja", "Japanese"),
        ("ko", "Korean"),
        ("ms", "Malay"),
        ("no", "Norwegian"),
        ("pl", "Polish"),
        ("pt", "Portuguese"),
        ("pt-br", "Portuguese (Brazil)"),
        ("ro", "Romanian"),
        ("ru", "Russian"),
        ("es", "Spanish"),
        ("sv", "Swedish"),
        ("th", "Thai"),
        ("tr", "Turkish"),
        ("uk", "Ukrainian"),
        ("vi", "Vietnamese"),
    ];

    private static readonly (string Code, string Label)[] Countries =
    [
        ("AU", "Australia"),
        ("AT", "Austria"),
        ("BE", "Belgium"),
        ("BR", "Brazil"),
        ("CA", "Canada"),
        ("CL", "Chile"),
        ("CN", "China"),
        ("CZ", "Czech Republic"),
        ("DK", "Denmark"),
        ("EG", "Egypt"),
        ("FI", "Finland"),
        ("FR", "France"),
        ("DE", "Germany"),
        ("GR", "Greece"),
        ("HK", "Hong Kong"),
        ("HU", "Hungary"),
        ("IN", "India"),
        ("ID", "Indonesia"),
        ("IE", "Ireland"),
        ("IL", "Israel"),
        ("IT", "Italy"),
        ("JP", "Japan"),
        ("KR", "Korea"),
        ("MY", "Malaysia"),
        ("MX", "Mexico"),
        ("NL", "Netherlands"),
        ("NZ", "New Zealand"),
        ("NG", "Nigeria"),
        ("NO", "Norway"),
        ("PL", "Poland"),
        ("PT", "Portugal"),
        ("RO", "Romania"),
        ("RU", "Russia"),
        ("SA", "Saudi Arabia"),
        ("SG", "Singapore"),
        ("ZA", "South Africa"),
        ("ES", "Spain"),
        ("SE", "Sweden"),
        ("CH", "Switzerland"),
        ("TW", "Taiwan"),
        ("TH", "Thailand"),
        ("TR", "Turkey"),
        ("UA", "Ukraine"),
        ("GB", "United Kingdom"),
        ("US", "United States"),
        ("VN", "Vietnam"),
    ];
}
