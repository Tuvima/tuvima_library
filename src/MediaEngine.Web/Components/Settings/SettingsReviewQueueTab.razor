@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject MediaEditorLauncherService MediaEditorLauncher
@inject ISnackbar Snackbar
@using MediaEngine.Web.Services.Editing

<div class="tl-page settings-review-page">
    <AppActionBar Align="AppHorizontalAlignment.End" Class="mb-3">
        <AppButton Label="Refresh"
                   Size="AppControlSize.Compact"
                   StartIcon="@Icons.Material.Outlined.Refresh"
                   Disabled="@_loading"
                   OnClick="LoadAsync" />
    </AppActionBar>

    @if (_loading && _items.Count == 0)
    {
        <AppProgressBar Indeterminate="true" />
    }
    else if (!string.IsNullOrWhiteSpace(_error) && _items.Count == 0)
    {
        <AppAlert Tone="AppUiTone.Warning">@_error</AppAlert>
    }
    else if (_items.Count == 0)
    {
        <AppEmptyState Title="No pending review items"
                       Message="The ingestion safety queue is clear." />
    }
    else
    {
        <div class="settings-review-table-shell @(_loading ? "is-refreshing" : null)">
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <AppAlert Tone="AppUiTone.Warning" Class="settings-review-refresh-error">@_error</AppAlert>
        }
        @if (_loading)
        {
            <AppProgressBar Indeterminate="true" Class="settings-review-refresh-bar" />
        }
        <AppTable Class="settings-review-table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Reason</th>
                    <th>Evidence</th>
                    <th>Age</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _items)
                {
                    var target = ReviewTargetResolver.Resolve(item.MediaType, item.Trigger);
                    <tr @key="item.Id">
                        <td>
                            <div class="settings-review-item">
                                <div class="settings-review-cover">
                                    @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                                    {
                                        <img src="@item.CoverUrl" alt="" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.ImageNotSupported" />
                                    }
                                </div>
                                <div>
                                    <strong>@DisplayTitle(item)</strong>
                                    <span class="settings-muted">@FirstNonBlank(item.MediaType, item.EntityType, "Unknown")</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <AppChip Text="@FormatTrigger(item.Trigger)" Tone="AppUiTone.Warning" />
                        </td>
                        <td>
                            <div class="settings-review-evidence">
                                <span>@ConfidenceLabel(item.ConfidenceScore)</span>
                                <span class="settings-muted">@BridgeSummary(item)</span>
                            </div>
                        </td>
                        <td>@RelativeAge(item.CreatedAt)</td>
                        <td>
                            <AppActionBar Align="AppHorizontalAlignment.Start" Class="settings-review-actions">
                                <AppButton Label="@target.PrimaryActionLabel"
                                           Size="AppControlSize.Compact"
                                           ButtonStyle="AppButtonStyle.Filled"
                                           Tone="AppUiTone.Warning"
                                           Disabled="@_busyIds.Contains(item.Id)"
                                           OnClick="@(() => OpenReviewEditorAsync(item))" />
                                <AppButton Label="Dismiss"
                                           Size="AppControlSize.Compact"
                                           Tone="AppUiTone.Warning"
                                           Disabled="@_busyIds.Contains(item.Id)"
                                           OnClick="@(() => DismissAsync(item))" />
                                @if (IsWikidataReview(item.Trigger))
                                {
                                    <AppButton Label="Mark Provider-Only"
                                               Size="AppControlSize.Compact"
                                               Disabled="@_busyIds.Contains(item.Id)"
                                               OnClick="@(() => SkipUniverseAsync(item))" />
                                }
                            </AppActionBar>
                        </td>
                    </tr>
                }
            </tbody>
        </AppTable>
        </div>
    }
</div>

@code {
    private List<ReviewItemViewModel> _items = [];
    private readonly HashSet<Guid> _busyIds = [];
    private bool _loading = true;
    private string? _error;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _items = await Orchestrator.GetPendingReviewsAsync(200);
        }
        catch (Exception ex)
        {
            _error = $"Review queue could not load: {ex.Message}";
            if (_items.Count == 0)
                _items = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DismissAsync(ReviewItemViewModel item)
    {
        _busyIds.Add(item.Id);
        try
        {
            if (await Orchestrator.DismissReviewAsync(item.Id))
            {
                _items.Remove(item);
                Snackbar.Add("Review item dismissed.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Review item could not be dismissed.", Severity.Warning);
            }
        }
        finally
        {
            _busyIds.Remove(item.Id);
        }
    }

    private async Task OpenReviewEditorAsync(ReviewItemViewModel item)
    {
        _busyIds.Add(item.Id);
        try
        {
            var target = ReviewTargetResolver.Resolve(item.MediaType, item.Trigger);
            var title = DisplayTitle(item);
            var applied = await MediaEditorLauncher.OpenAsync(new MediaEditorLaunchRequest
            {
                EntityIds = [item.EntityId],
                LaunchEntityId = item.EntityId,
                LaunchEntityKind = FirstNonBlank(item.EntityType, "review"),
                Mode = SharedMediaEditorMode.Review,
                IdentityIntent = target.Intent,
                InitialTab = target.InitialTab,
                InitialCanonicalTargetGroup = target.CanonicalTargetGroup,
                ReviewItemId = item.Id,
                ReviewTrigger = item.Trigger,
                MediaType = item.MediaType,
                HeaderTitle = title,
                HeaderSubtitle = FormatTrigger(item.Trigger),
                CoverUrl = item.CoverUrl,
                PreviewItems =
                [
                    new MediaEditorPreviewItem
                    {
                        EntityId = item.EntityId,
                        Title = title,
                        CoverUrl = item.CoverUrl,
                        MediaType = item.MediaType,
                    },
                ],
            });

            if (applied)
            {
                await LoadAsync();
                Snackbar.Add("Review changes applied.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Review editor could not open: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busyIds.Remove(item.Id);
        }
    }

    private async Task SkipUniverseAsync(ReviewItemViewModel item)
    {
        _busyIds.Add(item.Id);
        try
        {
            if (await Orchestrator.SkipUniverseAsync(item.Id))
            {
                _items.Remove(item);
                Snackbar.Add("Universe matching skipped for this item.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Universe matching could not be skipped.", Severity.Warning);
            }
        }
        finally
        {
            _busyIds.Remove(item.Id);
        }
    }

    private static string DisplayTitle(ReviewItemViewModel item) =>
        FirstNonBlank(item.EntityTitle, item.Detail, item.EntityId.ToString());

    private static string FormatTrigger(string trigger) =>
        string.IsNullOrWhiteSpace(trigger)
            ? "Review"
            : string.Concat(trigger.Select((c, i) => i > 0 && char.IsUpper(c) ? $" {c}" : c.ToString()));

    private static string ConfidenceLabel(double? confidence) =>
        confidence.HasValue ? $"{confidence.Value:P0} confidence" : "No confidence score";

    private static string BridgeSummary(ReviewItemViewModel item)
    {
        if (item.BridgeIdentifiers.Count == 0)
        {
            return "No bridge IDs";
        }

        return string.Join(", ", item.BridgeIdentifiers.Take(3).Select(kv => $"{kv.Key}: {kv.Value}"));
    }

    private static bool IsWikidataReview(string? trigger) =>
        trigger is "WikidataBridgeFailed" or "MissingQid" or "MultipleQidMatches" or "QidNoMatch";

    private static string RelativeAge(DateTimeOffset createdAt)
    {
        var elapsed = DateTimeOffset.UtcNow - createdAt;
        return elapsed.TotalMinutes switch
        {
            < 1 => "just now",
            < 60 => $"{(int)elapsed.TotalMinutes}m",
            < 1440 => $"{(int)elapsed.TotalHours}h",
            _ => $"{(int)elapsed.TotalDays}d",
        };
    }

    private static string FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? string.Empty;
}
