@namespace MediaEngine.Web.Components.Settings
@inject IStringLocalizer<SharedStrings> L

<div class="tl-page">
    <AppCard Class="wikidata-config__card">
        <header class="wikidata-config__section-header">
            <MudIcon Icon="@Icons.Material.Outlined.VerifiedUser" Size="Size.Small" />
            <h3>@L["Wikidata_Stage2Title"]</h3>
            <AppChip Text="@L["Wikidata_Stage2Badge"]" />
        </header>
        <p class="wikidata-config__copy">@L["Wikidata_Stage2Description"]</p>

        <div class="wikidata-config__eyebrow">@L["Wikidata_PropertiesFetched"]</div>
        <div class="wikidata-config__chip-row">
            @foreach (var prop in _stage2Properties)
            {
                <AppChip Text="@prop" Icon="@Icons.Material.Filled.CheckCircle" />
            }
        </div>

        <div class="wikidata-config__eyebrow">@L["Wikidata_MatchingThresholds"]</div>
        <div class="wikidata-config__grid">
            <AppSlider @bind-Value="_autoAcceptThreshold"
                       Label="@L["Wikidata_AutoAcceptThresholdLabel"]"
                       HelpText="@L["Wikidata_AutoAcceptThresholdDescription"]"
                       Min="50"
                       Max="100"
                       ShowBounds="true" />
            <AppSlider @bind-Value="_reviewThreshold"
                       Label="@L["Wikidata_ReviewThresholdLabel"]"
                       HelpText="@L["Wikidata_ReviewThresholdDescription"]"
                       Min="30"
                       Max="90"
                       Tone="AppUiTone.Info"
                       ShowBounds="true" />
        </div>

        <div class="wikidata-config__divider"></div>
        <div class="wikidata-config__eyebrow">@L["Wikidata_PipelineOptions"]</div>
        <div class="wikidata-config__grid">
            <AppSwitchRow @bind-Value="_continueOnFailure"
                          Label="@L["Wikidata_ContinueOnFailureLabel"]" />
            <AppNumericField @bind-Value="_maxQidCandidates"
                             Label="@L["Wikidata_MaxQidCandidatesLabel"]"
                             Min="1"
                             Max="20"
                             HelpText="@L["Wikidata_MaxQidCandidatesHelper"]" />
            <AppNumericField @bind-Value="_wikipediaMaxChars"
                             Label="@L["Wikidata_WikipediaMaxCharsLabel"]"
                             Min="100"
                             Max="5000"
                             Step="100"
                             HelpText="@L["Wikidata_WikipediaMaxCharsHelper"]" />
        </div>
    </AppCard>

    <AppCard Class="wikidata-config__card">
        <header class="wikidata-config__section-header">
            <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Size="Size.Small" />
            <h3>@L["Wikidata_Stage3Title"]</h3>
            <AppChip Text="@L["Wikidata_Stage3Badge"]" />
            <AppSwitchRow @bind-Value="_stage3Enabled"
                          Label="@L["Wikidata_Stage3Enabled"]"
                          Class="wikidata-config__header-switch" />
        </header>
        <p class="wikidata-config__copy">@L["Wikidata_Stage3Description"]</p>

        <div class="wikidata-config__eyebrow">@L["Wikidata_DataGroups"]</div>
        <div class="wikidata-config__rows">
            <AppSwitchRow @bind-Value="_enrichPeople"
                          Label="@L["Wikidata_PeopleGroupTitle"]"
                          Description="@L["Wikidata_PeopleGroupDescription"]"
                          Icon="@Icons.Material.Outlined.Person"
                          Class="wikidata-config__row" />
            <AppSwitchRow @bind-Value="_enrichLore"
                          Label="@L["Wikidata_UniverseLoreGroupTitle"]"
                          Description="@L["Wikidata_UniverseLoreGroupDescription"]"
                          Icon="@Icons.Material.Outlined.Collections"
                          Class="wikidata-config__row" />
            <AppSwitchRow @bind-Value="_enrichCrossMedia"
                          Label="@L["Wikidata_CrossMediaGroupTitle"]"
                          Description="@L["Wikidata_CrossMediaGroupDescription"]"
                          Icon="@Icons.Material.Outlined.DeviceHub"
                          Class="wikidata-config__row" />
        </div>

        <div class="wikidata-config__divider"></div>
        <div class="wikidata-config__eyebrow">@L["Wikidata_SchedulingDepth"]</div>
        <div class="wikidata-config__grid">
            <AppNumericField @bind-Value="_backgroundIdleDelay"
                             Label="@L["Wikidata_BackgroundIdleDelayLabel"]"
                             Min="1"
                             Max="300"
                             HelpText="@L["Wikidata_BackgroundIdleDelayHelper"]" />
            <AppTextField @bind-Value="_nightlySweepCron"
                          Label="@L["Wikidata_NightlySweepCronLabel"]"
                          HelpText="@L["Wikidata_NightlySweepCronHelper"]"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Outlined.Schedule" />
            <AppSlider @bind-Value="_lineageDepth"
                       Label="@L["Wikidata_RelationshipDepthLabel"]"
                       HelpText="@L["Wikidata_RelationshipDepthDescription"]"
                       Min="1"
                       Max="3"
                       ShowBounds="true" />
            <AppSwitchRow @bind-Value="_loreDeltaOnExplorerOpen"
                          Label="@L["Wikidata_LoreDeltaLabel"]"
                          Description="@L["Wikidata_LoreDeltaDescription"]" />
            <AppSlider @bind-Value="_stage3BatchSize"
                       Label="@L["Wikidata_Stage3BatchSize"]"
                       HelpText="@L["Wikidata_Stage3BatchSizeHelper"]"
                       Min="5"
                       Max="100"
                       Step="5"
                       ShowBounds="true" />
            <AppSlider @bind-Value="_stage3RefreshDays"
                       Label="@L["Wikidata_Stage3RefreshDays"]"
                       HelpText="@L["Wikidata_Stage3RefreshDaysHelper"]"
                       Min="7"
                       Max="90"
                       ShowBounds="true" />
        </div>

        <div class="wikidata-config__divider"></div>
        <div class="wikidata-config__trigger">
            <div>
                <div class="wikidata-config__trigger-title">@L["Wikidata_Stage3TriggerNow"]</div>
                <div class="wikidata-config__trigger-copy">@L["Wikidata_Stage3TriggerHint"]</div>
            </div>
            <AppButton Tone="AppUiTone.Primary"
                       Size="AppControlSize.Compact"
                       StartIcon="@Icons.Material.Outlined.PlayArrow"
                       OnClick="@TriggerManualSweepAsync"
                       Disabled="@(_triggering || !_stage3Enabled)"
                       Label="@(_triggering ? L["Wikidata_Saving"] : L["Wikidata_Stage3TriggerNow"])" />
        </div>
    </AppCard>

    <AppActionBar>
        <AppButton ButtonStyle="AppButtonStyle.Text"
                   Size="AppControlSize.Compact"
                   StartIcon="@Icons.Material.Outlined.RestartAlt"
                   OnClick="@ResetToDefaults">
            @L["Wikidata_ResetToDefaults"]
        </AppButton>
        <AppButton Tone="AppUiTone.Primary"
                   ButtonStyle="AppButtonStyle.Filled"
                   Size="AppControlSize.Compact"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="@SaveAsync"
                   Disabled="@_saving"
                   Label="@(_saving ? L["Wikidata_Saving"] : L["Wikidata_SaveConfiguration"])" />
    </AppActionBar>
</div>

@code {
    private static readonly string[] _stage2Properties =
    [
        "Title",
        "Author / Director / Artist",
        "Year",
        "Genre",
        "Series",
        "Series Position",
        "Bridge IDs",
        "Wikipedia Description",
    ];

    private int  _autoAcceptThreshold = 95;
    private int  _reviewThreshold     = 70;
    private bool _continueOnFailure   = true;
    private int  _maxQidCandidates    = 5;
    private int  _wikipediaMaxChars   = 1000;

    private bool   _stage3Enabled           = true;
    private bool   _enrichPeople            = true;
    private bool   _enrichLore              = true;
    private bool   _enrichCrossMedia        = true;
    private int    _backgroundIdleDelay     = 10;
    private string _nightlySweepCron        = "0 2 * * *";
    private int    _lineageDepth            = 2;
    private bool   _loreDeltaOnExplorerOpen = true;
    private int    _stage3BatchSize         = 50;
    private int    _stage3RefreshDays       = 30;

    private bool _saving;
    private bool _triggering;

    private void ResetToDefaults()
    {
        _autoAcceptThreshold    = 95;
        _reviewThreshold        = 70;
        _continueOnFailure      = true;
        _maxQidCandidates       = 5;
        _wikipediaMaxChars      = 1000;

        _stage3Enabled           = true;
        _enrichPeople            = true;
        _enrichLore              = true;
        _enrichCrossMedia        = true;
        _backgroundIdleDelay     = 10;
        _nightlySweepCron        = "0 2 * * *";
        _lineageDepth            = 2;
        _loreDeltaOnExplorerOpen = true;
        _stage3BatchSize         = 50;
        _stage3RefreshDays       = 30;
    }

    private async Task TriggerManualSweepAsync()
    {
        _triggering = true;
        await Task.Delay(600);
        _triggering = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        await Task.Delay(400);
        _saving = false;
    }
}
