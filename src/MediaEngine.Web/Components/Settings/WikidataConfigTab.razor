@namespace MediaEngine.Web.Components.Settings
@inject IStringLocalizer<SharedStrings> L

@* Wikidata Configuration — Stage 2 (Identity & Core Data) and Stage 3 (Universe Data) settings.
   Wikidata is the sole identity authority: every media item is identified by its Q-identifier.
   Stage 2 runs during ingestion hydration. Stage 3 runs deferred in the background.
   All state is local; no Engine API calls are made yet. *@

<div class="st-page">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Public" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">@L["Wikidata_PageTitle"]</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        @L["Wikidata_PageDescription"]
    </MudText>

    @* ════════════════════════════════════════════════════════════════════
       Stage 2 — Identity & Core Data
       ════════════════════════════════════════════════════════════════════ *@

    <MudPaper Elevation="0" Class="pa-5 mb-4" Style="@SectionCardStyle">

        @* Section label *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
            <MudIcon Icon="@Icons.Material.Outlined.VerifiedUser"
                     Size="Size.Small" Color="Color.Default" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                @L["Wikidata_Stage2Title"]
            </MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Default"
                     Variant="Variant.Outlined"
                     Style="font-size: 0.65rem; height: 20px;">
                @L["Wikidata_Stage2Badge"]
            </MudChip>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            @L["Wikidata_Stage2Description"]
        </MudText>

        @* ── Properties pulled (read-only) ───────────────────────────── *@
        <MudText Typo="Typo.overline" Color="Color.Default" Class="mb-2"
                 Style="letter-spacing: 0.08em; display: block;">
            @L["Wikidata_PropertiesFetched"]
        </MudText>
        <MudStack Row="true" Spacing="1" Style="flex-wrap: wrap;" Class="mb-5">
            @foreach (var prop in _stage2Properties)
            {
                <MudChip T="string"
                         Size="Size.Small"
                         Color="Color.Default"
                         Variant="Variant.Outlined"
                         Icon="@Icons.Material.Filled.CheckCircle"
                         Style="font-size: 0.75rem;">
                    @prop
                </MudChip>
            }
        </MudStack>

        @* ── QID matching thresholds ──────────────────────────────────── *@
        <MudText Typo="Typo.overline" Color="Color.Default" Class="mb-3"
                 Style="letter-spacing: 0.08em; display: block;">
            @L["Wikidata_MatchingThresholds"]
        </MudText>

        <MudGrid Spacing="4" Class="mb-2">

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">
                    @L["Wikidata_AutoAcceptThresholdLabel"]
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2"
                         Style="display: block;">
                    @L["Wikidata_AutoAcceptThresholdDescription"]
                </MudText>
                <MudSlider T="int"
                           @bind-Value="_autoAcceptThreshold"
                           Min="50" Max="100" Step="1"
                           Color="Color.Primary"
                           Immediate="true">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption">50</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                            @_autoAcceptThreshold
                        </MudText>
                        <MudText Typo="Typo.caption">100</MudText>
                    </MudStack>
                </MudSlider>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">
                    @L["Wikidata_ReviewThresholdLabel"]
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2"
                         Style="display: block;">
                    @L["Wikidata_ReviewThresholdDescription"]
                </MudText>
                <MudSlider T="int"
                           @bind-Value="_reviewThreshold"
                           Min="30" Max="90" Step="1"
                           Color="Color.Secondary"
                           Immediate="true">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption">30</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                            @_reviewThreshold
                        </MudText>
                        <MudText Typo="Typo.caption">90</MudText>
                    </MudStack>
                </MudSlider>
            </MudItem>

        </MudGrid>

        <MudDivider Class="my-4" />

        @* ── Pipeline options ─────────────────────────────────────────── *@
        <MudText Typo="Typo.overline" Color="Color.Default" Class="mb-3"
                 Style="letter-spacing: 0.08em; display: block;">
            @L["Wikidata_PipelineOptions"]
        </MudText>

        <MudGrid Spacing="3">

            <MudItem xs="12" sm="6" Class="d-flex align-center">
                <MudSwitch T="bool"
                           @bind-Value="_continueOnFailure"
                           Color="Color.Primary"
                           Label="@L["Wikidata_ContinueOnFailureLabel"]" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="int"
                                 @bind-Value="_maxQidCandidates"
                                 Label="@L["Wikidata_MaxQidCandidatesLabel"]"
                                 Min="1" Max="20"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 FullWidth="true"
                                 HelperText="@L["Wikidata_MaxQidCandidatesHelper"]" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField T="int"
                                 @bind-Value="_wikipediaMaxChars"
                                 Label="@L["Wikidata_WikipediaMaxCharsLabel"]"
                                 Min="100" Max="5000" Step="100"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 FullWidth="true"
                                 HelperText="@L["Wikidata_WikipediaMaxCharsHelper"]" />
            </MudItem>

        </MudGrid>

    </MudPaper>

    @* ════════════════════════════════════════════════════════════════════
       Stage 3 — Universe Data
       ════════════════════════════════════════════════════════════════════ *@

    <MudPaper Elevation="0" Class="pa-5 mb-4" Style="@SectionCardStyle">

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
            <MudIcon Icon="@Icons.Material.Outlined.AccountTree"
                     Size="Size.Small" Color="Color.Default" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                @L["Wikidata_Stage3Title"]
            </MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Default"
                     Variant="Variant.Outlined"
                     Style="font-size: 0.65rem; height: 20px;">
                @L["Wikidata_Stage3Badge"]
            </MudChip>
            <div style="flex: 1;" />
            <MudSwitch T="bool"
                       @bind-Value="_stage3Enabled"
                       Color="Color.Primary"
                       Label="@L["Wikidata_Stage3Enabled"]" />
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            @L["Wikidata_Stage3Description"]
        </MudText>

        @* ── Data groups ──────────────────────────────────────────────── *@
        <MudText Typo="Typo.overline" Color="Color.Default" Class="mb-3"
                 Style="letter-spacing: 0.08em; display: block;">
            @L["Wikidata_DataGroups"]
        </MudText>

        <MudPaper Elevation="0" Class="pa-3 mb-2" Style="@ToggleRowStyle">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Outlined.Person"
                         Size="Size.Small" Color="Color.Default" />
                <div style="flex: 1;">
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@L["Wikidata_PeopleGroupTitle"]</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @L["Wikidata_PeopleGroupDescription"]
                    </MudText>
                </div>
                <MudSwitch T="bool"
                           @bind-Value="_enrichPeople"
                           Color="Color.Primary" />
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-3 mb-2" Style="@ToggleRowStyle">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Outlined.Hub"
                         Size="Size.Small" Color="Color.Default" />
                <div style="flex: 1;">
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@L["Wikidata_UniverseLoreGroupTitle"]</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @L["Wikidata_UniverseLoreGroupDescription"]
                    </MudText>
                </div>
                <MudSwitch T="bool"
                           @bind-Value="_enrichLore"
                           Color="Color.Primary" />
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-3 mb-4" Style="@ToggleRowStyle">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Outlined.DeviceHub"
                         Size="Size.Small" Color="Color.Default" />
                <div style="flex: 1;">
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@L["Wikidata_CrossMediaGroupTitle"]</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @L["Wikidata_CrossMediaGroupDescription"]
                    </MudText>
                </div>
                <MudSwitch T="bool"
                           @bind-Value="_enrichCrossMedia"
                           Color="Color.Primary" />
            </MudStack>
        </MudPaper>

        <MudDivider Class="my-4" />

        @* ── Scheduling & depth ───────────────────────────────────────── *@
        <MudText Typo="Typo.overline" Color="Color.Default" Class="mb-3"
                 Style="letter-spacing: 0.08em; display: block;">
            @L["Wikidata_SchedulingDepth"]
        </MudText>

        <MudGrid Spacing="3">

            <MudItem xs="12" sm="6">
                <MudNumericField T="int"
                                 @bind-Value="_backgroundIdleDelay"
                                 Label="@L["Wikidata_BackgroundIdleDelayLabel"]"
                                 Min="1" Max="300"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 FullWidth="true"
                                 HelperText="@L["Wikidata_BackgroundIdleDelayHelper"]" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_nightlySweepCron"
                              Label="@L["Wikidata_NightlySweepCronLabel"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              FullWidth="true"
                              HelperText="@L["Wikidata_NightlySweepCronHelper"]"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Outlined.Schedule" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">
                    @L["Wikidata_RelationshipDepthLabel"]
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2"
                         Style="display: block;">
                    @L["Wikidata_RelationshipDepthDescription"]
                </MudText>
                <MudSlider T="int"
                           @bind-Value="_lineageDepth"
                           Min="1" Max="3" Step="1"
                           Color="Color.Primary"
                           Immediate="true">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption">1</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                            @_lineageDepth
                        </MudText>
                        <MudText Typo="Typo.caption">3</MudText>
                    </MudStack>
                </MudSlider>
            </MudItem>

            <MudItem xs="12" sm="6" Class="d-flex align-center">
                <div>
                    <MudSwitch T="bool"
                               @bind-Value="_loreDeltaOnExplorerOpen"
                               Color="Color.Primary"
                               Label="@L["Wikidata_LoreDeltaLabel"]" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                             Style="display: block; margin-left: 52px; margin-top: -4px;">
                        @L["Wikidata_LoreDeltaDescription"]
                    </MudText>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">
                    @L["Wikidata_Stage3BatchSize"]
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2"
                         Style="display: block;">
                    @L["Wikidata_Stage3BatchSizeHelper"]
                </MudText>
                <MudSlider T="int"
                           @bind-Value="_stage3BatchSize"
                           Min="5" Max="100" Step="5"
                           Color="Color.Primary"
                           Immediate="true">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption">5</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                            @_stage3BatchSize
                        </MudText>
                        <MudText Typo="Typo.caption">100</MudText>
                    </MudStack>
                </MudSlider>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2" Class="mb-1">
                    @L["Wikidata_Stage3RefreshDays"]
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2"
                         Style="display: block;">
                    @L["Wikidata_Stage3RefreshDaysHelper"]
                </MudText>
                <MudSlider T="int"
                           @bind-Value="_stage3RefreshDays"
                           Min="7" Max="90" Step="1"
                           Color="Color.Primary"
                           Immediate="true">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption">7</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                            @_stage3RefreshDays
                        </MudText>
                        <MudText Typo="Typo.caption">90</MudText>
                    </MudStack>
                </MudSlider>
            </MudItem>

        </MudGrid>

        <MudDivider Class="my-4" />

        @* ── Manual trigger ────────────────────────────────────────────── *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <div style="flex: 1;">
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">
                    @L["Wikidata_Stage3TriggerNow"]
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary"
                         Style="display: block; margin-top: 2px;">
                    @L["Wikidata_Stage3TriggerHint"]
                </MudText>
            </div>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Outlined.PlayArrow"
                       OnClick="@TriggerManualSweepAsync"
                       Disabled="@(_triggering || !_stage3Enabled)"
                       Style="border-radius: 8px; min-width: 130px;">
                @if (_triggering)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                    @:@L["Wikidata_Saving"]
                }
                else
                {
                    @:@L["Wikidata_Stage3TriggerNow"]
                }
            </MudButton>
        </MudStack>

    </MudPaper>

    @* ── Save row ─────────────────────────────────────────────────────────── *@
    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Outlined.RestartAlt"
                   OnClick="@ResetToDefaults">
            @L["Wikidata_ResetToDefaults"]
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="@SaveAsync"
                   Disabled="@_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                @:@L["Wikidata_Saving"]
            }
            else
            {
                @:@L["Wikidata_SaveConfiguration"]
            }
        </MudButton>
    </MudStack>

</div>

@code {

    // ── Stage 2 — properties pulled (display only) ───────────────────────────────

    private static readonly string[] _stage2Properties =
    [
        "Title",
        "Author / Director / Artist",
        "Year",
        "Genre",
        "Series",
        "Series Position",
        "Bridge IDs",
        "Wikipedia Description",
    ];

    // ── State — Stage 2 ──────────────────────────────────────────────────────────

    private int  _autoAcceptThreshold = 95;
    private int  _reviewThreshold     = 70;
    private bool _continueOnFailure   = true;
    private int  _maxQidCandidates    = 5;
    private int  _wikipediaMaxChars   = 1000;

    // ── State — Stage 3 ──────────────────────────────────────────────────────────

    private bool   _stage3Enabled           = true;
    private bool   _enrichPeople            = true;
    private bool   _enrichLore              = true;
    private bool   _enrichCrossMedia        = true;
    private int    _backgroundIdleDelay     = 10;
    private string _nightlySweepCron        = "0 2 * * *";
    private int    _lineageDepth            = 2;
    private bool   _loreDeltaOnExplorerOpen = true;
    private int    _stage3BatchSize         = 50;
    private int    _stage3RefreshDays       = 30;

    // ── Shared ───────────────────────────────────────────────────────────────────

    private bool _saving;
    private bool _triggering;

    // ── Actions ──────────────────────────────────────────────────────────────────

    private void ResetToDefaults()
    {
        _autoAcceptThreshold    = 95;
        _reviewThreshold        = 70;
        _continueOnFailure      = true;
        _maxQidCandidates       = 5;
        _wikipediaMaxChars      = 1000;

        _stage3Enabled           = true;
        _enrichPeople            = true;
        _enrichLore              = true;
        _enrichCrossMedia        = true;
        _backgroundIdleDelay     = 10;
        _nightlySweepCron        = "0 2 * * *";
        _lineageDepth            = 2;
        _loreDeltaOnExplorerOpen = true;
        _stage3BatchSize         = 50;
        _stage3RefreshDays       = 30;
    }

    private async Task TriggerManualSweepAsync()
    {
        _triggering = true;
        // No Engine API wired yet — simulate a brief acknowledgement delay.
        await Task.Delay(600);
        _triggering = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        // No Engine API yet — simulate a brief save operation.
        await Task.Delay(400);
        _saving = false;
    }

    // ── Styles ───────────────────────────────────────────────────────────────────

    private const string SectionCardStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 8px;";

    private const string ToggleRowStyle =
        "background: var(--app-glass-bg); " +
        "border: 1px solid var(--app-glass-border); " +
        "border-radius: 8px;";
}
