@namespace MediaEngine.Web.Components.Settings
@inject IStringLocalizer<SharedStrings> L

<div class="tl-page status-dashboard">
    <div class="status-dashboard__metrics">
        <AppMetricCard Label="@L["Status_ServerUptime"]"
                       Value="12d 4h 32m"
                       Icon="@Icons.Material.Outlined.RadioButtonChecked"
                       Tone="AppStatusTone.Success" />
        <AppMetricCard Label="@L["Status_TotalAssets"]"
                       Value="2,412"
                       Icon="@Icons.Material.Outlined.Storage"
                       Tone="AppStatusTone.Primary" />
        <AppMetricCard Label="@L["Status_Database"]"
                       Value="245 MB"
                       Icon="@Icons.Material.Outlined.SdStorage"
                       Tone="AppStatusTone.Warning" />
        <AppCard Class="status-dashboard__cache-card">
            <div class="status-dashboard__cache-copy">
                <MudIcon Icon="@Icons.Material.Outlined.Layers" />
                <div>
                    <span>@L["Status_GlobalCache"]</span>
                    <strong>1.2 TB</strong>
                </div>
            </div>
            <AppProgressBar Value="62" ShowValue="true" Class="status-dashboard__cache-progress" />
            <span class="status-dashboard__cache-caption">@L["Status_CacheUsed"]</span>
        </AppCard>
    </div>

    <AppCard Title="@L["Status_EngineInformation"]">
        <div class="status-dashboard__info-grid">
            <div class="status-dashboard__info-item">
                <span>@L["Status_ServerName"]</span>
                <strong>Tuvima Library</strong>
            </div>
            <div class="status-dashboard__info-item">
                <span>@L["Status_EngineUrl"]</span>
                <code class="tl-code">http://localhost:61495</code>
            </div>
            <div class="status-dashboard__info-item">
                <span>@L["Status_Version"]</span>
                <strong>0.1.0-dev</strong>
            </div>
            <div class="status-dashboard__info-item">
                <span>@L["Status_AiModels"]</span>
                <div class="status-dashboard__chips">
                    <AppChip Text="text_quality - Active" Tone="AppUiTone.Success" />
                    <AppChip Text="text_fast - Loaded" Tone="AppUiTone.Info" />
                    <AppChip Text="audio - Not Downloaded" Tone="AppUiTone.Neutral" />
                </div>
            </div>
        </div>
    </AppCard>
</div>
