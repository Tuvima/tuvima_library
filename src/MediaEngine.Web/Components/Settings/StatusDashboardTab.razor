@namespace MediaEngine.Web.Components.Settings
@inject IStringLocalizer<SharedStrings> L

@* Status Dashboard — server health overview with stat cards and engine info. *@

<div class="st-page">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.SpaceDashboard" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">@L["Status_StatusDashboard"]</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        @L["Status_StatusDashboardDescription"]
    </MudText>

    @* ── Stat Cards ───────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-6">

        @* Card 1 — Uptime *@
        <MudItem xs="12" sm="6" md="3">
            <div class="app-stat-card">
                <MudStack Spacing="1">
                    <MudIcon Icon="@Icons.Material.Outlined.RadioButtonChecked"
                             Style="color: #10b981; font-size: 2rem;" />
                    <MudText Typo="Typo.h5" Style="font-weight: 700; margin-top: 12px;">
                        12d 4h 32m
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Status_ServerUptime"]</MudText>
                </MudStack>
            </div>
        </MudItem>

        @* Card 2 — Indexed Assets *@
        <MudItem xs="12" sm="6" md="3">
            <div class="app-stat-card">
                <MudStack Spacing="1">
                    <MudIcon Icon="@Icons.Material.Outlined.Storage"
                             Style="color: #6366f1; font-size: 2rem;" />
                    <MudText Typo="Typo.h5" Style="font-weight: 700; margin-top: 12px;">
                        2,412
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Status_TotalAssets"]</MudText>
                </MudStack>
            </div>
        </MudItem>

        @* Card 3 — Database Size *@
        <MudItem xs="12" sm="6" md="3">
            <div class="app-stat-card">
                <MudStack Spacing="1">
                    <MudIcon Icon="@Icons.Material.Outlined.SdStorage"
                             Style="color: #f59e0b; font-size: 2rem;" />
                    <MudText Typo="Typo.h5" Style="font-weight: 700; margin-top: 12px;">
                        245 MB
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Status_Database"]</MudText>
                </MudStack>
            </div>
        </MudItem>

        @* Card 4 — Cache *@
        <MudItem xs="12" sm="6" md="3">
            <div class="app-stat-card">
                <MudStack Spacing="1">
                    <MudIcon Icon="@Icons.Material.Outlined.Layers"
                             Style="color: #3b82f6; font-size: 2rem;" />
                    <MudText Typo="Typo.h5" Style="font-weight: 700; margin-top: 12px;">
                        1.2 TB
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        @L["Status_GlobalCache"]
                    </MudText>
                    <MudProgressLinear Value="62"
                                       Color="Color.Info"
                         Rounded="false"
                                       Size="Size.Small"
                                       Style="opacity: 0.8;" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Status_CacheUsed"]</MudText>
                </MudStack>
            </div>
        </MudItem>

    </MudGrid>

    @* ── Engine Info ──────────────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Style="@InnerCardStyle">

        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Outlined.Info" Color="Color.Default" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@L["Status_EngineInformation"]</MudText>
        </MudStack>

        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.08em;">
                        @L["Status_ServerName"]
                    </MudText>
                    <MudText Typo="Typo.body1">Tuvima Library</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.08em;">
                        @L["Status_EngineUrl"]
                    </MudText>
                    <code style="font-family: monospace; font-size: 0.875rem;
                                  background: rgba(0,0,0,0.25); padding: 2px 8px;
                                  border-radius: 4px;">
                        http://localhost:61495
                    </code>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.08em;">
                        @L["Status_Version"]
                    </MudText>
                    <MudText Typo="Typo.body1">0.1.0-dev</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.08em;">
                        @L["Status_AiModels"]
                    </MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="flex-wrap: wrap;">
                        <MudChip T="string" Size="Size.Small" Color="Color.Success"
                                 Style="font-size: 0.75rem;">
                            text_quality · Active
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info"
                                 Style="font-size: 0.75rem;">
                            text_fast · Loaded
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                 Style="font-size: 0.75rem; opacity: 0.6;">
                            audio · Not Downloaded
                        </MudChip>
                    </MudStack>
                </MudStack>
            </MudItem>
        </MudGrid>

    </MudPaper>

</div>

@code {

    private const string InnerCardStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 8px; " +
        "padding: 24px;";
}
