@namespace MediaEngine.Web.Components.Settings
@using System.Globalization
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration

<MudPaper Elevation="0" Class="tl-card ingestion-live library-update">
    <header class="library-update__header">
        <div class="library-update__heading">
            <MudText Typo="Typo.h4" Class="library-update__title">Library Update</MudText>
            <MudText Typo="Typo.body2" Class="library-update__subtitle">
                Track what Tuvima is adding, matching, and waiting for review.
            </MudText>
            <MudText Typo="Typo.caption" Class="library-update__timestamp">@Model.TimestampLine</MudText>
        </div>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="library-update__actions">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Outlined.Refresh"
                       Disabled="@Loading"
                       OnClick="OnRefresh"
                       aria-label="Refresh library update status">
                Refresh
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Outlined.PlayArrow"
                       Disabled="@(Loading || ScanStarting)"
                       OnClick="OnScanNow">
                Scan Now
            </MudButton>
        </MudStack>
    </header>

    @if (Loading && Snapshot is null)
    {
        <MudGrid Class="library-update__skeleton">
            @for (var i = 0; i < 4; i++)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudSkeleton Height="94px" Animation="Animation.Wave" />
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <section class="library-update__metrics" aria-label="Library update summary">
            <div class="library-update-metric is-purple">
                <span class="library-update-metric__icon"><MudIcon Icon="@Icons.Material.Outlined.Description" /></span>
                <div>
                    <span>Files Found</span>
                    <strong>@FormatCount(Model.TotalFiles)</strong>
                </div>
            </div>
            <div class="library-update-metric is-blue">
                <span class="library-update-metric__icon"><MudIcon Icon="@Icons.Material.Outlined.CheckCircle" /></span>
                <div>
                    <span>Processed</span>
                    <strong>@FormatCount(Model.ProcessedFiles)</strong>
                </div>
            </div>
            <div class="library-update-metric is-green">
                <span class="library-update-metric__icon"><MudIcon Icon="@Icons.Material.Outlined.Link" /></span>
                <div>
                    <span>Matched</span>
                    <strong>@FormatCount(Model.MatchedItems)</strong>
                </div>
            </div>
            <div class="library-update-metric is-amber">
                <span class="library-update-metric__icon"><MudIcon Icon="@Icons.Material.Outlined.WarningAmber" /></span>
                <div>
                    <span>Need Review</span>
                    <strong>@FormatCount(Model.ReviewItems)</strong>
                </div>
            </div>
        </section>

        <section class="@MainStatusClass" aria-live="polite">
            <div class="library-update-status__top">
                <div>
                    <MudText Typo="Typo.h5" Class="library-update-status__title">@Model.Heading</MudText>
                    <p class="library-update-status__line">@Model.MainLine</p>
                </div>
                <span class="@StatusPillClass">
                    <span></span>
                    @Model.StatusLabel
                </span>
            </div>

            @if (Model.ShowProgress)
            {
                <div class="@ProgressClass" style="@ProgressStyle">
                    <div class="library-update-progress__track">
                        <span></span>
                    </div>
                    @if (!Model.IsIndeterminate)
                    {
                        <strong>@ProgressLabel</strong>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ActivityLine))
            {
                <p class="library-update-status__activity">@Model.ActivityLine</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SecondaryLine))
            {
                <p class="library-update-status__secondary">@Model.SecondaryLine</p>
            }

            @if (Model.PageState == LibraryUpdatePageState.Failed)
            {
                <div class="library-update-status__failure-actions">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.Replay"
                               OnClick="OnScanNow">
                        Try Again
                    </MudButton>
                    <MudButton Href="/settings/activity"
                               Variant="Variant.Outlined"
                               Color="Color.Default"
                               EndIcon="@Icons.Material.Outlined.ChevronRight">
                        View Activity
                    </MudButton>
                </div>
            }
        </section>

        <section class="@InfoGridClass">
            <div class="library-update-panel library-update-now">
                <span class="library-update-panel__icon is-purple"><MudIcon Icon="@PanelIcon" /></span>
                <div class="library-update-panel__body">
                    <MudText Typo="Typo.h6">@Model.PanelTitle</MudText>
                    <p>@Model.PanelText</p>

                    @if (Model.PageState == LibraryUpdatePageState.Running)
                    {
                        <div class="library-update-facts">
                            @if (!string.IsNullOrWhiteSpace(Model.CurrentItemTitle))
                            {
                                <div>
                                    <span>Current item</span>
                                    <strong>@Model.CurrentItemTitle</strong>
                                </div>
                            }
                            <div>
                                <span>Current step</span>
                                <strong>@Model.CurrentStep</strong>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.CurrentProvider))
                            {
                                <div>
                                    <span>Current source</span>
                                    <strong>@Model.CurrentProvider</strong>
                                </div>
                            }
                        </div>
                    }
                    else if (Model.HasPriorRun)
                    {
                        <div class="library-update-facts is-summary">
                            <div>
                                <span>Added or updated</span>
                                <strong>@FormatCount(Model.AddedOrUpdatedCount)</strong>
                            </div>
                            <div>
                                <span>Matched</span>
                                <strong>@FormatCount(Model.MatchedItems)</strong>
                            </div>
                            <div>
                                <span>Need review</span>
                                <strong>@FormatCount(Model.ReviewItems)</strong>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @if (Model.ReviewItems > 0)
            {
                <div class="library-update-panel library-update-attention">
                    <span class="library-update-panel__icon is-amber"><MudIcon Icon="@Icons.Material.Outlined.WarningAmber" /></span>
                    <div class="library-update-panel__body">
                        <MudText Typo="Typo.h6">Needs attention</MudText>
                        <p>@FormatCount(Model.ReviewItems) items need review before they can be fully added.</p>
                        <ul class="library-update-attention__reasons">
                            @foreach (var reason in Model.AttentionReasons)
                            {
                                <li><span></span>@FormatCount(reason.Count) @reason.Label</li>
                            }
                        </ul>
                    </div>
                    <MudButton Href="/settings/review"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               EndIcon="@Icons.Material.Outlined.ChevronRight"
                               Class="library-update-attention__button">
                        Review Items
                    </MudButton>
                </div>
            }
            else if (Model.HasPriorRun || Model.PageState == LibraryUpdatePageState.Running)
            {
                <div class="library-update-panel library-update-clear">
                    <span class="library-update-panel__icon is-green"><MudIcon Icon="@Icons.Material.Outlined.TaskAlt" /></span>
                    <div class="library-update-panel__body">
                        <MudText Typo="Typo.h6">No items need review</MudText>
                        <p>Tuvima has not found anything that needs a curator decision.</p>
                    </div>
                </div>
            }
        </section>

        <section class="library-update-steps" aria-label="Update steps">
            <MudText Typo="Typo.subtitle1">Update steps</MudText>
            <div class="library-update-stepper">
                @foreach (var step in Model.Steps)
                {
                    <div class="@StepClass(step)">
                        <span class="library-update-step__node">
                            <MudIcon Icon="@StepIcon(step)" />
                        </span>
                        <div>
                            <strong>@step.Label</strong>
                            <span>@step.StatusLabel</span>
                        </div>
                    </div>
                }
            </div>
        </section>

        @if (Model.HasPriorRun || Model.RecentItems.Count > 0 || Model.PageState == LibraryUpdatePageState.Running)
        {
            <section class="library-update-recent" aria-label="Recently added">
                <MudText Typo="Typo.subtitle1">Recently added</MudText>
                @if (Model.RecentItems.Count == 0)
                {
                    <div class="library-update-recent__empty">No new items were added in the last scan.</div>
                }
                else
                {
                    <div class="library-update-recent__list">
                        @foreach (var item in Model.RecentItems)
                        {
                            @if (!string.IsNullOrWhiteSpace(item.Href))
                            {
                                <a class="library-update-recent__row" href="@item.Href">
                                    @RecentItemContent(item)
                                </a>
                            }
                            else
                            {
                                <div class="library-update-recent__row">
                                    @RecentItemContent(item)
                                </div>
                            }
                        }
                    </div>
                }
            </section>
        }
    }
</MudPaper>

@code {
    [Parameter] public LibraryUpdateStatusViewModel? Status { get; set; }
    [Parameter] public IngestionOperationsSnapshotViewModel? Snapshot { get; set; }
    [Parameter] public IngestionDashboardMetrics Metrics { get; set; } = new(0, 0, 0, 0);
    [Parameter] public IngestionOverallProgress OverallProgress { get; set; } = new(0, 0, 0, "Ingestion_StageScanning", "Ingestion_StageScanningDetail", 0, 0, 0, null);
    [Parameter] public IReadOnlyList<IngestionDashboardStage> Stages { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionOperationsJobViewModel> Jobs { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionCurrentActivityViewModel> CurrentActivities { get; set; } = [];
    [Parameter] public IReadOnlyList<ActivityEntryViewModel> Activities { get; set; } = [];
    [Parameter] public IReadOnlyList<ReviewItemViewModel> PendingReviews { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionReviewReasonViewModel> ReviewReasons { get; set; } = [];
    [Parameter] public IngestionLiveMode LiveMode { get; set; }
    [Parameter] public EngineConnectionState ConnectionState { get; set; }
    [Parameter] public DateTimeOffset? LastUpdated { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool ScanStarting { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback OnScanNow { get; set; }

    private LibraryUpdateStatusViewModel Model => Status
        ?? IngestionLiveDashboardState.BuildLibraryUpdateStatus(
            Snapshot,
            Jobs,
            CurrentActivities,
            Activities,
            PendingReviews,
            Metrics,
            Error,
            LastUpdated,
            DateTimeOffset.UtcNow);

    private string MainStatusClass => $"library-update-status is-{Model.PageState.ToString().ToLowerInvariant()}";
    private string StatusPillClass => $"library-update-pill is-{Model.StatusTone}";
    private string InfoGridClass => $"library-update-info {(Model.ReviewItems > 0 ? "has-attention" : "is-clear")}";
    private string ProgressClass => $"library-update-progress {(Model.IsIndeterminate ? "is-indeterminate" : string.Empty)}";
    private string ProgressStyle => $"--library-update-progress: {Math.Clamp(Model.ProgressPercent, 0, 100).ToString("0.##", CultureInfo.InvariantCulture)}%;";
    private string ProgressLabel => $"{Math.Clamp(Model.ProgressPercent, 0, 100).ToString("0", CultureInfo.CurrentCulture)}%";
    private string PanelIcon => Model.PageState == LibraryUpdatePageState.Running
        ? Icons.Material.Outlined.GraphicEq
        : Icons.Material.Outlined.AutoAwesome;

    private static string StepClass(LibraryUpdateStepViewModel step) =>
        $"library-update-step is-{step.Status.ToString().ToLowerInvariant()}";

    private static string StepIcon(LibraryUpdateStepViewModel step) =>
        step.Status switch
        {
            LibraryUpdateStepStatus.Complete => Icons.Material.Outlined.Check,
            LibraryUpdateStepStatus.InProgress => Icons.Material.Outlined.Cached,
            LibraryUpdateStepStatus.NeedsReview => Icons.Material.Outlined.WarningAmber,
            _ => step.Icon,
        };

    private static RenderFragment RecentItemContent(LibraryUpdateRecentItemViewModel item) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "library-update-recent__thumb");
        if (!string.IsNullOrWhiteSpace(item.ThumbnailUrl))
        {
            builder.OpenElement(sequence++, "img");
            builder.AddAttribute(sequence++, "src", item.ThumbnailUrl);
            builder.AddAttribute(sequence++, "alt", "");
            builder.CloseElement();
        }
        else
        {
            builder.OpenComponent<MudIcon>(sequence++);
            builder.AddAttribute(sequence++, "Icon", Icons.Material.Outlined.LibraryBooks);
            builder.CloseComponent();
        }
        builder.CloseElement();

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "library-update-recent__copy");
        builder.OpenElement(sequence++, "strong");
        builder.AddContent(sequence++, item.Title);
        builder.CloseElement();
        builder.OpenElement(sequence++, "span");
        builder.AddContent(sequence++, item.StatusText);
        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", $"library-update-recent__pill is-{item.StatusTone}");
        builder.AddContent(sequence++, item.StatusLabel);
        builder.CloseElement();

        builder.OpenElement(sequence++, "time");
        builder.AddContent(sequence++, item.RelativeTime);
        builder.CloseElement();

        builder.OpenComponent<MudIcon>(sequence++);
        builder.AddAttribute(sequence++, "Icon", Icons.Material.Outlined.ChevronRight);
        builder.CloseComponent();
    };

    private static string FormatCount(int value) => value.ToString("N0", CultureInfo.CurrentCulture);
}
