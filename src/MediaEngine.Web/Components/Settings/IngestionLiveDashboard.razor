@namespace MediaEngine.Web.Components.Settings
@using System.Globalization
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration

<div class="ingestion-live library-update">
    @if (Loading && Snapshot is null)
    {
        <div class="library-update__skeleton">
            @for (var i = 0; i < 4; i++)
            {
                <AppSkeleton Class="library-update__skeleton-card" />
            }
        </div>
    }
    else
    {
        <section class="@MainStatusClass" aria-live="polite">
            @if (DisplayStageRows.Count > 0)
            {
                <div class="library-update-overall-progress" aria-label="Overall ingestion progress">
                    <div class="library-update-overall-progress__top">
                        <div>
                            <strong>Overall progress</strong>
                            <span>@FormatCount(OverallProgress.ProcessedFiles) of @FormatCount(OverallProgress.TotalFiles) files</span>
                        </div>
                        <em>@FormatPercent(OverallProgress.Percent)</em>
                        <AppActionBar Align="AppHorizontalAlignment.End" Class="library-update__actions">
                            <MudTooltip Text="Reload the latest ingestion status." Placement="Placement.Bottom">
                                <AppButton Label="Refresh"
                                           StartIcon="@Icons.Material.Outlined.Refresh"
                                           Disabled="@Loading"
                                           title="Reload the latest ingestion status."
                                           OnClick="OnRefresh" />
                            </MudTooltip>
                            <MudTooltip Text="Start a new scan of the watched folders." Placement="Placement.Bottom">
                                <AppButton Label="Scan Now"
                                           ButtonStyle="AppButtonStyle.Filled"
                                           Tone="AppUiTone.Primary"
                                           StartIcon="@Icons.Material.Outlined.PlayArrow"
                                           Disabled="@(Loading || ScanStarting)"
                                           title="Start a new scan of the watched folders."
                                           OnClick="OnScanNow" />
                            </MudTooltip>
                        </AppActionBar>
                    </div>
                    <AppProgressBar Value="@OverallProgress.Percent"
                                    ShowValue="false"
                                    Indeterminate="@(Model.IsIndeterminate && OverallProgress.TotalFiles <= 0)"
                                    Class="library-update-progress" />
                </div>

                <div class="library-update-stage-cards" aria-label="Ingestion stages">
                    @foreach (var stage in DisplayStageRows)
                    {
                        <AppNativeButton @key="StageRenderKey(stage)"
                                         Type="button"
                                         Class="@StageCardClass(stage)"
                                         AriaLabel="@StageSelectionLabel(stage)"
                                         OnClick="@(() => SelectStage(stage))">
                            <span class="library-update-stage-card__progress" aria-hidden="true" title="@StageProgressTooltip(stage)">
                                <MudTooltip Text="@StageProgressTooltip(stage)" Placement="Placement.Top">
                                    @if (IsStageComplete(stage))
                                    {
                                        <span class="library-update-stage-card__check">
                                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" />
                                        </span>
                                    }
                                    else
                                    {
                                        <svg viewBox="0 0 36 36" focusable="false">
                                            <circle class="library-update-stage-card__progress-track" cx="18" cy="18" r="15.5" pathLength="100" />
                                            <circle class="library-update-stage-card__progress-value" cx="18" cy="18" r="15.5" pathLength="100" stroke-dasharray="100" stroke-dashoffset="@StageRingOffset(stage)" />
                                        </svg>
                                    }
                                </MudTooltip>
                            </span>
                            <span class="library-update-stage-card__icon" title="@StageIconTooltip(stage)">
                                <MudTooltip Text="@StageIconTooltip(stage)" Placement="Placement.Top">
                                    @if (IsWikidataStage(stage))
                                    {
                                        <img src="/assets/providers/wikidata.svg" alt="" aria-hidden="true" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@stage.Icon" />
                                    }
                                </MudTooltip>
                            </span>
                            <strong>@DisplayStageLabel(stage)</strong>
                            <span>@StageCardSummary(stage)</span>
                        </AppNativeButton>
                    }
                </div>

                @if (SelectedStage is not null)
                {
                    <section class="library-update-stage-detail-panel" aria-label="@($"{DisplayStageLabel(SelectedStage)} details")">
                        <div class="library-update-stage-detail-panel__items">
                            @foreach (var detail in StageDetailLines(SelectedStage))
                            {
                                <div @key="StageDetailKey(detail)" class="@StageDetailClass(detail)">
                                    <span class="library-update-stage-detail__icon" aria-hidden="true" title="@StageDetailTooltip(detail)">
                                        <MudTooltip Text="@StageDetailTooltip(detail)" Placement="Placement.Top">
                                            <MudIcon Icon="@detail.Icon" />
                                        </MudTooltip>
                                    </span>
                                    <strong>@detail.Value</strong>
                                    <span>@detail.Label</span>
                                </div>
                            }
                        </div>
                    </section>
                }
            }
            else if (!Model.ShowProgress && Model.EnrichmentTotal <= 0)
            {
                <p class="library-update-status__line">@MainLineContent()</p>
            }

            @if (Model.PageState == LibraryUpdatePageState.Failed)
            {
                <div class="library-update-status__failure-actions">
                    <MudTooltip Text="Start the scan again after a failed update." Placement="Placement.Bottom">
                        <AppButton Label="Try Again"
                                   ButtonStyle="AppButtonStyle.Filled"
                                   Tone="AppUiTone.Primary"
                                   StartIcon="@Icons.Material.Outlined.Replay"
                                   title="Start the scan again after a failed update."
                                   OnClick="OnScanNow" />
                    </MudTooltip>
                    <MudTooltip Text="Open the activity log for ingestion work." Placement="Placement.Bottom">
                        <AppButton Label="View Activity"
                                   Href="/settings/activity"
                                   title="Open the activity log for ingestion work."
                                   EndIcon="@Icons.Material.Outlined.ChevronRight" />
                    </MudTooltip>
                </div>
            }
        </section>

        <section class="library-update-batches">
            <div class="library-update-batches__header">
                <span class="library-update-batches__icon" title="Recent batches show the latest scans and whether they are active or complete.">
                    <MudTooltip Text="Recent batches show the latest scans and whether they are active or complete." Placement="Placement.Top">
                        <MudIcon Icon="@Icons.Material.Outlined.History" />
                    </MudTooltip>
                </span>
                <div>
                    <h3>Recent batches</h3>
                    <p>Select a batch to load its stage details above.</p>
                </div>
            </div>

            @if (OrderedRecentBatches.Count > 0)
            {
                <div class="library-update-batch-list" role="list" aria-label="Recent ingestion batches">
                    @foreach (var batch in OrderedRecentBatches)
                    {
                        <div @key="BatchRenderKey(batch)"
                             class="@BatchCardClass(batch)"
                             role="listitem">
                            <AppNativeButton Type="button"
                                             Class="library-update-batch__select"
                                             AriaLabel="@($"Load details for {BatchTitle(batch)}")"
                                             OnClick="@(() => SelectBatch(batch))">
                                <span class="library-update-batch__favorite" title="@BatchSelectionTooltip(batch)">
                                    <MudTooltip Text="@BatchSelectionTooltip(batch)" Placement="Placement.Top">
                                        <MudIcon Icon="@(IsSelectedBatch(batch) ? Icons.Material.Filled.Star : Icons.Material.Outlined.ChevronRight)" />
                                    </MudTooltip>
                                </span>
                                <span class="library-update-batch__name">
                                    <strong>@BatchTitle(batch)</strong>
                                    <span>@BatchTiming(batch)</span>
                                </span>
                                <span class="library-update-batch__media" aria-label="Media types in batch">
                                    @foreach (var chip in BatchMediaChips(batch))
                                    {
                                        var mediaTooltip = BatchMediaTooltip(chip);
                                        <span class="@BatchMediaIconClass(chip)" title="@mediaTooltip" aria-label="@mediaTooltip">
                                            <MudTooltip Text="@mediaTooltip" Placement="Placement.Top">
                                                <MudIcon Icon="@chip.Icon" />
                                            </MudTooltip>
                                        </span>
                                    }
                                </span>
                                <span class="library-update-batch__stats">
                                    @foreach (var chip in BatchArtifactChips(batch))
                                    {
                                        var artifactTooltip = BatchArtifactTooltip(chip);
                                        <span class="@BatchChipClass(chip)" title="@artifactTooltip" aria-label="@artifactTooltip">
                                            <MudTooltip Text="@artifactTooltip" Placement="Placement.Top">
                                                <MudIcon Icon="@chip.Icon" />
                                            </MudTooltip>
                                            <strong>@FormatCount(chip.Count)</strong>
                                            <span>@chip.Label</span>
                                        </span>
                                    }
                                </span>
                            </AppNativeButton>
                            <a class="library-update-batch__activity"
                               href="@BatchActivityHref(batch)"
                               title="@BatchActivityTooltip(batch)"
                               aria-label="@BatchActivityTooltip(batch)">
                                <MudTooltip Text="@BatchActivityTooltip(batch)" Placement="Placement.Top">
                                    <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" />
                                </MudTooltip>
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="library-update-batches__empty">Run a scan to see batch history here.</p>
            }
        </section>

        @if (EffectiveProviderActivity.Count > 0)
        {
            <section class="library-update-batches">
                <div class="library-update-batches__header">
                    <span class="library-update-batches__icon" title="Provider activity shows live requests, throttling, and recent errors.">
                        <MudTooltip Text="Provider activity shows live requests, throttling, and recent errors." Placement="Placement.Top">
                            <MudIcon Icon="@Icons.Material.Outlined.Traffic" />
                        </MudTooltip>
                    </span>
                    <div>
                        <h3>Provider activity</h3>
                        <p>External lookups are rate-limited per service while ingestion continues in parallel.</p>
                    </div>
                </div>

                <div class="library-update-batch-list" role="list" aria-label="Provider request activity">
                    @foreach (var provider in EffectiveProviderActivity)
                    {
                        <div @key="provider.ProviderName" class="library-update-batch" role="listitem">
                            <div class="library-update-batch__select">
                                <span class="library-update-batch__favorite" title="@ProviderActivityTooltip(provider)">
                                    <MudTooltip Text="@ProviderActivityTooltip(provider)" Placement="Placement.Top">
                                        <MudIcon Icon="@ProviderActivityIcon(provider)" />
                                    </MudTooltip>
                                </span>
                                <span class="library-update-batch__name">
                                    <strong>@ProviderLabel(provider.ProviderName)</strong>
                                    <span>@ProviderActivitySummary(provider)</span>
                                </span>
                                <span class="library-update-batch__stats">
                                    <span class="@ProviderStatusChipClass(provider)">
                                        <MudIcon Icon="@ProviderStatusIcon(provider)" />
                                        <strong>@ProviderStatusValue(provider)</strong>
                                        <span>@ProviderStatusLabel(provider)</span>
                                    </span>
                                    @if (ProviderHasVisibleError(provider))
                                    {
                                        <span class="@ProviderErrorChipClass(provider)">
                                            <MudIcon Icon="@Icons.Material.Outlined.WarningAmber" />
                                            <strong>@ProviderErrorValue(provider)</strong>
                                            <span>@ProviderErrorLabel(provider)</span>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="@ProviderWaitChipClass(provider)">
                                            <MudIcon Icon="@Icons.Material.Outlined.Schedule" />
                                            <strong>@ProviderWaitValue(provider)</strong>
                                            <span>@ProviderWaitLabel(provider)</span>
                                        </span>
                                    }
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

    }
</div>
