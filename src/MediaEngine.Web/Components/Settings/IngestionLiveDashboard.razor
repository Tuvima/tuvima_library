    private static string BatchStatusTone(IngestionOperationsBatchViewModel batch) =>
        IsFailedBatchStatus(batch.Status)
            ? "danger"
            : batch.ReviewCount > 0
                ? "warning"
                : IsActiveBatchStatus(batch.Status)
                    ? "info"
                    : "success";

    private static string BatchStatusLabel(IngestionOperationsBatchViewModel batch) =>
        IsActiveBatchStatus(batch.Status)
            ? "Running"
            : IsFailedBatchStatus(batch.Status)
                ? "Failed"
                : batch.ReviewCount > 0
                    ? "Review"
                    : "Complete";

    private static bool IsActiveBatchStatus(string? status) =>
        status is not null
        && (status.Equals("running", StringComparison.OrdinalIgnoreCase)
            || status.Equals("processing", StringComparison.OrdinalIgnoreCase)
            || status.Equals("active", StringComparison.OrdinalIgnoreCase)
            || status.Equals("queued", StringComparison.OrdinalIgnoreCase));

    private static bool IsFailedBatchStatus(string? status) =>
        status is not null
        && (status.Equals("failed", StringComparison.OrdinalIgnoreCase)
            || status.Equals("abandoned", StringComparison.OrdinalIgnoreCase));

    private static string BatchTiming(IngestionOperationsBatchViewModel batch)
    {
        var when = batch.CompletedAt ?? batch.StartedAt;
        var relative = FormatRelative(when);
        if (IsActiveBatchStatus(batch.Status))
            return $"{FormatCount(batch.ProcessedFiles)} / {FormatCount(batch.TotalFiles)} files - started {relative}";
        if (batch.DurationSeconds is > 0)
            return $"{FormatCount(batch.ProcessedFiles)} / {FormatCount(batch.TotalFiles)} files - {FormatDuration(TimeSpan.FromSeconds(batch.DurationSeconds.Value))}";
        return $"{FormatCount(batch.ProcessedFiles)} / {FormatCount(batch.TotalFiles)} files - {relative}";
    }

