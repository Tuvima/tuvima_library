@namespace MediaEngine.Web.Components.Settings
@using System.Globalization
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration

<div class="ingestion-live library-update">
    @if (Loading && Snapshot is null)
    {
        <div class="library-update__skeleton">
            @for (var i = 0; i < 4; i++)
            {
                <AppSkeleton Class="library-update__skeleton-card" />
            }
        </div>
    }
    else
    {
        <section class="@MainStatusClass" aria-live="polite">
            @if (DisplayStageRows.Count > 0)
            {
                <div class="library-update-overall-progress" aria-label="Overall ingestion progress">
                    <div class="library-update-overall-progress__top">
                        <div>
                            <strong>Overall progress</strong>
                            <span>@FormatCount(OverallProgress.ProcessedFiles) of @FormatCount(OverallProgress.TotalFiles) files</span>
                        </div>
                        <em>@FormatPercent(OverallProgress.Percent)</em>
                        <AppActionBar Align="AppHorizontalAlignment.End" Class="library-update__actions">
                            <MudTooltip Text="Reload the latest ingestion status." Placement="Placement.Bottom">
                                <AppButton Label="Refresh"
                                           StartIcon="@Icons.Material.Outlined.Refresh"
                                           Disabled="@Loading"
                                           title="Reload the latest ingestion status."
                                           OnClick="OnRefresh" />
                            </MudTooltip>
                            <MudTooltip Text="Start a new scan of the watched folders." Placement="Placement.Bottom">
                                <AppButton Label="Scan Now"
                                           ButtonStyle="AppButtonStyle.Filled"
                                           Tone="AppUiTone.Primary"
                                           StartIcon="@Icons.Material.Outlined.PlayArrow"
                                           Disabled="@(Loading || ScanStarting)"
                                           title="Start a new scan of the watched folders."
                                           OnClick="OnScanNow" />
                            </MudTooltip>
                        </AppActionBar>
                    </div>
                    <AppProgressBar Value="@OverallProgress.Percent"
                                    ShowValue="false"
                                    Indeterminate="@(Model.IsIndeterminate && OverallProgress.TotalFiles <= 0)"
                                    Class="library-update-progress" />
                </div>

                <div class="library-update-stage-cards" aria-label="Ingestion stages">
                    @foreach (var stage in DisplayStageRows)
                    {
                        <AppNativeButton @key="StageRenderKey(stage)"
                                         Type="button"
                                         Class="@StageCardClass(stage)"
                                         AriaLabel="@StageSelectionLabel(stage)"
                                         OnClick="@(() => SelectStage(stage))">
                            <span class="library-update-stage-card__progress" aria-hidden="true" title="@StageProgressTooltip(stage)">
                                <MudTooltip Text="@StageProgressTooltip(stage)" Placement="Placement.Top">
                                    @if (IsStageComplete(stage))
                                    {
                                        <span class="library-update-stage-card__check">
                                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" />
                                        </span>
                                    }
                                    else
                                    {
                                        <svg viewBox="0 0 36 36" focusable="false">
                                            <circle class="library-update-stage-card__progress-track" cx="18" cy="18" r="15.5" pathLength="100" />
                                            <circle class="library-update-stage-card__progress-value" cx="18" cy="18" r="15.5" pathLength="100" stroke-dasharray="100" stroke-dashoffset="@StageRingOffset(stage)" />
                                        </svg>
                                    }
                                </MudTooltip>
                            </span>
                            <span class="library-update-stage-card__icon" title="@StageIconTooltip(stage)">
                                <MudTooltip Text="@StageIconTooltip(stage)" Placement="Placement.Top">
                                    @if (IsWikidataStage(stage))
                                    {
                                        <img src="/assets/providers/wikidata.svg" alt="" aria-hidden="true" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@stage.Icon" />
                                    }
                                </MudTooltip>
                            </span>
                            <strong>@DisplayStageLabel(stage)</strong>
                            <span>@StageCardSummary(stage)</span>
                        </AppNativeButton>
                    }
                </div>

                @if (SelectedStage is not null)
                {
                    <section class="library-update-stage-detail-panel" aria-label="@($"{DisplayStageLabel(SelectedStage)} details")">
                        <div class="library-update-stage-detail-panel__items">
                            @foreach (var detail in StageDetailLines(SelectedStage))
                            {
                                <div @key="StageDetailKey(detail)" class="@StageDetailClass(detail)">
                                    <span class="library-update-stage-detail__icon" aria-hidden="true" title="@StageDetailTooltip(detail)">
                                        <MudTooltip Text="@StageDetailTooltip(detail)" Placement="Placement.Top">
                                            <MudIcon Icon="@detail.Icon" />
                                        </MudTooltip>
                                    </span>
                                    <strong>@detail.Value</strong>
                                    <span>@detail.Label</span>
                                </div>
                            }
                        </div>
                    </section>
                }
            }
            else if (!Model.ShowProgress && Model.EnrichmentTotal <= 0)
            {
                <p class="library-update-status__line">@MainLineContent()</p>
            }

            @if (Model.PageState == LibraryUpdatePageState.Failed)
            {
                <div class="library-update-status__failure-actions">
                    <MudTooltip Text="Start the scan again after a failed update." Placement="Placement.Bottom">
                        <AppButton Label="Try Again"
                                   ButtonStyle="AppButtonStyle.Filled"
                                   Tone="AppUiTone.Primary"
                                   StartIcon="@Icons.Material.Outlined.Replay"
                                   title="Start the scan again after a failed update."
                                   OnClick="OnScanNow" />
                    </MudTooltip>
                    <MudTooltip Text="Open the activity log for ingestion work." Placement="Placement.Bottom">
                        <AppButton Label="View Activity"
                                   Href="/settings/activity"
                                   title="Open the activity log for ingestion work."
                                   EndIcon="@Icons.Material.Outlined.ChevronRight" />
                    </MudTooltip>
                </div>
            }
        </section>

        <section class="library-update-batches">
            <div class="library-update-batches__header">
                <span class="library-update-batches__icon" title="Recent batches show the latest scans and whether they are active or complete.">
                    <MudTooltip Text="Recent batches show the latest scans and whether they are active or complete." Placement="Placement.Top">
                        <MudIcon Icon="@Icons.Material.Outlined.History" />
                    </MudTooltip>
                </span>
                <div>
                    <h3>Recent batches</h3>
                    <p>Select a batch to load its stage details above.</p>
                </div>
            </div>

            @if (OrderedRecentBatches.Count > 0)
            {
                <div class="library-update-batch-list" role="list" aria-label="Recent ingestion batches">
                    @foreach (var batch in OrderedRecentBatches)
                    {
                        <div @key="BatchRenderKey(batch)"
                             class="@BatchCardClass(batch)"
                             role="listitem">
                            <AppNativeButton Type="button"
                                             Class="library-update-batch__select"
                                             AriaLabel="@($"Load details for {BatchTitle(batch)}")"
                                             OnClick="@(() => SelectBatch(batch))">
                                <span class="library-update-batch__favorite" title="@BatchSelectionTooltip(batch)">
                                    <MudTooltip Text="@BatchSelectionTooltip(batch)" Placement="Placement.Top">
                                        <MudIcon Icon="@(IsSelectedBatch(batch) ? Icons.Material.Filled.Star : Icons.Material.Outlined.ChevronRight)" />
                                    </MudTooltip>
                                </span>
                                <span class="library-update-batch__name">
                                    <strong>@BatchTitle(batch)</strong>
                                    <span>@BatchTiming(batch)</span>
                                </span>
                                <span class="library-update-batch__media" aria-label="Media types in batch">
                                    @foreach (var chip in BatchMediaChips(batch))
                                    {
                                        var mediaTooltip = BatchMediaTooltip(chip);
                                        <span class="@BatchMediaIconClass(chip)" title="@mediaTooltip" aria-label="@mediaTooltip">
                                            <MudTooltip Text="@mediaTooltip" Placement="Placement.Top">
                                                <MudIcon Icon="@chip.Icon" />
                                            </MudTooltip>
                                        </span>
                                    }
                                </span>
                                <span class="library-update-batch__stats">
                                    @foreach (var chip in BatchArtifactChips(batch))
                                    {
                                        var artifactTooltip = BatchArtifactTooltip(chip);
                                        <span class="@BatchChipClass(chip)" title="@artifactTooltip" aria-label="@artifactTooltip">
                                            <MudTooltip Text="@artifactTooltip" Placement="Placement.Top">
                                                <MudIcon Icon="@chip.Icon" />
                                            </MudTooltip>
                                            <strong>@FormatCount(chip.Count)</strong>
                                            <span>@chip.Label</span>
                                        </span>
                                    }
                                </span>
                            </AppNativeButton>
                            <a class="library-update-batch__activity"
                               href="@BatchActivityHref(batch)"
                               title="@BatchActivityTooltip(batch)"
                               aria-label="@BatchActivityTooltip(batch)">
                                <MudTooltip Text="@BatchActivityTooltip(batch)" Placement="Placement.Top">
                                    <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" />
                                </MudTooltip>
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="library-update-batches__empty">Run a scan to see batch history here.</p>
            }
        </section>

        @if (EffectiveProviderActivity.Count > 0)
        {
            <section class="library-update-batches">
                <div class="library-update-batches__header">
                    <span class="library-update-batches__icon" title="Provider activity shows live requests, throttling, and recent errors.">
                        <MudTooltip Text="Provider activity shows live requests, throttling, and recent errors." Placement="Placement.Top">
                            <MudIcon Icon="@Icons.Material.Outlined.Traffic" />
                        </MudTooltip>
                    </span>
                    <div>
                        <h3>Provider activity</h3>
                        <p>External lookups are rate-limited per service while ingestion continues in parallel.</p>
                    </div>
                </div>

                <div class="library-update-batch-list" role="list" aria-label="Provider request activity">
                    @foreach (var provider in EffectiveProviderActivity)
                    {
                        <div @key="provider.ProviderName" class="library-update-batch" role="listitem">
                            <div class="library-update-batch__select">
                                <span class="library-update-batch__favorite" title="@ProviderActivityTooltip(provider)">
                                    <MudTooltip Text="@ProviderActivityTooltip(provider)" Placement="Placement.Top">
                                        <MudIcon Icon="@(provider.ActiveRequests > 0 ? Icons.Material.Outlined.Sync : Icons.Material.Outlined.CheckCircle)" />
                                    </MudTooltip>
                                </span>
                                <span class="library-update-batch__name">
                                    <strong>@ProviderLabel(provider.ProviderName)</strong>
                                    <span>@ProviderActivitySummary(provider)</span>
                                </span>
                                <span class="library-update-batch__stats">
                                    <span class="@ProviderActivityChipClass(provider)">
                                        <MudIcon Icon="@Icons.Material.Outlined.Bolt" />
                                        <strong>@provider.ActiveRequests</strong>
                                        <span>active</span>
                                    </span>
                                    <span class="@ProviderErrorChipClass(provider)">
                                        <MudIcon Icon="@Icons.Material.Outlined.WarningAmber" />
                                        <strong>@FormatCount(provider.ErrorsLastMinute)</strong>
                                        <span>errors/min</span>
                                    </span>
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

    }
</div>

@code {
    [Parameter] public LibraryUpdateStatusViewModel? Status { get; set; }
    [Parameter] public IngestionOperationsSnapshotViewModel? Snapshot { get; set; }
    [Parameter] public IngestionDashboardMetrics Metrics { get; set; } = new(0, 0, 0, 0);
    [Parameter] public IngestionOverallProgress OverallProgress { get; set; } = new(0, 0, 0, "Ingestion_StageScanning", "Ingestion_StageScanningDetail", 0, 0, 0, null);
    [Parameter] public IReadOnlyList<IngestionDashboardStage> Stages { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionOperationsJobViewModel> Jobs { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionCurrentActivityViewModel> CurrentActivities { get; set; } = [];
    [Parameter] public IReadOnlyList<ActivityEntryViewModel> Activities { get; set; } = [];
    [Parameter] public IReadOnlyList<ReviewItemViewModel> PendingReviews { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionReviewReasonViewModel> ReviewReasons { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionProviderActivityViewModel> ProviderActivity { get; set; } = [];
    [Parameter] public IngestionLiveMode LiveMode { get; set; }
    [Parameter] public EngineConnectionState ConnectionState { get; set; }
    [Parameter] public DateTimeOffset? LastUpdated { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool ScanStarting { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback OnScanNow { get; set; }

    private string? _lastRenderSignature;
    private string? _selectedStageKey;
    private Guid? _selectedBatchId;
    private readonly HashSet<string> _expandedStageKeys = new(StringComparer.OrdinalIgnoreCase);

    private LibraryUpdateStatusViewModel Model => Status
        ?? IngestionLiveDashboardState.BuildLibraryUpdateStatus(
            Snapshot,
            Jobs,
            EffectiveCurrentActivities,
            Activities,
            PendingReviews,
            Metrics,
            Error,
            LastUpdated,
            DateTimeOffset.UtcNow);
    private IReadOnlyList<IngestionDashboardStage> StageRows => Stages
        .Where(stage => !IsReviewStage(stage))
        .OrderBy(stage => stage.StageNumber > 0 ? stage.StageNumber : int.MaxValue)
        .ThenBy(stage => stage.Key)
        .ToList();
    private IReadOnlyList<IngestionDashboardStage> DisplayStageRows =>
        UseSelectedBatchSnapshot && SelectedBatch is { } batch
            ? BuildBatchStages(batch)
            : StageRows;
    private IReadOnlyList<IngestionOperationsBatchViewModel> OrderedRecentBatches => RecentBatches
        .OrderByDescending(batch => IsActiveBatchStatus(batch.Status))
        .ThenByDescending(batch => batch.StartedAt)
        .Take(5)
        .ToList();
    private IngestionOperationsBatchViewModel? SelectedBatch => ResolveSelectedBatch();
    private bool UseSelectedBatchSnapshot => SelectedBatch is { StageProgress.Count: > 0 };
    private IngestionDashboardStage? SelectedStage =>
        DisplayStageRows.FirstOrDefault(stage => StageSelectionKey(stage).Equals(_selectedStageKey, StringComparison.OrdinalIgnoreCase))
        ?? DefaultSelectedStage(DisplayStageRows);
    private IngestionDashboardStage ActiveBatchStage =>
        StageRows.FirstOrDefault(stage => stage.StatusKey == "Ingestion_StatusActive")
        ?? StageRows.FirstOrDefault(stage => !IsStageComplete(stage))
        ?? StageRows.LastOrDefault()
        ?? new IngestionDashboardStage("scan", "Scan", "Scan", Icons.Material.Outlined.Radar, 0, 0, 0, "Ingestion_StatusIdle", 0, false, 0, 0, 0, false, 1);
    private int LatestBatchReviewDelta => OrderedRecentBatches.FirstOrDefault() is { } batch
        ? Math.Max(0, batch.ReviewCount)
        : 0;
    private string? ReviewMetricSubline => LatestBatchReviewDelta > 0
        ? $"+{FormatCount(LatestBatchReviewDelta)} this batch"
        : Model.ExpectedReviewItems > 0 || Model.UnexpectedReviewItems > 0
            ? FormatExpectedReview(Model)
            : null;

    protected override void OnParametersSet()
    {
        if (_selectedBatchId is null && OrderedRecentBatches.FirstOrDefault() is { } latestBatch)
            _selectedBatchId = latestBatch.BatchId;

        if (DisplayStageRows.Count == 0)
        {
            _selectedStageKey = null;
            return;
        }

        if (string.IsNullOrWhiteSpace(_selectedStageKey)
            || DisplayStageRows.All(stage => !StageSelectionKey(stage).Equals(_selectedStageKey, StringComparison.OrdinalIgnoreCase)))
        {
            _selectedStageKey = StageSelectionKey(DefaultSelectedStage(DisplayStageRows) ?? DisplayStageRows[0]);
        }
    }

    protected override bool ShouldRender()
    {
        var signature = BuildRenderSignature(
            Model,
            Loading,
            ScanStarting,
            Error,
            RecentBatches,
            DisplayStageRows,
            SelectionSignature);
        if (string.Equals(_lastRenderSignature, signature, StringComparison.Ordinal))
            return false;

        _lastRenderSignature = signature;
        return true;
    }

    private string MainStatusClass => $"library-update-status is-{Model.PageState.ToString().ToLowerInvariant()}";
    private string StatusPillClass => $"library-update-pill is-{Model.StatusTone}";
    private IReadOnlyList<IngestionOperationsBatchViewModel> RecentBatches => Snapshot?.RecentBatches ?? [];
    private IReadOnlyList<IngestionCurrentActivityViewModel> EffectiveCurrentActivities =>
        CurrentActivities.Count > 0 ? CurrentActivities : Snapshot?.CurrentActivities ?? [];
    private IReadOnlyList<IngestionProviderActivityViewModel> EffectiveProviderActivity =>
        ProviderActivity.Count > 0 ? ProviderActivity : Snapshot?.ProviderActivity ?? [];
    private double FileProcessingPercent => Model.TotalFiles > 0
        ? Math.Clamp(
            Model.PageState == LibraryUpdatePageState.Running && Model.ProgressPercent > 0
                ? Model.ProgressPercent
                : Model.ProcessedFiles * 100d / Model.TotalFiles,
            0,
            100)
        : Math.Clamp(Model.ProgressPercent, 0, 100);
    private string PanelIcon => Model.PageState == LibraryUpdatePageState.Running
        ? Icons.Material.Outlined.GraphicEq
        : Icons.Material.Outlined.AutoAwesome;

    private static string BuildRenderSignature(
        LibraryUpdateStatusViewModel model,
        bool loading,
        bool scanStarting,
        string? error,
        IReadOnlyList<IngestionOperationsBatchViewModel> recentBatches,
        IReadOnlyList<IngestionDashboardStage> stages,
        string expandedStageSignature)
    {
        var steps = string.Join(';', model.Steps.Select(step => $"{step.Label}:{step.Status}"));
        var enrichment = string.Join(';', model.EnrichmentStats.Select(stat => string.Join(':',
            stat.Key,
            stat.CompletedCount,
            stat.TotalCount,
            stat.ActiveCount,
            stat.QueuedCount)));
        var recent = string.Join(';', recentBatches.Select(batch => string.Join(':',
            batch.BatchId,
            batch.Status,
            batch.MoviesCount,
            batch.TvShowsCount,
            batch.BooksCount,
            batch.AudiobooksCount,
            batch.MusicCount,
            batch.ComicsCount,
            batch.PeopleGeneratedCount,
            batch.ReviewCount,
            batch.StartedAt.ToUnixTimeSeconds())));
        var reasons = string.Join(';', model.AttentionReasons.Select(reason => $"{reason.Label}:{reason.Count}"));
        var stageSignature = string.Join(';', stages.Select(stage => string.Join(':',
            stage.StageNumber,
            stage.Key,
            stage.Count,
            stage.Total,
            Math.Round(stage.Percent, 1),
            stage.StatusLabel,
            stage.ArtifactCount,
            stage.ActiveItemLabel,
            stage.ActiveGroupLabel,
            stage.ActiveCount,
            stage.QueuedCount,
            stage.IsStale,
            string.Join(',', StageDetailLines(stage).Select(detail => $"{detail.Label}={detail.Value}")))));

        return string.Join('|',
            loading,
            scanStarting,
            error,
            model.PageState,
            model.TotalFiles,
            model.ProcessedFiles,
            model.MatchedItems,
            model.EnrichmentCompleted,
            model.EnrichmentTotal,
            Math.Round(model.EnrichmentPercent, 1),
            model.ReviewItems,
            model.ExpectedReviewItems,
            model.UnexpectedReviewItems,
            model.ActiveItems,
            model.QueuedItems,
            Math.Round(model.ProgressPercent, 1),
            model.IsIndeterminate,
            model.Heading,
            model.ActivityLine,
            model.SecondaryLine,
            model.StatusLabel,
            model.CurrentItemTitle,
            model.CurrentStep,
            model.CurrentProvider,
            steps,
            enrichment,
            reasons,
            stageSignature,
            expandedStageSignature,
            recent);
    }

    private string SelectionSignature => $"{_selectedBatchId:N}:{_selectedStageKey}";

    private RenderFragment MainLineContent() => builder =>
    {
        var sequence = 0;
        if (Model.PageState is LibraryUpdatePageState.Running or LibraryUpdatePageState.Complete)
        {
            var remaining = Math.Max(0, Model.TotalFiles - Model.ProcessedFiles);
            var remainderText = ResolveMainRemainderText(Model.PageState, remaining);
            builder.OpenElement(sequence++, "span");
            builder.AddContent(sequence++, FormatCount(Model.ProcessedFiles));
            builder.CloseElement();
            builder.AddContent(sequence++, " of ");
            builder.AddContent(sequence++, FormatCount(Model.TotalFiles));
            builder.AddContent(sequence++, " files finished");
            builder.AddContent(sequence++, " - ");
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "library-update-status__remaining");
            builder.AddContent(sequence++, remainderText);
            builder.CloseElement();
            return;
        }

        builder.AddContent(sequence++, Model.MainLine);
    };

    private static string ResolveMainRemainderText(
        LibraryUpdatePageState pageState,
        int remainingFiles)
    {
        if (pageState == LibraryUpdatePageState.Running)
        {
            if (remainingFiles > 0)
                return $"{FormatCount(remainingFiles)} still in pipeline";
            return "waiting for latest worker status";
        }

        return remainingFiles > 0
            ? $"{FormatCount(remainingFiles)} still in pipeline"
            : "all file work complete";
    }

    private static string StageRowClass(IngestionDashboardStage stage)
    {
        var state = stage.IsStale
            ? "stale"
            : stage.StatusKey switch
            {
                "Ingestion_StatusActive" => "active",
                "Ingestion_StatusComplete" => "complete",
                "Ingestion_StatusIdle" => "idle",
                _ => "pending",
            };

        return $"library-update-stage is-{state} is-{stage.Key.Replace('_', '-')}";
    }

    private string StageCardClass(IngestionDashboardStage stage)
    {
        var state = StageVisualState(stage);
        var selected = SelectedStage is { } selectedStage
            && StageSelectionKey(selectedStage).Equals(StageSelectionKey(stage), StringComparison.OrdinalIgnoreCase)
            ? " is-selected"
            : string.Empty;
        var wikidata = IsWikidataStage(stage) ? " is-wikidata" : string.Empty;
        return $"library-update-stage-card is-{state}{selected}{wikidata}";
    }

    private static string StageVisualState(IngestionDashboardStage stage)
    {
        if (stage.IsStale)
            return "stale";
        if (IsStageComplete(stage))
            return "complete";
        if (stage.StatusKey == "Ingestion_StatusActive" || stage.ActiveCount > 0)
            return "active";
        if (stage.Percent > 0)
            return "pending";
        return "idle";
    }

    private static bool IsStageComplete(IngestionDashboardStage stage) =>
        stage.Percent >= 99.5
        || stage.StatusKey == "Ingestion_StatusComplete"
        || string.Equals(stage.StatusLabel, "Complete", StringComparison.OrdinalIgnoreCase);

    private static bool IsWikidataStage(IngestionDashboardStage stage) =>
        stage.Key.Equals("wikidata", StringComparison.OrdinalIgnoreCase);

    private static string StageRingOffset(IngestionDashboardStage stage) =>
        (100 - Math.Clamp(stage.Percent, 0, 100)).ToString("0.##", CultureInfo.InvariantCulture);

    private static string StageSelectionKey(IngestionDashboardStage stage) =>
        stage.StageNumber > 0 ? stage.StageNumber.ToString(CultureInfo.InvariantCulture) : stage.Key;

    private static string StageRenderKey(IngestionDashboardStage stage) =>
        $"{stage.StageNumber}:{stage.Key}";

    private static string StageSelectionLabel(IngestionDashboardStage stage) =>
        $"Show {DisplayStageLabel(stage)} details";

    private static string StageIconTooltip(IngestionDashboardStage stage)
    {
        var key = stage.Key.Replace('_', '-').ToLowerInvariant();
        return key switch
        {
            "scan" or "scanned" => "Files found in watched folders and handed to ingestion.",
            "retail" => "Matches files to retail catalog data like title, cover, and description.",
            "wikidata" => "Links matched items to Wikidata IDs so relationships can be built.",
            "people" => "Finds authors, cast, narrators, artists, and crew connected to the files.",
            "universes" or "relationships" => "Builds series, universe, character, and story relationship links.",
            "artwork" or "deep-artwork" => "Downloads covers, posters, backdrops, logos, and other artwork.",
            _ => $"{DisplayStageLabel(stage)} details for this ingestion stage.",
        };
    }

    private static string StageProgressTooltip(IngestionDashboardStage stage)
    {
        var label = DisplayStageLabel(stage);
        if (stage.IsStale)
            return $"{label} has not sent a fresh update recently.";
        if (IsStageComplete(stage))
            return $"{label} is complete for this batch.";
        if (stage.StatusKey == "Ingestion_StatusActive" || stage.ActiveCount > 0)
            return $"{label} is running now.";
        if (stage.QueuedCount > 0)
            return $"{FormatCount(stage.QueuedCount)} items are waiting for {label}.";
        if (stage.Percent > 0)
            return $"{label} has started but is not finished.";
        return $"{label} has not started yet.";
    }

    private static string StageCardSummary(IngestionDashboardStage stage)
    {
        var artifact = StageArtifactChip(stage);
        if (!string.IsNullOrWhiteSpace(artifact))
            return artifact;
        return StageCountLine(stage);
    }

    private static string StageDetailHeroClass(IngestionDashboardStage stage) =>
        $"library-update-stage-detail-panel__icon is-{StageVisualState(stage)}";

    private void SelectStage(IngestionDashboardStage stage)
    {
        _selectedStageKey = StageSelectionKey(stage);
    }

    private void SelectBatch(IngestionOperationsBatchViewModel batch)
    {
        _selectedBatchId = batch.BatchId;
        _selectedStageKey = null;
        OnParametersSet();
    }

    private bool IsSelectedBatch(IngestionOperationsBatchViewModel batch) =>
        SelectedBatch is { } selected && selected.BatchId == batch.BatchId;

    private IngestionOperationsBatchViewModel? ResolveSelectedBatch()
    {
        if (_selectedBatchId is { } selectedId)
        {
            var selected = OrderedRecentBatches.FirstOrDefault(batch => batch.BatchId == selectedId);
            if (selected is not null)
                return selected;
        }

        return OrderedRecentBatches.FirstOrDefault();
    }

    private static IngestionDashboardStage? DefaultSelectedStage(IReadOnlyList<IngestionDashboardStage> stages) =>
        stages.FirstOrDefault(stage => stage.StatusKey == "Ingestion_StatusActive")
        ?? stages.FirstOrDefault(stage => !IsStageComplete(stage))
        ?? stages.FirstOrDefault();

    private static string BatchRenderKey(IngestionOperationsBatchViewModel batch) =>
        batch.BatchId == Guid.Empty
            ? batch.StartedAt.ToUnixTimeMilliseconds().ToString(CultureInfo.InvariantCulture)
            : batch.BatchId.ToString("N");

    private static IReadOnlyList<IngestionDashboardStage> BuildBatchStages(IngestionOperationsBatchViewModel batch)
    {
        if (batch.StageProgress.Count > 0)
        {
            return IngestionLiveDashboardState.BuildStages(
                new IngestionOperationsSnapshotViewModel { StageProgress = batch.StageProgress },
                [],
                Math.Max(0, batch.TotalFiles));
        }

        var total = Math.Max(0, Math.Max(batch.TotalFiles, batch.ProcessedFiles));
        var processed = Math.Clamp(Math.Max(0, batch.ProcessedFiles), 0, total);
        var reviewOrFailed = Math.Max(0, batch.ReviewCount + batch.FailedCount);
        var typeTotal = batch.BooksCount
            + batch.MoviesCount
            + batch.TvShowsCount
            + batch.MusicCount
            + batch.ComicsCount
            + batch.AudiobooksCount;
        var unidentified = Math.Max(0, total - typeTotal);
        var complete = !IsActiveBatchStatus(batch.Status);
        var completeCount = complete ? total : processed;

        return
        [
            BatchStage(
                1,
                "scan",
                "Scanned",
                Icons.Material.Outlined.Folder,
                processed,
                total,
                "scanned",
                Math.Max(0, total - reviewOrFailed),
                Detail("Books", batch.BooksCount),
                Detail("Movies", batch.MoviesCount),
                Detail("TV", batch.TvShowsCount),
                Detail("Music", batch.MusicCount),
                Detail("Comics", batch.ComicsCount),
                Detail("Audiobooks", batch.AudiobooksCount),
                Detail("Unidentified", unidentified, unidentified > 0 ? "warning" : "neutral"),
                Detail("Skipped / duplicate", 0),
                Detail("Failed", batch.FailedCount, batch.FailedCount > 0 ? "danger" : "neutral")),
            BatchStage(
                2,
            "retail",
            "Retail Match",
            Icons.Material.Outlined.Search,
                Math.Max(0, batch.RegisteredCount + batch.ReviewCount + batch.FailedCount),
                total,
                "matches",
                batch.RegisteredCount,
                Detail("Matches", batch.RegisteredCount, "success"),
                Detail("Books", batch.BooksCount),
                Detail("Movies", batch.MoviesCount),
                Detail("TV", batch.TvShowsCount),
                Detail("Music", batch.MusicCount),
                Detail("Comics", batch.ComicsCount),
                Detail("Audiobooks", batch.AudiobooksCount),
                Detail("Failed / unresolved", reviewOrFailed, reviewOrFailed > 0 ? "warning" : "neutral"),
                Detail("Metadata fields", batch.MetadataUpdatedCount, "info"),
                Detail("Cover art assets", batch.ArtworkDownloadedCount, "success")),
            BatchStage(
                3,
            "wikidata",
            "Wikidata",
            Icons.Material.Outlined.TravelExplore,
            completeCount,
            total,
            "QIDs",
            batch.RegisteredCount,
                Detail("Files with media/work QID", batch.RegisteredCount, "success"),
                Detail("Related QIDs discovered", batch.MetadataUpdatedCount, "info")),
            BatchStage(
                4,
                "people",
                "People",
                Icons.Material.Outlined.Groups,
                completeCount,
                total,
                "people",
                batch.PeopleGeneratedCount,
                Detail("Cast", 0),
                Detail("Directors", 0),
                Detail("Authors", 0),
                Detail("Narrators", 0),
                Detail("Music artists", 0),
                Detail("Deeply enriched people", batch.PeopleGeneratedCount, "success")),
            BatchStage(
                5,
            "universes",
            "Universes",
            Icons.Material.Outlined.Public,
            completeCount,
            total,
                "links",
                batch.MetadataUpdatedCount,
                Detail("Files with universe links", batch.MetadataUpdatedCount, "success"),
                Detail("Series / shelves", 0),
                Detail("Universe roots", 0),
                Detail("Characters / locations / orgs", 0),
                Detail("Adaptation / story links", 0)),
            BatchStage(
                6,
            "artwork",
            "Artwork",
            Icons.Material.Outlined.Image,
                completeCount,
                total,
                "assets",
                batch.ArtworkDownloadedCount,
                Detail("Covers / posters", batch.ArtworkDownloadedCount, "success"),
                Detail("People headshots", 0),
                Detail("Backdrops", 0),
                Detail("Season / episode art", 0),
                Detail("Album / music art", 0),
                Detail("Logos", 0)),
        ];
    }

    private static IngestionDashboardStage BatchStage(
        int stageNumber,
        string key,
        string label,
        string icon,
        int count,
        int total,
        string artifactLabel,
        int artifactCount,
        params IngestionStageDetailItemViewModel[] details)
    {
        count = Math.Max(0, count);
        total = Math.Max(0, total);
        if (total > 0)
            count = Math.Clamp(count, 0, total);
        var percent = total > 0 ? count * 100d / total : 0;
        var status = percent >= 99.5
            ? "Ingestion_StatusComplete"
            : count > 0
                ? "Ingestion_StatusPending"
                : "Ingestion_StatusIdle";
        return new IngestionDashboardStage(
            key,
            label,
            label,
            icon,
            count,
            total,
            percent,
            status,
            percent,
            false,
            0,
            0,
            0,
            false,
            stageNumber,
            artifactLabel,
            Math.Max(0, artifactCount),
            DetailItems: details);
    }

