    private static bool IsReviewStage(IngestionDashboardStage stage) =>
        stage.StageNumber == 9 || stage.Key.Equals("review", StringComparison.OrdinalIgnoreCase);

    private bool IsStageExpanded(IngestionDashboardStage stage) =>
        stage.StatusKey == "Ingestion_StatusActive" || _expandedStageKeys.Contains(StageExpansionKey(stage));

    private void ToggleStage(IngestionDashboardStage stage)
    {
        var key = StageExpansionKey(stage);
        if (!_expandedStageKeys.Add(key))
            _expandedStageKeys.Remove(key);
    }

    private static string StageExpansionKey(IngestionDashboardStage stage) =>
        stage.StageNumber > 0 ? stage.StageNumber.ToString(CultureInfo.InvariantCulture) : stage.Key;

    private static string ToggleStageLabel(IngestionDashboardStage stage) =>
        $"Toggle {DisplayStageLabel(stage)} details";

    private static string StageNumberLabel(IngestionDashboardStage stage) =>
        stage.StageNumber > 0 ? stage.StageNumber.ToString(CultureInfo.CurrentCulture) : "-";

    private static string DisplayStageLabel(IngestionDashboardStage stage) =>
        stage.LabelKey switch
        {
            "Ingestion_StageScanning" => "Scanned",
            "Ingestion_StageRetailIdentification" => "Retail Match",
            "Ingestion_StageWikidataMatch" => "Wikidata",
            "Ingestion_StageEnrichment" => "Enrichment",
            var value => value,
        };

    private static string StageCountLine(IngestionDashboardStage stage)
    {
        if (stage.Total <= 0)
            return stage.Count > 0
                ? $"{FormatCount(stage.Count)} files"
                : "Waiting for files";

        return $"{FormatCount(stage.Count)} / {FormatCount(stage.Total)} files";
    }

    private static string? StageImportantStatusLabel(IngestionDashboardStage stage)
    {
        if (stage.StatusKey == "Ingestion_StatusActive")
            return "Active";
        if (stage.IsStale)
            return "Waiting";
        if (stage.QueuedCount > 0)
            return "Queued";
        if (!string.IsNullOrWhiteSpace(stage.StatusLabel)
            && !stage.StatusLabel.Equals("Complete", StringComparison.OrdinalIgnoreCase))
            return stage.StatusLabel;
        if (stage.Percent < 100 && stage.Count > 0)
            return "In progress";
        if (stage.Percent <= 0 && stage.Total > 0)
            return "Waiting";
        return null;
    }

    private static string FormatArtifact(IngestionDashboardStage stage)
    {
        var count = Math.Max(0, stage.ArtifactCount ?? 0);
        return $"{FormatCount(count)} {stage.ArtifactLabel}";
    }

    private static string? StageArtifactChip(IngestionDashboardStage stage) =>
        string.IsNullOrWhiteSpace(stage.ArtifactLabel)
            ? null
            : FormatArtifact(stage);

    private static string StageStatusChipClass(IngestionDashboardStage stage)
    {
        var tone = stage.IsStale
            ? "warning"
            : stage.StatusKey == "Ingestion_StatusActive"
                ? "info"
                : stage.QueuedCount > 0
                    ? "neutral"
                    : "warning";
        return $"library-update-stage__status is-{tone}";
    }

    private static string? StageActiveLabel(IngestionDashboardStage stage)
    {
        if (stage.ActiveCount <= 0)
            return null;

        if (!string.IsNullOrWhiteSpace(stage.ActiveGroupLabel))
            return stage.ActiveGroupLabel;
        if (!string.IsNullOrWhiteSpace(stage.ActiveItemLabel))
            return stage.ActiveItemLabel;
        return $"{FormatCount(stage.ActiveCount)} active";
    }

    private static IReadOnlyList<StageDetailLine> StageDetailLines(IngestionDashboardStage stage)
    {
        var lines = new List<StageDetailLine>();

        if (stage.ActiveCount > 0)
            lines.Add(new("Active", FormatCount(stage.ActiveCount), "info"));
        if (stage.QueuedCount > 0)
            lines.Add(new("Queued", FormatCount(stage.QueuedCount), "neutral"));
        if (stage.ActiveCount > 0 && !string.IsNullOrWhiteSpace(stage.ActiveGroupLabel))
            lines.Add(new("Active group", stage.ActiveGroupLabel!, "info"));
        if (stage.ActiveCount > 0 && !string.IsNullOrWhiteSpace(stage.ActiveItemLabel))
            lines.Add(new("Active item", stage.ActiveItemLabel!, "info"));
        if (!string.IsNullOrWhiteSpace(stage.LabelAccuracy) && !stage.LabelAccuracy.Equals("None", StringComparison.OrdinalIgnoreCase))
            lines.Add(new("Label accuracy", FormatLabelAccuracy(stage.LabelAccuracy), "neutral"));
        if (stage.IsStale)
            lines.Add(new("Worker status", "Waiting for fresh update", "warning"));

        foreach (var detail in stage.DetailItems ?? [])
        {
            if (string.IsNullOrWhiteSpace(detail.Label) || string.IsNullOrWhiteSpace(detail.Value))
                continue;
            if (lines.Any(line => line.Label.Equals(detail.Label, StringComparison.OrdinalIgnoreCase)))
                continue;
            lines.Add(new(detail.Label, detail.Value, detail.Tone ?? "neutral"));
        }

        return lines;
    }

