@namespace MediaEngine.Web.Components.Settings
@using System.Globalization
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration

<AppCard Class="tl-card ingestion-live library-update">
    <header class="library-update__header">
        <div class="library-update__heading">
            <h2 class="library-update__title">Library Update</h2>
            <p class="library-update__subtitle">
                Track what Tuvima is adding, matching, and waiting for review.
            </p>
            <span class="library-update__timestamp">@Model.TimestampLine</span>
        </div>
        <AppActionBar Align="AppHorizontalAlignment.End" Class="library-update__actions">
            <AppButton Label="Refresh"
                       StartIcon="@Icons.Material.Outlined.Refresh"
                       Disabled="@Loading"
                       OnClick="OnRefresh" />
            <AppButton Label="Scan Now"
                       ButtonStyle="AppButtonStyle.Filled"
                       Tone="AppUiTone.Primary"
                       StartIcon="@Icons.Material.Outlined.PlayArrow"
                       Disabled="@(Loading || ScanStarting)"
                       OnClick="OnScanNow" />
        </AppActionBar>
    </header>

    @if (Loading && Snapshot is null)
    {
        <div class="library-update__skeleton">
            @for (var i = 0; i < 4; i++)
            {
                <AppSkeleton Class="library-update__skeleton-card" />
            }
        </div>
    }
    else
    {
        <section class="library-update__metrics" aria-label="Library update summary">
            <div class="library-update-metric is-purple">
                <span class="library-update-metric__icon"><MudIcon Icon="@Icons.Material.Outlined.Description" /></span>
                <div>
                    <span>Files Found</span>
                    <strong>@FormatCount(Model.TotalFiles)</strong>
                </div>
            </div>
            <div class="library-update-metric is-blue">
                <span class="library-update-metric__icon"><MudIcon Icon="@Icons.Material.Outlined.CheckCircle" /></span>
                <div>
                    <span>Processed</span>
                    <strong>@FormatCount(Model.ProcessedFiles)</strong>
                </div>
            </div>
            <div class="library-update-metric is-green">
                <span class="library-update-metric__icon"><MudIcon Icon="@Icons.Material.Outlined.Link" /></span>
                <div>
                    <span>Matched</span>
                    <strong>@FormatCount(Model.MatchedItems)</strong>
                </div>
            </div>
            <div class="library-update-metric is-purple">
                <span class="library-update-metric__icon"><MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" /></span>
                <div>
                    <span>Enrichment</span>
                    <strong>@FormatEnrichmentValue(Model)</strong>
                </div>
            </div>
            <div class="library-update-metric is-amber">
                <span class="library-update-metric__icon"><MudIcon Icon="@Icons.Material.Outlined.WarningAmber" /></span>
                <div>
                    <span>Need Review</span>
                    <strong>@FormatCount(Model.ReviewItems)</strong>
                    @if (Model.ExpectedReviewItems > 0 || Model.UnexpectedReviewItems > 0)
                    {
                        <em class="library-update-metric__sub">@FormatExpectedReview(Model)</em>
                    }
                </div>
            </div>
        </section>

        <section class="library-update-primary-grid">

        <section class="@MainStatusClass" aria-live="polite">
            <div class="library-update-status__top">
                <div>
                    <h3 class="library-update-status__title">@Model.Heading</h3>
                    @if (!Model.ShowProgress && Model.EnrichmentTotal <= 0)
                    {
                        <p class="library-update-status__line">@MainLineContent()</p>
                    }
                </div>
                <span class="@StatusPillClass">
                    <span></span>
                    @Model.StatusLabel
                </span>
            </div>

            @if (Model.ShowProgress || Model.EnrichmentTotal > 0)
            {
                <div class="library-update-progress-stack">
                    <div class="library-update-progress-block">
                        <span class="library-update-progress-block__icon is-blue"><MudIcon Icon="@Icons.Material.Outlined.CheckCircle" /></span>
                        <div class="library-update-progress-block__content">
                            <div class="library-update-progress-block__top">
                                <div>
                                    <strong>File processing</strong>
                                    <span>@FormatCount(Model.ProcessedFiles) of @FormatCount(Model.TotalFiles) files processed</span>
                                </div>
                                <em>@FormatPercent(FileProcessingPercent)</em>
                            </div>
                            <AppProgressBar Value="@FileProcessingPercent"
                                            ShowValue="false"
                                            Indeterminate="@Model.IsIndeterminate"
                                            Class="library-update-progress" />
                            <p>Files have been scanned, parsed, and registered.</p>
                        </div>
                    </div>

                    @if (Model.EnrichmentTotal > 0)
                    {
                        <div class="library-update-progress-block">
                            <span class="library-update-progress-block__icon is-purple"><MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" /></span>
                            <div class="library-update-progress-block__content">
                                <div class="library-update-progress-block__top">
                                    <div>
                                        <strong>Enrichment</strong>
                                        <span>@FormatCount(Model.EnrichmentCompleted) of @FormatCount(Model.EnrichmentTotal) files fully complete</span>
                                    </div>
                                    <em>@FormatPercent(Model.EnrichmentPercent)</em>
                                </div>
                                <AppProgressBar Value="@Model.EnrichmentPercent"
                                                ShowValue="false"
                                                Class="library-update-progress is-enrichment" />
                                @if (Model.EnrichmentStats.Count > 0)
                                {
                                    <div class="library-update-enrichment-chips" aria-label="Enrichment progress by task">
                                        @foreach (var stat in Model.EnrichmentStats)
                                        {
                                            <span class="@EnrichmentChipClass(stat)">
                                                <MudIcon Icon="@stat.Icon" />
                                                <strong>@stat.Label</strong>
                                                <em>@FormatCount(stat.CompletedCount) found</em>
                                            </span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ActivityLine))
            {
                <p class="library-update-status__activity">@Model.ActivityLine</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SecondaryLine))
            {
                <p class="library-update-status__secondary">@Model.SecondaryLine</p>
            }

            @if (Model.PageState == LibraryUpdatePageState.Failed)
            {
                <div class="library-update-status__failure-actions">
                    <AppButton Label="Try Again"
                               ButtonStyle="AppButtonStyle.Filled"
                               Tone="AppUiTone.Primary"
                               StartIcon="@Icons.Material.Outlined.Replay"
                               OnClick="OnScanNow" />
                    <AppButton Label="View Activity"
                               Href="/settings/activity"
                               EndIcon="@Icons.Material.Outlined.ChevronRight" />
                </div>
            }
        </section>

        <section class="library-update-panel library-update-now">
            <span class="library-update-panel__icon is-purple"><MudIcon Icon="@PanelIcon" /></span>
            <div class="library-update-panel__body">
                <h3>@Model.PanelTitle</h3>
                <p>@Model.PanelText</p>

                @if (Model.PageState == LibraryUpdatePageState.Running)
                {
                    @if (ActivityRows.Count > 0)
                    {
                        <div class="library-update-now-list">
                            @foreach (var activity in ActivityRows)
                            {
                                <div class="@ActivityRowClass(activity)">
                                    <MudIcon Icon="@ActivityIcon(activity)" />
                                    <strong>@ActivityLabel(activity)</strong>
                                    <span>@ActivityCurrentItem(activity)</span>
                                </div>
                            }
                        </div>
                    }
                    <div class="library-update-facts">
                        @if (!string.IsNullOrWhiteSpace(Model.CurrentItemTitle))
                        {
                            <div>
                                <span>Current item</span>
                                <strong>@Model.CurrentItemTitle</strong>
                            </div>
                        }
                        <div>
                            <span>Current step</span>
                            <strong>@Model.CurrentStep</strong>
                        </div>
                        @if (Model.QueuedItems > 0)
                        {
                            <div>
                                <span>Still in pipeline</span>
                                <strong>@FormatCount(Model.QueuedItems)</strong>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.CurrentProvider))
                        {
                            <div>
                                <span>Current source</span>
                                <strong>@Model.CurrentProvider</strong>
                            </div>
                        }
                    </div>
                }
                else if (Model.HasPriorRun)
                {
                    <div class="library-update-facts is-summary">
                        <div>
                            <span>Added or updated</span>
                            <strong>@FormatCount(Model.AddedOrUpdatedCount)</strong>
                        </div>
                        <div>
                            <span>Matched</span>
                            <strong>@FormatCount(Model.MatchedItems)</strong>
                        </div>
                        <div>
                            <span>Need review</span>
                            <strong>@FormatCount(Model.ReviewItems)</strong>
                        </div>
                    </div>
                }
            </div>
        </section>
        </section>

        <section class="library-update-steps" aria-label="Update steps">
            <h3>Update steps</h3>
            <div class="library-update-stepper">
                @foreach (var step in Model.Steps)
                {
                    <div class="@StepClass(step)">
                        <span class="library-update-step__node">
                            <MudIcon Icon="@StepIcon(step)" />
                        </span>
                        <div>
                            <strong>@step.Label</strong>
                            <span>@step.StatusLabel</span>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="library-update-bottom-grid">
            @if (Model.ReviewItems > 0)
            {
                <div class="library-update-panel library-update-attention">
                    <span class="library-update-panel__icon is-amber"><MudIcon Icon="@Icons.Material.Outlined.WarningAmber" /></span>
                    <div class="library-update-panel__body">
                        <h3>Needs attention</h3>
                        <p>@FormatReviewAttentionText(Model)</p>
                        <ul class="library-update-attention__reasons">
                            @foreach (var reason in Model.AttentionReasons)
                            {
                                <li><span></span>@FormatCount(reason.Count) @reason.Label</li>
                            }
                        </ul>
                    </div>
                    <AppButton Label="Review Items"
                               Href="/settings/review"
                               ButtonStyle="AppButtonStyle.Filled"
                               Tone="AppUiTone.Primary"
                               EndIcon="@Icons.Material.Outlined.ChevronRight"
                               Class="library-update-attention__button" />
                </div>
            }
            else if (Model.HasPriorRun || Model.PageState == LibraryUpdatePageState.Running)
            {
                <div class="library-update-panel library-update-clear">
                    <span class="library-update-panel__icon is-green"><MudIcon Icon="@Icons.Material.Outlined.TaskAlt" /></span>
                    <div class="library-update-panel__body">
                        <h3>No items need review</h3>
                        <p>Tuvima has not found anything that needs a curator decision.</p>
                    </div>
                </div>
            }

            @if (Model.HasPriorRun || Model.RecentRuns.Count > 0 || Model.PageState == LibraryUpdatePageState.Running)
            {
                <details class="library-update-recent" aria-label="Recent update runs" open>
                    <summary class="library-update-recent__summary">
                        <span>Recent library updates</span>
                        <MudIcon Icon="@Icons.Material.Outlined.ExpandMore" />
                    </summary>
                    <div class="library-update-recent__content">
                        @if (RecentBatches.Count == 0)
                        {
                            <div class="library-update-recent__empty">No library update runs are available yet.</div>
                        }
                        else
                        {
                            <div class="library-update-batch-grid" role="table" aria-label="Recent library updates">
                                <div class="library-update-batch-grid__head" role="row">
                                    <span>Update</span>
                                    @BatchHeader("Movies", Icons.Material.Outlined.Movie, "movies")
                                    @BatchHeader("TV Shows", Icons.Material.Outlined.Tv, "tv")
                                    @BatchHeader("Books", Icons.Material.Outlined.MenuBook, "books")
                                    @BatchHeader("Audiobooks", Icons.Material.Outlined.Headphones, "audiobooks")
                                    @BatchHeader("Music", Icons.Material.Outlined.MusicNote, "music")
                                    @BatchHeader("Comics", Icons.Material.Outlined.AutoStories, "comics")
                                    @BatchHeader("People", Icons.Material.Outlined.Groups, "people")
                                    @BatchHeader("Review", Icons.Material.Outlined.RateReview, "review")
                                    <span>Status</span>
                                </div>
                                @foreach (var batch in RecentBatches)
                                {
                                    <a class="library-update-batch-grid__row"
                                       role="row"
                                       href="@BatchActivityHref(batch)"
                                       aria-label="View activity for @BatchTitle(batch)">
                                        <span class="library-update-batch-title">
                                            <strong>@BatchTitle(batch)</strong>
                                            <time>@FormatRelative(batch.StartedAt)</time>
                                        </span>
                                        @BatchCountChip(batch.MoviesCount, Icons.Material.Outlined.Movie, "movies")
                                        @BatchCountChip(batch.TvShowsCount, Icons.Material.Outlined.Tv, "tv")
                                        @BatchCountChip(batch.BooksCount, Icons.Material.Outlined.MenuBook, "books")
                                        @BatchCountChip(batch.AudiobooksCount, Icons.Material.Outlined.Headphones, "audiobooks")
                                        @BatchCountChip(batch.MusicCount, Icons.Material.Outlined.MusicNote, "music")
                                        @BatchCountChip(batch.ComicsCount, Icons.Material.Outlined.AutoStories, "comics")
                                        @BatchCountChip(batch.PeopleGeneratedCount, Icons.Material.Outlined.Groups, "people")
                                        @BatchCountChip(batch.ReviewCount, Icons.Material.Outlined.RateReview, "review")
                                        <span class="@BatchStatusClass(batch.Status)">@BatchStatusLabel(batch.Status)</span>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </details>
            }
        </section>
    }
</AppCard>

@code {
    [Parameter] public LibraryUpdateStatusViewModel? Status { get; set; }
    [Parameter] public IngestionOperationsSnapshotViewModel? Snapshot { get; set; }
    [Parameter] public IngestionDashboardMetrics Metrics { get; set; } = new(0, 0, 0, 0);
    [Parameter] public IngestionOverallProgress OverallProgress { get; set; } = new(0, 0, 0, "Ingestion_StageScanning", "Ingestion_StageScanningDetail", 0, 0, 0, null);
    [Parameter] public IReadOnlyList<IngestionDashboardStage> Stages { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionOperationsJobViewModel> Jobs { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionCurrentActivityViewModel> CurrentActivities { get; set; } = [];
    [Parameter] public IReadOnlyList<ActivityEntryViewModel> Activities { get; set; } = [];
    [Parameter] public IReadOnlyList<ReviewItemViewModel> PendingReviews { get; set; } = [];
    [Parameter] public IReadOnlyList<IngestionReviewReasonViewModel> ReviewReasons { get; set; } = [];
    [Parameter] public IngestionLiveMode LiveMode { get; set; }
    [Parameter] public EngineConnectionState ConnectionState { get; set; }
    [Parameter] public DateTimeOffset? LastUpdated { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool ScanStarting { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback OnScanNow { get; set; }

    private string? _lastRenderSignature;

    private LibraryUpdateStatusViewModel Model => Status
        ?? IngestionLiveDashboardState.BuildLibraryUpdateStatus(
            Snapshot,
            Jobs,
            EffectiveCurrentActivities,
            Activities,
            PendingReviews,
            Metrics,
            Error,
            LastUpdated,
            DateTimeOffset.UtcNow);

    protected override bool ShouldRender()
    {
        var signature = BuildRenderSignature(
            Model,
            Loading,
            ScanStarting,
            Error,
            RecentBatches,
            ActivityRows);
        if (string.Equals(_lastRenderSignature, signature, StringComparison.Ordinal))
            return false;

        _lastRenderSignature = signature;
        return true;
    }

    private string MainStatusClass => $"library-update-status is-{Model.PageState.ToString().ToLowerInvariant()}";
    private string StatusPillClass => $"library-update-pill is-{Model.StatusTone}";
    private IReadOnlyList<IngestionOperationsBatchViewModel> RecentBatches => Snapshot?.RecentBatches ?? [];
    private IReadOnlyList<IngestionCurrentActivityViewModel> EffectiveCurrentActivities =>
        CurrentActivities.Count > 0 ? CurrentActivities : Snapshot?.CurrentActivities ?? [];
    private double FileProcessingPercent => Model.TotalFiles > 0
        ? Math.Clamp(
            Model.PageState == LibraryUpdatePageState.Running && Model.ProgressPercent > 0
                ? Model.ProgressPercent
                : Model.ProcessedFiles * 100d / Model.TotalFiles,
            0,
            100)
        : Math.Clamp(Model.ProgressPercent, 0, 100);
    private IReadOnlyList<IngestionCurrentActivityViewModel> ActivityRows => EffectiveCurrentActivities
        .Where(activity => !string.IsNullOrWhiteSpace(activity.Message))
        .OrderBy(activity => ActivitySort(activity))
        .ThenByDescending(activity => activity.ActiveCount > 0)
        .ThenByDescending(activity => activity.LastUpdatedTime ?? DateTimeOffset.MinValue)
        .Take(4)
        .ToList();
    private string PanelIcon => Model.PageState == LibraryUpdatePageState.Running
        ? Icons.Material.Outlined.GraphicEq
        : Icons.Material.Outlined.AutoAwesome;

    private static string StepClass(LibraryUpdateStepViewModel step) =>
        $"library-update-step is-{step.Status.ToString().ToLowerInvariant()}";

    private static string StepIcon(LibraryUpdateStepViewModel step) =>
        step.Status switch
        {
            LibraryUpdateStepStatus.Complete => Icons.Material.Outlined.Check,
            LibraryUpdateStepStatus.InProgress => Icons.Material.Outlined.Cached,
            LibraryUpdateStepStatus.NeedsReview => Icons.Material.Outlined.WarningAmber,
            _ => step.Icon,
        };

    private static string BuildRenderSignature(
        LibraryUpdateStatusViewModel model,
        bool loading,
        bool scanStarting,
        string? error,
        IReadOnlyList<IngestionOperationsBatchViewModel> recentBatches,
        IReadOnlyList<IngestionCurrentActivityViewModel> activityRows)
    {
        var steps = string.Join(';', model.Steps.Select(step => $"{step.Label}:{step.Status}"));
        var enrichment = string.Join(';', model.EnrichmentStats.Select(stat => string.Join(':',
            stat.Key,
            stat.CompletedCount,
            stat.TotalCount,
            stat.ActiveCount,
            stat.QueuedCount)));
        var currentActivities = string.Join(';', activityRows.Select(activity => string.Join(':',
            activity.StageKey,
            activity.Message,
            activity.Detail,
            activity.CurrentItem,
            activity.ProcessedCount,
            activity.TotalCount,
            Math.Round(activity.PercentComplete, 1),
            activity.ActiveCount,
            activity.QueuedCount)));
        var recent = string.Join(';', recentBatches.Select(batch => string.Join(':',
            batch.BatchId,
            batch.Status,
            batch.MoviesCount,
            batch.TvShowsCount,
            batch.BooksCount,
            batch.AudiobooksCount,
            batch.MusicCount,
            batch.ComicsCount,
            batch.PeopleGeneratedCount,
            batch.ReviewCount,
            batch.StartedAt.ToUnixTimeSeconds())));
        var reasons = string.Join(';', model.AttentionReasons.Select(reason => $"{reason.Label}:{reason.Count}"));

        return string.Join('|',
            loading,
            scanStarting,
            error,
            model.PageState,
            model.TotalFiles,
            model.ProcessedFiles,
            model.MatchedItems,
            model.EnrichmentCompleted,
            model.EnrichmentTotal,
            Math.Round(model.EnrichmentPercent, 1),
            model.ReviewItems,
            model.ExpectedReviewItems,
            model.UnexpectedReviewItems,
            model.ActiveItems,
            model.QueuedItems,
            Math.Round(model.ProgressPercent, 1),
            model.IsIndeterminate,
            model.Heading,
            model.ActivityLine,
            model.SecondaryLine,
            model.StatusLabel,
            model.CurrentItemTitle,
            model.CurrentStep,
            model.CurrentProvider,
            steps,
            enrichment,
            currentActivities,
            reasons,
            recent);
    }

    private RenderFragment MainLineContent() => builder =>
    {
        var sequence = 0;
        if (Model.PageState is LibraryUpdatePageState.Running or LibraryUpdatePageState.Complete)
        {
            var remaining = Math.Max(0, Model.TotalFiles - Model.ProcessedFiles);
            var remainderText = ResolveMainRemainderText(Model.PageState, remaining);
            builder.OpenElement(sequence++, "span");
            builder.AddContent(sequence++, FormatCount(Model.ProcessedFiles));
            builder.CloseElement();
            builder.AddContent(sequence++, " of ");
            builder.AddContent(sequence++, FormatCount(Model.TotalFiles));
            builder.AddContent(sequence++, " files finished");
            builder.AddContent(sequence++, " - ");
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "library-update-status__remaining");
            builder.AddContent(sequence++, remainderText);
            builder.CloseElement();
            return;
        }

        builder.AddContent(sequence++, Model.MainLine);
    };

    private static string ResolveMainRemainderText(
        LibraryUpdatePageState pageState,
        int remainingFiles)
    {
        if (pageState == LibraryUpdatePageState.Running)
        {
            if (remainingFiles > 0)
                return $"{FormatCount(remainingFiles)} still in pipeline";
            return "waiting for latest worker status";
        }

        return remainingFiles > 0
            ? $"{FormatCount(remainingFiles)} still in pipeline"
            : "all file work complete";
    }

    private static string BatchTitle(IngestionOperationsBatchViewModel batch)
    {
        if (batch.BatchId != Guid.Empty)
            return $"Update {batch.BatchId.ToString("N")[..6]}";
        return "Update";
    }

    private static string BatchActivityHref(IngestionOperationsBatchViewModel batch) =>
        batch.BatchId == Guid.Empty
            ? "/settings/activity"
            : $"/settings/activity?batchId={batch.BatchId:D}";

    private static string FormatEnrichmentValue(LibraryUpdateStatusViewModel model) =>
        FormatCount(model.EnrichmentCompleted);

    private static string FormatExpectedReview(LibraryUpdateStatusViewModel model) =>
        model.UnexpectedReviewItems > 0
            ? $"{FormatCount(model.UnexpectedReviewItems)} unexpected"
            : $"{FormatCount(model.ExpectedReviewItems)} expected";

    private static string FormatReviewAttentionText(LibraryUpdateStatusViewModel model) =>
        model.UnexpectedReviewItems > 0
            ? $"{FormatCount(model.UnexpectedReviewItems)} unexpected items need review; {FormatCount(model.ExpectedReviewItems)} were expected by the harness."
            : model.ExpectedReviewItems > 0
                ? $"{FormatCount(model.ReviewItems)} expected items need review before they can be fully added."
                : $"{FormatCount(model.ReviewItems)} items need review before they can be fully added.";

    private static string FormatPercent(double percent) =>
        $"{Math.Clamp(percent, 0, 100).ToString("0", CultureInfo.CurrentCulture)}%";

    private static string EnrichmentChipClass(LibraryUpdateEnrichmentStatViewModel stat) =>
        $"library-update-enrichment-chip is-{stat.Tone}";

    private static string ActivityRowClass(IngestionCurrentActivityViewModel activity) =>
        $"library-update-now-row is-{ActivityTone(activity)}";

    private static string ActivityIcon(IngestionCurrentActivityViewModel activity)
    {
        var value = ActivityKey(activity);
        if (value.Contains("enhancer"))
            return Icons.Material.Outlined.AutoAwesome;
        if (value.Contains("art") || value.Contains("cover"))
            return Icons.Material.Outlined.ImageSearch;
        if (value.Contains("people") || value.Contains("cast"))
            return Icons.Material.Outlined.Groups;
        if (value.Contains("relationship") || value.Contains("series") || value.Contains("universe"))
            return Icons.Material.Outlined.Hub;
        if (value.Contains("retail") || value.Contains("identity") || value.Contains("match") || value.Contains("wikidata") || value.Contains("qid"))
            return Icons.Material.Outlined.Link;
        if (value.Contains("description") || value.Contains("summary"))
            return Icons.Material.Outlined.Article;
        if (value.Contains("scan") || value.Contains("read") || value.Contains("parse"))
            return Icons.Material.Outlined.FolderOpen;

        return Icons.Material.Outlined.AutoAwesome;
    }

    private static string ActivityLabel(IngestionCurrentActivityViewModel activity)
    {
        var value = ActivityKey(activity);
        if (value.Contains("enhancer"))
            return "Artwork, people & relationships";
        if (value.Contains("art") || value.Contains("cover"))
            return "Artwork lookup";
        if (value.Contains("people") || value.Contains("cast"))
            return "People enrichment";
        if (value.Contains("relationship") || value.Contains("series") || value.Contains("universe"))
            return "Relationships";
        if (value.Contains("retail") || value.Contains("identity") || value.Contains("match") || value.Contains("wikidata") || value.Contains("qid"))
            return "Identity match";
        if (value.Contains("description") || value.Contains("summary"))
            return "Descriptions";

        return FirstNonBlank(activity.Message, activity.Detail, "Worker activity");
    }

    private static string ActivityCurrentItem(IngestionCurrentActivityViewModel activity) =>
        FirstNonBlank(
            activity.CurrentItem,
            activity.CurrentBatch?.ActiveItems.FirstOrDefault(),
            activity.SampleItems.FirstOrDefault(),
            activity.Detail,
            activity.Source,
            "Working");

    private static string ActivityTone(IngestionCurrentActivityViewModel activity)
    {
        var value = ActivityKey(activity);
        if (value.Contains("enhancer"))
            return "purple";
        if (value.Contains("art") || value.Contains("cover"))
            return "pink";
        if (value.Contains("people") || value.Contains("cast"))
            return "amber";
        if (value.Contains("relationship") || value.Contains("series") || value.Contains("universe"))
            return "green";
        if (value.Contains("retail") || value.Contains("identity") || value.Contains("match") || value.Contains("wikidata") || value.Contains("qid"))
            return "blue";
        return "purple";
    }

    private static int ActivitySort(IngestionCurrentActivityViewModel activity)
    {
        var value = ActivityKey(activity);
        if (value.Contains("enhancer"))
            return 25;
        if (value.Contains("art") || value.Contains("cover"))
            return 10;
        if (value.Contains("people") || value.Contains("cast"))
            return 20;
        if (value.Contains("relationship") || value.Contains("series") || value.Contains("universe"))
            return 30;
        if (value.Contains("description") || value.Contains("summary"))
            return 40;
        if (value.Contains("retail") || value.Contains("identity") || value.Contains("match") || value.Contains("wikidata") || value.Contains("qid"))
            return 50;
        return 90;
    }

    private static string ActivityKey(IngestionCurrentActivityViewModel activity) =>
        string.Join(' ', activity.StageKey, activity.Message, activity.Detail, activity.MetricValue)
            .ToLowerInvariant();

    private static RenderFragment BatchHeader(string label, string icon, string tone) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", $"library-update-batch-head-chip is-{tone}");
        builder.OpenComponent<MudIcon>(sequence++);
        builder.AddAttribute(sequence++, "Icon", icon);
        builder.CloseComponent();
        builder.OpenElement(sequence++, "span");
        builder.AddContent(sequence++, label);
        builder.CloseElement();
        builder.CloseElement();
    };

    private static RenderFragment BatchCountChip(int count, string icon, string tone) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", $"library-update-batch-count is-{tone}");
        builder.OpenComponent<MudIcon>(sequence++);
        builder.AddAttribute(sequence++, "Icon", icon);
        builder.CloseComponent();
        builder.OpenElement(sequence++, "strong");
        builder.AddContent(sequence++, FormatCount(count));
        builder.CloseElement();
        builder.CloseElement();
    };

    private static string BatchStatusClass(string? status) =>
        $"library-update-batch-status is-{BatchStatusTone(status)}";

    private static string BatchStatusLabel(string? status) =>
        string.IsNullOrWhiteSpace(status)
            ? "Unknown"
            : CultureInfo.CurrentCulture.TextInfo.ToTitleCase(status.Replace('_', ' '));

    private static string BatchStatusTone(string? status)
    {
        var value = status ?? string.Empty;
        if (value.Contains("complete", StringComparison.OrdinalIgnoreCase))
            return "success";
        if (value.Contains("run", StringComparison.OrdinalIgnoreCase) || value.Contains("active", StringComparison.OrdinalIgnoreCase))
            return "info";
        if (value.Contains("fail", StringComparison.OrdinalIgnoreCase))
            return "danger";
        if (value.Contains("review", StringComparison.OrdinalIgnoreCase) || value.Contains("partial", StringComparison.OrdinalIgnoreCase))
            return "warning";
        return "neutral";
    }

    private static string FormatRelative(DateTimeOffset value)
    {
        var elapsed = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (elapsed.TotalSeconds < 60)
            return "just now";
        if (elapsed.TotalMinutes < 60)
            return $"{(int)elapsed.TotalMinutes}m ago";
        if (elapsed.TotalHours < 24)
            return $"{(int)elapsed.TotalHours}h ago";
        return value.ToLocalTime().ToString("MMM d, h:mm tt", CultureInfo.CurrentCulture);
    }

    private static string FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? string.Empty;

    private static string FormatCount(int value) => value.ToString("N0", CultureInfo.CurrentCulture);
}
