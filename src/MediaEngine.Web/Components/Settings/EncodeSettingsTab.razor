@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Contracts.Playback
@using MediaEngine.Contracts.Settings
@using MediaEngine.Web.Services.Integration
@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar

<div class="tl-page encode-settings">
    <AppPageHeader Title="Encode Settings"
                   Subtitle="Server-side controls for scheduled encodes, HLS fallback packages, and mobile-ready variants." />

    <div class="encode-settings__grid">
        <AppCard Title="Scheduling">
            <AppSwitchRow @bind-Value="_scheduledEncodesEnabled"
                          Label="Enable scheduled encodes" />
            <AppTextField @bind-Value="_maintenanceWindow"
                          Label="Maintenance window" />
            <AppNumericField @bind-Value="_maxConcurrentJobs"
                             Label="Maximum active jobs"
                             Min="1"
                             Max="4" />
            <AppSelect @bind-Value="_hardwarePreference"
                       Label="Hardware preference"
                       Options="@HardwareOptions" />
        </AppCard>

        <AppCard Title="Storage Policy">
            <AppTextField @bind-Value="_variantRoot"
                          Label="Variant cache location" />
            <AppNumericField @bind-Value="_cacheSizeGb"
                             Label="Cache size limit (GB)"
                             Min="1"
                             Max="5000" />
            <AppNumericField @bind-Value="_retentionDays"
                             Label="Retention days"
                             Min="1"
                             Max="3650" />
            <AppSwitchRow @bind-Value="_cleanupLru"
                          Label="Use least-recently-used cleanup before deleting old variants" />
        </AppCard>
    </div>

    <AppCard Title="Profiles"
             Class="encode-settings__profiles">
        <Actions>
            <AppButton Label="Add profile"
                       StartIcon="@Icons.Material.Outlined.Add"
                       Tone="AppUiTone.Primary"
                       OnClick="@AddProfile" />
        </Actions>
        <ChildContent>
            <AppTable>
                <thead>
                    <tr>
                        <th>Profile</th>
                        <th>Target</th>
                        <th>Codec</th>
                        <th>Container</th>
                        <th>Size guidance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var profile in _settings.QualityProfiles)
                    {
                        <tr>
                            <td>@profile.Name</td>
                            <td>@profile.Resolution</td>
                            <td>@profile.Codec / @profile.AudioCodec</td>
                            <td>@profile.Container</td>
                            <td>@profile.SizeGuidance</td>
                        </tr>
                    }
                </tbody>
            </AppTable>
        </ChildContent>
    </AppCard>

    <AppCard Title="Diagnostics">
        @if (_diagnostics is null)
        {
            <AppAlert Tone="AppUiTone.Info">Diagnostics unavailable.</AppAlert>
        }
        else
        {
            <div class="encode-settings__diagnostics">
                <AppMetricCard Label="FFmpeg"
                               Value="@(_diagnostics.FFmpegAvailable ? "Available" : "Unavailable")"
                               Tone="@(_diagnostics.FFmpegAvailable ? AppStatusTone.Success : AppStatusTone.Warning)" />
                <AppMetricCard Label="MediaInfo"
                               Value="@(_diagnostics.MediaInfoAvailable ? "Available" : "Unavailable")"
                               Tone="@(_diagnostics.MediaInfoAvailable ? AppStatusTone.Success : AppStatusTone.Warning)" />
                <AppMetricCard Label="Active jobs"
                               Value="@_diagnostics.ActiveJobs.Count.ToString()" />
            </div>
        }
    </AppCard>

    <AppButton Label="@(_saving ? "Saving..." : "Save Encode Settings")"
               ButtonStyle="AppButtonStyle.Filled"
               Tone="AppUiTone.Primary"
               FullWidth="true"
               Disabled="@_saving"
               OnClick="@SaveAsync" />
</div>

@code {
    private static readonly IReadOnlyList<AppSelectOption> HardwareOptions =
    [
        new("auto", "Auto"),
        new("cpu", "CPU"),
        new("gpu", "GPU when available"),
    ];

    private TranscodingSettings _settings = new();
    private bool _saving;
    private bool _scheduledEncodesEnabled = true;
    private string _maintenanceWindow = "01:00-05:00";
    private int _maxConcurrentJobs = 1;
    private string _hardwarePreference = "auto";
    private string _variantRoot = ".data/variants";
    private int _cacheSizeGb = 250;
    private int _retentionDays = 30;
    private bool _cleanupLru = true;
    private PlaybackDiagnosticsDto? _diagnostics;

    protected override async Task OnInitializedAsync()
    {
        _settings = await ApiClient.GetTranscodingSettingsAsync() ?? new TranscodingSettings();
        HydrateForm(_settings);
        _diagnostics = await ApiClient.GetPlaybackDiagnosticsAsync();
    }

    private void AddProfile() =>
        Snackbar.Add("Profile creation UI is next; existing profiles now persist through config/transcoding.json.", Severity.Info);

    private async Task SaveAsync()
    {
        _saving = true;
        ApplyForm(_settings);
        var saved = await ApiClient.SaveTranscodingSettingsAsync(_settings);
        _saving = false;

        if (saved is null)
        {
            Snackbar.Add("Encode settings could not be saved.", Severity.Error);
            return;
        }

        _settings = saved;
        HydrateForm(_settings);
        Snackbar.Add("Encode settings saved.", Severity.Success);
    }

    private void HydrateForm(TranscodingSettings settings)
    {
        _scheduledEncodesEnabled = settings.ScheduledEncodesEnabled;
        _maintenanceWindow = settings.MaintenanceWindow;
        _maxConcurrentJobs = settings.MaxConcurrentTranscodes;
        _hardwarePreference = settings.HardwareAcceleration;
        _variantRoot = settings.VariantCachePath;
        _cacheSizeGb = settings.ShadowStorageLimitGb;
        _retentionDays = settings.VariantRetentionDays;
        _cleanupLru = settings.CleanupLruEnabled;
    }

    private void ApplyForm(TranscodingSettings settings)
    {
        settings.ScheduledEncodesEnabled = _scheduledEncodesEnabled;
        settings.MaintenanceWindow = _maintenanceWindow;
        settings.MaxConcurrentTranscodes = _maxConcurrentJobs;
        settings.HardwareAcceleration = _hardwarePreference;
        settings.VariantCachePath = _variantRoot;
        settings.ShadowStorageLimitGb = _cacheSizeGb;
        settings.VariantRetentionDays = _retentionDays;
        settings.CleanupLruEnabled = _cleanupLru;
    }
}
