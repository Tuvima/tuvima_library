@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar

<div class="st-page user-overview-page">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else if (_overview is null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Your overview is not available yet. Profile details will appear here when the Engine is online.
        </MudAlert>
    }
    else
    {
        var profile = _overview.Profile;
        var initials = GetInitials(_displayName);

        <section class="user-overview-hero">
            <div class="user-overview-profile">
                <div class="user-overview-avatar" style="@($"--avatar-color: {_avatarColor}")">
                    <span>@initials</span>
                </div>

                <div class="user-overview-identity">
                    <MudTextField @bind-Value="_displayName"
                                  Variant="Variant.Text"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  MaxLength="64"
                                  Disabled="_savingProfile"
                                  Class="user-overview-name-field" />

                    <MudText Typo="Typo.body1" Class="user-overview-subtitle">Personal overview</MudText>

                    <div class="user-overview-badges">
                        <span>@profile.Role</span>
                        <span>Joined @profile.CreatedAt.ToLocalTime().ToString("MMM yyyy")</span>
                        <span>@_overview.Stats.TotalItems tracked items</span>
                    </div>

                    <div class="user-overview-swatches" aria-label="Avatar color">
                        @foreach (var color in AvatarColors)
                        {
                            <button type="button"
                                    class="@AvatarSwatchClass(color)"
                                    style="@($"--swatch-color: {color}")"
                                    title="@color"
                                    disabled="@_savingProfile"
                                    @onclick="() => SelectAvatarColor(color)">
                            </button>
                        }
                    </div>

                    @if (ProfileDirty)
                    {
                        <div class="user-overview-inline-actions">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Disabled="@(_savingProfile || string.IsNullOrWhiteSpace(_displayName))"
                                       OnClick="@SaveProfileAsync">
                                Save
                            </MudButton>
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Inherit"
                                       Size="Size.Small"
                                       Disabled="@_savingProfile"
                                       OnClick="@CancelProfileEdit">
                                Cancel
                            </MudButton>
                        </div>
                    }
                </div>
            </div>

            <MudPaper Elevation="0" Class="user-overview-glance">
                <div class="user-overview-panel-header">
                    <MudText Typo="Typo.h6">At a Glance</MudText>
                    <MudText Typo="Typo.caption" Class="user-overview-muted">This profile</MudText>
                </div>
                <div class="user-overview-glance-grid">
                    @foreach (var item in AtAGlanceItems())
                    {
                        <div class="user-overview-glance-item">
                            <MudIcon Icon="@item.Icon" />
                            <span>@item.Label</span>
                            <strong>@item.Value</strong>
                        </div>
                    }
                </div>
            </MudPaper>
        </section>

        <section class="user-overview-statistics">
            <MudText Typo="Typo.h6">Your Statistics</MudText>
            <div class="user-overview-stat-grid">
                <MudPaper Elevation="0" Class="user-overview-panel">
                    <div class="user-overview-panel-header">
                        <MudText Typo="Typo.subtitle1">Content Library</MudText>
                    </div>
                    <DictionaryRows Items="@LibraryCounts()" EmptyText="Library totals are not available yet." />
                </MudPaper>

                <MudPaper Elevation="0" Class="user-overview-panel user-overview-panel--emphasis">
                    <div class="user-overview-panel-header">
                        <MudText Typo="Typo.subtitle1">Time Tracked</MudText>
                        <MudText Typo="Typo.caption" Class="user-overview-muted">From saved progress</MudText>
                    </div>
                    <div class="user-overview-time-total">@FormatDuration(_overview.Stats.ConsumedSeconds)</div>
                    <DictionaryRows Items="@ConsumedByMediaType()" EmptyText="Time appears after playback or reading progress is saved." Suffix="min" />
                </MudPaper>

                <MudPaper Elevation="0" Class="user-overview-panel">
                    <div class="user-overview-panel-header">
                        <MudText Typo="Typo.subtitle1">Activity</MudText>
                    </div>
                    <DictionaryRows Items="@_overview.Stats.ActivityBuckets" EmptyText="No personal activity has been recorded." />
                </MudPaper>
            </div>
        </section>

        <section class="user-overview-dashboard">
            <MudPaper Elevation="0" Class="user-overview-panel user-overview-panel--wide">
                <div class="user-overview-panel-header">
                    <div>
                        <MudText Typo="Typo.overline">Continue</MudText>
                        <MudText Typo="Typo.h6">Continue Watching, Reading, Listening</MudText>
                    </div>
                </div>
                <MediaRail Items="@_overview.ContinueItems" EmptyText="Nothing is currently in progress." />
            </MudPaper>

            <MudPaper Elevation="0" Class="user-overview-panel">
                <div class="user-overview-panel-header">
                    <div>
                        <MudText Typo="Typo.overline">Taste</MudText>
                        <MudText Typo="Typo.h6">Top Genres</MudText>
                    </div>
                </div>
                <MudText Typo="Typo.body2" Class="user-overview-muted">
                    @(_overview.Taste?.Summary ?? "Taste signals will appear after the library has enough activity.")
                </MudText>
                <DictionaryRows Items="@TopGenres()" EmptyText="No genre signals yet." />
            </MudPaper>

            <MudPaper Elevation="0" Class="user-overview-panel user-overview-panel--wide">
                <div class="user-overview-panel-header">
                    <div>
                        <MudText Typo="Typo.overline">History</MudText>
                        <MudText Typo="Typo.h6">Recently Watched, Read, or Played</MudText>
                    </div>
                </div>
                <MediaRail Items="@_overview.RecentItems" EmptyText="Your recent history is empty." />
            </MudPaper>

            <MudPaper Elevation="0" Class="user-overview-panel">
                <div class="user-overview-panel-header">
                    <div>
                        <MudText Typo="Typo.overline">Mix</MudText>
                        <MudText Typo="Typo.h6">Media Type Mix</MudText>
                    </div>
                </div>
                <DictionaryRows Items="@_overview.Stats.MediaTypeMix" EmptyText="No media mix yet." />
            </MudPaper>

            <MudPaper Elevation="0" Class="user-overview-panel user-overview-panel--wide">
                <div class="user-overview-panel-header">
                    <div>
                        <MudText Typo="Typo.overline">Completed</MudText>
                        <MudText Typo="Typo.h6">Finished Recently</MudText>
                    </div>
                </div>
                <MediaRail Items="@_overview.CompletedItems" EmptyText="Completed items will appear here." />
            </MudPaper>

            <MudPaper Elevation="0" Class="user-overview-panel">
                <div class="user-overview-panel-header">
                    <div>
                        <MudText Typo="Typo.overline">Recently Added</MudText>
                        <MudText Typo="Typo.h6">New In Library</MudText>
                    </div>
                </div>
                <MediaRail Items="@_overview.RecentlyAddedItems" EmptyText="Recently added items will appear when library dates are available." />
            </MudPaper>
        </section>
    }
</div>

@code {
    private static readonly string[] AvatarColors =
    [
        "#C9922E",
        "#7C4DFF",
        "#2E7CF6",
        "#22C55E",
        "#EF3D73",
        "#06B6D4",
    ];

    private bool _loading = true;
    private bool _savingProfile;
    private ProfileOverviewViewModel? _overview;
    private string _displayName = string.Empty;
    private string _savedDisplayName = string.Empty;
    private string _avatarColor = "#7C4DFF";
    private string _savedAvatarColor = "#7C4DFF";

    private bool ProfileDirty =>
        !string.Equals(_displayName.Trim(), _savedDisplayName, StringComparison.Ordinal)
        || !string.Equals(_avatarColor, _savedAvatarColor, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var profile = await Orchestrator.GetActiveProfileAsync();
        if (profile is not null)
        {
            _overview = await ApiClient.GetProfileOverviewAsync(profile.Id);
            if (_overview is null)
                _overview = new ProfileOverviewViewModel { Profile = profile };

            SyncProfileEditor(_overview.Profile);
        }

        _loading = false;
    }

    private async Task SaveProfileAsync()
    {
        if (_overview is null || string.IsNullOrWhiteSpace(_displayName))
            return;

        _savingProfile = true;
        var current = _overview.Profile;
        var ok = await Orchestrator.UpdateProfileAsync(
            current.Id,
            _displayName.Trim(),
            _avatarColor,
            current.Role,
            current.NavigationConfig);

        if (ok)
        {
            var updated = current with { DisplayName = _displayName.Trim(), AvatarColor = _avatarColor };
            _overview.Profile = updated;
            SyncProfileEditor(updated);
            Snackbar.Add("Profile updated.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Could not save profile.", Severity.Error);
        }

        _savingProfile = false;
    }

    private void CancelProfileEdit()
    {
        _displayName = _savedDisplayName;
        _avatarColor = _savedAvatarColor;
    }

    private void SelectAvatarColor(string color) => _avatarColor = color;

    private void SyncProfileEditor(ProfileViewModel profile)
    {
        _displayName = profile.DisplayName;
        _savedDisplayName = profile.DisplayName;
        _avatarColor = string.IsNullOrWhiteSpace(profile.AvatarColor) ? "#7C4DFF" : profile.AvatarColor;
        _savedAvatarColor = _avatarColor;
    }

    private IReadOnlyDictionary<string, int> LibraryCounts() =>
        _overview?.Stats.LibraryCounts.Count > 0
            ? _overview.Stats.LibraryCounts
            : _overview?.Stats.MediaTypeMix ?? new Dictionary<string, int>();

    private IReadOnlyDictionary<string, int> TopGenres()
    {
        if (_overview?.Stats.TopGenres.Count > 0)
            return _overview.Stats.TopGenres;

        return _overview?.Taste?.GenreDistribution
            .OrderByDescending(item => item.Value)
            .Take(6)
            .ToDictionary(item => item.Key, item => (int)Math.Round(item.Value * 100), StringComparer.OrdinalIgnoreCase)
            ?? new Dictionary<string, int>();
    }

    private IReadOnlyDictionary<string, int> ConsumedByMediaType() =>
        _overview?.Stats.ConsumedSecondsByMediaType
            .Where(item => item.Value > 0)
            .OrderByDescending(item => item.Value)
            .ToDictionary(item => item.Key, item => (int)Math.Round(item.Value / 60), StringComparer.OrdinalIgnoreCase)
        ?? new Dictionary<string, int>();

    private IEnumerable<GlanceItem> AtAGlanceItems()
    {
        if (_overview is null)
            yield break;

        var counts = LibraryCounts().OrderByDescending(item => item.Value).Take(3).ToList();
        var icons = new[] { Icons.Material.Outlined.Movie, Icons.Material.Outlined.Tv, Icons.Material.Outlined.MenuBook };
        for (var i = 0; i < counts.Count; i++)
            yield return new GlanceItem(counts[i].Key, counts[i].Value.ToString("N0"), icons[i]);

        yield return new GlanceItem("In progress", _overview.Stats.InProgress.ToString("N0"), Icons.Material.Outlined.PlayCircle);
        yield return new GlanceItem("Completed", _overview.Stats.Completed.ToString("N0"), Icons.Material.Outlined.CheckCircle);
        yield return new GlanceItem("Tracked time", FormatDuration(_overview.Stats.ConsumedSeconds), Icons.Material.Outlined.Schedule);
    }

    private string AvatarSwatchClass(string color) =>
        string.Equals(color, _avatarColor, StringComparison.OrdinalIgnoreCase)
            ? "user-overview-swatch user-overview-swatch--selected"
            : "user-overview-swatch";

    private static string FormatDuration(double seconds)
    {
        if (seconds <= 0)
            return "0m";

        var totalMinutes = (int)Math.Round(seconds / 60);
        var hours = totalMinutes / 60;
        var minutes = totalMinutes % 60;
        return hours > 0 ? $"{hours}h {minutes}m" : $"{minutes}m";
    }

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][0].ToString().ToUpperInvariant(),
            _ => string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0]))),
        };
    }

    private readonly record struct GlanceItem(string Label, string Value, string Icon);
}
