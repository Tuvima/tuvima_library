@namespace MediaEngine.Web.Components.Settings
@using Microsoft.AspNetCore.Components.Forms
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar

<div class="tl-page user-overview-page">
    @if (_loading)
    {
        <MudStack Spacing="2">
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            <MudSkeleton Height="180px" Animation="Animation.Wave" />
            <MudSkeleton Height="220px" Animation="Animation.Wave" />
        </MudStack>
    }
    else if (_overview is null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Your overview is not available yet. Profile details will appear here when the Engine is online.
        </MudAlert>
    }
    else
    {
        var profile = _overview.Profile;

        <MudGrid Spacing="3" Class="user-overview-grid">
            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Class="tl-card settings-section-card user-overview-card user-overview-profile-card">
                    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Class="user-overview-profile-layout">
                        <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="user-overview-avatar-wrap">
                            <MudFileUpload T="IBrowserFile"
                                           Accept=".jpg,.jpeg,.png,.webp"
                                           FilesChanged="@UploadAvatarAsync"
                                           MaximumFileCount="1"
                                           Disabled="@_uploadingAvatar">
                                <CustomContent>
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Inherit"
                                               Class="user-overview-avatar-button"
                                               Disabled="@_uploadingAvatar"
                                               OnClick="@context.OpenFilePickerAsync"
                                               aria-label="Edit profile photo">
                                        <MudAvatar Size="Size.Large"
                                                   Color="Color.Primary"
                                                   Class="user-overview-avatar">
                                @if (!string.IsNullOrWhiteSpace(profile.AvatarImageUrl))
                                {
                                                <img src="@profile.AvatarImageUrl" alt="" class="user-overview-avatar-image" />
                                }
                                else
                                {
                                    @GetInitials(profile.DisplayName)
                                }
                                        </MudAvatar>
                                        <span class="user-overview-avatar-edit-badge">
                                            <MudIcon Icon="@Icons.Material.Outlined.PhotoCamera" Size="Size.Small" />
                                        </span>
                                    </MudButton>
                                </CustomContent>
                            </MudFileUpload>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @(_uploadingAvatar ? "Uploading" : "Edit photo")
                            </MudText>
                        </MudStack>

                        <MudStack Spacing="2" Class="flex-grow-1 user-overview-profile-copy">
                            @if (_editingName)
                            {
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="user-overview-name-edit">
                                    <MudTextField @bind-Value="_displayName"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Immediate="true"
                                                  MaxLength="64"
                                                  Disabled="_savingProfile"
                                                  Class="user-overview-name-field"
                                                  aria-label="Display name" />
                                    <MudIconButton Icon="@Icons.Material.Outlined.Check"
                                                   Color="Color.Success"
                                                   Size="Size.Small"
                                                   Disabled="@(_savingProfile || string.IsNullOrWhiteSpace(_displayName) || !ProfileDirty)"
                                                   OnClick="@SaveProfileAsync"
                                                   aria-label="Save display name" />
                                    <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                                   Color="Color.Default"
                                                   Size="Size.Small"
                                                   Disabled="_savingProfile"
                                                   OnClick="@CancelNameEdit"
                                                   aria-label="Cancel display name edit" />
                                </MudStack>
                            }
                            else
                            {
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="user-overview-name-row">
                                    <MudText Typo="Typo.h5" Class="user-overview-profile-name">@profile.DisplayName</MudText>
                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                                   Size="Size.Small"
                                                   Color="Color.Default"
                                                   Class="user-overview-inline-edit"
                                                   OnClick="@StartNameEdit"
                                                   aria-label="Edit display name" />
                                </MudStack>
                            }

                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="user-overview-role-row">
                                <MudIcon Icon="@Icons.Material.Outlined.Shield" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@profile.Role</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="user-overview-joined">
                                Joined @profile.CreatedAt.ToLocalTime().ToString("MMMM yyyy")
                            </MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Class="tl-card settings-section-card user-overview-card user-overview-stat-strip">
                    <MudGrid Spacing="2" Class="user-overview-stats-grid">
                        @foreach (var stat in StatItems())
                        {
                            <MudItem xs="12" sm="6" lg="3">
                                <MudStack Spacing="1" Class="user-overview-stat-card">
                                    <MudAvatar Color="@stat.Color" Variant="Variant.Filled" Class="user-overview-stat-icon">
                                        <MudIcon Icon="@stat.Icon" Size="Size.Small" />
                                    </MudAvatar>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@stat.Label</MudText>
                                    <MudText Typo="Typo.h4" Class="user-overview-stat-value">@stat.Value</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@stat.Subtitle</MudText>
                                </MudStack>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Class="tl-card settings-section-card user-overview-card user-overview-continue-card">
                    <MudText Typo="Typo.h6" Class="settings-card-title mb-3">Continue Your Activity</MudText>
                    <MediaRail Items="@_overview.ContinueItems" EmptyText="Nothing is currently in progress." ShowContinuation="true" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Class="tl-card settings-section-card user-overview-card user-overview-history-card">
                    <MudText Typo="Typo.h6" Class="settings-card-title mb-3">Recent History</MudText>
                    @if (_overview.RecentItems.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Your recent history is empty.</MudText>
                    }
                    else
                    {
                        <MudList T="ProfileOverviewItemViewModel" Dense="true">
                            @foreach (var item in _overview.RecentItems.Take(5))
                            {
                                <MudListItem Href="@item.Route" Class="user-overview-history-row">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="2">
                                        @ItemThumb(item)
                                        <MudStack Spacing="0" Class="flex-grow-1 min-w-0">
                                            <MudText Typo="Typo.body2">@item.Title</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @(item.Subtitle ?? item.CollectionName ?? FriendlyMediaType(item.MediaType))
                                            </MudText>
                                        </MudStack>
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@RelativeTime(item.LastAccessed)</MudText>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@FriendlyMediaType(item.MediaType)</MudChip>
                                        </MudStack>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Class="tl-card settings-section-card user-overview-card user-overview-taste-card">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h6" Class="settings-card-title">Your Taste / Top Genres</MudText>
                        <MudTooltip Text="Reset personalization is not available until the Engine exposes a reset endpoint.">
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Disabled="true">
                                Reset personalization
                            </MudButton>
                        </MudTooltip>
                    </MudStack>

                    @{
                        var genres = TopGenres().Take(6).ToList();
                    }
                    @if (genres.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Taste signals will appear after you use the library more.</MudText>
                    }
                    else
                    {
                        <MudGrid Spacing="2">
                            @foreach (var genre in genres)
                            {
                                var pct = NormalizeGenrePercent(genre.Value, genres);
                                <MudItem xs="12" sm="6">
                                    <MudStack Spacing="1" Class="user-overview-genre-row">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.body2">@genre.Key</MudText>
                                            <MudText Typo="Typo.body2">@($"{Math.Round(pct):0}%")</MudText>
                                        </MudStack>
                                        <MudProgressLinear Value="@pct" Color="Color.Primary" Rounded="true" Class="user-overview-mini-bar" />
                                    </MudStack>
                                </MudItem>
                            }
                        </MudGrid>
                        <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-3">
                            Based on your activity from the last 90 days.
                        </MudText>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Class="tl-card settings-section-card user-overview-card user-overview-compact-list-card">
                    <MudText Typo="Typo.h6" Class="settings-card-title mb-3">@CompactListTitle</MudText>
                    @if (CompactListItems.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Completed or recently added items will appear here.</MudText>
                    }
                    else
                    {
                        <MudList T="ProfileOverviewItemViewModel" Dense="true">
                            @foreach (var item in CompactListItems.Take(4))
                            {
                                <MudListItem Href="@item.Route" Class="user-overview-history-row">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="2">
                                        @ItemThumb(item)
                                        <MudStack Spacing="0" Class="flex-grow-1 min-w-0">
                                            <MudText Typo="Typo.body2">@item.Title</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@RelativeTime(CompactListDate(item))</MudText>
                                        </MudStack>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@FriendlyMediaType(item.MediaType)</MudChip>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</div>

@code {
    private bool _loading = true;
    private bool _savingProfile;
    private bool _uploadingAvatar;
    private bool _editingName;
    private ProfileOverviewViewModel? _overview;
    private string _displayName = string.Empty;
    private string _savedDisplayName = string.Empty;

    private bool ProfileDirty =>
        !string.Equals(_displayName.Trim(), _savedDisplayName, StringComparison.Ordinal);

    private string CompactListTitle =>
        _overview?.CompletedItems.Count > 0 ? "Recently Completed" : "Recently Added";

    private IReadOnlyList<ProfileOverviewItemViewModel> CompactListItems =>
        _overview?.CompletedItems.Count > 0
            ? _overview.CompletedItems
            : _overview?.RecentlyAddedItems ?? [];

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            var profile = await Orchestrator.GetActiveProfileAsync();
            if (profile is not null)
            {
                _overview = await ApiClient.GetProfileOverviewAsync(profile.Id);
                if (_overview is null)
                    _overview = new ProfileOverviewViewModel { Profile = profile };

                SyncProfileEditor(_overview.Profile);
            }
        }
        catch
        {
            _overview = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartNameEdit()
    {
        if (_overview is null)
            return;

        SyncProfileEditor(_overview.Profile);
        _editingName = true;
    }

    private void CancelNameEdit()
    {
        _displayName = _savedDisplayName;
        _editingName = false;
    }

    private async Task SaveProfileAsync()
    {
        if (_overview is null || string.IsNullOrWhiteSpace(_displayName))
            return;

        _savingProfile = true;
        var current = _overview.Profile;
        var ok = await Orchestrator.UpdateProfileAsync(
            current.Id,
            _displayName.Trim(),
            current.AvatarColor,
            current.Role,
            current.NavigationConfig);

        if (ok)
        {
            var updated = current with { DisplayName = _displayName.Trim() };
            _overview.Profile = updated;
            SyncProfileEditor(updated);
            _editingName = false;
            Snackbar.Add("Profile updated.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Could not save profile.", Severity.Error);
        }

        _savingProfile = false;
    }

    private async Task UploadAvatarAsync(IBrowserFile file)
    {
        if (_overview is null)
            return;

        _uploadingAvatar = true;
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var updated = await Orchestrator.UploadProfileAvatarAsync(_overview.Profile.Id, stream, file.Name);
            if (updated is null)
            {
                Snackbar.Add("Could not upload profile photo.", Severity.Error);
                return;
            }

            _overview.Profile = updated;
            SyncProfileEditor(updated);
            Snackbar.Add("Profile photo updated.", Severity.Success);
        }
        catch (IOException)
        {
            Snackbar.Add("Profile photo must be 5 MB or smaller.", Severity.Error);
        }
        finally
        {
            _uploadingAvatar = false;
        }
    }

    private void SyncProfileEditor(ProfileViewModel profile)
    {
        _displayName = profile.DisplayName;
        _savedDisplayName = profile.DisplayName;
    }

    private IEnumerable<StatItem> StatItems()
    {
        if (_overview is null)
            yield break;

        yield return new StatItem("In Progress", _overview.Stats.InProgress.ToString("N0"), "Across all media", Icons.Material.Outlined.Bookmarks, Color.Info);
        yield return new StatItem("Completed", _overview.Stats.Completed.ToString("N0"), "Books, shows & more", Icons.Material.Outlined.CheckCircle, Color.Success);
        yield return new StatItem("Time Tracked", FormatDuration(_overview.Stats.ConsumedSeconds), "From saved progress", Icons.Material.Outlined.Schedule, Color.Warning);
        yield return new StatItem("Recent Activity", RecentActivityValue(), "Recently watched, read, or played", Icons.Material.Outlined.History, Color.Warning);
    }

    private string RecentActivityValue()
    {
        if (_overview is null)
            return "No activity yet";

        if (_overview.Stats.RecentActivity > 0)
            return _overview.Stats.RecentActivity.ToString("N0");

        return _overview.RecentItems.Count > 0
            ? RelativeTime(_overview.RecentItems.Max(item => item.LastAccessed))
            : "No activity yet";
    }

    private IReadOnlyDictionary<string, int> TopGenres()
    {
        if (_overview?.Stats.TopGenres.Count > 0)
            return _overview.Stats.TopGenres;

        return _overview?.Taste?.GenreDistribution
            .OrderByDescending(item => item.Value)
            .Take(6)
            .ToDictionary(item => item.Key, item => (int)Math.Round(item.Value * 100), StringComparer.OrdinalIgnoreCase)
            ?? new Dictionary<string, int>();
    }

    private static double NormalizeGenrePercent(int value, IReadOnlyList<KeyValuePair<string, int>> genres)
    {
        if (value <= 0)
            return 0;

        var max = genres.Count == 0 ? value : Math.Max(1, genres.Max(item => item.Value));
        if (max <= 100 && genres.Sum(item => item.Value) <= 100)
            return Math.Clamp(value, 0, 100);

        return Math.Clamp(value * 100d / max, 6d, 100d);
    }

    private static DateTimeOffset CompactListDate(ProfileOverviewItemViewModel item) =>
        item.AddedAt ?? item.LastAccessed;

    private static string FormatDuration(double seconds)
    {
        if (seconds <= 0)
            return "0m";

        var totalMinutes = (int)Math.Round(seconds / 60);
        var hours = totalMinutes / 60;
        var minutes = totalMinutes % 60;
        return hours > 0 ? $"{hours}h {minutes}m" : $"{minutes}m";
    }

    private static string RelativeTime(DateTimeOffset timestamp)
    {
        var elapsed = DateTimeOffset.UtcNow - timestamp.ToUniversalTime();
        if (elapsed.TotalMinutes < 1)
            return "Just now";
        if (elapsed.TotalMinutes < 60)
            return $"{Math.Max(1, (int)Math.Round(elapsed.TotalMinutes))}m ago";
        if (elapsed.TotalHours < 24)
            return $"{Math.Max(1, (int)Math.Round(elapsed.TotalHours))}h ago";
        if (elapsed.TotalDays < 2)
            return "Yesterday";
        if (elapsed.TotalDays < 30)
            return $"{Math.Max(2, (int)Math.Round(elapsed.TotalDays))} days ago";
        return timestamp.ToLocalTime().ToString("MMM d");
    }

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][0].ToString().ToUpperInvariant(),
            _ => string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0]))),
        };
    }

    private static string FriendlyMediaType(string mediaType)
    {
        var normalized = mediaType.Trim().ToLowerInvariant();
        if (normalized.Contains("audio") && normalized.Contains("book"))
            return "Audiobook";
        if (normalized.Contains("podcast"))
            return "Podcast";
        if (normalized.Contains("comic"))
            return "Comic";
        if (normalized.Contains("book") || normalized.Contains("epub"))
            return "Book";
        if (normalized.Contains("tv") || normalized.Contains("show") || normalized.Contains("episode"))
            return "TV";
        if (normalized.Contains("movie") || normalized.Contains("video"))
            return "Movie";
        if (normalized.Contains("music") || normalized.Contains("album") || normalized.Contains("song"))
            return "Music";
        return string.IsNullOrWhiteSpace(mediaType) ? "Media" : mediaType;
    }

    private static string MediaIcon(string mediaType) => FriendlyMediaType(mediaType) switch
    {
        "Book" => Icons.Material.Outlined.MenuBook,
        "Audiobook" or "Podcast" => Icons.Material.Outlined.Headphones,
        "Music" => Icons.Material.Outlined.Album,
        "TV" => Icons.Material.Outlined.Tv,
        "Movie" => Icons.Material.Outlined.Movie,
        "Comic" => Icons.Material.Outlined.AutoStories,
        _ => Icons.Material.Outlined.PlayCircle,
    };

    private static RenderFragment ItemThumb(ProfileOverviewItemViewModel item) => @<MudAvatar Rounded="true" Class="user-overview-item-thumb">
        @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
        {
            <img src="@item.CoverUrl" alt="" />
        }
        else
        {
            <MudIcon Icon="@MediaIcon(item.MediaType)" Size="Size.Small" />
        }
    </MudAvatar>;

    private readonly record struct StatItem(string Label, string Value, string Subtitle, string Icon, Color Color);
}
