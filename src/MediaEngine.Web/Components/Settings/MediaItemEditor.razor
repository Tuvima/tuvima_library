@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar
@inject ProviderCatalogueService CatalogueService

<MudDialog Class="eo-dialog">
    <TitleContent>
        <div class="eo-title-bar">
            <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Style="color: #C9922E; font-size: 1.2rem;" />
            <span class="eo-title">Media Item Editor</span>
            <span style="flex: 1;"></span>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@Cancel"
                           Style="color: rgba(248,248,248,0.6);" />
        </div>
    </TitleContent>

    <DialogContent>
        @* ── Tab bar (inside dialog body so MudBlazor can't clip it) ── *@
        <div class="eo-tab-bar">
            <button class="eo-tab @(_activeTab == 0 ? "eo-tab--on" : "")"
                    @onclick="@(() => SetTab(0))">Details</button>
            <button class="eo-tab @(_activeTab == 1 ? "eo-tab--on" : "")"
                    @onclick="@(() => SetTab(1))">Update Match</button>
            <button class="eo-tab @(_activeTab == 2 ? "eo-tab--on" : "")"
                    @onclick="@(() => SetTab(2))">History</button>
            <button class="eo-tab @(_activeTab == 3 ? "eo-tab--on" : "")"
                    @onclick="@(() => SetTab(3))">Images</button>
        </div>

        <div class="eo-body">
            @if (_activeTab == 0)
            {
                @* ══════════ DETAILS TAB ══════════ *@
                <div class="eo-meta-tab">
                    @if (_loadingMeta)
                    {
                        <div class="eo-status"><MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.15);" /></div>
                    }
                    else
                    {
                        @* ── Authority banner ── *@
                        <div class="eo-authority-banner">
                            <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Style="font-size: 0.9rem; color: rgba(201,146,46,0.7);" />
                            <span>Verified from authoritative sources</span>
                            @if (!string.IsNullOrEmpty(_wikidataQid))
                            {
                                <a href="https://www.wikidata.org/wiki/@_wikidataQid" target="_blank"
                                   class="eo-qid-chip" title="View on Wikidata">
                                    @_wikidataQid
                                    <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Style="font-size: 0.65rem;" />
                                </a>
                            }
                        </div>

                        @RenderGroupedFields()

                        @* ── File Tags section ── *@
                        @if (_fileTagClaims is { Count: > 0 })
                        {
                            <div class="eo-group" style="margin-top: 12px;">
                                <div class="eo-group-header">
                                    <MudIcon Icon="@Icons.Material.Outlined.InsertDriveFile" Style="font-size: 0.85rem; color: rgba(255,255,255,0.25);" />
                                    <span class="eo-group-title">Embedded File Tags</span>
                                </div>
                                @foreach (var claim in _fileTagClaims.Where(c => !HiddenKeys.Contains(c.Key)))
                                {
                                    <div class="eo-row">
                                        <span class="eo-row-label">@FormatFieldKey(claim.Key)</span>
                                        <span class="eo-row-value">@Truncate(claim.Value, 300)</span>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            }
            else if (_activeTab == 1)
            {
                @* ══════════ UPDATE MATCH TAB ══════════ *@
                <div class="eo-search-tab">
                    @* ── Search bar + media type dropdown ── *@
                    <div class="eo-search-row">
                        <MudTextField @bind-Value="_searchQuery" Placeholder="Search..."
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                      OnAdornmentClick="@OnSearch" OnKeyUp="@OnSearchKeyUp"
                                      Style="flex: 1; font-size: 0.85rem;"
                                      Disabled="@_searching" />

                        <MudSelect T="string" Value="_selectedMediaType" ValueChanged="OnMediaTypeChanged"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense" Dense="true"
                                   Style="min-width: 130px; max-width: 150px; font-size: 0.82rem;"
                                   AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                            @foreach (var mt in _mediaTypeOptions)
                            {
                                <MudSelectItem Value="@mt.Value">@mt.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </div>

                    @* ── Two-column: images (left 50%) + results (right 50%) ── *@
                    <div class="eo-search-columns" style="flex: 1; min-height: 0;">
                        @* ── Left: image gallery ── *@
                        <div class="eo-poster-col">
                            @if (_retailCovers.Count > 0)
                            {
                                @* ── Selected image large ── *@
                                <div class="eo-poster-frame">
                                    <img src="@_retailCovers[_selectedCoverIndex].CoverUrl"
                                         alt="Cover art"
                                         class="eo-poster-img" />
                                </div>

                                @* ── Thumbnail strip: all images ── *@
                                @if (_retailCovers.Count > 1)
                                {
                                    <div class="eo-thumb-strip">
                                        @for (var i = 0; i < _retailCovers.Count; i++)
                                        {
                                            var idx = i;
                                            <div class="eo-thumb @(idx == _selectedCoverIndex ? "eo-thumb--on" : "")"
                                                 @onclick="@(() => _selectedCoverIndex = idx)">
                                                <img src="@_retailCovers[idx].CoverUrl"
                                                     alt="Cover art" />
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else if (_loadingRetail)
                            {
                                <div class="eo-poster-frame eo-poster-frame--empty">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                                         Style="color: rgba(201,146,46,0.5);" />
                                </div>
                            }
                            else
                            {
                                <div class="eo-poster-frame eo-poster-frame--empty">
                                    <MudIcon Icon="@Icons.Material.Outlined.MenuBook"
                                             Style="font-size: 2.5rem; opacity: 0.08;" />
                                </div>
                            }
                        </div>

                        @* ── Right: scrollable results + sticky apply bar ── *@
                        <div style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                            <div class="eo-results-col" style="flex: 1; min-height: 0;">
                                @if (_searching)
                                {
                                    <div class="eo-status">
                                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: #C9922E;" />
                                        <span>Searching...</span>
                                    </div>
                                }
                                else if (_results is not null && _results.Count == 0)
                                {
                                    <div class="eo-status">
                                        <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Style="font-size: 2rem; opacity: 0.12;" />
                                        <span>No matches found</span>
                                    </div>
                                }
                                else if (_results is not null)
                                {
                                    @foreach (var item in _results)
                                    {
                                        var isHighlighted = _highlightedItem == item;
                                        var isApplied = _appliedItem == item;
                                        <div class="eo-result @(isHighlighted ? "eo-result--hl" : "") @(isApplied ? "eo-result--applied" : "")"
                                             @onclick="@(() => OnResultClicked(item))">
                                            @if (item.ResultType == "audiobook_edition")
                                            {
                                                <div class="eo-result-type eo-result-type--audiobook" title="Audiobook edition">
                                                    <MudIcon Icon="@Icons.Material.Filled.Headphones" Style="font-size: 1.1rem;" />
                                                </div>
                                            }
                                            else if (item.ResultType == "work")
                                            {
                                                <div class="eo-result-type eo-result-type--work" title="Literary work (no audiobook edition found)">
                                                    <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 1.1rem;" />
                                                </div>
                                            }
                                            <div class="eo-result-text">
                                                <span class="eo-result-title">@(item.Title ?? "Untitled")</span>
                                                @if (!string.IsNullOrEmpty(item.Description))
                                                {
                                                    <span class="eo-result-desc">@Truncate(item.Description, 120)</span>
                                                }
                                                @if (item.Confidence > 0)
                                                {
                                                    <span class="eo-result-conf">@((item.Confidence * 100).ToString("F0"))% match</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="eo-status">
                                        <MudIcon Icon="@Icons.Material.Outlined.TravelExplore"
                                                 Style="font-size: 2rem; opacity: 0.08;" />
                                        <span>Search to find a match</span>
                                    </div>
                                }
                            </div>

                            @* ── Sticky Apply bar ── *@
                            <div class="eo-apply-bar">
                                @if (_applying)
                                {
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: #C9922E;" />
                                }
                                else if (_appliedItem is not null && _confirmingItem is null)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle">Applied</MudChip>
                                }
                                else if (_confirmingItem is not null)
                                {
                                    <span style="font-family: var(--app-font-sans, 'Nunito', sans-serif); font-size: 0.8rem; color: rgba(255,255,255,0.6);">Confirm Apply?</span>
                                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                               OnClick="@(() => OnConfirmApply(_confirmingItem))"
                                               Disabled="@_applying">
                                        Confirm
                                    </MudButton>
                                    <MudButton Variant="Variant.Text" Size="Size.Small"
                                               OnClick="@(() => _confirmingItem = null)"
                                               Style="color: rgba(255,255,255,0.4);">
                                        Cancel
                                    </MudButton>
                                }
                                else if (_highlightedItem is not null)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               OnClick="@(() => _confirmingItem = _highlightedItem)">
                                        Apply
                                    </MudButton>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (_activeTab == 2)
            {
                @* ══════════ HISTORY TAB ══════════ *@
                <div class="eo-meta-tab">
                    @if (_loadingHistory)
                    {
                        <div class="eo-status">
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="color: rgba(255,255,255,0.15);" />
                        </div>
                    }
                    else if (_history.Count == 0)
                    {
                        <div class="eo-status" style="padding: 80px 0;">
                            <MudIcon Icon="@Icons.Material.Outlined.Timeline" Style="font-size: 2.5rem; opacity: 0.08;" />
                            <span>No processing history available</span>
                        </div>
                    }
                    else
                    {
                        <div class="history-timeline">
                            @foreach (var entry in _history)
                            {
                                <div class="timeline-entry">
                                    <div class="timeline-dot" style="background: @GetEventColor(entry.EventType);"></div>
                                    <div class="timeline-content">
                                        <MudText Typo="Typo.body2" Style="font-weight: 500;">@entry.Label</MudText>
                                        @if (!string.IsNullOrEmpty(entry.Detail))
                                        {
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@entry.Detail</MudText>
                                        }
                                        <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.35); font-size: 0.7rem; margin-top: 2px;">
                                            @FormatTimeAgo(entry.OccurredAt)
                                        </MudText>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                @* ══════════ IMAGES TAB (stub) ══════════ *@
                <div class="eo-meta-tab">
                    <div class="eo-status" style="padding: 80px 0;">
                        <MudIcon Icon="@Icons.Material.Outlined.PhotoLibrary"
                                 Style="font-size: 2.5rem; opacity: 0.08;" />
                        <span>Image management coming soon</span>
                    </div>
                </div>
            }
        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Guid EntityId { get; set; }
    [Parameter] public Guid CollectionId { get; set; }
    [Parameter] public string? MediaType { get; set; }
    [Parameter] public string? PreloadedCandidates { get; set; }
    [Parameter] public string? InitialSearchQuery { get; set; }
    [Parameter] public List<CanonicalValueViewModel>? WorkCanonicalValues { get; set; }
    [Parameter] public RegistryItemViewModel? RegistryItem { get; set; }
    [Parameter] public int InitialTab { get; set; }

    // ── State ──────────────────────────────────────────────────────────
    private int _activeTab;
    private bool _loadingMeta;
    private List<CanonicalFieldViewModel>? _canonicalValues;
    private List<ClaimFieldDto>? _fileTagClaims;
    private string? _wikidataQid;

    private string _searchQuery = "";
    private string _selectedMediaType = "";
    private bool _searching;
    private bool _applying;
    private List<SearchResultItemViewModel>? _results;
    private SearchResultItemViewModel? _highlightedItem;
    private SearchResultItemViewModel? _confirmingItem;
    private SearchResultItemViewModel? _appliedItem;
    private bool _appliedAny;

    // Provider image gallery
    private List<RetailCoverEntry> _retailCovers = [];
    private int _selectedCoverIndex;
    private bool _loadingRetail;
    private CancellationTokenSource? _retailCts;

    // History
    private bool _loadingHistory;
    private List<RegistryItemHistoryDto> _history = [];

    private static readonly string WikidataProviderId = "b3000003-d000-4000-8000-000000000004";
    private static readonly Guid LocalFilesystemProviderId = Guid.Parse("a0000000-0000-4000-8000-000000000000");

    private static readonly Dictionary<string, int> ProviderPriority = new(StringComparer.OrdinalIgnoreCase)
    {
        ["apple_api"] = 100,
        ["tmdb"] = 90, ["open_library"] = 60,
    };

    private static readonly (string Label, string Value)[] _mediaTypeOptions =
    [
        ("Book", "Books"), ("Audiobook", "Audiobooks"), ("Movie", "Movies"),
        ("TV", "TV"), ("Comic", "Comic"), ("Music", "Music"),
    ];

    private sealed record RetailCoverEntry(string CoverUrl, string ProviderName, int Priority);

    // ── Lifecycle ──────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _activeTab = InitialTab;
        _selectedMediaType = !string.IsNullOrEmpty(MediaType) ? MediaType : "Books";
        if (!string.IsNullOrWhiteSpace(InitialSearchQuery))
            _searchQuery = InitialSearchQuery;
        TryLoadPreloadedCandidates();

        // Try loading cached results from the server
        if ((_results is null || _results.Count == 0) && EntityId != Guid.Empty)
        {
            try
            {
                var cached = await Orchestrator.GetSearchResultsCacheAsync(EntityId);
                if (!string.IsNullOrEmpty(cached))
                {
                    var items = System.Text.Json.JsonSerializer.Deserialize<List<SearchResultItemViewModel>>(
                        cached, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (items is { Count: > 0 })
                        _results = items;
                }
            }
            catch { /* Non-critical */ }
        }

        await LoadMetadataAsync();

        if (InitialTab == 2)
            await LoadHistoryAsync();

        // Auto-search when we have a pre-filled query but no cached/preloaded results
        if (!string.IsNullOrWhiteSpace(_searchQuery) && (_results is null || _results.Count == 0))
            await OnSearch();
    }

    private async Task LoadMetadataAsync()
    {
        _loadingMeta = true;
        StateHasChanged();

        try
        {
            var apiCanonicals = await Orchestrator.GetCanonicalValuesAsync(EntityId);
            if (apiCanonicals is { Count: > 0 })
                _canonicalValues = apiCanonicals;
            else if (WorkCanonicalValues is { Count: > 0 })
                _canonicalValues = WorkCanonicalValues
                    .Where(cv => !string.IsNullOrEmpty(cv.Value))
                    .Select(cv => new CanonicalFieldViewModel(cv.Key, cv.Value, 0.0, null, false, false))
                    .ToList();

            _wikidataQid = _canonicalValues?.FirstOrDefault(c => c.Key == "wikidata_qid")?.Value;

            var allClaims = await Orchestrator.GetClaimHistoryAsync(EntityId);
            if (allClaims is { Count: > 0 })
            {
                _fileTagClaims = allClaims
                    .Where(c => c.ProviderId == LocalFilesystemProviderId)
                    .GroupBy(c => c.ClaimKey)
                    .Select(g => g.OrderByDescending(c => c.Confidence).First())
                    .Select(c => new ClaimFieldDto(c.ClaimKey, c.ClaimValue))
                    .ToList();
            }

            if ((_fileTagClaims is null || _fileTagClaims.Count == 0) && WorkCanonicalValues is { Count: > 0 })
                _fileTagClaims = WorkCanonicalValues
                    .Where(cv => !string.IsNullOrEmpty(cv.Value))
                    .Select(cv => new ClaimFieldDto(cv.Key, cv.Value!))
                    .ToList();
        }
        catch
        {
            if (WorkCanonicalValues is { Count: > 0 })
                _canonicalValues = WorkCanonicalValues
                    .Where(cv => !string.IsNullOrEmpty(cv.Value))
                    .Select(cv => new CanonicalFieldViewModel(cv.Key, cv.Value, 0.0, null, false, false))
                    .ToList();
        }
        finally
        {
            _loadingMeta = false;
            StateHasChanged();
        }
    }

    private async Task SetTab(int tab)
    {
        _activeTab = tab;
        if (tab == 2 && _history.Count == 0 && !_loadingHistory)
            await LoadHistoryAsync();
        StateHasChanged();
    }

    private async Task LoadHistoryAsync()
    {
        _loadingHistory = true;
        StateHasChanged();
        try
        {
            _history = await ApiClient.GetItemHistoryAsync(EntityId);
        }
        catch
        {
            _history = [];
        }
        _loadingHistory = false;
        StateHasChanged();
    }

    // ── Preloaded candidates ───────────────────────────────────────────

    private void TryLoadPreloadedCandidates()
    {
        if (string.IsNullOrEmpty(PreloadedCandidates)) return;
        try
        {
            // Try cached search results format first (List<SearchResultItemViewModel>)
            var cached = System.Text.Json.JsonSerializer.Deserialize<List<SearchResultItemViewModel>>(
                PreloadedCandidates,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (cached is { Count: > 0 } && !string.IsNullOrEmpty(cached[0].Title))
            {
                _results = cached;
                return;
            }
        }
        catch { /* Not cached format — try review queue format */ }

        try
        {
            // Review queue format (qid/label/description/score)
            var candidates = System.Text.Json.JsonSerializer.Deserialize<List<PreloadedCandidate>>(PreloadedCandidates);
            if (candidates is { Count: > 0 })
                _results = candidates.Select(c => new SearchResultItemViewModel
                {
                    Title = c.Label, Description = c.Description, ProviderItemId = c.Qid,
                    Confidence = (c.Score ?? 0) / 100.0,
                    RawFields = new Dictionary<string, string> { ["wikidata_qid"] = c.Qid ?? "" },
                }).ToList();
        }
        catch { /* Ignore malformed JSON */ }
    }

    private sealed class PreloadedCandidate
    {
        [System.Text.Json.Serialization.JsonPropertyName("qid")] public string? Qid { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("label")] public string? Label { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("description")] public string? Description { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("score")] public double? Score { get; set; }
    }

    private sealed record ClaimFieldDto(string Key, string Value);

    // ── Search ─────────────────────────────────────────────────────────

    private async Task OnMediaTypeChanged(string mediaType)
    {
        _selectedMediaType = mediaType;
        _results = null;
        _confirmingItem = null;
        _appliedItem = null;
        _highlightedItem = null;
        _retailCovers = [];
        _selectedCoverIndex = 0;
        CancelRetailLookup();
        await InvokeAsync(StateHasChanged);

        if (!string.IsNullOrWhiteSpace(_searchQuery))
            await OnSearch();
    }

    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery)) return;
        _searching = true;
        _results = null;
        _confirmingItem = null;
        _appliedItem = null;
        _highlightedItem = null;
        _retailCovers = [];
        _selectedCoverIndex = 0;
        CancelRetailLookup();
        StateHasChanged();

        try
        {
            var fanOut = await Orchestrator.SearchMetadataFanOutAsync(
                _searchQuery, _selectedMediaType, WikidataProviderId);
            _results = fanOut?.Results is { Count: > 0 }
                ? fanOut.Results.SelectMany(p => p.Items).ToList()
                : [];
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
            _results = [];
        }
        finally
        {
            _searching = false;
            StateHasChanged();
        }

        // Cache results for future visits (30-day TTL, server-side)
        if (_results is { Count: > 0 } && EntityId != Guid.Empty)
        {
            try
            {
                var json = System.Text.Json.JsonSerializer.Serialize(_results);
                await Orchestrator.SaveSearchResultsCacheAsync(EntityId, json);
            }
            catch { /* Non-critical — cache write failure is silent */ }
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await OnSearch();
    }

    // ── Highlight & provider gallery ────────────────────────────────

    private async Task OnResultClicked(SearchResultItemViewModel item)
    {
        if (_highlightedItem == item)
        {
            _highlightedItem = null;
            _retailCovers = [];
            _selectedCoverIndex = 0;
            CancelRetailLookup();
            return;
        }

        _highlightedItem = item;
        _retailCovers = [];
        _selectedCoverIndex = 0;
        _confirmingItem = null;
        StateHasChanged();

        await FetchRetailCoversAsync(item);
    }

    /// <summary>
    /// Searches retail providers using BOTH the Wikidata label AND the user's original
    /// search query (if different). This ensures popular aliases like "1984" find Apple
    /// results even when Wikidata labels the work "Nineteen Eighty-Four".
    /// </summary>
    private async Task FetchRetailCoversAsync(SearchResultItemViewModel item)
    {
        CancelRetailLookup();
        _retailCts = new CancellationTokenSource();
        var ct = _retailCts.Token;

        var wikidataLabel = item.Title;
        if (string.IsNullOrWhiteSpace(wikidataLabel)) return;

        _loadingRetail = true;
        StateHasChanged();

        try
        {
            // Primary search: use the Wikidata label (formal title)
            var primaryTask = Orchestrator.SearchRetailAsync(wikidataLabel, _selectedMediaType, 5, ct: ct);

            // Secondary search: use the user's original query if it differs from the label
            // (catches popular aliases like "1984" vs "Nineteen Eighty-Four")
            Task<List<RetailCandidateDto>> secondaryTask;
            var userQuery = _searchQuery?.Trim();
            var labelsMatch = string.Equals(userQuery, wikidataLabel, StringComparison.OrdinalIgnoreCase);

            if (!string.IsNullOrWhiteSpace(userQuery) && !labelsMatch)
                secondaryTask = Orchestrator.SearchRetailAsync(userQuery, _selectedMediaType, 5, ct: ct);
            else
                secondaryTask = Task.FromResult(new List<RetailCandidateDto>());

            var primary = await primaryTask;
            var secondary = await secondaryTask;
            if (ct.IsCancellationRequested || _highlightedItem != item) return;

            // Combine, deduplicate by URL (not by provider — allow multiple from same provider),
            // sort by priority then confidence
            var allCovers = primary.Concat(secondary)
                .Where(c => !string.IsNullOrEmpty(c.CoverUrl))
                .DistinctBy(c => c.CoverUrl, StringComparer.OrdinalIgnoreCase)
                .Select(c => new RetailCoverEntry(
                    c.CoverUrl!,
                    FormatProviderName(c.ProviderName),
                    ProviderPriority.TryGetValue(c.ProviderName, out var p) ? p : 50))
                .OrderByDescending(e => e.Priority)
                .ToList();

            _retailCovers = allCovers;
            _selectedCoverIndex = 0;
        }
        catch (OperationCanceledException) { /* Expected on cancel */ }
        catch { /* Retail lookup is best-effort */ }
        finally
        {
            if (_highlightedItem == item)
            {
                _loadingRetail = false;
                StateHasChanged();
            }
        }
    }

    private void CancelRetailLookup()
    {
        _retailCts?.Cancel();
        _retailCts?.Dispose();
        _retailCts = null;
        _loadingRetail = false;
    }

    // ── Apply ──────────────────────────────────────────────────────────

    private async Task OnConfirmApply(SearchResultItemViewModel item)
    {
        _applying = true;
        StateHasChanged();

        try
        {
            var fields = item.RawFields
                .Where(kv => !string.IsNullOrEmpty(kv.Value))
                .ToDictionary(kv => kv.Key, kv => kv.Value);

            int applied = 0;
            if (fields.Count > 0)
            {
            var ok = await Orchestrator.SaveItemPreferencesAsync(EntityId, fields);
                if (ok) applied += fields.Count;
            }

            var coverUrl = _retailCovers.Count > 0
                ? _retailCovers[_selectedCoverIndex].CoverUrl
                : item.ThumbnailUrl;
            if (!string.IsNullOrEmpty(coverUrl))
            {
                var ok = await Orchestrator.ApplyCoverFromUrlAsync(EntityId, coverUrl);
                if (ok) applied++;
            }

            if (applied > 0)
            {
                _appliedItem = item;
                _confirmingItem = null;
                _appliedAny = true;
                Snackbar.Add($"Match applied — {applied} field(s) updated", Severity.Success);
                await LoadMetadataAsync();
            }
            else
            {
                Snackbar.Add("No fields were updated", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Apply failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _applying = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        CancelRetailLookup();
        MudDialog.Close(_appliedAny ? DialogResult.Ok(true) : DialogResult.Cancel());
    }

    // ── Helpers ─────────────────────────────────────────────────────────

    // ── Details tab rendering ───────────────────────────────────────────

    private RenderFragment RenderGroupedFields() => __builder =>
    {
        var visibleFields = GetVisibleCanonicalFields();
        var grouped = GroupFields(visibleFields);
        if (grouped.Count > 0)
        {
            foreach (var group in grouped)
            {
                <div class="eo-group">
                    <div class="eo-group-header">
                        <MudIcon Icon="@group.Icon" Style="font-size: 0.85rem; color: rgba(255,255,255,0.25);" />
                        <span class="eo-group-title">@group.Label</span>
                    </div>
                    @foreach (var field in group.Fields)
                    {
                        <div class="eo-row">
                            <span class="eo-row-label">@field.DisplayName</span>
                            <span class="eo-row-value">@Truncate(field.Value!, 300)</span>
                            @if (field.IsUserLocked)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size: 0.7rem; color: rgba(201,146,46,0.5);" title="Locked by you" />
                            }
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="eo-status"><span>No metadata available</span></div>
        }
    };

    // ── Details tab helpers ─────────────────────────────────────────────

    /// <summary>Fields that should not appear in the Details tab.</summary>
    private static readonly HashSet<string> HiddenKeys = new(StringComparer.OrdinalIgnoreCase)
    {
        "cover", "hero", "dominant_color",
        // Companion QID fields — only work QID and edition QID are shown
        "genre_qid", "author_qid", "narrator_qid", "director_qid",
        "cast_member_qid", "characters_qid", "series_qid",
        "publisher_qid", "location_qid", "franchise_qid",
    };

    private sealed record FieldGroup(string Label, string Icon, List<CanonicalFieldViewModel> Fields);

    private List<CanonicalFieldViewModel> GetVisibleCanonicalFields()
    {
        if (_canonicalValues is null) return [];
        return _canonicalValues
            .Where(c => !HiddenKeys.Contains(c.Key) && !string.IsNullOrEmpty(c.Value))
            .ToList();
    }

    private static List<FieldGroup> GroupFields(List<CanonicalFieldViewModel> fields)
    {
        if (fields.Count == 0) return [];

        // Category definitions: (label, icon, keys in display order)
        var categories = new (string Label, string Icon, string[] Keys)[]
        {
            ("About", Icons.Material.Outlined.MenuBook,
                ["title", "description", "year", "genre", "language"]),
            ("People", Icons.Material.Outlined.People,
                ["author", "narrator", "director", "cast_member"]),
            ("Series & Collection", Icons.Material.Outlined.CollectionsBookmark,
                ["series", "series_position", "publisher"]),
            ("Identifiers", Icons.Material.Outlined.Fingerprint,
                ["wikidata_qid", "edition_qid", "isbn", "asin", "apple_books_id",
                 "tmdb_id", "imdb_id", "musicbrainz_id", "goodreads_id"]),
            ("Technical", Icons.Material.Outlined.Settings,
                ["media_type", "page_count", "duration", "rating"]),
        };

        var grouped = new List<FieldGroup>();
        var assigned = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var (label, icon, keys) in categories)
        {
            var matching = new List<CanonicalFieldViewModel>();
            foreach (var key in keys)
            {
                var field = fields.FirstOrDefault(f =>
                    string.Equals(f.Key, key, StringComparison.OrdinalIgnoreCase));
                if (field is not null)
                {
                    matching.Add(field);
                    assigned.Add(field.Key);
                }
            }
            if (matching.Count > 0)
                grouped.Add(new FieldGroup(label, icon, matching));
        }

        // Any remaining fields not in a category
        var uncategorized = fields.Where(f => !assigned.Contains(f.Key)).ToList();
        if (uncategorized.Count > 0)
            grouped.Add(new FieldGroup("Other", Icons.Material.Outlined.MoreHoriz, uncategorized));

        return grouped;
    }

    private static string FormatFieldKey(string key) =>
        System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(key.Replace('_', ' '));

    private string FormatProviderName(string name)
    {
        // Prefer live catalogue display name
        var entry = CatalogueService.GetByName(name);
        if (entry is not null) return entry.DisplayName;

        // Fall back to hardcoded mapping
        return name switch
        {
            "apple_api"             => "Apple API",
            "open_library"          => "Open Library",
            "tmdb"                  => "TMDB",
            "musicbrainz"           => "MusicBrainz",
            "metron"                => "Metron",
            "fanart_tv"             => "Fanart.tv",
            "wikidata_reconciliation" => "Wikidata",
            _ => System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(name.Replace('_', ' ')),
        };
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength].TrimEnd() + "\u2026";

    // ── History helpers ─────────────────────────────────────────────────

    private static string GetEventColor(string eventType) => eventType switch
    {
        "FileDetected"         => "#4A90D9",
        "MetadataExtracted"    => "#4A90D9",
        "ConfidenceScored"     => "#C9922E",
        "WikidataMatched"      => "#4CAF50",
        "WikidataMatchFailed"  => "#EF5350",
        "CoverArtFound"        => "#4CAF50",
        "CoverArtNotFound"     => "#EF5350",
        "PersonLinked"         => "#4CAF50",
        "Staged"               => "#C9922E",
        "Promoted"             => "#4CAF50",
        "MetadataUpdated"      => "#4CAF50",
        "UserEdited"           => "#4A90D9",
        "Rejected"             => "#EF5350",
        "Recovered"            => "#4CAF50",
        "ReviewCreated"        => "#C9922E",
        "ReviewResolved"       => "#4CAF50",
        "HydrationStarted"     => "#4A90D9",
        "HydrationCompleted"   => "#4CAF50",
        "RetailEnriched"       => "#4CAF50",
        "RetailEnrichFailed"   => "#EF5350",
        _                      => "rgba(255,255,255,0.3)"
    };

    private static string FormatTimeAgo(DateTimeOffset occurredAt)
    {
        var diff = DateTimeOffset.UtcNow - occurredAt;
        if (diff.TotalSeconds < 60) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return occurredAt.ToString("MMM d, yyyy");
    }
}

