@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator

<div class="st-page settings-registry-page">
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h6">Registry</MudText>
                <MudText Typo="Typo.body2" Class="settings-muted">
                    Durable operational records that live in SQLite.
                </MudText>
            </MudStack>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" Href="/settings/activity" StartIcon="@Icons.Material.Outlined.Timeline">
                Activity
            </MudButton>
        </MudStack>

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="settings-registry-card">
                    <MudText Typo="Typo.overline">Activity entries</MudText>
                    <MudText Typo="Typo.h5">@(_stats?.TotalEntries ?? 0)</MudText>
                    <MudText Typo="Typo.caption" Class="settings-muted">@(_stats?.RetentionDays ?? 0) day retention</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="settings-registry-card">
                    <MudText Typo="Typo.overline">Review queue</MudText>
                    <MudText Typo="Typo.h5">@_reviewCount</MudText>
                    <MudText Typo="Typo.caption" Class="settings-muted">Pending items</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="settings-registry-card">
                    <MudText Typo="Typo.overline">Source of truth</MudText>
                    <MudText Typo="Typo.h5">SQLite</MudText>
                    <MudText Typo="Typo.caption" Class="settings-muted">Operational state</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudStack>
</div>

@code {
    private ActivityStatsViewModel? _stats;
    private int _reviewCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _stats = await Orchestrator.GetActivityStatsAsync();
        }
        catch
        {
            _stats = null;
        }

        try
        {
            _reviewCount = await Orchestrator.RefreshReviewCountAsync();
        }
        catch
        {
            _reviewCount = 0;
        }
    }
}
