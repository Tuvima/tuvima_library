@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar

@* — Edit Panel — Wikidata Reconciliation match tool ──────────────────────── *@

@if (!IsOpen) { return; }

<div class="hep-panel @(Persistent ? "hep-persistent" : "hep-standalone")">

    @* ── Header ── *@
    <div class="hep-header">
        <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Style="color: #C9922E; font-size: 1.2rem;" />
        <span class="hep-header-title">Match to Wikidata</span>
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                       OnClick="@(() => { IsOpen = false; IsOpenChanged.InvokeAsync(false); })"
                       Style="color:rgba(248,248,248,0.45);" />
    </div>

    @* ── Media type selector ── *@
    <div class="hep-media-type-bar">
        @foreach (var mt in _mediaTypeOptions)
        {
            var isActive = _selectedMediaType == mt.Value;
            <button class="hep-mt-btn @(isActive ? "hep-mt-btn--on" : "")"
                    @onclick="@(() => OnMediaTypeChanged(mt.Value))">
                @mt.Label
            </button>
        }
    </div>

    @* ── Search bar ── *@
    <div class="hep-search-bar">
        <MudTextField @bind-Value="_searchQuery" Placeholder="Search Wikidata..."
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                      OnAdornmentClick="@OnSearch" OnKeyUp="@OnSearchKeyUp"
                      Style="font-family:'Montserrat',sans-serif;"
                      Disabled="@_searching" />
    </div>

    @* ── Results area (scrollable) ── *@
    <div class="hep-results-scroll">

        @if (_searching)
        {
            <div class="hep-status-msg">
                <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                     Style="color: #C9922E;" />
                <span>Searching Wikidata...</span>
            </div>
        }
        else if (_results is not null && _results.Count == 0)
        {
            <div class="hep-status-msg">
                <MudIcon Icon="@Icons.Material.Outlined.SearchOff"
                         Style="font-size: 2rem; opacity: 0.15;" />
                <span>No matches found</span>
            </div>
        }
        else if (_results is not null)
        {
            @foreach (var item in _results)
            {
                var isSelected = _confirmingItem == item || _appliedItem == item;
                <div class="hep-result-card @(isSelected ? "hep-result-card--selected" : "")"
                     @onclick="@(() => OnResultClicked(item))">
                    <div class="hep-result-meta">
                        <span class="hep-result-title">@(item.Title ?? "Untitled")</span>
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <span class="hep-result-desc">@Truncate(item.Description, 140)</span>
                        }
                        @if (item.Confidence > 0)
                        {
                            <span class="hep-result-conf">@((item.Confidence * 100).ToString("F0"))%</span>
                        }
                    </div>

                    @* ── Inline apply: check → confirm → applied ── *@
                    <div class="hep-result-action" @onclick:stopPropagation="true">
                        @if (_appliedItem == item)
                        {
                            <div class="hep-check hep-check--applied" title="Applied">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                         Style="font-size: 1.3rem; color: #22c55e;" />
                            </div>
                        }
                        else if (_confirmingItem == item)
                        {
                            <button class="hep-check hep-check--confirm"
                                    @onclick="@(() => OnConfirmApply(item))"
                                    disabled="@_applying"
                                    title="Click to confirm">
                                @if (_applying)
                                {
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                                         Style="color: #22c55e;" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                             Style="font-size: 1.3rem;" />
                                    <span class="hep-confirm-label">Confirm?</span>
                                }
                            </button>
                        }
                        else
                        {
                            <button class="hep-check hep-check--idle"
                                    @onclick="@(() => { _confirmingItem = item; })"
                                    title="Apply this match">
                                <MudIcon Icon="@Icons.Material.Outlined.CheckCircleOutline"
                                         Style="font-size: 1.3rem;" />
                            </button>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="hep-status-msg">
                <MudIcon Icon="@Icons.Material.Outlined.TravelExplore"
                         Style="font-size: 2rem; opacity: 0.10;" />
                <span>Search for a Wikidata match</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public Guid CollectionId { get; set; }
    [Parameter] public Guid EntityId { get; set; }
    [Parameter] public string? MediaType { get; set; }
    [Parameter] public string? CurrentCoverUrl { get; set; }
    [Parameter] public string? PreloadedCandidates { get; set; }
    [Parameter] public EventCallback OnApplied { get; set; }

    /// <summary>When true, renders as a persistent side panel (no overlay).</summary>
    [Parameter] public bool Persistent { get; set; }

    private string _searchQuery = "";
    private bool _searching;
    private bool _applying;
    private string _selectedMediaType = "";
    private List<SearchResultItemViewModel>? _results;
    private SearchResultItemViewModel? _confirmingItem;
    private SearchResultItemViewModel? _appliedItem;
    private Guid _lastEntityId;

    private static readonly string WikidataProviderId = "b3000003-d000-4000-8000-000000000004";

    private static readonly (string Label, string Value)[] _mediaTypeOptions =
    [
        ("Book", "Books"),
        ("Audiobook", "Audiobooks"),
        ("Movie", "Movies"),
        ("TV", "TV"),
        ("Comic", "Comic"),
        ("Music", "Music"),
    ];

    protected override void OnParametersSet()
    {
        // Reset state when entity changes
        if (EntityId != Guid.Empty && EntityId != _lastEntityId)
        {
            _lastEntityId = EntityId;
            _results = null;
            _confirmingItem = null;
            _appliedItem = null;
            _searchQuery = "";
            _searching = false;
            _applying = false;

            // Auto-select media type from the file's detected type
            _selectedMediaType = !string.IsNullOrEmpty(MediaType) ? MediaType : "Books";

            // Load preloaded candidates if available (from pipeline disambiguation)
            TryLoadPreloadedCandidates();
        }

        // Fallback: ensure something is selected
        if (string.IsNullOrEmpty(_selectedMediaType))
        {
            _selectedMediaType = !string.IsNullOrEmpty(MediaType) ? MediaType : "Books";
        }
    }

    private void TryLoadPreloadedCandidates()
    {
        if (string.IsNullOrEmpty(PreloadedCandidates)) return;

        try
        {
            var candidates = System.Text.Json.JsonSerializer.Deserialize<List<PreloadedCandidate>>(
                PreloadedCandidates);

            if (candidates is { Count: > 0 })
            {
                _results = candidates.Select(c => new SearchResultItemViewModel
                {
                    Title = c.Label,
                    Description = c.Description,
                    ProviderItemId = c.Qid,
                    Confidence = (c.Score ?? 0) / 100.0,
                    RawFields = new Dictionary<string, string>
                    {
                        ["wikidata_qid"] = c.Qid ?? "",
                    },
                }).ToList();
            }
        }
        catch
        {
            // Ignore malformed JSON
        }
    }

    private sealed class PreloadedCandidate
    {
        [System.Text.Json.Serialization.JsonPropertyName("qid")]
        public string? Qid { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("label")]
        public string? Label { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("description")]
        public string? Description { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("score")]
        public double? Score { get; set; }
    }

    private void OnMediaTypeChanged(string mediaType)
    {
        _selectedMediaType = mediaType;
        // Clear results when switching media type
        _results = null;
        _confirmingItem = null;
        _appliedItem = null;
    }

    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery)) return;

        _searching = true;
        _results = null;
        _confirmingItem = null;
        _appliedItem = null;
        StateHasChanged();

        try
        {
            var fanOut = await Orchestrator.SearchMetadataFanOutAsync(
                _searchQuery,
                _selectedMediaType,
                WikidataProviderId);

            if (fanOut?.Results is { Count: > 0 })
            {
                _results = fanOut.Results
                    .SelectMany(p => p.Items)
                    .ToList();
            }
            else
            {
                _results = [];
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
            _results = [];
        }
        finally
        {
            _searching = false;
            StateHasChanged();
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await OnSearch();
    }

    private void OnResultClicked(SearchResultItemViewModel item)
    {
        // Clicking the card itself starts the confirm flow
        if (_confirmingItem == item)
        {
            _confirmingItem = null; // toggle off
        }
        else
        {
            _confirmingItem = item;
            _appliedItem = null;
        }
    }

    private async Task OnConfirmApply(SearchResultItemViewModel item)
    {
        _applying = true;
        StateHasChanged();

        try
        {
            var fields = item.RawFields
                .Where(kv => !string.IsNullOrEmpty(kv.Value))
                .ToDictionary(kv => kv.Key, kv => kv.Value);

            int applied = 0;

            if (fields.Count > 0)
            {
                var ok = await Orchestrator.OverrideMetadataAsync(EntityId, fields);
                if (ok) applied += fields.Count;
            }

            if (!string.IsNullOrEmpty(item.ThumbnailUrl))
            {
                var ok = await Orchestrator.ApplyCoverFromUrlAsync(EntityId, item.ThumbnailUrl);
                if (ok) applied++;
            }

            if (applied > 0)
            {
                _appliedItem = item;
                _confirmingItem = null;
                Snackbar.Add($"Match applied — {applied} field(s) updated", Severity.Success);
                await OnApplied.InvokeAsync();
            }
            else
            {
                Snackbar.Add("No fields were updated", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Apply failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _applying = false;
            StateHasChanged();
        }
    }

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength].TrimEnd() + "\u2026";
}

<style>
    /* ── Panel container ── */
    .hep-panel {
        display: flex;
        flex-direction: column;
        height: 100%;
        background: #0a0e1a;
        border-left: 1px solid rgba(255, 255, 255, 0.08);
    }

    .hep-persistent {
        min-width: 380px;
        max-width: 480px;
        flex-shrink: 0;
    }

    .hep-standalone {
        position: fixed;
        top: 56px;
        right: 0;
        bottom: 0;
        width: 460px;
        z-index: 100;
        box-shadow: -4px 0 24px rgba(0, 0, 0, 0.5);
    }

    /* ── Header ── */
    .hep-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        flex-shrink: 0;
    }

    .hep-header-title {
        font-family: 'Montserrat', sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        color: rgba(248, 248, 248, 0.90);
        flex: 1;
    }

    /* ── Media type selector ── */
    .hep-media-type-bar {
        display: flex;
        gap: 3px;
        padding: 8px 16px;
        flex-wrap: wrap;
        flex-shrink: 0;
    }

    .hep-mt-btn {
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: transparent;
        color: rgba(255, 255, 255, 0.35);
        font-family: 'Montserrat', sans-serif;
        transition: all 0.12s ease;
    }

    .hep-mt-btn:hover {
        border-color: rgba(255, 255, 255, 0.18);
        color: rgba(255, 255, 255, 0.6);
    }

    .hep-mt-btn--on {
        background: rgba(201, 146, 46, 0.12);
        border-color: rgba(201, 146, 46, 0.40);
        color: #C9922E;
    }

    /* ── Search bar ── */
    .hep-search-bar {
        padding: 0 16px 8px;
        flex-shrink: 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    /* ── Results (scrollable) ── */
    .hep-results-scroll {
        flex: 1;
        overflow-y: auto;
        padding: 8px 12px;
        min-height: 0;
    }

    .hep-results-scroll::-webkit-scrollbar { width: 5px; }
    .hep-results-scroll::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.06); border-radius: 3px; }

    .hep-status-msg {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 40px 0;
        color: rgba(255, 255, 255, 0.25);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
    }

    /* ── Result card ── */
    .hep-result-card {
        display: flex;
        gap: 12px;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        cursor: pointer;
        transition: all 0.12s ease;
        margin-bottom: 6px;
        align-items: flex-start;
    }

    .hep-result-card:hover {
        border-color: rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.02);
    }

    .hep-result-card--selected {
        border-color: rgba(34, 197, 94, 0.25);
        background: rgba(34, 197, 94, 0.04);
    }

    .hep-result-meta {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .hep-result-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        color: rgba(248, 248, 248, 0.90);
        line-height: 1.3;
    }

    .hep-result-desc {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.72rem;
        font-weight: 400;
        color: rgba(248, 248, 248, 0.35);
        line-height: 1.4;
        margin-top: 2px;
    }

    .hep-result-conf {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.68rem;
        font-weight: 600;
        color: rgba(201, 146, 46, 0.7);
        margin-top: 2px;
    }

    /* ── Inline apply checkmark ── */
    .hep-result-action {
        flex-shrink: 0;
        display: flex;
        align-items: flex-start;
        padding-top: 2px;
    }

    .hep-check {
        display: flex;
        align-items: center;
        gap: 4px;
        border: none;
        background: none;
        cursor: pointer;
        padding: 4px;
        border-radius: 6px;
        transition: all 0.15s ease;
    }

    .hep-check--idle {
        color: rgba(255, 255, 255, 0.15);
    }

    .hep-check--idle:hover {
        color: #22c55e;
        background: rgba(34, 197, 94, 0.08);
    }

    .hep-check--confirm {
        color: #22c55e;
        background: rgba(34, 197, 94, 0.10);
        animation: hep-pulse 1.2s ease-in-out infinite;
    }

    .hep-check--confirm:hover {
        background: rgba(34, 197, 94, 0.18);
    }

    .hep-confirm-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.68rem;
        font-weight: 600;
        color: #22c55e;
    }

    .hep-check--applied {
        padding: 4px;
    }

    @@keyframes hep-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.6; }
    }
</style>
