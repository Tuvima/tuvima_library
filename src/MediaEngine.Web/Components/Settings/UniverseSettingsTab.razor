@namespace MediaEngine.Web.Components.Settings

@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration

@inject UIOrchestratorService Orchestrator
@inject MudBlazor.ISnackbar Snackbar

@* Universe Settings — editable configuration for the Wikidata universe provider.

   Wikidata is the permanent universe provider. It spans all media types and
   provides authoritative Q-identifiers, external bridge IDs, and deep
   enrichment data via SPARQL. Endpoints, throttle, and concurrency are
   editable; the property map and bridge identifiers are read-only. *@

<div class="st-page">

    @* ── Header ────────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Public" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">Universe Provider</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Wikidata is the permanent universe provider. It connects your library to the
        open knowledge graph — linking every book, film, and person to authoritative
        identifiers across all platforms.
    </MudText>

    @* ── Provider info card ────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Class="pa-4 mb-4" Style="@InfoCardStyle">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Outlined.Collections" Color="Color.Default" />
            <div style="flex: 1;">
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Wikidata</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    https://www.wikidata.org
                </MudText>
            </div>
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                SPARQL
            </MudChip>
        </MudStack>
    </MudPaper>

    @* ── Configuration (editable) ─────────────────────────────────────── *@
    <MudPaper Elevation="0" Class="pa-4 mb-4" Style="@InfoCardStyle">
        <MudText Typo="Typo.overline" Color="Color.Default" Class="mb-2"
                 Style="letter-spacing: 0.08em;">
            CONFIGURATION
        </MudText>

        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_wikidataApiUrl"
                              Label="API Endpoint"
                              Placeholder="https://www.wikidata.org/w/api.php"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              FullWidth="true"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Api" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_sparqlUrl"
                              Label="SPARQL Endpoint"
                              Placeholder="https://query.wikidata.org/sparql"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              FullWidth="true"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Storage" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField T="int" @bind-Value="_throttleMs"
                                 Label="Throttle (ms)"
                                 Min="0" Max="10000"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField T="int" @bind-Value="_maxConcurrency"
                                 Label="Max Concurrency"
                                 Min="1" Max="5"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center">
                <MudSwitch T="bool" @bind-Value="_enabled"
                           Label="Enabled"
                           Color="Color.Primary" />
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3" Spacing="2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="@SaveConfigAsync"
                       Disabled="@_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                    @:Saving…
                }
                else
                {
                    @:Save
                }
            </MudButton>
        </MudStack>
    </MudPaper>

    @* ── Bridges section ───────────────────────────────────────────────── *@
    <MudExpansionPanels Elevation="0" Dense="true" Class="mb-4"
                        Style="background: transparent;">
        <MudExpansionPanel Text="Bridge Identifiers"
                           MaxHeight="2000"
                           Style="background: transparent; border: 1px solid var(--app-glass-border); border-radius: 8px;">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Link" Size="Size.Small" Color="Color.Default" />
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Bridge Identifiers</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                        @_bridges.Count
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Bridges connect Wikidata to your other providers. When the Engine finds a
                    Wikidata entry for a work, it uses these bridge properties to cross-reference
                    with Apple Books, Open Library, and more. Order determines priority — the first
                    matching bridge wins.
                </MudText>

                <MudSimpleTable Dense="true" Hover="true"
                                Style="background: transparent;">
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th>Property</th>
                            <th>Target Provider</th>
                            <th>Request Field</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < _bridges.Count; i++)
                        {
                            var bridge = _bridges[i];
                            var idx = i;
                            <tr>
                                <td>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@(idx + 1)</MudText>
                                </td>
                                <td>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@bridge.PCode</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            — @GetBridgeLabel(bridge.PCode)
                                        </MudText>
                                    </MudStack>
                                </td>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                             Variant="Variant.Text">
                                        @GetTargetProvider(bridge.PCode)
                                    </MudChip>
                                </td>
                                <td>
                                    <code style="font-size: 0.8rem;">@bridge.RequestField</code>
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @* ── Property map section ──────────────────────────────────────────── *@
    <MudExpansionPanels Elevation="0" Dense="true"
                        Style="background: transparent;">
        <MudExpansionPanel Text="Property Map"
                           MaxHeight="4000"
                           Style="background: transparent; border: 1px solid var(--app-glass-border); border-radius: 8px;">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Map" Size="Size.Small" Color="Color.Default" />
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Property Map</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                        @_propertyCount properties
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Wikidata properties mapped to claim keys. Each property carries
                    a confidence value used during scoring. Bridge properties link to external
                    platforms.
                </MudText>

                @foreach (var category in _propertiesByCategory)
                {
                    <MudText Typo="Typo.overline" Color="Color.Default" Class="mt-3 mb-1"
                             Style="letter-spacing: 0.08em;">
                        @category.Key
                    </MudText>

                    <MudSimpleTable Dense="true" Hover="true"
                                    Style="background: transparent; margin-bottom: 8px;">
                        <thead>
                            <tr>
                                <th>P-Code</th>
                                <th>Claim Key</th>
                                <th>Scope</th>
                                <th style="width: 80px;">Confidence</th>
                                <th style="width: 60px;">Enabled</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prop in category.Value)
                            {
                                <tr style="@(!prop.Enabled ? "opacity: 0.5;" : "")">
                                    <td>
                                        <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                            @prop.PCode
                                        </MudText>
                                    </td>
                                    <td>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <code style="font-size: 0.8rem;">@prop.ClaimKey</code>
                                            @if (prop.IsBridge)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                                         Variant="Variant.Outlined"
                                                         Style="font-size: 0.65rem;">
                                                    Bridge
                                                </MudChip>
                                            }
                                        </MudStack>
                                    </td>
                                    <td>
                                        <MudText Typo="Typo.caption">@prop.EntityScope</MudText>
                                    </td>
                                    <td>
                                        <MudText Typo="Typo.body2">@prop.Confidence.ToString("P0")</MudText>
                                    </td>
                                    <td>
                                        <MudIcon Icon="@(prop.Enabled
                                                          ? Icons.Material.Filled.CheckCircle
                                                          : Icons.Material.Filled.Cancel)"
                                                 Color="@(prop.Enabled ? Color.Success : Color.Error)"
                                                 Size="Size.Small" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
</div>

@code {
    // ── State ────────────────────────────────────────────────────────────

    private string _wikidataApiUrl = string.Empty;
    private string _sparqlUrl      = string.Empty;
    private int    _throttleMs     = 1100;
    private int    _maxConcurrency = 1;
    private bool   _enabled        = true;
    private bool   _saving;

    private readonly List<WikidataPropertyDefaults.BridgeEntry> _bridges =
        WikidataPropertyDefaults.GetBridgeEntries();

    private Dictionary<string, List<WikidataPropertyDefaults.WikidataPropertyInfo>> _propertiesByCategory = new();
    private int _propertyCount;

    // ── Lifecycle ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var allProps = WikidataPropertyDefaults.GetAllProperties();
        _propertiesByCategory = allProps
            .GroupBy(p => p.Category)
            .OrderBy(g => WikidataPropertyDefaults.CategoryOrder(g.Key))
            .ToDictionary(g => g.Key, g => g.OrderBy(p => p.PCode).ToList());
        _propertyCount = allProps.Count;

        try
        {
            var providers = await Orchestrator.GetProviderStatusAsync();
            var wikidata = providers.FirstOrDefault(p =>
                string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase));

            if (wikidata is not null)
            {
                _enabled        = wikidata.Enabled;
                _throttleMs     = wikidata.ThrottleMs > 0 ? wikidata.ThrottleMs : 1100;
                _maxConcurrency = wikidata.MaxConcurrency > 0 ? wikidata.MaxConcurrency : 1;

                if (wikidata.Endpoints is { Count: > 0 })
                {
                    _wikidataApiUrl = wikidata.Endpoints.TryGetValue("wikidata_api", out var api) ? api : string.Empty;
                    _sparqlUrl      = wikidata.Endpoints.TryGetValue("wikidata_sparql", out var sparql) ? sparql : string.Empty;
                }
            }
        }
        catch
        {
            // Engine may be unreachable — keep defaults.
        }
    }

    // ── Save ─────────────────────────────────────────────────────────────

    private async Task SaveConfigAsync()
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var config = new ProviderConfigUpdateDto
            {
                Enabled        = _enabled,
                ThrottleMs     = _throttleMs,
                MaxConcurrency = _maxConcurrency,
                Endpoints = new Dictionary<string, string>
                {
                    ["wikidata_api"]    = _wikidataApiUrl,
                    ["wikidata_sparql"] = _sparqlUrl,
                },
            };

            var ok = await Orchestrator.SaveProviderConfigAsync("wikidata", config);

            Snackbar.Add(
                ok ? "Wikidata configuration saved." : "Failed to save configuration.",
                ok ? MudBlazor.Severity.Success : MudBlazor.Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    // ── Helpers (delegated to shared defaults) ────────────────────────────

    private static string GetBridgeLabel(string pCode) =>
        WikidataPropertyDefaults.GetBridgeLabel(pCode);

    private static string GetTargetProvider(string pCode) =>
        WikidataPropertyDefaults.GetTargetProvider(pCode);

    // ── Styles ───────────────────────────────────────────────────────────

    private const string InfoCardStyle =
        "background: var(--app-glass-bg); " +
        "border: 1px solid var(--app-glass-border); " +
        "backdrop-filter: blur(10px); " +
        "-webkit-backdrop-filter: blur(10px); " +
        "border-radius: 8px;";
}
