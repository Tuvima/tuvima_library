@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject IStringLocalizer<SharedStrings> L
<div class="tl-page">
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.ToggleOn" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">@L["AiFeatures_AiFeatures"]</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        @L["AiFeatures_AiFeaturesDescription"]
    </MudText>
<MudExpansionPanels MultiExpansion="true">
<MudExpansionPanel @bind-Expanded="_panel1Open"
                           Style="@PanelStyle">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Input"
                             Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        @L["AiFeatures_Ingestion"]
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                             Style="font-size: 0.7rem;">
                        @L["AiFeatures_Automatic"]
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                             Style="font-size: 0.7rem;">
                        @EnabledCount(_ingestionFeatures) / @_ingestionFeatures.Count @L["AiFeatures_On"]
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary"
                         Style="margin-bottom: 16px; margin-top: 4px;">
                    @L["AiFeatures_IngestionDescription"]
                </MudText>
                @foreach (var f in _ingestionFeatures)
                {
                    var feature = f;
                    <div>
                        <div style="@FeatureRowStyle">
                            <div style="flex: 1; min-width: 0;">
                                <MudText Typo="Typo.body1" Style="font-weight: 600; margin-bottom: 2px;">
                                    @feature.Name
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @feature.Description
                                </MudText>
                            </div>
                            @if (!string.IsNullOrEmpty(feature.ModelRole))
                            {
                                <MudChip T="string" Size="Size.Small"
                                         Color="@ModelRoleColor(feature.ModelRole)"
                                         Style="font-family: monospace; font-size: 0.7rem; flex-shrink: 0;">
                                    @feature.ModelRole
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                         Style="font-family: monospace; font-size: 0.7rem; flex-shrink: 0; opacity: 0.5;">
                                    @L["AiFeatures_BuiltIn"]
                                </MudChip>
                            }
                            <MudSwitch @bind-Value="feature.Enabled"
                                       Color="Color.Primary"
                                       Style="flex-shrink: 0;" />
                        </div>
                        @if (!IsFeatureAvailable(feature.Key))
                        {
                            <MudText Typo="Typo.caption" Style="color: rgba(255,150,50,0.7); padding-bottom: 6px;">
                                @L["AiFeatures_Requires"] @GetRequiredTier(feature.Key) @L["AiFeatures_Tier"] - @GetUpgradeHint(feature.Key)
                            </MudText>
                        }
                    </div>
                }
            </ChildContent>
        </MudExpansionPanel>
<MudExpansionPanel @bind-Expanded="_panel2Open"
                           Style="@PanelStyle">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome"
                             Size="Size.Small" Color="Color.Info" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        @L["AiFeatures_Enrichment"]
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                             Style="font-size: 0.7rem;">
                        @L["AiFeatures_Background"]
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info"
                             Style="font-size: 0.7rem;">
                        @EnabledCount(_enrichmentFeatures) / @_enrichmentFeatures.Count @L["AiFeatures_On"]
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary"
                         Style="margin-bottom: 16px; margin-top: 4px;">
                    @L["AiFeatures_EnrichmentDescription"]
                </MudText>
                @foreach (var f in _enrichmentFeatures)
                {
                    var feature = f;
                    <div>
                        <div style="@FeatureRowStyle">
                            <div style="flex: 1; min-width: 0;">
                                <MudText Typo="Typo.body1" Style="font-weight: 600; margin-bottom: 2px;">
                                    @feature.Name
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @feature.Description
                                </MudText>
                            </div>
                            @if (!string.IsNullOrEmpty(feature.ModelRole))
                            {
                                <MudChip T="string" Size="Size.Small"
                                         Color="@ModelRoleColor(feature.ModelRole)"
                                         Style="font-family: monospace; font-size: 0.7rem; flex-shrink: 0;">
                                    @feature.ModelRole
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                         Style="font-family: monospace; font-size: 0.7rem; flex-shrink: 0; opacity: 0.5;">
                                    @L["AiFeatures_BuiltIn"]
                                </MudChip>
                            }
                            <MudSwitch @bind-Value="feature.Enabled"
                                       Color="Color.Primary"
                                       Style="flex-shrink: 0;" />
                        </div>
                        @if (!IsFeatureAvailable(feature.Key))
                        {
                            <MudText Typo="Typo.caption" Style="color: rgba(255,150,50,0.7); padding-bottom: 6px;">
                                @L["AiFeatures_Requires"] @GetRequiredTier(feature.Key) @L["AiFeatures_Tier"] - @GetUpgradeHint(feature.Key)
                            </MudText>
                        }
                    </div>
                }
            </ChildContent>
        </MudExpansionPanel>
<MudExpansionPanel @bind-Expanded="_panel3Open"
                           Style="@PanelStyle">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.TouchApp"
                             Size="Size.Small" Color="Color.Warning" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        @L["AiFeatures_OnDemand"]
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                             Style="font-size: 0.7rem;">
                        @L["AiFeatures_UserTriggered"]
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                             Style="font-size: 0.7rem;">
                        @EnabledCount(_onDemandFeatures) / @_onDemandFeatures.Count @L["AiFeatures_On"]
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary"
                         Style="margin-bottom: 16px; margin-top: 4px;">
                    @L["AiFeatures_OnDemandDescription"]
                </MudText>
                @foreach (var f in _onDemandFeatures)
                {
                    var feature = f;
                    <div>
                        <div style="@FeatureRowStyle">
                            <div style="flex: 1; min-width: 0;">
                                <MudText Typo="Typo.body1" Style="font-weight: 600; margin-bottom: 2px;">
                                    @feature.Name
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @feature.Description
                                </MudText>
                            </div>
                            @if (!string.IsNullOrEmpty(feature.ModelRole))
                            {
                                <MudChip T="string" Size="Size.Small"
                                         Color="@ModelRoleColor(feature.ModelRole)"
                                         Style="font-family: monospace; font-size: 0.7rem; flex-shrink: 0;">
                                    @feature.ModelRole
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                         Style="font-family: monospace; font-size: 0.7rem; flex-shrink: 0; opacity: 0.5;">
                                    @L["AiFeatures_BuiltIn"]
                                </MudChip>
                            }
                            <MudSwitch @bind-Value="feature.Enabled"
                                       Color="Color.Primary"
                                       Style="flex-shrink: 0;" />
                        </div>
                        @if (!IsFeatureAvailable(feature.Key))
                        {
                            <MudText Typo="Typo.caption" Style="color: rgba(255,150,50,0.7); padding-bottom: 6px;">
                                @L["AiFeatures_Requires"] @GetRequiredTier(feature.Key) @L["AiFeatures_Tier"] - @GetUpgradeHint(feature.Key)
                            </MudText>
                        }
                    </div>
                }
            </ChildContent>
        </MudExpansionPanel>
<MudExpansionPanel @bind-Expanded="_panel4Open"
                           Style="@PanelStyle">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Schedule"
                             Size="Size.Small" Color="Color.Secondary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        @L["AiFeatures_Scheduled"]
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                             Style="font-size: 0.7rem;">
                        @L["AiFeatures_Background"]
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                             Style="font-size: 0.7rem;">
                        @EnabledCount(_scheduledFeatures) / @_scheduledFeatures.Count @L["AiFeatures_On"]
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary"
                         Style="margin-bottom: 16px; margin-top: 4px;">
                    @L["AiFeatures_ScheduledDescription"]
                </MudText>
                @foreach (var f in _scheduledFeatures)
                {
                    var feature = f;
                    <div>
                        <div style="@FeatureRowStyle">
                            <div style="flex: 1; min-width: 0;">
                                <MudText Typo="Typo.body1" Style="font-weight: 600; margin-bottom: 2px;">
                                    @feature.Name
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @feature.Description
                                </MudText>
                            </div>
                            @if (!string.IsNullOrEmpty(feature.ModelRole))
                            {
                                <MudChip T="string" Size="Size.Small"
                                         Color="@ModelRoleColor(feature.ModelRole)"
                                         Style="font-family: monospace; font-size: 0.7rem; flex-shrink: 0;">
                                    @feature.ModelRole
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                         Style="font-family: monospace; font-size: 0.7rem; flex-shrink: 0; opacity: 0.5;">
                                    @L["AiFeatures_BuiltIn"]
                                </MudChip>
                            }
                            <MudSwitch @bind-Value="feature.Enabled"
                                       Color="Color.Primary"
                                       Style="flex-shrink: 0;" />
                        </div>
                        @if (!IsFeatureAvailable(feature.Key))
                        {
                            <MudText Typo="Typo.caption" Style="color: rgba(255,150,50,0.7); padding-bottom: 6px;">
                                @L["AiFeatures_Requires"] @GetRequiredTier(feature.Key) @L["AiFeatures_Tier"] - @GetUpgradeHint(feature.Key)
                            </MudText>
                        }
                    </div>
                }
            </ChildContent>
        </MudExpansionPanel>

    </MudExpansionPanels>

</div>

@code {

    private const string PanelStyle =
        "background: var(--app-surface-2); " +
        "border: 1px solid var(--app-border); " +
        "border-radius: 8px; " +
        "margin-bottom: 12px;";
    private const string FeatureRowStyle =
        "display: flex; align-items: center; gap: 12px; " +
        "padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05);";

    private bool _panel1Open = true;
    private bool _panel2Open = true;
    private bool _panel3Open = true;
    private bool _panel4Open = true;

    private HardwareProfileDto? _profile;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _profile = await Orchestrator.GetAiProfileAsync();
    }

    private string GetTier() => _profile?.Tier ?? "unknown";

    private bool IsFeatureAvailable(string key) => GetTier().ToLowerInvariant() switch
    {
        "high"   => true,
        "medium" => key is not "whisper_sync",
        "low"    => key is "smart_labeling" or "media_type_classification",
        _        => false,
    };

    private static string GetRequiredTier(string key) => key switch
    {
        "smart_labeling" or "media_type_classification" => "Low",
        "whisper_sync"                                  => "High",
        _                                               => "Medium",
    };

    private static string GetUpgradeHint(string key) => key switch
    {
        "smart_labeling" or "media_type_classification" => "add more RAM or a GPU",
        _                                               => "a GPU will significantly improve performance",
    };

    private sealed class AiFeature
    {
        public string Key         { get; init; } = string.Empty;   // machine-readable key for tier checks
        public string Name        { get; init; } = string.Empty;
        public string Description { get; init; } = string.Empty;
        public string ModelRole   { get; init; } = string.Empty;   // "text_quality" | "text_fast" | "audio" | ""
        public bool   Enabled     { get; set; }
    }

    private readonly List<AiFeature> _ingestionFeatures =
    [
        new()
        {
            Key         = "smart_labeling",
            Name        = "Smart Labeling",
            Description = "AI cleans filenames and extracts metadata from messy names",
            ModelRole   = "text_quality",
            Enabled     = true,
        },
        new()
        {
            Key         = "media_type_classification",
            Name        = "Media Type Classification",
            Description = "Determines if an MP3 is music or an audiobook",
            ModelRole   = "text_quality",
            Enabled     = true,
        },
        new()
        {
            Key         = "audio_language_detection",
            Name        = "Audio Language Detection",
            Description = "Detects the spoken language in audiobooks",
            ModelRole   = "audio",
            Enabled     = true,
        },
    ];

    private readonly List<AiFeature> _enrichmentFeatures =
    [
        new()
        {
            Key         = "vibe_tags",
            Name        = "Vibe Tags",
            Description = "Mood and atmosphere tags derived from metadata and descriptions",
            ModelRole   = "text_quality",
            Enabled     = true,
        },
        new()
        {
            Key         = "tldr",
            Name        = "TL;DR Descriptions",
            Description = "Short one-sentence summaries generated from full descriptions",
            ModelRole   = "text_fast",
            Enabled     = true,
        },
        new()
        {
            Key         = "cover_art_validation",
            Name        = "Cover Art Validation",
            Description = "Checks whether the cover image matches the content of the file",
            ModelRole   = "text_quality",
            Enabled     = false,
        },
        new()
        {
            Key         = "audio_similarity",
            Name        = "Audio Similarity",
            Description = "Chromaprint fingerprint matching to detect duplicate audio files",
            ModelRole   = "",
            Enabled     = true,
        },
        new()
        {
            Key         = "qid_disambiguation",
            Name        = "QID Disambiguation",
            Description = "Picks the best Wikidata match when multiple candidates exist",
            ModelRole   = "text_quality",
            Enabled     = true,
        },
        new()
        {
            Key         = "series_alignment",
            Name        = "Series Alignment",
            Description = "Detects reading/watching order across multi-volume series",
            ModelRole   = "text_quality",
            Enabled     = true,
        },
        new()
        {
            Key         = "description_intelligence",
            Name        = "Description Intelligence",
            Description = "Extracts themes, mood, setting, pace, and character names from descriptions using the 8B Scholar model",
            ModelRole   = "text_scholar",
            Enabled     = true,
        },
    ];

    private readonly List<AiFeature> _onDemandFeatures =
    [
        new()
        {
            Key         = "intent_search",
            Name        = "Intent Search",
            Description = "Converts natural language queries into structured library filters",
            ModelRole   = "text_fast",
            Enabled     = true,
        },
        new()
        {
            Key         = "watching_order",
            Name        = "Watching Order",
            Description = "Suggests cross-media consumption order for a franchise or universe",
            ModelRole   = "text_fast",
            Enabled     = true,
        },
        new()
        {
            Key         = "why_factor",
            Name        = "\"Why\" Factor",
            Description = "Explains in plain English why a title was recommended to you",
            ModelRole   = "text_fast",
            Enabled     = true,
        },
        new()
        {
            Key         = "url_paste",
            Name        = "URL Paste",
            Description = "Extracts and imports metadata from a URL pasted by the user",
            ModelRole   = "text_quality",
            Enabled     = true,
        },
    ];

    private readonly List<AiFeature> _scheduledFeatures =
    [
        new()
        {
            Key         = "taste_profiling",
            Name        = "Taste Profiling",
            Description = "Builds a personal preference model from your play history",
            ModelRole   = "text_quality",
            Enabled     = true,
        },
        new()
        {
            Key         = "whisper_sync",
            Name        = "Subtitle Sync",
            Description = "Aligns subtitle timing to the audio track in video files",
            ModelRole   = "audio",
            Enabled     = false,
        },
    ];

    private static int EnabledCount(List<AiFeature> features) =>
        features.Count(f => f.Enabled);

    private static Color ModelRoleColor(string role) => role switch
    {
        "text_quality"  => Color.Primary,
        "text_fast"     => Color.Info,
        "text_scholar"  => Color.Warning,
        "audio"         => Color.Secondary,
        _               => Color.Default,
    };
}
