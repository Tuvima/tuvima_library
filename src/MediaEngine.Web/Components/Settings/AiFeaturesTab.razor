@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator

<div class="tl-page">
    <AppActionBar Align="AppHorizontalAlignment.End" Class="mb-3">
        <AppButton Label="Save feature flags"
                   ButtonStyle="AppButtonStyle.Filled"
                   Tone="AppUiTone.Primary"
                   OnClick="SaveAsync"
                   Disabled="@(_config is null || _saving)" />
    </AppActionBar>

    @if (_config is null)
    {
        <AppAlert Tone="AppUiTone.Warning">AI config unavailable. Feature toggles are not shown as live.</AppAlert>
    }
    else
    {
        <AppAlert Tone="AppUiTone.Info" Class="mb-3">
            Feature toggles persist to config/ai.json. A feature is active only when it is enabled, connected, the Engine is healthy, and required model/hardware checks pass.
        </AppAlert>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <AppAlert Tone="@MessageTone" Class="mb-3">@_message</AppAlert>
        }

        <AppTable Class="ai-feature-table">
            <thead>
                <tr>
                    <th>Feature</th>
                    <th>Config key</th>
                    <th>Dependency</th>
                    <th>Status</th>
                    <th>Enabled</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var feature in FeatureDefinitions())
                {
                    var enabled = IsEnabled(feature.Key);
                    var dependency = GetDependency(feature);
                    <tr>
                        <td>
                            <strong class="ai-feature-table__name">@feature.Name</strong>
                            <span class="ai-feature-table__description">@feature.Description</span>
                        </td>
                        <td><AppChip Text="@feature.Key" /></td>
                        <td>
                            <span class="ai-feature-table__description">Model: @(feature.RequiredModelRole ?? "none")</span>
                            <span class="ai-feature-table__description">Tier: @feature.RequiredHardwareTier</span>
                        </td>
                        <td>
                            <AppChip Text="@dependency.Label" Tone="@dependency.Tone" />
                            <span class="ai-feature-table__description">@dependency.Explanation</span>
                        </td>
                        <td>
                            <AppSwitchRow Value="@enabled"
                                          ValueChanged="@((bool value) => SetEnabled(feature.Key, value))"
                                          Disabled="@(!feature.Connected)"
                                          StopClickPropagation="true" />
                            @if (!feature.Connected)
                            {
                                <span class="ai-feature-table__description">Saved setting is not connected to Engine behavior yet.</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </AppTable>
    }
</div>

@code {
    private AiConfigDto? _config;
    private AiHealthStatusDto? _status;
    private List<AiModelStatusDto> _models = [];
    private bool _saving;
    private string? _message;
    private Severity _messageSeverity = Severity.Info;
    private AppUiTone MessageTone => ToTone(_messageSeverity);

    protected override async Task OnInitializedAsync()
    {
        _config = await Orchestrator.GetAiConfigAsync();
        _status = await Orchestrator.GetAiStatusAsync();
        _models = (await Orchestrator.GetAiModelStatusesAsync()).ToList();
    }

    private bool IsEnabled(string key) => _config?.Features.TryGetValue(key, out var enabled) == true && enabled;

    private void SetEnabled(string key, bool enabled)
    {
        if (_config is null)
            return;

        _config.Features[key] = enabled;
    }

    private async Task SaveAsync()
    {
        if (_config is null)
            return;

        _saving = true;
        var ok = await Orchestrator.SaveAiConfigAsync(_config);
        _saving = false;
        _messageSeverity = ok ? Severity.Success : Severity.Error;
        _message = ok ? "AI feature flags saved." : "AI feature flags could not be saved.";
    }

    private DependencyStatus GetDependency(FeatureDefinition feature)
    {
        if (!feature.Connected)
            return new("Not connected", "This setting is saved but the Engine does not use it yet.", AppUiTone.Neutral);

        if (_status is null)
            return new("Engine unavailable", "AI status could not be loaded.", AppUiTone.Warning);

        if (!IsEnabled(feature.Key))
            return new("Disabled", "Enable the feature and save config.", AppUiTone.Neutral);

        if (!string.IsNullOrWhiteSpace(feature.RequiredModelRole))
        {
            var model = _models.FirstOrDefault(m => string.Equals(m.Role, feature.RequiredModelRole, StringComparison.OrdinalIgnoreCase));
            if (model is null)
                return new("Missing model", $"{feature.RequiredModelRole} is not configured.", AppUiTone.Error);

            if (model.State.Equals("Downloading", StringComparison.OrdinalIgnoreCase))
                return new("Downloading model", $"{feature.RequiredModelRole} is still downloading.", AppUiTone.Info);

            if (!model.State.Equals("Ready", StringComparison.OrdinalIgnoreCase) && !model.Loaded && !model.Active)
                return new("Missing model", $"{feature.RequiredModelRole} is not downloaded.", AppUiTone.Error);
        }

        if (!HardwareAdequate(feature.RequiredHardwareTier))
            return new("Hardware limited", $"This feature is best on {feature.RequiredHardwareTier} tier hardware.", AppUiTone.Warning);

        if (!_status.IsReady && feature.RequiredModelRole is not null)
            return new("Enabled but blocked", "AI subsystem is not fully ready.", AppUiTone.Warning);

        return new("Ready", $"{feature.RequiredModelRole ?? "No model"} dependency is available.", AppUiTone.Success);
    }

    private bool HardwareAdequate(string tier)
    {
        var current = _config?.HardwareProfile.Tier ?? "unknown";
        return TierRank(current) >= TierRank(tier);
    }

    private static int TierRank(string tier) => tier.ToLowerInvariant() switch
    {
        "high" => 3,
        "medium" => 2,
        "low" or "starter" => 1,
        _ => 0,
    };

    private static AppUiTone ToTone(Severity severity) => severity switch
    {
        Severity.Success => AppUiTone.Success,
        Severity.Warning => AppUiTone.Warning,
        Severity.Error => AppUiTone.Error,
        _ => AppUiTone.Info,
    };

    private sealed record DependencyStatus(string Label, string Explanation, AppUiTone Tone);
    private sealed record FeatureDefinition(string Key, string Name, string Description, string? RequiredModelRole, string RequiredHardwareTier, bool Connected);

    private static IReadOnlyList<FeatureDefinition> FeatureDefinitions() =>
    [
        new("smart_labeling", "Smart labeling", "Cleans filenames and extracts initial metadata during ingestion.", "text_fast", "low", true),
        new("type_logic", "Type logic", "Classifies ambiguous media types during ingestion.", "text_fast", "low", true),
        new("audio_language_detection", "Audio language detection", "Uses Whisper to detect audio language.", "audio", "medium", true),
        new("qid_disambiguation", "QID disambiguation", "Ranks ambiguous Wikidata candidates.", "text_quality", "medium", true),
        new("series_alignment", "Series alignment", "Assists order and grouping checks for multi-part works.", "text_quality", "medium", true),
        new("watching_order", "Watching order", "Optional on-demand order advice.", "text_fast", "low", true),
        new("vibe_tags", "Vibe tags", "Generates controlled vocabulary mood tags.", "text_quality", "medium", true),
        new("tldr", "TL;DR", "Generates short summaries from descriptions.", "text_fast", "low", true),
        new("cover_art_validation", "Cover art validation", "Checks whether cover images appear to match content.", "text_quality", "medium", true),
        new("whisper_alignment", "Whisper alignment", "Bakes transcript timing when audio models are available.", "audio", "medium", true),
        new("subtitle_sync", "Subtitle sync", "Subtitle alignment is saved as a flag but is not connected to Engine behavior yet.", "audio", "medium", false),
        new("taste_profiling", "Taste profiling", "Builds local preference signals from usage history.", "text_quality", "medium", true),
        new("why_factor", "Why factor", "Explains why an item matches a local taste profile.", "text_fast", "low", true),
        new("intent_search", "Intent search", "Parses natural-language search into structured filters.", "text_fast", "low", true),
        new("url_paste", "URL paste", "Extracts metadata from a pasted URL.", "text_quality", "medium", true),
        new("description_intelligence", "Description intelligence", "Extracts themes, mood, setting, and entities from descriptions.", "text_scholar", "high", true),
    ];
}
