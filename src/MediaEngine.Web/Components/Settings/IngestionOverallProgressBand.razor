@namespace MediaEngine.Web.Components.Settings
@using System.Globalization
@using MediaEngine.Web.Services.Integration
@inject IStringLocalizer<SharedStrings> L

<section class="ingestion-overall" aria-label="@L["Ingestion_OverallTitle"]">
    <div>
        <MudText Typo="Typo.subtitle1" Class="ingestion-overall__title">@L["Ingestion_OverallTitle"]</MudText>
        <MudText Typo="Typo.body2" Class="ingestion-overall__subtitle">@L["Ingestion_OverallSubtitle"]</MudText>
    </div>
    <div class="ingestion-overall__center">
        <strong>@L["Ingestion_OverallProcessed", FormatCount(Progress.ProcessedFiles), FormatCount(Progress.TotalFiles)]</strong>
        @if (Progress.ActiveStageTotal > 0)
        {
            <small>@L["Ingestion_OverallStageProgress", L[Progress.ActiveStageLabelKey], FormatCount(Progress.ActiveStageCount), FormatCount(Progress.ActiveStageTotal), Progress.ActiveStagePercent.ToString("0.#", CultureInfo.CurrentCulture)]</small>
        }
        <AppProgressBar Value="@Progress.Percent" Class="ingestion-overall__bar" />
    </div>
    <div class="ingestion-overall__meta">
        <strong>@Progress.Percent.ToString("0.#", CultureInfo.CurrentCulture)%</strong>
        <span>@L["Ingestion_OverallPipelineComplete"]</span>
        <small>@L["Ingestion_OverallActiveStage", L[Progress.ActiveStageLabelKey]]</small>
        <small>@L[Progress.ActiveStageDetailKey]</small>
        @if (Progress.EstimatedSecondsRemaining is > 0)
        {
            <small>@L["Ingestion_OverallRemaining", FormatRemaining(Progress.EstimatedSecondsRemaining.Value)]</small>
        }
    </div>
</section>

@code {
    [Parameter] public IngestionOverallProgress Progress { get; set; } = new(0, 0, 0, "Ingestion_StageScanning", "Ingestion_StageScanningDetail", 0, 0, 0, null);
    [Parameter] public IReadOnlyList<IngestionDashboardStage> Stages { get; set; } = [];

    private static string FormatCount(int value) => value.ToString("N0", CultureInfo.CurrentCulture);

    private static string FormatRemaining(int seconds)
    {
        var duration = TimeSpan.FromSeconds(Math.Max(0, seconds));
        return duration.TotalHours >= 1
            ? $"{(int)duration.TotalHours}h {duration.Minutes}m"
            : $"{Math.Max(1, (int)Math.Ceiling(duration.TotalMinutes))}m";
    }
}
