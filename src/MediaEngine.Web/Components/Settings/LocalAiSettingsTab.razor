@namespace MediaEngine.Web.Components.Settings

<div class="tl-page">
    <MudTabs Rounded="true" Elevation="0" Color="Color.Primary" Position="Position.Top" Class="settings-tab-strip">
        <MudTabPanel Text="Models" Icon="@Icons.Material.Outlined.Storage">
            <ModelsTab />
        </MudTabPanel>
        <MudTabPanel Text="Features" Icon="@Icons.Material.Outlined.ToggleOn">
            <AiFeaturesTab />
        </MudTabPanel>
        <MudTabPanel Text="Vocabulary" Icon="@Icons.Material.Outlined.Style">
            <VibeVocabularyTab />
        </MudTabPanel>
        <MudTabPanel Text="Schedule" Icon="@Icons.Material.Outlined.Schedule">
            <AiScheduleTab />
        </MudTabPanel>
        <MudTabPanel Text="Limits" Icon="@Icons.Material.Outlined.Speed">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                    Planned / not connected. Runtime limit controls are not persisted yet and do not change Engine behavior.
                </MudAlert>
                <MudGrid Spacing="4">
                    <MudItem xs="12" md="4"><MudNumericField T="int" @bind-Value="_maxConcurrentJobs" Label="Max concurrent AI jobs" Variant="Variant.Outlined" Min="1" Max="8" Disabled="true" /></MudItem>
                    <MudItem xs="12" md="4"><MudSwitch T="bool" @bind-Value="_pauseDuringPlayback" Color="Color.Primary" Label="Pause AI during playback" Disabled="true" /></MudItem>
                    <MudItem xs="12" md="4"><MudSwitch T="bool" @bind-Value="_pauseDuringTranscode" Color="Color.Primary" Label="Pause AI during transcode" Disabled="true" /></MudItem>
                    <MudItem xs="12" md="4"><MudSwitch T="bool" @bind-Value="_quietHours" Color="Color.Primary" Label="Quiet hours" Disabled="true" /></MudItem>
                    <MudItem xs="12" md="4"><MudSwitch T="bool" @bind-Value="_lowResourceMode" Color="Color.Primary" Label="Low resource mode" Disabled="true" /></MudItem>
                    <MudItem xs="12" md="12">
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                            Local AI work runs on this server and is intended to stay local unless a provider feature explicitly says otherwise.
                        </MudAlert>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
</div>

@code {
    private int _maxConcurrentJobs = 2;
    private bool _pauseDuringPlayback = true;
    private bool _pauseDuringTranscode = true;
    private bool _quietHours;
    private bool _lowResourceMode;
}
