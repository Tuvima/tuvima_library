@namespace MediaEngine.Web.Components.Settings

@* A single search result row matching the reference layout:
   [Thumbnail] [Title (bold) + by Author + description] [Year]
   Supports click-to-highlight via IsSelected; confirm is separate. *@

<div class="search-result-row @(IsSelected ? "search-result-selected" : "")"
     @onclick="@(() => OnSelected.InvokeAsync(Result))"
     style="display: flex; gap: 14px; padding: 12px 14px;
            border-bottom: 1px solid var(--mud-palette-lines-default);
            cursor: pointer; transition: background 0.15s ease, border-color 0.15s ease;
            @(IsSelected
                ? "border-left: 3px solid var(--mud-palette-primary); background: rgba(var(--mud-palette-primary-rgb), 0.08);"
                : "border-left: 3px solid transparent;")">

    @* ── Thumbnail (120×180px) ───────────────────────────────────── *@
    <div style="flex-shrink: 0; width: 120px; height: 180px; border-radius: 4px; overflow: hidden;
                background: var(--mud-palette-surface); display: flex; align-items: center; justify-content: center;">
        @if (!string.IsNullOrWhiteSpace(Result.ThumbnailUrl))
        {
            <img src="@Result.ThumbnailUrl" alt="@Result.Title"
                 style="width: 100%; height: 100%; object-fit: cover;"
                 loading="lazy" />
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported"
                     Size="Size.Small" Color="Color.Secondary" />
        }
    </div>

    @* ── Text content ─────────────────────────────────────────────── *@
    <div style="flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px;">
        <MudText Typo="Typo.body1" Style="font-weight: 600;">
            @Result.Title
        </MudText>

        @if (!string.IsNullOrWhiteSpace(Result.Author))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                by @Result.Author
            </MudText>
        }

        @if (!string.IsNullOrWhiteSpace(Result.Description))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary"
                     Style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
                            overflow: hidden; text-overflow: ellipsis; line-height: 1.4; margin-top: 2px; font-size: 0.8rem;">
                @Result.Description
            </MudText>
        }
    </div>

    @* ── Year + Match % (top-right) ─────────────────────────────── *@
    @if (!string.IsNullOrWhiteSpace(Result.Year) || Result.Confidence > 0)
    {
        <div style="flex-shrink: 0; padding-top: 2px; text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 2px;">
            @if (!string.IsNullOrWhiteSpace(Result.Year))
            {
                <MudText Typo="Typo.body1" Style="font-weight: 500;">
                    @MediaEngine.Web.Shared.DateFormatHelper.FormatFriendlyDate(Result.Year)
                </MudText>
            }
            @if (Result.Confidence > 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.72rem; white-space: nowrap;">
                    @((Result.Confidence * 100).ToString("F0"))% match
                </MudText>
            }
        </div>
    }
</div>

@code {
    /// <summary>The search result to display.</summary>
    [Parameter, EditorRequired]
    public MetadataSearchResultDto Result { get; set; } = null!;

    /// <summary>Whether this card is currently highlighted/selected.</summary>
    [Parameter]
    public bool IsSelected { get; set; }

    /// <summary>Fired when the user clicks the row (for highlight, not confirmation).</summary>
    [Parameter]
    public EventCallback<MetadataSearchResultDto> OnSelected { get; set; }
}
