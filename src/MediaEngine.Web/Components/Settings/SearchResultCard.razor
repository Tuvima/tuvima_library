@namespace MediaEngine.Web.Components.Settings

@* A single search result row matching the reference layout:
   [Thumbnail] [Title (bold) + by Author + description] [Year]
   Supports click-to-highlight via IsSelected; confirm is separate. *@

<div class="search-result-row @(IsSelected ? "search-result-selected" : "")"
     @onclick="@(() => OnSelected.InvokeAsync(Result))">
<div class="search-result-row__thumb">
        @if (!string.IsNullOrWhiteSpace(Result.ThumbnailUrl))
        {
            <img src="@Result.ThumbnailUrl" alt="@Result.Title"
                 class="search-result-row__image"
                 loading="lazy" />
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported"
                     Size="Size.Small" Color="Color.Secondary" />
        }
    </div>
<div class="search-result-row__body">
        <MudText Typo="Typo.body1" Class="tl-text-strong">
            @Result.Title
        </MudText>

        @if (!string.IsNullOrWhiteSpace(Result.Author))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                by @Result.Author
            </MudText>
        }

        @if (!string.IsNullOrWhiteSpace(Result.Description))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary"
                     Class="search-result-row__description">
                @Result.Description
            </MudText>
        }
    </div>
@if (!string.IsNullOrWhiteSpace(Result.Year) || Result.Confidence > 0)
    {
        <div class="search-result-row__meta">
            @if (!string.IsNullOrWhiteSpace(Result.Year))
            {
                <MudText Typo="Typo.body1" Class="tl-text-strong">
                    @MediaEngine.Web.Shared.DateFormatHelper.FormatFriendlyDate(Result.Year)
                </MudText>
            }
            @if (Result.Confidence > 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="tl-nowrap">
                    @((Result.Confidence * 100).ToString("F0"))% match
                </MudText>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public MetadataSearchResultDto Result { get; set; } = null!;
    [Parameter]
    public bool IsSelected { get; set; }
    [Parameter]
    public EventCallback<MetadataSearchResultDto> OnSelected { get; set; }
}
