@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs

@* â”€â”€ Field-by-field diff grid comparing current canonical values vs provider result â”€â”€ *@

<div class="diff-grid-wrap">
    <table class="diff-grid-table">
        <thead>
            <tr>
                <th class="diff-grid-th diff-grid-th-field">Field</th>
                <th class="diff-grid-th">Current</th>
                <th class="diff-grid-th">Provider</th>
                <th class="diff-grid-th diff-grid-th-check">
                    <MudCheckBox T="bool" Value="@_allChecked" ValueChanged="@ToggleAll"
                                 Size="Size.Small" Color="Color.Primary"
                                 Style="margin:0; padding:0;" />
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in BuildDiffEntries())
            {
                <tr class="@(entry.IsDifferent ? "diff-grid-row-diff" : "diff-grid-row-same")">
                    <td class="diff-grid-td diff-grid-td-key">@entry.DisplayName</td>
                    <td class="diff-grid-td diff-grid-td-current">
                        @if (entry.Key == "cover" && !string.IsNullOrEmpty(CurrentCoverUrl))
                        {
                            <img src="@CurrentCoverUrl" alt="Current" class="diff-grid-cover-thumb" />
                        }
                        else
                        {
                            @(Truncate(entry.CurrentValue ?? "\u2014", 40))
                        }
                    </td>
                    <td class="diff-grid-td diff-grid-td-provider">
                        @if (entry.Key == "cover" && !string.IsNullOrEmpty(entry.ProviderValue))
                        {
                            <img src="@entry.ProviderValue" alt="Provider" class="diff-grid-cover-thumb" />
                        }
                        else
                        {
                            @(Truncate(entry.ProviderValue ?? "\u2014", 40))
                        }
                    </td>
                    <td class="diff-grid-td diff-grid-td-check">
                        @if (!string.IsNullOrEmpty(entry.ProviderValue))
                        {
                            <MudCheckBox T="bool" Value="@entry.IsSelected"
                                         ValueChanged="@(v => OnFieldToggled(entry, v))"
                                         Size="Size.Small" Color="Color.Primary"
                                         Style="margin:0; padding:0;" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public List<CanonicalFieldViewModel> CanonicalFields { get; set; } = [];
    [Parameter] public SearchResultItemViewModel? ProviderItem { get; set; }
    [Parameter] public string? CurrentCoverUrl { get; set; }
    [Parameter] public Dictionary<string, string> SelectedFields { get; set; } = new();
    [Parameter] public EventCallback<Dictionary<string, string>> SelectedFieldsChanged { get; set; }
    [Parameter] public string? SelectedCoverUrl { get; set; }
    [Parameter] public EventCallback<string?> SelectedCoverUrlChanged { get; set; }

    private bool _allChecked;

    /// <summary>Build the diff entries comparing canonical values vs provider raw fields.</summary>
    private List<FieldDiffEntry> BuildDiffEntries()
    {
        var entries = new List<FieldDiffEntry>();
        if (ProviderItem?.RawFields is null) return entries;

        // Ordered field list for display
        var displayOrder = new[] { "title", "author", "year", "description", "cover",
                                   "isbn", "asin", "narrator", "series", "series_position",
                                   "genre", "publisher", "page_count", "language" };

        var allKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var k in displayOrder) allKeys.Add(k);
        foreach (var k in ProviderItem.RawFields.Keys) allKeys.Add(k);

        foreach (var key in displayOrder.Concat(
            ProviderItem.RawFields.Keys
                .Where(k => !displayOrder.Contains(k, StringComparer.OrdinalIgnoreCase))
                .OrderBy(k => k)))
        {
            if (!allKeys.Remove(key)) continue; // skip duplicates

            var canonical = CanonicalFields.FirstOrDefault(f =>
                string.Equals(f.Key, key, StringComparison.OrdinalIgnoreCase));

            ProviderItem.RawFields.TryGetValue(key, out var providerValue);

            // Skip fields where provider has no data
            if (string.IsNullOrEmpty(providerValue) && canonical is null) continue;

            var currentValue = canonical?.Value;
            var isDifferent = !string.Equals(currentValue, providerValue, StringComparison.OrdinalIgnoreCase);

            // Cover is a special case â€” compare thumbnails
            if (string.Equals(key, "cover", StringComparison.OrdinalIgnoreCase))
            {
                providerValue = ProviderItem.ThumbnailUrl;
                isDifferent = !string.IsNullOrEmpty(providerValue);
            }

            var isSelected = key == "cover"
                ? SelectedCoverUrl is not null
                : SelectedFields.ContainsKey(key);

            entries.Add(new FieldDiffEntry(
                Key: key,
                DisplayName: GetDisplayName(key),
                CurrentValue: currentValue,
                CurrentConfidence: canonical?.Confidence,
                ProviderValue: providerValue,
                IsDifferent: isDifferent,
                IsSelected: isSelected));
        }

        return entries;
    }

    private void OnFieldToggled(FieldDiffEntry entry, bool isChecked)
    {
        if (entry.Key == "cover")
        {
            SelectedCoverUrl = isChecked ? entry.ProviderValue : null;
            SelectedCoverUrlChanged.InvokeAsync(SelectedCoverUrl);
        }
        else
        {
            if (isChecked && !string.IsNullOrEmpty(entry.ProviderValue))
                SelectedFields[entry.Key] = entry.ProviderValue;
            else
                SelectedFields.Remove(entry.Key);
            SelectedFieldsChanged.InvokeAsync(SelectedFields);
        }
        UpdateAllChecked();
    }

    private void ToggleAll(bool val)
    {
        _allChecked = val;
        var entries = BuildDiffEntries().Where(e => !string.IsNullOrEmpty(e.ProviderValue)).ToList();

        SelectedFields.Clear();
        SelectedCoverUrl = null;

        if (val)
        {
            foreach (var e in entries)
            {
                if (e.Key == "cover")
                    SelectedCoverUrl = e.ProviderValue;
                else if (!string.IsNullOrEmpty(e.ProviderValue))
                    SelectedFields[e.Key] = e.ProviderValue;
            }
        }

        SelectedFieldsChanged.InvokeAsync(SelectedFields);
        SelectedCoverUrlChanged.InvokeAsync(SelectedCoverUrl);
    }

    private void UpdateAllChecked()
    {
        var entries = BuildDiffEntries().Where(e => !string.IsNullOrEmpty(e.ProviderValue)).ToList();
        _allChecked = entries.Count > 0 && entries.All(e => e.IsSelected);
    }

    private static string GetDisplayName(string key) => key switch
    {
        "title" => "Title",
        "author" => "Author",
        "year" => "Year",
        "description" => "Description",
        "cover" => "Cover Art",
        "isbn" => "ISBN",
        "asin" => "ASIN",
        "narrator" => "Narrator",
        "series" => "Series",
        "series_position" => "Series #",
        "genre" => "Genre",
        "publisher" => "Publisher",
        "page_count" => "Pages",
        "language" => "Language",
        "media_type" => "Media Type",
        "dominant_color" => "Color",
        _ => key.Replace("_", " "),
    };

    private static string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength].TrimEnd() + "\u2026";
}

<style>
    .diff-grid-wrap {
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        overflow: hidden;
        margin: 4px 0 8px;
    }

    .diff-grid-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.73rem;
    }

    .diff-grid-th {
        background: rgba(255, 255, 255, 0.05);
        padding: 7px 8px;
        font-weight: 700;
        font-size: 0.68rem;
        color: rgba(248, 248, 248, 0.45);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        text-align: left;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }

    .diff-grid-th-field { width: 70px; }
    .diff-grid-th-check { width: 36px; text-align: center; }

    .diff-grid-td {
        padding: 6px 8px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        vertical-align: middle;
    }

    .diff-grid-td-key {
        font-weight: 600;
        color: rgba(248, 248, 248, 0.55);
        white-space: nowrap;
    }

    .diff-grid-td-current {
        color: rgba(248, 248, 248, 0.60);
        word-break: break-word;
        max-width: 140px;
    }

    .diff-grid-td-provider {
        color: rgba(248, 248, 248, 0.80);
        word-break: break-word;
        max-width: 140px;
    }

    .diff-grid-td-check { text-align: center; }

    .diff-grid-row-diff {
        border-left: 3px solid rgba(201, 146, 46, 0.50);
    }

    .diff-grid-row-same {
        border-left: 3px solid transparent;
        opacity: 0.65;
    }

    .diff-grid-cover-thumb {
        width: 48px;
        height: 72px;
        object-fit: cover;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.04);
    }

    .diff-grid-table tr:last-child .diff-grid-td {
        border-bottom: none;
    }
</style>
