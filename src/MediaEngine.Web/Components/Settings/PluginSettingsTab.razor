@namespace MediaEngine.Web.Components.Settings
@using System.Globalization
@using System.Text.Json
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar

@if (_loading)
{
    <div class="settings-plugin-loading">
        <AppSkeleton Size="AppControlSize.Large" />
        <div class="settings-plugin-loading__grid">
            <AppSkeleton Size="AppControlSize.Large" />
            <AppSkeleton Size="AppControlSize.Large" />
        </div>
    </div>
}
else
{
    <div class="settings-playback-page settings-plugin-page">
        <AppCard Class="settings-summary-strip settings-plugin-summary">
            <div class="settings-plugin-summary__grid">
                <AppMetricCard Icon="@Icons.Material.Outlined.Extension"
                               Label="Plugins"
                               Value="@_plugins.Count.ToString()"
                               Tone="AppStatusTone.Primary" />
                <AppMetricCard Icon="@Icons.Material.Outlined.PowerSettingsNew"
                               Label="Enabled"
                               Value="@_plugins.Count(p => p.Enabled).ToString()"
                               Tone="AppStatusTone.Success" />
                <AppMetricCard Icon="@Icons.Material.Outlined.DynamicFeed"
                               Label="Dynamic"
                               Value="@_plugins.Count(p => !p.IsBuiltIn).ToString()"
                               Tone="AppStatusTone.Info" />
                <AppMetricCard Icon="@Icons.Material.Outlined.ReportProblem"
                               Label="Needs setup"
                               Value="@_plugins.Count(p => !string.IsNullOrWhiteSpace(p.LoadError)).ToString()"
                               Tone="AppStatusTone.Warning" />
                <div class="settings-plugin-summary__actions">
                    <AppButton Label="Reload"
                               StartIcon="@Icons.Material.Outlined.Refresh"
                               Tone="AppUiTone.Primary"
                               OnClick="@ReloadAsync" />
                </div>
            </div>
        </AppCard>

        <AppAlert Tone="AppUiTone.Info">
            Partial. Plugin list, enable/disable, plugin-provided settings, health checks, jobs, delete actions, and the approved GitHub catalog use Engine APIs where available. Install and update marketplace flows are planned and are not shown as live controls.
        </AppAlert>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <AppAlert Tone="AppUiTone.Error">@_error</AppAlert>
        }

        <div class="settings-plugin-manager">
            <AppCard Class="settings-plugin-list-panel">
                <AppSearchField Value="@_search"
                                ValueChanged="@((string? value) => _search = value ?? string.Empty)"
                                Placeholder="Search plugins..." />

                <AppActionBar Align="AppHorizontalAlignment.Start" Class="settings-plugin-filter-row">
                    @FilterButton("all", "All")
                    @FilterButton("enabled", "Enabled")
                    @FilterButton("dynamic", "Dynamic")
                    @FilterButton("setup", "Needs setup")
                </AppActionBar>

                <div class="settings-plugin-list">
                    @foreach (var plugin in FilteredPlugins)
                    {
                        var selected = string.Equals(plugin.Id, _selectedPluginId, StringComparison.OrdinalIgnoreCase);
                        <div class="settings-plugin-list-item @(selected ? "settings-plugin-list-item--selected" : null)"
                             role="button"
                             tabindex="0"
                             @onkeydown="@(args => HandlePluginKeyDown(args, plugin.Id))"
                             @onclick="@(() => SelectPlugin(plugin.Id))">
                            <span class="settings-plugin-list-item__icon">
                                <MudIcon Icon="@PluginIcon(plugin)" Size="Size.Small" />
                            </span>
                            <span class="settings-plugin-list-item__body">
                                <span class="settings-plugin-list-item__title">@plugin.Name</span>
                                <span class="settings-plugin-list-item__meta">@plugin.Id - v@(plugin.Version)</span>
                                <span class="settings-plugin-list-item__chips">
                                    <span>@(plugin.IsBuiltIn ? "Built-in" : "Dynamic")</span>
                                    @if (plugin.ToolRequirements.Count > 0)
                                    {
                                        <span>Tools</span>
                                    }
                                    @if (plugin.AiPermissions.Count > 0)
                                    {
                                        <span>AI</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(plugin.LoadError))
                                    {
                                        <span class="settings-plugin-list-item__chip--warning">Setup</span>
                                    }
                                </span>
                            </span>
                            <AppSwitchRow Value="@plugin.Enabled"
                                          ValueChanged="@(v => SetEnabledAsync(plugin, v))"
                                          StopClickPropagation="true"
                                          Class="settings-plugin-list-item__toggle" />
                        </div>
                    }
                </div>

                <div class="settings-plugin-list-count">@FilteredPlugins.Count() of @_plugins.Count plugins shown</div>
            </AppCard>

            <AppCard Class="settings-plugin-detail-panel">
                @if (SelectedPlugin is null)
                {
                    <AppAlert Tone="AppUiTone.Info">No plugin is selected.</AppAlert>
                }
                else
                {
                    var plugin = SelectedPlugin;

                    <div class="settings-plugin-detail-stack">
                        <div class="settings-plugin-detail-header">
                            <span class="settings-plugin-detail-header__icon">
                                <MudIcon Icon="@PluginIcon(plugin)" />
                            </span>
                            <div class="settings-plugin-detail-header__copy">
                                <div class="settings-plugin-detail-header__title-row">
                                    <span class="settings-plugin-detail-header__title">@plugin.Name</span>
                                    <AppChip Text="@plugin.Version" />
                                    <AppChip Text="@(plugin.IsBuiltIn ? "Built-in" : "Dynamic")"
                                             Tone="@(plugin.IsBuiltIn ? AppUiTone.Neutral : AppUiTone.Info)" />
                                </div>
                                <div class="settings-plugin-detail-header__id">@plugin.Id</div>
                                <div class="settings-plugin-detail-header__description">@plugin.Description</div>
                            </div>
                            <AppSwitchRow Value="@plugin.Enabled"
                                          ValueChanged="@(v => SetEnabledAsync(plugin, v))"
                                          Class="settings-plugin-detail-header__switch" />
                        </div>

                        @if (!string.IsNullOrWhiteSpace(plugin.LoadError))
                        {
                            <AppAlert Tone="AppUiTone.Warning">@plugin.LoadError</AppAlert>
                        }

                        <div class="settings-plugin-chiprow">
                            @foreach (var capability in plugin.Capabilities)
                            {
                                <MudTooltip Text="@capability.Description">
                                    <AppChip Text="@capability.Name" />
                                </MudTooltip>
                            }
                            @if (plugin.ToolRequirements.Count > 0)
                            {
                                <AppChip Text="@($"{plugin.ToolRequirements.Count} tool(s)")"
                                         Tone="AppUiTone.Warning" />
                            }
                            @if (plugin.AiPermissions.Count > 0)
                            {
                                <AppChip Text="@($"{plugin.AiPermissions.Count} AI permission(s)")"
                                         Tone="AppUiTone.Primary" />
                            }
                        </div>

                        <AppTabs Class="settings-tab-strip settings-plugin-tabs">
                            <AppTabPanel Text="Settings" Icon="@Icons.Material.Outlined.Tune">
                                <div class="settings-plugin-tab-body">
                                    @{
                                        var settingEntries = GetSettingEntries(plugin).ToList();
                                        var primarySettings = settingEntries.Where(setting => !setting.Advanced).ToList();
                                        var advancedSettings = settingEntries.Where(setting => setting.Advanced).ToList();
                                    }
                                    @if (settingEntries.Count == 0)
                                    {
                                        <AppAlert Tone="AppUiTone.Info">This plugin does not expose user settings.</AppAlert>
                                    }
                                    else
                                    {
                                        @foreach (var setting in primarySettings)
                                        {
                                            @SettingEditor(plugin, setting)
                                        }

                                        @if (advancedSettings.Count > 0)
                                        {
                                            <MudExpansionPanels Elevation="0" Dense="true" Class="mb-2">
                                                <MudExpansionPanel Text="Advanced settings">
                                                    @foreach (var setting in advancedSettings)
                                                    {
                                                        @SettingEditor(plugin, setting)
                                                    }
                                                </MudExpansionPanel>
                                            </MudExpansionPanels>
                                        }
                                    }
                                </div>
                            </AppTabPanel>
                            <AppTabPanel Text="Jobs & health" Icon="@Icons.Material.Outlined.HealthAndSafety">
                                <div class="settings-plugin-tab-body">
                                    <AppActionBar Align="AppHorizontalAlignment.Start">
                                        <AppButton Label="Check health"
                                                   StartIcon="@Icons.Material.Outlined.HealthAndSafety"
                                                   Size="AppControlSize.Compact"
                                                   OnClick="@(() => CheckHealthAsync(plugin))" />
                                        <AppButton Label="Refresh jobs"
                                                   StartIcon="@Icons.Material.Outlined.History"
                                                   Size="AppControlSize.Compact"
                                                   Tone="AppUiTone.Primary"
                                                   OnClick="@(() => LoadJobsAsync(plugin))" />
                                    </AppActionBar>

                                    @if (_health.TryGetValue(plugin.Id, out var health))
                                    {
                                        <AppAlert Tone="@HealthTone(health.Status)">
                                            @health.Status
                                            @if (health.Checks.Count > 0)
                                            {
                                                <span> - @string.Join(" ", health.Checks.Select(c => c.Message).Where(m => !string.IsNullOrWhiteSpace(m)))</span>
                                            }
                                        </AppAlert>
                                    }

                                    @if (_jobs.TryGetValue(plugin.Id, out var jobs) && jobs.Count > 0)
                                    {
                                        <AppTable Class="settings-plugin-job-table">
                                            <thead>
                                                <tr>
                                                    <th>Status</th>
                                                    <th>Type</th>
                                                    <th>Assets</th>
                                                    <th>Segments</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var job in jobs.Take(8))
                                                {
                                                    <tr>
                                                        <td>@job.Status</td>
                                                        <td>@job.JobType</td>
                                                        <td>@job.AssetsScanned</td>
                                                        <td>@job.SegmentsWritten</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </AppTable>
                                    }
                                    else
                                    {
                                        <AppAlert Tone="AppUiTone.Info">No recent jobs are recorded for this plugin.</AppAlert>
                                    }
                                </div>
                            </AppTabPanel>
                            <AppTabPanel Text="Approved catalog" Icon="@Icons.Material.Outlined.Verified">
                                <div class="settings-plugin-tab-body">
                                    <div class="settings-plugin-catalog-header">
                                        <AppButton Label="Refresh GitHub catalog"
                                                   StartIcon="@Icons.Material.Outlined.CloudDownload"
                                                   Size="AppControlSize.Compact"
                                                   Tone="AppUiTone.Primary"
                                                   OnClick="@LoadApprovedCatalogAsync" />
                                        @if (_approvedCatalog?.LastUpdated is not null)
                                        {
                                            <span class="settings-plugin-updated">Updated @_approvedCatalog.LastUpdated.Value.ToLocalTime().ToString("g")</span>
                                        }
                                    </div>

                                    @if (_approvedCatalogLoading)
                                    {
                                        <AppSkeleton Size="AppControlSize.Large" />
                                    }
                                    else if (_approvedCatalog is null)
                                    {
                                        <AppAlert Tone="AppUiTone.Info">The approved plugin catalog has not been loaded yet.</AppAlert>
                                    }
                                    else
                                    {
                                        <AppAlert Tone="@CatalogTone(_approvedCatalog.Status)">
                                            GitHub catalog status: @_approvedCatalog.Status
                                            @if (!string.IsNullOrWhiteSpace(_approvedCatalog.Message))
                                            {
                                                <span> - @_approvedCatalog.Message</span>
                                            }
                                        </AppAlert>

                                        @if (_approvedCatalog.Plugins.Count == 0)
                                        {
                                            <AppAlert Tone="AppUiTone.Info">No approved third-party plugins are listed right now.</AppAlert>
                                        }
                                        else
                                        {
                                            <AppTable Class="settings-plugin-job-table">
                                                <thead>
                                                    <tr>
                                                        <th>Plugin</th>
                                                        <th>Status</th>
                                                        <th>Capabilities</th>
                                                        <th>Package</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in _approvedCatalog.Plugins)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <div class="settings-plugin-table-title">@item.Name</div>
                                                                <div class="settings-plugin-table-meta">@item.Id - v@item.Version</div>
                                                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                                                {
                                                                    <div class="settings-plugin-table-meta">@item.Description</div>
                                                                }
                                                            </td>
                                                            <td>@item.Status</td>
                                                            <td>@string.Join(", ", item.Capabilities)</td>
                                                            <td>
                                                                <div class="settings-plugin-link-stack">
                                                                    @if (!string.IsNullOrWhiteSpace(item.ReleaseUrl))
                                                                    {
                                                                        <MudLink Href="@item.ReleaseUrl" Target="_blank">Release</MudLink>
                                                                    }
                                                                    @if (!string.IsNullOrWhiteSpace(item.PackageUrl))
                                                                    {
                                                                        <MudLink Href="@item.PackageUrl" Target="_blank">Package</MudLink>
                                                                    }
                                                                    @if (!string.IsNullOrWhiteSpace(item.Sha256))
                                                                    {
                                                                        <span>SHA-256 pinned</span>
                                                                    }
                                                                    @if (!string.IsNullOrWhiteSpace(item.InstallNotes))
                                                                    {
                                                                        <span>@item.InstallNotes</span>
                                                                    }
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </AppTable>
                                        }
                                    }
                                </div>
                            </AppTabPanel>
                            <AppTabPanel Text="How to use" Icon="@Icons.Material.Outlined.MenuBook">
                                <div class="settings-plugin-tab-body">
                                    <AppAlert Tone="AppUiTone.Info">
                                        Admins use this page to enable built-in plugins, configure dynamic plugins, check health, and discover approved plugins from GitHub. Installing a downloaded plugin is still a manual dynamic-plugin folder step.
                                    </AppAlert>
                                    <AppTable Class="settings-plugin-job-table">
                                        <tbody>
                                            <tr><td>Use a plugin</td><td>Download an approved release, verify the published SHA-256 when one is provided, extract it under the library root at .data/plugins/plugin-folder, reload the Engine, then enable it here.</td></tr>
                                            <tr><td>Configure a plugin</td><td>Select the plugin, update the fields it exposes, then run Jobs & health before relying on scheduled work.</td></tr>
                                            <tr><td>Build a plugin</td><td>Create a .NET class library that references MediaEngine.Plugins, implement ITuvimaPlugin, ship plugin.json beside the compiled assembly, and include settings schema metadata for every admin-facing option.</td></tr>
                                            <tr><td>Submit for approval</td><td>Publish a GitHub release with a versioned archive, checksum, source repository, manifest, and installation notes so maintainers can add it to the approved catalog.</td></tr>
                                        </tbody>
                                    </AppTable>
                                </div>
                            </AppTabPanel>
                            <AppTabPanel Text="Danger" Icon="@Icons.Material.Outlined.Delete">
                                <div class="settings-plugin-tab-body">
                                    @if (plugin.IsBuiltIn)
                                    {
                                        <AppAlert Tone="AppUiTone.Info">Built-in plugins can be disabled, but they cannot be deleted from this page.</AppAlert>
                                    }
                                    else
                                    {
                                        <AppAlert Tone="AppUiTone.Warning">
                                            Deleting this plugin removes its dynamic plugin folder and saved plugin configuration.
                                        </AppAlert>
                                        @if (string.Equals(_deletePluginId, plugin.Id, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <AppActionBar Align="AppHorizontalAlignment.Start">
                                                <AppButton Label="Confirm delete"
                                                           StartIcon="@Icons.Material.Outlined.DeleteForever"
                                                           ButtonStyle="AppButtonStyle.Filled"
                                                           Tone="AppUiTone.Error"
                                                           OnClick="@(() => DeletePluginAsync(plugin))" />
                                                <AppButton Label="Cancel"
                                                           OnClick="@(() => _deletePluginId = null)" />
                                            </AppActionBar>
                                        }
                                        else
                                        {
                                            <AppButton Label="Delete plugin"
                                                       StartIcon="@Icons.Material.Outlined.Delete"
                                                       Tone="AppUiTone.Error"
                                                       OnClick="@(() => _deletePluginId = plugin.Id)" />
                                        }
                                    }
                                </div>
                            </AppTabPanel>
                        </AppTabs>
                    </div>
                }
            </AppCard>
        </div>
    </div>
}

@code {
    private readonly JsonSerializerOptions _json = new(JsonSerializerDefaults.Web);
    private readonly Dictionary<string, PluginHealthViewModel> _health = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, IReadOnlyList<PluginJobViewModel>> _jobs = new(StringComparer.OrdinalIgnoreCase);
    private List<PluginViewModel> _plugins = [];
    private ApprovedPluginCatalogViewModel? _approvedCatalog;
    private bool _approvedCatalogLoading;
    private bool _loading = true;
    private string? _error;
    private string? _selectedPluginId;
    private string _search = "";
    private string _filter = "all";
    private string? _deletePluginId;

    private IEnumerable<PluginViewModel> FilteredPlugins => _plugins.Where(MatchesFilter);

    private PluginViewModel? SelectedPlugin => _plugins.FirstOrDefault(p => string.Equals(p.Id, _selectedPluginId, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _plugins = (await Orchestrator.GetPluginsAsync()).OrderBy(p => p.Name).ToList();
            if (_plugins.Count > 0 && SelectedPlugin is null)
                _selectedPluginId = _plugins[0].Id;

            _approvedCatalog ??= await Orchestrator.GetApprovedPluginCatalogAsync();
        }
        catch
        {
            _error = "Plugin settings could not be loaded.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private void SelectPlugin(string pluginId)
    {
        _selectedPluginId = pluginId;
        _deletePluginId = null;
    }

    private void HandlePluginKeyDown(KeyboardEventArgs args, string pluginId)
    {
        if (args.Key is "Enter" or " ")
            SelectPlugin(pluginId);
    }

    private async Task SetEnabledAsync(PluginViewModel plugin, bool enabled)
    {
        if (!await Orchestrator.SetPluginEnabledAsync(plugin.Id, enabled))
        {
            Snackbar.Add("Plugin state could not be saved.", Severity.Error);
            return;
        }

        plugin.Enabled = enabled;
        Snackbar.Add($"{plugin.Name} {(enabled ? "enabled" : "disabled")}.", Severity.Success);
    }

    private async Task SaveSettingAsync(PluginViewModel plugin, string key, JsonElement value)
    {
        plugin.Settings[key] = value;
        if (!await Orchestrator.SavePluginSettingsAsync(plugin.Id, plugin.Settings))
        {
            Snackbar.Add("Plugin setting could not be saved.", Severity.Error);
            return;
        }
    }

    private async Task SaveRawSettingAsync(PluginViewModel plugin, string key, string rawJson)
    {
        try
        {
            var element = JsonSerializer.Deserialize<JsonElement>(rawJson);
            await SaveSettingAsync(plugin, key, element);
        }
        catch (JsonException ex)
        {
            Snackbar.Add($"Setting value is invalid: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveNumberSettingAsync(PluginViewModel plugin, string key, string? raw)
    {
        if (!double.TryParse(raw, NumberStyles.Float, CultureInfo.InvariantCulture, out var parsed))
        {
            Snackbar.Add("Setting number is invalid.", Severity.Error);
            return;
        }

        await SaveSettingAsync(plugin, key, JsonSerializer.SerializeToElement(parsed, _json));
    }

    private async Task DeletePluginAsync(PluginViewModel plugin)
    {
        if (!await Orchestrator.DeletePluginAsync(plugin.Id))
        {
            Snackbar.Add("Plugin could not be deleted.", Severity.Error);
            return;
        }

        Snackbar.Add($"{plugin.Name} deleted.", Severity.Success);
        _selectedPluginId = null;
        _deletePluginId = null;
        await ReloadAsync();
    }

    private async Task CheckHealthAsync(PluginViewModel plugin)
    {
        var result = await Orchestrator.CheckPluginHealthAsync(plugin.Id);
        if (result is not null)
            _health[plugin.Id] = result;
    }

    private async Task LoadJobsAsync(PluginViewModel plugin)
    {
        _jobs[plugin.Id] = await Orchestrator.GetPluginJobsAsync(plugin.Id);
    }

    private async Task LoadApprovedCatalogAsync()
    {
        _approvedCatalogLoading = true;
        try
        {
            _approvedCatalog = await Orchestrator.GetApprovedPluginCatalogAsync();
            if (_approvedCatalog is null)
                Snackbar.Add("Approved plugin catalog could not be loaded.", Severity.Error);
        }
        finally
        {
            _approvedCatalogLoading = false;
        }
    }

    private bool MatchesFilter(PluginViewModel plugin)
    {
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var text = $"{plugin.Name} {plugin.Id} {plugin.Description}";
            if (!text.Contains(_search, StringComparison.OrdinalIgnoreCase))
                return false;
        }

        return _filter switch
        {
            "enabled" => plugin.Enabled,
            "dynamic" => !plugin.IsBuiltIn,
            "setup" => !string.IsNullOrWhiteSpace(plugin.LoadError),
            _ => true,
        };
    }

    private RenderFragment FilterButton(string value, string label) => @<AppButton Label="@label"
                                                                                   ButtonStyle="@(string.Equals(_filter, value, StringComparison.OrdinalIgnoreCase) ? AppButtonStyle.Filled : AppButtonStyle.Outlined)"
                                                                                   Tone="AppUiTone.Primary"
                                                                                   Size="AppControlSize.Compact"
                                                                                   OnClick="@(() => _filter = value)" />;

    private RenderFragment SettingEditor(PluginViewModel plugin, PluginSettingDefinition setting)
    {
        var options = GetSelectOptions(setting);
        if (options.Count > 0)
        {
            return @<AppSelect Label="@setting.Label"
                               Value="@ReadSettingText(setting.Value)"
                               ValueChanged="@(v => SaveStringSettingAsync(plugin, setting, v))"
                               Options="@options"
                               HelpText="@setting.HelpText" />;
        }

        if (IsBooleanSetting(setting))
        {
            return @<AppSwitchRow Label="@setting.Label"
                                 Description="@setting.HelpText"
                                 Icon="@Icons.Material.Outlined.ToggleOn"
                                 Value="@ReadBoolean(setting.Value)"
                                 ValueChanged="@(v => SaveSettingAsync(plugin, setting.Key, JsonSerializer.SerializeToElement(v, _json)))" />;
        }

        if (IsNumberSetting(setting))
        {
            return @<AppTextField Label="@setting.Label"
                                  Value="@ReadNumberText(setting.Value)"
                                  ValueChanged="@(v => SaveNumberSettingAsync(plugin, setting, v))"
                                  HelpText="@setting.HelpText"
                                  InputType="InputType.Number" />;
        }

        if (IsStringSetting(setting))
        {
            return @<AppTextField Label="@setting.Label"
                                  Value="@ReadString(setting.Value)"
                                  ValueChanged="@(v => SaveStringSettingAsync(plugin, setting, v))"
                                  HelpText="@setting.HelpText"
                                  Placeholder="@setting.Key"
                                  InputType="@TextInputType(setting)" />;
        }

        return @<AppTextarea Label="@setting.Label"
                             Value="@setting.Value.GetRawText()"
                             ValueChanged="@(v => SaveRawSettingAsync(plugin, setting.Key, v ?? "null"))"
                             HelpText="@setting.HelpText"
                             Lines="4" />;
    }

    private IEnumerable<PluginSettingDefinition> GetSettingEntries(PluginViewModel plugin)
    {
        var emitted = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var order = 0;
        if (TryGetSchemaProperties(plugin.SettingsSchema, out var properties))
        {
            foreach (var property in properties.EnumerateObject())
            {
                var value = plugin.Settings.TryGetValue(property.Name, out var current)
                    ? current
                    : ReadDefaultValue(property.Value);
                emitted.Add(property.Name);
                yield return new PluginSettingDefinition(property.Name, value, property.Value, order++);
            }
        }

        foreach (var setting in plugin.Settings
                     .Where(kvp => !emitted.Contains(kvp.Key))
                     .OrderBy(kvp => kvp.Key, StringComparer.OrdinalIgnoreCase))
        {
            yield return new PluginSettingDefinition(setting.Key, setting.Value, null, order++);
        }
    }

    private async Task SaveStringSettingAsync(PluginViewModel plugin, PluginSettingDefinition setting, string? raw)
    {
        var value = CoerceStringValue(setting, raw ?? string.Empty);
        await SaveSettingAsync(plugin, setting.Key, value);
    }

    private async Task SaveNumberSettingAsync(PluginViewModel plugin, PluginSettingDefinition setting, string? raw)
    {
        if (IsIntegerSetting(setting))
        {
            if (!long.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsedInteger))
            {
                Snackbar.Add("Setting number is invalid.", Severity.Error);
                return;
            }

            await SaveSettingAsync(plugin, setting.Key, JsonSerializer.SerializeToElement(parsedInteger, _json));
            return;
        }

        if (!double.TryParse(raw, NumberStyles.Float, CultureInfo.InvariantCulture, out var parsed))
        {
            Snackbar.Add("Setting number is invalid.", Severity.Error);
            return;
        }

        await SaveSettingAsync(plugin, setting.Key, JsonSerializer.SerializeToElement(parsed, _json));
    }

    private static bool TryGetSchemaProperties(JsonElement? schema, out JsonElement properties)
    {
        if (schema is { ValueKind: JsonValueKind.Object } root
            && root.TryGetProperty("properties", out properties)
            && properties.ValueKind == JsonValueKind.Object)
        {
            return true;
        }

        properties = default;
        return false;
    }

    private static JsonElement ReadDefaultValue(JsonElement definition)
    {
        if (definition.ValueKind == JsonValueKind.Object
            && definition.TryGetProperty("default", out var defaultValue)
            && defaultValue.ValueKind is not JsonValueKind.Undefined)
        {
            return defaultValue.Clone();
        }

        var type = ReadSchemaString(definition, "type");
        return type?.ToLowerInvariant() switch
        {
            "boolean" or "bool" => JsonSerializer.SerializeToElement(false),
            "integer" or "int" => JsonSerializer.SerializeToElement(0),
            "number" => JsonSerializer.SerializeToElement(0d),
            "array" => JsonSerializer.SerializeToElement(Array.Empty<string>()),
            "object" => JsonSerializer.SerializeToElement(new Dictionary<string, string>()),
            _ => JsonSerializer.SerializeToElement(string.Empty),
        };
    }

    private static JsonElement CoerceStringValue(PluginSettingDefinition setting, string raw)
    {
        if (IsIntegerSetting(setting) && long.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out var integer))
            return JsonSerializer.SerializeToElement(integer);
        if (IsNumberSetting(setting) && double.TryParse(raw, NumberStyles.Float, CultureInfo.InvariantCulture, out var number))
            return JsonSerializer.SerializeToElement(number);
        if (IsBooleanSetting(setting) && bool.TryParse(raw, out var boolean))
            return JsonSerializer.SerializeToElement(boolean);
        return JsonSerializer.SerializeToElement(raw);
    }

    private static bool IsBooleanSetting(PluginSettingDefinition setting) =>
        IsSchemaType(setting, "boolean", "bool") || setting.Value.ValueKind is JsonValueKind.True or JsonValueKind.False;

    private static bool IsIntegerSetting(PluginSettingDefinition setting) =>
        IsSchemaType(setting, "integer", "int");

    private static bool IsNumberSetting(PluginSettingDefinition setting) =>
        IsIntegerSetting(setting) || IsSchemaType(setting, "number") || setting.Value.ValueKind == JsonValueKind.Number;

    private static bool IsStringSetting(PluginSettingDefinition setting) =>
        IsSchemaType(setting, "string") || setting.Value.ValueKind == JsonValueKind.String;

    private static bool IsSchemaType(PluginSettingDefinition setting, params string[] types)
    {
        var type = ReadSchemaString(setting.Schema, "type");
        return type is not null && types.Contains(type, StringComparer.OrdinalIgnoreCase);
    }

    private static bool ReadBoolean(JsonElement value) =>
        value.ValueKind switch
        {
            JsonValueKind.True => true,
            JsonValueKind.False => false,
            JsonValueKind.String when bool.TryParse(value.GetString(), out var parsed) => parsed,
            _ => false,
        };

    private static IReadOnlyList<AppSelectOption> GetSelectOptions(PluginSettingDefinition setting)
    {
        if (setting.Schema is not { ValueKind: JsonValueKind.Object } schema
            || !schema.TryGetProperty("enum", out var values)
            || values.ValueKind != JsonValueKind.Array)
        {
            return [];
        }

        return values.EnumerateArray()
            .Select(value => new AppSelectOption(ReadSettingText(value), ToTitle(ReadSettingText(value))))
            .ToList();
    }

    private static InputType TextInputType(PluginSettingDefinition setting) =>
        string.Equals(ReadSchemaString(setting.Schema, "format"), "password", StringComparison.OrdinalIgnoreCase)
        || ReadSchemaBool(setting.Schema, "secret")
            ? InputType.Password
            : InputType.Text;

    private static string ReadString(JsonElement value) => value.ValueKind == JsonValueKind.String ? value.GetString() ?? "" : "";

    private static string ReadSettingText(JsonElement value) =>
        value.ValueKind switch
        {
            JsonValueKind.String => value.GetString() ?? string.Empty,
            JsonValueKind.Number => value.GetRawText(),
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            _ => value.GetRawText(),
        };

    private static string ReadNumberText(JsonElement value) =>
        value.TryGetDouble(out var parsed)
            ? parsed.ToString(CultureInfo.InvariantCulture)
            : "0";

    private static string? ReadSchemaString(JsonElement? schema, string propertyName) =>
        schema is { ValueKind: JsonValueKind.Object } element
        && element.TryGetProperty(propertyName, out var property)
        && property.ValueKind == JsonValueKind.String
            ? property.GetString()
            : null;

    private static bool ReadSchemaBool(JsonElement? schema, string propertyName) =>
        schema is { ValueKind: JsonValueKind.Object } element
        && element.TryGetProperty(propertyName, out var property)
        && property.ValueKind is JsonValueKind.True or JsonValueKind.False
        && property.GetBoolean();

    private static AppUiTone HealthTone(string status) => string.Equals(status, "healthy", StringComparison.OrdinalIgnoreCase) ? AppUiTone.Success : AppUiTone.Warning;

    private static AppUiTone CatalogTone(string status) => string.Equals(status, "ok", StringComparison.OrdinalIgnoreCase) ? AppUiTone.Success : AppUiTone.Warning;

    private static string PluginIcon(PluginViewModel plugin) => plugin.Id switch
    {
        var id when id.Contains("commercial", StringComparison.OrdinalIgnoreCase) => Icons.Material.Outlined.LiveTv,
        var id when id.Contains("intro", StringComparison.OrdinalIgnoreCase) => Icons.Material.Outlined.FastForward,
        var id when id.Contains("credits", StringComparison.OrdinalIgnoreCase) => Icons.Material.Outlined.MovieFilter,
        var id when id.Contains("ai", StringComparison.OrdinalIgnoreCase) => Icons.Material.Outlined.Memory,
        _ => Icons.Material.Outlined.Extension,
    };

    private static string ToTitle(string key)
    {
        var text = key.Replace('_', ' ').Replace('-', ' ');
        return string.IsNullOrWhiteSpace(text)
            ? key
            : string.Concat(char.ToUpperInvariant(text[0]), text[1..]);
    }

    private sealed record PluginSettingDefinition(
        string Key,
        JsonElement Value,
        JsonElement? Schema,
        int Order)
    {
        public string Label => ReadSchemaString(Schema, "title")
            ?? ReadSchemaString(Schema, "label")
            ?? ToTitle(Key);

        public string? HelpText => ReadSchemaString(Schema, "description")
            ?? ReadSchemaString(Schema, "help_text");

        public bool Advanced => ReadSchemaBool(Schema, "advanced")
            || ReadSchemaBool(Schema, "ui:advanced")
            || ReadSchemaBool(Schema, "x-advanced");
    }
}
