@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject IConfiguration Configuration

<div class="tl-page settings-system-page">
    @if (_loading)
    {
        <AppProgressBar Indeterminate="true" />
    }
    else
    {
        <div class="settings-system-grid">
            <div class="settings-system-cell">
                <AppCard Class="settings-system-card tl-card-hover--quiet">
                    <div class="settings-system-card-header">
                        <div class="settings-system-eyebrow">Health</div>
                        <h2 class="settings-system-title">Runtime status</h2>
                        <p class="settings-system-description">
                            Current server reachability and the version reported by the engine.
                        </p>
                    </div>

                    <div class="settings-system-metric-row">
                        <AppMetricCard Label="Engine"
                                       Value="@(_status?.IsHealthy == true ? "Online" : "Unavailable")"
                                       Tone="@(_status?.IsHealthy == true ? AppStatusTone.Success : AppStatusTone.Warning)" />
                        <AppMetricCard Label="Version"
                                       Value="@(_status?.Version ?? "Unknown")" />
                        <AppMetricCard Label="Language"
                                       Value="@(_serverGeneral?.DisplayLanguage ?? _status?.Language ?? "en")" />
                    </div>
                </AppCard>
            </div>

            <div class="settings-system-cell">
                <AppCard Class="settings-system-card tl-card-hover--quiet">
                    <div class="settings-system-card-header">
                        <div class="settings-system-eyebrow">Connectivity</div>
                        <h2 class="settings-system-title">Dashboard target</h2>
                        <p class="settings-system-description">
                            The dashboard checks this engine endpoint for availability before system actions run.
                        </p>
                    </div>

                    <code class="settings-system-endpoint">@_engineBaseUrl</code>

                    @if (_status?.IsHealthy != true)
                    {
                        <AppAlert Tone="AppUiTone.Warning"
                                  Icon="@Icons.Material.Outlined.WarningAmber"
                                  Class="settings-system-warning">
                            The engine did not respond to the latest health probe. Save and maintenance actions may fail until it is reachable again.
                        </AppAlert>
                    }
                </AppCard>
            </div>
        </div>
    }

    <AppCard Class="settings-system-shell">
        <div class="settings-system-card-header">
            <div class="settings-system-eyebrow">Configuration</div>
            <h2 class="settings-system-title">Server identity and regional defaults</h2>
            <p class="settings-system-description">
                Regional behavior, language preferences, and default date or time formatting for the engine.
            </p>
        </div>

        <div class="settings-system-shell-body">
            <ServerGeneralTab />
        </div>
    </AppCard>
</div>

@code {
    private bool _loading = true;
    private SystemStatusViewModel? _status;
    private ServerGeneralSettingsDto? _serverGeneral;
    private string _engineBaseUrl = "Configured at runtime";

    protected override async Task OnInitializedAsync()
    {
        _engineBaseUrl = Configuration["Engine:BaseUrl"]
            ?? Environment.GetEnvironmentVariable("TUVIMA_ENGINE_URL")
            ?? "Configured at runtime";

        try
        {
            _status = await Orchestrator.GetSystemStatusAsync();
        }
        catch
        {
            _status = null;
        }

        try
        {
            _serverGeneral = await Orchestrator.GetServerGeneralAsync();
        }
        catch
        {
            _serverGeneral = null;
        }

        _loading = false;
    }
}
