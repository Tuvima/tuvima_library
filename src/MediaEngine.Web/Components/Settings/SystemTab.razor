@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject IConfiguration Configuration

<div class="tl-page settings-system-page">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else
    {
        <div class="settings-system-grid">
            <div class="settings-system-cell">
                <MudPaper Elevation="0" Class="settings-system-card tl-card-hover--quiet">
                    <div class="settings-system-card-header">
                        <MudText Typo="Typo.overline" Class="settings-system-eyebrow">Health</MudText>
                        <MudText Typo="Typo.h6">Runtime status</MudText>
                        <MudText Typo="Typo.body2" Class="settings-system-description">
                            Current server reachability and the version reported by the engine.
                        </MudText>
                    </div>

                    <div class="settings-system-metric-row">
                        <div class="settings-system-metric">
                            <span class="settings-system-metric-label">Engine</span>
                            <span class="settings-system-metric-value @(_status?.IsHealthy == true ? "settings-system-metric-value--healthy" : "settings-system-metric-value--warning")">
                                @(_status?.IsHealthy == true ? "Online" : "Unavailable")
                            </span>
                        </div>
                        <div class="settings-system-metric">
                            <span class="settings-system-metric-label">Version</span>
                            <span class="settings-system-metric-value">@(_status?.Version ?? "Unknown")</span>
                        </div>
                        <div class="settings-system-metric">
                            <span class="settings-system-metric-label">Language</span>
                            <span class="settings-system-metric-value">@(_serverGeneral?.DisplayLanguage ?? _status?.Language ?? "en")</span>
                        </div>
                    </div>
                </MudPaper>
            </div>

            <div class="settings-system-cell">
                <MudPaper Elevation="0" Class="settings-system-card tl-card-hover--quiet">
                    <div class="settings-system-card-header">
                        <MudText Typo="Typo.overline" Class="settings-system-eyebrow">Connectivity</MudText>
                        <MudText Typo="Typo.h6">Dashboard target</MudText>
                        <MudText Typo="Typo.body2" Class="settings-system-description">
                            The dashboard checks this engine endpoint for availability before system actions run.
                        </MudText>
                    </div>

                    <code class="settings-system-endpoint">@_engineBaseUrl</code>

                    @if (_status?.IsHealthy != true)
                    {
                        <MudAlert Dense="true"
                                  Severity="Severity.Warning"
                                  Variant="Variant.Outlined"
                                  Icon="@Icons.Material.Outlined.WarningAmber"
                                  Class="settings-system-warning">
                            The engine did not respond to the latest health probe. Save and maintenance actions may fail until it is reachable again.
                        </MudAlert>
                    }
                </MudPaper>
            </div>
        </div>
    }

    <MudPaper Elevation="0" Class="settings-system-shell">
        <div class="settings-system-card-header">
            <MudText Typo="Typo.overline" Class="settings-system-eyebrow">Configuration</MudText>
            <MudText Typo="Typo.h6">Server identity and regional defaults</MudText>
            <MudText Typo="Typo.body2" Class="settings-system-description">
                Regional behavior, language preferences, and default date or time formatting for the engine.
            </MudText>
        </div>

        <div class="settings-system-shell-body">
            <ServerGeneralTab />
        </div>
    </MudPaper>
</div>

@code {
    private bool _loading = true;
    private SystemStatusViewModel? _status;
    private ServerGeneralSettingsDto? _serverGeneral;
    private string _engineBaseUrl = "Configured at runtime";

    protected override async Task OnInitializedAsync()
    {
        _engineBaseUrl = Configuration["Engine:BaseUrl"]
            ?? Environment.GetEnvironmentVariable("TUVIMA_ENGINE_URL")
            ?? "Configured at runtime";

        try
        {
            _status = await Orchestrator.GetSystemStatusAsync();
        }
        catch
        {
            _status = null;
        }

        try
        {
            _serverGeneral = await Orchestrator.GetServerGeneralAsync();
        }
        catch
        {
            _serverGeneral = null;
        }

        _loading = false;
    }
}
