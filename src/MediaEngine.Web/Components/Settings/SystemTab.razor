@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject IConfiguration Configuration

<div class="st-page settings-system-page">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else
    {
        <div class="settings-system-grid">
            <div class="settings-system-cell">
                <AppSurfaceCard Eyebrow="Health"
                                Title="Runtime status"
                                Description="Current server reachability and the version reported by the engine."
                                Class="settings-system-card">
                    <div class="settings-system-metric-row">
                        <div class="settings-system-metric">
                            <span class="settings-system-metric-label">Engine</span>
                            <span class="settings-system-metric-value @(_status?.IsHealthy == true ? "settings-system-metric-value--healthy" : "settings-system-metric-value--warning")">
                                @(_status?.IsHealthy == true ? "Online" : "Unavailable")
                            </span>
                        </div>
                        <div class="settings-system-metric">
                            <span class="settings-system-metric-label">Version</span>
                            <span class="settings-system-metric-value">@(_status?.Version ?? "Unknown")</span>
                        </div>
                        <div class="settings-system-metric">
                            <span class="settings-system-metric-label">Language</span>
                            <span class="settings-system-metric-value">@(_serverGeneral?.DisplayLanguage ?? _status?.Language ?? "en")</span>
                        </div>
                    </div>
                </AppSurfaceCard>
            </div>

            <div class="settings-system-cell">
                <AppSurfaceCard Eyebrow="Connectivity"
                                Title="Dashboard target"
                                Description="The dashboard checks this engine endpoint for availability before system actions run."
                                Class="settings-system-card">
                    <code class="settings-system-endpoint">@_engineBaseUrl</code>

                    @if (_status?.IsHealthy != true)
                    {
                        <div class="settings-system-warning">
                            <AppIcon Name="@AppIcons.Warning" Class="settings-system-warning-icon" />
                            <span>The engine did not respond to the latest health probe. Save and maintenance actions may fail until it is reachable again.</span>
                        </div>
                    }
                </AppSurfaceCard>
            </div>
        </div>
    }

    <AppSurfaceCard Eyebrow="Configuration"
                    Title="Server identity and regional defaults"
                    Description="Regional behavior, language preferences, and default date or time formatting for the engine."
                    Class="settings-system-shell"
                    BodyClassName="settings-system-shell-body">
        <ServerGeneralTab />
    </AppSurfaceCard>
</div>

@code {
    private bool _loading = true;
    private SystemStatusViewModel? _status;
    private ServerGeneralSettingsDto? _serverGeneral;
    private string _engineBaseUrl = "Configured at runtime";

    protected override async Task OnInitializedAsync()
    {
        _engineBaseUrl = Configuration["Engine:BaseUrl"]
            ?? Environment.GetEnvironmentVariable("TUVIMA_ENGINE_URL")
            ?? "Configured at runtime";

        try
        {
            _status = await Orchestrator.GetSystemStatusAsync();
        }
        catch
        {
            _status = null;
        }

        try
        {
            _serverGeneral = await Orchestrator.GetServerGeneralAsync();
        }
        catch
        {
            _serverGeneral = null;
        }

        _loading = false;
    }
}
