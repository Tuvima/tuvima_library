@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient

<div class="tl-page settings-overview-page">
    <div class="settings-overview-summary">
        <LibraryOverviewPanel ReadOnly="true" />
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4" />
    }
    else
    {
        <div class="settings-overview-grid">
            <div class="settings-overview-cell">
                <MudPaper Elevation="0" Class="settings-overview-card tl-card-hover--quiet">
                    <div class="settings-overview-card-header">
                        <MudText Typo="Typo.overline" Class="settings-overview-eyebrow">System</MudText>
                        <MudText Typo="Typo.h6">Heartbeat</MudText>
                        <MudText Typo="Typo.body2" Class="settings-overview-description">
                            Live status from the engine, grounded in the same health checks the dashboard uses.
                        </MudText>
                    </div>

                    <div class="settings-overview-metrics">
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Status</span>
                            <span class="settings-overview-metric-value @(_systemStatus?.IsHealthy == true ? "settings-overview-metric-value--healthy" : "settings-overview-metric-value--warning")">
                                @(_systemStatus?.IsHealthy == true ? "Online" : "Unavailable")
                            </span>
                        </div>
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Version</span>
                            <span class="settings-overview-metric-value">@(_systemStatus?.Version ?? "Unknown")</span>
                        </div>
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Language</span>
                            <span class="settings-overview-metric-value">@(_serverGeneral?.DisplayLanguage ?? _systemStatus?.Language ?? "en")</span>
                        </div>
                    </div>
                </MudPaper>
            </div>

            <div class="settings-overview-cell">
                <MudPaper Elevation="0" Class="settings-overview-card tl-card-hover--quiet">
                    <div class="settings-overview-card-header">
                        <MudText Typo="Typo.overline" Class="settings-overview-eyebrow">Deep Enrichment</MudText>
                        <MudText Typo="Typo.h6">Stage 3 coverage</MudText>
                        <MudText Typo="Typo.body2" Class="settings-overview-description">
                            Universe assignment and deferred enrichment coverage across the current library.
                        </MudText>
                    </div>

                    <div class="settings-overview-metrics">
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Stage 3 ready</span>
                            <span class="settings-overview-metric-value">@(_overview is null ? "0" : _overview.EnrichedStage3.ToString("N0"))</span>
                        </div>
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Universe assigned</span>
                            <span class="settings-overview-metric-value">@(_overview is null ? "0" : _overview.UniverseAssigned.ToString("N0"))</span>
                        </div>
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Art pending</span>
                            <span class="settings-overview-metric-value">@(_overview is null ? "0" : _overview.ArtPending.ToString("N0"))</span>
                        </div>
                    </div>
                </MudPaper>
            </div>

            <div class="settings-overview-cell">
                <MudPaper Elevation="0" Class="settings-overview-card tl-card-hover--quiet">
                    <div class="settings-overview-card-header">
                        <MudText Typo="Typo.overline" Class="settings-overview-eyebrow">Quick Links</MudText>
                        <MudText Typo="Typo.h6">Continue work</MudText>
                        <MudText Typo="Typo.body2" Class="settings-overview-description">
                            Jump straight to the parts of settings that usually need attention first.
                        </MudText>
                    </div>

                    <div class="settings-overview-actions">
                        <MudButton Href="/settings/review"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Outlined.RateReview"
                                   Class="settings-overview-action settings-overview-action--primary">
                            Review @ReviewCount
                        </MudButton>
                        <MudButton Href="/settings/providers"
                                   Variant="Variant.Outlined"
                                   Color="Color.Inherit"
                                   StartIcon="@Icons.Material.Outlined.Collections"
                                   Class="settings-overview-action">
                            Providers
                        </MudButton>
                        <MudButton Href="/settings/ingestion"
                                   Variant="Variant.Outlined"
                                   Color="Color.Inherit"
                                   StartIcon="@Icons.Material.Outlined.PendingActions"
                                   Class="settings-overview-action">
                            Ingestion
                        </MudButton>
                        <MudButton Href="/settings/libraries"
                                   Variant="Variant.Outlined"
                                   Color="Color.Inherit"
                                   StartIcon="@Icons.Material.Outlined.FolderOpen"
                                   Class="settings-overview-action">
                            Libraries
                        </MudButton>
                    </div>
                </MudPaper>
            </div>
        </div>

        <div class="settings-overview-cell settings-overview-cell--full">
            <MudPaper Elevation="0" Class="settings-overview-card tl-card-hover--quiet">
                <div class="settings-overview-card-header">
                    <MudText Typo="Typo.overline" Class="settings-overview-eyebrow">Ingestion</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.h6">@(_ingestionSummary.IsActive ? "Ingestion in progress" : "Ingestion idle")</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@(_ingestionSummary.IsActive ? Color.Info : Color.Default)">
                            @(_ingestionSummary.IsActive ? "Active" : "Idle")
                        </MudChip>
                    </MudStack>
                    <MudText Typo="Typo.body2" Class="settings-overview-description">
                        @(_ingestionSummary.IsActive
                            ? "A compact summary of the current library run."
                            : $"No active ingestion. Last completed run: {_ingestionSummary.LastCompletedRun}.")
                    </MudText>
                </div>

                <MudProgressLinear Value="@_ingestionSummary.Progress"
                                   Color="@(_ingestionSummary.IsActive ? Color.Primary : Color.Default)"
                                   Rounded="false"
                                   Class="mb-4" />

                <div class="settings-overview-metrics">
                    <div class="settings-overview-metric">
                        <span class="settings-overview-metric-label">Processed</span>
                        <span class="settings-overview-metric-value">@($"{_ingestionSummary.Processed:N0} / {_ingestionSummary.Total:N0}")</span>
                    </div>
                    <div class="settings-overview-metric">
                        <span class="settings-overview-metric-label">Stage</span>
                        <span class="settings-overview-metric-value">@_ingestionSummary.Stage</span>
                    </div>
                    <div class="settings-overview-metric">
                        <span class="settings-overview-metric-label">Current item</span>
                        <span class="settings-overview-metric-value">@_ingestionSummary.CurrentItem</span>
                    </div>
                    <div class="settings-overview-metric">
                        <span class="settings-overview-metric-label">Active tasks</span>
                        <span class="settings-overview-metric-value">@_ingestionSummary.ActiveTasks</span>
                    </div>
                    <div class="settings-overview-metric">
                        <span class="settings-overview-metric-label">Queued tasks</span>
                        <span class="settings-overview-metric-value">@_ingestionSummary.QueuedTasks</span>
                    </div>
                    <div class="settings-overview-metric">
                        <span class="settings-overview-metric-label">Needs review</span>
                        <span class="settings-overview-metric-value">@ReviewCount</span>
                    </div>
                    <div class="settings-overview-metric">
                        <span class="settings-overview-metric-label">Failed tasks</span>
                        <span class="settings-overview-metric-value">@_ingestionSummary.FailedTasks</span>
                    </div>
                    <div class="settings-overview-metric">
                        <span class="settings-overview-metric-label">Elapsed</span>
                        <span class="settings-overview-metric-value">@_ingestionSummary.Elapsed</span>
                    </div>
                </div>

                <MudButton Href="/settings/ingestion"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Outlined.PendingActions"
                           Class="mt-4">
                    View ingestion details
                </MudButton>
                @* TODO: Replace placeholder ingestion summary with live ingestion/background task API data when available. *@
            </MudPaper>
        </div>

        <div class="settings-overview-cell settings-overview-cell--full">
            <MudPaper Elevation="0" Class="settings-overview-card tl-card-hover--quiet">
                <div class="settings-overview-card-header">
                    <MudText Typo="Typo.overline" Class="settings-overview-eyebrow">Coming Next</MudText>
                    <MudText Typo="Typo.h6">Overview will keep growing</MudText>
                    <MudText Typo="Typo.body2" Class="settings-overview-description">
                        Additional statistics will land here as more trustworthy live metrics are wired through the engine. Until then, this page stays focused on the signals the app can verify today.
                    </MudText>
                </div>
            </MudPaper>
        </div>
    }
</div>

@code {
    [Parameter] public int ReviewCount { get; set; }

    private bool _loading = true;
    private SystemStatusViewModel? _systemStatus;
    private ServerGeneralSettingsDto? _serverGeneral;
    private LibraryOverviewViewModel? _overview;
    private readonly IngestionSummary _ingestionSummary = new();

    private sealed class IngestionSummary
    {
        public bool IsActive { get; init; }
        public double Progress { get; init; }
        public int Processed { get; init; }
        public int Total { get; init; }
        public string Stage { get; init; } = "Idle";
        public string CurrentItem { get; init; } = "None";
        public int ActiveTasks { get; init; }
        public int QueuedTasks { get; init; }
        public int FailedTasks { get; init; }
        public string Elapsed { get; init; } = "0:00";
        public string LastCompletedRun { get; init; } = "not available";
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        try
        {
            _systemStatus = await Orchestrator.GetSystemStatusAsync();
        }
        catch
        {
            _systemStatus = null;
        }

        try
        {
            _serverGeneral = await Orchestrator.GetServerGeneralAsync();
        }
        catch
        {
            _serverGeneral = null;
        }

        try
        {
            _overview = await ApiClient.GetLibraryOverviewAsync();
        }
        catch
        {
            _overview = null;
        }

        _loading = false;
    }
}
