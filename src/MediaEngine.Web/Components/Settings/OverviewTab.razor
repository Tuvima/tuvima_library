@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient

<div class="st-page settings-overview-page">
    <div class="settings-overview-summary">
        <LibraryOverviewPanel ReadOnly="true" />
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4" />
    }
    else
    {
        <div class="settings-overview-grid">
            <div class="settings-overview-cell">
                <AppSurfaceCard Eyebrow="System"
                                Title="Heartbeat"
                                Description="Live status from the engine, grounded in the same health checks the dashboard uses."
                                Class="settings-overview-card">
                    <div class="settings-overview-metrics">
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Status</span>
                            <span class="settings-overview-metric-value @(_systemStatus?.IsHealthy == true ? "settings-overview-metric-value--healthy" : "settings-overview-metric-value--warning")">
                                @(_systemStatus?.IsHealthy == true ? "Online" : "Unavailable")
                            </span>
                        </div>
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Version</span>
                            <span class="settings-overview-metric-value">@(_systemStatus?.Version ?? "Unknown")</span>
                        </div>
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Language</span>
                            <span class="settings-overview-metric-value">@(_serverGeneral?.DisplayLanguage ?? _systemStatus?.Language ?? "en")</span>
                        </div>
                    </div>
                </AppSurfaceCard>
            </div>

            <div class="settings-overview-cell">
                <AppSurfaceCard Eyebrow="Deep Enrichment"
                                Title="Stage 3 coverage"
                                Description="Universe assignment and deferred enrichment coverage across the current library."
                                Class="settings-overview-card">
                    <div class="settings-overview-metrics">
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Stage 3 ready</span>
                            <span class="settings-overview-metric-value">@(_overview is null ? "0" : _overview.EnrichedStage3.ToString("N0"))</span>
                        </div>
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Universe assigned</span>
                            <span class="settings-overview-metric-value">@(_overview is null ? "0" : _overview.UniverseAssigned.ToString("N0"))</span>
                        </div>
                        <div class="settings-overview-metric">
                            <span class="settings-overview-metric-label">Art pending</span>
                            <span class="settings-overview-metric-value">@(_overview is null ? "0" : _overview.ArtPending.ToString("N0"))</span>
                        </div>
                    </div>
                </AppSurfaceCard>
            </div>

            <div class="settings-overview-cell">
                <AppSurfaceCard Eyebrow="Quick Links"
                                Title="Continue work"
                                Description="Jump straight to the parts of settings that usually need attention first."
                                Class="settings-overview-card">
                    <div class="settings-overview-actions">
                        <a href="/settings/review" class="settings-overview-action settings-overview-action--primary">
                            <AppIcon Name="@AppIcons.Review" Class="settings-overview-action-icon" />
                            <span>Review @ReviewCount</span>
                        </a>
                        <a href="/settings/providers" class="settings-overview-action">
                            <AppIcon Name="@AppIcons.Providers" Class="settings-overview-action-icon" />
                            <span>Providers</span>
                        </a>
                        <a href="/settings/system" class="settings-overview-action">
                            <AppIcon Name="@AppIcons.Server" Class="settings-overview-action-icon" />
                            <span>System</span>
                        </a>
                        <a href="/settings/folders" class="settings-overview-action">
                            <AppIcon Name="@AppIcons.Library" Class="settings-overview-action-icon" />
                            <span>Folders</span>
                        </a>
                    </div>
                </AppSurfaceCard>
            </div>
        </div>

        <div class="settings-overview-cell settings-overview-cell--full">
            <AppSurfaceCard Eyebrow="Coming Next"
                            Title="Overview will keep growing"
                            Description="Additional statistics will land here as more trustworthy live metrics are wired through the engine. Until then, this page stays focused on the signals the app can verify today."
                            Class="settings-overview-card" />
        </div>
    }
</div>

@code {
    [Parameter] public int ReviewCount { get; set; }

    private bool _loading = true;
    private SystemStatusViewModel? _systemStatus;
    private ServerGeneralSettingsDto? _serverGeneral;
    private LibraryOverviewViewModel? _overview;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        try
        {
            _systemStatus = await Orchestrator.GetSystemStatusAsync();
        }
        catch
        {
            _systemStatus = null;
        }

        try
        {
            _serverGeneral = await Orchestrator.GetServerGeneralAsync();
        }
        catch
        {
            _serverGeneral = null;
        }

        try
        {
            _overview = await ApiClient.GetLibraryOverviewAsync();
        }
        catch
        {
            _overview = null;
        }

        _loading = false;
    }
}
