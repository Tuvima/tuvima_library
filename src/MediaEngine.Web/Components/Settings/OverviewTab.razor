@namespace MediaEngine.Web.Components.Settings
@using System.Globalization
@using MediaEngine.Contracts.Playback
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject IEngineApiClient ApiClient
@inject UniverseStateContainer StateContainer
@implements IDisposable

<div class="tl-page admin-overview-page">
    <div class="admin-overview-toolbar">
        <div>
            <MudText Typo="Typo.caption" Class="admin-overview-muted">Last updated @FormatClock(_lastUpdated)</MudText>
        </div>
        <div class="admin-overview-actions">
            <AppButton Variant="Variant.Outlined"
                       Size="Size.Small"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Outlined.Refresh"
                       Disabled="@_loading"
                       OnClick="LoadAsync">
                Refresh
            </AppButton>
            <AppButton Href="/settings/review"
                       Variant="Variant.Outlined"
                       Size="Size.Small"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Outlined.RateReview">
                Review @_pendingReviewCount
            </AppButton>
            <AppButton Variant="Variant.Filled"
                       Size="Size.Small"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.PlayArrow"
                       Disabled="@(_startingIngestion || _currentRun.IsActive)"
                       OnClick="StartIngestionAsync">
                New ingestion
            </AppButton>
        </div>
    </div>

    @if (_loading)
    {
        <AppPanel Elevation="0" Class="tl-card admin-overview-loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Loading overview...</MudText>
        </AppPanel>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <AppAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">@_error</AppAlert>
    }

    <AppPanel Elevation="0" Class="tl-card admin-library-banner">
        <div class="admin-library-banner__content">
            <div class="admin-library-banner__main">
                <div class="admin-library-banner__icon">
                    <MudIcon Icon="@Icons.Material.Outlined.Layers" />
                </div>
                <div>
                    <MudText Typo="Typo.h4" Class="admin-library-banner__title">
                        <span>@FormatCount(_libraryTotal)</span> items in your library
                    </MudText>
                    <MudText Typo="Typo.body2" Class="admin-library-banner__subtitle">
                        Books, movies, TV, music, audiobooks, and comics
                    </MudText>
                </div>
            </div>

            <div class="admin-library-breakdown" aria-label="Library media type breakdown">
                @foreach (var media in MediaBreakdown)
                {
                    <AppCssElement Tag="div" Class="admin-library-media" Css="@media.AccentStyle">
                        <span class="admin-library-media__icon">
                            <MudIcon Icon="@media.Icon" />
                        </span>
                        <span class="admin-library-media__label">@media.Label</span>
                        <span class="admin-library-media__count">@FormatCount(media.Count)</span>
                        <span class="admin-library-media__percent">@FormatPercent(media.Percent)</span>
                    </AppCssElement>
                }
            </div>

            <div class="admin-composition-bar" aria-label="Library composition by media type">
                @if (MediaBreakdown.Any(item => item.Count > 0))
                {
                    @foreach (var media in MediaBreakdown.Where(item => item.Count > 0))
                    {
                        <AppCssElement Tag="span" Class="admin-composition-bar__segment"
                              title="@($"{media.Label}: {media.Percent:0.#}%")"
                              Css="@SegmentStyle(media)"></AppCssElement>
                    }
                }
                else
                {
                    <span class="admin-composition-bar__empty"></span>
                }
            </div>

            <div class="admin-composition-labels" aria-hidden="true">
                @foreach (var media in MediaBreakdown.Where(item => item.Count > 0))
                {
                    <AppCssElement Tag="span" Css="@CompositionLabelStyle(media)">@FormatPercent(media.Percent)</AppCssElement>
                }
            </div>
        </div>
    </AppPanel>

    <div class="admin-overview-primary-grid">
        <AppPanel Elevation="0" Class="tl-card admin-overview-card admin-overview-card--feature">
            <div class="admin-overview-card__header">
                <div>
                    <MudText Typo="Typo.caption" Class="admin-overview-eyebrow">Ingestion</MudText>
                    <MudText Typo="Typo.h6">Ingestion Progress</MudText>
                </div>
                <span class="@StatusBadgeClass(_currentRun.Status)">@_currentRun.Status</span>
            </div>

            @if (_currentRun.IsActive)
            {
                <div class="admin-run-progress">
                    <div class="admin-run-progress__copy">
                        <span>@FormatCount(_currentRun.Processed) / @FormatCount(_currentRun.Total) processed</span>
                        <span>@_currentRun.Progress.ToString("0")%</span>
                    </div>
                    <div class="admin-progress-track">
                        <AppCssElement Tag="span" Class="admin-progress-fill" Css="@ProgressStyle(_currentRun.Progress)"></AppCssElement>
                    </div>
                </div>

                <div class="admin-detail-grid">
                    @Detail("Library", _currentRun.Library)
                    @Detail("Current item", _currentRun.CurrentItem)
                    @Detail("Stage", _currentRun.Stage)
                    @Detail("Started by", _currentRun.StartedBy)
                    @Detail("Elapsed", _currentRun.Elapsed)
                    @Detail("Remaining / ETA", _currentRun.Remaining)
                </div>
            }
            else
            {
                <div class="admin-empty-state">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" />
                    <div>
                        <MudText Typo="Typo.subtitle2">No ingestion currently running</MudText>
                        <MudText Typo="Typo.body2" Class="admin-overview-muted">@_currentRun.IdleDetail</MudText>
                    </div>
                </div>
            }

            <div class="admin-chip-row">
                <span class="admin-chip admin-chip--info">@FormatCount(_currentRun.Queued) queued</span>
                <span class="admin-chip @(_currentRun.Failed > 0 ? "admin-chip--danger" : "")">@FormatCount(_currentRun.Failed) failed</span>
                <span class="admin-chip @(_pendingReviewCount > 0 ? "admin-chip--warning" : "admin-chip--success")">@FormatCount(_pendingReviewCount) needs review</span>
            </div>

            <div class="admin-card-actions">
                <AppButton Href="/settings/ingestion" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary">View run</AppButton>
                <AppButton Href="/settings/ingestion" Variant="Variant.Text" Size="Size.Small" Color="Color.Default">Open tasks</AppButton>
            </div>
        </AppPanel>

        <AppPanel Elevation="0" Class="tl-card admin-overview-card">
            <div class="admin-overview-card__header">
                <div>
                    <MudText Typo="Typo.caption" Class="admin-overview-eyebrow">Curation</MudText>
                    <MudText Typo="Typo.h6">Review Queue</MudText>
                </div>
                <span class="@(_pendingReviewCount > 0 ? "admin-status admin-status--warning" : "admin-status admin-status--success")">
                    @(_pendingReviewCount > 0 ? $"{FormatCount(_pendingReviewCount)} pending" : "Clear")
                </span>
            </div>

            <div class="admin-review-stats">
                @Metric("High priority", FormatCount(_highPriorityReviewCount), Icons.Material.Outlined.PriorityHigh)
                @Metric("Oldest", _oldestReviewAge, Icons.Material.Outlined.Schedule)
                @Metric("New today", FormatCount(_newReviewTodayCount), Icons.Material.Outlined.Today)
            </div>

            @if (_reviewItems.Count == 0)
            {
                <div class="admin-empty-state admin-empty-state--success">
                    <MudIcon Icon="@Icons.Material.Outlined.Verified" />
                    <div>
                        <MudText Typo="Typo.subtitle2">Review queue is clear</MudText>
                        <MudText Typo="Typo.body2" Class="admin-overview-muted">No pending decisions need attention.</MudText>
                    </div>
                </div>
            }
            else
            {
                <div class="admin-compact-list">
                    @foreach (var item in _reviewItems.Take(3))
                    {
                        <div class="admin-compact-row">
                            <MudIcon Icon="@MediaIcon(item.MediaType ?? item.EntityType)" />
                            <div class="admin-compact-row__body">
                                <span>@ReviewTitle(item)</span>
                                <small>@FirstNonBlank(item.MediaType, item.EntityType, "Unknown")</small>
                            </div>
                            <span class="admin-reason-badge">@FormatTrigger(item.Trigger)</span>
                        </div>
                    }
                </div>
            }

            <div class="admin-card-actions">
                <AppButton Href="/settings/review" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Warning">Open review queue</AppButton>
            </div>
        </AppPanel>

        <AppPanel Elevation="0" Class="tl-card admin-overview-card">
            <div class="admin-overview-card__header">
                <div>
                    <MudText Typo="Typo.caption" Class="admin-overview-eyebrow">Playback</MudText>
                    <MudText Typo="Typo.h6">Active Streams</MudText>
                </div>
                <span class="@(_activeTranscodes > 0 ? "admin-status admin-status--info" : "admin-status")">
                    @(_activeTranscodes > 0 ? "Transcoding" : "Idle")
                </span>
            </div>

            <div class="admin-stream-stats">
                @Metric("Active streams", FormatCount(_activeStreams), Icons.Material.Outlined.LiveTv)
                @Metric("Transcodes", FormatCount(_activeTranscodes), Icons.Material.Outlined.VideoSettings)
                @Metric("Direct play", FormatCount(_directPlayStreams), Icons.Material.Outlined.PlayCircle)
            </div>

            <div class="admin-split-bar" aria-label="Playback mode split">
                <AppCssElement Tag="span" Class="admin-split-bar__transcode" Css="@ProgressStyle(_transcodePercent)"></AppCssElement>
                <AppCssElement Tag="span" Class="admin-split-bar__direct" Css="@ProgressStyle(_directPlayPercent)"></AppCssElement>
            </div>

            @if (_activeEncodeJobs.Count == 0)
            {
                <div class="admin-empty-state">
                    <MudIcon Icon="@Icons.Material.Outlined.PlayCircle" />
                    <div>
                        <MudText Typo="Typo.subtitle2">No active streams</MudText>
                        <MudText Typo="Typo.body2" Class="admin-overview-muted">Playback session reporting is not available yet; active transcodes will appear here.</MudText>
                    </div>
                </div>
            }
            else
            {
                <div class="admin-compact-list">
                    @foreach (var job in _activeEncodeJobs.Take(3))
                    {
                        <div class="admin-compact-row">
                            <MudIcon Icon="@Icons.Material.Outlined.VideoSettings" />
                            <div class="admin-compact-row__body">
                                <span>@ShortId(job.AssetId)</span>
                                <small>@FormatEncodeTiming(job)</small>
                            </div>
                            <span class="admin-reason-badge">Transcoding @FormatProfile(job.ProfileKey)</span>
                        </div>
                    }
                </div>
            }

            <div class="admin-card-actions">
                <AppButton Href="/settings/delivery" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary">Open playback</AppButton>
            </div>
        </AppPanel>
    </div>

    <div class="admin-overview-bottom-grid">
        <AppPanel Elevation="0" Class="tl-card admin-overview-card">
            <div class="admin-overview-card__header">
                <div>
                    <MudText Typo="Typo.caption" Class="admin-overview-eyebrow">Recent Work</MudText>
                    <MudText Typo="Typo.h6">Recent Ingestion Runs</MudText>
                </div>
            </div>

            @if (_recentRuns.Count == 0)
            {
                <div class="admin-empty-state">
                    <MudIcon Icon="@Icons.Material.Outlined.PendingActions" />
                    <div>
                        <MudText Typo="Typo.subtitle2">No recent ingestion runs</MudText>
                        <MudText Typo="Typo.body2" Class="admin-overview-muted">Runs will appear after scans are started.</MudText>
                    </div>
                </div>
            }
            else
            {
                <div class="admin-run-table">
                    <div class="admin-run-table__head">
                        <span>Run ID</span>
                        <span>Library</span>
                        <span>Stage</span>
                        <span>Status</span>
                        <span>Started</span>
                    </div>
                    @foreach (var run in _recentRuns.Take(3))
                    {
                        <a class="admin-run-table__row" href="/settings/ingestion" aria-label="@($"Open ingestion run {ShortId(run.Id)}")">
                            <span>@ShortId(run.Id)</span>
                            <span>@RunLibrary(run)</span>
                            <span>@RunStage(run)</span>
                            <span><span class="@StatusBadgeClass(run.Status)">@FormatStatus(run.Status)</span></span>
                            <span>@FormatRelative(run.StartedAt)</span>
                        </a>
                    }
                </div>
            }
        </AppPanel>

        <AppPanel Elevation="0" Class="tl-card admin-overview-card">
            <div class="admin-overview-card__header">
                <div>
                    <MudText Typo="Typo.caption" Class="admin-overview-eyebrow">Today</MudText>
                    <MudText Typo="Typo.h6">Operational Snapshot</MudText>
                </div>
            </div>

            <div class="admin-snapshot-grid">
                @Metric("Added today", FormatCount(_overview?.Added24h ?? 0), Icons.Material.Outlined.AddCircle)
                @Metric("Processed today", FormatCount(_processedToday), Icons.Material.Outlined.TaskAlt)
                @Metric("Needs review", FormatCount(_pendingReviewCount), Icons.Material.Outlined.RateReview)
                @Metric("Active transcodes", FormatCount(_activeTranscodes), Icons.Material.Outlined.VideoSettings)
                @Metric("Recent imports", FormatCount(_recentImportsToday), Icons.Material.Outlined.MoveToInbox)
            </div>
        </AppPanel>
    </div>
</div>

@code {
    [Parameter] public int ReviewCount { get; set; }

    private bool _loading = true;
    private bool _startingIngestion;
    private string? _error;
    private DateTimeOffset? _lastUpdated;

    private LibraryOverviewViewModel? _overview;
    private List<ReviewItemViewModel> _reviewItems = [];
    private IReadOnlyList<IngestionBatchViewModel> _recentRuns = [];
    private List<ActivityEntryViewModel> _recentActivity = [];
    private List<EncodeJobDto> _encodeJobs = [];
    private OverviewRun _currentRun = OverviewRun.Empty;

    private int _pendingReviewCount;
    private int _highPriorityReviewCount;
    private int _newReviewTodayCount;
    private int _processedToday;
    private int _recentImportsToday;
    private int _activeStreams;
    private int _activeTranscodes;
    private int _directPlayStreams;
    private double _transcodePercent;
    private double _directPlayPercent;
    private string _oldestReviewAge = "None";

    private int _libraryTotal
    {
        get
        {
            if (_overview?.MediaTypeCounts.Count > 0)
            {
                return MediaBreakdown.Sum(item => item.Count);
            }

            return _overview?.TotalItems ?? 0;
        }
    }

    private List<EncodeJobDto> _activeEncodeJobs =>
        _encodeJobs
            .Where(job => IsActiveEncodeStatus(job.Status))
            .OrderByDescending(job => job.StartedAt ?? job.CreatedAt)
            .ToList();

    private IReadOnlyList<MediaBreakdownItem> MediaBreakdown
    {
        get
        {
            var counts = _overview?.MediaTypeCounts ?? [];
            var items = new[]
            {
                MediaItem("Books", Icons.Material.Outlined.MenuBook, counts),
                MediaItem("Audiobooks", Icons.Material.Outlined.Headphones, counts),
                MediaItem("Movies", Icons.Material.Outlined.Movie, counts),
                MediaItem("TV Episodes", Icons.Material.Outlined.LiveTv, counts),
                MediaItem("Music", Icons.Material.Outlined.MusicNote, counts),
                MediaItem("Comics", Icons.Material.Outlined.AutoStories, counts),
            };

            var total = items.Sum(item => item.Count);
            if (total <= 0)
            {
                return items;
            }

            return items
                .Select(item => item with { Percent = item.Count * 100d / total })
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        StateContainer.OnStateChanged += OnRealtimeStateChanged;
        await LoadAsync();
    }

    public void Dispose()
    {
        StateContainer.OnStateChanged -= OnRealtimeStateChanged;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var overviewTask = ApiClient.GetLibraryOverviewAsync();
            var reviewsTask = Orchestrator.GetPendingReviewsAsync(3);
            var runsTask = Orchestrator.GetIngestionBatchesAsync(6);
            var activityTask = Orchestrator.GetRecentActivityAsync(25);
            var encodeTask = ApiClient.GetEncodeJobsAsync();

            await Task.WhenAll(overviewTask, reviewsTask, runsTask, activityTask, encodeTask);

            _overview = await overviewTask;
            _reviewItems = await reviewsTask;
            _recentRuns = await runsTask;
            _recentActivity = await activityTask;
            _encodeJobs = await encodeTask;

            Recompute();
            _lastUpdated = DateTimeOffset.Now;
        }
        catch (Exception ex)
        {
            _error = $"Overview data could not load: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task StartIngestionAsync()
    {
        _startingIngestion = true;
        try
        {
            await Orchestrator.TriggerRescanAsync();
            await LoadAsync();
        }
        finally
        {
            _startingIngestion = false;
        }
    }

    private void OnRealtimeStateChanged()
    {
        Recompute();
        InvokeAsync(StateHasChanged);
    }

    private void Recompute()
    {
        _pendingReviewCount = Math.Max(ReviewCount, Math.Max(_overview?.ReviewTotal ?? 0, _reviewItems.Count));
        _highPriorityReviewCount = _reviewItems.Count(item =>
            item.ConfidenceScore is <= 0.60
            || item.Trigger.Contains("LowConfidence", StringComparison.OrdinalIgnoreCase)
            || item.Trigger.Contains("Multiple", StringComparison.OrdinalIgnoreCase));
        _newReviewTodayCount = _reviewItems.Count(item => IsToday(item.CreatedAt));
        _oldestReviewAge = _reviewItems.Count == 0
            ? "None"
            : FormatRelative(_reviewItems.Min(item => item.CreatedAt));

        _processedToday = _recentRuns
            .Where(run => IsToday(run.StartedAt))
            .Sum(run => run.FilesProcessed);

        _recentImportsToday = _recentActivity.Count(entry =>
            IsToday(entry.OccurredAt)
            && (entry.ActionType.Contains("Ingest", StringComparison.OrdinalIgnoreCase)
                || entry.ActionType.Contains("MediaAdded", StringComparison.OrdinalIgnoreCase)));

        _activeTranscodes = _activeEncodeJobs.Count;
        _activeStreams = _activeTranscodes;
        _directPlayStreams = 0;
        var playbackTotal = _activeTranscodes + _directPlayStreams;
        _transcodePercent = playbackTotal > 0 ? _activeTranscodes * 100d / playbackTotal : 0;
        _directPlayPercent = playbackTotal > 0 ? _directPlayStreams * 100d / playbackTotal : 0;

        _currentRun = BuildCurrentRun();
    }

    private OverviewRun BuildCurrentRun()
    {
        var batchProgress = StateContainer.BatchProgress;
        if (batchProgress is not null)
        {
            return new OverviewRun(
                IsActive: true,
                Status: "Processing",
                Progress: batchProgress.ProgressPercent,
                Processed: batchProgress.FilesProcessed,
                Total: batchProgress.FilesTotal,
                Library: "Current batch",
                CurrentItem: FirstNonBlank(batchProgress.CurrentFileTitle, batchProgress.RecentTitles?.FirstOrDefault(), "Processing item"),
                Stage: FirstNonBlank(batchProgress.CurrentStage, batchProgress.LifecycleStage, "Processing"),
                StartedBy: "Engine",
                Elapsed: "In progress",
                Remaining: batchProgress.EstimatedSecondsRemaining.HasValue
                    ? FormatDuration(TimeSpan.FromSeconds(batchProgress.EstimatedSecondsRemaining.Value))
                    : "Calculating",
                Queued: batchProgress.FilesQueued,
                Failed: batchProgress.FilesFailed,
                IdleDetail: "");
        }

        var signalProgress = StateContainer.IngestionProgress;
        if (signalProgress is not null)
        {
            var percent = signalProgress.TotalCount > 0
                ? signalProgress.ProcessedCount * 100d / signalProgress.TotalCount
                : 0;

            return new OverviewRun(
                IsActive: true,
                Status: signalProgress.Stage,
                Progress: percent,
                Processed: signalProgress.ProcessedCount,
                Total: signalProgress.TotalCount,
                Library: "Watch folder",
                CurrentItem: FirstNonBlank(signalProgress.CurrentFile, "Scanning"),
                Stage: signalProgress.Stage,
                StartedBy: "Engine",
                Elapsed: "In progress",
                Remaining: signalProgress.TotalCount > 0 ? "Calculating" : "Discovering files",
                Queued: Math.Max(0, signalProgress.TotalCount - signalProgress.ProcessedCount),
                Failed: 0,
                IdleDetail: "");
        }

        var activeRun = _recentRuns.FirstOrDefault(run => IsActiveRunStatus(run.Status) && !IsRunEffectivelyComplete(run));
        if (activeRun is not null)
        {
            var progress = activeRun.FilesTotal > 0
                ? activeRun.FilesProcessed * 100d / activeRun.FilesTotal
                : 0;

            return new OverviewRun(
                IsActive: true,
                Status: FormatStatus(activeRun.Status),
                Progress: progress,
                Processed: activeRun.FilesProcessed,
                Total: activeRun.FilesTotal,
                Library: RunLibrary(activeRun),
                CurrentItem: "Current item unavailable",
                Stage: RunStage(activeRun),
                StartedBy: "Engine",
                Elapsed: FormatDuration(DateTimeOffset.UtcNow - activeRun.StartedAt.ToUniversalTime()),
                Remaining: "Calculating",
                Queued: Math.Max(0, activeRun.FilesTotal - activeRun.FilesProcessed),
                Failed: activeRun.FilesFailed,
                IdleDetail: "");
        }

        var lastRun = _recentRuns.FirstOrDefault();
        return OverviewRun.Empty with
        {
            Failed = _recentRuns.Sum(run => run.FilesFailed),
            IdleDetail = lastRun is null
                ? "No recent run data is available."
                : $"Last run {FormatStatus(lastRun.Status).ToLowerInvariant()} {FormatRelative(lastRun.StartedAt)}."
        };
    }

    private static RenderFragment Detail(string label, string value) => @<div class="admin-detail">
        <span>@label</span>
        <strong>@value</strong>
    </div>;

    private static RenderFragment Metric(string label, string value, string icon) => @<div class="admin-metric">
        <MudIcon Icon="@icon" />
        <div>
            <span>@label</span>
            <strong>@value</strong>
        </div>
    </div>;

    private static MediaBreakdownItem MediaItem(string label, string icon, Dictionary<string, int> counts) =>
        new(label, icon, CountFor(counts, label), 0);

    private static int CountFor(Dictionary<string, int> counts, string label)
    {
        string[] aliases = label switch
        {
            "Books" => new[] { "book", "books", "epub" },
            "Audiobooks" => new[] { "audiobook", "audiobooks", "m4b" },
            "Movies" => new[] { "movie", "movies", "film", "video" },
            "TV Episodes" => new[] { "tv", "tv episode", "tv episodes", "episode", "episodes" },
            "Music" => new[] { "music", "track", "tracks", "song", "songs", "album" },
            "Comics" => new[] { "comic", "comics", "cbz", "cbr" },
            _ => new[] { label },
        };

        var normalizedAliases = aliases.Select(NormalizeMediaKey).ToHashSet(StringComparer.OrdinalIgnoreCase);
        return counts
            .Where(kv => normalizedAliases.Contains(NormalizeMediaKey(kv.Key)))
            .Sum(kv => kv.Value);
    }

    private static string NormalizeMediaKey(string value) =>
        new(value
            .Where(char.IsLetterOrDigit)
            .Select(char.ToLowerInvariant)
            .ToArray());

    private static string SegmentStyle(MediaBreakdownItem item) =>
        $"width: {Math.Max(item.Percent, 1).ToString("0.###", CultureInfo.InvariantCulture)}%; background: {item.Color};";

    private static string CompositionLabelStyle(MediaBreakdownItem item) =>
        $"flex-basis: {Math.Max(item.Percent, 1).ToString("0.###", CultureInfo.InvariantCulture)}%; color: {item.Color};";

    private static string ProgressStyle(double percent) =>
        $"width: {Math.Clamp(percent, 0, 100).ToString("0.###", CultureInfo.InvariantCulture)}%;";

    private static string FormatCount(int value) => value.ToString("N0", CultureInfo.CurrentCulture);

    private static string FormatPercent(double value) =>
        value <= 0 ? "0%" : $"{Math.Round(value):0}%";

    private static string FormatClock(DateTimeOffset? value) =>
        value.HasValue ? value.Value.ToLocalTime().ToString("h:mm tt", CultureInfo.CurrentCulture) : "not yet";

    private static string FormatDuration(TimeSpan duration)
    {
        duration = duration.Duration();
        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        }

        return $"{duration.Minutes}m {duration.Seconds}s";
    }

    private static string FormatRelative(string value) =>
        DateTimeOffset.TryParse(value, out var parsed) ? FormatRelative(parsed) : "recently";

    private static string FormatRelative(DateTimeOffset value)
    {
        var elapsed = DateTimeOffset.UtcNow - value.ToUniversalTime();
        return elapsed.TotalMinutes switch
        {
            < 1 => "just now",
            < 60 => $"{(int)elapsed.TotalMinutes}m ago",
            < 1440 => $"{(int)elapsed.TotalHours}h ago",
            _ => $"{(int)elapsed.TotalDays}d ago",
        };
    }

    private static bool IsToday(DateTimeOffset value) => value.ToLocalTime().Date == DateTimeOffset.Now.Date;

    private static bool IsToday(string value) =>
        DateTimeOffset.TryParse(value, out var parsed) && IsToday(parsed);

    private static string ReviewTitle(ReviewItemViewModel item) =>
        FirstNonBlank(item.EntityTitle, item.Detail, item.EntityId.ToString());

    private static string FormatTrigger(string trigger)
    {
        if (string.IsNullOrWhiteSpace(trigger))
        {
            return "Review";
        }

        var text = trigger.Replace("_", " ").Replace("-", " ");
        var chars = text.SelectMany((c, i) =>
            i > 0 && char.IsUpper(c) && !char.IsWhiteSpace(text[i - 1])
                ? new[] { ' ', c }
                : new[] { c });
        return new string(chars.ToArray()).Trim();
    }

    private static string MediaIcon(string? mediaType)
    {
        if (string.IsNullOrWhiteSpace(mediaType))
        {
            return Icons.Material.Outlined.Inventory2;
        }

        return LibraryHelpers.GetMediaTypeIcon(mediaType);
    }

    private static string StatusBadgeClass(string status)
    {
        var normalized = status.ToLowerInvariant();
        var tone = normalized switch
        {
            var s when s.Contains("fail") || s.Contains("error") => "danger",
            var s when s.Contains("queue") => "info",
            var s when s.Contains("process") || s.Contains("running") || s.Contains("active") => "primary",
            var s when s.Contains("complete") || s.Contains("ready") => "success",
            _ => "neutral",
        };

        return $"admin-status admin-status--{tone}";
    }

    private static string FormatStatus(string status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "Unknown";
        }

        return FormatTrigger(status);
    }

    private static bool IsActiveRunStatus(string status) =>
        status.Contains("processing", StringComparison.OrdinalIgnoreCase)
        || status.Contains("running", StringComparison.OrdinalIgnoreCase)
        || status.Contains("queued", StringComparison.OrdinalIgnoreCase)
        || status.Contains("active", StringComparison.OrdinalIgnoreCase);

    private static bool IsRunEffectivelyComplete(IngestionBatchViewModel run) =>
        run.FilesTotal > 0
        && run.FilesProcessed >= run.FilesTotal
        && !run.Status.Contains("fail", StringComparison.OrdinalIgnoreCase);

    private static bool IsActiveEncodeStatus(string status) =>
        status.Equals(EncodeJobStatuses.Running, StringComparison.OrdinalIgnoreCase)
        || status.Equals(EncodeJobStatuses.Queued, StringComparison.OrdinalIgnoreCase)
        || status.Equals(EncodeJobStatuses.Scheduled, StringComparison.OrdinalIgnoreCase);

    private static string RunLibrary(IngestionBatchViewModel run) =>
        FirstNonBlank(run.Category, ShortPath(run.SourcePath), "Library");

    private static string RunStage(IngestionBatchViewModel run)
    {
        if (run.FilesFailed > 0)
        {
            return "Failed";
        }

        if (run.FilesReview > 0)
        {
            return "Review";
        }

        if (run.FilesProcessed < run.FilesTotal)
        {
            return "Processing";
        }

        return "Complete";
    }

    private static string ShortPath(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return string.Empty;
        }

        var trimmed = path.TrimEnd('\\', '/');
        var index = Math.Max(trimmed.LastIndexOf('\\'), trimmed.LastIndexOf('/'));
        return index >= 0 ? trimmed[(index + 1)..] : trimmed;
    }

    private static string ShortId(Guid id) => id.ToString("N")[..8];

    private static string FormatProfile(string profileKey) =>
        string.IsNullOrWhiteSpace(profileKey) ? "media" : profileKey.Replace("-", " ");

    private static string FormatEncodeTiming(EncodeJobDto job)
    {
        if (job.ProgressPct > 0)
        {
            return $"{job.ProgressPct:0}% complete";
        }

        return FormatStatus(job.Status);
    }

    private static string FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? string.Empty;

    private sealed record MediaBreakdownItem(string Label, string Icon, int Count, double Percent)
    {
        public string Color => Label switch
        {
            "Books" => "#9a6dff",
            "Audiobooks" => "#c065df",
            "Movies" => "#72a5ff",
            "TV Episodes" => "#5adcf5",
            "Music" => "#50d6c4",
            "Comics" => "#ff9a45",
            _ => "#94a3b8",
        };

        public string AccentStyle => $"--media-color: {Color};";
    }

    private sealed record OverviewRun(
        bool IsActive,
        string Status,
        double Progress,
        int Processed,
        int Total,
        string Library,
        string CurrentItem,
        string Stage,
        string StartedBy,
        string Elapsed,
        string Remaining,
        int Queued,
        int Failed,
        string IdleDetail)
    {
        public static OverviewRun Empty { get; } = new(
            false,
            "Idle",
            0,
            0,
            0,
            "None",
            "None",
            "Idle",
            "None",
            "0m",
            "None",
            0,
            0,
            "No recent run data is available.");
    }
}