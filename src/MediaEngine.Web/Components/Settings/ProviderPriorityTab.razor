@namespace MediaEngine.Web.Components.Settings
@inject IEngineApiClient ApiClient
@inject MediaEngine.Web.Services.Integration.ProviderCatalogueService CatalogueService
@inject ILogger<ProviderPriorityTab> Logger
@inject ISnackbar Snackbar
@using MediaEngine.Domain.Enums
@using MediaEngine.Contracts.Settings
@using MediaEngine.Web.Models.ViewDTOs

<div class="provider-page">
    <header class="provider-hero">
        <div class="provider-hero__bar">
            <div>
                <h2 class="provider-hero__title">Metadata Providers</h2>
                <div class="provider-hero__copy">
                    Assign providers to every media type and manage Engine-backed provider settings from one place. If Engine configuration cannot load, this page shows an unavailable state instead of sample defaults.
                </div>
            </div>
            <SettingsStatusBadge Status="@(_engineConfigurationUnavailable ? SettingsStatusKind.EngineUnavailable : SettingsStatusKind.Live)" />
        </div>
    </header>

    <section class="provider-stage-strip" aria-label="Metadata provider stages">
        @foreach (var stage in ProviderStages)
        {
            <div class="provider-stage-card @(stage.Number == 1 ? "is-active" : null)">
                <div class="provider-stage-card__number">@stage.Number</div>
                <div class="provider-stage-card__body">
                    <div class="provider-stage-card__title">@stage.Title</div>
                    <div class="provider-stage-card__copy">@stage.Description</div>
                </div>
            </div>
        }
    </section>

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <AppAlert Tone="AppUiTone.Warning" Class="mb-4">
            @_loadError
        </AppAlert>
    }
    else if (_liveCatalogue.Count == 0)
    {
        <AppAlert Tone="AppUiTone.Warning" Class="mb-4">
            Provider catalogue metadata is unavailable from the Engine. Existing configured chains can still be viewed, but adding providers is disabled so sample data is not presented as live configuration.
        </AppAlert>
    }

    <div class="provider-layout">
        <section class="provider-panel">
            <div class="provider-panel__header">
                <div>
                    <h3 class="provider-panel__title">Available Providers</h3>
                    <div class="provider-panel__copy">Drag providers into media type slots, or select one to edit its settings.</div>
                </div>
            </div>
            <div class="provider-list">
                @if (GetProviderCards().Count == 0)
                {
                    <div class="provider-empty-state">
                        Provider catalogue metadata is unavailable from the Engine. Existing assignments remain visible on the right.
                    </div>
                }
                else
                {
                    @foreach (var provider in GetProviderCards())
                    {
                        var providerName = provider.Name;
                        var logoUrl = GetProviderLogoUrl(providerName);
                        <div class="provider-list-card @(IsSelectedProvider(providerName) ? "is-selected" : null)"
                             draggable="true"
                             @ondragstart="@(() => BeginProviderDrag(providerName))"
                             @onclick="@(() => SelectProvider(providerName))"
                             role="button"
                             tabindex="0">
                            <AppProviderLogo ImageUrl="@logoUrl"
                                             Icon="@GetProviderIcon(providerName)"
                                             AccentColor="@GetProviderAccent(providerName)"
                                             FallbackText="@GetProviderInitials(providerName)"
                                             AltText="" />
                            <div class="provider-list-card__body">
                                <div class="provider-list-card__name">@providerName</div>
                                <div class="provider-list-card__description">@GetProviderDescription(providerName)</div>
                                <div class="provider-chip-row">
                                    @foreach (var mt in GetProviderMediaTypes(providerName))
                                    {
                                        <AppChip Icon="@GetMediaTypeIcon(mt)" Tone="AppUiTone.Primary" Class="provider-chip">
                                            @GetMediaTypeDisplay(mt)
                                        </AppChip>
                                    }
                                </div>
                            </div>
                            <div class="provider-drag-handle" title="Drag to assign">
                                <MudIcon Icon="@Icons.Material.Outlined.DragIndicator" Size="Size.Small" />
                            </div>
                        </div>
                    }
                }
            </div>
        </section>

        <div class="provider-min">
            <section class="provider-panel provider-assignment-card">
                <div class="provider-panel__header">
                    <div>
                        <h3 class="provider-panel__title">Assign to Media Types (Retail Lookup)</h3>
                        <div class="provider-panel__copy">Every supported Tuvima media type has its own provider order and lookup strategy.</div>
                    </div>
                    <AppButton Label="How it works"
                               StartIcon="@Icons.Material.Outlined.HelpOutline"
                               Size="AppControlSize.Compact" />
                </div>

                <div class="provider-media-grid">
                    @foreach (var mediaType in _mediaTypes)
                    {
                        var chain = GetChain(mediaType);
                        <div class="provider-media-slot @(mediaType == _activeTab ? "is-selected" : null)"
                             @onclick="@(() => _activeTab = mediaType)"
                             @ondragover:preventDefault="true"
                             @ondrop="@(() => DropProviderOnMediaType(mediaType))">
                            <div class="provider-media-slot__header">
                                <div class="provider-media-slot__icon">
                                    <MudIcon Icon="@GetMediaTypeIcon(mediaType)" Size="Size.Small" />
                                </div>
                                <div class="provider-media-slot__title">@GetMediaTypeDisplay(mediaType)</div>
                                <div class="provider-media-slot__strategy">@GetStrategy(mediaType)</div>
                            </div>

                            <div class="provider-assignment-list">
                                @for (var i = 0; i < chain.Count; i++)
                                {
                                    var idx = i;
                                    var assignment = chain[idx];
                                    var assignmentLogoUrl = GetProviderLogoUrl(assignment.Name);
                                    <div class="provider-assignment-row @(IsSelectedAssignment(mediaType, idx) ? "is-selected" : null)"
                                         draggable="true"
                                         @ondragstart="@(() => BeginAssignmentDrag(mediaType, idx))"
                                         @ondragover:preventDefault="true"
                                         @ondrop="@(() => DropOnAssignment(mediaType, idx))"
                                         @onclick:stopPropagation="true"
                                         @onclick="@(() => SelectAssignment(mediaType, idx))"
                                         role="button"
                                         tabindex="0">
                                        <div class="provider-assignment-rank">@(idx + 1)</div>
                                        <AppProviderLogo ImageUrl="@assignmentLogoUrl"
                                                         Icon="@GetProviderIcon(assignment.Name)"
                                                         AccentColor="@GetProviderAccent(assignment.Name)"
                                                         FallbackText="@GetProviderInitials(assignment.Name)"
                                                         Size="AppControlSize.Compact"
                                                         AltText="" />
                                        <div class="provider-min">
                                            <div class="provider-assignment-row__name">@assignment.Name</div>
                                            <div class="provider-assignment-row__meta">@GetSuccessRateDisplay(assignment.Name)</div>
                                        </div>
                                        <div class="provider-assignment-actions" @onclick:stopPropagation="true">
                                            <AppIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                                           Size="AppControlSize.Compact"
                                                           Disabled="@(idx == 0)"
                                                           AriaLabel="Move provider up"
                                                           Tooltip="Move up"
                                                           OnClick="@(() => MoveLeft(mediaType, idx))" />
                                            <AppIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                                           Size="AppControlSize.Compact"
                                                           Disabled="@(idx == chain.Count - 1)"
                                                           AriaLabel="Move provider down"
                                                           Tooltip="Move down"
                                                           OnClick="@(() => MoveRight(mediaType, idx))" />
                                            <MudIcon Icon="@Icons.Material.Outlined.DragIndicator" Size="Size.Small" />
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="provider-drop-zone">Drag providers here</div>
                            <div class="provider-media-slot__footer" @onclick:stopPropagation="true">
                                <AppSelect T="string" Value="@GetStrategy(mediaType)"
                                           ValueChanged="@(v => SetStrategy(mediaType, v ?? "Waterfall"))"
                                           Options="@StrategyOptions"
                                           Disabled="@(_engineConfigurationUnavailable || _liveCatalogue.Count == 0)"
                                           Size="AppControlSize.Compact"
                                           Class="provider-strategy-select" />
                                <AppButton Label="Add"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           Size="AppControlSize.Compact"
                                           Disabled="@_engineConfigurationUnavailable"
                                           OnClick="@(() => OpenAddDialog(mediaType))" />
                            </div>
                        </div>
                    }
                </div>
            </section>

            <section class="provider-panel provider-settings-card">
                @if (_drawerAssignment is null)
                {
                    <div class="provider-empty-state">Select a provider or assigned media slot to edit provider settings.</div>
                }
                else
                {
                    var drawerInfo = GetProviderInfo(_drawerAssignment.Name);
                    <div class="provider-settings-card__header">
                        <div>
                            <h3 class="provider-panel__title">Provider Settings</h3>
                            <div class="provider-panel__copy">Edit settings for the selected provider.</div>
                        </div>
                        <AppChip Icon="@Icons.Material.Filled.Circle" Tone="AppUiTone.Success" Class="provider-chip">
                            Editing: @_drawerAssignment.Name
                        </AppChip>
                    </div>
                    <div class="provider-settings-grid">
                        <div>
                            <div class="provider-settings-summary">
                                @{
                                    var selectedLogoUrl = GetProviderLogoUrl(_drawerAssignment.Name);
                                }
                                <AppProviderLogo ImageUrl="@selectedLogoUrl"
                                                 Icon="@GetProviderIcon(_drawerAssignment.Name)"
                                                 AccentColor="@GetProviderAccent(_drawerAssignment.Name)"
                                                 FallbackText="@GetProviderInitials(_drawerAssignment.Name)"
                                                 Size="AppControlSize.Large"
                                                 AltText="" />
                                <div class="provider-min">
                                    <div class="provider-settings__name">@_drawerAssignment.Name</div>
                                    <div class="provider-settings__description">@GetProviderDescription(_drawerAssignment.Name)</div>
                                    <div class="provider-chip-row">
                                        @foreach (var mt in GetProviderMediaTypes(_drawerAssignment.Name))
                                        {
                                            <AppChip Icon="@GetMediaTypeIcon(mt)" Tone="AppUiTone.Primary" Class="provider-chip">
                                                @GetMediaTypeDisplay(mt)
                                            </AppChip>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="provider-settings-details">
                                <div class="provider-settings__detail">Health: @GetSuccessRateDisplay(_drawerAssignment.Name)</div>
                                <div class="provider-settings__detail">Latency: @GetLatencyDisplay(_drawerAssignment.Name)</div>
                                <div class="provider-settings__detail">Domain: @GetProviderDomain(_drawerAssignment.Name)</div>
                                <div class="provider-settings__detail">Authentication: @(drawerInfo?.RequiresKey == true ? "API key required" : "No key required")</div>
                            </div>
                        </div>

                        <div>
                            <div class="provider-settings-fields">
                                <AppTextField Value="@_drawerAssignment.Name"
                                              Label="Provider Name"
                                              Disabled="true" />
                                <AppSwitchRow Label="Status"
                                              Value="@_drawerAssignment.Enabled"
                                              ValueChanged="@(v => _drawerAssignment.Enabled = v)"
                                              SwitchLabel="@(_drawerAssignment.Enabled ? "Enabled" : "Disabled")" />
                                @if (drawerInfo?.RequiresKey == true)
                                {
                                    @if (drawerInfo.AuthType == "basic")
                                    {
                                        <AppTextField @bind-Value="_drawerAssignment.Username"
                                                      Label="Username" />
                                        <AppTextField @bind-Value="_drawerAssignment.Password"
                                                      Label="Password"
                                                      InputType="InputType.Password" />
                                    }
                                    else
                                    {
                                        <AppTextField @bind-Value="_drawerAssignment.ApiKey"
                                                      Label="API Key"
                                                      InputType="InputType.Password"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Outlined.Visibility" />
                                    }
                                }
                                else
                                {
                                    <AppTextField Value="@("Zero-key provider")"
                                                  Label="API Key"
                                                  Disabled="true" />
                                }
                                <AppNumericField @bind-Value="_drawerAssignment.TimeoutMs"
                                                 Label="Request Timeout (ms)"
                                                 Min="500"
                                                 Max="60000" />
                                <AppSelect T="string" @bind-Value="_drawerAssignment.LanguageStrategy"
                                           Label="Region / Language"
                                           Options="@LanguageStrategyOptions" />
                            </div>

                            <AppActionBar Class="provider-settings-actions">
                                @if (_drawerIndex >= 0)
                                {
                                    <AppButton Label="Remove"
                                               Tone="AppUiTone.Error"
                                               Size="AppControlSize.Compact"
                                               StartIcon="@Icons.Material.Outlined.RemoveCircleOutline"
                                               OnClick="RemoveFromChain" />
                                }
                                <AppButton Label="Test Connection"
                                           Size="AppControlSize.Compact"
                                           StartIcon="@Icons.Material.Outlined.NetworkCheck"
                                           OnClick="@TestConnectionAsync" />
                                <AppButton Tone="AppUiTone.Primary"
                                           ButtonStyle="AppButtonStyle.Filled"
                                           Size="AppControlSize.Compact"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="SaveDrawerAsync"
                                           Disabled="@_drawerSaving"
                                           Label="@(_drawerSaving ? "Saving..." : "Save Provider")" />
                                <AppButton Tone="AppUiTone.Primary"
                                           ButtonStyle="AppButtonStyle.Filled"
                                           Size="AppControlSize.Compact"
                                           StartIcon="@Icons.Material.Outlined.Done"
                                           OnClick="@SaveAsync"
                                           Disabled="@(_saving || _engineConfigurationUnavailable || !HasProviderChanges)"
                                           Label="@(_saving ? "Saving..." : "Save Changes")" />
                            </AppActionBar>

                            @if (_lastProviderTests.TryGetValue(_drawerAssignment.Name, out var test))
                            {
                                <div class="provider-message provider-message--test @(test.Success ? "provider-message--success" : "provider-message--error")">
                                    Last tested @test.TestedAt.LocalDateTime.ToString("MMM d, HH:mm"): @test.Message
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(_drawerSaveMessage))
                            {
                                <div class="provider-message @(_drawerSaveSuccess ? "provider-message--success" : "provider-message--error")">
                                    @_drawerSaveMessage
                                </div>
                            }
                            <div class="provider-message">
                                @ProviderStatusDescription(_drawerAssignment)
                            </div>
                        </div>
                    </div>
                }
            </section>
        </div>
    </div>
</div>
<AppDialog @bind-Visible="_addDialogOpen"
           Title="@($"Add Provider - {_addDialogMediaType}")"
           Size="Small"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true })">
    <ChildContent>
        <AppSearchField @bind-Value="_addDialogSearch"
                        Placeholder="Search providers..."
                        Class="mb-3" />

        @{
            var available = GetAvailableProviders(_addDialogMediaType);
            var filtered  = string.IsNullOrWhiteSpace(_addDialogSearch)
                ? available
                : available.Where(p => p.Name.Contains(_addDialogSearch, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        @if (!filtered.Any())
        {
            <div class="provider-empty-state">
                No Engine-backed providers are available for this media type.
            </div>
        }
        else
        {
            @foreach (var p in filtered)
            {
                var pCapture = p;
                var pLogoUrl = GetProviderLogoUrl(pCapture.Name);
                <div class="provider-add-row"
                     @onclick="@(() => AddProviderToChain(pCapture.Name))"
                     role="button"
                     tabindex="0">

                    <AppProviderLogo ImageUrl="@pLogoUrl"
                                     Icon="@GetProviderIcon(pCapture.Name)"
                                     AccentColor="@GetProviderAccent(pCapture.Name)"
                                     FallbackText="@GetProviderInitials(pCapture.Name)"
                                     Size="AppControlSize.Compact"
                                     AltText="" />

                    <div class="provider-add-row__body">
                        <div class="provider-add-row__name">@pCapture.Name</div>
                        <div class="provider-add-row__meta">
                            @pCapture.Type  -  @(pCapture.RequiresKey ? "Requires key" : "Zero-key")
                        </div>
                    </div>

                    <div class="provider-add-row__rate">
                        @((pCapture.SuccessRate * 100).ToString("F0"))%
                    </div>

                </div>
            }
        }
    </ChildContent>
    <FooterContent>
        <AppButton Label="Cancel" OnClick="@(() => _addDialogOpen = false)" />
    </FooterContent>
</AppDialog>

@code {

    private sealed record ProviderInfo(
        string   Name,
        string   Type,
        bool     RequiresKey,
        string[] Supports,
        int      LatencyMs,
        double   SuccessRate,
        string   AuthType = "api_key");

    private sealed record ProviderStageDef(int Number, string Title, string Description);

    private static readonly ProviderStageDef[] ProviderStages =
    [
        new(1, "Retail Lookup", "Find metadata from retail sources"),
        new(2, "Canonical Identity", "Build people and title identity"),
        new(3, "Enrichment & Artwork", "Add artwork and enrich data"),
    ];

    private static readonly IReadOnlyList<AppSelectOption> StrategyOptions =
    [
        new("Waterfall", "Waterfall"),
        new("Cascade", "Cascade"),
        new("Sequential", "Sequential"),
    ];

    private static readonly IReadOnlyList<AppSelectOption> LanguageStrategyOptions =
    [
        new("source", "Source defaults"),
        new("localized", "Localized metadata"),
        new("both", "Source + localized"),
    ];

    private static readonly ProviderInfo[] AllProviderCatalogue =
    [
        new("Apple API",      "Retail", false, ["Books", "Audiobooks", "Music"],                 120, 0.94),
        new("Open Library",   "Open",   false, ["Books"],                                        240, 0.87),
        new("TMDB",           "Retail", true,  ["Movies", "TV"],                                 110, 0.96),
        new("MusicBrainz",    "Open",   false, ["Music"],                                        210, 0.89),
        new("Comic Vine",      "Retail", true,  ["Comics"],                                       200, 0.88),
        new("Wikidata",       "Open",   false, ["Books","Movies","TV","Music","Comics","Audiobooks"], 300, 0.85),
        new("Fanart.tv",      "Image",  true,  ["Movies","TV","Music"],                           180, 0.91),
        new("LRCLIB",         "Enrichment", false, ["Music"],                                     160, 0.90),
        new("OpenSubtitles",   "Enrichment", true, ["Movies", "TV"],                              220, 0.90),
    ];

    private sealed class ProviderAssignment
    {
        public string Name             { get; set; } = "";
        public int    TimeoutMs        { get; set; } = 3000;
        public string ApiKey           { get; set; } = "";
        public string Username         { get; set; } = "";
        public string Password         { get; set; } = "";
        public bool   Enabled          { get; set; } = true;
        public int    Retries          { get; set; } = 1;
        public string LanguageStrategy { get; set; } = "source";
    }

    private sealed record ProviderTestSessionResult(bool Success, DateTimeOffset TestedAt, string Message);

    private static readonly Dictionary<string, string> DefaultStrategies = new()
    {
        ["Books"]      = "Cascade",
        ["Audiobooks"] = "Sequential",
        ["Movies"]     = "Waterfall",
        ["TV"]         = "Waterfall",
        ["Music"]      = "Sequential",
        ["Comics"]     = "Waterfall",
    };

    private static readonly Dictionary<string, List<ProviderAssignment>> DefaultAssignments = new()
    {
        ["Books"]      = [new() { Name = "Apple API", LanguageStrategy = "localized" }],
        ["Audiobooks"] = [new() { Name = "Apple API", LanguageStrategy = "localized" }],
        ["Movies"]     = [new() { Name = "TMDB", LanguageStrategy = "localized" }],
        ["TV"]         = [new() { Name = "TMDB", LanguageStrategy = "localized" }],
        ["Music"]      = [new() { Name = "MusicBrainz", LanguageStrategy = "source" }],
        ["Comics"]     = [new() { Name = "Comic Vine", LanguageStrategy = "source" }],
    };

    private static readonly Dictionary<string, string[]> ProviderMediaTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Apple API"]      = ["Books", "Audiobooks", "Music"],
        ["Open Library"]   = ["Books"],
        ["TMDB"]           = ["Movies", "TV"],
        ["MusicBrainz"]    = ["Music"],
        ["Comic Vine"]     = ["Comics"],
        ["Wikidata"]       = ["All"],
        ["Fanart.tv"]      = ["Movies", "TV", "Music"],
        ["LRCLIB"]         = ["Music"],
        ["OpenSubtitles"]  = ["Movies", "TV"],
    };

    private readonly string[] _mediaTypes =
        ["Movies", "TV", "Music", "Books", "Audiobooks", "Comics"];

    private static readonly Dictionary<string, string> ProviderIconFallbacks = new(StringComparer.OrdinalIgnoreCase)
    {
        ["apple_api"] = "images/providers/apple_books.svg",
        ["comicvine"] = "images/providers/comicvine.png",
        ["fanart_tv"] = "images/providers/fanart_tv.png",
        ["lrclib"] = "images/providers/lrclib.png",
        ["musicbrainz"] = "images/providers/musicbrainz.svg",
        ["opensubtitles"] = "images/providers/opensubtitles.png",
        ["open_library"] = "images/providers/open_library.png",
        ["tmdb"] = "images/providers/tmdb.svg",
        ["wikidata"] = "images/providers/wikidata_reconciliation.svg",
        ["wikidata_reconciliation"] = "images/providers/wikidata_reconciliation.svg",
    };

    private string _activeTab = "Movies";
    private Dictionary<string, List<ProviderAssignment>> _assignments = new();
    private Dictionary<string, string> _strategies = new();
    private PipelineConfiguration _pipelineConfiguration = new();
    private string             _drawerMediaType   = "";
    private int                _drawerIndex       = -1;
    private ProviderAssignment? _drawerAssignment  = null;
    private bool   _addDialogOpen      = false;
    private string _addDialogMediaType = "";
    private string _addDialogSearch    = "";

    private bool _saving = false;
    private bool   _drawerSaving       = false;
    private string _drawerSaveMessage  = "";
    private bool   _drawerSaveSuccess  = false;

    private Dictionary<string, ProviderHealthDto> _healthData = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<ProviderCatalogueDto> _liveCatalogue = [];
    private Dictionary<string, ProviderStatusDto> _providerStatusByKey = new(StringComparer.OrdinalIgnoreCase);
    private string? _loadError;
    private bool _engineConfigurationUnavailable;
    private Dictionary<string, List<ProviderAssignment>> _savedAssignments = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> _savedStrategies = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, ProviderTestSessionResult> _lastProviderTests = new(StringComparer.OrdinalIgnoreCase);
    private string? _dragProviderName;
    private string? _dragAssignmentMediaType;
    private int _dragAssignmentIndex = -1;

    private bool HasProviderChanges =>
        !SerializeAssignments(_assignments).Equals(SerializeAssignments(_savedAssignments), StringComparison.Ordinal)
        || !_strategies.OrderBy(kv => kv.Key, StringComparer.OrdinalIgnoreCase)
            .SequenceEqual(_savedStrategies.OrderBy(kv => kv.Key, StringComparer.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _liveCatalogue = await CatalogueService.GetCatalogueAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not load live provider catalogue.");
            _liveCatalogue = [];
        }
        await LoadFromEngineAsync();
        await LoadHealthDataAsync();
        SelectFirstAssignmentIfNeeded();
    }

    private async Task LoadFromEngineAsync()
    {
        try
        {
            _providerStatusByKey = BuildProviderStatusLookup(await ApiClient.GetProviderStatusAsync());
            var pipelines = await ApiClient.GetPipelinesAsync();
            if (pipelines?.Pipelines is { Count: > 0 })
            {
                ApplyPipelineConfiguration(pipelines);
                SnapshotProviderBaseline();
                _loadError = null;
                _engineConfigurationUnavailable = false;
                return;
            }

            _loadError = "Provider priority configuration is unavailable from the Engine.";
            _engineConfigurationUnavailable = true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not load provider priority configuration from Engine.");
            _loadError = "Provider priority configuration is unavailable. Start the Engine or retry before editing provider order.";
            _engineConfigurationUnavailable = true;
        }

        InitializeEmptyAssignments();
        SnapshotProviderBaseline();
    }

    private void ApplyPipelineConfiguration(PipelineConfiguration pipelines)
    {
        _pipelineConfiguration = pipelines;
        _assignments = new Dictionary<string, List<ProviderAssignment>>(StringComparer.OrdinalIgnoreCase);
        _strategies = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var mediaType in _mediaTypes)
        {
            var pipeline = pipelines.GetPipelineForMediaType(mediaType);
            _assignments[mediaType] = pipeline.Providers
                .OrderBy(provider => provider.Rank)
                .Select(provider => CreateAssignmentFromProviderKey(provider.Name))
                .ToList();
            _strategies[mediaType] = FormatProviderStrategy(pipeline.Strategy);
        }
    }

    private ProviderAssignment CreateAssignmentFromProviderKey(string providerSlotName)
    {
        var displayName = ResolveDisplayName(providerSlotName);
        var info = AllProviderCatalogue.FirstOrDefault(p =>
            p.Name.Replace(" ", "_").Equals(providerSlotName, StringComparison.OrdinalIgnoreCase));
        _providerStatusByKey.TryGetValue(providerSlotName, out var status);
        status ??= _providerStatusByKey.GetValueOrDefault(displayName);
        var resolvedName = status?.DisplayName ?? info?.Name ?? displayName;

        return new ProviderAssignment
        {
            Name             = resolvedName,
            Enabled          = status?.Enabled ?? true,
            TimeoutMs        = (status?.TimeoutSeconds ?? 3) * 1000,
            LanguageStrategy = NormalizeLanguageStrategy(status?.LanguageStrategy)
                               ?? GetDefaultLanguageStrategy(resolvedName),
        };
    }

    private static Dictionary<string, ProviderStatusDto> BuildProviderStatusLookup(
        IReadOnlyList<ProviderStatusDto> statuses)
    {
        var lookup = new Dictionary<string, ProviderStatusDto>(StringComparer.OrdinalIgnoreCase);
        foreach (var status in statuses)
        {
            AddProviderStatusLookup(lookup, status.Name, status);
            AddProviderStatusLookup(lookup, status.DisplayName, status);
            AddProviderStatusLookup(lookup, status.Name.Replace("_", " "), status);
            AddProviderStatusLookup(lookup, status.DisplayName.Replace(" ", "_"), status);
        }

        return lookup;
    }

    private static void AddProviderStatusLookup(
        IDictionary<string, ProviderStatusDto> lookup,
        string? key,
        ProviderStatusDto status)
    {
        if (!string.IsNullOrWhiteSpace(key))
            lookup[key] = status;
    }

    private static string? NormalizeLanguageStrategy(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var candidate = value.Trim().ToLowerInvariant();
        return candidate is "source" or "localized" or "both" ? candidate : null;
    }

    private string GetDefaultLanguageStrategy(string providerName)
    {
        if (_providerStatusByKey.TryGetValue(providerName, out var status))
            return NormalizeLanguageStrategy(status.LanguageStrategy) ?? "source";

        return DefaultAssignments
            .SelectMany(kv => kv.Value)
            .FirstOrDefault(a => string.Equals(a.Name, providerName, StringComparison.OrdinalIgnoreCase))
            ?.LanguageStrategy
            ?? "source";
    }

    private ProviderAssignment CreateAssignmentFromProviderName(string providerName)
    {
        _providerStatusByKey.TryGetValue(providerName, out var status);
        status ??= _providerStatusByKey.GetValueOrDefault(providerName.Replace(" ", "_"));

        return new ProviderAssignment
        {
            Name             = status?.DisplayName ?? providerName,
            Enabled          = status?.Enabled ?? true,
            TimeoutMs        = (status?.TimeoutSeconds ?? 3) * 1000,
            LanguageStrategy = NormalizeLanguageStrategy(status?.LanguageStrategy)
                               ?? GetDefaultLanguageStrategy(providerName),
        };
    }

    private static string ResolveDisplayName(string slotName)
    {
        var match = AllProviderCatalogue.FirstOrDefault(p =>
            p.Name.Replace(" ", "_").Equals(slotName, StringComparison.OrdinalIgnoreCase));
        if (match is not null) return match.Name;
        return string.Join(' ', slotName.Split('_')
            .Select(w => w.Length > 0 ? char.ToUpperInvariant(w[0]) + w[1..] : w));
    }

