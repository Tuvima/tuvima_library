@namespace MediaEngine.Web.Components.Settings
@inject IEngineApiClient ApiClient
@inject MediaEngine.Web.Services.Integration.ProviderCatalogueService CatalogueService
@using MediaEngine.Domain.Enums
@using MediaEngine.Storage.Models
@using MediaEngine.Web.Models.ViewDTOs
<style>
    .provider-page { width: 100%; padding: 24px; box-sizing: border-box; }


    .category-strip {
        display: flex; gap: 0; overflow-x: auto; -webkit-overflow-scrolling: touch;
        margin-bottom: 32px; border-bottom: 1px solid var(--app-glass-inner-border, var(--tl-border-subtle));
    }
    .category-item {
        display: flex; flex-direction: column; align-items: center; gap: 4px;
        padding: 12px 20px 10px; cursor: pointer; border: none; background: none;
        color: var(--mud-palette-text-secondary); transition: color 0.15s;
        border-bottom: 2px solid transparent; flex-shrink: 0; min-width: 64px;
    }
    .category-item:hover { color: var(--mud-palette-text-primary); }
    .category-item.active {
        color: var(--mud-palette-primary);
        border-bottom-color: var(--mud-palette-primary);
    }
    .category-item .cat-icon { font-size: 1.5rem; line-height: 1; }
    .category-item .cat-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; white-space: nowrap; }


    .chain-container {
        display: flex; flex-wrap: wrap; align-items: center; gap: 16px; margin-bottom: 24px;
    }
    .chain-card {
        position: relative; background: var(--app-surface-2, #272832);
        border: 1px solid var(--app-border, #293036);
        border-radius: var(--app-radius-lg, 8px); padding: 14px 16px 10px; cursor: pointer;
        transition: border-color 0.15s, box-shadow 0.15s;
        display: flex; flex-direction: column; align-items: flex-start;
        flex: 1 1 200px; min-width: 180px; max-width: 320px;
    }
    .chain-card:hover {
        border-color: var(--mud-palette-primary);
        box-shadow: 0 0 20px rgba(201, 146, 46, 0.08);
    }
    .chain-connector {
        width: 28px; height: 1px; flex-shrink: 0;
        background: linear-gradient(to right, rgba(255,255,255,0.18), rgba(255,255,255,0.05));
    }
    .chain-add-btn {
        min-width: 100px; height: 40px; flex-shrink: 0;
    }


    @@media (max-width: 600px) {
        .provider-page { padding: 12px; }
        .category-item { padding: 10px 12px 8px; min-width: 48px; }
        .category-item .cat-label { font-size: 0.62rem; }
        .chain-container { flex-direction: column; align-items: stretch; gap: 8px; }
        .chain-card { max-width: none; flex: 1 1 auto; }
        .chain-connector { width: 1px; height: 20px; align-self: center;
            background: linear-gradient(to bottom, rgba(255,255,255,0.18), rgba(255,255,255,0.05)); }
        .drawer-panel { width: 100% !important; top: 48px !important; }
    }


    @@media (min-width: 601px) and (max-width: 960px) {
        .chain-card { max-width: none; flex: 1 1 calc(50% - 24px); }
    }


    .provider-chip {
        display: inline-block; font-size: 0.66rem; padding: 1px 6px;
        border-radius: var(--app-radius-lg, 8px); border: 1px solid var(--app-border, #293036);
        color: var(--mud-palette-text-secondary); line-height: 1.6;
    }


    .drawer-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 1200; }
    .drawer-panel {
        position: fixed; top: 64px; right: 0; bottom: 0; width: 380px;
        background: var(--app-surface, #1e1f27);
        border-left: 1px solid var(--app-border, #293036);
        z-index: 1201; padding: 0; overflow-y: auto;
        display: flex; flex-direction: column;
    }
    .drawer-header {
        padding: 24px 24px 16px; border-bottom: 1px solid var(--app-glass-inner-border, var(--tl-border-subtle));
    }
    .drawer-icon-circle {
        width: 44px; height: 44px; border-radius: var(--app-radius-lg, 8px);
        background: var(--mud-palette-primary); display: flex;
        align-items: center; justify-content: center; flex-shrink: 0;
    }
    .drawer-stats-row {
        display: flex; gap: 16px; margin-top: 14px; padding: 10px 12px;
        background: var(--app-glass-inner-bg, rgba(255,255,255,0.03));
        border: 1px solid var(--app-glass-inner-border, var(--tl-border-subtle));
        border-radius: 8px;
    }
    .drawer-stat {
        display: flex; align-items: center; gap: 6px;
        font-size: 0.78rem; color: var(--mud-palette-text-secondary);
    }
    .drawer-section {
        padding: 20px 24px 0;
    }
    .drawer-section-label {
        display: block; font-size: 0.68rem; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--mud-palette-text-secondary); margin-bottom: 14px;
    }
    .drawer-field-row {
        display: flex; align-items: center; margin-bottom: 4px;
    }


    .save-bar {
        display: flex; justify-content: flex-end; gap: 12px; align-items: center;
        padding-top: 16px; margin-top: 24px;
        border-top: 1px solid var(--app-glass-inner-border, var(--tl-border-subtle));
    }
</style>

<div class="provider-page">
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Outlined.Collections" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">Providers</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-5">
        Build a priority chain for each media type. Choose a strategy to control
        how providers interact - waterfall stops at the first match, cascade
        merges results from all, sequential chains providers together.
    </MudText>
<div class="category-strip">
        @foreach (var mt in _mediaTypes)
        {
            var mediaType = mt;
            <button class="category-item @(mediaType == _activeTab ? "active" : "")"
                    @onclick="@(() => _activeTab = mediaType)">
                <MudIcon Icon="@GetMediaTypeIcon(mediaType)" Class="cat-icon" />
                <span class="cat-label">@mediaType</span>
            </button>
        }
    </div>
@{
        var chain = GetChain(_activeTab);
    }
<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); white-space: nowrap;">
            Strategy:
        </MudText>
        <MudSelect T="string"
                   Value="@GetStrategy(_activeTab)"
                   ValueChanged="@(v => SetStrategy(_activeTab, v))"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Dense="true"
                   Style="max-width: 220px;">
            <MudSelectItem T="string" Value="@("Waterfall")">
                Waterfall - first match wins
            </MudSelectItem>
            <MudSelectItem T="string" Value="@("Cascade")">
                Cascade - all run, merge results
            </MudSelectItem>
            <MudSelectItem T="string" Value="@("Sequential")">
                Sequential - chained, each feeds next
            </MudSelectItem>
        </MudSelect>
    </div>

    <div class="chain-container">
        @for (int i = 0; i < chain.Count; i++)
        {
            var idx        = i;
            var assignment = chain[idx];
            var info       = GetProviderInfo(assignment.Name);
            var strategy = GetStrategy(_activeTab);
            var posLabel = strategy == "Sequential"
                ? $"Step {idx + 1}"
                : idx == 0 ? "Primary" : idx == 1 ? "Secondary" : $"Rank {idx + 1}";
            var enabledDot = assignment.Enabled ? "var(--tl-status-success)" : "var(--tl-status-danger)";
<div class="chain-card"
                 @onclick="@(() => OpenDrawer(_activeTab, idx))"
                 role="button"
                 tabindex="0">
<div style="position: absolute; top: 10px; right: 10px;
                            width: 9px; height: 9px; border-radius: 50%;
                            background: @enabledDot;" />

                @* Provider icon *@
                <MudIcon Icon="@GetProviderIcon(assignment.Name)"
                         Size="Size.Medium"
                         Style="color: var(--mud-palette-primary); margin-bottom: 6px;" />

                @* Name + position *@
                <MudText Typo="Typo.body2"
                         Style="font-weight: 700; line-height: 1.2; margin-bottom: 2px;">
                    @assignment.Name
                </MudText>
                <MudText Typo="Typo.caption"
                         Style="color: var(--mud-palette-text-secondary); margin-bottom: 6px; display: block;">
                    @posLabel
                </MudText>

                @* Media type chips *@
                <div style="display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px;">
                    @foreach (var mt in GetProviderMediaTypes(assignment.Name))
                    {
                        <span class="provider-chip">@mt</span>
                    }
                </div>
<MudText Typo="Typo.caption"
                         Style="color: var(--mud-palette-text-secondary); display: block; line-height: 1.6;">
                    @GetLatencyDisplay(assignment.Name)  -  @GetSuccessRateDisplay(assignment.Name)
                </MudText>

                @* Reorder buttons *@
                <div style="display: flex; justify-content: center; gap: 2px; margin-top: 8px; width: 100%;"
                     @onclick:stopPropagation="true">
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                   Size="Size.Small"
                                   Disabled="@(idx == 0)"
                                   OnClick="@(() => MoveLeft(_activeTab, idx))"
                                   Style="padding: 2px;" />
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                   Size="Size.Small"
                                   Disabled="@(idx == chain.Count - 1)"
                                   OnClick="@(() => MoveRight(_activeTab, idx))"
                                   Style="padding: 2px;" />
                </div>

            </div>
@if (idx < chain.Count - 1)
            {
                <div class="chain-connector" />
            }
        }
@if (chain.Count > 0)
        {
            <div class="chain-connector" />
        }

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Add"
                   Size="Size.Small"
                   Class="chain-add-btn"
                   Style="border-radius: 8px;
                          border: 1px dashed var(--app-glass-inner-border);
                          color: var(--mud-palette-text-secondary);"
                   OnClick="@(() => OpenAddDialog(_activeTab))">
            Add
        </MudButton>

    </div>
@if (chain.Count == 0)
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4"
                 Style="display: block;">
            No providers assigned. Click Add to build a priority chain.
        </MudText>
    }
<div class="save-bar">
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Outlined.RestartAlt"
                   OnClick="@ResetToDefaults">
            Reset to Defaults
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="@SaveAsync"
                   Disabled="@_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                @:Saving...
            }
            else
            {
                @:Save
            }
        </MudButton>
    </div>

</div>
@if (_drawerOpen)
{
    @* Backdrop *@
    <div class="drawer-backdrop" @onclick="CloseDrawer" />

    @* Panel *@
    <div class="drawer-panel">

        @{
            var drawerInfo = GetProviderInfo(_drawerAssignment?.Name ?? "");
            var positionLabel = _drawerIndex == 0 ? "Primary" : _drawerIndex == 1 ? "Secondary" : "Fallback";
        }
<div class="drawer-header">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 4px;">
                <div class="drawer-icon-circle">
                    <MudIcon Icon="@GetProviderIcon(_drawerAssignment?.Name ?? "")"
                             Size="Size.Medium" Style="color: white;" />
                </div>
                <div style="flex: 1; min-width: 0;">
                    <MudText Typo="Typo.h6" Style="font-weight: 700; line-height: 1.2; margin: 0;">
                        @(_drawerAssignment?.Name ?? "")
                    </MudText>
                    <MudText Typo="Typo.caption"
                             Style="color: var(--mud-palette-text-secondary); display: block; margin-top: 2px;">
                        @(drawerInfo?.Type ?? "") provider  -  @positionLabel
                    </MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               OnClick="CloseDrawer"
                               Style="align-self: flex-start;" />
            </div>
@if (drawerInfo is not null)
            {
                var healthColor = IsProviderHealthy(_drawerAssignment?.Name ?? "") ? "var(--tl-status-success)" : "var(--tl-status-danger)";
                <div class="drawer-stats-row">
                    <div class="drawer-stat">
                        <MudIcon Icon="@Icons.Material.Outlined.Speed" Size="Size.Small"
                                 Style="color: var(--mud-palette-text-secondary);" />
                        <span>@GetLatencyDisplay(_drawerAssignment?.Name ?? "")</span>
                    </div>
                    <div class="drawer-stat">
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircleOutline" Size="Size.Small"
                                 Style="@($"color: {healthColor};")" />
                        <span>@GetSuccessRateDisplay(_drawerAssignment?.Name ?? "")</span>
                    </div>
                    <div class="drawer-stat">
                        <MudIcon Icon="@Icons.Material.Outlined.VpnKey" Size="Size.Small"
                                 Style="color: var(--mud-palette-text-secondary);" />
                        <span>@(drawerInfo.RequiresKey ? "Key required" : "No key")</span>
                    </div>
                </div>
            }
        </div>

        @if (_drawerAssignment is not null)
        {
<div class="drawer-section">
                <span class="drawer-section-label">STATUS</span>
                <div class="drawer-field-row">
                    <MudText Typo="Typo.body2" Style="flex: 1;">Enabled</MudText>
                    <MudSwitch T="bool"
                               Value="@_drawerAssignment.Enabled"
                               ValueChanged="@(v => _drawerAssignment.Enabled = v)"
                               Color="Color.Success" />
                </div>
                <div class="drawer-field-row" style="gap: 8px;">
                    <MudIcon Icon="@Icons.Material.Outlined.FiberManualRecord"
                             Size="Size.Small"
                             Style="@($"color: {(_drawerAssignment.Enabled ? "var(--tl-status-success)" : "var(--tl-status-danger)")}; flex-shrink: 0;")" />
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                        @(_drawerAssignment.Enabled ? "Provider is active and will be queried" : "Provider is disabled and will be skipped")
                    </MudText>
                </div>
            </div>
<div class="drawer-section">
                <span class="drawer-section-label">CONNECTION</span>

                @if (drawerInfo?.RequiresKey == true)
                {
                    @if (drawerInfo?.AuthType == "basic")
                    {
                        <MudTextField T="string"
                                      @bind-Value="_drawerAssignment.Username"
                                      Label="Username"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Outlined.Person"
                                      AdornmentColor="Color.Default"
                                      Style="margin-bottom: 12px;" />
                        <MudTextField T="string"
                                      @bind-Value="_drawerAssignment.Password"
                                      Label="Password"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Outlined.Lock"
                                      AdornmentColor="Color.Default"
                                      Style="margin-bottom: 16px;" />
                    }
                    else
                    {
                        <MudTextField T="string"
                                      @bind-Value="_drawerAssignment.ApiKey"
                                      Label="API Key"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Outlined.VpnKey"
                                      AdornmentColor="Color.Default"
                                      Style="margin-bottom: 16px;" />
                    }
                }

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Info"
                           StartIcon="@Icons.Material.Outlined.NetworkCheck"
                           FullWidth="true"
                           Size="Size.Small"
                           OnClick="@TestConnectionAsync"
                           Style="border-radius: 8px;">
                    Test Connection
                </MudButton>
                <MudText Typo="Typo.caption"
                         Style="color: var(--mud-palette-text-secondary); display: block; margin-top: 8px;">
                    Last tested: -
                </MudText>
            </div>
<div class="drawer-section">
                <span class="drawer-section-label">BEHAVIOUR</span>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <MudNumericField T="int"
                                     @bind-Value="_drawerAssignment.TimeoutMs"
                                     Label="Timeout (ms)"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     FullWidth="true"
                                     Min="500"
                                     Max="60000" />
                    <MudNumericField T="int"
                                     @bind-Value="_drawerAssignment.Retries"
                                     Label="Retries"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     FullWidth="true"
                                     Min="0"
                                     Max="5" />
                </div>
                <MudSelect T="string"
                           @bind-Value="_drawerAssignment.LanguageStrategy"
                           Label="Language Strategy"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           FullWidth="true"
                           Class="mt-3">
                    <MudSelectItem T="string" Value="@("source")">Source (always English)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("localized")">Localized (your language)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("both")">Both (try both, merge)</MudSelectItem>
                </MudSelect>
                <MudText Typo="Typo.caption"
                         Style="color: var(--mud-palette-text-secondary); display: block; margin-top: 8px;">
                    Failed requests will retry up to @(_drawerAssignment.Retries) time@(_drawerAssignment.Retries == 1 ? "" : "s")
                    before moving to the next provider. Language strategy controls whether queries use
                    your metadata language, English, or both.
                </MudText>
            </div>
<div class="drawer-section">
                <span class="drawer-section-label">SUPPORTED MEDIA</span>
                <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                    @foreach (var mt in GetProviderMediaTypes(_drawerAssignment.Name))
                    {
                        <span class="provider-chip" style="font-size: 0.72rem; padding: 3px 10px;">@mt</span>
                    }
                </div>
            </div>
<div style="padding: 20px 24px 0;">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           FullWidth="true"
                           Size="Size.Small"
                           OnClick="SaveDrawerAsync"
                           Disabled="@_drawerSaving"
                           Style="border-radius: 8px; margin-bottom: 12px;">
                    @if (_drawerSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                        @:Saving...
                    }
                    else
                    {
                        @:Save Provider Settings
                    }
                </MudButton>
                @if (!string.IsNullOrEmpty(_drawerSaveMessage))
                {
                    <MudText Typo="Typo.caption"
                             Style="@($"color: {(_drawerSaveSuccess ? "var(--tl-status-success)" : "var(--tl-status-danger)")}; display: block; margin-bottom: 8px;")">
                        @_drawerSaveMessage
                    </MudText>
                }
            </div>
<div style="margin-top: auto; padding-top: 20px; border-top: 1px solid rgba(244,67,54,0.2);">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Outlined.RemoveCircleOutline"
                           FullWidth="true"
                           Size="Size.Small"
                           OnClick="RemoveFromChain"
                           Style="border-radius: 8px;">
                    Remove from Priority Chain
                </MudButton>
            </div>
        }

    </div>
}
<MudDialog @bind-Visible="_addDialogOpen"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Add Provider - @_addDialogMediaType</MudText>
    </TitleContent>
    <DialogContent>

        <MudTextField T="string"
                      @bind-Value="_addDialogSearch"
                      Placeholder="Search providers..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Class="mb-3" />

        @{
            var available = GetAvailableProviders(_addDialogMediaType);
            var filtered  = string.IsNullOrWhiteSpace(_addDialogSearch)
                ? available
                : available.Where(p => p.Name.Contains(_addDialogSearch, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        @if (!filtered.Any())
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                No providers available for this media type.
            </MudText>
        }
        else
        {
            @foreach (var p in filtered)
            {
                var pCapture = p;
                <div style="display: flex; align-items: center; gap: 12px;
                            padding: 10px 8px; border-radius: 8px; cursor: pointer;
                            transition: background 0.12s; margin-bottom: 4px;"
                     @onclick="@(() => AddProviderToChain(pCapture.Name))"
                     role="button"
                     tabindex="0">

                    <MudIcon Icon="@GetProviderIcon(pCapture.Name)"
                             Size="Size.Small"
                             Style="color: var(--mud-palette-primary); flex-shrink: 0;" />

                    <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                        <MudText Typo="Typo.body2" Style="font-weight: 600; line-height: 1.2;">
                            @pCapture.Name
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @pCapture.Type  -  @(pCapture.RequiresKey ? "Requires key" : "Zero-key")
                        </MudText>
                    </MudStack>

                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex-shrink: 0;">
                        @((pCapture.SuccessRate * 100).ToString("F0"))%
                    </MudText>

                </div>
            }
        }

    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _addDialogOpen = false)">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {

    private sealed record ProviderInfo(
        string   Name,
        string   Type,
        bool     RequiresKey,
        string[] Supports,
        int      LatencyMs,
        double   SuccessRate,
        string   AuthType = "api_key");

    private static readonly ProviderInfo[] AllProviderCatalogue =
    [
        new("Apple API",      "Retail", false, ["Books", "Audiobooks"],                          120, 0.94),
        new("Open Library",   "Open",   false, ["Books"],                                        240, 0.87),
        new("TMDB",           "Retail", true,  ["Movies", "TV"],                                 110, 0.96),
        new("MusicBrainz",    "Open",   false, ["Music"],                                        210, 0.89),
        new("Metron",          "Open",   true,  ["Comics"],                                       200, 0.88, "basic"),
        new("Wikidata",       "Open",   false, ["Books","Movies","TV","Music","Comics","Audiobooks"], 300, 0.85),
        new("Fanart.tv",      "Image",  true,  ["Movies","TV","Music"],                           180, 0.91),
    ];

    private sealed class ProviderAssignment
    {
        public string Name             { get; set; } = "";
        public int    TimeoutMs        { get; set; } = 3000;
        public string ApiKey           { get; set; } = "";
        public string Username         { get; set; } = "";
        public string Password         { get; set; } = "";
        public bool   Enabled          { get; set; } = true;
        public int    Retries          { get; set; } = 1;
        public string LanguageStrategy { get; set; } = "source";
    }

    private static readonly Dictionary<string, string> DefaultStrategies = new()
    {
        ["Books"]      = "Cascade",
        ["Audiobooks"] = "Sequential",
        ["Movies"]     = "Waterfall",
        ["TV"]         = "Waterfall",
        ["Music"]      = "Sequential",
        ["Comics"]     = "Waterfall",
    };

    private static readonly Dictionary<string, List<ProviderAssignment>> DefaultAssignments = new()
    {
        ["Books"]      = [new() { Name = "Apple API", LanguageStrategy = "localized" }],
        ["Audiobooks"] = [new() { Name = "Apple API", LanguageStrategy = "localized" }],
        ["Movies"]     = [new() { Name = "TMDB", LanguageStrategy = "localized" }],
        ["TV"]         = [new() { Name = "TMDB", LanguageStrategy = "localized" }],
        ["Music"]      = [new() { Name = "MusicBrainz", LanguageStrategy = "source" }],
        ["Comics"]     = [new() { Name = "Metron", LanguageStrategy = "source" }],
    };

    private static readonly Dictionary<string, string[]> ProviderMediaTypes = new()
    {
        ["Apple API"]      = ["Books", "Audiobooks"],
        ["Open Library"]   = ["Books"],
        ["TMDB"]           = ["Movies", "TV"],
        ["MusicBrainz"]    = ["Music"],
        ["Metron"]         = ["Comics"],
        ["Wikidata"]       = ["All"],
        ["Fanart.tv"]      = ["Movies", "TV", "Music"],
    };

    private readonly string[] _mediaTypes =
        ["Books", "Audiobooks", "Movies", "TV", "Music", "Comics"];

    private string _activeTab = "Books";
    private Dictionary<string, List<ProviderAssignment>> _assignments = new();
    private Dictionary<string, string> _strategies = new();
    private PipelineConfiguration _pipelineConfiguration = new();
    private bool               _drawerOpen        = false;
    private string             _drawerMediaType   = "";
    private int                _drawerIndex       = -1;
    private ProviderAssignment? _drawerAssignment  = null;
    private bool   _addDialogOpen      = false;
    private string _addDialogMediaType = "";
    private string _addDialogSearch    = "";

    private bool _saving = false;
    private bool   _drawerSaving       = false;
    private string _drawerSaveMessage  = "";
    private bool   _drawerSaveSuccess  = false;

    private Dictionary<string, ProviderHealthDto> _healthData = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<ProviderCatalogueDto> _liveCatalogue = [];
    private Dictionary<string, ProviderStatusDto> _providerStatusByKey = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _liveCatalogue = await CatalogueService.GetCatalogueAsync();
        await LoadFromEngineAsync();
        await LoadHealthDataAsync();
    }

    private async Task LoadFromEngineAsync()
    {
        try
        {
            _providerStatusByKey = BuildProviderStatusLookup(await ApiClient.GetProviderStatusAsync());
            var pipelines = await ApiClient.GetPipelinesAsync();
            if (pipelines?.Pipelines is { Count: > 0 })
            {
                ApplyPipelineConfiguration(pipelines);
                return;
            }
        }
        catch {  }

        ResetToDefaults();
    }

    private void ApplyPipelineConfiguration(PipelineConfiguration pipelines)
    {
        _pipelineConfiguration = pipelines;
        _assignments = new Dictionary<string, List<ProviderAssignment>>(StringComparer.OrdinalIgnoreCase);
        _strategies = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var mediaType in _mediaTypes)
        {
            var pipeline = pipelines.GetPipelineForMediaType(mediaType);
            _assignments[mediaType] = pipeline.Providers
                .OrderBy(provider => provider.Rank)
                .Select(provider => CreateAssignmentFromProviderKey(provider.Name))
                .ToList();
            _strategies[mediaType] = FormatProviderStrategy(pipeline.Strategy);
        }
    }

    private ProviderAssignment CreateAssignmentFromProviderKey(string providerSlotName)
    {
        var displayName = ResolveDisplayName(providerSlotName);
        var info = AllProviderCatalogue.FirstOrDefault(p =>
            p.Name.Replace(" ", "_").Equals(providerSlotName, StringComparison.OrdinalIgnoreCase));
        _providerStatusByKey.TryGetValue(providerSlotName, out var status);
        status ??= _providerStatusByKey.GetValueOrDefault(displayName);
        var resolvedName = status?.DisplayName ?? info?.Name ?? displayName;

        return new ProviderAssignment
        {
            Name             = resolvedName,
            Enabled          = status?.Enabled ?? true,
            TimeoutMs        = (status?.TimeoutSeconds ?? 3) * 1000,
            LanguageStrategy = NormalizeLanguageStrategy(status?.LanguageStrategy)
                               ?? GetDefaultLanguageStrategy(resolvedName),
        };
    }

    private static Dictionary<string, ProviderStatusDto> BuildProviderStatusLookup(
        IReadOnlyList<ProviderStatusDto> statuses)
    {
        var lookup = new Dictionary<string, ProviderStatusDto>(StringComparer.OrdinalIgnoreCase);
        foreach (var status in statuses)
        {
            AddProviderStatusLookup(lookup, status.Name, status);
            AddProviderStatusLookup(lookup, status.DisplayName, status);
            AddProviderStatusLookup(lookup, status.Name.Replace("_", " "), status);
            AddProviderStatusLookup(lookup, status.DisplayName.Replace(" ", "_"), status);
        }

        return lookup;
    }

    private static void AddProviderStatusLookup(
        IDictionary<string, ProviderStatusDto> lookup,
        string? key,
        ProviderStatusDto status)
    {
        if (!string.IsNullOrWhiteSpace(key))
            lookup[key] = status;
    }

    private static string? NormalizeLanguageStrategy(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var candidate = value.Trim().ToLowerInvariant();
        return candidate is "source" or "localized" or "both" ? candidate : null;
    }

    private string GetDefaultLanguageStrategy(string providerName)
    {
        if (_providerStatusByKey.TryGetValue(providerName, out var status))
            return NormalizeLanguageStrategy(status.LanguageStrategy) ?? "source";

        return DefaultAssignments
            .SelectMany(kv => kv.Value)
            .FirstOrDefault(a => string.Equals(a.Name, providerName, StringComparison.OrdinalIgnoreCase))
            ?.LanguageStrategy
            ?? "source";
    }

    private ProviderAssignment CreateAssignmentFromProviderName(string providerName)
    {
        _providerStatusByKey.TryGetValue(providerName, out var status);
        status ??= _providerStatusByKey.GetValueOrDefault(providerName.Replace(" ", "_"));

        return new ProviderAssignment
        {
            Name             = status?.DisplayName ?? providerName,
            Enabled          = status?.Enabled ?? true,
            TimeoutMs        = (status?.TimeoutSeconds ?? 3) * 1000,
            LanguageStrategy = NormalizeLanguageStrategy(status?.LanguageStrategy)
                               ?? GetDefaultLanguageStrategy(providerName),
        };
    }

    private static string ResolveDisplayName(string slotName)
    {
        var match = AllProviderCatalogue.FirstOrDefault(p =>
            p.Name.Replace(" ", "_").Equals(slotName, StringComparison.OrdinalIgnoreCase));
        if (match is not null) return match.Name;
        return string.Join(' ', slotName.Split('_')
            .Select(w => w.Length > 0 ? char.ToUpperInvariant(w[0]) + w[1..] : w));
    }

    private async Task LoadHealthDataAsync()
    {
        try
        {
            var healthList = await ApiClient.GetProviderHealthAsync();
            foreach (var h in healthList)
            {
                _healthData[h.ProviderId] = h;
            }
        }
        catch {  }
    }

    private List<ProviderAssignment> GetChain(string mediaType)
    {
        if (!_assignments.TryGetValue(mediaType, out var list))
        {
            list = [];
            _assignments[mediaType] = list;
        }
        return list;
    }

    private void MoveLeft(string mediaType, int idx)
    {
        if (idx <= 0) return;
        var chain = GetChain(mediaType);
        (chain[idx - 1], chain[idx]) = (chain[idx], chain[idx - 1]);
    }

    private void MoveRight(string mediaType, int idx)
    {
        var chain = GetChain(mediaType);
        if (idx >= chain.Count - 1) return;
        (chain[idx], chain[idx + 1]) = (chain[idx + 1], chain[idx]);
    }

    private void OpenDrawer(string mediaType, int idx)
    {
        _drawerMediaType   = mediaType;
        _drawerIndex       = idx;
        _drawerAssignment  = GetChain(mediaType)[idx];
        _drawerOpen        = true;
        _drawerSaveMessage = "";
    }

    private void CloseDrawer()
    {
        _drawerOpen       = false;
        _drawerAssignment = null;
    }

    private void RemoveFromChain()
    {
        if (_drawerIndex >= 0)
            GetChain(_drawerMediaType).RemoveAt(_drawerIndex);
        CloseDrawer();
    }

    private async Task TestConnectionAsync()
    {
        if (_drawerAssignment is null) return;
        await SaveDrawerAsync();

        var providerName = _drawerAssignment.Name.Replace(" ", "_").ToLowerInvariant();
        try
        {
            var result = await ApiClient.TestProviderAsync(providerName);
            if (result is not null)
            {
                _drawerSaveSuccess = result.Success;
                _drawerSaveMessage = result.Success
                    ? $"Connected in {result.ResponseTimeMs}ms - {result.SampleFields?.Count ?? 0} fields returned"
                    : $"Test failed: {result.Message}";
            }
            else
            {
                _drawerSaveSuccess = false;
                _drawerSaveMessage = "No response from Engine";
            }
        }
        catch (Exception ex)
        {
            _drawerSaveSuccess = false;
            _drawerSaveMessage = $"Error: {ex.Message}";
        }
    }

    private async Task SaveDrawerAsync()
    {
        if (_drawerAssignment is null) return;
        _drawerSaving      = true;
        _drawerSaveMessage = "";
        try
        {
            var providerName = _drawerAssignment.Name.Replace(" ", "_").ToLowerInvariant();
            var info = GetProviderInfo(_drawerAssignment.Name);
            string? apiKeyValue = null;
            if (info?.RequiresKey == true)
            {
                if (info.AuthType == "basic")
                {
                    apiKeyValue = $"{_drawerAssignment.Username}:{_drawerAssignment.Password}";
                }
                else
                {
                    apiKeyValue = _drawerAssignment.ApiKey;
                }
            }

            var config = new MediaEngine.Web.Models.ViewDTOs.ProviderConfigUpdateDto
            {
                Enabled         = _drawerAssignment.Enabled,
                TimeoutSeconds  = _drawerAssignment.TimeoutMs / 1000,
                ApiKey          = apiKeyValue,
                LanguageStrategy = _drawerAssignment.LanguageStrategy,
            };

            var success = await ApiClient.SaveProviderConfigAsync(providerName, config);
            _drawerSaveSuccess = success;
            _drawerSaveMessage = success ? "Saved successfully" : "Failed to save - check Engine connection";
        }
        catch (Exception ex)
        {
            _drawerSaveSuccess = false;
            _drawerSaveMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _drawerSaving = false;
        }
    }

    private void OpenAddDialog(string mediaType)
    {
        _addDialogMediaType = mediaType;
        _addDialogSearch    = "";
        _addDialogOpen      = true;
    }

    private List<ProviderInfo> GetAvailableProviders(string mediaType)
    {
        var chain   = GetChain(mediaType);
        var inChain = chain.Select(a => a.Name).ToHashSet();
        if (_liveCatalogue.Count > 0)
        {
            return _liveCatalogue
                .Where(p => p.Name != "local_filesystem")  // internal only
                .Where(p => !inChain.Contains(p.DisplayName) &&
                            (p.MediaTypes.Contains(mediaType, StringComparer.OrdinalIgnoreCase) ||
                             p.Name is "wikidata_reconciliation" or "wikidata"))
                .Select(p => new ProviderInfo(
                    Name:        p.DisplayName,
                    Type:        p.Category,
                    RequiresKey: p.RequiresKey,
                    Supports:    [.. p.MediaTypes],
                    LatencyMs:   120,
                    SuccessRate: 0.90,
                    AuthType:    p.AuthType))
                .ToList();
        }
        return AllProviderCatalogue
            .Where(p => !inChain.Contains(p.Name) &&
                        (p.Supports.Contains(mediaType) || p.Name == "Wikidata"))
            .ToList();
    }

    private void AddProviderToChain(string name)
    {
        GetChain(_addDialogMediaType).Add(CreateAssignmentFromProviderName(name));
        _addDialogOpen = false;
    }

    private void ResetToDefaults()
    {
        _assignments = DefaultAssignments.ToDictionary(
            kv => kv.Key,
            kv => kv.Value.Select(a => new ProviderAssignment
            {
                Name             = a.Name,
                TimeoutMs        = a.TimeoutMs,
                ApiKey           = a.ApiKey,
                Enabled          = a.Enabled,
                Retries          = a.Retries,
                LanguageStrategy = a.LanguageStrategy,
            }).ToList());
        _strategies = new Dictionary<string, string>(DefaultStrategies, StringComparer.OrdinalIgnoreCase);
    }

    private string GetStrategy(string mediaType)
    {
        if (_strategies.TryGetValue(mediaType, out var s)) return s;
        return DefaultStrategies.GetValueOrDefault(mediaType, "Waterfall");
    }

    private void SetStrategy(string mediaType, string strategy)
    {
        _strategies[mediaType] = strategy;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            var savedProviders = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            foreach (var (_, chain) in _assignments)
            {
                foreach (var assignment in chain)
                {
                    if (!savedProviders.Add(assignment.Name)) continue;
                    var providerName = ResolveProviderConfigName(assignment.Name);
                    var info = GetProviderInfo(assignment.Name);
                    string? apiKeyValue = null;
                    if (info?.RequiresKey == true)
                    {
                        apiKeyValue = info.AuthType == "basic"
                            ? $"{assignment.Username}:{assignment.Password}"
                            : assignment.ApiKey;
                    }

                    var config = new MediaEngine.Web.Models.ViewDTOs.ProviderConfigUpdateDto
                    {
                        Enabled        = assignment.Enabled,
                        TimeoutSeconds = assignment.TimeoutMs / 1000,
                        ApiKey         = apiKeyValue,
                        LanguageStrategy = assignment.LanguageStrategy,
                    };
                    await ApiClient.SaveProviderConfigAsync(providerName, config);
                }
            }

            var pipelines = BuildPipelineConfigurationForSave();
            await ApiClient.SavePipelinesAsync(pipelines);
            _pipelineConfiguration = pipelines;
        }
        catch
        {
        }
        finally
        {
            _saving = false;
        }
    }

    private PipelineConfiguration BuildPipelineConfigurationForSave()
    {
        _pipelineConfiguration.Pipelines ??= new Dictionary<string, MediaTypePipeline>(StringComparer.OrdinalIgnoreCase);

        foreach (var mediaType in _mediaTypes)
        {
            if (!_pipelineConfiguration.Pipelines.TryGetValue(mediaType, out var pipeline))
            {
                pipeline = new MediaTypePipeline();
                _pipelineConfiguration.Pipelines[mediaType] = pipeline;
            }

            pipeline.Strategy = ParseProviderStrategy(GetStrategy(mediaType));
            pipeline.Providers = GetChain(mediaType)
                .Select((assignment, index) => new PipelineProviderEntry
                {
                    Rank = index + 1,
                    Name = ResolveProviderConfigName(assignment.Name),
                })
                .ToList();
        }

        return _pipelineConfiguration;
    }

    private static string FormatProviderStrategy(ProviderStrategy strategy) => strategy switch
    {
        ProviderStrategy.Cascade => "Cascade",
        ProviderStrategy.Sequential => "Sequential",
        _ => "Waterfall",
    };

    private static ProviderStrategy ParseProviderStrategy(string strategy) =>
        strategy.Trim().ToLowerInvariant() switch
        {
            "cascade" => ProviderStrategy.Cascade,
            "sequential" => ProviderStrategy.Sequential,
            _ => ProviderStrategy.Waterfall,
        };

    private string ResolveProviderConfigName(string providerName)
    {
        var live = _liveCatalogue.FirstOrDefault(p =>
            string.Equals(p.DisplayName, providerName, StringComparison.OrdinalIgnoreCase)
            || string.Equals(p.Name, providerName, StringComparison.OrdinalIgnoreCase));
        if (live is not null)
            return live.Name;

        return providerName.Replace(" ", "_").ToLowerInvariant();
    }

    private static string GetMediaTypeIcon(string mediaType) => mediaType switch
    {
        "Books"      => Icons.Material.Outlined.MenuBook,
        "Audiobooks" => Icons.Material.Outlined.Headphones,
        "Movies"     => Icons.Material.Outlined.Movie,
        "TV"         => Icons.Material.Outlined.Tv,
        "Music"      => Icons.Material.Outlined.MusicNote,
        "Comics"     => Icons.Material.Outlined.AutoStories,
        _            => Icons.Material.Outlined.Category,
    };

    private string GetProviderIcon(string provider)
    {
        var catalogueEntry = _liveCatalogue.FirstOrDefault(p =>
            string.Equals(p.DisplayName, provider, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(p.Name.Replace("_", " "), provider, StringComparison.OrdinalIgnoreCase));
        if (catalogueEntry is not null)
        {
            var (_, icon) = MediaEngine.Web.Models.ProviderAccentMap.GetAccent(
                catalogueEntry.Name, catalogueEntry.MaterialIcon);
            return icon;
        }
        return provider switch
        {
            "Apple API"                     => Icons.Material.Outlined.MenuBook,
            "Open Library"                  => Icons.Material.Outlined.LocalLibrary,
            "TMDB"                          => Icons.Material.Outlined.Movie,
            "MusicBrainz"                   => Icons.Material.Outlined.MusicNote,
            "Metron"                        => Icons.Material.Outlined.AutoStories,
            "Wikidata"                      => Icons.Material.Outlined.Collections,
            "Fanart.tv"                     => Icons.Material.Outlined.Image,
            _                               => Icons.Material.Outlined.Storage,
        };
    }

    private ProviderInfo? GetProviderInfo(string name)
    {
        var live = _liveCatalogue.FirstOrDefault(p =>
            string.Equals(p.DisplayName, name, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(p.Name.Replace("_", " "), name, StringComparison.OrdinalIgnoreCase));
        if (live is not null)
        {
            return new ProviderInfo(
                Name:        live.DisplayName,
                Type:        live.Category,
                RequiresKey: live.RequiresKey,
                Supports:    [.. live.MediaTypes],
                LatencyMs:   120,       // not in catalogue - health data used at runtime
                SuccessRate: 0.90,      // not in catalogue - health data used at runtime
                AuthType:    live.AuthType);
        }
        return AllProviderCatalogue.FirstOrDefault(p => p.Name == name);
    }
    private string GetLatencyDisplay(string providerName)
    {
        var key = providerName.Replace(" ", "_").ToLowerInvariant();
        if (_healthData.TryGetValue(key, out var h) && h.LastSuccessAt is not null)
            return h.Status;
        var info = GetProviderInfo(providerName);
        return info is not null ? $"{info.LatencyMs} ms" : "-";
    }
    private string GetSuccessRateDisplay(string providerName)
    {
        var key = providerName.Replace(" ", "_").ToLowerInvariant();
        if (_healthData.TryGetValue(key, out var h))
        {
            return h.Status switch
            {
                "Healthy"  => "Healthy",
                "Degraded" => $"Degraded ({h.ConsecutiveFailures} failures)",
                "Down"     => $"Down - {h.LastFailureReason ?? "unknown"}",
                _          => h.Status,
            };
        }
        var info = GetProviderInfo(providerName);
        return info is not null ? $"{(info.SuccessRate * 100):F0}%" : "-";
    }
    private bool IsProviderHealthy(string providerName)
    {
        var key = providerName.Replace(" ", "_").ToLowerInvariant();
        if (_healthData.TryGetValue(key, out var h))
            return !string.Equals(h.Status, "Down", StringComparison.OrdinalIgnoreCase);
        return true; // assume healthy if no health data
    }

    private string[] GetProviderMediaTypes(string provider)
    {
        var live = _liveCatalogue.FirstOrDefault(p =>
            string.Equals(p.DisplayName, provider, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(p.Name.Replace("_", " "), provider, StringComparison.OrdinalIgnoreCase));
        if (live is not null && live.MediaTypes.Count > 0)
            return [.. live.MediaTypes];
        return ProviderMediaTypes.TryGetValue(provider, out var types) ? types : ["All"];
    }
}
