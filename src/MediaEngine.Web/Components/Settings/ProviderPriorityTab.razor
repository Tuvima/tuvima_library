@namespace MediaEngine.Web.Components.Settings

@* Providers — priority chain design.
   Each media type tab shows assigned providers as horizontal connected cards.
   Clicking a card opens a slide-in config overlay from the right.
   "+ Add" opens a dialog to pick from the available provider catalogue.
   Reorder with chevron buttons; remove via the config overlay. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Hub" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">Providers</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-5">
        Build a priority chain for each media type. The Engine tries providers left to right,
        stopping when one returns a result.
    </MudText>

    @* ── Media type tabs ─────────────────────────────────────────────────── *@
    <MudTabs Elevation="0"
             Rounded="true"
             ApplyEffectsToContainer="true"
             Style="background: transparent;">

        @foreach (var mediaType in _mediaTypes)
        {
            <MudTabPanel Text="@mediaType" Icon="@GetMediaTypeIcon(mediaType)">

                <div class="pt-5">

                    @* ── Priority chain ──────────────────────────────────── *@
                    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 0; margin-bottom: 24px;">

                        @{
                            var chain = GetChain(mediaType);
                        }

                        @for (int i = 0; i < chain.Count; i++)
                        {
                            var idx        = i;
                            var assignment = chain[idx];
                            var info       = GetProviderInfo(assignment.Name);
                            var posLabel   = idx == 0 ? "Primary" : idx == 1 ? "Secondary" : "Fallback";
                            var enabledDot = assignment.Enabled ? "#4caf50" : "#f44336";

                            @* ── Provider card ── *@
                            <div style="@ProviderChainCardStyle"
                                 @onclick="@(() => OpenDrawer(mediaType, idx))"
                                 role="button"
                                 tabindex="0">

                                @* Status dot — top right *@
                                <div style="position: absolute; top: 10px; right: 10px;
                                            width: 9px; height: 9px; border-radius: 50%;
                                            background: @enabledDot; flex-shrink: 0;" />

                                @* Provider icon *@
                                <MudIcon Icon="@GetProviderIcon(assignment.Name)"
                                         Size="Size.Medium"
                                         Style="color: var(--mud-palette-primary); margin-bottom: 6px;" />

                                @* Name + position *@
                                <MudText Typo="Typo.body2"
                                         Style="font-weight: 700; line-height: 1.2; margin-bottom: 2px;">
                                    @assignment.Name
                                </MudText>
                                <MudText Typo="Typo.caption"
                                         Style="color: var(--mud-palette-text-secondary); margin-bottom: 6px; display: block;">
                                    @posLabel
                                </MudText>

                                @* Media type chips *@
                                <div style="display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px;">
                                    @foreach (var mt in GetProviderMediaTypes(assignment.Name))
                                    {
                                        <span style="@SmallChipStyle">@mt</span>
                                    }
                                </div>

                                @* Stats *@
                                @if (info is not null)
                                {
                                    <MudText Typo="Typo.caption"
                                             Style="color: var(--mud-palette-text-secondary); display: block; line-height: 1.6;">
                                        @info.LatencyMs ms · @((info.SuccessRate * 100).ToString("F0"))% success
                                    </MudText>
                                }

                                @* Reorder buttons *@
                                <div style="display: flex; justify-content: center; gap: 2px; margin-top: 8px;"
                                     @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                                   Size="Size.Small"
                                                   Disabled="@(idx == 0)"
                                                   OnClick="@(() => MoveLeft(mediaType, idx))"
                                                   Style="padding: 2px;" />
                                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                                   Size="Size.Small"
                                                   Disabled="@(idx == chain.Count - 1)"
                                                   OnClick="@(() => MoveRight(mediaType, idx))"
                                                   Style="padding: 2px;" />
                                </div>

                            </div>

                            @* ── Connector line between cards ── *@
                            @if (idx < chain.Count - 1)
                            {
                                <div style="@ConnectorLineStyle" />
                            }
                        }

                        @* ── + Add button ── *@
                        @if (chain.Count > 0)
                        {
                            <div style="@ConnectorLineStyle" />
                        }

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Style="min-width: 100px; height: 40px; border-radius: 8px;
                                          border: 1px dashed var(--app-glass-inner-border);
                                          color: var(--mud-palette-text-secondary);"
                                   OnClick="@(() => OpenAddDialog(mediaType))">
                            Add
                        </MudButton>

                    </div>

                    @* ── Empty state ── *@
                    @if (chain.Count == 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4"
                                 Style="display: block;">
                            No providers assigned. Click Add to build a priority chain.
                        </MudText>
                    }

                </div>

            </MudTabPanel>
        }

    </MudTabs>

    @* ── Save row ─────────────────────────────────────────────────────────── *@
    <MudDivider Class="mt-6 mb-4" />
    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Outlined.RestartAlt"
                   OnClick="@ResetToDefaults">
            Reset to Defaults
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="@SaveAsync"
                   Disabled="@_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                @:Saving…
            }
            else
            {
                @:Save
            }
        </MudButton>
    </MudStack>

</MudPaper>

@* ════════════════════════════════════════════════════════════════════════════
   Config Drawer — slide-in overlay from the right
   ════════════════════════════════════════════════════════════════════════════ *@

@if (_drawerOpen)
{
    @* Backdrop *@
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 1200;"
         @onclick="CloseDrawer" />

    @* Panel *@
    <div style="@DrawerPanelStyle">

        @* Header *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
            <MudIcon Icon="@GetProviderIcon(_drawerAssignment?.Name ?? "")"
                     Size="Size.Medium"
                     Style="color: var(--mud-palette-primary);" />
            <MudText Typo="Typo.h6" Style="flex: 1; font-weight: 700;">
                @(_drawerAssignment?.Name ?? "")
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           OnClick="CloseDrawer" />
        </MudStack>

        @{
            var drawerInfo = GetProviderInfo(_drawerAssignment?.Name ?? "");
        }
        @if (drawerInfo is not null && _drawerAssignment is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4" Style="display: block;">
                @drawerInfo.LatencyMs ms avg · @((drawerInfo.SuccessRate * 100).ToString("F0"))% success rate
            </MudText>

            <MudDivider Class="mb-4" />

            @* Enabled toggle *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudText Typo="Typo.body2">Enabled</MudText>
                <MudSwitch T="bool"
                           Value="@_drawerAssignment.Enabled"
                           ValueChanged="@(v => _drawerAssignment.Enabled = v)"
                           Color="Color.Success" />
            </MudStack>

            @* API Key (only if needed) *@
            @if (drawerInfo.RequiresKey)
            {
                <MudTextField T="string"
                              @bind-Value="_drawerAssignment.ApiKey"
                              Label="API Key"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              FullWidth="true"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Outlined.VpnKey"
                              AdornmentColor="Color.Default"
                              Class="mb-3" />
            }

            @* Timeout *@
            <MudNumericField T="int"
                             @bind-Value="_drawerAssignment.TimeoutMs"
                             Label="Timeout (ms)"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             FullWidth="true"
                             Min="500"
                             Max="60000"
                             Class="mb-3" />

            @* Retries *@
            <MudNumericField T="int"
                             @bind-Value="_drawerAssignment.Retries"
                             Label="Retries"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             FullWidth="true"
                             Min="0"
                             Max="5"
                             Class="mb-4" />

            @* Test Connection *@
            <MudButton Variant="Variant.Text"
                       Color="Color.Info"
                       StartIcon="@Icons.Material.Outlined.NetworkCheck"
                       FullWidth="true"
                       OnClick="@TestConnectionAsync"
                       Class="mb-2">
                Test Connection
            </MudButton>

            @* Remove from chain *@
            <MudButton Variant="Variant.Text"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Outlined.RemoveCircleOutline"
                       FullWidth="true"
                       OnClick="RemoveFromChain">
                Remove from Priority
            </MudButton>
        }

    </div>
}

@* ════════════════════════════════════════════════════════════════════════════
   Add Provider Dialog
   ════════════════════════════════════════════════════════════════════════════ *@

<MudDialog @bind-Visible="_addDialogOpen"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Add Provider — @_addDialogMediaType</MudText>
    </TitleContent>
    <DialogContent>

        <MudTextField T="string"
                      @bind-Value="_addDialogSearch"
                      Placeholder="Search providers…"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Class="mb-3" />

        @{
            var available = GetAvailableProviders(_addDialogMediaType);
            var filtered  = string.IsNullOrWhiteSpace(_addDialogSearch)
                ? available
                : available.Where(p => p.Name.Contains(_addDialogSearch, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        @if (!filtered.Any())
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                No providers available for this media type.
            </MudText>
        }
        else
        {
            @foreach (var p in filtered)
            {
                var pCapture = p;
                <div style="@AddProviderRowStyle"
                     @onclick="@(() => AddProviderToChain(pCapture.Name))"
                     role="button"
                     tabindex="0">

                    <MudIcon Icon="@GetProviderIcon(pCapture.Name)"
                             Size="Size.Small"
                             Style="color: var(--mud-palette-primary); flex-shrink: 0;" />

                    <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                        <MudText Typo="Typo.body2" Style="font-weight: 600; line-height: 1.2;">
                            @pCapture.Name
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @pCapture.Type · @(pCapture.RequiresKey ? "Requires key" : "Zero-key")
                        </MudText>
                    </MudStack>

                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex-shrink: 0;">
                        @((pCapture.SuccessRate * 100).ToString("F0"))%
                    </MudText>

                </div>
            }
        }

    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _addDialogOpen = false)">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {

    // ── Provider catalogue ────────────────────────────────────────────────────────

    private sealed record ProviderInfo(
        string Name,
        string Type,
        bool   RequiresKey,
        string[] Supports,
        int    LatencyMs,
        double SuccessRate);

    private static readonly ProviderInfo[] AllProviderCatalogue =
    [
        new("Apple API",      "Retail", false, ["Books", "Audiobooks"],                          120, 0.94),
        new("Google Books",   "Retail", true,  ["Books", "Audiobooks"],                          180, 0.91),
        new("Open Library",   "Open",   false, ["Books"],                                        240, 0.87),
        new("TMDB",           "Retail", true,  ["Movies", "TV"],                                 110, 0.96),
        new("MusicBrainz",    "Open",   false, ["Music"],                                        210, 0.89),
        new("Comic Vine",     "Retail", true,  ["Comics"],                                       160, 0.92),
        new("Apple Podcasts", "Retail", false, ["Podcasts"],                                     130, 0.93),
        new("Podcast Index",  "Open",   false, ["Podcasts"],                                     200, 0.88),
        new("Wikidata",       "Open",   false, ["Books","Movies","TV","Music","Comics","Audiobooks","Podcasts"], 300, 0.85),
    ];

    // ── Per-media-type provider assignment ────────────────────────────────────────

    private sealed class ProviderAssignment
    {
        public string Name      { get; set; } = "";
        public int    TimeoutMs { get; set; } = 3000;
        public string ApiKey    { get; set; } = "";
        public bool   Enabled   { get; set; } = true;
        public int    Retries   { get; set; } = 1;
    }

    private static readonly Dictionary<string, List<ProviderAssignment>> DefaultAssignments = new()
    {
        ["Books"]      = [new() { Name = "Apple API" }, new() { Name = "Google Books" }],
        ["Audiobooks"] = [new() { Name = "Apple API" }],
        ["Movies"]     = [new() { Name = "TMDB" }],
        ["TV"]         = [new() { Name = "TMDB" }],
        ["Music"]      = [new() { Name = "MusicBrainz" }],
        ["Comics"]     = [new() { Name = "Comic Vine" }],
        ["Podcasts"]   = [new() { Name = "Apple Podcasts" }, new() { Name = "Podcast Index" }],
    };

    private static readonly Dictionary<string, string[]> ProviderMediaTypes = new()
    {
        ["Apple API"]      = ["Books", "Audiobooks"],
        ["Google Books"]   = ["Books", "Audiobooks"],
        ["Open Library"]   = ["Books"],
        ["TMDB"]           = ["Movies", "TV"],
        ["MusicBrainz"]    = ["Music"],
        ["Comic Vine"]     = ["Comics"],
        ["Apple Podcasts"] = ["Podcasts"],
        ["Podcast Index"]  = ["Podcasts"],
        ["Wikidata"]       = ["All"],
    };

    // ── State ────────────────────────────────────────────────────────────────────

    private readonly string[] _mediaTypes =
        ["Books", "Audiobooks", "Movies", "TV", "Music", "Comics", "Podcasts"];

    // Working copy: mediaType → ordered list of assignments
    private Dictionary<string, List<ProviderAssignment>> _assignments = new();

    // Drawer state
    private bool               _drawerOpen        = false;
    private string             _drawerMediaType   = "";
    private int                _drawerIndex       = -1;
    private ProviderAssignment? _drawerAssignment  = null;

    // Add dialog state
    private bool   _addDialogOpen      = false;
    private string _addDialogMediaType = "";
    private string _addDialogSearch    = "";

    private bool _saving = false;

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override void OnInitialized() => ResetToDefaults();

    // ── Chain helpers ────────────────────────────────────────────────────────────

    private List<ProviderAssignment> GetChain(string mediaType)
    {
        if (!_assignments.TryGetValue(mediaType, out var list))
        {
            list = [];
            _assignments[mediaType] = list;
        }
        return list;
    }

    private void MoveLeft(string mediaType, int idx)
    {
        if (idx <= 0) return;
        var chain = GetChain(mediaType);
        (chain[idx - 1], chain[idx]) = (chain[idx], chain[idx - 1]);
    }

    private void MoveRight(string mediaType, int idx)
    {
        var chain = GetChain(mediaType);
        if (idx >= chain.Count - 1) return;
        (chain[idx], chain[idx + 1]) = (chain[idx + 1], chain[idx]);
    }

    // ── Drawer ───────────────────────────────────────────────────────────────────

    private void OpenDrawer(string mediaType, int idx)
    {
        _drawerMediaType  = mediaType;
        _drawerIndex      = idx;
        _drawerAssignment = GetChain(mediaType)[idx];
        _drawerOpen       = true;
    }

    private void CloseDrawer()
    {
        _drawerOpen       = false;
        _drawerAssignment = null;
    }

    private void RemoveFromChain()
    {
        if (_drawerIndex >= 0)
            GetChain(_drawerMediaType).RemoveAt(_drawerIndex);
        CloseDrawer();
    }

    private async Task TestConnectionAsync()
    {
        // Simulated connection test — no Engine API yet.
        await Task.Delay(600);
    }

    // ── Add dialog ───────────────────────────────────────────────────────────────

    private void OpenAddDialog(string mediaType)
    {
        _addDialogMediaType = mediaType;
        _addDialogSearch    = "";
        _addDialogOpen      = true;
    }

    private List<ProviderInfo> GetAvailableProviders(string mediaType)
    {
        var chain   = GetChain(mediaType);
        var inChain = chain.Select(a => a.Name).ToHashSet();

        return AllProviderCatalogue
            .Where(p => !inChain.Contains(p.Name) &&
                        (p.Supports.Contains(mediaType) || p.Name == "Wikidata"))
            .ToList();
    }

    private void AddProviderToChain(string name)
    {
        GetChain(_addDialogMediaType).Add(new ProviderAssignment { Name = name });
        _addDialogOpen = false;
    }

    // ── Actions ──────────────────────────────────────────────────────────────────

    private void ResetToDefaults()
    {
        _assignments = DefaultAssignments.ToDictionary(
            kv => kv.Key,
            kv => kv.Value.Select(a => new ProviderAssignment
            {
                Name      = a.Name,
                TimeoutMs = a.TimeoutMs,
                ApiKey    = a.ApiKey,
                Enabled   = a.Enabled,
                Retries   = a.Retries,
            }).ToList());
    }

    private async Task SaveAsync()
    {
        _saving = true;
        // No Engine API yet — simulate a brief save operation.
        await Task.Delay(400);
        _saving = false;
    }

    // ── Display helpers ──────────────────────────────────────────────────────────

    private static string GetMediaTypeIcon(string mediaType) => mediaType switch
    {
        "Books"      => Icons.Material.Outlined.MenuBook,
        "Audiobooks" => Icons.Material.Outlined.Headphones,
        "Movies"     => Icons.Material.Outlined.Movie,
        "TV"         => Icons.Material.Outlined.Tv,
        "Music"      => Icons.Material.Outlined.MusicNote,
        "Comics"     => Icons.Material.Outlined.AutoStories,
        "Podcasts"   => Icons.Material.Outlined.Podcasts,
        _            => Icons.Material.Outlined.Category,
    };

    private static string GetProviderIcon(string provider) => provider switch
    {
        "Apple API" or "Apple Podcasts" => Icons.Material.Outlined.PhoneIphone,
        "Google Books"                  => Icons.Material.Outlined.Book,
        "Open Library"                  => Icons.Material.Outlined.LocalLibrary,
        "TMDB"                          => Icons.Material.Outlined.Movie,
        "MusicBrainz"                   => Icons.Material.Outlined.MusicNote,
        "Comic Vine"                    => Icons.Material.Outlined.AutoStories,
        "Podcast Index"                 => Icons.Material.Outlined.Podcasts,
        "Wikidata"                      => Icons.Material.Outlined.Public,
        _                               => Icons.Material.Outlined.Storage,
    };

    private static ProviderInfo? GetProviderInfo(string name) =>
        AllProviderCatalogue.FirstOrDefault(p => p.Name == name);

    private static string[] GetProviderMediaTypes(string provider) =>
        ProviderMediaTypes.TryGetValue(provider, out var types) ? types : ["All"];

    // ── Styles ───────────────────────────────────────────────────────────────────

    private const string GlassStyle =
        "background: var(--app-glass-bg); " +
        "border: 1px solid var(--app-glass-border); " +
        "backdrop-filter: blur(10px); " +
        "-webkit-backdrop-filter: blur(10px); " +
        "border-radius: 12px; " +
        "padding: 32px;";

    private const string ProviderChainCardStyle =
        "position: relative; " +
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 10px; " +
        "padding: 14px 16px 10px 16px; " +
        "min-width: 200px; " +
        "max-width: 240px; " +
        "cursor: pointer; " +
        "transition: border-color 0.15s, box-shadow 0.15s; " +
        "display: flex; flex-direction: column; align-items: flex-start;";

    private const string ConnectorLineStyle =
        "height: 1px; width: 28px; flex-shrink: 0; " +
        "background: linear-gradient(to right, rgba(255,255,255,0.18), rgba(255,255,255,0.05));";

    private const string SmallChipStyle =
        "display: inline-block; " +
        "font-size: 0.66rem; " +
        "padding: 1px 6px; " +
        "border-radius: 10px; " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "color: var(--mud-palette-text-secondary); " +
        "line-height: 1.6;";

    private const string DrawerPanelStyle =
        "position: fixed; top: 0; right: 0; bottom: 0; " +
        "width: 340px; " +
        "background: var(--app-glass-bg); " +
        "border-left: 1px solid var(--app-glass-border); " +
        "backdrop-filter: blur(16px); " +
        "-webkit-backdrop-filter: blur(16px); " +
        "z-index: 1201; " +
        "padding: 24px 20px; " +
        "overflow-y: auto; " +
        "display: flex; flex-direction: column;";

    private const string AddProviderRowStyle =
        "display: flex; align-items: center; gap: 12px; " +
        "padding: 10px 8px; " +
        "border-radius: 8px; " +
        "cursor: pointer; " +
        "transition: background 0.12s; " +
        "margin-bottom: 4px;";
}
