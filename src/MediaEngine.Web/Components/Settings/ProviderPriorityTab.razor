@namespace MediaEngine.Web.Components.Settings
@inject IEngineApiClient ApiClient

@* Providers — full-width priority chain design.
   Icon-above-label category selector. Provider cards flow responsively.
   Clicking a card opens a slide-in config overlay from the right.
   "+ Add" opens a dialog to pick from the available provider catalogue.
   Reorder with chevron buttons; remove via the config overlay. *@

<style>
    .provider-page { width: 100%; padding: 24px; box-sizing: border-box; }

    /* ── Category selector ── */
    .category-strip {
        display: flex; gap: 0; overflow-x: auto; -webkit-overflow-scrolling: touch;
        margin-bottom: 32px; border-bottom: 1px solid var(--app-glass-inner-border, rgba(255,255,255,0.08));
    }
    .category-item {
        display: flex; flex-direction: column; align-items: center; gap: 4px;
        padding: 12px 20px 10px; cursor: pointer; border: none; background: none;
        color: var(--mud-palette-text-secondary); transition: color 0.15s;
        border-bottom: 2px solid transparent; flex-shrink: 0; min-width: 64px;
    }
    .category-item:hover { color: var(--mud-palette-text-primary); }
    .category-item.active {
        color: var(--mud-palette-primary);
        border-bottom-color: var(--mud-palette-primary);
    }
    .category-item .cat-icon { font-size: 1.5rem; line-height: 1; }
    .category-item .cat-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; white-space: nowrap; }

    /* ── Priority chain ── */
    .chain-container {
        display: flex; flex-wrap: wrap; align-items: center; gap: 16px; margin-bottom: 24px;
    }
    .chain-card {
        position: relative; background: var(--app-glass-inner-bg, rgba(255,255,255,0.04));
        border: 1px solid var(--app-glass-inner-border, rgba(255,255,255,0.08));
        border-radius: 10px; padding: 14px 16px 10px; cursor: pointer;
        transition: border-color 0.15s, box-shadow 0.15s;
        display: flex; flex-direction: column; align-items: flex-start;
        flex: 1 1 200px; min-width: 180px; max-width: 320px;
    }
    .chain-card:hover {
        border-color: var(--mud-palette-primary);
        box-shadow: 0 0 20px rgba(201, 146, 46, 0.08);
    }
    .chain-connector {
        width: 28px; height: 1px; flex-shrink: 0;
        background: linear-gradient(to right, rgba(255,255,255,0.18), rgba(255,255,255,0.05));
    }
    .chain-add-btn {
        min-width: 100px; height: 40px; flex-shrink: 0;
    }

    /* ── Mobile: stack vertically ── */
    @@media (max-width: 600px) {
        .provider-page { padding: 12px; }
        .category-item { padding: 10px 12px 8px; min-width: 48px; }
        .category-item .cat-label { font-size: 0.62rem; }
        .chain-container { flex-direction: column; align-items: stretch; gap: 8px; }
        .chain-card { max-width: none; flex: 1 1 auto; }
        .chain-connector { width: 1px; height: 20px; align-self: center;
            background: linear-gradient(to bottom, rgba(255,255,255,0.18), rgba(255,255,255,0.05)); }
        .drawer-panel { width: 100% !important; top: 48px !important; }
    }

    /* ── Tablet: 2-col cards ── */
    @@media (min-width: 601px) and (max-width: 960px) {
        .chain-card { max-width: none; flex: 1 1 calc(50% - 24px); }
    }

    /* ── Small chip ── */
    .provider-chip {
        display: inline-block; font-size: 0.66rem; padding: 1px 6px;
        border-radius: 10px; border: 1px solid var(--app-glass-inner-border, rgba(255,255,255,0.08));
        color: var(--mud-palette-text-secondary); line-height: 1.6;
    }

    /* ── Drawer ── */
    .drawer-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 1200; }
    .drawer-panel {
        position: fixed; top: 64px; right: 0; bottom: 0; width: 380px;
        background: var(--app-glass-bg, rgba(10,14,30,0.95));
        border-left: 1px solid var(--app-glass-border, rgba(255,255,255,0.06));
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        z-index: 1201; padding: 0; overflow-y: auto;
        display: flex; flex-direction: column;
    }
    .drawer-header {
        padding: 24px 24px 16px; border-bottom: 1px solid var(--app-glass-inner-border, rgba(255,255,255,0.08));
    }
    .drawer-icon-circle {
        width: 44px; height: 44px; border-radius: 10px;
        background: var(--mud-palette-primary); display: flex;
        align-items: center; justify-content: center; flex-shrink: 0;
    }
    .drawer-stats-row {
        display: flex; gap: 16px; margin-top: 14px; padding: 10px 12px;
        background: var(--app-glass-inner-bg, rgba(255,255,255,0.03));
        border: 1px solid var(--app-glass-inner-border, rgba(255,255,255,0.06));
        border-radius: 8px;
    }
    .drawer-stat {
        display: flex; align-items: center; gap: 6px;
        font-size: 0.78rem; color: var(--mud-palette-text-secondary);
    }
    .drawer-section {
        padding: 20px 24px 0;
    }
    .drawer-section-label {
        display: block; font-size: 0.68rem; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--mud-palette-text-secondary); margin-bottom: 14px;
    }
    .drawer-field-row {
        display: flex; align-items: center; margin-bottom: 4px;
    }

    /* ── Save bar ── */
    .save-bar {
        display: flex; justify-content: flex-end; gap: 12px; align-items: center;
        padding-top: 16px; margin-top: 24px;
        border-top: 1px solid var(--app-glass-inner-border, rgba(255,255,255,0.08));
    }
</style>

<div class="provider-page">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Outlined.Hub" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">Providers</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-5">
        Build a priority chain for each media type. The Engine tries providers left to right,
        stopping when one returns a result.
    </MudText>

    @* ── Category selector (icons on top) ────────────────────────────────── *@
    <div class="category-strip">
        @foreach (var mt in _mediaTypes)
        {
            var mediaType = mt;
            <button class="category-item @(mediaType == _activeTab ? "active" : "")"
                    @onclick="@(() => _activeTab = mediaType)">
                <MudIcon Icon="@GetMediaTypeIcon(mediaType)" Class="cat-icon" />
                <span class="cat-label">@mediaType</span>
            </button>
        }
    </div>

    @* ── Priority chain for active tab ───────────────────────────────────── *@
    @{
        var chain = GetChain(_activeTab);
    }

    <div class="chain-container">
        @for (int i = 0; i < chain.Count; i++)
        {
            var idx        = i;
            var assignment = chain[idx];
            var info       = GetProviderInfo(assignment.Name);
            var posLabel   = idx == 0 ? "Primary" : idx == 1 ? "Secondary" : "Fallback";
            var enabledDot = assignment.Enabled ? "#4caf50" : "#f44336";

            @* ── Provider card ── *@
            <div class="chain-card"
                 @onclick="@(() => OpenDrawer(_activeTab, idx))"
                 role="button"
                 tabindex="0">

                @* Status dot — top right *@
                <div style="position: absolute; top: 10px; right: 10px;
                            width: 9px; height: 9px; border-radius: 50%;
                            background: @enabledDot;" />

                @* Provider icon *@
                <MudIcon Icon="@GetProviderIcon(assignment.Name)"
                         Size="Size.Medium"
                         Style="color: var(--mud-palette-primary); margin-bottom: 6px;" />

                @* Name + position *@
                <MudText Typo="Typo.body2"
                         Style="font-weight: 700; line-height: 1.2; margin-bottom: 2px;">
                    @assignment.Name
                </MudText>
                <MudText Typo="Typo.caption"
                         Style="color: var(--mud-palette-text-secondary); margin-bottom: 6px; display: block;">
                    @posLabel
                </MudText>

                @* Media type chips *@
                <div style="display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px;">
                    @foreach (var mt in GetProviderMediaTypes(assignment.Name))
                    {
                        <span class="provider-chip">@mt</span>
                    }
                </div>

                @* Stats — prefer live health data, fall back to catalogue *@
                <MudText Typo="Typo.caption"
                         Style="color: var(--mud-palette-text-secondary); display: block; line-height: 1.6;">
                    @GetLatencyDisplay(assignment.Name) · @GetSuccessRateDisplay(assignment.Name)
                </MudText>

                @* Reorder buttons *@
                <div style="display: flex; justify-content: center; gap: 2px; margin-top: 8px; width: 100%;"
                     @onclick:stopPropagation="true">
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                   Size="Size.Small"
                                   Disabled="@(idx == 0)"
                                   OnClick="@(() => MoveLeft(_activeTab, idx))"
                                   Style="padding: 2px;" />
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                   Size="Size.Small"
                                   Disabled="@(idx == chain.Count - 1)"
                                   OnClick="@(() => MoveRight(_activeTab, idx))"
                                   Style="padding: 2px;" />
                </div>

            </div>

            @* ── Connector line between cards ── *@
            @if (idx < chain.Count - 1)
            {
                <div class="chain-connector" />
            }
        }

        @* ── + Add button ── *@
        @if (chain.Count > 0)
        {
            <div class="chain-connector" />
        }

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Add"
                   Size="Size.Small"
                   Class="chain-add-btn"
                   Style="border-radius: 8px;
                          border: 1px dashed var(--app-glass-inner-border);
                          color: var(--mud-palette-text-secondary);"
                   OnClick="@(() => OpenAddDialog(_activeTab))">
            Add
        </MudButton>

    </div>

    @* ── Empty state ── *@
    @if (chain.Count == 0)
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4"
                 Style="display: block;">
            No providers assigned. Click Add to build a priority chain.
        </MudText>
    }

    @* ── Save bar ────────────────────────────────────────────────────────── *@
    <div class="save-bar">
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Outlined.RestartAlt"
                   OnClick="@ResetToDefaults">
            Reset to Defaults
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="@SaveAsync"
                   Disabled="@_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                @:Saving…
            }
            else
            {
                @:Save
            }
        </MudButton>
    </div>

</div>

@* ════════════════════════════════════════════════════════════════════════════
   Config Drawer — slide-in overlay from the right
   ════════════════════════════════════════════════════════════════════════════ *@

@if (_drawerOpen)
{
    @* Backdrop *@
    <div class="drawer-backdrop" @onclick="CloseDrawer" />

    @* Panel *@
    <div class="drawer-panel">

        @{
            var drawerInfo = GetProviderInfo(_drawerAssignment?.Name ?? "");
            var positionLabel = _drawerIndex == 0 ? "Primary" : _drawerIndex == 1 ? "Secondary" : "Fallback";
        }

        @* ── Header section ── *@
        <div class="drawer-header">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 4px;">
                <div class="drawer-icon-circle">
                    <MudIcon Icon="@GetProviderIcon(_drawerAssignment?.Name ?? "")"
                             Size="Size.Medium" Style="color: white;" />
                </div>
                <div style="flex: 1; min-width: 0;">
                    <MudText Typo="Typo.h6" Style="font-weight: 700; line-height: 1.2; margin: 0;">
                        @(_drawerAssignment?.Name ?? "")
                    </MudText>
                    <MudText Typo="Typo.caption"
                             Style="color: var(--mud-palette-text-secondary); display: block; margin-top: 2px;">
                        @(drawerInfo?.Type ?? "") provider · @positionLabel
                    </MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               OnClick="CloseDrawer"
                               Style="align-self: flex-start;" />
            </div>

            @* Stats row — prefer live health data *@
            @if (drawerInfo is not null)
            {
                var healthColor = IsProviderHealthy(_drawerAssignment?.Name ?? "") ? "#4caf50" : "#f44336";
                <div class="drawer-stats-row">
                    <div class="drawer-stat">
                        <MudIcon Icon="@Icons.Material.Outlined.Speed" Size="Size.Small"
                                 Style="color: var(--mud-palette-text-secondary);" />
                        <span>@GetLatencyDisplay(_drawerAssignment?.Name ?? "")</span>
                    </div>
                    <div class="drawer-stat">
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircleOutline" Size="Size.Small"
                                 Style="@($"color: {healthColor};")" />
                        <span>@GetSuccessRateDisplay(_drawerAssignment?.Name ?? "")</span>
                    </div>
                    <div class="drawer-stat">
                        <MudIcon Icon="@Icons.Material.Outlined.VpnKey" Size="Size.Small"
                                 Style="color: var(--mud-palette-text-secondary);" />
                        <span>@(drawerInfo.RequiresKey ? "Key required" : "No key")</span>
                    </div>
                </div>
            }
        </div>

        @if (_drawerAssignment is not null)
        {
            @* ── Status section ── *@
            <div class="drawer-section">
                <span class="drawer-section-label">STATUS</span>
                <div class="drawer-field-row">
                    <MudText Typo="Typo.body2" Style="flex: 1;">Enabled</MudText>
                    <MudSwitch T="bool"
                               Value="@_drawerAssignment.Enabled"
                               ValueChanged="@(v => _drawerAssignment.Enabled = v)"
                               Color="Color.Success" />
                </div>
                <div class="drawer-field-row" style="gap: 8px;">
                    <MudIcon Icon="@Icons.Material.Outlined.FiberManualRecord"
                             Size="Size.Small"
                             Style="@($"color: {(_drawerAssignment.Enabled ? "#4caf50" : "#f44336")}; flex-shrink: 0;")" />
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                        @(_drawerAssignment.Enabled ? "Provider is active and will be queried" : "Provider is disabled and will be skipped")
                    </MudText>
                </div>
            </div>

            @* ── Connection section ── *@
            <div class="drawer-section">
                <span class="drawer-section-label">CONNECTION</span>

                @if (drawerInfo?.RequiresKey == true)
                {
                    @if (drawerInfo?.AuthType == "basic")
                    {
                        <MudTextField T="string"
                                      @bind-Value="_drawerAssignment.Username"
                                      Label="Username"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Outlined.Person"
                                      AdornmentColor="Color.Default"
                                      Style="margin-bottom: 12px;" />
                        <MudTextField T="string"
                                      @bind-Value="_drawerAssignment.Password"
                                      Label="Password"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Outlined.Lock"
                                      AdornmentColor="Color.Default"
                                      Style="margin-bottom: 16px;" />
                    }
                    else
                    {
                        <MudTextField T="string"
                                      @bind-Value="_drawerAssignment.ApiKey"
                                      Label="API Key"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Outlined.VpnKey"
                                      AdornmentColor="Color.Default"
                                      Style="margin-bottom: 16px;" />
                    }
                }

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Info"
                           StartIcon="@Icons.Material.Outlined.NetworkCheck"
                           FullWidth="true"
                           Size="Size.Small"
                           OnClick="@TestConnectionAsync"
                           Style="border-radius: 8px;">
                    Test Connection
                </MudButton>
                <MudText Typo="Typo.caption"
                         Style="color: var(--mud-palette-text-secondary); display: block; margin-top: 8px;">
                    Last tested: —
                </MudText>
            </div>

            @* ── Behaviour section ── *@
            <div class="drawer-section">
                <span class="drawer-section-label">BEHAVIOUR</span>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <MudNumericField T="int"
                                     @bind-Value="_drawerAssignment.TimeoutMs"
                                     Label="Timeout (ms)"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     FullWidth="true"
                                     Min="500"
                                     Max="60000" />
                    <MudNumericField T="int"
                                     @bind-Value="_drawerAssignment.Retries"
                                     Label="Retries"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     FullWidth="true"
                                     Min="0"
                                     Max="5" />
                </div>
                <MudSelect T="string"
                           @bind-Value="_drawerAssignment.LanguageStrategy"
                           Label="Language Strategy"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           FullWidth="true"
                           Class="mt-3">
                    <MudSelectItem T="string" Value="@("source")">Source (always English)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("localized")">Localized (your language)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("both")">Both (try both, merge)</MudSelectItem>
                </MudSelect>
                <MudText Typo="Typo.caption"
                         Style="color: var(--mud-palette-text-secondary); display: block; margin-top: 8px;">
                    Failed requests will retry up to @(_drawerAssignment.Retries) time@(_drawerAssignment.Retries == 1 ? "" : "s")
                    before moving to the next provider. Language strategy controls whether queries use
                    your metadata language, English, or both.
                </MudText>
            </div>

            @* ── Media types section ── *@
            <div class="drawer-section">
                <span class="drawer-section-label">SUPPORTED MEDIA</span>
                <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                    @foreach (var mt in GetProviderMediaTypes(_drawerAssignment.Name))
                    {
                        <span class="provider-chip" style="font-size: 0.72rem; padding: 3px 10px;">@mt</span>
                    }
                </div>
            </div>

            @* ── Save bar (inside drawer) ── *@
            <div style="padding: 20px 24px 0;">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           FullWidth="true"
                           Size="Size.Small"
                           OnClick="SaveDrawerAsync"
                           Disabled="@_drawerSaving"
                           Style="border-radius: 8px; margin-bottom: 12px;">
                    @if (_drawerSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                        @:Saving…
                    }
                    else
                    {
                        @:Save Provider Settings
                    }
                </MudButton>
                @if (!string.IsNullOrEmpty(_drawerSaveMessage))
                {
                    <MudText Typo="Typo.caption"
                             Style="@($"color: {(_drawerSaveSuccess ? "#4caf50" : "#f44336")}; display: block; margin-bottom: 8px;")">
                        @_drawerSaveMessage
                    </MudText>
                }
            </div>

            @* ── Danger zone ── *@
            <div style="margin-top: auto; padding-top: 20px; border-top: 1px solid rgba(244,67,54,0.2);">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Outlined.RemoveCircleOutline"
                           FullWidth="true"
                           Size="Size.Small"
                           OnClick="RemoveFromChain"
                           Style="border-radius: 8px;">
                    Remove from Priority Chain
                </MudButton>
            </div>
        }

    </div>
}

@* ════════════════════════════════════════════════════════════════════════════
   Add Provider Dialog
   ════════════════════════════════════════════════════════════════════════════ *@

<MudDialog @bind-Visible="_addDialogOpen"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Add Provider — @_addDialogMediaType</MudText>
    </TitleContent>
    <DialogContent>

        <MudTextField T="string"
                      @bind-Value="_addDialogSearch"
                      Placeholder="Search providers…"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Class="mb-3" />

        @{
            var available = GetAvailableProviders(_addDialogMediaType);
            var filtered  = string.IsNullOrWhiteSpace(_addDialogSearch)
                ? available
                : available.Where(p => p.Name.Contains(_addDialogSearch, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        @if (!filtered.Any())
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                No providers available for this media type.
            </MudText>
        }
        else
        {
            @foreach (var p in filtered)
            {
                var pCapture = p;
                <div style="display: flex; align-items: center; gap: 12px;
                            padding: 10px 8px; border-radius: 8px; cursor: pointer;
                            transition: background 0.12s; margin-bottom: 4px;"
                     @onclick="@(() => AddProviderToChain(pCapture.Name))"
                     role="button"
                     tabindex="0">

                    <MudIcon Icon="@GetProviderIcon(pCapture.Name)"
                             Size="Size.Small"
                             Style="color: var(--mud-palette-primary); flex-shrink: 0;" />

                    <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                        <MudText Typo="Typo.body2" Style="font-weight: 600; line-height: 1.2;">
                            @pCapture.Name
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @pCapture.Type · @(pCapture.RequiresKey ? "Requires key" : "Zero-key")
                        </MudText>
                    </MudStack>

                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex-shrink: 0;">
                        @((pCapture.SuccessRate * 100).ToString("F0"))%
                    </MudText>

                </div>
            }
        }

    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _addDialogOpen = false)">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {

    // ── Provider catalogue ────────────────────────────────────────────────────────

    private sealed record ProviderInfo(
        string   Name,
        string   Type,
        bool     RequiresKey,
        string[] Supports,
        int      LatencyMs,
        double   SuccessRate,
        string   AuthType = "api_key");

    private static readonly ProviderInfo[] AllProviderCatalogue =
    [
        new("Apple API",      "Retail", false, ["Books", "Audiobooks"],                          120, 0.94),
        new("Google Books",   "Retail", true,  ["Books", "Audiobooks"],                          180, 0.91),
        new("Open Library",   "Open",   false, ["Books"],                                        240, 0.87),
        new("TMDB",           "Retail", true,  ["Movies", "TV"],                                 110, 0.96),
        new("MusicBrainz",    "Open",   false, ["Music"],                                        210, 0.89),
        new("Metron",          "Open",   true,  ["Comics"],                                       200, 0.88, "basic"),
        new("Apple Podcasts", "Retail", false, ["Podcasts"],                                     130, 0.93),
