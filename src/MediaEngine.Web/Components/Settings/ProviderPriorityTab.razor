    // ── Per-media-type provider assignment ────────────────────────────────────────

    private sealed class ProviderAssignment
    {
        public string Name             { get; set; } = "";
        public int    TimeoutMs        { get; set; } = 3000;
        public string ApiKey           { get; set; } = "";
        public string Username         { get; set; } = "";
        public string Password         { get; set; } = "";
        public bool   Enabled          { get; set; } = true;
        public int    Retries          { get; set; } = 1;
        public string LanguageStrategy { get; set; } = "source";
    }

    private static readonly Dictionary<string, List<ProviderAssignment>> DefaultAssignments = new()
    {
        ["Books"]      = [new() { Name = "Apple API", LanguageStrategy = "localized" }, new() { Name = "Google Books", LanguageStrategy = "source" }],
        ["Audiobooks"] = [new() { Name = "Apple API", LanguageStrategy = "localized" }],
        ["Movies"]     = [new() { Name = "TMDB", LanguageStrategy = "localized" }],
        ["TV"]         = [new() { Name = "TMDB", LanguageStrategy = "localized" }],
        ["Music"]      = [new() { Name = "MusicBrainz", LanguageStrategy = "source" }],
        ["Comics"]     = [new() { Name = "Metron", LanguageStrategy = "source" }],
        ["Podcasts"]   = [new() { Name = "Apple Podcasts", LanguageStrategy = "localized" }, new() { Name = "Podcast Index", LanguageStrategy = "source" }],
    };

    private static readonly Dictionary<string, string[]> ProviderMediaTypes = new()
    {
        ["Apple API"]      = ["Books", "Audiobooks"],
        ["Google Books"]   = ["Books", "Audiobooks"],
        ["Open Library"]   = ["Books"],
        ["TMDB"]           = ["Movies", "TV"],
        ["MusicBrainz"]    = ["Music"],
        ["Metron"]         = ["Comics"],
        ["Apple Podcasts"] = ["Podcasts"],
        ["Podcast Index"]  = ["Podcasts"],
        ["Wikidata"]       = ["All"],
        ["Fanart.tv"]      = ["Movies", "TV", "Music"],
    };

    // ── State ────────────────────────────────────────────────────────────────────

    private readonly string[] _mediaTypes =
        ["Books", "Audiobooks", "Movies", "TV", "Music", "Comics", "Podcasts"];

    private string _activeTab = "Books";

    // Working copy: mediaType → ordered list of assignments
    private Dictionary<string, List<ProviderAssignment>> _assignments = new();

    // Drawer state
    private bool               _drawerOpen        = false;
    private string             _drawerMediaType   = "";
    private int                _drawerIndex       = -1;
    private ProviderAssignment? _drawerAssignment  = null;

    // Add dialog state
    private bool   _addDialogOpen      = false;
    private string _addDialogMediaType = "";
    private string _addDialogSearch    = "";

    private bool _saving = false;

    // Drawer save state
    private bool   _drawerSaving       = false;
    private string _drawerSaveMessage  = "";
    private bool   _drawerSaveSuccess  = false;

    // ── Health data ─────────────────────────────────────────────────────────────

    private Dictionary<string, ProviderHealthDto> _healthData = new(StringComparer.OrdinalIgnoreCase);

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadFromEngineAsync();
        await LoadHealthDataAsync();
    }

    private async Task LoadFromEngineAsync()
    {
        try
        {
            var slots = await ApiClient.GetProviderSlotsAsync();
            if (slots is not null && slots.Count > 0)
            {
                _assignments = new Dictionary<string, List<ProviderAssignment>>();
                foreach (var (mediaType, slotConfig) in slots)
                {
                    var chain = new List<ProviderAssignment>();
                    if (!string.IsNullOrWhiteSpace(slotConfig.Primary))
                        chain.Add(CreateAssignmentFromSlot(slotConfig.Primary));
                    if (!string.IsNullOrWhiteSpace(slotConfig.Secondary))
                        chain.Add(CreateAssignmentFromSlot(slotConfig.Secondary));
                    if (!string.IsNullOrWhiteSpace(slotConfig.Tertiary))
                        chain.Add(CreateAssignmentFromSlot(slotConfig.Tertiary));

                    // Normalize key to title case (e.g. "books" → "Books")
                    var normalizedKey = char.ToUpperInvariant(mediaType[0]) + mediaType[1..];
                    _assignments[normalizedKey] = chain;
                }

                // Ensure all media types have an entry even if the Engine returned nothing for them.
                foreach (var mt in _mediaTypes)
                {
                    if (!_assignments.ContainsKey(mt))
                        _assignments[mt] = [];
                }
                return;
            }
        }
        catch { /* Fall through to defaults */ }

        ResetToDefaults();
    }

    private static ProviderAssignment CreateAssignmentFromSlot(string providerSlotName)
    {
        // Slot names are stored as "apple_api", "google_books" etc. — convert to display name.
        var displayName = ResolveDisplayName(providerSlotName);
        var info = AllProviderCatalogue.FirstOrDefault(p =>
            p.Name.Replace(" ", "_").Equals(providerSlotName, StringComparison.OrdinalIgnoreCase));

        return new ProviderAssignment
        {
            Name             = info?.Name ?? displayName,
            LanguageStrategy = "source",
        };
    }

    private static string ResolveDisplayName(string slotName)
    {
        // Try to match against the known catalogue first.
        var match = AllProviderCatalogue.FirstOrDefault(p =>
            p.Name.Replace(" ", "_").Equals(slotName, StringComparison.OrdinalIgnoreCase));
        if (match is not null) return match.Name;

        // Fallback: title-case the slot name (e.g. "apple_api" → "Apple Api")
        return string.Join(' ', slotName.Split('_')
            .Select(w => w.Length > 0 ? char.ToUpperInvariant(w[0]) + w[1..] : w));
    }

    private async Task LoadHealthDataAsync()
    {
        try
        {
            var healthList = await ApiClient.GetProviderHealthAsync();
            foreach (var h in healthList)
            {
                _healthData[h.ProviderId] = h;
            }
        }
        catch { /* ignore — catalogue defaults will be used */ }
    }

    // ── Chain helpers ────────────────────────────────────────────────────────────

    private List<ProviderAssignment> GetChain(string mediaType)
    {
        if (!_assignments.TryGetValue(mediaType, out var list))
        {
            list = [];
            _assignments[mediaType] = list;
        }
        return list;
    }

    private void MoveLeft(string mediaType, int idx)
    {
        if (idx <= 0) return;
        var chain = GetChain(mediaType);
        (chain[idx - 1], chain[idx]) = (chain[idx], chain[idx - 1]);
    }

    private void MoveRight(string mediaType, int idx)
    {
        var chain = GetChain(mediaType);
        if (idx >= chain.Count - 1) return;
        (chain[idx], chain[idx + 1]) = (chain[idx + 1], chain[idx]);
    }

    // ── Drawer ───────────────────────────────────────────────────────────────────

    private void OpenDrawer(string mediaType, int idx)
    {
        _drawerMediaType   = mediaType;
        _drawerIndex       = idx;
        _drawerAssignment  = GetChain(mediaType)[idx];
        _drawerOpen        = true;
        _drawerSaveMessage = "";
    }

    private void CloseDrawer()
    {
        _drawerOpen       = false;
        _drawerAssignment = null;
    }

    private void RemoveFromChain()
    {
        if (_drawerIndex >= 0)
            GetChain(_drawerMediaType).RemoveAt(_drawerIndex);
        CloseDrawer();
    }

    private async Task TestConnectionAsync()
    {
        if (_drawerAssignment is null) return;
        // Save first so the Engine has the latest API key, then test.
        await SaveDrawerAsync();

        var providerName = _drawerAssignment.Name.Replace(" ", "_").ToLowerInvariant();
        try
        {
            var result = await ApiClient.TestProviderAsync(providerName);
            if (result is not null)
            {
                _drawerSaveSuccess = result.Success;
                _drawerSaveMessage = result.Success
                    ? $"Connected in {result.ResponseTimeMs}ms — {result.SampleFields?.Count ?? 0} fields returned"
                    : $"Test failed: {result.Message}";
            }
            else
            {
                _drawerSaveSuccess = false;
                _drawerSaveMessage = "No response from Engine";
            }
        }
        catch (Exception ex)
        {
            _drawerSaveSuccess = false;
            _drawerSaveMessage = $"Error: {ex.Message}";
        }
    }

    private async Task SaveDrawerAsync()
    {
        if (_drawerAssignment is null) return;
        _drawerSaving      = true;
        _drawerSaveMessage = "";
        try
        {
            var providerName = _drawerAssignment.Name.Replace(" ", "_").ToLowerInvariant();
            var info = GetProviderInfo(_drawerAssignment.Name);
            string? apiKeyValue = null;
            if (info?.RequiresKey == true)
            {
                if (info.AuthType == "basic")
                {
                    // Metron uses basic auth — send as "username:password"
                    apiKeyValue = $"{_drawerAssignment.Username}:{_drawerAssignment.Password}";
                }
                else
                {
                    apiKeyValue = _drawerAssignment.ApiKey;
                }
            }

            var config = new MediaEngine.Web.Models.ViewDTOs.ProviderConfigUpdateDto
            {
                Enabled         = _drawerAssignment.Enabled,
                TimeoutSeconds  = _drawerAssignment.TimeoutMs / 1000,
                ApiKey          = apiKeyValue,
            };

            var success = await ApiClient.SaveProviderConfigAsync(providerName, config);
            _drawerSaveSuccess = success;
            _drawerSaveMessage = success ? "Saved successfully" : "Failed to save — check Engine connection";
        }
        catch (Exception ex)
        {
            _drawerSaveSuccess = false;
            _drawerSaveMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _drawerSaving = false;
        }
    }

    // ── Add dialog ───────────────────────────────────────────────────────────────

    private void OpenAddDialog(string mediaType)
    {
        _addDialogMediaType = mediaType;
        _addDialogSearch    = "";
        _addDialogOpen      = true;
    }

    private List<ProviderInfo> GetAvailableProviders(string mediaType)
    {
        var chain   = GetChain(mediaType);
        var inChain = chain.Select(a => a.Name).ToHashSet();

        return AllProviderCatalogue
            .Where(p => !inChain.Contains(p.Name) &&
                        (p.Supports.Contains(mediaType) || p.Name == "Wikidata"))
            .ToList();
    }

    private void AddProviderToChain(string name)
    {
        GetChain(_addDialogMediaType).Add(new ProviderAssignment { Name = name });
        _addDialogOpen = false;
    }

    // ── Actions ──────────────────────────────────────────────────────────────────

    private void ResetToDefaults()
    {
        _assignments = DefaultAssignments.ToDictionary(
            kv => kv.Key,
            kv => kv.Value.Select(a => new ProviderAssignment
            {
                Name             = a.Name,
                TimeoutMs        = a.TimeoutMs,
                ApiKey           = a.ApiKey,
                Enabled          = a.Enabled,
                Retries          = a.Retries,
                LanguageStrategy = a.LanguageStrategy,
            }).ToList());
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            // Save per-provider configs (enabled, API key, timeout) for each provider in all chains.
            var savedProviders = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            foreach (var (_, chain) in _assignments)
            {
                foreach (var assignment in chain)
                {
                    if (!savedProviders.Add(assignment.Name)) continue;
                    var providerName = assignment.Name.Replace(" ", "_").ToLowerInvariant();
                    var info = GetProviderInfo(assignment.Name);
                    string? apiKeyValue = null;
                    if (info?.RequiresKey == true)
                    {
                        apiKeyValue = info.AuthType == "basic"
                            ? $"{assignment.Username}:{assignment.Password}"
                            : assignment.ApiKey;
                    }

                    var config = new MediaEngine.Web.Models.ViewDTOs.ProviderConfigUpdateDto
                    {
                        Enabled        = assignment.Enabled,
                        TimeoutSeconds = assignment.TimeoutMs / 1000,
                        ApiKey         = apiKeyValue,
                    };
                    await ApiClient.SaveProviderConfigAsync(providerName, config);
                }
            }

            // Save priority order per media type via slots.
            var slots = _assignments.ToDictionary(
                kv => kv.Key.ToLowerInvariant(),
                kv =>
                {
                    var names = kv.Value.Select(a => a.Name.Replace(" ", "_").ToLowerInvariant()).ToList();
                    return new MediaEngine.Web.Models.ViewDTOs.ProviderSlotDto
                    {
                        Primary   = names.Count > 0 ? names[0] : null,
                        Secondary = names.Count > 1 ? names[1] : null,
                        Tertiary  = names.Count > 2 ? names[2] : null,
                    };
                });
            await ApiClient.UpdateProviderSlotsAsync(slots);
        }
        catch
        {
            // Silently degrade — toast system not yet integrated.
        }
        finally
        {
            _saving = false;
        }
    }

