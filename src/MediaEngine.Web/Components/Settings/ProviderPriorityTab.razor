    private static ProviderInfo? GetProviderInfo(string name) =>
        AllProviderCatalogue.FirstOrDefault(p => p.Name == name);

    /// <summary>Returns live latency string from health data, or catalogue default.</summary>
    private string GetLatencyDisplay(string providerName)
    {
        var key = providerName.Replace(" ", "_").ToLowerInvariant();
        if (_healthData.TryGetValue(key, out var h) && h.LastSuccessAt is not null)
            return h.Status;
        var info = GetProviderInfo(providerName);
        return info is not null ? $"{info.LatencyMs} ms" : "—";
    }

    /// <summary>Returns live success rate or status from health data, or catalogue default.</summary>
    private string GetSuccessRateDisplay(string providerName)
    {
        var key = providerName.Replace(" ", "_").ToLowerInvariant();
        if (_healthData.TryGetValue(key, out var h))
        {
            return h.Status switch
            {
                "Healthy"  => "Healthy",
                "Degraded" => $"Degraded ({h.ConsecutiveFailures} failures)",
                "Down"     => $"Down — {h.LastFailureReason ?? "unknown"}",
                _          => h.Status,
            };
        }
        var info = GetProviderInfo(providerName);
        return info is not null ? $"{(info.SuccessRate * 100):F0}%" : "—";
    }

    /// <summary>Returns true if health data indicates the provider is not down.</summary>
    private bool IsProviderHealthy(string providerName)
    {
        var key = providerName.Replace(" ", "_").ToLowerInvariant();
        if (_healthData.TryGetValue(key, out var h))
            return !string.Equals(h.Status, "Down", StringComparison.OrdinalIgnoreCase);
        return true; // assume healthy if no health data
    }

    private static string[] GetProviderMediaTypes(string provider) =>
        ProviderMediaTypes.TryGetValue(provider, out var types) ? types : ["All"];
}
