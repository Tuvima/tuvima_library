@namespace MediaEngine.Web.Components.Settings

@* Providers — unified screen combining priority slot assignment and connection settings.
   Three numbered slots (Primary/Secondary/Tertiary) are shown per media type.
   Below the slots, every provider is shown as an expandable card where connection
   settings (API key, endpoint, timeout, cache TTL) can be configured.
   State is local with hardcoded defaults; no Engine API calls in this version. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Hub" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">Providers</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-5">
        Manage provider connections and choose which ones the Engine tries first for each media type.
    </MudText>

    @* ── Media type tabs ─────────────────────────────────────────────────── *@
    <MudTabs Elevation="0"
             Rounded="true"
             ApplyEffectsToContainer="true"
             Style="background: transparent;">

        @foreach (var mediaType in _mediaTypes)
        {
            <MudTabPanel Text="@mediaType" Icon="@GetMediaTypeIcon(mediaType)">

                <div class="pt-4">
                <MudGrid Spacing="3">

                    @* ── Priority slots ──────────────────────────────────── *@
                    @for (int i = 0; i < 3; i++)
                    {
                        var slotIndex = i;
                        var label = slotIndex switch { 0 => "Primary", 1 => "Secondary", _ => "Tertiary" };
                        var description = slotIndex switch
                        {
                            0 => "Tried first. Best result wins.",
                            1 => "Tried when Primary returns nothing.",
                            _ => "Last resort before leaving the field empty.",
                        };

                        <MudItem xs="12" sm="4">
                            <div style="@SlotCardStyle">
                                @* Slot number badge *@
                                <MudStack Row="true" AlignItems="AlignItems.Center"
                                          Spacing="1" Class="mb-2">
                                    <div style="@SlotBadgeStyle">@(slotIndex + 1)</div>
                                    <MudText Typo="Typo.subtitle2"
                                             Style="font-weight: 600;">
                                        @label
                                    </MudText>
                                </MudStack>

                                <MudText Typo="Typo.caption" Color="Color.Secondary"
                                         Class="mb-3" Style="display: block;">
                                    @description
                                </MudText>

                                @* Provider selector *@
                                <MudSelect T="string"
                                           Value="@GetSlot(mediaType, slotIndex)"
                                           ValueChanged="@(v => SetSlot(mediaType, slotIndex, v))"
                                           Label="Provider"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           FullWidth="true"
                                           Dense="true"
                                           Clearable="true"
                                           AnchorOrigin="Origin.BottomLeft">
                                    <MudSelectItem T="string" Value='@("")'>
                                        <MudText Color="Color.Secondary">— None —</MudText>
                                    </MudSelectItem>
                                    @foreach (var p in _allProviders)
                                    {
                                        <MudSelectItem T="string" Value="@p">
                                            <MudStack Row="true" AlignItems="AlignItems.Center"
                                                      Spacing="1">
                                                <div style="@GetStatusDotStyle(p)"></div>
                                                @p
                                            </MudStack>
                                        </MudSelectItem>
                                    }
                                </MudSelect>

                                @* Status indicator for the currently assigned provider *@
                                @{
                                    var assigned = GetSlot(mediaType, slotIndex);
                                }
                                @if (!string.IsNullOrEmpty(assigned))
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center"
                                              Spacing="1" Class="mt-2">
                                        <div style="@GetStatusDotStyle(assigned)"></div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @GetProviderMeta(assigned)
                                        </MudText>
                                    </MudStack>
                                }
                            </div>
                        </MudItem>
                    }

                </MudGrid>

                @* ── All Providers section ────────────────────────────── *@
                <MudDivider Class="my-4" />

                <MudText Typo="Typo.overline" Color="Color.Default" Class="mb-1"
                         Style="letter-spacing: 0.08em; display: block;">
                    ALL PROVIDERS
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3"
                         Style="display: block;">
                    All providers can be assigned to any slot. Expand a card to configure connection settings.
                </MudText>

                @foreach (var p in _allProviders)
                {
                    var providerName = p;
                    var isAssigned   = IsAssignedInTab(mediaType, providerName);
                    var isExpanded   = _expandedProviders.Contains(providerName);
                    var config       = GetProviderConfig(providerName);
                    var mediaLabels  = GetProviderMediaTypes(providerName);
                    var needsKey     = ProvidersNeedingKey.Contains(providerName);

                    <div style="@ProviderCardStyle">

                        @* ── Collapsed header (always visible) ─────── *@
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

                            @* Status dot *@
                            <div style="@GetStatusDotStyle(providerName)"></div>

                            @* Name + type label *@
                            <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                                <MudText Typo="Typo.body2" Style="font-weight: 600; line-height: 1.2;">
                                    @providerName
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @GetProviderMeta(providerName)
                                </MudText>
                            </MudStack>

                            @* Media type chips *@
                            <MudStack Row="true" Spacing="1" Style="flex-wrap: wrap; flex: 1;">
                                @foreach (var mt in mediaLabels)
                                {
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Variant="Variant.Outlined"
                                             Color="Color.Default"
                                             Style="font-size: 0.68rem; height: 20px; padding: 0 6px;">
                                        @mt
                                    </MudChip>
                                }
                            </MudStack>

                            @* Enabled toggle *@
                            <MudSwitch T="bool"
                                       Value="@config.Enabled"
                                       ValueChanged="@(v => config.Enabled = v)"
                                       Color="Color.Success"
                                       Size="Size.Small" />

                            @* Assignment checkmark *@
                            @if (isAssigned)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                         Size="Size.Small"
                                         Color="Color.Success"
                                         Style="flex-shrink: 0;" />
                            }
                            else
                            {
                                @* Placeholder to keep layout stable *@
                                <div style="width: 20px; flex-shrink: 0;"></div>
                            }

                            @* Expand/collapse chevron *@
                            <MudIconButton Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                           Size="Size.Small"
                                           OnClick="@(() => ToggleExpand(providerName))"
                                           Style="flex-shrink: 0;" />

                        </MudStack>

                        @* ── Expanded connection settings ────────────── *@
                        @if (isExpanded)
                        {
                            <div style="@ExpandedSectionStyle">

                                <MudGrid Spacing="2">

                                    @if (needsKey)
                                    {
                                        <MudItem xs="12" sm="6">
                                            <MudTextField T="string"
                                                          Value="@config.ApiKey"
                                                          ValueChanged="@(v => config.ApiKey = v)"
                                                          Label="API Key"
                                                          InputType="InputType.Password"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          FullWidth="true"
                                                          Adornment="Adornment.End"
                                                          AdornmentIcon="@Icons.Material.Outlined.VpnKey"
                                                          AdornmentColor="Color.Default" />
                                        </MudItem>
                                    }

                                    <MudItem xs="12" sm="@(needsKey ? 6 : 12)">
                                        <MudTextField T="string"
                                                      Value="@config.Endpoint"
                                                      ValueChanged="@(v => config.Endpoint = v)"
                                                      Label="Endpoint URL"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      FullWidth="true"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Outlined.Link"
                                                      AdornmentColor="Color.Default" />
                                    </MudItem>

                                    <MudItem xs="12" sm="6">
                                        <MudNumericField T="int"
                                                         Value="@config.TimeoutSeconds"
                                                         ValueChanged="@(v => config.TimeoutSeconds = v)"
                                                         Label="Request Timeout (seconds)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         FullWidth="true"
                                                         Min="5" Max="120" />
                                    </MudItem>

                                    <MudItem xs="12" sm="6">
                                        <MudNumericField T="int"
                                                         Value="@config.CacheTtlHours"
                                                         ValueChanged="@(v => config.CacheTtlHours = v)"
                                                         Label="Cache TTL (hours)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         FullWidth="true"
                                                         Min="1" Max="720" />
                                    </MudItem>

                                </MudGrid>

                                <MudStack Row="true" AlignItems="AlignItems.Center"
                                          Justify="Justify.SpaceBetween" Class="mt-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Last successful call: —
                                    </MudText>
                                    <MudButton Variant="Variant.Outlined"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Outlined.NetworkCheck"
                                               OnClick="@(() => TestConnectionAsync(providerName))">
                                        Test Connection
                                    </MudButton>
                                </MudStack>

                            </div>
                        }

                    </div>
                }

                </div>

            </MudTabPanel>
        }

    </MudTabs>

    @* ── Save row ─────────────────────────────────────────────────────────── *@
    <MudDivider Class="mt-6 mb-4" />
    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Outlined.RestartAlt"
                   OnClick="@ResetToDefaults">
            Reset to Defaults
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="@SaveAsync"
                   Disabled="@_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                @:Saving…
            }
            else
            {
                @:Save
            }
        </MudButton>
    </MudStack>

</MudPaper>

@code {

    // ── Default slot assignments ─────────────────────────────────────────────────

    private static readonly Dictionary<string, string[]> DefaultSlots = new()
    {
        ["Books"]      = ["Apple API", "Google Books", "Open Library"],
        ["Audiobooks"] = ["Apple API", "Google Books", ""],
        ["Movies"]     = ["TMDB", "", ""],
        ["TV"]         = ["TMDB", "", ""],
        ["Music"]      = ["MusicBrainz", "", ""],
        ["Comics"]     = ["Comic Vine", "", ""],
        ["Podcasts"]   = ["Apple Podcasts", "Podcast Index", ""],
    };

    // ── Provider catalogue ────────────────────────────────────────────────────────

    private static readonly string[] _allProviders =
    [
        "Apple API",
        "Google Books",
        "Open Library",
        "TMDB",
        "MusicBrainz",
        "Comic Vine",
        "Apple Podcasts",
        "Podcast Index",
        "Wikidata",
    ];

    private static readonly Dictionary<string, string> ProviderMeta = new()
    {
        ["Apple API"]      = "Zero-key · Retail",
        ["Google Books"]   = "API key · Retail",
        ["Open Library"]   = "Zero-key · Retail",
        ["TMDB"]           = "Free key · Retail",
        ["MusicBrainz"]    = "Zero-key · Retail",
        ["Comic Vine"]     = "Free key · Retail",
        ["Apple Podcasts"] = "Zero-key · Retail",
        ["Podcast Index"]  = "Free key · Retail",
        ["Wikidata"]       = "Zero-key · Universe",
    };

    private static readonly Dictionary<string, string[]> ProviderMediaTypes = new()
    {
        ["Apple API"]      = ["Books", "Audiobooks"],
        ["Google Books"]   = ["Books", "Audiobooks"],
        ["Open Library"]   = ["Books"],
        ["TMDB"]           = ["Movies", "TV"],
        ["MusicBrainz"]    = ["Music"],
        ["Comic Vine"]     = ["Comics"],
        ["Apple Podcasts"] = ["Podcasts"],
        ["Podcast Index"]  = ["Podcasts"],
        ["Wikidata"]       = ["All"],
    };

    private static readonly HashSet<string> ProvidersNeedingKey = new()
    {
        "Google Books", "TMDB", "Comic Vine", "Podcast Index"
    };

    // ── Default endpoints ────────────────────────────────────────────────────────

    private static readonly Dictionary<string, string> DefaultEndpoints = new()
    {
        ["Apple API"]      = "https://itunes.apple.com/search",
        ["Google Books"]   = "https://www.googleapis.com/books/v1/volumes",
        ["Open Library"]   = "https://openlibrary.org/search.json",
        ["TMDB"]           = "https://api.themoviedb.org/3",
        ["MusicBrainz"]    = "https://musicbrainz.org/ws/2",
        ["Comic Vine"]     = "https://comicvine.gamespot.com/api",
        ["Apple Podcasts"] = "https://itunes.apple.com/search",
        ["Podcast Index"]  = "https://api.podcastindex.org/api/1.0",
        ["Wikidata"]       = "https://www.wikidata.org/w/api.php",
    };

    // ── State ────────────────────────────────────────────────────────────────────

    private readonly string[] _mediaTypes =
        ["Books", "Audiobooks", "Movies", "TV", "Music", "Comics", "Podcasts"];

    // Working copy: [mediaType][slotIndex] → provider name (empty string = unset)
    private Dictionary<string, string[]> _slots = new();

    // Per-provider expanded state
    private readonly HashSet<string> _expandedProviders = new();

    // Per-provider config state (local defaults, keyed by provider name)
    private readonly Dictionary<string, ProviderConfig> _providerConfigs = new();

    private bool _saving;

    // ── Provider config record ────────────────────────────────────────────────────

    private sealed class ProviderConfig
    {
        public string ApiKey        { get; set; } = "";
        public string Endpoint      { get; set; } = "";
        public int    TimeoutSeconds { get; set; } = 30;
        public int    CacheTtlHours  { get; set; } = 168;
        public bool   Enabled        { get; set; } = true;
    }

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        ResetToDefaults();

        // Initialise per-provider configs with default endpoints.
        foreach (var p in _allProviders)
        {
            _providerConfigs[p] = new ProviderConfig
            {
                Endpoint     = DefaultEndpoints.TryGetValue(p, out var ep) ? ep : "",
                CacheTtlHours = GetDefaultCacheTtl(p),
            };
        }
    }

    // ── Slot access helpers ──────────────────────────────────────────────────────

    private string GetSlot(string mediaType, int index)
    {
        if (_slots.TryGetValue(mediaType, out var arr) && index < arr.Length)
            return arr[index];
        return string.Empty;
    }

    private void SetSlot(string mediaType, int index, string value)
    {
        if (!_slots.ContainsKey(mediaType))
            _slots[mediaType] = ["", "", ""];

        _slots[mediaType][index] = value ?? string.Empty;
    }

    private bool IsAssignedInTab(string mediaType, string provider)
    {
        if (!_slots.TryGetValue(mediaType, out var arr))
            return false;
        return arr.Any(s => s == provider);
    }

    // ── Provider config helpers ───────────────────────────────────────────────────

    private ProviderConfig GetProviderConfig(string provider)
    {
        if (!_providerConfigs.TryGetValue(provider, out var cfg))
        {
            cfg = new ProviderConfig
            {
                Endpoint = DefaultEndpoints.TryGetValue(provider, out var ep) ? ep : ""
            };
            _providerConfigs[provider] = cfg;
        }
        return cfg;
    }

    private static string[] GetProviderMediaTypes(string provider) =>
        ProviderMediaTypes.TryGetValue(provider, out var types) ? types : ["All"];

    private static int GetDefaultCacheTtl(string provider) => provider switch
    {
        "Open Library" or "MusicBrainz" => 336,   // 14 days
        "Comic Vine"                    => 720,   // 30 days
        _                               => 168,   // 7 days (default)
    };

    // ── Expand/collapse ───────────────────────────────────────────────────────────

    private void ToggleExpand(string provider)
    {
        if (_expandedProviders.Contains(provider))
            _expandedProviders.Remove(provider);
        else
            _expandedProviders.Add(provider);
    }

    // ── Actions ──────────────────────────────────────────────────────────────────

    private void ResetToDefaults()
    {
        _slots = DefaultSlots.ToDictionary(
            kv => kv.Key,
            kv => (string[])kv.Value.Clone());
    }

    private async Task SaveAsync()
    {
        _saving = true;
        // No Engine API yet — simulate a brief save operation.
        await Task.Delay(400);
        _saving = false;
    }

    private async Task TestConnectionAsync(string provider)
    {
        // Simulated connection test — no Engine API yet.
        await Task.Delay(600);
    }

    // ── Display helpers ──────────────────────────────────────────────────────────

    private static string GetMediaTypeIcon(string mediaType) => mediaType switch
    {
        "Books"      => Icons.Material.Outlined.MenuBook,
        "Audiobooks" => Icons.Material.Outlined.Headphones,
        "Movies"     => Icons.Material.Outlined.Movie,
        "TV"         => Icons.Material.Outlined.Tv,
        "Music"      => Icons.Material.Outlined.MusicNote,
        "Comics"     => Icons.Material.Outlined.AutoStories,
        "Podcasts"   => Icons.Material.Outlined.Podcasts,
        _            => Icons.Material.Outlined.Category,
    };

    private static string GetProviderMeta(string provider) =>
        ProviderMeta.TryGetValue(provider, out var meta) ? meta : string.Empty;

    // All providers treated as online for now; extend when Engine status API is wired.
    private static string GetStatusDotStyle(string _) =>
        "width: 8px; height: 8px; border-radius: 50%; " +
        "background: #4caf50; flex-shrink: 0;";

    // ── Styles ───────────────────────────────────────────────────────────────────

    private const string GlassStyle =
        "background: var(--app-glass-bg); " +
        "border: 1px solid var(--app-glass-border); " +
        "backdrop-filter: blur(10px); " +
        "-webkit-backdrop-filter: blur(10px); " +
        "border-radius: 12px; " +
        "padding: 32px;";

    private const string SlotCardStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 8px; " +
        "padding: 16px; " +
        "height: 100%;";

    private const string SlotBadgeStyle =
        "width: 22px; height: 22px; border-radius: 50%; " +
        "background: var(--mud-palette-primary); " +
        "color: white; font-size: 0.7rem; font-weight: 700; " +
        "display: flex; align-items: center; justify-content: center; " +
        "flex-shrink: 0;";

    private const string ProviderCardStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 8px; " +
        "padding: 12px 16px; " +
        "margin-bottom: 8px;";

    private const string ExpandedSectionStyle =
        "margin-top: 12px; " +
        "padding-top: 12px; " +
        "border-top: 1px solid var(--app-glass-inner-border);";
}
