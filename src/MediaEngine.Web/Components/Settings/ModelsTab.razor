@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator

@* ModelsTab — AI model management dashboard.
   Displays hardware profile card, then three model cards (text_fast, text_quality, audio)
   with status indicators, RAM/size info, and download/load/unload/delete actions.
   Also shows models directory config and idle-unload settings. *@

<div style="width: 100%; padding: 24px; box-sizing: border-box;">

    @* ── Header ────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Memory" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">AI Models</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Download, load, and manage the local AI models that power intelligent features.
        Models run entirely on your machine — no data leaves.
    </MudText>

    @* ── Hardware Profile ─────────────────────────────────────────────── *@
    <MudPaper Class="pa-4 mb-4" Style="background: rgba(255,255,255,0.03); border: 1px solid rgba(201,146,46,0.2); border-radius: 12px;">
        <div class="d-flex align-center justify-space-between mb-3">
            <MudText Typo="Typo.h6" Style="color: #C9922E;">Hardware Profile</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                       OnClick="RunBenchmark" Disabled="@_benchmarking">
                @if (_benchmarking)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Re-run Benchmark
            </MudButton>
        </div>

        @if (_profile is not null)
        {
            <div class="d-flex gap-6 flex-wrap">
                @* Tier Badge *@
                <div>
                    <MudText Typo="Typo.caption" Style="opacity: 0.5;">PERFORMANCE TIER</MudText>
                    <MudChip T="string" Color="@GetTierColor(_profile.Tier)" Size="Size.Large"
                             Style="font-weight: 600; font-size: 1.1rem; text-transform: uppercase;">
                        @_profile.Tier
                    </MudChip>
                </div>

                @* Backend *@
                <div>
                    <MudText Typo="Typo.caption" Style="opacity: 0.5;">COMPUTE BACKEND</MudText>
                    <MudText Typo="Typo.body1">
                        @(_profile.GpuName ?? (_profile.Backend == "cpu" ? "CPU Only" : _profile.Backend.ToUpper()))
                    </MudText>
                </div>

                @* Speed *@
                <div>
                    <MudText Typo="Typo.caption" Style="opacity: 0.5;">INFERENCE SPEED</MudText>
                    <MudText Typo="Typo.body1">@_profile.TokensPerSecond.ToString("F1") tok/s</MudText>
                </div>

                @* RAM *@
                <div>
                    <MudText Typo="Typo.caption" Style="opacity: 0.5;">AVAILABLE MEMORY</MudText>
                    <MudText Typo="Typo.body1">@FormatRam(_profile.AvailableRamMb)</MudText>
                </div>

                @* Last Benchmark *@
                @if (_profile.BenchmarkedAt.HasValue)
                {
                    <div>
                        <MudText Typo="Typo.caption" Style="opacity: 0.5;">LAST BENCHMARK</MudText>
                        <MudText Typo="Typo.body1">@_profile.BenchmarkedAt.Value.ToLocalTime().ToString("g")</MudText>
                    </div>
                }
            </div>
        }
        else
        {
            <MudText Typo="Typo.body2" Style="opacity: 0.5;">
                No benchmark data yet — the Engine will benchmark automatically on first startup.
            </MudText>
        }
    </MudPaper>

    @* ── Resource Monitor ────────────────────────────────────────────────── *@
    <MudPaper Class="pa-4 mb-4" Style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px;">
        <MudText Typo="Typo.subtitle2" Style="font-weight: 600; margin-bottom: 12px;">Resource Monitor</MudText>
        <div class="d-flex gap-6 flex-wrap">
            <div>
                <MudText Typo="Typo.caption" Style="opacity: 0.5;">ENGINE RAM</MudText>
                <MudText Typo="Typo.body1">@FormatRam(_resources?.EngineRamMb ?? 0)</MudText>
            </div>
            <div>
                <MudText Typo="Typo.caption" Style="opacity: 0.5;">FREE RAM</MudText>
                <MudText Typo="Typo.body1">@FormatRam(_resources?.FreeRamMb ?? 0)</MudText>
            </div>
            <div>
                <MudText Typo="Typo.caption" Style="opacity: 0.5;">CPU PRESSURE</MudText>
                <MudChip T="string" Size="Size.Small" Color="@CpuPressureColor(_resources?.CpuPressure ?? 1)">
                    @CpuPressureLabel(_resources?.CpuPressure ?? 1)
                </MudChip>
            </div>
            <div>
                <MudText Typo="Typo.caption" Style="opacity: 0.5;">TRANSCODING</MudText>
                <MudChip T="string" Size="Size.Small"
                         Color="@(_resources?.TranscodingActive == true ? Color.Error : Color.Success)">
                    @(_resources?.TranscodingActive == true ? "Active" : "Idle")
                </MudChip>
            </div>
        </div>
    </MudPaper>

    @* ── Model Cards Grid ───────────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-6">
        @foreach (var model in _models)
        {
            var m = model; @* capture for lambda *@
            <MudItem xs="12" md="3">
                <div style="@ModelCardStyle">

                    @* Role badge *@
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@RoleBadgeColor(m.Role)"
                             Style="margin-bottom: 12px; font-family: monospace; font-size: 0.75rem;">
                        @m.Role
                    </MudChip>

                    @* Model name *@
                    <MudText Typo="Typo.subtitle1"
                             Style="font-weight: 700; margin-bottom: 4px;">
                        @m.ModelName
                    </MudText>

                    @* Purpose *@
                    <MudText Typo="Typo.body2"
                             Color="Color.Secondary"
                             Style="margin-bottom: 16px; min-height: 38px;">
                        @m.Purpose
                    </MudText>

                    @* Status indicator *@
                    <MudStack Row="true" AlignItems="AlignItems.Center"
                              Spacing="2" Style="margin-bottom: 12px;">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@StatusChipColor(m.Status)">
                            @m.Status
                        </MudChip>
                    </MudStack>

                    @* Metrics row *@
                    <MudStack Row="true" Spacing="4" Style="margin-bottom: 16px;">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">RAM</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@m.RamUsage</MudText>
                        </MudStack>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Size</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@m.FileSize</MudText>
                        </MudStack>
                    </MudStack>

                    @* Download progress bar (shown only when downloading) *@
                    @if (m.Status == ModelStatus.Downloading)
                    {
                        <MudProgressLinear Value="@m.DownloadProgress"
                                           Color="Color.Primary"
                                           Rounded="true"
                                           Size="Size.Small"
                                           Style="margin-bottom: 12px;" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                 Style="margin-bottom: 12px;">
                            Downloading… @m.DownloadProgress%
                        </MudText>
                    }

                    @* Action buttons *@
                    <MudStack Row="true" AlignItems="AlignItems.Center"
                              Spacing="1" Style="flex-wrap: wrap; gap: 4px;">

                        @* Download — only when not downloaded *@
                        @if (m.Status == ModelStatus.NotDownloaded)
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Outlined.Download"
                                       OnClick="@(() => SimulateDownload(m))">
                                Download
                            </MudButton>
                        }

                        @* Load — when downloaded but not loaded *@
                        @if (m.Status == ModelStatus.Downloaded)
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Outlined"
                                       Color="Color.Info"
                                       StartIcon="@Icons.Material.Outlined.PlayCircleOutline"
                                       OnClick="@(() => ChangeStatus(m, ModelStatus.Loaded))">
                                Load
                            </MudButton>
                        }

                        @* Unload — when currently loaded or active *@
                        @if (m.Status is ModelStatus.Loaded or ModelStatus.Active)
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Outlined"
                                       Color="Color.Warning"
                                       StartIcon="@Icons.Material.Outlined.PauseCircleOutline"
                                       OnClick="@(() => ChangeStatus(m, ModelStatus.Downloaded))">
                                Unload
                            </MudButton>
                        }

                        @* Spacer *@
                        <MudSpacer />

                        @* Delete — only when downloaded (and not currently active) *@
                        @if (m.Status is ModelStatus.Downloaded or ModelStatus.Loaded)
                        {
                            <MudTooltip Text="Delete model files from disk">
                                <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => ChangeStatus(m, ModelStatus.NotDownloaded))" />
                            </MudTooltip>
                        }

                    </MudStack>

                </div>
            </MudItem>
        }
    </MudGrid>

    @* ── Configuration card ─────────────────────────────────────────────── *@
    <div style="@ModelCardStyle">

        <MudText Typo="Typo.subtitle2" Style="font-weight: 600; margin-bottom: 16px;">
            Storage &amp; Runtime Settings
        </MudText>

        <MudTextField Value="@_modelsDirectory"
                      Label="Models Directory"
                      Variant="Variant.Outlined"
                      ReadOnly="true"
                      FullWidth="true"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.FolderOpen"
                      Class="mb-4" />

        <MudNumericField @bind-Value="_idleTimeoutSeconds"
                         Label="Idle auto-unload timeout (seconds)"
                         Variant="Variant.Outlined"
                         FullWidth="true"
                         Min="60"
                         Max="3600"
                         Step="60"
                         HelperText="Unload model from RAM after this many seconds of inactivity."
                         Class="mb-4" />

        <MudSwitch @bind-Value="_gpuEnabled"
                   Label="GPU Acceleration (CUDA / Vulkan)"
                   Color="Color.Primary" />
        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top: 4px;">
            @if (_profile is not null && _profile.Backend != "cpu")
            {
                <span style="color: rgba(100,200,100,0.8);">Active — using @(_profile.Backend.ToUpper()) on @(_profile.GpuName ?? "GPU")</span>
            }
            else
            {
                <span>CPU inference active. A dedicated GPU (NVIDIA, AMD, or Intel Arc) enables 6-7× faster inference.</span>
            }
        </MudText>

    </div>

</div>

@code {

    // ── Hardware Profile ──────────────────────────────────────────────────────────

    private HardwareProfileDto?  _profile;
    private bool                 _benchmarking;
    private ResourceSnapshotDto? _resources;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _profile   = await Orchestrator.GetAiProfileAsync();
        _resources = await Orchestrator.GetResourceSnapshotAsync();
    }

    private async Task RunBenchmark()
    {
        _benchmarking = true;
        StateHasChanged();
        _profile      = await Orchestrator.RunBenchmarkAsync();
        _benchmarking = false;
        StateHasChanged();
    }

    private static Color GetTierColor(string tier) => tier.ToLowerInvariant() switch
    {
        "high"   => Color.Success,
        "medium" => Color.Warning,
        "low"    => Color.Error,
        _        => Color.Default,
    };

    private static string FormatRam(long mb) =>
        mb >= 1024 ? $"{mb / 1024.0:F1} GB" : $"{mb} MB";

    private static Color CpuPressureColor(int pressure) => pressure switch
    {
        >= 3 => Color.Error,
        >= 2 => Color.Warning,
        _    => Color.Success,
    };

    private static string CpuPressureLabel(int pressure) => pressure switch
    {
        >= 3 => "High",
        >= 2 => "Moderate",
        _    => "Low",
    };

    // ── Styles ────────────────────────────────────────────────────────────────────

    private const string ModelCardStyle =
        "background: rgba(255,255,255,0.04); " +
        "border: 1px solid rgba(255,255,255,0.08); " +
        "border-radius: 10px; " +
        "padding: 20px; " +
        "height: 100%;";

    // ── Model status enum ─────────────────────────────────────────────────────────

    private enum ModelStatus
    {
        NotDownloaded,
        Downloading,
        Downloaded,
        Loaded,
        Active
    }

    // ── Model descriptor ──────────────────────────────────────────────────────────

    private sealed class ModelInfo
    {
        public string      Role             { get; init; } = string.Empty;
        public string      ModelName        { get; init; } = string.Empty;
        public string      Purpose          { get; init; } = string.Empty;
        public ModelStatus Status           { get; set; }
        public string      RamUsage         { get; init; } = string.Empty;
        public string      FileSize         { get; init; } = string.Empty;
        public int         DownloadProgress { get; set; }
    }

    // ── State ─────────────────────────────────────────────────────────────────────

    private readonly List<ModelInfo> _models =
    [
        new()
        {
            Role      = "text_fast",
            ModelName = "Llama 3.2 1B Q4_K_M",
            Purpose   = "Powers search and quick tasks",
            Status    = ModelStatus.Active,
            RamUsage  = "~750MB",
            FileSize  = "~750MB",
        },
        new()
        {
            Role      = "text_quality",
            ModelName = "Llama 3.2 3B Q4_K_M",
            Purpose   = "Powers ingestion and metadata",
            Status    = ModelStatus.Loaded,
            RamUsage  = "~2.4GB",
            FileSize  = "~2GB",
        },
        new()
        {
            Role      = "text_scholar",
            ModelName = "Llama 3.1 8B Q4_K_M",
            Purpose   = "Deep enrichment — themes, mood, people extraction",
            Status    = ModelStatus.Downloaded,
            RamUsage  = "~4.9GB",
            FileSize  = "~4.6GB",
        },
        new()
        {
            Role      = "audio",
            ModelName = "Whisper Medium",
            Purpose   = "Transcription and language detection",
            Status    = ModelStatus.Downloaded,
            RamUsage  = "~1.5GB",
            FileSize  = "~1.5GB",
        },
    ];

    private string _modelsDirectory    = "/models";
    private int    _idleTimeoutSeconds = 300;
    private bool   _gpuEnabled;

    // ── Helpers ───────────────────────────────────────────────────────────────────

    private static Color RoleBadgeColor(string role) => role switch
    {
        "text_fast"    => Color.Info,
        "text_quality" => Color.Primary,
        "text_scholar" => Color.Warning,
        "audio"        => Color.Secondary,
        _              => Color.Default,
    };

    private static Color StatusChipColor(ModelStatus status) => status switch
    {
        ModelStatus.Active        => Color.Success,
        ModelStatus.Loaded        => Color.Info,
        ModelStatus.Downloaded    => Color.Default,
        ModelStatus.Downloading   => Color.Warning,
        ModelStatus.NotDownloaded => Color.Warning,
        _                         => Color.Default,
    };

    private static string StatusLabel(ModelStatus status) => status switch
    {
        ModelStatus.Active        => "Active",
        ModelStatus.Loaded        => "Loaded",
        ModelStatus.Downloaded    => "Downloaded",
        ModelStatus.Downloading   => "Downloading",
        ModelStatus.NotDownloaded => "Not Downloaded",
        _                         => "Unknown",
    };

    // ── Actions ───────────────────────────────────────────────────────────────────

    private void ChangeStatus(ModelInfo model, ModelStatus newStatus)
    {
        model.Status = newStatus;
        StateHasChanged();
    }

    private async Task SimulateDownload(ModelInfo model)
    {
        model.Status = ModelStatus.Downloading;
        model.DownloadProgress = 0;
        StateHasChanged();

        // Simulate progress in increments
        while (model.DownloadProgress < 100)
        {
            await Task.Delay(80);
            model.DownloadProgress = Math.Min(100, model.DownloadProgress + 10);
            StateHasChanged();
        }

        model.Status = ModelStatus.Downloaded;
        StateHasChanged();
    }
}
