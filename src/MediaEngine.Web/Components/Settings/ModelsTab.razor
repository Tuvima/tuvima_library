@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator

<div class="tl-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">Models</MudText>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="RefreshAsync" Disabled="_loading">Refresh</MudButton>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <MudAlert Severity="@_messageSeverity" Variant="Variant.Outlined" Class="mb-3">@_message</MudAlert>
    }

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Rounded="false" />
    }
    else if (_models.Count == 0)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Model status unavailable.</MudAlert>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var model in _models.OrderBy(m => m.Role))
            {
                <MudItem xs="12" md="6" lg="4">
                    <MudPaper Elevation="0" Class="tl-card pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@model.Role</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="@StateColor(model)">@StateLabel(model)</MudChip>
                        </MudStack>
                        <MudText Typo="Typo.subtitle2">@(!string.IsNullOrWhiteSpace(model.Description) ? model.Description : "Configured model")</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">@model.ModelFile</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Size: @FormatMb(model.SizeMB). Source: @(model.DownloadUrlHost ?? "not configured"). Required tier: @model.RequiredHardwareTier.</MudText>

                        @if (model.State.Equals("Downloading", StringComparison.OrdinalIgnoreCase))
                        {
                            <MudProgressLinear Value="@model.DownloadProgressPercent" Color="Color.Primary" Rounded="false" Class="mt-3" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@model.DownloadProgressPercent% downloaded</MudText>
                        }

                        @if (!string.IsNullOrWhiteSpace(model.ErrorMessage))
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mt-3">@model.ErrorMessage</MudAlert>
                        }

                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-3">Used by enabled features: @UsedBy(model.Role)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Memory footprint: @(model.MemoryFootprintMB > 0 ? FormatMb(model.MemoryFootprintMB) : "not loaded").</MudText>

                        @if (!model.Supported)
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-3">Configured, but lifecycle endpoints do not support this role.</MudAlert>
                        }
                        else
                        {
                            <MudStack Row="true" Spacing="1" Class="mt-3" Style="flex-wrap: wrap;">
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Download"
                                           Disabled="@(!CanDownload(model))" OnClick="@(() => RunAction(model.Role, AiModelAction.Download))">Download</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Outlined.Cancel"
                                           Disabled="@(!CanCancel(model))" OnClick="@(() => RunAction(model.Role, AiModelAction.Cancel))">Cancel</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Outlined.PlayArrow"
                                           Disabled="@(!CanLoad(model))" OnClick="@(() => RunAction(model.Role, AiModelAction.Load))">Load</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Outlined.Stop"
                                           Disabled="@(!CanUnload(model))" OnClick="@(() => RunAction(model.Role, AiModelAction.Unload))">Unload</MudButton>
                            </MudStack>
                        }
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-4">
        Delete is not shown because the Engine has no public model deletion endpoint. Local model downloads do not imply cloud inference.
    </MudAlert>
</div>

@code {
    private List<AiModelStatusDto> _models = [];
    private AiConfigDto? _config;
    private bool _loading;
    private string? _message;
    private Severity _messageSeverity = Severity.Info;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        _loading = true;
        _models = (await Orchestrator.GetAiModelStatusesAsync()).ToList();
        _config = await Orchestrator.GetAiConfigAsync();
        _loading = false;
    }

    private async Task RunAction(string role, AiModelAction action)
    {
        _message = null;
        var ok = action switch
        {
            AiModelAction.Download => await Orchestrator.StartAiModelDownloadAsync(role),
            AiModelAction.Cancel => await Orchestrator.CancelAiModelDownloadAsync(role),
            AiModelAction.Load => await Orchestrator.LoadAiModelAsync(role),
            AiModelAction.Unload => await Orchestrator.UnloadAiModelAsync(role),
            _ => false,
        };

        _messageSeverity = ok ? Severity.Success : Severity.Error;
        _message = ok ? $"{action} requested for {role}." : $"{action} failed for {role}. State was not changed locally.";
        await RefreshAsync();
    }

    private string UsedBy(string role)
    {
        if (_config is null)
            return "unknown";

        var names = FeatureDefinitions()
            .Where(f => string.Equals(f.RequiredModelRole, role, StringComparison.OrdinalIgnoreCase))
            .Where(f => _config.Features.TryGetValue(f.Key, out var enabled) && enabled)
            .Select(f => f.Name)
            .ToList();

        return names.Count == 0 ? "none currently enabled" : string.Join(", ", names);
    }

    private static bool CanDownload(AiModelStatusDto m) =>
        m.Supported && IsState(m, "NotDownloaded", "Error") && !string.IsNullOrWhiteSpace(m.ModelFile);

    private static bool CanCancel(AiModelStatusDto m) => m.Supported && IsState(m, "Downloading");

    private static bool CanLoad(AiModelStatusDto m) => m.Supported && IsState(m, "Ready") && !m.Loaded;

    private static bool CanUnload(AiModelStatusDto m) => m.Supported && (m.Loaded || m.Active || IsState(m, "Loaded"));

    private static bool IsState(AiModelStatusDto m, params string[] states) =>
        states.Any(s => string.Equals(m.State, s, StringComparison.OrdinalIgnoreCase));

    private static string StateLabel(AiModelStatusDto model) => model.Active ? "Active" : model.Loaded ? "Loaded" : model.State;

    private static Color StateColor(AiModelStatusDto model) => StateLabel(model).ToLowerInvariant() switch
    {
        "active" or "loaded" or "ready" => Color.Success,
        "downloading" => Color.Info,
        "error" => Color.Error,
        _ => Color.Warning,
    };

    private static string FormatMb(long mb) => mb >= 1024 ? $"{mb / 1024.0:F1} GB" : $"{mb} MB";

    private enum AiModelAction { Download, Cancel, Load, Unload }

    private sealed record FeatureDefinition(string Key, string Name, string RequiredModelRole);

    private static IReadOnlyList<FeatureDefinition> FeatureDefinitions() =>
    [
        new("smart_labeling", "Smart labeling", "text_fast"),
        new("type_logic", "Type logic", "text_fast"),
        new("audio_language_detection", "Audio language detection", "audio"),
        new("qid_disambiguation", "QID disambiguation", "text_quality"),
        new("series_alignment", "Series alignment", "text_quality"),
        new("watching_order", "Watching order", "text_fast"),
        new("vibe_tags", "Vibe tags", "text_quality"),
        new("tldr", "TL;DR", "text_fast"),
        new("cover_art_validation", "Cover art validation", "text_quality"),
        new("whisper_alignment", "Whisper alignment", "audio"),
        new("subtitle_sync", "Subtitle sync", "audio"),
        new("taste_profiling", "Taste profiling", "text_quality"),
        new("why_factor", "Why factor", "text_fast"),
        new("intent_search", "Intent search", "text_fast"),
        new("url_paste", "URL paste", "text_quality"),
        new("description_intelligence", "Description intelligence", "text_scholar"),
    ];
}
