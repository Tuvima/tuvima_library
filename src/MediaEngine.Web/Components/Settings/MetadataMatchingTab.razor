@namespace MediaEngine.Web.Components.Settings

<div class="tl-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudText Typo="Typo.h6">Metadata & Matching</MudText>
        <SettingsStatusBadge Status="SettingsStatusKind.Partial" />
        <MudSpacer />
        <MudButton Href="/settings/providers"
                   Variant="Variant.Text"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Outlined.Collections">
            Provider settings
        </MudButton>
    </MudStack>
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        Catalog, Wikidata, hydration, media type, and pipeline settings below are Engine/config backed where their tab exposes a save action. Matching-rule controls without persistence are disabled and marked not connected.
    </MudAlert>
    <MudTabs Rounded="true" Elevation="0" Color="Color.Primary" Position="Position.Top" Class="settings-tab-strip">
        <MudTabPanel Text="Catalog & Media Rules" Icon="@Icons.Material.Outlined.Category">
            <SettingsCatalogTab />
        </MudTabPanel>
        <MudTabPanel Text="Canonical Identity & Wikidata" Icon="@Icons.Material.Outlined.Public">
            <WikidataConfigTab />
        </MudTabPanel>
        <MudTabPanel Text="Matching Rules" Icon="@Icons.Material.Outlined.Rule">
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                Not connected. These threshold controls are intentionally read-only until the scoring/review persistence API exposes exact live thresholds used by ingestion and Review Queue routing.
            </MudAlert>
            <MudGrid Spacing="4">
                <MudItem xs="12" md="4"><MudNumericField T="int" @bind-Value="_autoAcceptThreshold" Label="Auto-accept threshold" Variant="Variant.Outlined" Min="0" Max="100" Disabled="true" HelperText="Not connected - will affect ingestion and canonical identity once backed by scoring config." /></MudItem>
                <MudItem xs="12" md="4"><MudNumericField T="int" @bind-Value="_needsReviewThreshold" Label="Needs-review threshold" Variant="Variant.Outlined" Min="0" Max="100" Disabled="true" HelperText="Not connected - Review Queue routing remains Engine-owned." /></MudItem>
                <MudItem xs="12" md="4"><MudNumericField T="int" @bind-Value="_duplicateThreshold" Label="Duplicate detection threshold" Variant="Variant.Outlined" Min="0" Max="100" Disabled="true" HelperText="Not connected - duplicate review behavior is not editable here." /></MudItem>
                <MudItem xs="12" md="6"><MudSelect T="string" @bind-Value="_titleStrictness" Label="Title fuzzy matching strictness" Variant="Variant.Outlined" Disabled="true"><MudSelectItem T="string" Value="@("balanced")">Balanced</MudSelectItem><MudSelectItem T="string" Value="@("strict")">Strict</MudSelectItem><MudSelectItem T="string" Value="@("loose")">Loose</MudSelectItem></MudSelect></MudItem>
                <MudItem xs="12" md="6"><MudSelect T="string" @bind-Value="_editionPreference" Label="Edition/work matching preference" Variant="Variant.Outlined" Disabled="true"><MudSelectItem T="string" Value="@("edition-first")">Edition first</MudSelectItem><MudSelectItem T="string" Value="@("work-first")">Work first</MudSelectItem></MudSelect></MudItem>
                <MudItem xs="12" md="6"><MudSelect T="string" @bind-Value="_languageBehavior" Label="Language matching behavior" Variant="Variant.Outlined" Disabled="true"><MudSelectItem T="string" Value="@("prefer-profile")">Prefer profile language</MudSelectItem><MudSelectItem T="string" Value="@("original")">Prefer original language</MudSelectItem></MudSelect></MudItem>
                <MudItem xs="12" md="6"><MudSwitch T="bool" @bind-Value="_disambiguateAudiobookBook" Color="Color.Primary" Label="Disambiguate audiobook vs book editions" Disabled="true" /></MudItem>
                <MudItem xs="12" md="6"><MudSwitch T="bool" @bind-Value="_strictPersonIdentity" Color="Color.Primary" Label="Use stricter person identity matching" Disabled="true" /></MudItem>
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="Pipeline Rules" Icon="@Icons.Material.Outlined.AccountTree">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
                    Read-only summary. Provider matching order is live under Providers. Hydration behavior is live where the Wikidata tab exposes saved Engine config.
                </MudAlert>
                <MudSwitch T="bool" @bind-Value="_stage1RetailLookup" Color="Color.Primary" Label="Stage 1 retail lookup priority" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_stage2Wikidata" Color="Color.Primary" Label="Stage 2 Wikidata reconciliation" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_stage3Universe" Color="Color.Primary" Label="Stage 3 universe enrichment" Disabled="true" />
                <MudSelect T="string" @bind-Value="_artworkFallback" Label="Artwork fallback strategy" Variant="Variant.Outlined" Class="mt-3" Disabled="true"><MudSelectItem T="string" Value="@("provider-then-generated")">Provider, then generated</MudSelectItem><MudSelectItem T="string" Value="@("embedded-first")">Embedded first</MudSelectItem></MudSelect>
                <MudSelect T="string" @bind-Value="_providerFailureFallback" Label="Provider failure fallback behavior" Variant="Variant.Outlined" Class="mt-3" Disabled="true"><MudSelectItem T="string" Value="@("retry-later")">Retry later</MudSelectItem><MudSelectItem T="string" Value="@("review")">Send to review</MudSelectItem></MudSelect>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="Universe Rules" Icon="@Icons.Material.Outlined.Hub">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
                    Not connected. Universe controls are planned for a later phase and are disabled so they are not mistaken for saved Engine behavior.
                </MudAlert>
                <MudSwitch T="bool" @bind-Value="_enableUniverseGrouping" Color="Color.Primary" Label="Enable universe/franchise grouping" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_useWikidataUniverse" Color="Color.Primary" Label="Use Wikidata universe/franchise relationships" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_useSeriesRelationships" Color="Color.Primary" Label="Use series relationships" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_linkAdaptations" Color="Color.Primary" Label="Link adaptations across media types" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_showCharactersSeparately" Color="Color.Primary" Label="Show characters separately from cast/creators" Disabled="true" />
                <MudNumericField T="int" @bind-Value="_maxRelationshipDepth" Label="Maximum relationship depth" Variant="Variant.Outlined" Min="1" Max="5" Class="mt-3" Disabled="true" />
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="Review Thresholds" Icon="@Icons.Material.Outlined.RateReview">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
                    Review Queue remains the exception workflow. These summary controls are read-only until exact persisted review thresholds are exposed by the Engine.
                </MudAlert>
                <MudSwitch T="bool" @bind-Value="_missingArtReview" Color="Color.Primary" Label="Missing art goes to review" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_lowConfidenceReview" Color="Color.Primary" Label="Low confidence match goes to review" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_conflictingProvidersReview" Color="Color.Primary" Label="Conflicting provider results go to review" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_duplicatesReview" Color="Color.Primary" Label="Duplicate candidate goes to review" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_retryProvisionalItems" Color="Color.Primary" Label="Newly provisional items retry matching later" Disabled="true" />
                <MudButton Href="/settings/review" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.RateReview" Class="mt-4">Open review queue</MudButton>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
</div>

@code {
    private int _autoAcceptThreshold = 92;
    private int _needsReviewThreshold = 72;
    private int _duplicateThreshold = 88;
    private string _titleStrictness = "balanced";
    private string _editionPreference = "edition-first";
    private string _languageBehavior = "prefer-profile";
    private bool _disambiguateAudiobookBook = true;
    private bool _strictPersonIdentity = true;
    private bool _stage1RetailLookup = true;
    private bool _stage2Wikidata = true;
    private bool _stage3Universe = true;
    private string _artworkFallback = "provider-then-generated";
    private string _providerFailureFallback = "retry-later";
    private bool _enableUniverseGrouping = true;
    private bool _useWikidataUniverse = true;
    private bool _useSeriesRelationships = true;
    private bool _linkAdaptations = true;
    private bool _showCharactersSeparately = true;
    private int _maxRelationshipDepth = 2;
    private bool _missingArtReview = true;
    private bool _lowConfidenceReview = true;
    private bool _conflictingProvidersReview = true;
    private bool _duplicatesReview = true;
    private bool _retryProvisionalItems = true;
}
