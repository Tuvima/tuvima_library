@namespace MediaEngine.Web.Components.Settings

<div class="tl-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
        <MudText Typo="Typo.h6">Users & Access</MudText>
        <SettingsStatusBadge Status="SettingsStatusKind.Partial" />
    </MudStack>
    <MudTabs Rounded="true" Elevation="0" Color="Color.Primary" Position="Position.Top" Class="settings-tab-strip">
        <MudTabPanel Text="Profiles & Roles" Icon="@Icons.Material.Outlined.Group">
            <UsersTab />
        </MudTabPanel>
        <MudTabPanel Text="Sign-in & Security" Icon="@Icons.Material.Outlined.AdminPanelSettings">
            <SecurityTab />
        </MudTabPanel>
        <MudTabPanel Text="API Keys" Icon="@Icons.Material.Outlined.Key">
            <ApiKeysTab />
        </MudTabPanel>
        <MudTabPanel Text="Access Rules" Icon="@Icons.Material.Outlined.Policy">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                    Not connected. Local network, remote access, and rate-limit controls are read-only here until the Engine exposes persisted access-rule settings.
                </MudAlert>
                <MudTextField @bind-Value="_allowedNetworks" Label="Allowed local networks" Variant="Variant.Outlined" FullWidth="true" ReadOnly="true" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_remoteAccessEnabled" Color="Color.Primary" Label="Remote access enabled" Disabled="true" />
                <MudNumericField T="int" @bind-Value="_rateLimitPerMinute" Label="Rate limit per minute" Variant="Variant.Outlined" Min="10" Max="1000" Disabled="true" />
                <MudNumericField T="int" @bind-Value="_streamingLimit" Label="Streaming limits" Variant="Variant.Outlined" Min="1" Max="20" Disabled="true" />
                <MudSwitch T="bool" @bind-Value="_adminOnlyActions" Color="Color.Primary" Label="Restrict sensitive actions to admins" Disabled="true" />
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="Sessions" Icon="@Icons.Material.Outlined.Devices">
            <MudPaper Elevation="0" Class="tl-card pa-4">
                <MudTable Items="_sessions" Dense="true" Hover="true">
                    <HeaderContent><MudTh>Profile</MudTh><MudTh>Device</MudTh><MudTh>Last active</MudTh><MudTh></MudTh></HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Profile">@context.Profile</MudTd>
                        <MudTd DataLabel="Device">@context.Device</MudTd>
                        <MudTd DataLabel="Last active">@context.LastActive</MudTd>
                        <MudTd><MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" Disabled="true">Revoke</MudButton></MudTd>
                    </RowTemplate>
                </MudTable>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">
                    Planned. Session listing and revocation are not persisted by the Engine yet.
                </MudAlert>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
</div>

@code {
    private sealed record SessionRow(string Profile, string Device, string LastActive);

    private readonly SessionRow[] _sessions = [];
    private string _allowedNetworks = "192.168.0.0/16, 10.0.0.0/8";
    private bool _remoteAccessEnabled;
    private int _rateLimitPerMinute = 120;
    private int _streamingLimit = 4;
    private bool _adminOnlyActions = true;
}
