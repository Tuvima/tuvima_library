@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedStrings> L
<div class="tl-page">
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Group" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">@L["Users_PageTitle"]</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="@OpenCreateDialog"
                   Disabled="@_loading">
            @L["Users_NewProfile"]
        </MudButton>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        @L["Users_PageDescription"]
    </MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
    }
    else if (_allRows.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mt-2">
            @L["Users_NoProfiles"]
        </MudAlert>
    }
    else
    {
        <MudSimpleTable Dense="true" Hover="true" Striped="false"
                        Style="background: transparent;">
            <thead>
                <tr>
                    <th style="@ThStyle">@L["Users_ColAvatar"]</th>
                    <th style="@ThStyle">@L["Users_ColName"]</th>
                    <th style="@ThStyle">@L["Users_ColRole"]</th>
                    <th style="@ThStyle">Sign-in</th>
                    <th style="@ThStyle">@L["Users_ColLastActive"]</th>
                    <th style="@ThStyle">@L["Users_ColStatus"]</th>
                    <th style="@ThStyle text-align:right">@L["Users_ColActions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _allRows)
                {
                    <tr>
                        @* Avatar *@
                        <td style="@TdStyle">
                            <MudAvatar Size="Size.Small"
                                       Style="@($"background: {row.AvatarColor}; font-size: 0.75rem;")">
                                @(row.Initials)
                            </MudAvatar>
                        </td>

                        @* Name *@
                        <td style="@TdStyle">
                            <MudText Style="font-weight: 500;">@row.DisplayName</MudText>
                        </td>

                        @* Role badge *@
                        <td style="@TdStyle">
                            <MudChip T="string" Size="Size.Small"
                                     Color="@RoleColor(row.Role)"
                                     Style="font-size: 0.75rem;">
                                @row.Role
                            </MudChip>
                        </td>

                        <td style="@TdStyle">
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Style="font-size: 0.75rem;">
                                @(row.ExternalLoginCount == 0 ? "Local profile" : $"{row.ExternalLoginCount} linked")
                            </MudChip>
                        </td>

                        @* Last Active *@
                        <td style="@TdStyle">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @row.LastActive
                            </MudText>
                        </td>

                        @* Status pill *@
                        <td style="@TdStyle">
                            <div style="@StatusPillStyle(row.Status)">
                                @row.Status
                            </div>
                        </td>

                        @* Actions *@
                        <td style="@TdStyle text-align:right">
                            <MudIconButton Icon="@Icons.Material.Outlined.Link"
                                           Color="Color.Default"
                                           Size="Size.Medium"
                                           title="Manage sign-in accounts"
                                           Disabled="@row.Id.Equals(Guid.Empty)"
                                           OnClick="@(() => OpenExternalLoginsDialogAsync(row))" />
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                           Color="Color.Error"
                                           Size="Size.Medium"
                                           title="@L["Users_DeleteProfileTooltip"]"
                                           Disabled="@row.IsSeed"
                                           OnClick="@(() => DeleteProfileAsync(row))" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }

</div>
<MudDialog @bind-Visible="_createOpen" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" />
            @L["Users_CreateProfileTitle"]
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newDisplayName"
                      Label="@L["Users_DisplayNameLabel"]"
                      Placeholder="@L["Users_DisplayNamePlaceholder"]"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Immediate="true"
                      MaxLength="50"
                      Class="mb-4" />

        <MudSelect @bind-Value="_newRole"
                   Label="@L["Users_RoleLabel"]"
                   Variant="Variant.Outlined"
                   FullWidth="true"
                   Class="mb-4">
            <MudSelectItem Value="@("Administrator")">@L["Users_RoleAdministrator"]</MudSelectItem>
            <MudSelectItem Value="@("Curator")">@L["Users_RoleCurator"]</MudSelectItem>
            <MudSelectItem Value="@("Consumer")">@L["Users_RoleConsumer"]</MudSelectItem>
        </MudSelect>

        @* Preview *@
        <MudStack AlignItems="AlignItems.Center" Class="mt-4">
            <MudAvatar Size="Size.Large"
                       Style="@($"background: {_newAvatarColor}; width: 64px; height: 64px; font-size: 1.5rem;")">
                @(_newDisplayName.Length > 0 ? _newDisplayName[0].ToString().ToUpper() : "?")
            </MudAvatar>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseCreateDialog">@L["Users_Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(_newDisplayName) || _creating)"
                   OnClick="@CreateProfileAsync">
            @(_creating ? L["Users_Creating"] : L["Users_Create"])
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_externalLoginsOpen" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Outlined.Link" Class="mr-2" />
            Sign-in accounts
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_selectedUser is not null)
        {
            <MudText Typo="Typo.subtitle2" Class="mb-3">@_selectedUser.DisplayName</MudText>
        }

        @if (_externalLoginsLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }
        else if (_externalLogins.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                No SSO or OAuth accounts are linked to this profile yet.
            </MudAlert>
        }
        else
        {
            <MudStack Spacing="2" Class="mb-4">
                @foreach (var login in _externalLogins)
                {
                    <MudPaper Elevation="0" Class="tl-card tl-card--compact">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudStack Spacing="0" Style="flex:1; min-width: 0;">
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@login.Provider</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    @(login.Email ?? login.DisplayName ?? login.Subject)
                                </MudText>
                            </MudStack>
                            <MudIconButton Icon="@Icons.Material.Outlined.LinkOff"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           title="Unlink account"
                                           OnClick="@(() => UnlinkExternalLoginAsync(login.Id))" />
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }

        <MudDivider Class="my-4" />
        <MudText Typo="Typo.subtitle2" Class="mb-3">Link account manually</MudText>
        <MudTextField @bind-Value="_newLoginProvider"
                      Label="Provider"
                      Placeholder="oidc, google, microsoft, authentik"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Class="mb-3" />
        <MudTextField @bind-Value="_newLoginSubject"
                      Label="Subject"
                      Placeholder="Stable user ID from the identity provider"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Class="mb-3" />
        <MudTextField @bind-Value="_newLoginEmail"
                      Label="Email"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Class="mb-3" />
        <MudTextField @bind-Value="_newLoginDisplayName"
                      Label="Display name"
                      Variant="Variant.Outlined"
                      FullWidth="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseExternalLoginsDialog">Close</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(_selectedUser is null || string.IsNullOrWhiteSpace(_newLoginProvider) || string.IsNullOrWhiteSpace(_newLoginSubject) || _linkingExternalLogin)"
                   OnClick="@LinkExternalLoginAsync">
            @(_linkingExternalLogin ? "Linking" : "Link account")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    private const string ThStyle =
        "padding: 12px 16px; " +
        "font-size: 0.75rem; " +
        "text-transform: uppercase; " +
        "letter-spacing: 0.08em; " +
        "color: var(--mud-palette-text-secondary); " +
        "border-bottom: 1px solid var(--app-glass-border);";

    private const string TdStyle =
        "padding: 14px 16px; " +
        "border-bottom: 1px solid var(--tl-divider); " +
        "vertical-align: middle;";

    private const string LinkedAccountStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 8px; " +
        "padding: 12px;";

    private sealed record UserRow(
        Guid   Id,
        string DisplayName,
        string Initials,
        string AvatarColor,
        string Role,
        int    ExternalLoginCount,
        string LastActive,
        string Status,
        bool   IsSeed);

    private bool           _loading  = true;
    private List<UserRow>  _allRows  = [];
    private bool   _createOpen;
    private bool   _creating;
    private string _newDisplayName = string.Empty;
    private string _newRole        = "Consumer";
    private string _newAvatarColor = "#7C4DFF";
    private bool   _externalLoginsOpen;
    private bool   _externalLoginsLoading;
    private bool   _linkingExternalLogin;
    private UserRow? _selectedUser;
    private List<ProfileExternalLoginViewModel> _externalLogins = [];
    private string _newLoginProvider = string.Empty;
    private string _newLoginSubject = string.Empty;
    private string? _newLoginEmail;
    private string? _newLoginDisplayName;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth         = MaxWidth.Small,
        FullWidth        = true,
        CloseOnEscapeKey = true,
    };

    protected override async Task OnInitializedAsync()
    {
        await RefreshProfilesAsync();
    }

    private static Color RoleColor(string role) => role switch
    {
        "Administrator" => Color.Primary,
        "Curator"       => Color.Info,
        "Consumer"      => Color.Default,
        "Viewer"        => Color.Default,
        "Reviewer"      => Color.Warning,
        _               => Color.Default,
    };

    private static string StatusPillStyle(string status)
    {
        var (bg, color) = status switch
        {
            "Active"  => ("var(--tl-status-success-soft)", "var(--tl-status-success)"),
            "Pending" => ("var(--tl-status-warning-soft)",  "var(--tl-status-warning)"),
            _         => ("var(--tl-status-idle-soft)", "var(--tl-text-muted)"),
        };
        return $"display: inline-block; padding: 2px 10px; border-radius: 9999px; " +
               $"background: {bg}; color: {color}; font-size: 0.75rem; font-weight: 500;";
    }

    private static string GetInitials(string displayName)
    {
        var parts = displayName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][0].ToString().ToUpper(),
            _ => $"{parts[0][0]}{parts[^1][0]}".ToUpper(),
        };
    }

    private async Task RefreshProfilesAsync()
    {
        _loading = true;

        var profiles = await Orchestrator.GetProfilesAsync();
        if (profiles.Count > 0)
        {
            var rows = new List<UserRow>();
            foreach (var p in profiles)
            {
                var linkedAccounts = await Orchestrator.GetProfileExternalLoginsAsync(p.Id);
                rows.Add(new UserRow(
                    p.Id,
                    p.DisplayName,
                    GetInitials(p.DisplayName),
                    p.AvatarColor,
                    p.Role,
                    linkedAccounts.Count,
                    p.CreatedAt.LocalDateTime.ToString("MMM d, yyyy"),
                    "Active",
                    p.IsSeed));
            }

            _allRows = rows;
        }
        else
        {
            _allRows =
            [
                new(Guid.Empty, "Bob Smith",    "BS", "#7C4DFF", "Administrator", 0, "Now",        "Active",  true),
                new(Guid.Empty, "Alice Chen",   "AC", "#00BFA5", "Viewer",        0, "2 days ago", "Active",  false),
                new(Guid.Empty, "Charlie Dave", "CD", "#FF8F00", "Reviewer",      0, "1 week ago", "Pending", false),
            ];
        }

        _loading = false;
    }

    private void OpenCreateDialog()
    {
        _newDisplayName = string.Empty;
        _newRole        = "Consumer";
        _newAvatarColor = "#7C4DFF";
        _createOpen     = true;
    }

    private void CloseCreateDialog()
    {
        _createOpen     = false;
        _newDisplayName = string.Empty;
    }

    private async Task CreateProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(_newDisplayName)) return;
        _creating = true;

        var ok = await Orchestrator.CreateProfileAsync(
            _newDisplayName.Trim(), _newAvatarColor, _newRole);

        _creating = false;

        if (ok)
        {
            Snackbar.Add($"Profile \"{_newDisplayName.Trim()}\" created", Severity.Success);
            _createOpen = false;
            await RefreshProfilesAsync();
        }
        else
        {
            Snackbar.Add(L["Users_CreateError"], Severity.Error);
        }
    }

    private async Task DeleteProfileAsync(UserRow row)
    {
        if (row.IsSeed || row.Id == Guid.Empty) return;

        var ok = await Orchestrator.DeleteProfileAsync(row.Id);
        if (ok)
        {
            Snackbar.Add($"Profile \"{row.DisplayName}\" deleted", Severity.Info);
            await RefreshProfilesAsync();
        }
        else
        {
            Snackbar.Add(L["Users_DeleteError"], Severity.Error);
        }
    }

    private async Task OpenExternalLoginsDialogAsync(UserRow row)
    {
        _selectedUser = row;
        _externalLoginsOpen = true;
        _externalLoginsLoading = true;
        ResetExternalLoginForm();
        _externalLogins = await Orchestrator.GetProfileExternalLoginsAsync(row.Id);
        _externalLoginsLoading = false;
    }

    private void CloseExternalLoginsDialog()
    {
        _externalLoginsOpen = false;
        _selectedUser = null;
        _externalLogins = [];
        ResetExternalLoginForm();
    }

    private async Task LinkExternalLoginAsync()
    {
        if (_selectedUser is null ||
            string.IsNullOrWhiteSpace(_newLoginProvider) ||
            string.IsNullOrWhiteSpace(_newLoginSubject))
        {
            return;
        }

        _linkingExternalLogin = true;
        var login = await Orchestrator.LinkProfileExternalLoginAsync(
            _selectedUser.Id,
            _newLoginProvider,
            _newLoginSubject,
            _newLoginEmail,
            _newLoginDisplayName);
        _linkingExternalLogin = false;

        if (login is null)
        {
            Snackbar.Add("Could not link sign-in account.", Severity.Error);
            return;
        }

        Snackbar.Add("Sign-in account linked.", Severity.Success);
        ResetExternalLoginForm();
        _externalLogins = await Orchestrator.GetProfileExternalLoginsAsync(_selectedUser.Id);
        await RefreshProfilesAsync();
    }

    private async Task UnlinkExternalLoginAsync(Guid loginId)
    {
        if (_selectedUser is null)
            return;

        var ok = await Orchestrator.UnlinkProfileExternalLoginAsync(loginId);
        if (!ok)
        {
            Snackbar.Add("Could not unlink sign-in account.", Severity.Error);
            return;
        }

        Snackbar.Add("Sign-in account unlinked.", Severity.Info);
        _externalLogins = await Orchestrator.GetProfileExternalLoginsAsync(_selectedUser.Id);
        await RefreshProfilesAsync();
    }

    private void ResetExternalLoginForm()
    {
        _newLoginProvider = string.Empty;
        _newLoginSubject = string.Empty;
        _newLoginEmail = null;
        _newLoginDisplayName = null;
    }

}
