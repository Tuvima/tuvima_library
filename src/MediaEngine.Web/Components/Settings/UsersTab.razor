@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedStrings> L

<div class="tl-page users-page">
    <AppActionBar Align="AppHorizontalAlignment.End" Class="users-page__actions mb-3">
        <AppButton Label="@L["Users_NewProfile"].Value"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   ButtonStyle="AppButtonStyle.Filled"
                   Tone="AppUiTone.Primary"
                   Disabled="@_loading"
                   OnClick="@OpenCreateDialog" />
    </AppActionBar>

    @if (_loading)
    {
        <AppProgressBar Indeterminate="true" Class="users-page__progress" />
    }
    else if (_allRows.Count == 0)
    {
        <AppEmptyState Title="@L["Users_NoProfiles"].Value" />
    }
    else
    {
        <AppTable Class="users-table">
            <thead>
                <tr>
                    <th>@L["Users_ColAvatar"]</th>
                    <th>@L["Users_ColName"]</th>
                    <th>@L["Users_ColRole"]</th>
                    <th>Sign-in</th>
                    <th>@L["Users_ColLastActive"]</th>
                    <th>@L["Users_ColStatus"]</th>
                    <th class="users-table__actions">@L["Users_ColActions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _allRows)
                {
                    <tr>
                        <td>
                            <AppAvatar Initials="@row.Initials"
                                       AccentColor="@row.AvatarColor"
                                       Size="AppControlSize.Compact"
                                       Title="@row.DisplayName" />
                        </td>
                        <td>
                            <div class="users-table__name">@row.DisplayName</div>
                        </td>
                        <td>
                            <AppChip Text="@row.Role" Tone="@RoleTone(row.Role)" />
                        </td>
                        <td>
                            <AppChip Text="@(row.ExternalLoginCount == 0 ? "Local profile" : $"{row.ExternalLoginCount} linked")" />
                        </td>
                        <td>
                            <span class="users-table__muted">@row.LastActive</span>
                        </td>
                        <td>
                            <AppStatusBadge Text="@row.Status" Tone="@StatusTone(row.Status)" />
                        </td>
                        <td class="users-table__actions">
                            <AppIconButton Icon="@Icons.Material.Outlined.Link"
                                           Tooltip="Manage sign-in accounts"
                                           AriaLabel="Manage sign-in accounts"
                                           Disabled="@row.Id.Equals(Guid.Empty)"
                                           OnClick="@(() => OpenExternalLoginsDialogAsync(row))" />
                            <AppIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                           Tooltip="@L["Users_DeleteProfileTooltip"].Value"
                                           AriaLabel="@L["Users_DeleteProfileTooltip"].Value"
                                           Tone="AppUiTone.Error"
                                           Disabled="@row.IsSeed"
                                           OnClick="@(() => DeleteProfileAsync(row))" />
                        </td>
                    </tr>
                }
            </tbody>
        </AppTable>
    }
</div>

<AppDialog @bind-Visible="_createOpen"
           Title="@L["Users_CreateProfileTitle"].Value"
           Icon="@Icons.Material.Filled.PersonAdd"
           Size="Small"
           Options="@_dialogOptions"
           OnClose="@CloseCreateDialog">
    <ChildContent>
        <AppForm>
            <AppTextField @bind-Value="_newDisplayName"
                          Label="@L["Users_DisplayNameLabel"].Value"
                          Placeholder="@L["Users_DisplayNamePlaceholder"].Value"
                          MaxLength="50" />

            <AppSelect T="string" @bind-Value="_newRole"
                       Label="@L["Users_RoleLabel"].Value"
                       Options="@RoleOptions" />

            <div class="users-dialog-preview">
                <AppAvatar Initials="@PreviewInitial"
                           AccentColor="@_newAvatarColor"
                           Size="AppControlSize.Large"
                           Title="@PreviewInitial" />
            </div>
        </AppForm>
    </ChildContent>
    <FooterContent>
        <AppActionBar>
            <AppButton Label="@L["Users_Cancel"].Value"
                       OnClick="@CloseCreateDialog" />
            <AppButton Label="@(_creating ? L["Users_Creating"].Value : L["Users_Create"].Value)"
                       ButtonStyle="AppButtonStyle.Filled"
                       Tone="AppUiTone.Primary"
                       Disabled="@(string.IsNullOrWhiteSpace(_newDisplayName) || _creating)"
                       OnClick="@CreateProfileAsync" />
        </AppActionBar>
    </FooterContent>
</AppDialog>

<AppDialog @bind-Visible="_externalLoginsOpen"
           Title="Sign-in accounts"
           Icon="@Icons.Material.Outlined.Link"
           Size="Small"
           Options="@_dialogOptions"
           OnClose="@CloseExternalLoginsDialog">
    <ChildContent>
        @if (_selectedUser is not null)
        {
            <div class="users-dialog-title">@_selectedUser.DisplayName</div>
        }

        @if (_externalLoginsLoading)
        {
            <AppProgressBar Indeterminate="true" Class="users-page__progress" />
        }
        else if (_externalLogins.Count == 0)
        {
            <AppAlert Tone="AppUiTone.Info">
                No SSO or OAuth accounts are linked to this profile yet.
            </AppAlert>
        }
        else
        {
            <div class="users-linked-list">
                @foreach (var login in _externalLogins)
                {
                    <AppCard Density="AppSurfaceDensity.Compact" Class="users-linked-account">
                        <div class="users-linked-account__body">
                            <div class="users-linked-account__provider">@login.Provider</div>
                            <div class="users-linked-account__identity">
                                @(login.Email ?? login.DisplayName ?? login.Subject)
                            </div>
                        </div>
                        <AppIconButton Icon="@Icons.Material.Outlined.LinkOff"
                                       Tooltip="Unlink account"
                                       AriaLabel="Unlink account"
                                       Tone="AppUiTone.Error"
                                       Size="AppControlSize.Compact"
                                       OnClick="@(() => UnlinkExternalLoginAsync(login.Id))" />
                    </AppCard>
                }
            </div>
        }

        <div class="users-dialog-divider"></div>
        <div class="users-dialog-title">Link account manually</div>
        <AppForm>
            <AppTextField @bind-Value="_newLoginProvider"
                          Label="Provider"
                          Placeholder="oidc, google, microsoft, authentik" />
            <AppTextField @bind-Value="_newLoginSubject"
                          Label="Subject"
                          Placeholder="Stable user ID from the identity provider" />
            <AppTextField @bind-Value="_newLoginEmail"
                          Label="Email" />
            <AppTextField @bind-Value="_newLoginDisplayName"
                          Label="Display name" />
        </AppForm>
    </ChildContent>
    <FooterContent>
        <AppActionBar>
            <AppButton Label="Close"
                       OnClick="@CloseExternalLoginsDialog" />
            <AppButton Label="@(_linkingExternalLogin ? "Linking" : "Link account")"
                       ButtonStyle="AppButtonStyle.Filled"
                       Tone="AppUiTone.Primary"
                       Disabled="@(_selectedUser is null || string.IsNullOrWhiteSpace(_newLoginProvider) || string.IsNullOrWhiteSpace(_newLoginSubject) || _linkingExternalLogin)"
                       OnClick="@LinkExternalLoginAsync" />
        </AppActionBar>
    </FooterContent>
</AppDialog>

@code {
    private sealed record UserRow(
        Guid   Id,
        string DisplayName,
        string Initials,
        string AvatarColor,
        string Role,
        int    ExternalLoginCount,
        string LastActive,
        string Status,
        bool   IsSeed);

    private bool           _loading  = true;
    private List<UserRow>  _allRows  = [];
    private bool   _createOpen;
    private bool   _creating;
    private string _newDisplayName = string.Empty;
    private string _newRole        = "Consumer";
    private string _newAvatarColor = "#7C4DFF";
    private bool   _externalLoginsOpen;
    private bool   _externalLoginsLoading;
    private bool   _linkingExternalLogin;
    private UserRow? _selectedUser;
    private List<ProfileExternalLoginViewModel> _externalLogins = [];
    private string _newLoginProvider = string.Empty;
    private string _newLoginSubject = string.Empty;
    private string? _newLoginEmail;
    private string? _newLoginDisplayName;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth         = MaxWidth.Small,
        FullWidth        = true,
        CloseOnEscapeKey = true,
    };

    private IReadOnlyList<AppSelectOption> RoleOptions =>
    [
        new("Administrator", L["Users_RoleAdministrator"].Value),
        new("Curator", L["Users_RoleCurator"].Value),
        new("Consumer", L["Users_RoleConsumer"].Value),
    ];

    private string PreviewInitial =>
        _newDisplayName.Length > 0 ? _newDisplayName[0].ToString().ToUpperInvariant() : "?";

    protected override async Task OnInitializedAsync()
    {
        await RefreshProfilesAsync();
    }

    private static AppUiTone RoleTone(string role) => role switch
    {
        "Administrator" => AppUiTone.Primary,
        "Curator"       => AppUiTone.Info,
        "Reviewer"      => AppUiTone.Warning,
        _               => AppUiTone.Neutral,
    };

    private static AppStatusTone StatusTone(string status) => status switch
    {
        "Active"  => AppStatusTone.Success,
        "Pending" => AppStatusTone.Warning,
        _         => AppStatusTone.Neutral,
    };

    private static string GetInitials(string displayName)
    {
        var parts = displayName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][0].ToString().ToUpper(),
            _ => $"{parts[0][0]}{parts[^1][0]}".ToUpper(),
        };
    }

    private async Task RefreshProfilesAsync()
    {
        _loading = true;

        var profiles = await Orchestrator.GetProfilesAsync();
        if (profiles.Count > 0)
        {
            var rows = new List<UserRow>();
            foreach (var p in profiles)
            {
                var linkedAccounts = await Orchestrator.GetProfileExternalLoginsAsync(p.Id);
                rows.Add(new UserRow(
                    p.Id,
                    p.DisplayName,
                    GetInitials(p.DisplayName),
                    p.AvatarColor,
                    p.Role,
                    linkedAccounts.Count,
                    p.CreatedAt.LocalDateTime.ToString("MMM d, yyyy"),
                    "Active",
                    p.IsSeed));
            }

            _allRows = rows;
        }
        else
        {
            _allRows =
            [
                new(Guid.Empty, "Bob Smith",    "BS", "#7C4DFF", "Administrator", 0, "Now",        "Active",  true),
                new(Guid.Empty, "Alice Chen",   "AC", "#00BFA5", "Viewer",        0, "2 days ago", "Active",  false),
                new(Guid.Empty, "Charlie Dave", "CD", "#FF8F00", "Reviewer",      0, "1 week ago", "Pending", false),
            ];
        }

        _loading = false;
    }

    private void OpenCreateDialog()
    {
        _newDisplayName = string.Empty;
        _newRole        = "Consumer";
        _newAvatarColor = "#7C4DFF";
        _createOpen     = true;
    }

    private void CloseCreateDialog()
    {
        _createOpen     = false;
        _newDisplayName = string.Empty;
    }

    private async Task CreateProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(_newDisplayName)) return;
        _creating = true;

        var ok = await Orchestrator.CreateProfileAsync(
            _newDisplayName.Trim(), _newAvatarColor, _newRole);

        _creating = false;

        if (ok)
        {
            Snackbar.Add($"Profile \"{_newDisplayName.Trim()}\" created", Severity.Success);
            _createOpen = false;
            await RefreshProfilesAsync();
        }
        else
        {
            Snackbar.Add(L["Users_CreateError"], Severity.Error);
        }
    }

    private async Task DeleteProfileAsync(UserRow row)
    {
        if (row.IsSeed || row.Id == Guid.Empty) return;

        var ok = await Orchestrator.DeleteProfileAsync(row.Id);
        if (ok)
        {
            Snackbar.Add($"Profile \"{row.DisplayName}\" deleted", Severity.Info);
            await RefreshProfilesAsync();
        }
        else
        {
            Snackbar.Add(L["Users_DeleteError"], Severity.Error);
        }
    }

    private async Task OpenExternalLoginsDialogAsync(UserRow row)
    {
        _selectedUser = row;
        _externalLoginsOpen = true;
        _externalLoginsLoading = true;
        ResetExternalLoginForm();
        _externalLogins = await Orchestrator.GetProfileExternalLoginsAsync(row.Id);
        _externalLoginsLoading = false;
    }

    private void CloseExternalLoginsDialog()
    {
        _externalLoginsOpen = false;
        _selectedUser = null;
        _externalLogins = [];
        ResetExternalLoginForm();
    }

    private async Task LinkExternalLoginAsync()
    {
        if (_selectedUser is null ||
            string.IsNullOrWhiteSpace(_newLoginProvider) ||
            string.IsNullOrWhiteSpace(_newLoginSubject))
        {
            return;
        }

        _linkingExternalLogin = true;
        var login = await Orchestrator.LinkProfileExternalLoginAsync(
            _selectedUser.Id,
            _newLoginProvider,
            _newLoginSubject,
            _newLoginEmail,
            _newLoginDisplayName);
        _linkingExternalLogin = false;

        if (login is null)
        {
            Snackbar.Add("Could not link sign-in account.", Severity.Error);
            return;
        }

        Snackbar.Add("Sign-in account linked.", Severity.Success);
        ResetExternalLoginForm();
        _externalLogins = await Orchestrator.GetProfileExternalLoginsAsync(_selectedUser.Id);
        await RefreshProfilesAsync();
    }

    private async Task UnlinkExternalLoginAsync(Guid loginId)
    {
        if (_selectedUser is null)
            return;

        var ok = await Orchestrator.UnlinkProfileExternalLoginAsync(loginId);
        if (!ok)
        {
            Snackbar.Add("Could not unlink sign-in account.", Severity.Error);
            return;
        }

        Snackbar.Add("Sign-in account unlinked.", Severity.Info);
        _externalLogins = await Orchestrator.GetProfileExternalLoginsAsync(_selectedUser.Id);
        await RefreshProfilesAsync();
    }

    private void ResetExternalLoginForm()
    {
        _newLoginProvider = string.Empty;
        _newLoginSubject = string.Empty;
        _newLoginEmail = null;
        _newLoginDisplayName = null;
    }
}
