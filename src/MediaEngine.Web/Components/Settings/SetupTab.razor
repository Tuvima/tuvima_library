@namespace MediaEngine.Web.Components.Settings
@inject SetupReadinessService ReadinessService
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar

<div class="tl-page setup-checklist">
    <AppPageHeader Title="Setup checklist"
                   Subtitle="Confirm the Engine, folders, providers, optional local AI, scan state, and Review Queue before importing your first media.">
        <Actions>
            <AppButton Label="Refresh readiness"
                       Size="AppControlSize.Compact"
                       StartIcon="@Icons.Material.Outlined.Refresh"
                       Disabled="@_loading"
                       OnClick="LoadReadinessAsync" />
        </Actions>
    </AppPageHeader>

    @if (_loading && _snapshot is null)
    {
        <AppCard Class="setup-loading">
            <AppProgressBar Indeterminate="true" />
            <span>Checking setup readiness...</span>
        </AppCard>
    }
    else if (_snapshot is { } snapshot)
    {
        @if (!string.IsNullOrWhiteSpace(snapshot.Error))
        {
            <AppAlert Tone="AppUiTone.Warning" Class="mb-4">
                @snapshot.Error
            </AppAlert>
        }

        @if (_scanStarted)
        {
            <AppAlert Tone="AppUiTone.Success" Class="mb-4">
                Scan request sent. Open Ingestion to watch progress and review any items that need confirmation.
            </AppAlert>
        }

        <div class="setup-checklist-grid">
            @ReadinessRow(
                "Engine connection",
                EngineStatus(snapshot),
                snapshot.EngineReachable
                    ? "The Dashboard can reach the Engine."
                    : "The Dashboard cannot reach the Engine. Start the Engine, then retry readiness.",
                Icons.Material.Outlined.Dns,
                "Retry",
                LoadReadinessAsync,
                "Open Ingestion",
                "/settings/ingestion")

            @ReadinessRow(
                "Folders",
                FolderStatus(snapshot),
                FolderDescription(snapshot),
                Icons.Material.Outlined.FolderOpen,
                "Configure folders",
                null,
                "Open folder settings",
                "/settings/folders")

            @FolderDetail(snapshot.LibraryRoot)
            @FolderDetail(snapshot.WatchFolder)

            @ReadinessRow(
                "Providers",
                ProviderStatus(snapshot),
                ProviderDescription(snapshot),
                Icons.Material.Outlined.Collections,
                "Open provider settings",
                null,
                null,
                "/settings/providers")

            @ReadinessRow(
                "Local AI",
                AiStatus(snapshot),
                AiDescription(snapshot),
                Icons.Material.Outlined.Memory,
                "Open Local AI settings",
                null,
                null,
                "/settings/ai")

            @ReadinessRow(
                "Scan and ingestion",
                ScanStatus(snapshot),
                ScanDescription(snapshot),
                Icons.Material.Outlined.PlayCircle,
                ScanPrimaryLabel(snapshot),
                ScanNowAsync,
                "Open Ingestion",
                "/settings/ingestion",
                primaryDisabled: !snapshot.CanScan || _scanStarting)

            @ReadinessRow(
                "Review Queue",
                ReviewStatus(snapshot),
                snapshot.PendingReviewCount > 0
                    ? $"{snapshot.PendingReviewCount:N0} item(s) need confirmation before they can be fully added."
                    : "No review work is waiting right now.",
                Icons.Material.Outlined.RateReview,
                "Open Review Queue",
                null,
                null,
                "/settings/review")
        </div>
    }
</div>

@code {
    private SetupReadinessSnapshot? _snapshot;
    private bool _loading = true;
    private bool _scanStarting;
    private bool _scanStarted;

    protected override async Task OnInitializedAsync()
    {
        await LoadReadinessAsync();
    }

    private async Task LoadReadinessAsync()
    {
        _loading = true;
        try
        {
            _snapshot = await ReadinessService.GetSnapshotAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ScanNowAsync()
    {
        _scanStarting = true;
        _scanStarted = false;

        try
        {
            var started = await Orchestrator.TriggerRescanAsync();
            if (started)
            {
                _scanStarted = true;
                Snackbar.Add("Scan started. Ingestion will show progress as the Engine reports it.", Severity.Success);
            }
            else
            {
                Snackbar.Add(Orchestrator.LastApiError ?? "Scan could not be started.", Severity.Error);
            }

            await LoadReadinessAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Scan could not be started: {ex.Message}", Severity.Error);
        }
        finally
        {
            _scanStarting = false;
        }
    }

    private static SetupReadinessStatus EngineStatus(SetupReadinessSnapshot snapshot) =>
        snapshot.EngineReachable ? SetupReadinessStatus.Complete : SetupReadinessStatus.Unavailable;

    private static SetupReadinessStatus FolderStatus(SetupReadinessSnapshot snapshot)
    {
        if (!snapshot.EngineReachable)
        {
            return SetupReadinessStatus.Unavailable;
        }

        return snapshot.FoldersReady ? SetupReadinessStatus.Complete : SetupReadinessStatus.NeedsAttention;
    }

    private static SetupReadinessStatus ProviderStatus(SetupReadinessSnapshot snapshot)
    {
        if (!snapshot.EngineReachable || !snapshot.Providers.StatusLoaded)
        {
            return SetupReadinessStatus.Unavailable;
        }

        if (snapshot.Providers.EnabledProviders.Count == 0)
        {
            return SetupReadinessStatus.NeedsAttention;
        }

        return snapshot.Providers.HasUsableZeroKeyProvider
               || snapshot.Providers.EnabledProviders.Any(provider => provider.RequiresApiKey && provider.HasApiKey)
            ? SetupReadinessStatus.Complete
            : SetupReadinessStatus.NeedsAttention;
    }

    private static SetupReadinessStatus AiStatus(SetupReadinessSnapshot snapshot)
    {
        if (!snapshot.EngineReachable)
        {
            return SetupReadinessStatus.Unavailable;
        }

        return snapshot.LocalAi.ProfileLoaded || snapshot.LocalAi.ResourcesLoaded
            ? SetupReadinessStatus.Optional
            : SetupReadinessStatus.Unavailable;
    }

    private static SetupReadinessStatus ScanStatus(SetupReadinessSnapshot snapshot)
    {
        if (snapshot.IsIngestionActive)
        {
            return SetupReadinessStatus.InProgress;
        }

        if (snapshot.HasScanEverRun)
        {
            return SetupReadinessStatus.Complete;
        }

        if (!snapshot.EngineReachable)
        {
            return SetupReadinessStatus.Unavailable;
        }

        return snapshot.FoldersReady ? SetupReadinessStatus.NeedsAttention : SetupReadinessStatus.Unavailable;
    }

    private static SetupReadinessStatus ReviewStatus(SetupReadinessSnapshot snapshot) =>
        snapshot.PendingReviewCount > 0 ? SetupReadinessStatus.NeedsAttention : SetupReadinessStatus.Complete;

    private static string FolderDescription(SetupReadinessSnapshot snapshot)
    {
        if (!snapshot.LibraryRoot.IsConfigured && !snapshot.WatchFolder.IsConfigured)
        {
            return "Choose where organized media should live and where new files are detected.";
        }

        if (!snapshot.LibraryRoot.IsReady)
        {
            return "The Library Root needs to exist and allow read/write access so Tuvima can organize files.";
        }

        if (!snapshot.WatchFolder.IsReady)
        {
            return "The Watch Folder needs to exist and allow read/write access before scans can start.";
        }

        return "The Library Root and Watch Folder are configured and accessible.";
    }

    private static string ProviderDescription(SetupReadinessSnapshot snapshot)
    {
        if (!snapshot.Providers.StatusLoaded)
        {
            return "Provider status is unavailable. Open provider settings or retry readiness.";
        }

        if (snapshot.Providers.EnabledProviders.Count == 0)
        {
            return "No metadata providers are enabled yet. Enable at least one provider before scanning.";
        }

        if (snapshot.Providers.MissingCredentialProviders.Count > 0)
        {
            var names = string.Join(", ", snapshot.Providers.MissingCredentialProviders.Select(provider => provider.DisplayName));
            if (snapshot.Providers.HasUsableZeroKeyProvider)
            {
                return $"At least one provider can run without secrets. These providers still need API keys: {names}.";
            }

            return $"Some enabled providers require API keys before they can enrich metadata: {names}.";
        }

        return $"{snapshot.Providers.EnabledProviders.Count:N0} provider(s) are enabled for metadata enrichment.";
    }

    private static string AiDescription(SetupReadinessSnapshot snapshot)
    {
        if (snapshot.LocalAi.ProfileLoaded && snapshot.LocalAi.HardwareProfile is { } profile)
        {
            return $"Local AI profile is readable ({profile.Tier}, {profile.Backend}). Local AI is optional for first ingestion.";
        }

        if (snapshot.LocalAi.ResourcesLoaded)
        {
            return "Local AI resource status is readable. Local AI is optional for first ingestion.";
        }

        return "Local AI status is unavailable or not configured. This does not block first ingestion when folders and providers are ready.";
    }

    private static string ScanDescription(SetupReadinessSnapshot snapshot)
    {
        if (snapshot.IsIngestionActive)
        {
            return "A scan or ingestion job is already running. Open Ingestion to follow progress.";
        }

        if (snapshot.HasScanEverRun)
        {
            return "A scan has already run. You can run another scan or watch progress in Ingestion.";
        }

        return snapshot.FoldersReady
            ? "Your folders are ready. Scan now to import media from the Watch Folder."
            : "Configure reachable folders before starting a scan.";
    }

    private static string ScanPrimaryLabel(SetupReadinessSnapshot snapshot) =>
        snapshot.IsIngestionActive ? "Scan running" : "Scan Now";

    private RenderFragment ReadinessRow(
        string title,
        SetupReadinessStatus status,
        string description,
        string icon,
        string primaryLabel,
        Func<Task>? primaryAction,
        string? secondaryLabel,
        string? href,
        bool primaryDisabled = false) => @<AppCard Class="setup-row">
        <MudIcon Icon="@icon" Color="@StatusColor(status)" />
        <div class="setup-row__content">
            <div class="setup-row__heading">
                <strong>@title</strong>
                @StatusChip(status)
            </div>
            <p>@description</p>
        </div>
        <div class="setup-row__actions">
            @if (primaryAction is not null)
            {
                <AppButton Label="@(_scanStarting && primaryLabel.Contains("Scan", StringComparison.OrdinalIgnoreCase) ? "Starting..." : primaryLabel)"
                           ButtonStyle="AppButtonStyle.Filled"
                           Tone="AppUiTone.Primary"
                           Size="AppControlSize.Compact"
                           StartIcon="@Icons.Material.Outlined.PlayArrow"
                           Disabled="@primaryDisabled"
                           OnClick="@(() => primaryAction.Invoke())" />
            }
            else if (!string.IsNullOrWhiteSpace(href))
            {
                <AppButton Label="@primaryLabel"
                           ButtonStyle="AppButtonStyle.Filled"
                           Tone="AppUiTone.Primary"
                           Size="AppControlSize.Compact"
                           Href="@href" />
            }

            @if (!string.IsNullOrWhiteSpace(secondaryLabel) && !string.IsNullOrWhiteSpace(href))
            {
                <AppButton Label="@secondaryLabel"
                           ButtonStyle="AppButtonStyle.Text"
                           Size="AppControlSize.Compact"
                           Href="@href" />
            }
        </div>
    </AppCard>;

    private static RenderFragment FolderDetail(SetupPathReadiness folder) => @<div class="setup-folder-detail">
        <MudIcon Icon="@(folder.IsReady ? Icons.Material.Outlined.CheckCircle : Icons.Material.Outlined.WarningAmber)"
                 Color="@(folder.IsReady ? Color.Success : Color.Warning)" />
        <div class="setup-folder-detail__content">
            <strong>@folder.Label</strong>
            <code class="setup-folder-detail__path">@(folder.IsConfigured ? folder.Path : "Not configured")</code>
            <span>@FolderProbeText(folder)</span>
        </div>
    </div>;

    private static string FolderProbeText(SetupPathReadiness folder)
    {
        if (!folder.IsConfigured)
        {
            return folder.Label == "Library Root"
                ? "This is where organized media should live."
                : "This is where new files are detected.";
        }

        if (folder.Probe is null)
        {
            return "Folder access has not been confirmed.";
        }

        if (!folder.Exists)
        {
            return "Folder was not found by the Engine.";
        }

        if (!folder.HasRead)
        {
            return "The Engine cannot read this folder.";
        }

        if (folder.RequiresWriteAccess && !folder.HasWrite)
        {
            return "The Engine can read this folder but cannot write to it.";
        }

        return "Read/write access confirmed.";
    }

    private static RenderFragment StatusChip(SetupReadinessStatus status) => @<AppChip Text="@StatusLabel(status)" Tone="@StatusTone(status)" />;

    private static string StatusLabel(SetupReadinessStatus status) => status switch
    {
        SetupReadinessStatus.Complete => "Complete",
        SetupReadinessStatus.NeedsAttention => "Needs attention",
        SetupReadinessStatus.Optional => "Optional",
        SetupReadinessStatus.Unavailable => "Unavailable",
        SetupReadinessStatus.InProgress => "In progress",
        _ => "Unavailable",
    };

    private static Color StatusColor(SetupReadinessStatus status) => status switch
    {
        SetupReadinessStatus.Complete => Color.Success,
        SetupReadinessStatus.NeedsAttention => Color.Warning,
        SetupReadinessStatus.Optional => Color.Info,
        SetupReadinessStatus.Unavailable => Color.Default,
        SetupReadinessStatus.InProgress => Color.Primary,
        _ => Color.Default,
    };

    private static AppUiTone StatusTone(SetupReadinessStatus status) => status switch
    {
        SetupReadinessStatus.Complete => AppUiTone.Success,
        SetupReadinessStatus.NeedsAttention => AppUiTone.Warning,
        SetupReadinessStatus.Optional => AppUiTone.Info,
        SetupReadinessStatus.InProgress => AppUiTone.Primary,
        _ => AppUiTone.Neutral,
    };
}
