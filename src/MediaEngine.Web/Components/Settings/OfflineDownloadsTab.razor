@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Contracts.Playback
@using MediaEngine.Web.Services.Integration
@inject IEngineApiClient ApiClient
@inject ISnackbar Snackbar

<div class="tl-page">
    <AppPageHeader Title="Offline Downloads"
                   Subtitle="Prepared variants for phones, tablets, and travel playback." />

    <AppActionBar Class="mb-4">
        <AppButton Label="Refresh" StartIcon="@Icons.Material.Outlined.Refresh" OnClick="@LoadJobsAsync" />
        <AppButton Label="Run cleanup" StartIcon="@Icons.Material.Outlined.DeleteSweep" OnClick="@CleanupAsync" />
    </AppActionBar>

    <AppCard Title="Encode Queue">
        @if (_loading)
        {
            <AppProgressBar Indeterminate="true" />
        }
        else if (_jobs.Count == 0)
        {
            <AppEmptyState Title="No encode jobs have been queued yet." />
        }
        else
        {
            <AppTable Class="offline-downloads-table">
                <thead>
                    <tr>
                        <th>Asset</th>
                        <th>Profile</th>
                        <th>Status</th>
                        <th>Progress</th>
                        <th>Scheduled</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in _jobs)
                    {
                        <tr>
                            <td>@job.AssetId</td>
                            <td>@job.ProfileKey</td>
                            <td><AppChip Text="@job.Status" Tone="@StatusTone(job.Status)" /></td>
                            <td>@job.ProgressPct.ToString("0.#")%</td>
                            <td>@(job.ScheduledFor?.LocalDateTime.ToString("g") ?? "Immediate")</td>
                            <td>
                                <AppButton Label="Cancel"
                                           ButtonStyle="AppButtonStyle.Text"
                                           Tone="AppUiTone.Warning"
                                           Size="AppControlSize.Compact"
                                           Disabled="@IsTerminal(job.Status)"
                                           OnClick="@(() => CancelAsync(job.Id))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </AppTable>
        }
    </AppCard>

    <AppCard Title="Prepared Variant Actions" Class="mt-4">
        <div class="offline-actions-grid">
            <div class="offline-action-block">
                <strong>Queue</strong>
                <span>Prepare mobile versions from item detail pages or future watchlist rules.</span>
            </div>
            <div class="offline-action-block">
                <strong>Retry and delete</strong>
                <span>Failed jobs and old variants are managed without touching original library files.</span>
            </div>
            <div class="offline-action-block">
                <strong>Download</strong>
                <span>Ready variants use range-capable Engine download URLs for clients.</span>
            </div>
        </div>
    </AppCard>
</div>

@code {
    private bool _loading;
    private List<EncodeJobDto> _jobs = [];

    protected override async Task OnInitializedAsync() => await LoadJobsAsync();

    private async Task LoadJobsAsync()
    {
        _loading = true;
        _jobs = await ApiClient.GetEncodeJobsAsync();
        _loading = false;
    }

    private async Task CancelAsync(Guid jobId)
    {
        var ok = await ApiClient.CancelEncodeJobAsync(jobId);
        Snackbar.Add(ok ? "Encode job cancelled" : "Encode job could not be cancelled", ok ? Severity.Success : Severity.Warning);
        await LoadJobsAsync();
    }

    private Task CleanupAsync()
    {
        Snackbar.Add("Cleanup policy is captured here; backend cleanup execution comes with variant generation.", Severity.Info);
        return Task.CompletedTask;
    }

    private static bool IsTerminal(string status) =>
        status.Equals(EncodeJobStatuses.Complete, StringComparison.OrdinalIgnoreCase)
        || status.Equals(EncodeJobStatuses.Failed, StringComparison.OrdinalIgnoreCase)
        || status.Equals(EncodeJobStatuses.Cancelled, StringComparison.OrdinalIgnoreCase);

    private static AppUiTone StatusTone(string status) => status.ToLowerInvariant() switch
    {
        EncodeJobStatuses.Complete => AppUiTone.Success,
        EncodeJobStatuses.Failed => AppUiTone.Error,
        EncodeJobStatuses.Cancelled => AppUiTone.Neutral,
        EncodeJobStatuses.Running => AppUiTone.Info,
        _ => AppUiTone.Warning,
    };
}
