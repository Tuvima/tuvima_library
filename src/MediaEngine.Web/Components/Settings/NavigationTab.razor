@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar

@using MediaEngine.Web.Models.ViewDTOs

@* Navigation Settings — configures the header Action Cluster and bottom
   Navigation Tray (Virtual Libraries). Uses drag-and-drop reordering.
   Changes are persisted to the profile's navigation_config JSON blob. *@

<MudStack Spacing="6">
    @* ── Section header ───────────────────────────────────────────────── *@
    <MudText Typo="Typo.h5" Style="font-weight: 600;">Navigation</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Customise the header actions and bottom navigation tray.
    </MudText>

    @* ── Action Cluster ───────────────────────────────────────────────── *@
    <MudPaper Class="pa-6" Style="border-radius: 24px; background: var(--app-glass-bg);
        border: 1px solid var(--app-glass-border);
        backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);">

        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mb-1">
            <MudIcon Icon="@Icons.Material.Outlined.Tune" Size="Size.Small"
                     Style="vertical-align: middle; margin-right: 8px;" />
            Action Cluster
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Icon buttons in the header. Drag to reorder.
        </MudText>

        <MudDropContainer T="ActionClusterDragItem" Items="_clusterItems"
                          ItemsSelector="@((item, zone) => item.Zone == zone)" ItemUpdated="OnClusterItemUpdated"
                          Class="nav-drag-list">
            <ChildContent>
                <MudDropZone T="ActionClusterDragItem" Identifier="cluster" AllowReorder="true" Class="nav-drag-zone">
                </MudDropZone>
            </ChildContent>
            <ItemRenderer>
                <div class="nav-drag-row">
                    <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small" Class="nav-drag-handle" />
                    <MudIcon Icon="@GetClusterItemIcon(context.Key)" Size="Size.Small" Style="flex-shrink: 0;" />
                    <MudText Typo="Typo.body2" Style="flex: 1;">
                        @GetClusterItemLabel(context.Key)
                    </MudText>
                    <MudSwitch T="bool" Value="@context.Enabled"
                               ValueChanged="@(v => { context.Enabled = v; SyncClusterFromDragItems(); SaveConfig(); })"
                               Color="Color.Primary" />
                </div>
            </ItemRenderer>
        </MudDropContainer>
    </MudPaper>

    @* ── Tray Libraries ───────────────────────────────────────────────── *@
    <MudPaper Class="pa-6" Style="border-radius: 24px; background: var(--app-glass-bg);
        border: 1px solid var(--app-glass-border);
        backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);">

        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mb-1">
            <MudIcon Icon="@Icons.Material.Outlined.Menu" Size="Size.Small"
                     Style="vertical-align: middle; margin-right: 8px;" />
            Tray Libraries
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Libraries shown in the bottom nav tray. Drag to reorder.
        </MudText>

        <MudDropContainer T="TrayLibraryDragItem" Items="_trayItems"
                          ItemsSelector="@((item, zone) => item.Zone == zone)" ItemUpdated="OnTrayItemUpdated" Class="nav-drag-list">
            <ChildContent>
                <MudDropZone T="TrayLibraryDragItem" Identifier="tray" AllowReorder="true" Class="nav-drag-zone">
                </MudDropZone>
            </ChildContent>
            <ItemRenderer>
                @{
                    var lib = context.Library;
                }
                <MudPaper Elevation="0" Class="nav-tray-card mb-2">
                    @* ── Row 1: handle | icon | label | enable | delete ── *@
                    <div class="nav-drag-row">
                        <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small"
                                 Class="nav-drag-handle" />
                        <MudIcon Icon="@NavigationDefaults.GetMudIcon(lib.Icon)" Size="Size.Small"
                                 Style="@($"color: {NavigationDefaults.GetMediaTypeColor(lib.Icon)}; flex-shrink: 0;")" />
                        <MudTextField @bind-Value="lib.Label" Variant="Variant.Text" Margin="Margin.Dense"
                                      Style="flex: 1; min-width: 0;" Immediate="true" OnBlur="@SaveConfig" />
                        <MudSwitch T="bool" Value="@lib.Enabled"
                                   ValueChanged="@(v => { lib.Enabled = v; SyncTrayFromDragItems(); SaveConfig(); })"
                                   Color="Color.Primary" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => RemoveLibrary(lib))" title="Remove" />
                    </div>

                    @* ── Row 2: icon selector + media type chips ── *@
                    <div class="nav-tray-meta">
                        <MudSelect T="string" Value="@lib.Icon" Label="Icon" Variant="Variant.Outlined"
                                   Margin="Margin.Dense" Dense="true" Style="max-width: 160px; flex-shrink: 0;"
                                   ValueChanged="@(v => { lib.Icon = v; SyncTrayFromDragItems(); SaveConfig(); })">
                            <MudSelectItem Value="@("LiveTv")">TV</MudSelectItem>
                            <MudSelectItem Value="@("Movie")">Movie</MudSelectItem>
                            <MudSelectItem Value="@("MenuBook")">Book</MudSelectItem>
                            <MudSelectItem Value="@("Headphones")">Headphones</MudSelectItem>
                            <MudSelectItem Value="@("AutoStories")">Comics</MudSelectItem>
                            <MudSelectItem Value="@("Category")">Category</MudSelectItem>
                            <MudSelectItem Value="@("MusicNote")">Music</MudSelectItem>
                            <MudSelectItem Value="@("Podcasts")">Podcast</MudSelectItem>
                        </MudSelect>

                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" AlignItems="AlignItems.Center">
                            @foreach (var mt in AllMediaTypes)
                            {
                                var isSelected = lib.MediaTypes.Contains(mt, StringComparer.OrdinalIgnoreCase);
                                <MudChip T="string" Value="@mt" Color="@(isSelected? Color.Primary: Color.Default)"
                                         Variant="@(isSelected ? MudBlazor.Variant.Filled : MudBlazor.Variant.Outlined)"
                                         Size="Size.Small" OnClick="@(() => ToggleMediaType(lib, mt))">
                                    @mt
                                </MudChip>
                            }
                        </MudStack>
                    </div>
                </MudPaper>
            </ItemRenderer>
        </MudDropContainer>

        @* Add Library + Reset buttons *@
        <MudStack Row="true" Spacing="2" Class="mt-2">
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined" Color="Color.Primary"
                       OnClick="@AddLibrary">
                Add Library
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.RestartAlt" Variant="Variant.Text" Color="Color.Secondary"
                       OnClick="@ResetToDefaults">
                Reset to Defaults
            </MudButton>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    /// <summary>The profile ID to persist navigation config changes.</summary>
    [Parameter] public Guid ProfileId { get; set; }

    /// <summary>Initial navigation config JSON from the profile.</summary>
    [Parameter] public string? NavigationConfigJson { get; set; }

    /// <summary>Fires after saving so the parent can refresh.</summary>
    [Parameter] public EventCallback OnConfigChanged { get; set; }

    private NavigationConfigViewModel _config = NavigationDefaults.CreateDefault();
    private bool _saving;

    // ── Drag item lists ───────────────────────────────────────────────────

    private List<ActionClusterDragItem> _clusterItems = [];
    private List<TrayLibraryDragItem> _trayItems = [];

    private static readonly string[] AllMediaTypes =
        ["Movie", "TvShow", "Epub", "Audiobook", "Comic", "Podcast", "Music"];

    protected override void OnParametersSet()
    {
        _config = NavigationDefaults.Deserialize(NavigationConfigJson);
        RebuildDragItems();
    }

    // ── Drag item sync ────────────────────────────────────────────────────

    private void RebuildDragItems()
    {
        _clusterItems = _config.ActionCluster.Items
            .Select(i => new ActionClusterDragItem { Key = i.Key, Enabled = i.Enabled, Zone = "cluster" })
            .ToList();

        _trayItems = _config.Tray.Libraries
            .Select(l => new TrayLibraryDragItem { Library = l, Zone = "tray" })
            .ToList();
    }

    private void SyncClusterFromDragItems()
    {
        _config.ActionCluster.Items = _clusterItems
            .Select(i => new ActionClusterItem { Key = i.Key, Enabled = i.Enabled })
            .ToList();
    }

    private void SyncTrayFromDragItems()
    {
        _config.Tray.Libraries = _trayItems.Select(t => t.Library).ToList();
    }

    // ── Drop callbacks ────────────────────────────────────────────────────

    private void OnClusterItemUpdated(MudItemDropInfo<ActionClusterDragItem> drop)
    {
        if (drop.Item is null) return;
        _clusterItems.Remove(drop.Item);
        _clusterItems.Insert(drop.IndexInZone, drop.Item);
        SyncClusterFromDragItems();
        SaveConfig();
    }

    private void OnTrayItemUpdated(MudItemDropInfo<TrayLibraryDragItem> drop)
    {
        if (drop.Item is null) return;
        _trayItems.Remove(drop.Item);
        _trayItems.Insert(drop.IndexInZone, drop.Item);
        SyncTrayFromDragItems();
        SaveConfig();
    }

    // ── Action Cluster helpers ────────────────────────────────────────────

    private static string GetClusterItemIcon(string key) => key switch
    {
        "cast" => Icons.Material.Filled.Cast,
        "profile" => Icons.Material.Filled.Person,
        _ => Icons.Material.Filled.Extension,
    };

    private static string GetClusterItemLabel(string key) => key switch
    {
        "cast" => "Cast (Coming soon)",
        "profile" => "Profile Avatar",
        _ => key,
    };

    // ── Tray Library helpers ──────────────────────────────────────────────

    private void ToggleMediaType(VirtualLibrary lib, string mediaType)
    {
        if (lib.MediaTypes.Contains(mediaType, StringComparer.OrdinalIgnoreCase))
            lib.MediaTypes.RemoveAll(mt => mt.Equals(mediaType, StringComparison.OrdinalIgnoreCase));
        else
            lib.MediaTypes.Add(mediaType);
        SyncTrayFromDragItems();
        SaveConfig();
    }

    private void RemoveLibrary(VirtualLibrary lib)
    {
        _trayItems.RemoveAll(t => ReferenceEquals(t.Library, lib));
        SyncTrayFromDragItems();
        SaveConfig();
    }

    private void AddLibrary()
    {
        var key = $"custom_{Guid.NewGuid():N}"[..12];
        var lib = new VirtualLibrary
        {
            Key = key,
            Label = "New Library",
            Icon = "Category",
            MediaTypes = [],
            Enabled = true,
        };
        _trayItems.Add(new TrayLibraryDragItem { Library = lib, Zone = "tray" });
        SyncTrayFromDragItems();
        SaveConfig();
    }

    private void ResetToDefaults()
    {
        _config = NavigationDefaults.CreateDefault();
        RebuildDragItems();
        SaveConfig();
    }

    // ── Persistence ──────────────────────────────────────────────────────

    private async void SaveConfig()
    {
        if (_saving) return;
        _saving = true;

        try
        {
            var json = NavigationDefaults.Serialize(_config);
            var profile = await Orchestrator.GetActiveProfileAsync();
            if (profile is not null)
            {
                await Orchestrator.UpdateProfileAsync(
                    ProfileId,
                    profile.DisplayName,
                    profile.AvatarColor,
                    profile.Role,
                    json);
            }

            await OnConfigChanged.InvokeAsync();
        }
        catch
        {
            Snackbar.Add("Failed to save navigation config", Severity.Error);
        }
        finally
        {
            _saving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Drag item models ─────────────────────────────────────────────────

    private sealed class ActionClusterDragItem
    {
        public string Key { get; set; } = string.Empty;
        public bool Enabled { get; set; }
        public string Zone { get; set; } = "cluster";
    }

    private sealed class TrayLibraryDragItem
    {
        public VirtualLibrary Library { get; set; } = new();
        public string Zone { get; set; } = "tray";
    }
}

<style>
    /* ── Drag list container ───────────────────────────────────── */
    .nav-drag-list {
        display: flex;
        flex-direction: column;
    }

    .nav-drag-zone {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-height: 48px;
    }

    /* ── Generic drag row (used by both Action Cluster + Tray header) ── */
    .nav-drag-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 12px;
        background: var(--app-glass-inner-bg, rgba(255, 255, 255, 0.03));
        border: 1px solid var(--app-glass-border, rgba(255, 255, 255, 0.08));
        transition: background 0.15s ease;
        cursor: default;
    }

    .nav-drag-row:hover {
        background: var(--app-hover-overlay, rgba(255, 255, 255, 0.06));
    }

    /* ── Drag handle ──────────────────────────────────────────── */
    .nav-drag-handle {
        color: var(--mud-palette-text-disabled);
        cursor: grab;
        flex-shrink: 0;
    }

    .nav-drag-handle:active {
        cursor: grabbing;
    }

    /* ── Tray library card ────────────────────────────────────── */
    .nav-tray-card {
        background: var(--app-glass-inner-bg, rgba(255, 255, 255, 0.03)) !important;
        border: 1px solid var(--app-glass-border, rgba(255, 255, 255, 0.08)) !important;
        border-radius: 16px !important;
        padding: 4px 4px 8px 4px;
        transition: border-color 0.15s ease;
    }

    .nav-tray-card:hover {
        border-color: var(--mud-palette-primary-lighten) !important;
    }

    .nav-tray-card .nav-drag-row {
        border: none;
        background: transparent;
        padding-bottom: 4px;
    }

    /* ── Meta row (icon select + chips) ──────────────────────── */
    .nav-tray-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        padding: 0 12px 4px 40px;
        /* 40px left indent aligns with content past handle */
    }

    /* ── Responsive ───────────────────────────────────────────── */
    @@media (max-width: 600px) {
        .nav-tray-meta {
            padding-left: 12px;
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
