@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar

@* MetadataEditDialog — reusable inline MudDialog for manually editing metadata
   fields. Pre-fills with current canonical values and returns only changed fields. *@

<MudDialog @bind-Visible="Visible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
            Edit Metadata
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (!string.IsNullOrWhiteSpace(_entityTitle))
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-3">
                @_entityTitle
            </MudText>
        }

        @foreach (var field in _editableFields)
        {
            <MudTextField T="string" @bind-Value="field.Value"
                          Label="@FieldDictionary.GetDisplayName(field.Key)"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@FieldDictionary.GetIcon(field.Key)"
                          Lines="@(field.Key == "description" ? 3 : 1)" />
        }

        @if (_editableFields.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                No editable fields available for this entity.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">Cancel</MudButton>
        <MudButton OnClick="SaveAsync" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@(_saving || !HasChanges)">
            @(_saving ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    /// <summary>Two-way bound visibility toggle.</summary>
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    /// <summary>The entity whose metadata is being edited.</summary>
    [Parameter] public Guid EntityId { get; set; }

    /// <summary>The media type, used to determine which fields to show.</summary>
    [Parameter] public string? MediaType { get; set; }

    /// <summary>Current canonical values for the entity (key → value).</summary>
    [Parameter] public Dictionary<string, string>? CurrentValues { get; set; }

    /// <summary>Fired when save succeeds. Returns the map of changed fields.</summary>
    [Parameter] public EventCallback<Dictionary<string, string>> OnSaved { get; set; }

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth         = MaxWidth.Medium,
        FullWidth        = true,
        CloseOnEscapeKey = true,
    };

    private List<EditableField> _editableFields = [];
    private Dictionary<string, string> _originalValues = new();
    private bool _saving;
    private string? _entityTitle;

    /// <summary>
    /// Fields to present based on media type. Core fields first, then any
    /// existing canonical values not yet listed.
    /// </summary>
    private static readonly string[] CommonFields =
    [
        "title", "author", "description", "genre", "year",
        "series", "series_position", "isbn", "asin",
        "narrator", "publisher", "language",
    ];

    protected override void OnParametersSet()
    {
        if (!Visible) return;

        _originalValues = CurrentValues != null
            ? new Dictionary<string, string>(CurrentValues, StringComparer.OrdinalIgnoreCase)
            : new(StringComparer.OrdinalIgnoreCase);

        _entityTitle = _originalValues.GetValueOrDefault("title");
        BuildEditableFields();
    }

    private void BuildEditableFields()
    {
        _editableFields = [];
        var added = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        // Add common fields (ordered).
        foreach (var key in CommonFields)
        {
            if (!ShouldShowField(key)) continue;

            _editableFields.Add(new EditableField
            {
                Key   = key,
                Value = _originalValues.GetValueOrDefault(key) ?? string.Empty,
            });
            added.Add(key);
        }

        // Add any remaining canonical values not yet listed.
        foreach (var (key, value) in _originalValues)
        {
            if (added.Contains(key)) continue;
            // Skip bridge/internal fields — users shouldn't edit these directly.
            if (FieldDictionary.GetCategory(key) == "Bridge") continue;

            _editableFields.Add(new EditableField
            {
                Key   = key,
                Value = value,
            });
            added.Add(key);
        }
    }

    /// <summary>
    /// Filter fields based on media type relevance.
    /// </summary>
    private bool ShouldShowField(string key)
    {
        var mt = MediaType?.ToLowerInvariant();
        return key switch
        {
            "isbn"     => mt is "epub" or "audiobook" or "comic" or null,
            "asin"     => mt is "epub" or "audiobook" or null,
            "narrator" => mt is "audiobook" or null,
            _          => true,
        };
    }

    private bool HasChanges => _editableFields.Any(f =>
    {
        var original = _originalValues.GetValueOrDefault(f.Key) ?? string.Empty;
        return !string.Equals(f.Value?.Trim(), original.Trim(), StringComparison.Ordinal);
    });

    private async Task SaveAsync()
    {
        if (!HasChanges) return;

        _saving = true;
        StateHasChanged();

        // Build the changed-fields dictionary.
        var changes = new Dictionary<string, string>();
        foreach (var field in _editableFields)
        {
            var trimmed  = field.Value?.Trim() ?? string.Empty;
            var original = _originalValues.GetValueOrDefault(field.Key) ?? string.Empty;
            if (!string.Equals(trimmed, original.Trim(), StringComparison.Ordinal)
                && !string.IsNullOrWhiteSpace(trimmed))
            {
                changes[field.Key] = trimmed;
            }
        }

        if (changes.Count == 0)
        {
            _saving = false;
            return;
        }

        var ok = await Orchestrator.OverrideMetadataAsync(EntityId, changes);
        _saving = false;

        if (ok)
        {
            Snackbar.Add($"Updated {changes.Count} field(s) successfully.", Severity.Success);
            await OnSaved.InvokeAsync(changes);
            await Close();
        }
        else
        {
            Snackbar.Add("Failed to save metadata overrides. Check the Engine connection.",
                         Severity.Error);
        }
    }

    private async Task Cancel() => await Close();

    private async Task Close()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }

    private sealed class EditableField
    {
        public string Key { get; init; } = string.Empty;
        public string? Value { get; set; }
    }
}
