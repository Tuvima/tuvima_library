@namespace MediaEngine.Web.Components.Settings

@using MediaEngine.Web.Models.ViewDTOs
<div class="wikidata-connection-panel">
<MudText Typo="Typo.overline" Color="Color.Default" Class="mb-1"
             Style="letter-spacing: 0.08em;">
        CONNECTION DETAILS
    </MudText>

    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_wikidataApiUrl"
                          Label="Wikidata API"
                          Placeholder="https://www.wikidata.org/w/api.php"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Disabled="@(!IsAdmin)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Api" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_sparqlUrl"
                          Label="SPARQL Endpoint"
                          Placeholder="https://query.wikidata.org/sparql"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Disabled="@(!IsAdmin)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Storage" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudNumericField T="int" @bind-Value="_throttleMs"
                             Label="Throttle (ms)"
                             Min="0" Max="5000"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Disabled="@(!IsAdmin)" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudNumericField T="int" @bind-Value="_maxConcurrency"
                             Label="Max Concurrency"
                             Min="1" Max="5"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Disabled="@(!IsAdmin)" />
        </MudItem>
    </MudGrid>
<MudStack Row="true" Spacing="2" Class="mt-3 mb-4">
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   OnClick="@(() => OnTestClicked.InvokeAsync())"
                   Disabled="@(!IsAdmin || IsTesting)">
            @if (IsTesting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                @:Testing...
            }
            else
            {
                @:Test Connection
            }
        </MudButton>
    </MudStack>
@if (TestResult is not null)
    {
        <MudAlert Severity="@(TestResult.Success ? Severity.Success : Severity.Error)"
                  Class="mb-4"
                  Dense="true">
            @TestResult.Message
            @if (TestResult.Success)
            {
                <span style="margin-left: 8px; opacity: 0.7;">(@(TestResult.ResponseTimeMs)ms)</span>
            }
        </MudAlert>
    }
<MudDivider Class="mb-3" />

    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
        The sections below are read-only - they show what Wikidata collects for your library.
    </MudText>
<MudExpansionPanels Elevation="0" Dense="true" Class="mb-4"
                        Style="background: transparent;">
        <MudExpansionPanel MaxHeight="2000"
                           Style="background: transparent; border: 1px solid var(--app-glass-border); border-radius: 8px;">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Link" Size="Size.Small" Color="Color.Default" />
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Bridge Identifiers</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                        @_bridges.Count
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Bridges connect Wikidata to your other providers. When a Wikidata entry is found,
                    these bridge properties cross-reference with Apple Books, Open Library, and more.
                    Order determines priority - the first matching bridge wins.
                </MudText>

                <MudSimpleTable Dense="true" Hover="true" Style="background: transparent;">
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th>Property</th>
                            <th>Target Provider</th>
                            <th>Request Field</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < _bridges.Count; i++)
                        {
                            var bridge = _bridges[i];
                            var idx = i;
                            <tr>
                                <td>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@(idx + 1)</MudText>
                                </td>
                                <td>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@bridge.PCode</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            - @WikidataPropertyDefaults.GetBridgeLabel(bridge.PCode)
                                        </MudText>
                                    </MudStack>
                                </td>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                             Variant="Variant.Text">
                                        @WikidataPropertyDefaults.GetTargetProvider(bridge.PCode)
                                    </MudChip>
                                </td>
                                <td>
                                    <code style="font-size: 0.8rem;">@bridge.RequestField</code>
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
<MudExpansionPanels Elevation="0" Dense="true"
                        Style="background: transparent;">
        <MudExpansionPanel MaxHeight="4000"
                           Style="background: transparent; border: 1px solid var(--app-glass-border); border-radius: 8px;">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Map" Size="Size.Small" Color="Color.Default" />
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Property Map</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                        @_propertyCount properties
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Wikidata properties mapped to claim keys. Each property carries a
                    confidence value used during scoring. Bridge properties link to external platforms.
                </MudText>

                @foreach (var category in _propertiesByCategory)
                {
                    <MudText Typo="Typo.overline" Color="Color.Default" Class="mt-3 mb-1"
                             Style="letter-spacing: 0.08em;">
                        @category.Key
                    </MudText>

                    <MudSimpleTable Dense="true" Hover="true"
                                    Style="background: transparent; margin-bottom: 8px;">
                        <thead>
                            <tr>
                                <th>P-Code</th>
                                <th>Claim Key</th>
                                <th>Scope</th>
                                <th style="width: 80px;">Confidence</th>
                                <th style="width: 100px;">Stage</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prop in category.Value)
                            {
                                <tr>
                                    <td>
                                        <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                            @prop.PCode
                                        </MudText>
                                    </td>
                                    <td>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <code style="font-size: 0.8rem;">@prop.ClaimKey</code>
                                            @if (prop.IsBridge)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                                         Variant="Variant.Outlined"
                                                         Style="font-size: 0.65rem;">
                                                    Bridge
                                                </MudChip>
                                            }
                                        </MudStack>
                                    </td>
                                    <td>
                                        <MudText Typo="Typo.caption">@prop.EntityScope</MudText>
                                    </td>
                                    <td>
                                        <MudText Typo="Typo.body2">@prop.Confidence.ToString("P0")</MudText>
                                    </td>
                                    <td>
                                        <MudChip T="string" Size="Size.Small"
                                                 Variant="Variant.Outlined"
                                                 Color="@(prop.StageApplicability == "Human Collection" ? Color.Success : Color.Info)"
                                                 Style="font-size: 0.6rem;">
                                            @prop.StageApplicability
                                        </MudChip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
@if (IsAdmin)
    {
        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="@DoSave"
                       Disabled="@IsSaving">
                @if (IsSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                    @:Saving...
                }
                else
                {
                    @:Save Connection Settings
                }
            </MudButton>
        </MudStack>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public ProviderStatusDto Provider { get; set; } = default!;
    [Parameter] public bool IsAdmin { get; set; }
    [Parameter] public EventCallback OnTestClicked { get; set; }
    [Parameter] public EventCallback<ProviderConfigUpdateDto> OnSaveClicked { get; set; }
    [Parameter] public ProviderTestResultDto? TestResult { get; set; }
    [Parameter] public bool IsTesting { get; set; }
    [Parameter] public bool IsSaving { get; set; }

    private string _wikidataApiUrl = string.Empty;
    private string _sparqlUrl = string.Empty;
    private int _throttleMs;
    private int _maxConcurrency = 1;

    private readonly List<WikidataPropertyDefaults.BridgeEntry> _bridges =
        WikidataPropertyDefaults.GetBridgeEntries();

    private Dictionary<string, List<WikidataPropertyDefaults.WikidataPropertyInfo>> _propertiesByCategory = new();
    private int _propertyCount;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(_wikidataApiUrl) && Provider.Endpoints is { Count: > 0 })
        {
            _wikidataApiUrl = Provider.Endpoints.TryGetValue("wikidata_api", out var api) ? api : string.Empty;
            _sparqlUrl = Provider.Endpoints.TryGetValue("wikidata_sparql", out var sparql) ? sparql : string.Empty;
        }

        if (_throttleMs == 0 && Provider.ThrottleMs > 0)
            _throttleMs = Provider.ThrottleMs;

        if (_maxConcurrency == 1 && Provider.MaxConcurrency > 1)
            _maxConcurrency = Provider.MaxConcurrency;
    }

    protected override void OnInitialized()
    {
        var allProps = WikidataPropertyDefaults.GetAllProperties();
        _propertiesByCategory = allProps
            .GroupBy(p => p.Category)
            .OrderBy(g => WikidataPropertyDefaults.CategoryOrder(g.Key))
            .ToDictionary(g => g.Key, g => g.OrderBy(p => p.PCode).ToList());
        _propertyCount = allProps.Count;
    }

    private async Task DoSave()
    {
        var config = new ProviderConfigUpdateDto
        {
            Enabled = true,
            Weight = Provider.DefaultWeight,
            FieldWeights = Provider.FieldWeights is not null
                ? new Dictionary<string, double>(Provider.FieldWeights)
                : new(),
            CapabilityTags = Provider.CapabilityTags?.ToList() ?? [],
            Endpoints = new Dictionary<string, string>
            {
                ["wikidata_api"] = _wikidataApiUrl,
                ["wikidata_sparql"] = _sparqlUrl,
            },
            ThrottleMs = _throttleMs,
            MaxConcurrency = _maxConcurrency,
        };

        await OnSaveClicked.InvokeAsync(config);
    }

}

<style>
    .wikidata-connection-panel {
        padding-top: 8px;
    }
</style>

