@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar

@* Maintenance — Housekeeping tools: library reconciliation, crawl, and weekly sync.
   Activity timeline and retention policy have moved to the dedicated Activity tab
   under the Metadata settings group. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Section Header ──────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Build" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">Maintenance</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Housekeeping tools for library integrity and periodic metadata refresh.
    </MudText>

    @* ── Section 1: Library Reconciliation ──────────────────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.FactCheck"
                     Color="Color.Primary" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                Library Reconciliation
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Scan all library assets and verify their files still exist on disk.
            Missing files are cleaned up automatically — orphaned cover art,
            sidecar XML, and empty folders are removed.
        </MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       OnClick="@RunReconciliationAsync"
                       Disabled="@_reconciling">
                @(_reconciling ? "Scanning..." : "Reconcile Now")
            </MudButton>
            @if (_lastResult is not null)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                         Style="opacity: 0.8;">
                    @_lastResult.TotalScanned scanned · @_lastResult.MissingCount missing · @(_lastResult.ElapsedMs)ms
                </MudChip>
            }
        </MudStack>
    </MudPaper>

    @* ── Section 2: Library Crawl (stub) ────────────────────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.FindInPage"
                     Color="Color.Secondary" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                Library Crawl
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Scan the Library Root for library.xml sidecars and rebuild the database
            from the filesystem. Coming in a future update.
        </MudText>
    </MudPaper>

    @* ── Section 3: Weekly Sync (stub) ──────────────────────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.Sync"
                     Color="Color.Secondary" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                Weekly Sync
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Periodic metadata refresh with artwork hash verification.
            Coming in a future update.
        </MudText>
    </MudPaper>

</MudPaper>

@code {
    // ── Style constants ──────────────────────────────────────────────────────────

    private const string GlassStyle =
        "background: var(--app-glass-bg); " +
        "border: 1px solid var(--app-glass-border); " +
        "backdrop-filter: blur(10px); " +
        "-webkit-backdrop-filter: blur(10px); " +
        "border-radius: 32px; " +
        "padding: 32px;";

    private const string InnerCardStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 16px; " +
        "padding: 24px;";

    // ── State ────────────────────────────────────────────────────────────────────

    private bool _reconciling;
    private ReconciliationResultDto? _lastResult;

    // ── Actions ──────────────────────────────────────────────────────────────────

    private async Task RunReconciliationAsync()
    {
        _reconciling = true;
        StateHasChanged();

        var result = await Orchestrator.TriggerReconciliationAsync();
        _reconciling = false;

        if (result is not null)
        {
            _lastResult = result;
            var msg = result.MissingCount > 0
                ? $"Reconciliation found {result.MissingCount} missing file(s) — cleaned up"
                : "Reconciliation complete — all files present";
            Snackbar.Add(msg, result.MissingCount > 0 ? Severity.Warning : Severity.Success);
        }
        else
        {
            Snackbar.Add("Reconciliation failed — is the Engine running?", Severity.Error);
        }
    }
}
