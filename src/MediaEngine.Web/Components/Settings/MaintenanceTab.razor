@namespace MediaEngine.Web.Components.Settings

@* Maintenance — Housekeeping tools: library crawl and weekly sync.
   Activity timeline and retention policy have moved to the dedicated Activity tab
   under the Metadata settings group. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Section Header ──────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Build" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">Maintenance</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Housekeeping tools for library integrity and periodic metadata refresh.
    </MudText>

    @* ── Section 1: Library Crawl (stub for Phase 3) ──────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.FindInPage"
                     Color="Color.Secondary" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                Library Crawl
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Scan the Library Root for library.xml sidecars and rebuild the database
            from the filesystem. Coming in a future update.
        </MudText>
    </MudPaper>

    @* ── Section 2: Weekly Sync (stub for Phase 4) ────────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.Sync"
                     Color="Color.Secondary" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                Weekly Sync
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Periodic metadata refresh with artwork hash verification.
            Coming in a future update.
        </MudText>
    </MudPaper>

</MudPaper>

@code {
    // ── Style constants ──────────────────────────────────────────────────────────

    private const string GlassStyle =
        "background: var(--app-glass-bg); " +
        "border: 1px solid var(--app-glass-border); " +
        "backdrop-filter: blur(10px); " +
        "-webkit-backdrop-filter: blur(10px); " +
        "border-radius: 32px; " +
        "padding: 32px;";

    private const string InnerCardStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 16px; " +
        "padding: 24px;";
}
