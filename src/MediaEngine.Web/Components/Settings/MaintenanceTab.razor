@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

@* Maintenance — Housekeeping tools: library reconciliation, crawl, and weekly sync.
   Activity timeline and retention policy have moved to the dedicated Activity tab
   under the Metadata settings group. *@

<div class="st-page">

    @* ── Section Header ──────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Build" Color="Color.Default" Class="mr-2" />
        <MudText Typo="Typo.h6">@L["Maintenance_PageTitle"]</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        @L["Maintenance_PageDescription"]
    </MudText>

    @* ── Section 1: Library Reconciliation ──────────────────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.FactCheck"
                     Color="Color.Default" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                @L["Maintenance_ReconciliationTitle"]
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            @L["Maintenance_ReconciliationDescription"]
        </MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                  Class="maintenance-action-row">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       OnClick="@RunReconciliationAsync"
                       Disabled="@_reconciling">
                @(_reconciling ? L["Maintenance_Scanning"] : L["Maintenance_ReconcileNow"])
            </MudButton>
            @if (_lastResult is not null)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                         Style="opacity: 0.8;">
                    @_lastResult.TotalScanned scanned · @_lastResult.MissingCount missing · @(_lastResult.ElapsedMs)ms
                </MudChip>
            }
        </MudStack>
    </MudPaper>

    @* ── Section 2: Universe Enrichment ─────────────────────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.AutoFixHigh"
                     Color="Color.Default" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                @L["Maintenance_UniverseEnrichmentTitle"]
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            @L["Maintenance_UniverseEnrichmentDescription"]
        </MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                  Class="maintenance-action-row">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.AutoFixHigh"
                       OnClick="@TriggerPass2Async"
                       Disabled="@(_pass2Loading || _pass2Status?.PendingCount == 0)">
                @(_pass2Loading ? L["Maintenance_Running"] : L["Maintenance_RunPass2Now"])
            </MudButton>
            @if (_pass2Status?.PendingCount > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                    @_pass2Status.PendingCount @L["Maintenance_Pending"]
                </MudChip>
            }
        </MudStack>
    </MudPaper>

    @* ── Section 3: Auto Re-tag Sweep ───────────────────────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.LabelImportant"
                     Color="Color.Default" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                Auto Re-tag Sweep
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Walks every matched file and re-applies metadata whenever
            <code>writeback-fields.json</code> changes or a tagger version is bumped.
            Locked files are retried in the next off-hours window; permanent
            failures are routed to the Action Center.
        </MudText>

        @if (_retagState is { HasPendingDiff: true, PendingDiff.Count: > 0 })
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-3" Dense="true">
                <MudText Typo="Typo.body2" Style="font-weight: 600;">
                    A change to <code>writeback-fields.json</code> is waiting for you to Apply.
                </MudText>
                <MudText Typo="Typo.caption">
                    Click Apply to re-tag every file affected by the change below.
                    Nothing will touch the library until you do.
                </MudText>
            </MudAlert>

            <MudStack Spacing="1" Class="mb-3">
                @foreach (var d in _retagState.PendingDiff)
                {
                    <div style="border-left: 2px solid var(--app-accent); padding-left: 12px;">
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@d.MediaType</MudText>
                        @if (d.AddedFields.Count > 0)
                        {
                            <MudText Typo="Typo.caption" Style="color: #7cb342;">
                                + @string.Join(", ", d.AddedFields)
                            </MudText>
                        }
                        @if (d.RemovedFields.Count > 0)
                        {
                            <MudText Typo="Typo.caption" Style="color: #e57373;">
                                − @string.Join(", ", d.RemovedFields)
                            </MudText>
                        }
                    </div>
                }
            </MudStack>
        }

        @if (_retagRunning && _retagProgress is not null)
        {
            <MudStack Spacing="1" Class="mb-3">
                <MudProgressLinear Indeterminate="@(!_retagProgress.IsFinal)"
                                   Color="Color.Primary"
                                   Value="@(_retagProgress.IsFinal ? 100 : 0)" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Processed @_retagProgress.Processed ·
                    @_retagProgress.Succeeded written ·
                    @_retagProgress.Transient retrying ·
                    @_retagProgress.Terminal failed
                </MudText>
            </MudStack>
        }

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                  Class="maintenance-action-row">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Check"
                       OnClick="@ApplyRetagPendingAsync"
                       Disabled="@(_retagBusy || _retagState?.HasPendingDiff != true)">
                Apply
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       OnClick="@RunRetagNowAsync"
                       Disabled="@_retagBusy">
                Run Now
            </MudButton>
        </MudStack>
    </MudPaper>

    @* ── Section 4: Initial Library Sweep ─────────────────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.Fingerprint"
                     Color="Color.Default" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                Library Hash Sweep
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Fingerprints every media file across all configured library source paths.
            The hash cache lets Tuvima detect moved and renamed files without re-reading
            every byte — subsequent sweeps only re-hash files whose size or modification
            time have changed.
        </MudText>

        @if (_sweepRunning && _sweepProgress is not null)
        {
            <MudStack Spacing="1" Class="mb-3">
                <MudProgressLinear Color="Color.Primary"
                                    Value="@SweepPercent"
                                    Max="100"
                                    Rounded="true"
                                    Size="Size.Medium" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @_sweepProgress.Processed / @_sweepProgress.Discovered files ·
                    @_sweepProgress.Hashed hashed ·
                    @_sweepProgress.Cached cached ·
                    @_sweepProgress.Failed failed ·
                    @FormatBytes(_sweepProgress.BytesHashed)
                </MudText>
            </MudStack>
        }
        else if (_sweepComplete && _sweepProgress is not null)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Text" Dense="true" Class="mb-3">
                Completed — @_sweepProgress.Discovered files discovered,
                @_sweepProgress.Hashed hashed,
                @_sweepProgress.Cached from cache,
                @_sweepProgress.Failed failed
                (@_sweepProgress.ElapsedSeconds.ToString("F1")s)
            </MudAlert>
        }

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                  Class="maintenance-action-row">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       OnClick="@RunInitialSweepAsync"
                       Disabled="@_sweepRunning">
                @(_sweepRunning ? "Sweeping…" : "Run Sweep Now")
            </MudButton>
        </MudStack>
    </MudPaper>

    @* ── Section 5: Library Crawl (stub) ────────────────────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.FindInPage"
                     Color="Color.Secondary" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                @L["Maintenance_LibraryCrawlTitle"]
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @L["Maintenance_LibraryCrawlDescription"]
        </MudText>
    </MudPaper>

    @* ── Section 5: Weekly Sync (stub) ──────────────────────────────────── *@

    <MudPaper Elevation="0" Style="@InnerCardStyle">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.Sync"
                     Color="Color.Secondary" Class="mr-2" />
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                @L["Maintenance_WeeklySyncTitle"]
            </MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @L["Maintenance_WeeklySyncDescription"]
        </MudText>
    </MudPaper>

</div>

@code {
    // ── Style constants ──────────────────────────────────────────────────────────

    private const string InnerCardStyle =
        "background: var(--app-glass-inner-bg); " +
        "border: 1px solid var(--app-glass-inner-border); " +
        "border-radius: 8px; " +
        "padding: 24px;";

    // ── State ────────────────────────────────────────────────────────────────────

    private bool _reconciling;
    private ReconciliationResultDto? _lastResult;

    private Pass2StatusDto? _pass2Status;
    private bool _pass2Loading;

    private RetagSweepStateDto? _retagState;
    private RetagSweepProgressDto? _retagProgress;
    private bool _retagBusy;
    private bool _retagRunning;

    // Initial sweep state
    private InitialSweepProgressDto? _sweepProgress;
    private bool _sweepRunning;
    private bool _sweepComplete;

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _pass2Status = await Orchestrator.GetPass2StatusAsync();
        _retagState  = await Orchestrator.GetRetagSweepStateAsync();

        Orchestrator.OnRetagSweepProgress  += HandleRetagProgress;
        Orchestrator.OnRetagSweepCompleted += HandleRetagCompleted;
        Orchestrator.OnInitialSweepProgress  += HandleSweepProgress;
        Orchestrator.OnInitialSweepCompleted += HandleSweepCompleted;
    }

    public void Dispose()
    {
        Orchestrator.OnRetagSweepProgress  -= HandleRetagProgress;
        Orchestrator.OnRetagSweepCompleted -= HandleRetagCompleted;
        Orchestrator.OnInitialSweepProgress  -= HandleSweepProgress;
        Orchestrator.OnInitialSweepCompleted -= HandleSweepCompleted;
    }

    private void HandleRetagProgress(RetagSweepProgressDto ev)
    {
        _retagProgress = ev;
        _retagRunning  = !ev.IsFinal;
        InvokeAsync(StateHasChanged);
    }

    private async void HandleRetagCompleted(RetagSweepProgressDto ev)
    {
        _retagProgress = ev;
        _retagRunning  = false;
        // Refresh the pending diff — after a successful pass the hashes are current.
        _retagState = await Orchestrator.GetRetagSweepStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    // ── Retag Sweep Actions ──────────────────────────────────────────────────────

    private async Task ApplyRetagPendingAsync()
    {
        _retagBusy = true;
        try
        {
            var ok = await Orchestrator.ApplyRetagSweepPendingAsync();
            if (ok)
            {
                _retagRunning = true;
                Snackbar.Add("Applied — the re-tag sweep is starting.", Severity.Success);
                _retagState = await Orchestrator.GetRetagSweepStateAsync();
            }
            else
            {
                Snackbar.Add("Apply failed — see Engine logs.", Severity.Error);
            }
        }
        finally
        {
            _retagBusy = false;
        }
    }

    private async Task RunRetagNowAsync()
    {
        _retagBusy = true;
        try
        {
            var ok = await Orchestrator.RunRetagSweepNowAsync();
            if (ok)
            {
                _retagRunning = true;
                Snackbar.Add("Re-tag sweep triggered.", Severity.Info);
            }
            else
            {
                Snackbar.Add("Could not trigger the sweep.", Severity.Error);
            }
        }
        finally
        {
            _retagBusy = false;
        }
    }

    // ── Actions ──────────────────────────────────────────────────────────────────

    private async Task RunReconciliationAsync()
    {
        _reconciling = true;
        StateHasChanged();

        var result = await Orchestrator.TriggerReconciliationAsync();
        _reconciling = false;

        if (result is not null)
        {
            _lastResult = result;
            var msg = result.MissingCount > 0
                ? $"Reconciliation found {result.MissingCount} missing file(s) — cleaned up"
                : L["Maintenance_ReconciliationComplete"];
            Snackbar.Add(msg, result.MissingCount > 0 ? Severity.Warning : Severity.Success);
        }
        else
        {
            Snackbar.Add(L["Maintenance_ReconciliationError"], Severity.Error);
        }
    }

    // ── Initial Sweep Actions ────────────────────────────────────────────────────

    private double SweepPercent =>
        _sweepProgress is { Discovered: > 0 }
            ? Math.Min(100, 100.0 * _sweepProgress.Processed / _sweepProgress.Discovered)
            : 0;

    private static string FormatBytes(long bytes) => bytes switch
    {
        < 1024             => $"{bytes} B",
        < 1024 * 1024      => $"{bytes / 1024.0:F1} KB",
        < 1024 * 1024 * 1024 => $"{bytes / (1024.0 * 1024):F1} MB",
        _                  => $"{bytes / (1024.0 * 1024 * 1024):F2} GB",
    };

    private void HandleSweepProgress(InitialSweepProgressDto ev)
    {
        _sweepProgress = ev;
        _sweepRunning  = true;
        _sweepComplete = false;
        InvokeAsync(StateHasChanged);
    }

    private void HandleSweepCompleted(InitialSweepProgressDto ev)
    {
        _sweepProgress = ev;
        _sweepRunning  = false;
        _sweepComplete = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task RunInitialSweepAsync()
    {
        _sweepRunning  = true;
        _sweepComplete = false;
        _sweepProgress = null;
        StateHasChanged();

        var ok = await Orchestrator.RunInitialSweepAsync();
        if (!ok)
        {
            _sweepRunning = false;
            Snackbar.Add("Could not start the sweep — check Engine connection.", Severity.Error);
        }
    }

    // ── Pass 2 Actions ───────────────────────────────────────────────────────────

    private async Task TriggerPass2Async()
    {
        _pass2Loading = true;
        StateHasChanged();

        try
        {
            var result = await Orchestrator.TriggerPass2NowAsync();
            if (result is not null)
            {
                Snackbar.Add(result.Message, Severity.Success);
                _pass2Status = await Orchestrator.GetPass2StatusAsync();
            }
            else
            {
                Snackbar.Add(L["Maintenance_Pass2Error"], Severity.Error);
            }
        }
        finally
        {
            _pass2Loading = false;
        }
    }
}

<style>
    @@media (max-width: 768px) {
        .maintenance-action-row {
            flex-wrap: wrap !important;
        }
    }
</style>
