@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Web.Models.ViewDTOs

@if (Items.Count == 0)
{
    <MudText Typo="Typo.body2" Color="Color.Secondary">@EmptyText</MudText>
}
else
{
    <MudStack Row="true" Spacing="2" Style="overflow-x:auto; padding-bottom: 0.25rem;">
        @foreach (var item in Items)
        {
            <MediaRailCard Item="@item" ShowContinuation="@ShowContinuation" />
        }
    </MudStack>
}

@code {
    [Parameter] public IReadOnlyList<ProfileOverviewItemViewModel> Items { get; set; } = [];
    [Parameter] public string EmptyText { get; set; } = string.Empty;
    [Parameter] public bool ShowContinuation { get; set; }
}
