@namespace MediaEngine.Web.Components.Settings
@using MediaEngine.Domain
@using MediaEngine.Domain.Constants
@using MediaEngine.Domain.Enums
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Services.Integration
@using MudBlazor
@inject IEngineApiClient ApiClient
@inject ProviderCatalogueService Catalogue

<div class="settings-internal-tool" data-temporary-tool="provider-tester">

    <MudText Typo="Typo.h4" GutterBottom="true"
             Class="tl-u-color-tl-text-primary tl-u-font-family-app-font-sans tl-u-font-weight-700">
        Provider Tester
    </MudText>
    <MudText Typo="Typo.body2" Class="mb-6 tl-u-color-tl-text-secondary"
             >
        Search retail providers and Wikidata using the same attribute-targeted methodology as the library editor.
        Select a media type and optionally filter to a specific provider.
    </MudText>

    @* -- Filters -- *@
    <AppPanel Elevation="0" Class="pa-4 mb-4 tl-u-background-tl-divider tl-u-border-1px-solid-tl-border-subtle tl-u-border-radius-12px"
              >
        <MudGrid>
            <MudItem xs="12" sm="4">
                <AppSelect Value="@_selectedMediaType"
                           Label="Media Type"
                           Variant="Variant.Outlined"
                           T="string"
                           ValueChanged="OnMediaTypeChanged">
                    @foreach (var mt in _mediaTypes)
                    {
                        <MudSelectItem Value="@mt">@mt</MudSelectItem>
                    }
                </AppSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <AppSelect @bind-Value="_selectedProvider"
                           Label="Provider"
                           Variant="Variant.Outlined"
                           T="string">
                    <MudSelectItem Value="@("all")">All Providers</MudSelectItem>
                    <MudSelectItem Value="@("wikidata")">
                        <div class="d-flex align-center gap-2">
                            <span class="tl-u-width-8px tl-u-height-8px tl-u-border-radius-50pct tl-u-background-tl-status-success tl-u-display-inline-block"></span>
                            Wikidata
                        </div>
                    </MudSelectItem>
                    @foreach (var p in _filteredProviders)
                    {
                        <MudSelectItem Value="@p.Name">
                            <div class="d-flex align-center gap-2">
                                <AppCssElement Tag="span" Css="@($"width: 8px; height: 8px; border-radius: 50%; background: {p.AccentColor}; display: inline-block;")"></AppCssElement>
                                @p.DisplayName
                                @if (!p.Enabled)
                                {
                                    <span class="tl-u-color-tl-text-muted tl-u-font-size-0-75rem">(disabled)</span>
                                }
                            </div>
                        </MudSelectItem>
                    }
                </AppSelect>
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center">
                <AppButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="@RunSearch"
                           Disabled="@(_loading || !HasAnyFieldValue())"
                           StartIcon="@Icons.Material.Outlined.Bolt">
                    Search
                </AppButton>
            </MudItem>
        </MudGrid>
    </AppPanel>

    @* -- Search Fields -- *@
    <AppPanel Elevation="0" Class="pa-4 mb-4 tl-u-background-tl-divider tl-u-border-1px-solid-tl-border-subtle tl-u-border-radius-12px"
              >

        @* Field picker chips *@
        <MudText Typo="Typo.caption" Class="mb-2 tl-u-color-tl-text-muted tl-u-text-transform-uppercase tl-u-letter-spacing-1px"
                 >
            Search Fields
        </MudText>
        <div class="d-flex flex-wrap gap-2 mb-4">
            @foreach (var field in _searchableFields)
            {
                var isActive = _activeFields.Contains(field.FieldKey);
                <AppChip T="string"
                         Color="@(isActive ? Color.Primary : Color.Default)"
                         Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                         OnClick="@(() => ToggleField(field.FieldKey))"
                         Css="@(isActive ? "" : "border-color: var(--tl-border-strong); color: var(--tl-text-muted);")">
                    @field.DisplayLabel
                </AppChip>
            }
        </div>

        @* Active field inputs *@
        <MudGrid>
            @foreach (var field in _searchableFields.Where(f => _activeFields.Contains(f.FieldKey)))
            {
                <MudItem xs="12" sm="4">
                    <AppTextField @bind-Value="_fieldValues[field.FieldKey]"
                                  Label="@field.DisplayLabel"
                                  Placeholder="@($"Enter {field.DisplayLabel.ToLower()}...")"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Outlined.Close"
                                  OnAdornmentClick="@(() => ClearField(field.FieldKey))"
                                  OnKeyUp="@OnFieldKeyUp" />
                </MudItem>
            }
        </MudGrid>
    </AppPanel>

    @* -- Loading -- *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4 tl-u-border-radius-4px"
                            />
        <MudText Typo="Typo.body2" Class="mb-4 tl-u-color-tl-text-secondary" >
            Searching @(_selectedProvider == "wikidata" ? "Wikidata" : "providers")...
        </MudText>
    }

    @* -- Error -- *@
    @if (!string.IsNullOrEmpty(_error))
    {
        <AppAlert Severity="Severity.Error" Class="mb-4" Variant="Variant.Outlined">@_error</AppAlert>
    }

    @* -- Wikidata Results -- *@
    @if (_universeResults is { Count: > 0 })
    {
        <div class="d-flex align-center gap-4 mb-4 tl-u-color-tl-text-secondary" >
            <MudText Typo="Typo.body2">
                <strong class="tl-u-color-tl-text-primary">@_universeResults.Count</strong> Wikidata result@(_universeResults.Count == 1 ? "" : "s")
            </MudText>
            @if (_searchDuration > TimeSpan.Zero)
            {
                <MudText Typo="Typo.body2" Class="tl-u-color-tl-text-muted">
                    @_searchDuration.TotalMilliseconds.ToString("F0")ms
                </MudText>
            }
        </div>

        <AppPanel Elevation="0" Class="tl-card tl-card--flush mb-4 tl-u-background-rgba-255-255-255-0-03 tl-u-border-1px-solid-tl-border-subtle tl-u-border-radius-12px tl-u-overflow-hidden"
                  >
            <div class="pa-3 d-flex align-center gap-2 tl-u-background-tl-status-success-soft tl-u-border-bottom-1px-solid-tl-border-subtle"
                 >
                <span class="tl-u-width-10px tl-u-height-10px tl-u-border-radius-50pct tl-u-background-tl-status-success"></span>
                <MudText Typo="Typo.subtitle2" Class="tl-u-color-tl-text-primary tl-u-font-weight-600">Wikidata</MudText>
                <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-muted">
                    @_universeResults.Count result@(_universeResults.Count == 1 ? "" : "s")
                </MudText>
            </div>

            @foreach (var result in _universeResults)
            {
                var isExpanded = _expandedUniverseResult == result.Qid;
                <div class="pt-result-row @(isExpanded ? "pt-result-expanded" : "")"
                     @onclick="() => ToggleUniverseExpand(result.Qid)">
                    <div class="d-flex gap-3 pa-3 tl-u-cursor-pointer" >
                        <div class="tl-u-width-60px tl-u-height-60px tl-u-border-radius-8px tl-u-overflow-hidden tl-u-flex-shrink-0 tl-u-background-tl-divider">
                            @if (!string.IsNullOrEmpty(result.CoverUrl))
                            {
                                <img src="@result.CoverUrl" alt="" class="tl-u-width-100pct tl-u-height-100pct tl-u-object-fit-cover" loading="lazy" />
                            }
                            else
                            {
                                <div class="d-flex align-center justify-center tl-u-width-100pct tl-u-height-100pct" >
                                    <MudIcon Icon="@Icons.Material.Outlined.Public" Class="tl-u-font-size-24px tl-u-color-rgba-255-255-255-0-1" />
                                </div>
                            }
                        </div>
                        <div class="tl-u-flex-1 tl-u-min-width-0">
                            <MudText Typo="Typo.subtitle1" Class="tl-u-color-tl-text-primary tl-u-font-weight-600 tl-u-white-space-nowrap tl-u-overflow-hidden tl-u-text-overflow-ellipsis">
                                @result.Label
                            </MudText>
                            <MudText Typo="Typo.body2" Class="tl-u-color-tl-text-secondary">
                                @result.Description
                            </MudText>
                        </div>
                        <div class="d-flex flex-column align-end tl-u-flex-shrink-0" >
                            <AppChip T="string" Size="Size.Small"
                                     Color="@GetScoreColor(result.Confidence)"
                                     Variant="Variant.Outlined"
                                     Class="tl-u-font-family-jetbrains-mono-monospace tl-u-font-size-0-7rem">
                                @result.Confidence.ToString("F2")
                            </AppChip>
                            <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-faint tl-u-margin-top-4px tl-u-font-family-jetbrains-mono-monospace tl-u-font-size-0-65rem">
                                @result.Qid
                            </MudText>
                        </div>
                    </div>

                    @* -- Expanded details -- *@
                    @if (isExpanded)
                    {
                        <div class="px-3 pb-3 tl-u-padding-left-75px"  @onclick:stopPropagation="true">
                            @if (!string.IsNullOrEmpty(result.WikipediaExtract))
                            {
                                <MudText Typo="Typo.body2" Class="mb-2 tl-u-color-tl-text-secondary tl-u-font-size-0-8rem tl-u-line-height-1-5" >
                                    @(result.WikipediaExtract.Length > 500 ? result.WikipediaExtract[..497] + "..." : result.WikipediaExtract)
                                </MudText>
                            }
                            <div class="d-flex flex-wrap gap-3 mb-2">
                                @if (!string.IsNullOrEmpty(result.Author))
                                {
                                    <span class="tl-u-font-size-0-75rem">
                                        <span class="tl-u-color-tl-text-muted">Author:</span>
                                        <span class="tl-u-color-tl-text-secondary">@result.Author</span>
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(result.Director))
                                {
                                    <span class="tl-u-font-size-0-75rem">
                                        <span class="tl-u-color-tl-text-muted">Director:</span>
                                        <span class="tl-u-color-tl-text-secondary">@result.Director</span>
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(result.Year))
                                {
                                    <span class="tl-u-font-size-0-75rem">
                                        <span class="tl-u-color-tl-text-muted">Year:</span>
                                        <span class="tl-u-color-tl-text-secondary">@result.Year</span>
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(result.ResolutionTier))
                                {
                                    <span class="tl-u-font-size-0-75rem">
                                        <span class="tl-u-color-tl-text-muted">Resolution:</span>
                                        <span class="tl-u-color-tl-text-secondary">@result.ResolutionTier</span>
                                    </span>
                                }
                            </div>
                            @if (result.BridgeIds.Count > 0)
                            {
                                <div class="d-flex flex-wrap gap-1 mb-2">
                                    @foreach (var (key, val) in result.BridgeIds)
                                    {
                                        <AppChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Class="tl-u-font-size-0-65rem tl-u-height-20px tl-u-color-tl-text-muted tl-u-border-color-rgba-255-255-255-0-1"
                                                 title="@val">
                                            @LibraryHelpers.FormatClaimKey(key)
                                        </AppChip>
                                    }
                                </div>
                            }
                            @if (result.MatchScores is not null)
                            {
                                <div class="d-flex flex-wrap gap-3">
                                    <span class="tl-u-font-size-0-7rem">
                                        <span class="tl-u-color-tl-text-muted">Title:</span>
                                        <span class="tl-u-color-tl-text-secondary">@result.MatchScores.TitleScore.ToString("F2")</span>
                                    </span>
                                    <span class="tl-u-font-size-0-7rem">
                                        <span class="tl-u-color-tl-text-muted">Author:</span>
                                        <span class="tl-u-color-tl-text-secondary">@result.MatchScores.AuthorScore.ToString("F2")</span>
                                    </span>
                                    <span class="tl-u-font-size-0-7rem">
                                        <span class="tl-u-color-tl-text-muted">Year:</span>
                                        <span class="tl-u-color-tl-text-secondary">@result.MatchScores.YearScore.ToString("F2")</span>
                                    </span>
                                    <span class="tl-u-font-size-0-7rem">
                                        <span class="tl-u-color-tl-text-muted">Composite:</span>
                                        <span class="tl-u-color-tl-text-secondary">@result.MatchScores.CompositeScore.ToString("F2")</span>
                                    </span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </AppPanel>
    }

    @* -- Retail Results -- *@
    @if (_results is { Count: > 0 })
    {
        @* Stats bar *@
        <div class="d-flex align-center gap-4 mb-4 tl-u-color-tl-text-secondary" >
            <MudText Typo="Typo.body2">
                <strong class="tl-u-color-tl-text-primary">@_results.Count</strong> retail result@(_results.Count == 1 ? "" : "s")
                from <strong class="tl-u-color-tl-text-primary">@_results.Select(r => r.ProviderName).Distinct().Count()</strong> provider@(_results.Select(r => r.ProviderName).Distinct().Count() == 1 ? "" : "s")
            </MudText>
            @if (_searchDuration > TimeSpan.Zero)
            {
                <MudText Typo="Typo.body2" Class="tl-u-color-tl-text-muted">
                    @_searchDuration.TotalMilliseconds.ToString("F0")ms
                </MudText>
            }
        </div>

        @* Group results by provider *@
        @foreach (var providerGroup in _results.GroupBy(r => r.ProviderName).OrderByDescending(g => g.Max(r => r.CompositeScore)))
        {
            var providerColor = Catalogue.GetAccentColor(providerGroup.Key);
            var providerDisplay = Catalogue.GetDisplayName(providerGroup.Key);

            <AppPanel Elevation="0" Class="tl-card tl-card--flush mb-4 tl-u-background-rgba-255-255-255-0-03 tl-u-border-1px-solid-tl-border-subtle tl-u-border-radius-12px tl-u-overflow-hidden"
                      >

                @* Provider header *@
                <AppCssElement Tag="div" Class="pa-3 d-flex align-center gap-2"
                     Css="@($"background: {providerColor}18; border-bottom: 1px solid var(--tl-border-subtle);")">
                    <AppCssElement Tag="span" Css="@($"width: 10px; height: 10px; border-radius: 50%; background: {providerColor};")"></AppCssElement>
                    <MudText Typo="Typo.subtitle2" Class="tl-u-color-tl-text-primary tl-u-font-weight-600">
                        @providerDisplay
                    </MudText>
                    <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-muted">
                        @providerGroup.Count() result@(providerGroup.Count() == 1 ? "" : "s")
                    </MudText>
                </AppCssElement>

                @* Result rows *@
                @foreach (var result in providerGroup.OrderByDescending(r => r.CompositeScore))
                {
                    var resultKey = $"{result.ProviderName}:{result.ProviderItemId ?? result.Title}";
                    var isExpanded = _expandedResult == resultKey;

                    <div class="pt-result-row @(isExpanded ? "pt-result-expanded" : "")"
                         @onclick="() => ToggleExpand(resultKey)">

                        @* Cover + main info *@
                        <div class="d-flex gap-3 pa-3 tl-u-cursor-pointer" >
                            @* Cover thumbnail *@
                            <div class="tl-u-width-60px tl-u-height-60px tl-u-border-radius-8px tl-u-overflow-hidden tl-u-flex-shrink-0 tl-u-background-tl-divider">
                                @if (!string.IsNullOrEmpty(result.CoverUrl))
                                {
                                    <img src="@result.CoverUrl" alt="" class="tl-u-width-100pct tl-u-height-100pct tl-u-object-fit-cover" loading="lazy" />
                                }
                                else
                                {
                                    <div class="d-flex align-center justify-center tl-u-width-100pct tl-u-height-100pct" >
                                        <MudIcon Icon="@Icons.Material.Outlined.Image" Class="tl-u-font-size-24px tl-u-color-rgba-255-255-255-0-1" />
                                    </div>
                                }
                            </div>

                            @* Title + metadata *@
                            <div class="tl-u-flex-1 tl-u-min-width-0">
                                <MudText Typo="Typo.subtitle1" Class="tl-u-color-tl-text-primary tl-u-font-weight-600 tl-u-white-space-nowrap tl-u-overflow-hidden tl-u-text-overflow-ellipsis">
                                    @result.Title
                                </MudText>
                                @{
                                    var subline = GetSubline(result);
                                    var tertiary = GetTertiary(result);
                                }
                                @if (!string.IsNullOrEmpty(subline) || !string.IsNullOrEmpty(tertiary))
                                {
                                    <MudText Typo="Typo.body2" Class="tl-u-color-tl-text-secondary">
                                        @subline
                                        @if (!string.IsNullOrEmpty(subline) && !string.IsNullOrEmpty(tertiary))
                                        {
                                            <span class="tl-u-color-tl-text-faint tl-u-margin-0-6px">&middot;</span>
                                        }
                                        @tertiary
                                    </MudText>
                                }
                                @if (!isExpanded && !string.IsNullOrEmpty(result.Description))
                                {
                                    <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-muted tl-u-margin-top-2px">
                                        @(result.Description.Length > 150 ? result.Description[..147] + "..." : result.Description)
                                    </MudText>
                                }
                            </div>

                            @* Score badges *@
                            <div class="d-flex flex-column align-end tl-u-flex-shrink-0" >
                                <AppChip T="string"
                                         Size="Size.Small"
                                         Color="@GetScoreColor(result.CompositeScore)"
                                         Variant="Variant.Outlined"
                                         Class="tl-u-font-family-jetbrains-mono-monospace tl-u-font-size-0-7rem">
                                    @result.CompositeScore.ToString("F2")
                                </AppChip>
                                @if (result.Confidence > 0 && Math.Abs(result.Confidence - result.CompositeScore) > 0.01)
                                {
                                    <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-faint tl-u-margin-top-2px tl-u-font-family-jetbrains-mono-monospace tl-u-font-size-0-6rem"
                                             title="Raw provider confidence score">
                                        raw: @result.Confidence.ToString("F2")
                                    </MudText>
                                }
                                @if (!string.IsNullOrEmpty(result.ProviderItemId))
                                {
                                    <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-faint tl-u-margin-top-2px tl-u-font-family-jetbrains-mono-monospace tl-u-font-size-0-65rem">
                                        @(result.ProviderItemId.Length > 20 ? result.ProviderItemId[..17] + "..." : result.ProviderItemId)
                                    </MudText>
                                }
                                <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                         Size="Size.Small" Class="tl-u-color-tl-text-faint tl-u-margin-top-2px" />
                            </div>
                        </div>

                        @* -- Expanded detail panel -- *@
                        @if (isExpanded)
                        {
                            <div class="pt-detail-panel" @onclick:stopPropagation="true">
                                @* Full description *@
                                @if (!string.IsNullOrEmpty(result.Description))
                                {
                                    <div class="mb-3">
                                        <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-muted tl-u-text-transform-uppercase tl-u-letter-spacing-0-5px tl-u-font-size-0-6rem tl-u-margin-bottom-4px">
                                            Description
                                        </MudText>
                                        <MudText Typo="Typo.body2" Class="tl-u-color-tl-text-secondary tl-u-font-size-0-8rem tl-u-line-height-1-5">
                                            @result.Description
                                        </MudText>
                                    </div>
                                }

                                @* Scores breakdown *@
                                <div class="mb-3">
                                    <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-muted tl-u-text-transform-uppercase tl-u-letter-spacing-0-5px tl-u-font-size-0-6rem tl-u-margin-bottom-4px">
                                        Scores
                                    </MudText>
                                    <div class="d-flex flex-wrap gap-3">
                                        <span class="tl-u-font-size-0-75rem">
                                            <span class="tl-u-color-tl-text-muted">Composite:</span>
                                            <AppCssElement Tag="span" Css="@($"color: {GetScoreHex(result.CompositeScore)}; font-family: 'JetBrains Mono', monospace;")">@result.CompositeScore.ToString("F3")</AppCssElement>
                                        </span>
                                        <span class="tl-u-font-size-0-75rem">
                                            <span class="tl-u-color-tl-text-muted">Provider confidence:</span>
                                            <AppCssElement Tag="span" Css="@($"color: {GetScoreHex(result.Confidence)}; font-family: 'JetBrains Mono', monospace;")">@result.Confidence.ToString("F3")</AppCssElement>
                                        </span>
                                        @if (result.DescriptionMatchScore > 0)
                                        {
                                            <span class="tl-u-font-size-0-75rem">
                                                <span class="tl-u-color-tl-text-muted">Description match:</span>
                                                <AppCssElement Tag="span" Css="@($"color: {GetScoreHex(result.DescriptionMatchScore)}; font-family: 'JetBrains Mono', monospace;")">@result.DescriptionMatchScore.ToString("F3")</AppCssElement>
                                            </span>
                                        }
                                    </div>
                                    @if (result.MatchScores is not null)
                                    {
                                        <div class="d-flex flex-wrap gap-3 mt-1">
                                            <span class="tl-u-font-size-0-7rem">
                                                <span class="tl-u-color-tl-text-muted">Title:</span>
                                                <span class="tl-u-color-tl-text-secondary tl-u-font-family-jetbrains-mono-monospace">@result.MatchScores.TitleScore.ToString("F2")</span>
                                            </span>
                                            <span class="tl-u-font-size-0-7rem">
                                                <span class="tl-u-color-tl-text-muted">Author:</span>
                                                <span class="tl-u-color-tl-text-secondary tl-u-font-family-jetbrains-mono-monospace">@result.MatchScores.AuthorScore.ToString("F2")</span>
                                            </span>
                                            <span class="tl-u-font-size-0-7rem">
                                                <span class="tl-u-color-tl-text-muted">Year:</span>
                                                <span class="tl-u-color-tl-text-secondary tl-u-font-family-jetbrains-mono-monospace">@result.MatchScores.YearScore.ToString("F2")</span>
                                            </span>
                                        </div>
                                    }
                                </div>

                                @* Detail fields *@
                                @{
                                    var details = GetDetailFields(result);
                                }
                                @if (details.Count > 0)
                                {
                                    <div class="mb-3">
                                        <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-muted tl-u-text-transform-uppercase tl-u-letter-spacing-0-5px tl-u-font-size-0-6rem tl-u-margin-bottom-4px">
                                            Metadata
                                        </MudText>
                                        <div class="d-flex flex-wrap gap-3">
                                            @foreach (var (label, val) in details)
                                            {
                                                <span class="tl-u-font-size-0-75rem">
                                                    <span class="tl-u-color-tl-text-muted">@label:</span>
                                                    <span class="tl-u-color-tl-text-secondary">@val</span>
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }

                                @* Bridge IDs *@
                                @{
                                    var bridges = GetBridgeFields(result);
                                }
                                @if (bridges.Count > 0)
                                {
                                    <div class="mb-3">
                                        <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-muted tl-u-text-transform-uppercase tl-u-letter-spacing-0-5px tl-u-font-size-0-6rem tl-u-margin-bottom-4px">
                                            Bridge IDs
                                        </MudText>
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var (label, val) in bridges)
                                            {
                                                <AppChip T="string"
                                                         Size="Size.Small"
                                                         Variant="Variant.Outlined"
                                                         Class="tl-u-font-size-0-65rem tl-u-height-22px tl-u-color-tl-text-secondary tl-u-border-color-tl-border-default"
                                                         title="@val">
                                                    @label: @(val.Length > 30 ? val[..27] + "..." : val)
                                                </AppChip>
                                            }
                                        </div>
                                    </div>
                                }

                                @* Extra fields *@
                                @if (result.ExtraFields.Count > 0)
                                {
                                    <div class="mb-2">
                                        <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-muted tl-u-text-transform-uppercase tl-u-letter-spacing-0-5px tl-u-font-size-0-6rem tl-u-margin-bottom-4px">
                                            Extra Fields
                                        </MudText>
                                        <div class="d-flex flex-wrap gap-3">
                                            @foreach (var (key, val) in result.ExtraFields.OrderBy(kv => kv.Key))
                                            {
                                                <span class="tl-u-font-size-0-7rem">
                                                    <span class="tl-u-color-tl-text-muted">@LibraryHelpers.FormatClaimKey(key):</span>
                                                    <span class="tl-u-color-tl-text-secondary">@(val.Length > 120 ? val[..117] + "..." : val)</span>
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }

                                @* Description field matches *@
                                @if (result.DescriptionFieldMatches is { Count: > 0 })
                                {
                                    <div>
                                        <MudText Typo="Typo.caption" Class="tl-u-color-tl-text-muted tl-u-text-transform-uppercase tl-u-letter-spacing-0-5px tl-u-font-size-0-6rem tl-u-margin-bottom-4px">
                                            Description Field Matches
                                        </MudText>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var fm in result.DescriptionFieldMatches)
                                            {
                                                <AppChip T="string"
                                                         Size="Size.Small"
                                                         Variant="Variant.Outlined"
                                                         Css="@($"font-size: 0.65rem; height: 22px; color: {(fm.Matched ? "#4CAF50" : "var(--tl-text-muted)")}; border-color: {(fm.Matched ? "var(--tl-status-success-border)" : "var(--tl-border-subtle)")};")">
                                                    @LibraryHelpers.FormatClaimKey(fm.FieldKey)
                                                    @(fm.Matched ? " \u2713" : " \u2717")
                                                </AppChip>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </AppPanel>
        }
    }
    else if (!_loading && _hasSearched && _universeResults is not { Count: > 0 })
    {
        <AppAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
            No results found. Try broadening your search or changing the media type.
        </AppAlert>
    }

</div>
@code {

    private string _selectedMediaType = "Books";
    private string _selectedProvider = "all";
    private bool _loading;
    private bool _hasSearched;
    private string? _error;
    private TimeSpan _searchDuration;
    private string? _expandedResult;
    private string? _expandedUniverseResult;

    private IReadOnlyList<SearchableField> _searchableFields = [];
    private readonly HashSet<string> _activeFields = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> _fieldValues = new(StringComparer.OrdinalIgnoreCase);

    private List<RetailCandidateDto> _results = [];
    private List<UniverseCandidateDto> _universeResults = [];
    private IReadOnlyList<ProviderCatalogueDto> _filteredProviders = [];

    private static readonly string[] _mediaTypes =
        ["Books", "Audiobooks", "Music", "Movies", "TV", "Comics"];

    protected override async Task OnInitializedAsync()
    {
        await Catalogue.GetCatalogueAsync();
        await RefreshProviderListAsync();
        RefreshSearchableFields();
    }

    private async Task OnMediaTypeChanged(string newType)
    {
        _selectedMediaType = newType;
        _selectedProvider = "all";
        await RefreshProviderListAsync();
        RefreshSearchableFields();
        _results = [];
        _universeResults = [];
        _hasSearched = false;
        _error = null;
        _expandedResult = null;
        _expandedUniverseResult = null;
    }

    private async Task RefreshProviderListAsync()
    {
        var catalogue = await Catalogue.GetCatalogueAsync();
        _filteredProviders = catalogue
            .Where(p => p.MediaTypes.Any(mt =>
                string.Equals(mt, _selectedMediaType, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(mt, MapMediaTypeAlias(_selectedMediaType), StringComparison.OrdinalIgnoreCase)))
            .Where(p => !string.Equals(p.Name, "wikidata_reconciliation", StringComparison.OrdinalIgnoreCase)
                     && !string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase))
            .OrderBy(p => p.DisplayName)
            .ToList();
    }

    private void RefreshSearchableFields()
    {
        var mediaType = ParseMediaType(_selectedMediaType);
        _searchableFields = MediaTypeFieldCatalog.GetSearchableFields(mediaType);
        _activeFields.Clear();
        _fieldValues.Clear();
        foreach (var f in _searchableFields)
        {
            _fieldValues[f.FieldKey] = "";
            if (f.IsDefault)
                _activeFields.Add(f.FieldKey);
        }
    }

    private void ToggleField(string key)
    {
        if (_activeFields.Contains(key))
        {
            _activeFields.Remove(key);
            _fieldValues[key] = "";
        }
        else
        {
            _activeFields.Add(key);
        }
    }

    private void ClearField(string key)
    {
        _fieldValues[key] = "";
    }

    private bool HasAnyFieldValue() =>
        _activeFields.Any(k => _fieldValues.TryGetValue(k, out var v) && !string.IsNullOrWhiteSpace(v));

    private async Task OnFieldKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && HasAnyFieldValue())
            await RunSearch();
    }

    private void ToggleExpand(string resultKey)
    {
        _expandedResult = _expandedResult == resultKey ? null : resultKey;
    }

    private void ToggleUniverseExpand(string qid)
    {
        _expandedUniverseResult = _expandedUniverseResult == qid ? null : qid;
    }

    private async Task RunSearch()
    {
        if (!HasAnyFieldValue()) return;

        _loading = true;
        _error = null;
        _results = [];
        _universeResults = [];
        _hasSearched = true;
        _expandedResult = null;
        _expandedUniverseResult = null;
        StateHasChanged();

        var sw = System.Diagnostics.Stopwatch.StartNew();

        try
        {
            var searchFields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            foreach (var key in _activeFields)
            {
                if (_fieldValues.TryGetValue(key, out var val) && !string.IsNullOrWhiteSpace(val))
                    searchFields[key] = val.Trim();
            }
            var combinedQuery = string.Join(" ", searchFields.Values);

            var isWikidataOnly = _selectedProvider == "wikidata";
            if (!isWikidataOnly)
            {
                var response = await ApiClient.SearchRetailAsync(
                    combinedQuery,
                    _selectedMediaType,
                    maxCandidates: 25,
                    searchFields: searchFields);

                if (response?.Candidates is not null)
                {
                    _results = response.Candidates;
                    if (_selectedProvider != "all" && _selectedProvider != "wikidata")
                    {
                        _results = _results
                            .Where(r => string.Equals(r.ProviderName, _selectedProvider, StringComparison.OrdinalIgnoreCase))
                            .ToList();
                    }
                }
            }
            if (_selectedProvider == "all" || isWikidataOnly)
            {
                searchFields.TryGetValue("author", out var author);
                if (author is null) searchFields.TryGetValue("artist", out author);

                var universeResponse = await ApiClient.SearchUniverseAsync(
                    combinedQuery,
                    _selectedMediaType,
                    maxCandidates: 10,
                    localAuthor: author);

                if (universeResponse?.Candidates is not null)
                {
                    _universeResults = universeResponse.Candidates;
                }
            }
        }
        catch (Exception ex)
        {
            _error = $"Search failed: {ex.Message}";
        }
        finally
        {
            sw.Stop();
            _searchDuration = sw.Elapsed;
            _loading = false;
            StateHasChanged();
        }
    }

    private string? GetSubline(RetailCandidateDto result)
    {
        var display = MediaTypeFieldCatalog.GetSearchDisplay(ParseMediaType(_selectedMediaType));
        return GetFieldValue(result, display.Subline);
    }

    private string? GetTertiary(RetailCandidateDto result)
    {
        var display = MediaTypeFieldCatalog.GetSearchDisplay(ParseMediaType(_selectedMediaType));
        return GetFieldValue(result, display.Tertiary);
    }

    private List<(string Label, string Value)> GetDetailFields(RetailCandidateDto result)
    {
        var display = MediaTypeFieldCatalog.GetSearchDisplay(ParseMediaType(_selectedMediaType));
        var allFields = BuildFieldLookup(result);
        var details = new List<(string, string)>();

        foreach (var key in display.DetailFields)
        {
            if (key == display.Subline || key == display.Tertiary) continue;
            if (allFields.TryGetValue(key, out var val) && !string.IsNullOrWhiteSpace(val))
                details.Add((LibraryHelpers.FormatClaimKey(key), val.Length > 80 ? val[..77] + "\u2026" : val));
        }
        return details;
    }

    private List<(string Label, string Value)> GetBridgeFields(RetailCandidateDto result)
    {
        var display = MediaTypeFieldCatalog.GetSearchDisplay(ParseMediaType(_selectedMediaType));
        var allFields = BuildFieldLookup(result);
        var bridges = new List<(string, string)>();

        foreach (var key in display.BridgeLabels)
        {
            if (allFields.TryGetValue(key, out var val) && !string.IsNullOrWhiteSpace(val))
                bridges.Add((LibraryHelpers.FormatClaimKey(key), val));
        }
        return bridges;
    }

    private string? GetFieldValue(RetailCandidateDto result, string key)
    {
        var lookup = BuildFieldLookup(result);
        return lookup.TryGetValue(key, out var val) && !string.IsNullOrWhiteSpace(val) ? val : null;
    }

    private static Dictionary<string, string> BuildFieldLookup(RetailCandidateDto result)
    {
        var lookup = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrEmpty(result.Title)) lookup["title"] = result.Title;
        if (!string.IsNullOrEmpty(result.Author)) { lookup["author"] = result.Author; lookup["artist"] = result.Author; }
        if (!string.IsNullOrEmpty(result.Director)) lookup["director"] = result.Director;
        if (!string.IsNullOrEmpty(result.Year)) lookup["year"] = result.Year;
        if (!string.IsNullOrEmpty(result.Description)) lookup["description"] = result.Description;
        if (!string.IsNullOrEmpty(result.ProviderItemId)) lookup["provider_item_id"] = result.ProviderItemId;
        foreach (var (key, val) in result.ExtraFields)
        {
            if (!string.IsNullOrWhiteSpace(val))
                lookup.TryAdd(key, val);
        }

        return lookup;
    }

    private static Color GetScoreColor(double score) => score switch
    {
        >= 0.85 => Color.Success,
        >= 0.60 => Color.Warning,
        _ => Color.Default,
    };

    private static string GetScoreHex(double score) => score switch
    {
        >= 0.85 => "#4CAF50",
        >= 0.60 => "var(--tl-status-warning)",
        _ => "var(--tl-text-secondary)",
    };

    private static MediaType ParseMediaType(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return MediaType.Unknown;
        var normalized = s.Trim() switch
        {
            "Epub" => "Books",
            "Audiobook" or "Audiobooks" => "Audiobooks",
            "Comics" => "Comic",
            _ => s.Trim(),
        };
        return Enum.TryParse<MediaType>(normalized, ignoreCase: true, out var mt) ? mt : MediaType.Unknown;
    }

    private static string? MapMediaTypeAlias(string type) => type switch
    {
        "Books" => "Epub",
        "Audiobooks" => "Audiobook",
        _ => null,
    };
}
