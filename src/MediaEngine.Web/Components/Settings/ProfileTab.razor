@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject DeviceContextService DeviceContext
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedStrings> L
@inject NavigationManager Nav
@implements IDisposable
@{
    var layout       = DeviceContext.Settings.Pages.Preferences.GeneralTabLayout;
    var showProfile  = !DeviceContext.IsFeatureDisabled("profile_section") && layout != "theme-only";
    var showLocale   = !DeviceContext.IsFeatureDisabled("locale_section") && layout != "theme-only";

    var initials = _displayName.Length > 0 ? _displayName[0].ToString().ToUpper() : "?";
}

<div class="tl-page">
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6" Spacing="2">
        <MudIcon Icon="@Icons.Material.Outlined.Fingerprint" Color="Color.Default" Class="mr-1" />
        <MudText Typo="Typo.h6">@L["Profile_AccountIdentity"]</MudText>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else
    {
@if (showProfile)
        {
            @* Avatar + fields row *@
            <div class="tl-u-display-flex tl-u-flex-direction-row tl-u-align-items-flex-start tl-u-gap-2rem tl-u-margin-bottom-1-5rem">

                @* Large avatar with camera overlay *@
                <div class="tl-u-position-relative tl-u-flex-shrink-0">
                    <AppAvatar Initials="@initials"
                               AccentColor="@_avatarColor"
                               Class="profile-avatar-preview" />
<div class="tl-u-position-absolute tl-u-bottom-0 tl-u-right-0 tl-u-width-32px tl-u-height-32px tl-u-border-radius-50pct tl-u-background-rgba-17-20-25-0-9 tl-u-border-1px-solid-rgba-51-65-85-0-6 tl-u-display-flex tl-u-align-items-center tl-u-justify-content-center tl-u-cursor-pointer"
                         title="@L["Profile_UploadAvatarComingSoon"]">
                        <MudIcon Icon="@Icons.Material.Outlined.CameraAlt"
                                 Class="tl-u-font-size-1rem tl-u-color-mud-palette-text-secondary" />
                    </div>
                </div>
<div class="tl-u-flex-1 tl-u-min-width-0">
                    <MudGrid Spacing="3">
                        @* Display Name *@
                        <MudItem xs="12" sm="6">
                            @if (DeviceContext.Settings.Constraints.AllowTextInput)
                            {
                                <AppTextField @bind-Value="_displayName"
                                              Label="@L["Profile_DisplayName"]"
                                              Variant="Variant.Outlined"
                                              FullWidth="true"
                                              Immediate="true"
                                              MaxLength="50" />
                            }
                            else
                            {
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@L["Profile_DisplayName"]</MudText>
                                <MudText Typo="Typo.body1">@_displayName</MudText>
                            }
                        </MudItem>
<MudItem xs="12" sm="6">
                            <div class="tl-u-border-1px-solid-rgba-255-255-255-0-23 tl-u-border-radius-4px tl-u-padding-16-5px-14px tl-u-cursor-not-allowed tl-u-opacity-0-7">
                                <div class="tl-u-font-size-0-75rem tl-u-color-mud-palette-text-secondary tl-u-margin-bottom-4px tl-u-line-height-1">
                                    @L["Profile_Role"]
                                </div>
                                <div class="tl-u-font-size-1rem tl-u-color-mud-palette-text-secondary">
                                    @_role
                                </div>
                            </div>
                        </MudItem>
                    </MudGrid>
                </div>

            </div>

            <MudDivider Class="my-6" />
        }
@if (showLocale && DeviceContext.Settings.Constraints.AllowTextInput)
        {
            <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-4 tl-u-letter-spacing-0-08em"
                     >
                @L["Profile_DisplayAndLocale"]
            </MudText>

            <MudGrid Spacing="3" Class="mb-6">
                <MudItem xs="12" sm="6">
                    <AppSelect T="string"
                               @bind-Value="_dateFormat"
                               Label="@L["Profile_DateFormat"]"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               AnchorOrigin="Origin.BottomLeft">
                        <MudSelectItem T="string" Value="@("System")">@L["Profile_SystemDefault"]</MudSelectItem>
                        <MudSelectItem T="string" Value="@("DD/MM/YYYY")">DD/MM/YYYY</MudSelectItem>
                        <MudSelectItem T="string" Value="@("MM/DD/YYYY")">MM/DD/YYYY</MudSelectItem>
                        <MudSelectItem T="string" Value="@("YYYY-MM-DD")">YYYY-MM-DD</MudSelectItem>
                    </AppSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <AppSelect T="string"
                               @bind-Value="_timeFormat"
                               Label="@L["Profile_TimeFormat"]"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               AnchorOrigin="Origin.BottomLeft">
                        <MudSelectItem T="string" Value="@("System")">@L["Profile_SystemDefault"]</MudSelectItem>
                        <MudSelectItem T="string" Value="@("12-hour")">@L["Profile_TimeFormat12Hour"]</MudSelectItem>
                        <MudSelectItem T="string" Value="@("24-hour")">@L["Profile_TimeFormat24Hour"]</MudSelectItem>
                    </AppSelect>
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-6" />
        }
@if (showLocale && DeviceContext.Settings.Constraints.AllowTextInput)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Translate" Color="Color.Default" Class="mr-1" />
                <MudText Typo="Typo.overline" Color="Color.Secondary"
                         Class="tl-u-letter-spacing-0-08em">
                    @L["Profile_LanguagePreferences"]
                </MudText>
            </MudStack>

            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                @L["Profile_LanguagePreferencesHint"]
            </MudText>

            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12" sm="6">
                    <AppSelect T="string"
                               @bind-Value="_displayLanguage"
                               Label="@L["Profile_DisplayLanguage"]"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               HelperText="@L["Profile_DisplayLanguageHelper"]"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var lang in _languageOptions)
                        {
                            <MudSelectItem T="string" Value="@lang.Code">@lang.Name</MudSelectItem>
                        }
                    </AppSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <AppSelect T="string"
                               @bind-Value="_metadataLanguage"
                               Label="@L["Profile_MetadataLanguage"]"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               HelperText="@L["Profile_MetadataLanguageHelper"]"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var lang in _languageOptions)
                        {
                            <MudSelectItem T="string" Value="@lang.Code">@lang.Name</MudSelectItem>
                        }
                    </AppSelect>
                </MudItem>
            </MudGrid>

            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12">
                    <AppSelect T="string"
                               @bind-SelectedValues="_additionalLanguages"
                               Label="@L["Profile_AdditionalContentLanguages"]"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               MultiSelection="true"
                               HelperText="@L["Profile_AdditionalContentLanguagesHelper"]"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var lang in _languageOptions)
                        {
                            <MudSelectItem T="string" Value="@lang.Code">@lang.Name</MudSelectItem>
                        }
                    </AppSelect>
                </MudItem>
            </MudGrid>

            <AppSwitchRow T="bool"
                       @bind-Value="_acceptAnyLanguage"
                       Label="@L["Profile_AcceptAnyLanguage"]"
                       Color="Color.Primary"
                       Class="mb-2" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-6">
                @L["Profile_AcceptAnyLanguageHint"]
            </MudText>

            <MudDivider Class="my-6" />
        }
@if (showProfile)
        {
            <AppButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="@SaveProfileAsync"
                       Disabled="@(_saving || string.IsNullOrWhiteSpace(_displayName))">
                @(_saving ? L["Profile_Saving"] : L["Profile_SaveProfile"])
            </AppButton>
        }
    }

</div>

@code {

    private bool   _loading     = true;
    private bool   _saving;
    private Guid   _profileId;
    private string _displayName = string.Empty;
    private string _avatarColor = "#7C4DFF";
    private string _role        = "Administrator";
    private string _dateFormat  = "System";
    private string _timeFormat  = "System";
    private string _savedDisplayLanguage = "en";  // track original to detect changes
    private string _displayLanguage    = "en";
    private string _metadataLanguage   = "en";
    private IReadOnlyCollection<string> _additionalLanguages = Array.Empty<string>();
    private bool   _acceptAnyLanguage  = true;

    private static readonly (string Code, string Name)[] _languageOptions =
    [
        ("en", "English"),
        ("fr", "French"),
        ("de", "German"),
        ("es", "Spanish"),
        ("pt", "Portuguese"),
        ("it", "Italian"),
        ("ja", "Japanese"),
        ("ko", "Korean"),
        ("zh", "Chinese"),
        ("ru", "Russian"),
        ("hi", "Hindi"),
        ("ar", "Arabic"),
        ("nl", "Dutch"),
        ("sv", "Swedish"),
        ("pl", "Polish"),
        ("tr", "Turkish"),
    ];

    protected override async Task OnInitializedAsync()
    {
        DeviceContext.OnChanged += OnDeviceChanged;
        await LoadProfileAsync();
        await LoadLanguagePrefsAsync();
    }

    public void Dispose()
    {
        DeviceContext.OnChanged -= OnDeviceChanged;
    }

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadProfileAsync()
    {
        _loading = true;
        var profiles = await Orchestrator.GetProfilesAsync();
        if (profiles is { Count: > 0 })
        {
            var active    = profiles[0];
            _profileId    = active.Id;
            _displayName  = active.DisplayName;
            _avatarColor  = active.AvatarColor;
            _role         = active.Role;
        }
        _loading = false;
    }

    private async Task LoadLanguagePrefsAsync()
    {
        var settings = await Orchestrator.GetServerGeneralAsync();
        if (settings is not null)
        {
            _displayLanguage    = settings.DisplayLanguage;
            _savedDisplayLanguage = settings.DisplayLanguage;
            _metadataLanguage   = settings.MetadataLanguage;
            _additionalLanguages = settings.AdditionalLanguages?.AsReadOnly()
                                   ?? (IReadOnlyCollection<string>)Array.Empty<string>();
            _acceptAnyLanguage  = settings.AcceptAnyLanguage;
        }
    }

    private async Task SaveProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(_displayName)) return;
        _saving = true;

        var ok = await Orchestrator.UpdateProfileAsync(_profileId, _displayName.Trim(), _avatarColor, _role);
        if (ok)
            Snackbar.Add(L["Profile_ProfileUpdated"], Severity.Success);
        else
            Snackbar.Add(L["Profile_CouldNotSaveProfile"], Severity.Error);
        var currentSettings = await Orchestrator.GetServerGeneralAsync();
        if (currentSettings is not null)
        {
            var updated = currentSettings with
            {
                DisplayLanguage     = _displayLanguage,
                MetadataLanguage    = _metadataLanguage,
                AdditionalLanguages = _additionalLanguages.ToList(),
                AcceptAnyLanguage   = _acceptAnyLanguage,
            };
            var langOk = await Orchestrator.UpdateServerGeneralAsync(updated);
            if (!langOk)
                Snackbar.Add(L["Profile_CouldNotSaveLanguagePreferences"], Severity.Warning);
            if (langOk && !string.Equals(_displayLanguage, _savedDisplayLanguage, StringComparison.OrdinalIgnoreCase))
            {
                var redirectBack = Uri.EscapeDataString(Nav.Uri);
                Nav.NavigateTo($"/culture/set?culture={Uri.EscapeDataString(_displayLanguage)}&redirectUri={redirectBack}", forceLoad: true);
                return; // page will reload
            }
        }

        _saving = false;
    }

}
