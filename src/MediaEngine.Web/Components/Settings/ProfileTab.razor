@namespace MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject DeviceContextService DeviceContext
@inject ISnackbar Snackbar
@implements IDisposable

@* ProfileTab — Profile identity, visual preferences, and locale settings.
   Layout driven by device context:
     "full"       → Web: all sections visible (profile + avatar colour + locale)
     "stacked"    → Mobile: compact profile, fewer swatches
     "theme-only" → Television / Automotive: minimal display *@

@{
    var layout       = DeviceContext.Settings.Pages.Preferences.GeneralTabLayout;
    var swatchCount  = DeviceContext.Settings.Pages.Preferences.ColorSwatchCount;
    var showProfile  = !DeviceContext.IsFeatureDisabled("profile_section") && layout != "theme-only";
    var showColorPicker = !DeviceContext.IsFeatureDisabled("color_picker") && layout != "theme-only";
    var showLocale   = !DeviceContext.IsFeatureDisabled("locale_section") && layout != "theme-only";

    var initials = _displayName.Length > 0 ? _displayName[0].ToString().ToUpper() : "?";
}

<div class="st-page">

    @* ── Section header: Account Identity ───────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6" Spacing="2">
        <MudIcon Icon="@Icons.Material.Outlined.Fingerprint" Color="Color.Default" Class="mr-1" />
        <MudText Typo="Typo.h6">Account Identity</MudText>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else
    {
        @* ── Profile section (hidden on TV/automotive) ─────────────────── *@

        @if (showProfile)
        {
            @* Avatar + fields row *@
            <div style="display: flex; flex-direction: row; align-items: flex-start; gap: 2rem; margin-bottom: 1.5rem;">

                @* Large avatar with camera overlay *@
                <div style="position: relative; flex-shrink: 0;">
                    <MudAvatar Style="@($"background: {_avatarColor}; width: 128px; height: 128px; font-size: 2.5rem; border-radius: 2.5rem;")">
                        @initials
                    </MudAvatar>
                    @* Camera icon overlay — bottom-right corner, future avatar upload *@
                    <div style="position: absolute; bottom: 0; right: 0;
                                width: 32px; height: 32px; border-radius: 50%;
                                background: rgba(17,20,25,0.9); border: 1px solid rgba(51,65,85,0.6);
                                display: flex; align-items: center; justify-content: center;
                                cursor: pointer;"
                         title="Upload avatar (coming soon)">
                        <MudIcon Icon="@Icons.Material.Outlined.CameraAlt"
                                 Style="font-size: 1rem; color: var(--mud-palette-text-secondary);" />
                    </div>
                </div>

                @* Display Name + Role — 2-column grid *@
                <div style="flex: 1; min-width: 0;">
                    <MudGrid Spacing="3">
                        @* Display Name *@
                        <MudItem xs="12" sm="6">
                            @if (DeviceContext.Settings.Constraints.AllowTextInput)
                            {
                                <MudTextField @bind-Value="_displayName"
                                              Label="Display Name"
                                              Variant="Variant.Outlined"
                                              FullWidth="true"
                                              Immediate="true"
                                              MaxLength="50" />
                            }
                            else
                            {
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Display Name</MudText>
                                <MudText Typo="Typo.body1">@_displayName</MudText>
                            }
                        </MudItem>

                        @* Role — read-only *@
                        <MudItem xs="12" sm="6">
                            <div style="border: 1px solid rgba(255,255,255,0.23); border-radius: 4px; padding: 16.5px 14px; cursor: not-allowed; opacity: 0.7;">
                                <div style="font-size: 0.75rem; color: var(--mud-palette-text-secondary); margin-bottom: 4px; line-height: 1;">
                                    Role
                                </div>
                                <div style="font-size: 1rem; color: var(--mud-palette-text-secondary);">
                                    @_role
                                </div>
                            </div>
                        </MudItem>
                    </MudGrid>
                </div>

            </div>

            @* Avatar colour swatches *@
            @if (showColorPicker)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-1">Avatar Colour</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                    Choose a colour for your avatar circle.
                </MudText>

                <MudStack Row="true" Spacing="2" Style="flex-wrap: wrap;" Class="mb-6">
                    @foreach (var hex in _avatarPresets.Take(swatchCount))
                    {
                        <MudAvatar Size="Size.Medium"
                                   Style="@AvatarSwatchStyle(hex)"
                                   @onclick="@(() => { _avatarColor = hex; })" />
                    }
                </MudStack>
            }

            <MudDivider Class="my-6" />
        }

        @* ── Locale section ──────────────────────────────────────────────── *@

        @if (showLocale && DeviceContext.Settings.Constraints.AllowTextInput)
        {
            <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-4"
                     Style="letter-spacing: 0.08em;">
                Display &amp; Locale
            </MudText>

            <MudGrid Spacing="3" Class="mb-6">
                <MudItem xs="12" sm="6">
                    <MudSelect T="string"
                               @bind-Value="_dateFormat"
                               Label="Date Format"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               AnchorOrigin="Origin.BottomLeft">
                        <MudSelectItem T="string" Value="@("System")">System Default</MudSelectItem>
                        <MudSelectItem T="string" Value="@("DD/MM/YYYY")">DD/MM/YYYY</MudSelectItem>
                        <MudSelectItem T="string" Value="@("MM/DD/YYYY")">MM/DD/YYYY</MudSelectItem>
                        <MudSelectItem T="string" Value="@("YYYY-MM-DD")">YYYY-MM-DD</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string"
                               @bind-Value="_timeFormat"
                               Label="Time Format"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               AnchorOrigin="Origin.BottomLeft">
                        <MudSelectItem T="string" Value="@("System")">System Default</MudSelectItem>
                        <MudSelectItem T="string" Value="@("12-hour")">12-hour (AM/PM)</MudSelectItem>
                        <MudSelectItem T="string" Value="@("24-hour")">24-hour</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-6" />
        }

        @* ── Language Preferences section ──────────────────────────────── *@

        @if (showLocale && DeviceContext.Settings.Constraints.AllowTextInput)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Translate" Color="Color.Default" Class="mr-1" />
                <MudText Typo="Typo.overline" Color="Color.Secondary"
                         Style="letter-spacing: 0.08em;">
                    Language Preferences
                </MudText>
            </MudStack>

            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                Control which languages the Engine uses for metadata lookups and which content languages
                are accepted without review.
            </MudText>

            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12" sm="6">
                    <MudSelect T="string"
                               @bind-Value="_displayLanguage"
                               Label="Display Language"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               HelperText="Language for UI labels and Wikidata display"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var lang in _languageOptions)
                        {
                            <MudSelectItem T="string" Value="@lang.Code">@lang.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string"
                               @bind-Value="_metadataLanguage"
                               Label="Metadata Language"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               HelperText="Language for provider queries and Wikidata lookups"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var lang in _languageOptions)
                        {
                            <MudSelectItem T="string" Value="@lang.Code">@lang.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12">
                    <MudSelect T="string"
                               @bind-SelectedValues="_additionalLanguages"
                               Label="Additional Content Languages"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               MultiSelection="true"
                               HelperText="Languages you consume content in — files in these languages won't be flagged"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var lang in _languageOptions)
                        {
                            <MudSelectItem T="string" Value="@lang.Code">@lang.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudSwitch T="bool"
                       @bind-Value="_acceptAnyLanguage"
                       Label="Accept any language"
                       Color="Color.Primary"
                       Class="mb-2" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-6">
                When enabled, files in any language are ingested without review flags.
                Disable this to restrict accepted languages to your display, metadata, and additional languages.
            </MudText>

            <MudDivider Class="my-6" />
        }

        @* ── Save button (only when profile section is visible) ──────── *@

        @if (showProfile)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="@SaveProfileAsync"
                       Disabled="@(_saving || string.IsNullOrWhiteSpace(_displayName))">
                @(_saving ? "Saving..." : "Save Profile")
            </MudButton>
        }
    }

</div>

@code {

    // ── Avatar colour presets ────────────────────────────────────────────────────

    private static readonly string[] _avatarPresets =
    [
        "#7C4DFF", "#00BFA5", "#FF8F00", "#E91E63",
        "#2196F3", "#4CAF50", "#FF5722", "#9C27B0",
    ];

    // ── State ────────────────────────────────────────────────────────────────────

    private bool   _loading     = true;
    private bool   _saving;
    private Guid   _profileId;
    private string _displayName = string.Empty;
    private string _avatarColor = "#7C4DFF";
    private string _role        = "Administrator";

    // Locale preferences — stored locally, no API round-trip yet
    private string _dateFormat  = "System";
    private string _timeFormat  = "System";

    // Language preferences
    private string _displayLanguage    = "en";
    private string _metadataLanguage   = "en";
    private IReadOnlyCollection<string> _additionalLanguages = Array.Empty<string>();
    private bool   _acceptAnyLanguage  = true;

    private static readonly (string Code, string Name)[] _languageOptions =
    [
        ("en", "English"),
        ("fr", "French"),
        ("de", "German"),
        ("es", "Spanish"),
        ("pt", "Portuguese"),
        ("it", "Italian"),
        ("ja", "Japanese"),
        ("ko", "Korean"),
        ("zh", "Chinese"),
        ("ru", "Russian"),
        ("hi", "Hindi"),
        ("ar", "Arabic"),
        ("nl", "Dutch"),
        ("sv", "Swedish"),
        ("pl", "Polish"),
        ("tr", "Turkish"),
    ];

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        DeviceContext.OnChanged += OnDeviceChanged;
        await LoadProfileAsync();
        await LoadLanguagePrefsAsync();
    }

    public void Dispose()
    {
        DeviceContext.OnChanged -= OnDeviceChanged;
    }

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    // ── Profile ──────────────────────────────────────────────────────────────────

    private async Task LoadProfileAsync()
    {
        _loading = true;
        var profiles = await Orchestrator.GetProfilesAsync();
        if (profiles is { Count: > 0 })
        {
            var active    = profiles[0];
            _profileId    = active.Id;
            _displayName  = active.DisplayName;
            _avatarColor  = active.AvatarColor;
            _role         = active.Role;
        }
        _loading = false;
    }

    private async Task LoadLanguagePrefsAsync()
    {
        var settings = await Orchestrator.GetServerGeneralAsync();
        if (settings is not null)
        {
            _displayLanguage    = settings.DisplayLanguage;
            _metadataLanguage   = settings.MetadataLanguage;
            _additionalLanguages = settings.AdditionalLanguages?.AsReadOnly()
                                   ?? (IReadOnlyCollection<string>)Array.Empty<string>();
            _acceptAnyLanguage  = settings.AcceptAnyLanguage;
        }
    }

    private async Task SaveProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(_displayName)) return;
        _saving = true;

        var ok = await Orchestrator.UpdateProfileAsync(_profileId, _displayName.Trim(), _avatarColor, _role);
        if (ok)
            Snackbar.Add("Profile updated", Severity.Success);
        else
            Snackbar.Add("Could not save profile — is the Engine running?", Severity.Error);

        // Save language preferences to Engine config
        var currentSettings = await Orchestrator.GetServerGeneralAsync();
        if (currentSettings is not null)
        {
            var updated = currentSettings with
            {
                DisplayLanguage     = _displayLanguage,
                MetadataLanguage    = _metadataLanguage,
                AdditionalLanguages = _additionalLanguages.ToList(),
                AcceptAnyLanguage   = _acceptAnyLanguage,
            };
            var langOk = await Orchestrator.UpdateServerGeneralAsync(updated);
            if (!langOk)
                Snackbar.Add("Could not save language preferences", Severity.Warning);
        }

        _saving = false;
    }

    // ── Swatch styles ────────────────────────────────────────────────────────────

    private string AvatarSwatchStyle(string hex)
    {
        bool isActive = _avatarColor.Equals(hex, StringComparison.OrdinalIgnoreCase);
        return $"background: {hex}; cursor: pointer; " +
               $"border: 3px solid {(isActive ? "var(--app-swatch-active)" : "var(--app-swatch-border)")}; " +
               "transition: border 0.2s ease;";
    }
}
