@namespace MediaEngine.Web.Components.Shared.Shell

<header class="sidebar-page-header">
    <div class="sidebar-page-header__copy">
        @if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            <div class="sidebar-page-header__eyebrow">@Eyebrow</div>
        }
        <h1>@Title</h1>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <p>@Subtitle</p>
        }
    </div>

    @if (Actions is not null || !string.IsNullOrWhiteSpace(Status))
    {
        <div class="sidebar-page-header__actions">
            @if (!string.IsNullOrWhiteSpace(Status))
            {
                <span class="sidebar-page-header__status @(Healthy ? "is-healthy" : "is-warning")">
                    @Status
                </span>
            }
            @Actions
        </div>
    }
</header>

@code {
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? Status { get; set; }
    [Parameter] public bool Healthy { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
