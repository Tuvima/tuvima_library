@namespace MediaEngine.Web.Components.Shared
@using MediaEngine.Web.Resources
@inject IStringLocalizer<SharedStrings> L

<div class="@RootClass" role="alert">
    <MudIcon Icon="@ResolvedIcon" Class="app-error-state__icon" />
    <div class="app-error-state__copy">
        <h3>@ResolvedTitle</h3>
        <p>@ResolvedMessage</p>
        @if (!string.IsNullOrWhiteSpace(Details))
        {
            <p class="app-error-state__details">@Details</p>
        }
    </div>
    @if (Retry.HasDelegate)
    {
        <MudButton Variant="Variant.Outlined"
                   Size="@(Compact ? Size.Small : Size.Medium)"
                   StartIcon="@Icons.Material.Outlined.Refresh"
                   OnClick="Retry"
                   Class="app-error-state__retry">
            @RetryLabel
        </MudButton>
    }
</div>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Message { get; set; }
    [Parameter] public string? Details { get; set; }
    [Parameter] public EventCallback Retry { get; set; }
    [Parameter] public bool Compact { get; set; }
    [Parameter] public string? Icon { get; set; }

    private string ResolvedTitle => string.IsNullOrWhiteSpace(Title)
        ? L["Error"].Value
        : Title;

    private string ResolvedMessage => string.IsNullOrWhiteSpace(Message)
        ? L["Try again"].Value
        : Message;

    private string RetryLabel => L["Retry"].Value;

    private string ResolvedIcon => string.IsNullOrWhiteSpace(Icon)
        ? Icons.Material.Outlined.ErrorOutline
        : Icon;

    private string RootClass => Compact
        ? "app-error-state app-error-state--compact"
        : "app-error-state";
}
