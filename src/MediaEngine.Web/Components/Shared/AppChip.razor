@namespace MediaEngine.Web.Components.Shared

<span class="@RootClass"
      title="@Title"
      style="@ResolvedStyle"
      role="@Role"
      tabindex="@TabIndex"
      @onclick="HandleClick"
      @onkeydown="HandleKeyDown"
      @attributes="AdditionalAttributes">
    @if (!string.IsNullOrWhiteSpace(Icon))
    {
        <MudIcon Icon="@Icon" Size="MudBlazor.Size.Small" />
    }
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        <span>@Text</span>
    }
</span>

@code {
    [Parameter] public string? Text { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public AppUiTone Tone { get; set; } = AppUiTone.Neutral;
    [Parameter] public object? Size { get; set; } = AppControlSize.Compact;
    [Parameter] public Color? Color { get; set; }
    [Parameter] public Variant? Variant { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? T { get; set; }
    [Parameter] public string? InlineStyle { get; set; }
    [Parameter] public string? Css { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string? Role => OnClick.HasDelegate && !Disabled ? "button" : null;
    private int? TabIndex => OnClick.HasDelegate && !Disabled ? 0 : null;
    private string? ResolvedStyle => !string.IsNullOrWhiteSpace(Css) ? Css : InlineStyle;

    private AppUiTone ResolvedTone => Color switch
    {
        MudBlazor.Color.Primary => AppUiTone.Primary,
        MudBlazor.Color.Info => AppUiTone.Info,
        MudBlazor.Color.Success => AppUiTone.Success,
        MudBlazor.Color.Warning => AppUiTone.Warning,
        MudBlazor.Color.Error => AppUiTone.Error,
        _ => Tone,
    };

    private AppControlSize AppSize => AppUiMaps.ToAppControlSize(Size);

    private string RootClass =>
        string.Join(" ", new[]
        {
            "app-chip",
            AppUiMaps.SizeClass(AppSize),
            AppUiMaps.ToneClass(ResolvedTone),
            Variant == MudBlazor.Variant.Filled ? "app-chip--filled" : null,
            OnClick.HasDelegate ? "app-chip--clickable" : null,
            Disabled ? "is-disabled" : null,
            Class,
        }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private Task HandleClick(MouseEventArgs _) =>
        Disabled ? Task.CompletedTask : OnClick.InvokeAsync();

    private Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (Disabled || !OnClick.HasDelegate || (args.Key is not "Enter" and not " "))
        {
            return Task.CompletedTask;
        }

        return OnClick.InvokeAsync();
    }
}
