@namespace MediaEngine.Web.Components.Shared

<MudTabs Class="@RootClass"
         Elevation="@Elevation"
         Rounded="@Rounded"
         Border="@Border"
         ApplyEffectsToContainer="@ApplyEffectsToContainer"
         Color="@Color"
         SliderColor="@SliderColor"
         Position="@Position"
         ActivePanelIndex="@ActivePanelIndex"
         ActivePanelIndexChanged="@ActivePanelIndexChanged"
         @attributes="AdditionalAttributes">
    @ChildContent
</MudTabs>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public int ActivePanelIndex { get; set; }
    [Parameter] public EventCallback<int> ActivePanelIndexChanged { get; set; }
    [Parameter] public int Elevation { get; set; }
    [Parameter] public bool Rounded { get; set; }
    [Parameter] public bool Border { get; set; }
    [Parameter] public bool ApplyEffectsToContainer { get; set; }
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public Color SliderColor { get; set; } = Color.Primary;
    [Parameter] public Position Position { get; set; } = Position.Top;
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string RootClass =>
        string.Join(" ", new[] { "app-tabs", Class }.Where(value => !string.IsNullOrWhiteSpace(value)));
}
