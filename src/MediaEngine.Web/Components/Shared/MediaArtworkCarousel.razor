@namespace MediaEngine.Web.Components.Shared

@if (CarouselItems.Count > 0 && ActiveItem is { } activeItem)
{
    <div class="@CarouselClass"
         role="group"
         aria-label="@AriaLabel"
         tabindex="0"
         @onkeydown="HandleKeyDownAsync">
        <div class="media-artwork-carousel__stage">
            @if (PreviousArtwork is { } previousItem)
            {
                <img @key="@($"previous-{previousItem.Id}")"
                     class="@SideArtworkClass(previousItem, "is-previous")"
                     src="@previousItem.ImageUrl"
                     alt=""
                     loading="eager"
                     decoding="async" />
            }

            @if (NextArtwork is { } nextItem)
            {
                <img @key="@($"next-{nextItem.Id}")"
                     class="@SideArtworkClass(nextItem, "is-next")"
                     src="@nextItem.ImageUrl"
                     alt=""
                     loading="eager"
                     decoding="async" />
            }

            @if (CarouselItems.Count > 1)
            {
                <button type="button"
                        class="media-artwork-carousel__arrow is-previous"
                        aria-label="Previous @ItemNoun"
                        title="Previous @ItemNoun"
                        disabled="@(!CanPrevious)"
                        @onclick="SelectPreviousAsync"
                        @onclick:stopPropagation="true">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" />
                </button>
            }

            <button @key="@($"active-{activeItem.Id}")"
                    type="button"
                    class="@ActiveArtworkClass(activeItem)"
                    aria-label="@($"Open {activeItem.Title}")"
                    title="@($"Open {activeItem.Title}")"
                    @onclick="OpenActiveItemAsync"
                    @onclick:stopPropagation="true">
                <img src="@activeItem.ImageUrl"
                     alt="@activeItem.Title"
                     loading="eager"
                     decoding="async" />
            </button>

            @if (CarouselItems.Count > 1)
            {
                <button type="button"
                        class="media-artwork-carousel__arrow is-next"
                        aria-label="Next @ItemNoun"
                        title="Next @ItemNoun"
                        disabled="@(!CanNext)"
                        @onclick="SelectNextAsync"
                        @onclick:stopPropagation="true">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
                </button>
            }
        </div>

        <div class="media-artwork-carousel__caption" aria-live="polite" aria-atomic="true">
            <strong>@activeItem.Title</strong>
            <span>@ActivePositionLabel</span>
        </div>

        @if (CarouselItems.Count > 1)
        {
            <div class="media-artwork-carousel__pagination" aria-hidden="true">
                <div class="media-artwork-carousel__dots">
                    @foreach (var indicatorIndex in IndicatorIndexes)
                    {
                        <span @key="indicatorIndex"
                              class="@(indicatorIndex == ActiveIndex ? "media-artwork-carousel__dot is-active" : "media-artwork-carousel__dot")"></span>
                    }
                </div>
                <span>@(ActiveIndex + 1) of @ResolvedTotalCount</span>
            </div>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<ArtworkStackItem> Items { get; set; } = [];
    [Parameter] public string? SelectedItemId { get; set; }
    [Parameter] public EventCallback<ArtworkStackItem> SelectedItemChanged { get; set; }
    [Parameter] public EventCallback<ArtworkStackItem> ActiveItemClicked { get; set; }
    [Parameter] public string ItemNoun { get; set; } = "item";
    [Parameter] public int? TotalCount { get; set; }
    [Parameter] public bool Circular { get; set; } = true;
    [Parameter] public string AriaLabel { get; set; } = "Artwork carousel";
    [Parameter] public MediaArtworkCarouselDensity Density { get; set; } = MediaArtworkCarouselDensity.Tile;

    private IReadOnlyList<ArtworkStackItem> CarouselItems => Items
        .Where(item => !string.IsNullOrWhiteSpace(item.ImageUrl))
        .DistinctBy(item => item.Id)
        .ToList();

    private int ActiveIndex
    {
        get
        {
            if (CarouselItems.Count == 0 || string.IsNullOrWhiteSpace(SelectedItemId))
            {
                return 0;
            }

            var index = CarouselItems
                .Select((item, itemIndex) => (item, itemIndex))
                .FirstOrDefault(pair => string.Equals(pair.item.Id, SelectedItemId, StringComparison.Ordinal))
                .itemIndex;
            return index >= 0 && index < CarouselItems.Count ? index : 0;
        }
    }

    private ArtworkStackItem? ActiveItem => CarouselItems.Count == 0 ? null : CarouselItems[ActiveIndex];
    private int ResolvedTotalCount => Math.Max(TotalCount ?? CarouselItems.Count, CarouselItems.Count);
    private bool CanPrevious => CarouselItems.Count > 1 && (Circular || ActiveIndex > 0);
    private bool CanNext => CarouselItems.Count > 1 && (Circular || ActiveIndex < CarouselItems.Count - 1);

    private ArtworkStackItem? PreviousArtwork => CarouselItems.Count switch
    {
        <= 2 => null,
        _ when CanPrevious => CarouselItems[PreviousIndex],
        _ => null,
    };

    private ArtworkStackItem? NextArtwork => CarouselItems.Count switch
    {
        <= 1 => null,
        _ when CanNext => CarouselItems[NextIndex],
        _ => null,
    };

    private int PreviousIndex => Circular
        ? (ActiveIndex - 1 + CarouselItems.Count) % CarouselItems.Count
        : ActiveIndex - 1;

    private int NextIndex => Circular
        ? (ActiveIndex + 1) % CarouselItems.Count
        : ActiveIndex + 1;

    private string CarouselClass =>
        $"media-artwork-carousel {(Density == MediaArtworkCarouselDensity.Detail ? "is-detail" : "is-tile")}";

    private string ActivePositionLabel
    {
        get
        {
            if (ActiveItem is not { } activeItem)
            {
                return string.Empty;
            }

            var position = string.IsNullOrWhiteSpace(activeItem.Position)
                ? $"{ActiveIndex + 1} of {ResolvedTotalCount}"
                : activeItem.Position;
            return $"{ToTitleCase(ItemNoun)} {position}";
        }
    }

    private IReadOnlyList<int> IndicatorIndexes
    {
        get
        {
            const int maximumIndicators = 5;
            if (CarouselItems.Count <= maximumIndicators)
            {
                return Enumerable.Range(0, CarouselItems.Count).ToList();
            }

            var start = Math.Clamp(ActiveIndex - 2, 0, CarouselItems.Count - maximumIndicators);
            return Enumerable.Range(start, maximumIndicators).ToList();
        }
    }

    private Task SelectPreviousAsync() =>
        CanPrevious ? SelectItemAsync(PreviousIndex) : Task.CompletedTask;

    private Task SelectNextAsync() =>
        CanNext ? SelectItemAsync(NextIndex) : Task.CompletedTask;

    private Task SelectFirstAsync() =>
        CarouselItems.Count > 0 ? SelectItemAsync(0) : Task.CompletedTask;

    private Task SelectLastAsync() =>
        CarouselItems.Count > 0 ? SelectItemAsync(CarouselItems.Count - 1) : Task.CompletedTask;

    private Task SelectItemAsync(int index) =>
        SelectedItemChanged.InvokeAsync(CarouselItems[index]);

    private Task OpenActiveItemAsync() => ActiveItem is { } activeItem
        ? ActiveItemClicked.InvokeAsync(activeItem)
        : Task.CompletedTask;

    private Task HandleKeyDownAsync(KeyboardEventArgs args) => args.Key switch
    {
        "ArrowLeft" => SelectPreviousAsync(),
        "ArrowRight" => SelectNextAsync(),
        "Home" => SelectFirstAsync(),
        "End" => SelectLastAsync(),
        _ => Task.CompletedTask,
    };

    private static string SideArtworkClass(ArtworkStackItem item, string positionClass) =>
        $"media-artwork-carousel__side-artwork {positionClass} {ShapeClass(item.Shape)}";

    private static string ActiveArtworkClass(ArtworkStackItem item) =>
        $"media-artwork-carousel__active-artwork {ShapeClass(item.Shape)}";

    private static string ShapeClass(ArtworkShape shape) => shape switch
    {
        ArtworkShape.Square => "is-square-art",
        ArtworkShape.Wide => "is-wide-art",
        _ => "is-portrait-art",
    };

    private static string ToTitleCase(string value) =>
        string.IsNullOrWhiteSpace(value)
            ? "Item"
            : char.ToUpperInvariant(value[0]) + value[1..];
}
