@namespace MediaEngine.Web.Components.Shared

<div class="@RootClass">
    <div class="app-checkbox-row__copy">
        <div class="app-checkbox-row__label">@Label</div>
        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <div class="app-checkbox-row__description">@Description</div>
        }
    </div>
    <MudCheckBox T="bool"
                 Value="@Value"
                 ValueChanged="@ValueChanged"
                 Color="@MudColor"
                 Disabled="@Disabled" />
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public AppUiTone Tone { get; set; } = AppUiTone.Primary;
    [Parameter] public string? Class { get; set; }

    private Color MudColor => AppUiMaps.ToMudColor(Tone);

    private string RootClass =>
        string.Join(" ", new[] { "app-checkbox-row", AppUiMaps.ToneClass(Tone), Class }
            .Where(value => !string.IsNullOrWhiteSpace(value)));
}
