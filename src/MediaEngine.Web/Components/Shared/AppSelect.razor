@namespace MediaEngine.Web.Components.Shared

<div class="@RootClass">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="app-field__label" for="@InputId">@Label</label>
    }

    <MudSelect T="string"
               InputId="@InputId"
               Value="@Value"
               ValueChanged="OnValueChanged"
               Placeholder="@EffectivePlaceholder"
               Variant="@Variant"
               Margin="@Margin"
               Dense="@Dense"
               Disabled="@Disabled"
               FullWidth="@FullWidth"
               Adornment="@(string.IsNullOrWhiteSpace(LeadingIcon) ? MudBlazor.Adornment.None : MudBlazor.Adornment.Start)"
               AdornmentIcon="@LeadingIcon"
               PopoverClass="@PopoverClass"
               Style="@InlineStyle"
               Class="app-control app-select"
               @attributes="AdditionalAttributes">
        @if (Options is not null)
        {
            @foreach (var option in Options)
            {
                <MudSelectItem T="string" Value="@option.Value">
                    @if (!string.IsNullOrWhiteSpace(option.Icon))
                    {
                        <MudIcon Icon="@option.Icon" Size="MudBlazor.Size.Small" Class="app-select__option-icon" />
                    }
                    @option.Label
                </MudSelectItem>
            }
        }
        else
        {
            @ChildContent
        }
    </MudSelect>

    @if (!string.IsNullOrWhiteSpace(HelpText))
    {
        <div class="app-field__help">@HelpText</div>
    }
</div>

@code {
    private readonly string InputId = $"app-select-{Guid.NewGuid():N}";

    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? HelpText { get; set; }
    [Parameter] public string? LeadingIcon { get; set; }
    [Parameter] public IReadOnlyList<AppSelectOption>? Options { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool FullWidth { get; set; } = true;
    [Parameter] public AppControlSize Size { get; set; } = AppControlSize.Normal;
    [Parameter] public Variant Variant { get; set; } = Variant.Outlined;
    [Parameter] public Margin Margin { get; set; } = Margin.Dense;
    [Parameter] public bool Dense { get; set; } = true;
    [Parameter] public string PopoverClass { get; set; } = "app-select__popover";
    [Parameter] public string? T { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? InlineStyle { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string RootClass =>
        string.Join(" ", new[] { "app-field", AppUiMaps.SizeClass(Size), Class }
            .Where(value => !string.IsNullOrWhiteSpace(value)));

    private string? EffectivePlaceholder =>
        !string.IsNullOrWhiteSpace(Placeholder)
            ? Placeholder
            : Options?.FirstOrDefault(option => string.Equals(option.Value, Value ?? string.Empty, StringComparison.Ordinal))?.Label;

    private Task OnValueChanged(string? value) => ValueChanged.InvokeAsync(value);
}
