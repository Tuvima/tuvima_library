@namespace MediaEngine.Web.Components.Shared

<section class="@RootClass">
    @if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(Description) || Actions is not null)
    {
        <header class="app-card__header">
            <div class="app-card__copy">
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <h2 class="app-card__title">@Title</h2>
                }
                @if (!string.IsNullOrWhiteSpace(Description))
                {
                    <p class="app-card__description">@Description</p>
                }
            </div>
            @if (Actions is not null)
            {
                <div class="app-card__actions">@Actions</div>
            }
        </header>
    }
    <div class="app-card__body">
        @ChildContent
    </div>
</section>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public AppSurfaceVariant Variant { get; set; }
    [Parameter] public AppSurfaceDensity Density { get; set; } = AppSurfaceDensity.Normal;
    [Parameter] public string? Class { get; set; }

    private string RootClass =>
        string.Join(" ", new[]
        {
            "app-card",
            $"app-card--{Variant.ToString().ToLowerInvariant()}",
            $"app-card--{Density.ToString().ToLowerInvariant()}",
            Class,
        }.Where(value => !string.IsNullOrWhiteSpace(value)));
}
