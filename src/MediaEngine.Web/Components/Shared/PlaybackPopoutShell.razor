@namespace MediaEngine.Web.Components.Shared
@using System.Linq
@using Microsoft.AspNetCore.Components.Web
@using MediaEngine.Web.Services.Playback

<AppCssElement Tag="div"
               Class="@RootClass"
               Css="@Css"
               OnKeyDown="@OnKeyDown"
               @attributes="AdditionalAttributes">
    @ChildContent
</AppCssElement>

@code {
    [Parameter]
    public PlaybackExperience Experience { get; set; } = PlaybackExperience.Music;

    [Parameter]
    public bool IsSheetOpen { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Css { get; set; }

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ExperienceClass => Experience switch
    {
        PlaybackExperience.Audiobook => "playback-popout-shell--audiobook",
        PlaybackExperience.Video => "playback-popout-shell--video",
        _ => "playback-popout-shell--music",
    };

    private string RootClass => string.Join(" ", new[]
    {
        "playback-popout-shell",
        ExperienceClass,
        IsSheetOpen ? "playback-popout-shell--sheet-open" : null,
        Class,
    }.Where(value => !string.IsNullOrWhiteSpace(value)));
}
