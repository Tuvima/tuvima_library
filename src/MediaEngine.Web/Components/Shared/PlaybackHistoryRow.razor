@namespace MediaEngine.Web.Components.Shared
@using System.Linq
@using Microsoft.AspNetCore.Components.Web

<span class="@ShellClass">
    <AppNativeButton Type="button"
                     Class="@ButtonClass"
                     OnClick="@HandleClickAsync"
                     AriaLabel="@ResolvedAriaLabel"
                     title="@ResolvedAriaLabel"
                     @attributes="AdditionalAttributes">
        <span class="playback-history-row__copy">
            <strong class="playback-history-row__title">@Title</strong>
            @if (!string.IsNullOrWhiteSpace(PositionText))
            {
                <span class="playback-history-row__position">@PositionText</span>
            }
            @if (!string.IsNullOrWhiteSpace(TimestampText))
            {
                <span class="playback-history-row__meta">
                    <MudIcon Icon="@TimestampIcon" Class="playback-history-row__meta-icon" />
                    <span>@TimestampText</span>
                </span>
            }
        </span>
        <span class="playback-history-row__action" aria-hidden="true">
            <span class="playback-history-row__action-ring">
                <MudIcon Icon="@ActionIcon" Class="playback-history-row__action-icon" />
            </span>
            <span class="playback-history-row__action-label">@ActionLabel</span>
        </span>
    </AppNativeButton>
</span>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? PositionText { get; set; }

    [Parameter]
    public string? TimestampText { get; set; }

    [Parameter]
    public string ActionLabel { get; set; } = "Resume";

    [Parameter]
    public string ActionIcon { get; set; } = Icons.Material.Filled.PlayArrow;

    [Parameter]
    public string TimestampIcon { get; set; } = Icons.Material.Outlined.CalendarMonth;

    [Parameter]
    public string Size { get; set; } = "standard";

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string NormalizedSize => Size switch
    {
        "compact" => "compact",
        "large" => "large",
        _ => "standard",
    };

    private string ResolvedAriaLabel => string.IsNullOrWhiteSpace(AriaLabel)
        ? string.Join(" ", new[] { ActionLabel, Title, PositionText }.Where(value => !string.IsNullOrWhiteSpace(value)))
        : AriaLabel;

    private string ShellClass => string.Join(" ", new[]
    {
        "playback-history-row-shell",
        $"playback-history-row-shell--{NormalizedSize}",
        Class,
    }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private string ButtonClass => string.Join(" ", new[]
    {
        "playback-history-row",
        $"playback-history-row--{NormalizedSize}",
    }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private Task HandleClickAsync(MouseEventArgs _) => OnClick.InvokeAsync();
}
