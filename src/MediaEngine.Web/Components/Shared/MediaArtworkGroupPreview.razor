@namespace MediaEngine.Web.Components.Shared

<div class="@PreviewClass"
     role="img"
     aria-label="@AriaLabel">
    @for (var index = 0; index < VisibleItems.Count; index++)
    {
        var artwork = VisibleItems[index];
        @if (Layout == MediaArtworkGroupPreviewLayout.Adaptive)
        {
            <div @key="artwork.Id" class="@SlotClass(artwork, index)">
                @if (!string.IsNullOrWhiteSpace(artwork.ImageUrl))
                {
                    <img class="media-artwork-group-preview__artwork"
                         src="@artwork.ImageUrl"
                         alt=""
                         loading="lazy"
                         decoding="async" />
                }
                else
                {
                    <div class="media-artwork-group-preview__artwork-fallback" aria-hidden="true">
                        <MudIcon Icon="@FallbackIcon(artwork.MediaType)" />
                    </div>
                }
            </div>
        }
        else
        {
            <img @key="artwork.Id"
                 class="@ArtworkClass(artwork, index)"
                 src="@artwork.ImageUrl"
                 alt=""
                 loading="lazy"
                 decoding="async" />
        }
    }

    @if (ShowOverflowCount && OverflowCount > 0)
    {
        <span class="media-artwork-group-preview__overflow" aria-hidden="true">+@OverflowCount</span>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<ArtworkStackItem> Items { get; set; } = [];
    [Parameter] public int? TotalCount { get; set; }
    [Parameter] public string AriaLabel { get; set; } = "Group artwork preview";
    [Parameter] public MediaArtworkGroupPreviewLayout Layout { get; set; } = MediaArtworkGroupPreviewLayout.Cluster;
    [Parameter] public bool ShowOverflowCount { get; set; } = true;

    private IReadOnlyList<ArtworkStackItem> VisibleItems => BuildVisibleItems();

    private int ResolvedTotalCount => Math.Max(TotalCount ?? VisibleItems.Count, VisibleItems.Count);
    private int OverflowCount => Math.Max(0, ResolvedTotalCount - VisibleItems.Count);

    private string PreviewClass =>
        $"media-artwork-group-preview {CountClass} {ShapeClusterClass} {ShapeSignatureClass} {LayoutClass}";

    private string LayoutClass => Layout switch
    {
        MediaArtworkGroupPreviewLayout.Strip => "is-strip-layout",
        MediaArtworkGroupPreviewLayout.Adaptive => "is-adaptive-layout",
        _ => "is-cluster-layout",
    };

    private string CountClass
    {
        get
        {
            if (VisibleItems.Count >= 4 && ResolvedTotalCount > 4)
            {
                return "has-more";
            }

            return VisibleItems.Count switch
            {
                1 => "has-one",
                2 => "has-two",
                3 => "has-three",
                _ => "has-four",
            };
        }
    }

    private string ShapeClusterClass
    {
        get
        {
            if (VisibleItems.Count == 0)
            {
                return "is-empty";
            }

            var firstShape = VisibleItems[0].Shape;
            if (VisibleItems.Any(item => item.Shape != firstShape))
            {
                return "is-mixed";
            }

            return firstShape switch
            {
                ArtworkShape.Square => "is-square-cluster",
                ArtworkShape.Wide => "is-wide-cluster",
                _ => "is-portrait-cluster",
            };
        }
    }

    private string ShapeSignatureClass =>
        $"shape-p{VisibleItems.Count(item => item.Shape == ArtworkShape.Portrait)}-s{VisibleItems.Count(item => item.Shape == ArtworkShape.Square)}-w{VisibleItems.Count(item => item.Shape == ArtworkShape.Wide)}";

    private IReadOnlyList<ArtworkStackItem> BuildVisibleItems()
    {
        var result = new List<ArtworkStackItem>(4);
        var ids = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var imageUrls = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var item in Items)
        {
            if (result.Count == 4 || string.IsNullOrWhiteSpace(item.Id) || !ids.Add(item.Id))
            {
                continue;
            }

            if (string.IsNullOrWhiteSpace(item.ImageUrl))
            {
                if (Layout == MediaArtworkGroupPreviewLayout.Adaptive)
                {
                    result.Add(item);
                }

                continue;
            }

            if (imageUrls.Add(item.ImageUrl))
            {
                result.Add(item);
            }
        }

        return result;
    }

    private static string ArtworkClass(ArtworkStackItem item, int index) =>
        $"media-artwork-group-preview__artwork is-slot-{index + 1} {ShapeClass(item.Shape)}";

    private static string SlotClass(ArtworkStackItem item, int index) =>
        $"media-artwork-group-preview__slot is-slot-{index + 1} {ShapeClass(item.Shape)}";

    private static string ShapeClass(ArtworkShape shape) => shape switch
    {
        ArtworkShape.Square => "is-square-art",
        ArtworkShape.Wide => "is-wide-art",
        _ => "is-portrait-art",
    };

    private static string FallbackIcon(string? mediaType) => mediaType?.Trim().ToLowerInvariant() switch
    {
        "book" or "comic" => Icons.Material.Outlined.AutoStories,
        "music" or "album" => Icons.Material.Outlined.Album,
        "audiobook" => Icons.Material.Outlined.Headphones,
        "movie" or "tv" => Icons.Material.Outlined.Movie,
        _ => Icons.Material.Outlined.ImageNotSupported,
    };
}
