@namespace MediaEngine.Web.Components.Shared

@if (Items.Count == 0)
{
    <AppEmptyState Title="@EmptyTitle" Message="@EmptyMessage" />
}
else
{
    <div class="@RootClass">
        @foreach (var item in Items)
        {
            <div class="app-evidence-list__row" @key="@($"{item.Kind}-{item.Label}-{item.OccurredAt:O}")">
                <div>
                    <strong>@FriendlyValue(item)</strong>
                    <span>@FriendlySource(FirstNonBlank(item.Source, item.ProviderId, item.Kind))</span>
                </div>
                <span class="app-evidence-list__kind" title="@SplitPascal(item.Kind)">
                    <AppMaterialIcon Icon="@KindIcon(item.Kind)" Size="MudBlazor.Size.Small" />
                    @SplitPascal(item.Kind)
                </span>
            </div>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<ActivityEvidenceViewModel> Items { get; set; } = [];
    [Parameter] public string EmptyTitle { get; set; } = "No source evidence";
    [Parameter] public string EmptyMessage { get; set; } = "No provider or artifact evidence is available for this item.";
    [Parameter] public string? Class { get; set; }

    private string RootClass =>
        string.Join(" ", new[] { "app-evidence-list", Class }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private static string FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? "";

    private static string FriendlyValue(ActivityEvidenceViewModel item)
    {
        var value = FirstNonBlank(item.Value, item.Label, item.Kind).Trim();
        var normalized = value.Replace('_', ' ').Replace('-', ' ').ToLowerInvariant();
        if (normalized.Contains("apple", StringComparison.Ordinal) &&
            (normalized.Contains("api", StringComparison.Ordinal) || normalized.Contains("book", StringComparison.Ordinal) || normalized.Contains("music", StringComparison.Ordinal)))
        {
            return "Apple";
        }

        return normalized switch
        {
            "retailmatchambiguous" => "Possible catalog match needs review",
            "retailmatchfailed" => "No catalog match found",
            "qidnomatch" => "No Wikidata match found",
            "missingqid" => "Missing Wikidata identity",
            "apple api" or "appleapi" or "applebooks" or "apple books" or "apple music" or "applemusic" => "Apple",
            "openlibrary" or "open library" => "Open Library",
            "tmdb" => "TMDB",
            "wikidata" => "Wikidata",
            { Length: > 0 } => SplitPascal(value)
                .Replace("[TMDB]", "(TMDB)", StringComparison.OrdinalIgnoreCase)
                .Replace(" Api", " API", StringComparison.Ordinal),
            _ => "Source evidence",
        };
    }

    private static string FriendlySource(string value) => value.Trim().ToLowerInvariant() switch
    {
        "tmdb" => "TMDB",
        "wikidata" => "Wikidata",
        "openlibrary" or "open_library" => "Open Library",
        "applebooks" or "apple_books" or "appleapi" or "apple_api" or "applemusic" or "apple_music" => "Apple",
        "provider_match" => "Catalog match",
        { Length: > 0 } source => SplitPascal(source),
        _ => "Source",
    };

    private static string KindIcon(string kind) => kind.Trim().ToLowerInvariant() switch
    {
        "provider_match" => Icons.Material.Outlined.TravelExplore,
        "artwork" or "cover_art" => Icons.Material.Outlined.Image,
        "person" or "people" => Icons.Material.Outlined.People,
        "wikidata" or "qid" => Icons.Material.Outlined.Hub,
        _ => Icons.Material.Outlined.Source,
    };

    private static string SplitPascal(string value)
    {
        var normalized = value.Replace('_', ' ');
        var result = new System.Text.StringBuilder(normalized.Length + 8);
        for (var i = 0; i < normalized.Length; i++)
        {
            if (i > 0 && char.IsUpper(normalized[i]) && !char.IsWhiteSpace(normalized[i - 1]))
                result.Append(' ');
            result.Append(normalized[i]);
        }
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(result.ToString().Trim()) switch
        {
            "Qid" => "QID",
            "Tmdb" => "TMDB",
            "Tv" => "TV",
            var label => label,
        };
    }
}
