@namespace MediaEngine.Web.Components.Shared

<MudTooltip Text="@Tooltip" Disabled="@string.IsNullOrWhiteSpace(Tooltip)">
    <MudIconButton Icon="@Icon"
                   Color="@MudColor"
                   Size="@MudSize"
                   Disabled="@Disabled"
                   Href="@Href"
                   Target="@Target"
                   aria-label="@AriaLabel"
                   OnClick="HandleClick"
                   Style="@InlineStyle"
                   Class="@RootClass"
                   @attributes="AdditionalAttributes" />
</MudTooltip>

@code {
    [Parameter, EditorRequired] public string Icon { get; set; } = string.Empty;
    [Parameter] public string? Tooltip { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Target { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public object? Size { get; set; } = AppControlSize.Normal;
    [Parameter] public AppUiTone Tone { get; set; } = AppUiTone.Neutral;
    [Parameter] public Color? Color { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? InlineStyle { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private Size MudSize => AppUiMaps.ToMudSize(Size);
    private Color MudColor => Color ?? AppUiMaps.ToMudColor(Tone);
    private AppControlSize AppSize => AppUiMaps.ToAppControlSize(Size);

    private string RootClass =>
        string.Join(" ", new[]
        {
            "app-icon-button",
            AppUiMaps.SizeClass(AppSize),
            AppUiMaps.ToneClass(Tone),
            Class,
        }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private Task HandleClick(MouseEventArgs _) => OnClick.InvokeAsync();
}
