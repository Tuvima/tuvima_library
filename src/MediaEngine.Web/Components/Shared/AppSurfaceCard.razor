@namespace MediaEngine.Web.Components.Shared

<MudPaper Elevation="0" Class="@RootClass">
    @if (HasHeader)
    {
        <div class="app-surface-card__header">
            <div class="app-surface-card__copy">
                @if (!string.IsNullOrWhiteSpace(Eyebrow))
                {
                    <div class="app-surface-card__eyebrow">@Eyebrow</div>
                }

                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <h2 class="app-surface-card__title">@Title</h2>
                }

                @if (!string.IsNullOrWhiteSpace(Description))
                {
                    <p class="app-surface-card__description">@Description</p>
                }
            </div>

            @if (Actions is not null)
            {
                <div class="app-surface-card__actions">
                    @Actions
                </div>
            }
        </div>
    }

    <div class="@BodyClass">
        @ChildContent
    </div>
</MudPaper>

@code {
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? BodyClassName { get; set; }

    private bool HasHeader =>
        !string.IsNullOrWhiteSpace(Eyebrow)
        || !string.IsNullOrWhiteSpace(Title)
        || !string.IsNullOrWhiteSpace(Description)
        || Actions is not null;

    private string RootClass =>
        string.Join(
            " ",
            new[]
            {
                "app-surface-card",
                string.IsNullOrWhiteSpace(Class) ? null : Class,
            }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private string BodyClass =>
        string.Join(
            " ",
            new[]
            {
                "app-surface-card__body",
                string.IsNullOrWhiteSpace(BodyClassName) ? null : BodyClassName,
            }.Where(value => !string.IsNullOrWhiteSpace(value)));
}
