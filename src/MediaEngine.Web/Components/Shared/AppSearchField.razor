@namespace MediaEngine.Web.Components.Shared

<AppTextField Value="@Value"
              ValueChanged="OnValueChanged"
              Placeholder="@Placeholder"
              Label="@Label"
              HelpText="@HelpText"
              Disabled="@Disabled"
              FullWidth="@FullWidth"
              Size="@Size"
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Outlined.Search"
              Class="@($"app-search-field {Class}".Trim())" />

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Search...";
    [Parameter] public string? HelpText { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool FullWidth { get; set; } = true;
    [Parameter] public AppControlSize Size { get; set; } = AppControlSize.Normal;
    [Parameter] public string? Class { get; set; }

    private Task OnValueChanged(string? value) => ValueChanged.InvokeAsync(string.IsNullOrWhiteSpace(value) ? null : value);
}
