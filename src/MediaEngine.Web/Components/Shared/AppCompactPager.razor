@namespace MediaEngine.Web.Components.Shared

<div class="@RootClass">
    <span class="app-compact-pager__summary">@Summary</span>
    <div class="app-compact-pager__actions">
        <AppButton Label="Previous"
                   Size="AppControlSize.Compact"
                   StartIcon="@Icons.Material.Outlined.ChevronLeft"
                   Disabled="@(Offset <= 0 || Loading)"
                   OnClick="@PreviousAsync" />
        <AppStatusChip Text="@($"Page {CurrentPage:N0}")" Tone="primary" />
        <AppButton Label="Next"
                   Size="AppControlSize.Compact"
                   EndIcon="@Icons.Material.Outlined.ChevronRight"
                   Disabled="@(!HasMore || Loading)"
                   OnClick="@NextAsync" />
    </div>
</div>

@code {
    [Parameter] public int Offset { get; set; }
    [Parameter] public int Limit { get; set; } = 25;
    [Parameter] public bool HasMore { get; set; }
    [Parameter] public int? TotalCount { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<int> OffsetChanged { get; set; }
    [Parameter] public string? Class { get; set; }

    private int CurrentPage => Limit <= 0 ? 1 : (Offset / Limit) + 1;

    private string Summary
    {
        get
        {
            var start = Offset + 1;
            var end = Offset + Limit;
            return TotalCount.HasValue
                ? $"Showing {Math.Min(start, TotalCount.Value):N0}-{Math.Min(end, TotalCount.Value):N0} of {TotalCount.Value:N0}"
                : $"Showing {start:N0}-{end:N0}";
        }
    }

    private string RootClass =>
        string.Join(" ", new[] { "app-compact-pager", Class }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private Task PreviousAsync() => OffsetChanged.InvokeAsync(Math.Max(0, Offset - Limit));

    private Task NextAsync() => OffsetChanged.InvokeAsync(Offset + Limit);
}
