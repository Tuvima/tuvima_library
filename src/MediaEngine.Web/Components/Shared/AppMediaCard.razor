@namespace MediaEngine.Web.Components.Shared

<button type="button" class="@RootClass" style="@RootStyle" @onclick="OnClick">
    <AppMediaArtwork ImageUrl="@ImageUrl"
                     Alt="@Title"
                     FallbackText="@FallbackText"
                     FallbackIcon="@FallbackIcon"
                     AspectRatio="@AspectRatio"
                     AccentColor="@AccentColor"
                     Progress="@Progress"
                     Badge="@Badge" />
    <span class="app-media-card__body">
        <span class="app-media-card__title">@Title</span>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <span class="app-media-card__subtitle">@Subtitle</span>
        }
        @if (Meta is not null)
        {
            <span class="app-media-card__meta">@Meta</span>
        }
    </span>
</button>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string? FallbackText { get; set; }
    [Parameter] public string FallbackIcon { get; set; } = Icons.Material.Outlined.Image;
    [Parameter] public string? AccentColor { get; set; }
    [Parameter] public double? Progress { get; set; }
    [Parameter] public int? Width { get; set; }
    [Parameter] public AppMediaCardVariant Variant { get; set; } = AppMediaCardVariant.Portrait;
    [Parameter] public RenderFragment? Badge { get; set; }
    [Parameter] public RenderFragment? Meta { get; set; }
    [Parameter] public EventCallback OnSelected { get; set; }
    [Parameter] public string? Class { get; set; }

    private string AspectRatio => Variant switch
    {
        AppMediaCardVariant.Square => "1 / 1",
        AppMediaCardVariant.Landscape or AppMediaCardVariant.Wide => "16 / 9",
        AppMediaCardVariant.List or AppMediaCardVariant.Compact => "1 / 1",
        _ => "2 / 3",
    };

    private string RootStyle =>
        Width.HasValue
            ? $"--app-media-card-width: {Width.Value}px;"
            : string.Empty;

    private string RootClass =>
        string.Join(" ", new[]
        {
            "app-media-card",
            $"app-media-card--{Variant.ToString().ToLowerInvariant()}",
            Class,
        }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private Task OnClick() => OnSelected.InvokeAsync();
}
