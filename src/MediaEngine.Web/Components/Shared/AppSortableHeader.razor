@namespace MediaEngine.Web.Components.Shared

<button type="button"
        class="@RootClass"
        @onclick="HandleClickAsync"
        aria-sort="@AriaSort">
    <span>@Label</span>
    <AppMaterialIcon Icon="@Icon" Size="MudBlazor.Size.Small" />
</button>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string SortKey { get; set; } = "";
    [Parameter] public string? ActiveSort { get; set; }
    [Parameter] public string? Direction { get; set; }
    [Parameter] public EventCallback<string> SortRequested { get; set; }
    [Parameter] public string? Class { get; set; }

    private bool IsActive => string.Equals(ActiveSort, SortKey, StringComparison.OrdinalIgnoreCase);
    private bool IsAscending => IsActive && string.Equals(Direction, "asc", StringComparison.OrdinalIgnoreCase);
    private string Icon => IsActive
        ? (IsAscending ? Icons.Material.Outlined.KeyboardArrowUp : Icons.Material.Outlined.KeyboardArrowDown)
        : Icons.Material.Outlined.UnfoldMore;
    private string AriaSort => IsActive ? (IsAscending ? "ascending" : "descending") : "none";
    private string RootClass => string.Join(" ", new[] { "app-sortable-header", IsActive ? "is-active" : null, Class }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private Task HandleClickAsync() => SortRequested.InvokeAsync(SortKey);
}
