@namespace MediaEngine.Web.Components.Shared

<div class="@RootClass" style="@RootStyle">
    @if (!string.IsNullOrWhiteSpace(ImageUrl))
    {
        <img src="@ImageUrl" alt="@Alt" class="app-media-artwork__image" loading="lazy" />
    }
    else
    {
        <div class="app-media-artwork__fallback">
            <MudIcon Icon="@FallbackIcon" />
            @if (!string.IsNullOrWhiteSpace(FallbackText))
            {
                <span>@FallbackText</span>
            }
        </div>
    }
    @if (Badge is not null)
    {
        <div class="app-media-artwork__badge">@Badge</div>
    }
    @if (Progress is > 0)
    {
        <AppProgressBar Value="@Progress" AccentColor="@AccentColor" Class="app-media-artwork__progress" />
    }
</div>

@code {
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string? Alt { get; set; }
    [Parameter] public string? FallbackText { get; set; }
    [Parameter] public string FallbackIcon { get; set; } = Icons.Material.Outlined.Image;
    [Parameter] public string AspectRatio { get; set; } = "2 / 3";
    [Parameter] public string? AccentColor { get; set; }
    [Parameter] public double? Progress { get; set; }
    [Parameter] public RenderFragment? Badge { get; set; }
    [Parameter] public string? Class { get; set; }

    private string RootStyle =>
        string.IsNullOrWhiteSpace(AccentColor)
            ? $"--app-media-artwork-aspect: {AspectRatio};"
            : $"--app-media-artwork-aspect: {AspectRatio}; --app-media-accent: {AccentColor};";

    private string RootClass =>
        string.Join(" ", new[]
        {
            "app-media-artwork",
            string.IsNullOrWhiteSpace(ImageUrl) ? "app-media-artwork--empty" : null,
            Class,
        }.Where(value => !string.IsNullOrWhiteSpace(value)));
}
