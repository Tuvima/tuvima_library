@namespace MediaEngine.Web.Components.Shared

@if (Items.Count == 0)
{
    <AppEmptyState Title="@EmptyTitle" Message="@EmptyMessage" />
}
else
{
    <ol class="@RootClass">
        @foreach (var item in Items)
        {
            <li class="@($"app-timeline-list__item is-{NormalizeTone(item.Tone)}")" @key="@($"{item.EventType}-{item.OccurredAt:O}-{item.Detail}")">
                <span class="app-timeline-list__dot"></span>
                <div class="app-timeline-list__body">
                    <div class="app-timeline-list__head">
                        <strong>@LabelFor(item)</strong>
                        <time>@item.OccurredAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</time>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(item.Detail))
                    {
                        <p>@item.Detail</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(item.Source))
                    {
                        <span class="app-timeline-list__source">@item.Source</span>
                    }
                </div>
            </li>
        }
    </ol>
}

@code {
    [Parameter] public IReadOnlyList<ActivityTimelineEventViewModel> Items { get; set; } = [];
    [Parameter] public string EmptyTitle { get; set; } = "No timeline events";
    [Parameter] public string EmptyMessage { get; set; } = "No detailed events are available for this item.";
    [Parameter] public string? Class { get; set; }

    private string RootClass =>
        string.Join(" ", new[] { "app-timeline-list", Class }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private static string LabelFor(ActivityTimelineEventViewModel item) =>
        string.IsNullOrWhiteSpace(item.Label) ? item.EventType : SplitPascal(item.Label);

    private static string NormalizeTone(string? tone) => tone?.ToLowerInvariant() switch
    {
        "success" => "success",
        "warning" => "warning",
        "danger" => "danger",
        _ => "neutral",
    };

    private static string SplitPascal(string value)
    {
        var result = new System.Text.StringBuilder(value.Length + 8);
        for (var i = 0; i < value.Length; i++)
        {
            if (i > 0 && char.IsUpper(value[i]) && !char.IsWhiteSpace(value[i - 1]))
                result.Append(' ');
            result.Append(value[i]);
        }
        return result.ToString();
    }
}
