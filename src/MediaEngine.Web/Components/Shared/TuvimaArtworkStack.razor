@namespace MediaEngine.Web.Components.Shared
@using MediaEngine.Web.Models.ViewDTOs

<div class="artwork-stack @VariantClass @LayoutClass @Class"
     style="@StackStyle"
     data-count="@VisibleArtwork.Count"
     aria-hidden="@(IsDecorative ? "true" : null)"
     aria-label="@(!IsDecorative ? AriaLabel : null)"
     role="@(!IsDecorative ? "img" : null)">
    <div class="artwork-stack__stage">
        @if (VisibleArtwork.Count == 0)
        {
            <div class="artwork-stack__placeholder">
                <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" />
            </div>
        }
        else
        {
            @foreach (var slot in VisibleArtwork.Select((item, index) => new { item, index }))
            {
                <div class="artwork-stack__item"
                     data-shape="@ShapeValue(slot.item.Shape)"
                     style="@SlotStyle(slot.index, slot.item.Shape)">
                    <img src="@slot.item.ImageUrl"
                         alt="@(IsDecorative ? string.Empty : slot.item.Title)"
                         loading="lazy" />
                    @if (ShowPositionBadge(slot.item))
                    {
                        <span class="artwork-stack__position" aria-hidden="true">@slot.item.Position</span>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<ArtworkStackItem> Items { get; set; } = [];
    [Parameter] public string Seed { get; set; } = string.Empty;
    [Parameter] public ArtworkStackVariant Variant { get; set; } = ArtworkStackVariant.Card;
    [Parameter] public int? MaxVisible { get; set; }
    [Parameter] public bool IsDecorative { get; set; } = true;
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public bool PreferShapeBalancedLayout { get; set; } = true;
    [Parameter] public bool PreserveOrder { get; set; }
    [Parameter] public MediaEngine.Domain.Models.ArtworkPalette? Palette { get; set; }

    private string? StackStyle => Palette?.CssVariableStyle;

    private IReadOnlyList<ArtworkStackItem> VisibleArtwork
    {
        get
        {
            var maxVisible = Math.Clamp(MaxVisible ?? DefaultVisibleCount, 1, 7);
            var artwork = Items
                .Where(item => !string.IsNullOrWhiteSpace(item.ImageUrl))
                .Select(item => new ArtworkStackItem
                {
                    Id = item.Id,
                    Title = item.Title,
                    ImageUrl = item.ImageUrl,
                    MediaType = item.MediaType,
                    Shape = item.Shape,
                    Position = item.Position,
                });

            if (!PreserveOrder)
            {
                artwork = artwork.OrderBy(item => StableHash($"{Seed}|{item.Id}|{item.ImageUrl}"));
            }

            return artwork.Take(maxVisible).ToList();
        }
    }

    private int DefaultVisibleCount => Variant switch
    {
        ArtworkStackVariant.Compact => 3,
        ArtworkStackVariant.Card => 4,
        ArtworkStackVariant.SeriesStrip => 4,
        ArtworkStackVariant.Hero => 5,
        ArtworkStackVariant.Dense => 5,
        _ => 4,
    };

    private string VariantClass => $"artwork-stack--{Variant.ToString().ToLowerInvariant()}";

    private string LayoutClass
    {
        get
        {
            if (VisibleArtwork.Count == 0)
                return "artwork-stack--empty";

            var distinctShapes = VisibleArtwork.Select(item => item.Shape).Distinct().ToList();
            if (PreferShapeBalancedLayout && distinctShapes.Count == 1 && distinctShapes[0] == ArtworkShape.Square)
                return "artwork-stack--all-square";

            if (PreferShapeBalancedLayout && distinctShapes.Count == 1 && distinctShapes[0] == ArtworkShape.Portrait)
                return "artwork-stack--all-portrait";

            return "artwork-stack--mixed";
        }
    }

    private string SlotStyle(int index, ArtworkShape shape)
    {
        var slot = ResolveSlot(index, shape);
        return $"--artwork-width:{slot.Width};--left:{slot.Left};--top:{slot.Top};--rotate:{slot.Rotate};--scale:{slot.Scale};--z:{slot.Z};";
    }

    private StackSlot ResolveSlot(int index, ArtworkShape shape)
    {
        var count = VisibleArtwork.Count;
        if (Variant == ArtworkStackVariant.SeriesStrip)
            return ResolveSeriesStripSlot(index, count, shape);

        if (count == 1)
            return new("38%", "50%", "50%", "0deg", "1", 5);

        var layout = LayoutClass;
        return layout switch
        {
            "artwork-stack--all-square" => ResolveSquareSlot(index, count),
            "artwork-stack--all-portrait" => ResolvePortraitSlot(index, count),
            _ => ResolveMixedSlot(index, count, shape),
        };
    }

    private static StackSlot ResolveMixedSlot(int index, int count, ArtworkShape shape)
    {
        StackSlot[] slots = count switch
        {
            2 =>
            [
                new StackSlot("34%", "38%", "50%", "-2deg", ".98", 2),
                new StackSlot("34%", "62%", "48%", "2deg", "1", 3),
            ],
            3 =>
            [
                new StackSlot("30%", "27%", "45%", "-2deg", ".98", 2),
                new StackSlot("34%", "53%", "38%", "1deg", "1", 4),
                new StackSlot("30%", "45%", "68%", "0deg", ".98", 3),
            ],
            4 =>
            [
                new StackSlot("29%", "21%", "43%", "-1deg", ".98", 2),
                new StackSlot("31%", "49%", "34%", "0deg", "1", 4),
                new StackSlot("29%", "76%", "48%", "1deg", ".98", 3),
                new StackSlot("31%", "50%", "69%", "0deg", "1", 5),
            ],
            _ =>
            [
                new StackSlot("28%", "18%", "42%", "-1deg", ".98", 2),
                new StackSlot("31%", "48%", "30%", "0deg", "1", 4),
                new StackSlot("28%", "78%", "45%", "1deg", ".98", 3),
                new StackSlot("30%", "36%", "70%", "0deg", ".98", 5),
                new StackSlot("30%", "58%", "68%", "0deg", "1.02", 6),
            ],
        };

        return slots[Math.Min(index, slots.Length - 1)] with
        {
            Width = shape == ArtworkShape.Wide ? "38%" : slots[Math.Min(index, slots.Length - 1)].Width,
        };
    }

    private static StackSlot ResolveSeriesStripSlot(int index, int count, ArtworkShape shape)
    {
        StackSlot[] slots = count switch
        {
            <= 1 =>
            [
                new StackSlot("34%", "38%", "48%", "0deg", "1.04", 5),
            ],
            2 =>
            [
                new StackSlot("36%", "36%", "49%", "0deg", "1.05", 5),
                new StackSlot("31%", "63%", "51%", "3deg", ".95", 4),
            ],
            3 =>
            [
                new StackSlot("36%", "30%", "49%", "0deg", "1.05", 6),
                new StackSlot("31%", "55%", "51%", "2deg", ".96", 5),
                new StackSlot("29%", "76%", "53%", "4deg", ".9", 4),
            ],
            _ =>
            [
                new StackSlot("35%", "25%", "49%", "0deg", "1.06", 7),
                new StackSlot("30%", "49%", "50%", "2deg", ".97", 6),
                new StackSlot("28%", "69%", "52%", "4deg", ".9", 5),
                new StackSlot("26%", "86%", "54%", "6deg", ".84", 4),
            ],
        };

        var slot = slots[Math.Min(index, slots.Length - 1)];
        return shape == ArtworkShape.Wide
            ? slot with { Width = "42%" }
            : slot;
    }

    private static StackSlot ResolveSquareSlot(int index, int count)
    {
        StackSlot[] slots = count switch
        {
            2 =>
            [
                new StackSlot("34%", "42%", "50%", "-2deg", ".98", 2),
                new StackSlot("34%", "60%", "43%", "2deg", "1", 3),
            ],
            3 =>
            [
                new StackSlot("30%", "34%", "45%", "-2deg", ".96", 2),
                new StackSlot("34%", "56%", "41%", "1deg", "1", 4),
                new StackSlot("30%", "46%", "67%", "0deg", ".98", 3),
            ],
            4 =>
            [
                new StackSlot("29%", "28%", "43%", "-1deg", ".96", 2),
                new StackSlot("31%", "51%", "35%", "1deg", ".99", 4),
                new StackSlot("29%", "74%", "46%", "1deg", ".96", 3),
                new StackSlot("31%", "48%", "69%", "0deg", "1", 5),
            ],
            _ =>
            [
                new StackSlot("28%", "25%", "43%", "-1deg", ".94", 2),
                new StackSlot("31%", "50%", "33%", "1deg", "1", 4),
                new StackSlot("28%", "76%", "45%", "1deg", ".95", 3),
                new StackSlot("30%", "36%", "69%", "0deg", ".98", 5),
                new StackSlot("31%", "61%", "69%", "0deg", "1.02", 6),
            ],
        };

        return slots[Math.Min(index, slots.Length - 1)];
    }

    private static StackSlot ResolvePortraitSlot(int index, int count)
    {
        StackSlot[] slots = count switch
        {
            2 =>
            [
                new StackSlot("30%", "40%", "48%", "-2deg", ".98", 2),
                new StackSlot("30%", "61%", "45%", "2deg", "1", 3),
            ],
            3 =>
            [
                new StackSlot("28%", "29%", "44%", "-2deg", ".96", 2),
                new StackSlot("31%", "54%", "40%", "1deg", "1", 4),
                new StackSlot("28%", "45%", "69%", "0deg", ".98", 3),
            ],
            4 =>
            [
                new StackSlot("27%", "22%", "43%", "-1deg", ".97", 2),
                new StackSlot("30%", "48%", "37%", "1deg", "1", 4),
                new StackSlot("27%", "74%", "47%", "1deg", ".96", 3),
                new StackSlot("29%", "51%", "70%", "0deg", "1", 5),
            ],
            _ =>
            [
                new StackSlot("27%", "18%", "42%", "-1deg", ".97", 2),
                new StackSlot("30%", "45%", "34%", "0deg", "1", 4),
                new StackSlot("27%", "75%", "45%", "1deg", ".96", 3),
                new StackSlot("27%", "34%", "71%", "0deg", ".98", 5),
                new StackSlot("30%", "58%", "69%", "0deg", "1.02", 6),
            ],
        };

        return slots[Math.Min(index, slots.Length - 1)];
    }

    private static string ShapeValue(ArtworkShape shape) => shape switch
    {
        ArtworkShape.Square => "square",
        ArtworkShape.Wide => "wide",
        _ => "portrait",
    };

    private bool ShowPositionBadge(ArtworkStackItem item) =>
        Variant == ArtworkStackVariant.SeriesStrip
        && !string.IsNullOrWhiteSpace(item.Position);

    private static int StableHash(string value)
    {
        unchecked
        {
            var hash = 17;
            foreach (var character in value)
                hash = (hash * 31) + character;
            return hash & int.MaxValue;
        }
    }

    private sealed record StackSlot(string Width, string Left, string Top, string Rotate, string Scale, int Z);
}

<style>
    .artwork-stack {
        position: relative;
        width: 100%;
        height: 100%;
        min-height: 10rem;
        overflow: hidden;
        border-radius: inherit;
        isolation: isolate;
        pointer-events: none;
    }

    .artwork-stack__stage {
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background:
            radial-gradient(circle at 35% 40%, var(--art-bg-glow, rgba(245, 158, 80, .18)), transparent 44%),
            radial-gradient(circle at 70% 50%, var(--art-bg-glow-secondary, rgba(124, 92, 255, .18)), transparent 48%),
            linear-gradient(135deg, var(--art-bg-base-dark, rgba(3, 7, 14, .92)), var(--art-bg-base, rgba(12, 17, 29, .74)) 54%, var(--art-bg-base-dark, rgba(3, 7, 13, .96)));
    }

    .artwork-stack__stage::before {
        content: "";
        position: absolute;
        inset: 8%;
        z-index: 0;
        background:
            radial-gradient(circle at 35% 40%, var(--art-bg-glow, rgba(245, 158, 80, .22)), transparent 45%),
            radial-gradient(circle at 70% 50%, var(--art-bg-glow-secondary, rgba(124, 92, 255, .20)), transparent 48%),
            radial-gradient(circle at 55% 70%, rgba(45, 212, 191, .12), transparent 44%);
        filter: blur(44px);
        opacity: .9;
    }

    .artwork-stack__stage::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
            linear-gradient(90deg, rgba(2, 6, 16, .72), transparent 38%, rgba(2, 6, 16, .28)),
            linear-gradient(180deg, rgba(255, 255, 255, .03), rgba(2, 6, 16, .34));
        pointer-events: none;
    }

    .artwork-stack__item {
        --artwork-radius: clamp(.55rem, 1.2vw, .9rem);
        --artwork-ratio: 2 / 3;
        position: absolute;
        left: var(--left);
        top: var(--top);
        width: var(--artwork-width);
        aspect-ratio: var(--artwork-ratio);
        overflow: hidden;
        border-radius: var(--artwork-radius);
        background: rgba(255, 255, 255, .04);
        border: 1px solid rgba(255, 255, 255, .13);
        border-color: var(--art-bg-border, rgba(255, 255, 255, .13));
        box-shadow:
            0 24px 70px var(--art-bg-shadow, rgba(0, 0, 0, .45)),
            0 10px 26px rgba(0, 0, 0, .28),
            0 0 0 1px rgba(255, 255, 255, .08);
        transform: translate(-50%, -50%) rotate(var(--rotate)) scale(var(--scale));
        transform-origin: center center;
        z-index: var(--z);
    }

    .artwork-stack__item[data-shape="square"] {
        --artwork-ratio: 1 / 1;
    }

    .artwork-stack__item[data-shape="portrait"] {
        --artwork-ratio: 2 / 3;
    }

    .artwork-stack__item[data-shape="wide"] {
        --artwork-ratio: 16 / 9;
    }

    .artwork-stack__item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .artwork-stack__position {
        position: absolute;
        left: .42rem;
        bottom: .42rem;
        z-index: 2;
        min-width: 1.45rem;
        height: 1.45rem;
        padding: 0 .38rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-ui);
        font-size: .68rem;
        font-weight: 600;
        line-height: 1;
        color: rgba(248, 250, 252, .96);
        background: rgba(2, 6, 16, .72);
        border: 1px solid rgba(255, 255, 255, .16);
        box-shadow: 0 8px 18px rgba(0, 0, 0, .34);
        backdrop-filter: blur(10px);
    }

    .artwork-stack__placeholder {
        position: absolute;
        left: 50%;
        top: 50%;
        z-index: 2;
        display: grid;
        place-items: center;
        width: min(42%, 12rem);
        aspect-ratio: 1 / 1;
        color: rgba(226, 232, 240, .38);
        border: 1px solid rgba(255, 255, 255, .12);
        border-radius: 1rem;
        background: rgba(255, 255, 255, .04);
        box-shadow: 0 24px 70px rgba(0, 0, 0, .34);
        transform: translate(-50%, -50%);
    }

    .artwork-stack__placeholder ::deep .mud-icon-root {
        font-size: clamp(2.2rem, 7vw, 4.2rem);
    }

    .artwork-stack--compact .artwork-stack__item {
        --artwork-radius: .55rem;
    }

    .artwork-stack--card .artwork-stack__item {
        --artwork-radius: .62rem;
    }

    .artwork-stack--seriesstrip .artwork-stack__item {
        --artwork-radius: clamp(.5rem, .7vw, .72rem);
    }

    .artwork-stack--hero .artwork-stack__item {
        --artwork-radius: clamp(.75rem, 1.1vw, 1rem);
        top: calc(var(--top) - 5%);
        width: calc(var(--artwork-width) * 1.72);
    }

    .artwork-stack--hero {
        min-height: clamp(46rem, 84vh, 64rem);
        overflow: visible;
    }

    .artwork-stack--hero .artwork-stack__stage {
        background: transparent;
        overflow: visible;
    }

    .artwork-stack--hero .artwork-stack__stage::before,
    .artwork-stack--hero .artwork-stack__stage::after {
        display: none;
    }

    .artwork-stack--card .artwork-stack__item,
    .artwork-stack--compact .artwork-stack__item,
    .artwork-stack--seriesstrip .artwork-stack__item {
        left: min(96%, calc(var(--left) + 18%));
    }

    @@media (max-width: 720px) {
        .artwork-stack__item:nth-of-type(n + 4) {
            display: none;
        }

        .artwork-stack__item {
            width: calc(var(--artwork-width) * 1.18);
            border-radius: .7rem;
        }
    }
</style>
