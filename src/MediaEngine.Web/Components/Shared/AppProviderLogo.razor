@namespace MediaEngine.Web.Components.Shared

<span class="@RootClass" style="@AccentStyle" aria-hidden="@string.IsNullOrWhiteSpace(AltText)">
    @if (!string.IsNullOrWhiteSpace(ImageUrl))
    {
        <img src="@ImageUrl" alt="@AltText" />
    }
    else if (!string.IsNullOrWhiteSpace(Icon))
    {
        <MudIcon Icon="@Icon" Size="@MudSize" />
    }
    else
    {
        <span class="app-provider-logo__fallback">@FallbackText</span>
    }
</span>

@code {
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? AltText { get; set; }
    [Parameter] public string? AccentColor { get; set; }
    [Parameter] public string? FallbackText { get; set; }
    [Parameter] public AppControlSize Size { get; set; } = AppControlSize.Normal;
    [Parameter] public string? Class { get; set; }

    private Size MudSize => AppUiMaps.ToMudSize(Size);

    private string? AccentStyle =>
        string.IsNullOrWhiteSpace(AccentColor) ? null : $"--app-provider-logo-accent: {AccentColor};";

    private bool HasImage => !string.IsNullOrWhiteSpace(ImageUrl);

    private string RootClass =>
        string.Join(" ", new[]
        {
            "app-provider-logo",
            HasImage ? "app-provider-logo--image" : "app-provider-logo--fallback",
            AppUiMaps.SizeClass(Size),
            Class,
        }
            .Where(value => !string.IsNullOrWhiteSpace(value)));
}
