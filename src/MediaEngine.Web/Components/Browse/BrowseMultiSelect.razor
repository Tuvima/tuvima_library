@namespace MediaEngine.Web.Components.Browse

<div class="browse-multi-select @Class">
    <span class="browse-multi-select__label">@Label</span>
    <MudMenu Dense="true"
             Open="@_open"
             OpenChanged="OnOpenChanged"
             AnchorOrigin="Origin.BottomLeft"
             TransformOrigin="Origin.TopLeft"
             Class="browse-multi-select__menu"
             PopoverClass="browse-multi-select__popover">
        <ActivatorContent>
            <AppNativeButton Type="button"
                             Class="@TriggerClass"
                             AriaLabel="@ResolvedAriaLabel"
                             aria-haspopup="dialog"
                             aria-expanded="@(_open ? "true" : "false")"
                             OnClick="@context.ToggleAsync">
                <MudIcon Icon="@Icon" />
                <span>@ButtonLabel</span>
                <MudIcon Icon="@Icons.Material.Outlined.KeyboardArrowDown" Class="browse-multi-select__chevron" />
            </AppNativeButton>
        </ActivatorContent>
        <ChildContent>
            <div class="browse-multi-select__panel"
                 role="group"
                 aria-label="@ButtonLabel"
                 @onclick:stopPropagation="true">
                @if (Searchable)
                {
                    <label class="browse-multi-select__search">
                        <MudIcon Icon="@Icons.Material.Outlined.Search" />
                        <AppNativeInput Value="@_searchText"
                                        OnInput="OnSearchChanged"
                                        Placeholder="@SearchPlaceholder"
                                        AriaLabel="@SearchPlaceholder" />
                    </label>
                }

                <div class="browse-multi-select__options">
                    <label class="@OptionClass(SelectedValues.Count == 0)">
                        <AppNativeInput Type="checkbox"
                                        Checked="@(SelectedValues.Count == 0)"
                                        AriaLabel="@AllLabel"
                                        OnChange="ClearAsync" />
                        <span>
                            <strong>@AllLabel</strong>
                            @if (!string.IsNullOrWhiteSpace(AllHelpText))
                            {
                                <small>@AllHelpText</small>
                            }
                        </span>
                    </label>

                    @foreach (var option in FilteredOptions)
                    {
                        var selected = SelectedValues.Contains(option, StringComparer.OrdinalIgnoreCase);
                        <label class="@OptionClass(selected)" @key="option">
                            <AppNativeInput Type="checkbox"
                                            Checked="@selected"
                                            AriaLabel="@option"
                                            OnChange="@(_ => ToggleAsync(option))" />
                            <span><strong>@option</strong></span>
                        </label>
                    }

                    @if (FilteredOptions.Count == 0)
                    {
                        <div class="browse-multi-select__empty">@EmptyText</div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(HelpText))
                {
                    <div class="browse-multi-select__help">@HelpText</div>
                }
            </div>
        </ChildContent>
    </MudMenu>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ButtonLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Icon { get; set; } = Icons.Material.Outlined.FilterList;
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public bool Searchable { get; set; } = true;
    [Parameter] public string SearchPlaceholder { get; set; } = "Search...";
    [Parameter] public string AllLabel { get; set; } = "All";
    [Parameter] public string? AllHelpText { get; set; }
    [Parameter] public string EmptyText { get; set; } = "No matching options";
    [Parameter] public string? HelpText { get; set; }
    [Parameter] public IReadOnlyList<string> Options { get; set; } = [];
    [Parameter] public IReadOnlyList<string> SelectedValues { get; set; } = [];
    [Parameter] public EventCallback<IReadOnlyList<string>> SelectedValuesChanged { get; set; }

    private bool _open;
    private string _searchText = string.Empty;

    private IReadOnlyList<string> FilteredOptions => Options
        .Where(option => string.IsNullOrWhiteSpace(_searchText)
                         || option.Contains(_searchText.Trim(), StringComparison.OrdinalIgnoreCase))
        .ToList();

    private string TriggerClass =>
        $"browse-multi-select__trigger {(SelectedValues.Count > 0 ? "is-active" : string.Empty)}";

    private string ResolvedAriaLabel => AriaLabel
        ?? (SelectedValues.Count == 0
            ? ButtonLabel
            : $"{ButtonLabel}, {SelectedValues.Count} selected");

    private static string OptionClass(bool selected) =>
        $"browse-multi-select__option {(selected ? "is-selected" : string.Empty)}";

    private void OnOpenChanged(bool open) => _open = open;

    private void OnSearchChanged(ChangeEventArgs args) =>
        _searchText = args.Value?.ToString() ?? string.Empty;

    private async Task ToggleAsync(string option)
    {
        var selected = SelectedValues.ToHashSet(StringComparer.OrdinalIgnoreCase);
        if (!selected.Add(option))
        {
            selected.Remove(option);
        }

        await SelectedValuesChanged.InvokeAsync(selected
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .ToList());
        _open = true;
    }

    private async Task ClearAsync()
    {
        if (SelectedValues.Count > 0)
        {
            await SelectedValuesChanged.InvokeAsync([]);
        }

        _open = true;
    }
}
