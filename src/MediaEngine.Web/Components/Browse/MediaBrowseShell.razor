    private async Task ToggleFavoriteAsync(Guid workId)
    {
        var membership = await Favorites.ToggleAsync(workId, _activeProfileId);
        if (membership is null)
        {
            Snackbar.Add("The favorite could not be updated.", Severity.Warning);
            return;
        }

        Snackbar.Add(membership.IsFavorite ? "Added to Favorites." : "Removed from Favorites.", Severity.Success);
