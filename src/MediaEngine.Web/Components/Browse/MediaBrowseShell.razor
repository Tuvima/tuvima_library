@namespace MediaEngine.Web.Components.Browse
@using System.Security.Cryptography
@using System.Text
@using MediaEngine.Contracts.Display
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.MediaTiles
@using MediaEngine.Web.Services.Editing
@using MediaEngine.Web.Services.Integration
@using MediaEngine.Web.Services.Navigation

@implements IDisposable

@inject IEngineApiClient ApiClient
@inject MediaEditorLauncherService MediaEditorLauncher
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<MediaBrowseShell> Logger
@inject UniverseStateContainer StateContainer

<BrowseShellStyles />

<div class="@RootClass">
    <div class="browse-shell__toolbar-anchor">
        <div class="browse-shell__toolbar-panel">
            @if (ShowHeaderRow)
            {
                <div class="browse-shell__tab-row">
                    @if (ShowTitleBlock)
                    {
                        <div class="browse-shell__title-block">
                            <div class="browse-shell__title-eyebrow">@Preset.Title</div>
                            <div class="browse-shell__title-text">@CurrentTab.Label</div>
                        </div>
                    }

                    @if (ShowTabs)
                    {
                        <div class="browse-shell__tabs-frame">
                            <AppTabs ActivePanelIndex="@ActiveBrowseTabIndex"
                                     ActivePanelIndexChanged="OnBrowseTabChanged"
                                     Rounded="false"
                                     Border="false"
                                     Elevation="0"
                                     Class="browse-shell__tabs">
                                @foreach (var tab in Preset.Tabs)
                                {
                                    <MudTabPanel @key="tab.Id" Text="@tab.Label" />
                                }
                            </AppTabs>
                        </div>
                    }
                </div>
            }

            <div class="@ToolbarClass">
                <AppTextField T="string"
                              @bind-Value="_searchText"
                              Placeholder="Search your library"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Search"
                              Immediate="true"
                              DebounceInterval="250"
                              OnDebounceIntervalElapsed="OnSearchChanged"
                              Class="browse-shell__search" />

                @if (CurrentTab.GroupingOptions.Count > 1)
                {
                    <div class="browse-shell__groupings" role="group" aria-label="@($"{CurrentTab.Label} grouping")">
                        @foreach (var option in CurrentTab.GroupingOptions)
                        {
                            <AppNativeButton Type="button"
                                             @key="option.Value"
                                             Class="@GroupingChipClass(option.Value)"
                                             AriaLabel="@option.Label"
                                             aria-pressed="@(string.Equals(_grouping, option.Value, StringComparison.OrdinalIgnoreCase) ? "true" : "false")"
                                             OnClick="@(() => SwitchGroupingAsync(option.Value))">
                                <MudIcon Icon="@option.Icon" Class="browse-shell__grouping-icon" />
                                <span>@option.Label</span>
                            </AppNativeButton>
                        }
                    </div>
                }

                <div class="browse-shell__controls">
                    @if (UseListLayout && _selectedItems.Count > 1 && !IsContainerGrouping)
                    {
                        <AppButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Outlined.Edit"
                                   OnClick="OpenBatchEditorAsync"
                                   Class="browse-shell__batch-edit">
                            Edit @_selectedItems.Count
                        </AppButton>
                    }

                    <AppSelect T="string"
                               Value="@_sortBy"
                               ValueChanged="OnSortChanged"
                               Label="Sort"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Class="browse-shell__sort">
                        @foreach (var option in GetSortOptions())
                        {
                            <MudSelectItem T="string" @key="option.Value" Value="@option.Value">@option.Label</MudSelectItem>
                        }
                    </AppSelect>

                    @if (SupportsLayoutToggle)
                    {
                        <div class="browse-shell__layout-toggle" role="group" aria-label="View mode">
                            <AppNativeButton Type="button"
                                             Class="@LayoutToggleClass(LibraryLayoutMode.Card)"
                                             AriaLabel="Show cards"
                                             Title="Show cards"
                                             aria-pressed="@(_layout == LibraryLayoutMode.Card ? "true" : "false")"
                                             OnClick="@(_ => SwitchLayoutAsync(LibraryLayoutMode.Card))">
                                <MudIcon Icon="@Icons.Material.Outlined.GridView" />
                                <span>Cards</span>
                            </AppNativeButton>
                            <AppNativeButton Type="button"
                                             Class="@LayoutToggleClass(LibraryLayoutMode.List)"
                                             AriaLabel="Show list"
                                             Title="Show list"
                                             aria-pressed="@(_layout == LibraryLayoutMode.List ? "true" : "false")"
                                             OnClick="@(_ => SwitchLayoutAsync(LibraryLayoutMode.List))">
                                <MudIcon Icon="@Icons.Material.Outlined.ViewList" />
                                <span>List</span>
                            </AppNativeButton>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (_loading && !_hasLoadedOnce)
    {
        <div class="browse-shell__loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Class="tl-u-color-tl-text-faint" />
        </div>
    }
    else if (_loadFailed)
    {
        <AppErrorState Title="Library view failed to load"
                       Message="The Dashboard could not load this library view from the Engine."
                       Details="@_loadError"
                       Retry="ReloadAsync" />
    }
    else if (UseListLayout)
    {
        <div class="browse-shell__list">
            <LibraryConfigurableTable Columns="@ActiveColumns"
                                      VisibleColumnKeys="@VisibleColumnKeys"
                                      Items="@ActiveTableItems"
                                      Loading="@_loading"
                                      PosterSize="56"
                                      SelectedItems="@_selectedItems"
                                      SelectedItemsChanged="OnSelectionChanged"
                                      OnEditClicked="OpenItemEditorAsync"
                                      OnRowClicked="HandleTableRowClicked" />
        </div>
    }
    else if (_cards.Count == 0)
    {
        <div class="browse-shell__empty">
            <MudIcon Icon="@Icons.Material.Outlined.Inbox" Class="tl-u-font-size-52px tl-u-opacity-0-16" />
            <h3>@EmptyStateTitle</h3>
            <p>@EmptyStateMessage</p>
            @if (string.IsNullOrWhiteSpace(_searchText))
            {
                <AppButton Variant="Variant.Text"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Outlined.PendingActions"
                           Href="/settings/ingestion">
                    Open Ingestion
                </AppButton>
            }
        </div>
    }
    else
    {
        <MediaTileGrid Items="@_cards"
                       HoverMode="@GridHoverMode"
                       OnEditClicked="OpenCardEditorAsync"
                       HideMediaKindBadges="true"
                       HideSourceBadges="true"
                       Class="browse-shell__grid" />
    }

    @if (_hasMore && !IsContainerGrouping)
    {
        <div class="browse-shell__load-more">
            <AppButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="LoadMoreAsync"
                       Class="browse-shell__load-more-button">
                Load more
            </AppButton>
        </div>
    }
</div>

@code {
    [Parameter] public string? Tab { get; set; }
    [Parameter, EditorRequired] public LibraryBrowsePreset Preset { get; set; } = default!;
    [Parameter] public bool Embedded { get; set; }
    [Parameter] public bool ShowTitleBlock { get; set; } = true;

    private const int PageSize = 72;

    private readonly HashSet<Guid> _selectedItems = [];
    private readonly List<MediaTileViewModel> _cards = [];

    private string _activeTabId = string.Empty;
    private string _grouping = "all";
    private string _searchText = string.Empty;
    private string _sortBy = "newest";
    private LibraryLayoutMode _layout = LibraryLayoutMode.Card;
    private bool _loading;
    private bool _hasLoadedOnce;
    private bool _hasMore;
    private bool _navigatingInternally;
    private bool _loadFailed;
    private string? _loadError;

    private List<LibraryItemViewModel> _items = [];
    private List<ContentGroupViewModel> _groups = [];

    private BrowseTabPreset CurrentTab =>
        Preset.Tabs.FirstOrDefault(tab => string.Equals(tab.Id, _activeTabId, StringComparison.OrdinalIgnoreCase))
        ?? Preset.Tabs[0];

    private string RootClass =>
        $"browse-shell {(Embedded ? "browse-shell--embedded" : string.Empty)}".Trim();
    private bool ShowTabs => Preset.Tabs.Count > 1;
    private bool ShowHeaderRow => ShowTitleBlock || ShowTabs;
    private string ToolbarClass =>
        ShowHeaderRow ? "browse-shell__toolbar" : "browse-shell__toolbar browse-shell__toolbar--standalone";
    private int ActiveBrowseTabIndex => GetSelectedIndex(Preset.Tabs.Select(tab => tab.Id), _activeTabId);
    private bool IsContainerGrouping => BrowseQueryBuilder.IsContainerGrouping(_grouping);
    private bool IsTvShowsGrouping =>
        string.Equals(_activeTabId, "tv", StringComparison.OrdinalIgnoreCase)
        && string.Equals(_grouping, "shows", StringComparison.OrdinalIgnoreCase)
        && string.Equals(CurrentTab.MediaType, "TV", StringComparison.OrdinalIgnoreCase);
    private bool UseListLayout => _layout == LibraryLayoutMode.List || _grouping == "tracks";
    private bool SupportsLayoutToggle => _grouping != "tracks";
    private MediaTileHoverMode? GridHoverMode => null;
    private string EmptyStateTitle =>
        !string.IsNullOrWhiteSpace(_searchText)
            ? "No matches found"
            : IsContainerGrouping
                ? $"No {CurrentTab.Label.ToLowerInvariant()} groups yet"
                : $"No {CurrentTab.Label.ToLowerInvariant()} in your library yet";

    private string EmptyStateMessage =>
        !string.IsNullOrWhiteSpace(_searchText)
            ? "Try a different search term or clear the search box."
            : IsContainerGrouping
                ? "Groups appear only when the Engine has real series, collection, artist, album, or show data."
                : $"Once supported {CurrentTab.Label.ToLowerInvariant()} files are ingested, they will appear here.";

    private async Task OnBrowseTabChanged(int index)
    {
        if (index < 0 || index >= Preset.Tabs.Count)
        {
            return;
        }

        await SwitchTabAsync(Preset.Tabs[index].Id);
    }

    private string LayoutToggleClass(LibraryLayoutMode mode) =>
        $"browse-shell__layout-button {(_layout == mode ? "is-active" : string.Empty)}";

    private string GroupingChipClass(string value) =>
        $"browse-shell__grouping-button {(string.Equals(_grouping, value, StringComparison.OrdinalIgnoreCase) ? "is-active" : string.Empty)}";

    private List<LibraryColumnDef> ActiveColumns =>
        IsContainerGrouping
            ? LibraryColumnDefinitions.GetColumnsByTab(_activeTabId, _grouping)
            : LibraryColumnDefinitions.GetColumnsByTab(_activeTabId);

    private List<string> VisibleColumnKeys =>
        ActiveColumns
            .Where(column => column.DefaultVisible && !string.Equals(column.Key, "checkbox", StringComparison.OrdinalIgnoreCase))
            .Select(column => column.Key)
            .ToList();

    private List<LibraryItemViewModel> ActiveTableItems =>
        IsContainerGrouping ? BuildContainerDisplayItems() : _items;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        StateContainer.MediaAddedReceived += OnMediaAdded;
    }

    protected override async Task OnParametersSetAsync()
    {
        ReadUrlState();
        await LoadBrowseContentAsync();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            if (_navigatingInternally)
            {
                _navigatingInternally = false;
                return;
            }

            ReadUrlState();
            await InvokeAsync(async () =>
            {
                await LoadBrowseContentAsync();
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to handle browse route change");
        }
    }

    private void ReadUrlState()
    {
        var state = BrowseQueryBuilder.Read(Preset, Tab, Nav.Uri);
        _activeTabId = state.ActiveTabId;
        _grouping = state.Grouping;
        _layout = state.Layout;
        _searchText = state.SearchText;
        _sortBy = state.SortBy;

        ClearActiveGroupState();
    }

    private static string ResolveGrouping(string? requestedGrouping, BrowseTabPreset tab) =>
        BrowseQueryBuilder.ResolveGrouping(requestedGrouping, tab);

    private static LibraryLayoutMode ResolveLayout(string? requestedLayout, BrowseTabPreset tab, string grouping) =>
        BrowseQueryBuilder.ResolveLayout(requestedLayout, tab, grouping);

    private string ResolveSort(string? requestedSort) =>
        BrowseQueryBuilder.ResolveSort(requestedSort, _activeTabId, _grouping);

    private async Task LoadBrowseContentAsync(bool append = false)
    {
        _loadFailed = false;
        _loadError = null;
        _loading = true;
        if (!_hasLoadedOnce)
            StateHasChanged();

        try
        {
            if (IsContainerGrouping)
            {
                if (IsTvShowsGrouping && !UseListLayout)
                {
                    if (!await LoadDisplayCardsAsync(append))
                    {
                        throw new InvalidOperationException("Display API did not return a TV browse page.");
                    }
                }
                else
                {
                    await LoadGroupsAsync();
                    _cards.Clear();
                    _cards.AddRange(_groups.Select(ToGroupCard));
                }
            }
            else
            {
                if (!UseListLayout)
                {
                    if (!await LoadDisplayCardsAsync(append))
                    {
                        throw new InvalidOperationException("Display API did not return a browse page.");
                    }
                }
                else
                {
                    await LoadItemsAsync(append);
                }
            }
        }
        catch (Exception ex)
        {
            _loadFailed = true;
            _loadError = ApiClient.LastError ?? ex.Message;
        }
        finally
        {
            _loading = false;
            _hasLoadedOnce = true;
        }
    }

    private Task ReloadAsync() => LoadBrowseContentAsync();

    private void OnMediaAdded(MediaAddedEvent ev)
    {
        _ = InvokeAsync(async () =>
        {
            Snackbar.Add($"Added to library: {ev.Title}", Severity.Success);
            await LoadBrowseContentAsync();
            StateHasChanged();
        });
    }

    private async Task<bool> LoadDisplayCardsAsync(bool append)
    {
        var requestedOffset = append ? _cards.Count : 0;
        var page = await ApiClient.GetDisplayBrowseAsync(
            mediaType: CurrentTab.MediaType,
            grouping: _grouping,
            search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
            offset: requestedOffset,
            limit: PageSize);

        if (page is null)
        {
            return false;
        }

        var incoming = SortCards(page.Catalog.Select(MediaTileComposerService.FromDisplayCard)).ToList();
        if (append)
        {
            _cards.AddRange(incoming);
            var sorted = SortCards(_cards).ToList();
            _cards.Clear();
            _cards.AddRange(sorted);
        }
        else
        {
            _cards.Clear();
            _cards.AddRange(incoming);
        }

        _items = [];
        _groups = [];
        _hasMore = page.Catalog.Count >= PageSize;
        return true;
    }

    private async Task LoadItemsAsync(bool append)
    {
        var requestedOffset = append ? _items.Count : 0;
        var response = await ApiClient.GetLibraryCatalogItemsAsync(
            offset: requestedOffset,
            limit: PageSize,
            search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
            type: CurrentTab.MediaType,
            sort: ResolveLibraryItemSort());

        var incoming = response?.Items?.Select(LibraryItemViewModel.From).ToList() ?? [];
        if (response is null && !string.IsNullOrWhiteSpace(ApiClient.LastError))
        {
            _loadFailed = true;
            _loadError = ApiClient.LastError;
            return;
        }
        incoming = SortItems(incoming);

        if (append)
        {
            _items.AddRange(incoming);
            _items = SortItems(_items);
        }
        else
        {
            _items = incoming;
        }

        _hasMore = response?.HasMore ?? false;
    }

    private async Task LoadGroupsAsync()
    {
        var systemGroupField = GetSystemViewGroupField();
        var mediaType = CurrentTab.MediaType;

        var groups = systemGroupField is not null
            ? await ApiClient.GetSystemViewGroupsAsync(mediaType, systemGroupField)
            : await ApiClient.GetContentGroupsAsync();
        if (groups.Count == 0 && !string.IsNullOrWhiteSpace(ApiClient.LastError))
        {
            _loadFailed = true;
            _loadError = ApiClient.LastError;
            return;
        }

        if (systemGroupField is null)
        {
            groups = groups
                .Where(group => MediaTypeMatches(group.PrimaryMediaType, mediaType))
                .ToList();
        }

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            groups = groups.Where(group =>
                    group.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                    || (!string.IsNullOrWhiteSpace(group.Creator) && group.Creator.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
                    || (!string.IsNullOrWhiteSpace(group.Network) && group.Network.Contains(_searchText, StringComparison.OrdinalIgnoreCase)))
                .ToList();
        }

        _groups = SortGroups(groups);
        _hasMore = false;
    }

    private string? ResolveLibraryItemSort() => _sortBy switch
    {
        "title" => "title",
        "oldest" => "oldest",
        _ => "newest",
    };

    private List<LibraryItemViewModel> SortItems(IEnumerable<LibraryItemViewModel> source)
    {
        return _sortBy switch
        {
            "title" => source.OrderBy(item => item.Title, StringComparer.OrdinalIgnoreCase).ToList(),
            "oldest" => source.OrderBy(item => item.CreatedAt).ToList(),
            "creator" => source.OrderBy(item => item.Creator ?? item.ContextLabel ?? item.Title, StringComparer.OrdinalIgnoreCase).ToList(),
            "year" => source.OrderByDescending(item => ParseYear(item.Year)).ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase).ToList(),
            _ => source.OrderByDescending(item => item.CreatedAt).ToList(),
        };
    }

    private List<ContentGroupViewModel> SortGroups(IEnumerable<ContentGroupViewModel> source)
    {
        return _sortBy switch
        {
            "title" => source.OrderBy(group => group.DisplayName, StringComparer.OrdinalIgnoreCase).ToList(),
            "newest" => source.OrderByDescending(group => group.CreatedAt).ThenBy(group => group.DisplayName, StringComparer.OrdinalIgnoreCase).ToList(),
            _ => source.OrderByDescending(group => group.WorkCount).ThenBy(group => group.DisplayName, StringComparer.OrdinalIgnoreCase).ToList(),
        };
    }

    private IEnumerable<MediaTileViewModel> SortCards(IEnumerable<MediaTileViewModel> source)
    {
        return _sortBy switch
        {
            "title" => source.OrderBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            "oldest" => source.OrderBy(card => card.SortTimestamp),
            "creator" => source.OrderBy(card => card.Creator ?? card.Subtitle ?? card.Title, StringComparer.OrdinalIgnoreCase),
            "year" => source.OrderByDescending(card => card.SortYear).ThenBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            _ => source.OrderByDescending(card => card.SortTimestamp),
        };
    }

    private MediaTileViewModel ToGroupCard(ContentGroupViewModel group)
    {
        var presentation = (_activeTabId, _grouping) switch
        {
            ("tv", "shows") => "tvSeries",
            ("movies", "series") => "movieSeries",
            ("books", "series") => "bookSeries",
            ("comics", "series") => "comicSeries",
            ("audiobooks", "series") => "audiobookSeries",
            ("music", "albums") => "album",
            ("music", "artists") => "artist",
            _ => "default",
        };

        var wideArtwork = BrowseArtworkRules.ResolveWideArtwork(group.BackgroundUrl, group.BannerUrl);
        var navigationUrl = BuildGroupNavigationUrl(group);
        var displayMediaType = FormatMediaLabel(group.PrimaryMediaType);
        var coverUrl = string.Equals(presentation, "artist", StringComparison.OrdinalIgnoreCase)
            ? group.ArtistPhotoUrl
            : group.CoverUrl;
        var coverSmallUrl = MediaTileArtworkUrl.Sized(coverUrl, "s");
        var coverMediumUrl = MediaTileArtworkUrl.Sized(coverUrl, "m");
        var coverLargeUrl = MediaTileArtworkUrl.Sized(coverUrl, "l");
        var artistSmallUrl = MediaTileArtworkUrl.Sized(group.ArtistPhotoUrl, "s");
        var artistMediumUrl = MediaTileArtworkUrl.Sized(group.ArtistPhotoUrl, "m");
        var artistLargeUrl = MediaTileArtworkUrl.Sized(group.ArtistPhotoUrl, "l");
        var bannerSmallUrl = MediaTileArtworkUrl.Sized(group.BannerUrl, "s");
        var bannerMediumUrl = MediaTileArtworkUrl.Sized(group.BannerUrl, "m");
        var bannerLargeUrl = MediaTileArtworkUrl.Sized(group.BannerUrl, "l");
        var backgroundSmallUrl = MediaTileArtworkUrl.Sized(wideArtwork, "s");
        var backgroundMediumUrl = MediaTileArtworkUrl.Sized(wideArtwork, "m");
        var backgroundLargeUrl = MediaTileArtworkUrl.Sized(wideArtwork, "l");
        var card = new DisplayCardDto(
            Id: GetGroupNavigationId(group),
            WorkId: null,
            AssetId: null,
            CollectionId: group.CollectionId,
            MediaType: displayMediaType,
            GroupingType: string.Equals(presentation, "default", StringComparison.OrdinalIgnoreCase) ? "collection" : presentation,
            Title: group.DisplayName,
            Subtitle: group.Creator ?? group.Network,
            Facts: BrowseArtworkRules.CompactFacts(group.Year, GroupCountLabel(group)),
            Artwork: new DisplayArtworkDto(coverUrl, coverSmallUrl, coverMediumUrl, coverLargeUrl, group.ArtistPhotoUrl, artistSmallUrl, artistMediumUrl, artistLargeUrl, group.BannerUrl, bannerSmallUrl, bannerMediumUrl, bannerLargeUrl, wideArtwork, backgroundSmallUrl, backgroundMediumUrl, backgroundLargeUrl, group.LogoUrl, group.CoverWidthPx, group.CoverHeightPx, group.SquareWidthPx, group.SquareHeightPx, group.BannerWidthPx, group.BannerHeightPx, group.BackgroundWidthPx, group.BackgroundHeightPx, group.MediaTypeColor ?? AccentForMedia(group.PrimaryMediaType)),
            PreferredShape: BrowseArtworkRules.PreferredDisplayShape(group.PrimaryMediaType, wideArtwork, group.ArtistPhotoUrl),
            Presentation: presentation,
            TileTextMode: "caption",
            PreviewPlacement: "smart",
            Progress: null,
            Actions: [new DisplayActionDto("openCollection", "Explore", null, null, group.CollectionId, navigationUrl)],
            Flags: new DisplayCardFlagsDto(IsPlayableMedia(group.PrimaryMediaType), IsReadMedia(group.PrimaryMediaType), false, true, false),
            SortTimestamp: group.CreatedAt);

        return WithCardOverrides(
            MediaTileComposerService.FromDisplayCard(card),
            description: BuildGroupDescription(group),
            heroUrl: null,
            previewImages: BuildGroupPreviewImages(group, wideArtwork, presentation),
            creator: group.Creator,
            collectionKey: group.DisplayName,
            sortYear: ParseYear(group.Year));
    }

    private static IReadOnlyList<string> BuildGroupPreviewImages(ContentGroupViewModel group, string? wideArtwork, string presentation)
    {
        IEnumerable<string?> candidates = string.Equals(presentation, "artist", StringComparison.OrdinalIgnoreCase)
            ? new[] { group.ArtistPhotoUrl, group.CoverUrl, group.BannerUrl, group.BackgroundUrl }
            : new[] { wideArtwork, group.BannerUrl, group.BackgroundUrl, group.CoverUrl };

        return candidates
            .Select(value => MediaTileArtworkUrl.Sized(value, "s") ?? value)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Cast<string>()
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(5)
            .ToList();
    }

    private static string GroupCountLabel(ContentGroupViewModel group)
    {
        if (string.Equals(group.PrimaryMediaType, "TV", StringComparison.OrdinalIgnoreCase)
            && group.SeasonCount is int seasonCount
            && seasonCount > 0)
        {
            return seasonCount == 1 ? "1 season" : $"{seasonCount} seasons";
        }

        var noun = group.PrimaryMediaType switch
        {
            "Comic" => group.WorkCount == 1 ? "issue" : "issues",
            "Music" => group.WorkCount == 1 ? "track" : "tracks",
            _ => group.WorkCount == 1 ? "title" : "titles",
        };

        return $"{group.WorkCount} {noun}";
    }

    private List<LibraryItemViewModel> BuildContainerDisplayItems()
    {
        var isSystemGroup = GetSystemViewGroupField() is not null;
        return _groups.Select(group => new LibraryItemViewModel
        {
            EntityId = isSystemGroup ? GenerateDeterministicGuid(group.DisplayName) : group.CollectionId,
            Title = group.DisplayName,
            MediaType = group.PrimaryMediaType,
            CoverUrl = group.ArtistPhotoUrl ?? group.CoverUrl,
            ArtistPhotoUrl = group.ArtistPhotoUrl,
            BackgroundUrl = group.BackgroundUrl,
            BannerUrl = group.BannerUrl,
            Author = group.Creator,
            Artist = group.Creator,
            Network = group.Network,
            Year = group.Year,
            SeasonCount = group.SeasonCount?.ToString(),
            AlbumCount = group.AlbumCount?.ToString(),
            TrackCount = group.WorkCount.ToString(),
        }).ToList();
    }

    private async Task SwitchTabAsync(string tabId)
    {
        if (string.Equals(_activeTabId, tabId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _activeTabId = tabId;
        var tab = CurrentTab;
        _grouping = tab.DefaultGrouping;
        _layout = ResolveLayout(null, tab, _grouping);
        _sortBy = ResolveSort(null);
        _searchText = string.Empty;
        ClearActiveGroupState();
        await NavigateAndReloadAsync();
    }

    private async Task SwitchGroupingAsync(string grouping)
    {
        if (string.Equals(_grouping, grouping, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _grouping = grouping;
        _layout = ResolveLayout(null, CurrentTab, _grouping);
        _sortBy = ResolveSort(null);
        ClearActiveGroupState();
        await NavigateAndReloadAsync();
    }

    private async Task SwitchLayoutAsync(LibraryLayoutMode layout)
    {
        if (_layout == layout || !SupportsLayoutToggle)
        {
            return;
        }

        _layout = layout;
        _selectedItems.Clear();
        await NavigateAndReloadAsync(reloadData: true);
    }

    private async Task OnSearchChanged(string _)
    {
        ClearActiveGroupState();
        await NavigateAndReloadAsync(reloadData: true, replace: true);
    }

    private async Task OnSortChanged(string value)
    {
        _sortBy = value;
        await NavigateAndReloadAsync();
    }

    private async Task LoadMoreAsync()
    {
        await LoadBrowseContentAsync(append: true);
    }

    private Task OnSelectionChanged(HashSet<Guid> selected)
    {
        _selectedItems.Clear();
        foreach (var item in selected)
        {
            _selectedItems.Add(item);
        }
        return Task.CompletedTask;
    }

    private void HandleTableRowClicked(Guid entityId)
    {
        if (IsContainerGrouping)
        {
            var displayItem = ActiveTableItems.FirstOrDefault(item => item.EntityId == entityId);
            if (displayItem is null)
            {
                return;
            }

            var matchingGroup = _groups.FirstOrDefault(group =>
                string.Equals(group.DisplayName, displayItem.Title, StringComparison.OrdinalIgnoreCase));

            if (matchingGroup is not null)
            {
                _navigatingInternally = true;
                Nav.NavigateTo(BuildGroupNavigationUrl(matchingGroup));
            }

            return;
        }

        var selectedItem = ActiveTableItems.FirstOrDefault(item => item.EntityId == entityId);
        Nav.NavigateTo(selectedItem is not null
            ? MediaNavigation.ForLibraryItem(selectedItem)
            : $"/book/{entityId}");
    }

    private Task OpenItem(Guid entityId)
    {
        var displayItem = _items.FirstOrDefault(item => item.EntityId == entityId);
        Nav.NavigateTo(displayItem is not null
            ? MediaNavigation.ForLibraryItem(displayItem)
            : $"/book/{entityId}");
        return Task.CompletedTask;
    }

    private Task OpenCardEditorAsync(MediaTileViewModel card)
    {
        var item = _items.FirstOrDefault(candidate => candidate.EntityId == card.WorkId);
        return OpenEditorAsync(
            card.WorkId ?? card.Id,
            card.Title,
            card.Subtitle,
            card.CoverUrl,
            item?.MediaType ?? card.MediaKind,
            reloadOrigin: true);
    }

    private async Task OpenItemEditorAsync(Guid entityId)
    {
        var item = ActiveTableItems.FirstOrDefault(candidate => candidate.EntityId == entityId)
                   ?? _items.FirstOrDefault(candidate => candidate.EntityId == entityId);

        await OpenEditorAsync(
            entityId,
            item?.Title,
            item?.Creator ?? item?.ContextLabel,
            item?.CoverUrl,
            item?.MediaType,
            reloadOrigin: true);
    }

    private async Task OpenBatchEditorAsync()
    {
        if (_selectedItems.Count <= 1)
        {
            return;
        }

        var selected = ActiveTableItems
            .Where(item => _selectedItems.Contains(item.EntityId))
            .ToList();

        var applied = await MediaEditorLauncher.OpenAsync(new MediaEditorLaunchRequest
        {
            EntityIds = _selectedItems.ToList(),
            Mode = SharedMediaEditorMode.Batch,
            MediaType = selected.Select(item => item.MediaType).FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? CurrentTab.MediaType,
            HeaderTitle = $"Edit {_selectedItems.Count} items",
            HeaderSubtitle = CurrentTab.Label,
            PreviewItems = selected
                .Select(item => new MediaEditorPreviewItem
                {
                    EntityId = item.EntityId,
                    Title = item.Title,
                    CoverUrl = item.CoverUrl,
                    MediaType = item.MediaType,
                })
                .ToList(),
        });

        if (applied)
        {
            _selectedItems.Clear();
            await RefreshOriginAsync();
            Snackbar.Add("Selected items updated.", Severity.Success);
        }
    }

    private async Task OpenEditorAsync(
        Guid entityId,
        string? title,
        string? subtitle,
        string? coverUrl,
        string? mediaType,
        bool reloadOrigin)
    {
        if (entityId == Guid.Empty)
        {
            return;
        }

        var resolvedTitle = string.IsNullOrWhiteSpace(title) ? "Untitled item" : title!;
        var normalizedMediaType = NormalizeEditorMediaType(mediaType ?? CurrentTab.MediaType);
        var applied = await MediaEditorLauncher.OpenAsync(new MediaEditorLaunchRequest
        {
            EntityIds = [entityId],
            LaunchEntityId = entityId,
            LaunchEntityKind = "browse",
            Mode = SharedMediaEditorMode.Normal,
            InitialTab = "details",
            MediaType = normalizedMediaType,
            HeaderTitle = resolvedTitle,
            HeaderSubtitle = subtitle,
            CoverUrl = coverUrl,
            PreviewItems =
            [
                new MediaEditorPreviewItem
                {
                    EntityId = entityId,
                    Title = resolvedTitle,
                    CoverUrl = coverUrl,
                    MediaType = normalizedMediaType,
                },
            ],
        });

        if (!applied)
        {
            return;
        }

        await RefreshOriginAsync(reloadOrigin);
        Snackbar.Add("Media details updated.", Severity.Success);
    }

    private async Task RefreshOriginAsync(bool reloadOrigin = true)
    {
        if (reloadOrigin)
            await LoadBrowseContentAsync();
    }

    private static string NormalizeEditorMediaType(string? mediaType)
    {
        var value = mediaType ?? string.Empty;
        if (value.Contains("movie", StringComparison.OrdinalIgnoreCase))
            return "Movies";
        if (value.Contains("tv", StringComparison.OrdinalIgnoreCase))
            return "TV";
        if (value.Contains("music", StringComparison.OrdinalIgnoreCase))
            return "Music";
        if (value.Contains("audio", StringComparison.OrdinalIgnoreCase))
            return "Audiobooks";
        if (value.Contains("comic", StringComparison.OrdinalIgnoreCase))
            return "Comics";
        return "Books";
    }

    private static bool MediaTypeMatches(string? candidate, string? requested) =>
        string.Equals(candidate, requested, StringComparison.OrdinalIgnoreCase)
        || string.Equals(NormalizeEditorMediaType(candidate), NormalizeEditorMediaType(requested), StringComparison.OrdinalIgnoreCase);

    private Task NavigateAndReloadAsync(bool reloadData = true, bool replace = false)
    {
        _navigatingInternally = true;
        Nav.NavigateTo(BuildCurrentUrl(), replace: replace);
        return reloadData ? LoadBrowseContentAsync() : Task.CompletedTask;
    }

    private string BuildCurrentUrl()
    {
        var defaultTab = Preset.Tabs[0].Id;
        var path = string.Equals(_activeTabId, defaultTab, StringComparison.OrdinalIgnoreCase)
                   && !Preset.UseExplicitDefaultTabRoute
            ? Preset.RouteBase
            : $"{Preset.RouteBase}/{_activeTabId}";

        var queryParts = new List<string>();

        if (!string.Equals(_grouping, CurrentTab.DefaultGrouping, StringComparison.OrdinalIgnoreCase))
        {
            queryParts.Add($"grouping={Uri.EscapeDataString(_grouping)}");
        }

        if (_layout != ResolveLayout(null, CurrentTab, _grouping))
        {
            queryParts.Add($"layout={_layout.ToString().ToLowerInvariant()}");
        }

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            queryParts.Add($"search={Uri.EscapeDataString(_searchText)}");
        }

        if (!string.Equals(_sortBy, ResolveSort(null), StringComparison.OrdinalIgnoreCase))
        {
            queryParts.Add($"sort={Uri.EscapeDataString(_sortBy)}");
        }

        return queryParts.Count == 0 ? path : $"{path}?{string.Join("&", queryParts)}";
    }

    private string BuildGroupNavigationUrl(ContentGroupViewModel group)
    {
        return (_activeTabId, _grouping) switch
        {
            ("tv", "shows") => $"/watch/tv/show/{GetTvShowGroupRouteId(group):D}",
            ("movies", "series") => $"/details/movieseries/{group.CollectionId:D}?context=watch",
            ("books", "series") => $"/details/bookseries/{group.CollectionId:D}?context=read",
            ("audiobooks", "series") => $"/details/bookseries/{group.CollectionId:D}?context=read",
            ("comics", "series") => $"/details/comicseries/{group.CollectionId:D}?context=comics",
            ("music", "albums") => $"/listen/music/albums/{group.CollectionId:D}",
            ("music", "artists") => $"/listen/music/artists/{Uri.EscapeDataString(group.DisplayName)}",
            _ => BuildCurrentUrl(),
        };
    }

    private Guid GetGroupNavigationId(ContentGroupViewModel group) =>
        GetSystemViewGroupField() is not null
            ? GenerateDeterministicGuid(group.DisplayName)
            : IsTvShowsGrouping
                ? GetTvShowGroupRouteId(group)
            : group.CollectionId;

    private static Guid GetTvShowGroupRouteId(ContentGroupViewModel group) =>
        group.RootWorkId ?? group.CollectionId;

    private string? GetSystemViewGroupField() =>
        BrowseQueryBuilder.GetSystemViewGroupField(_activeTabId, _grouping);

    private void ClearActiveGroupState()
    {
    }

    private IEnumerable<(string Value, string Label)> GetSortOptions() =>
        BrowseQueryBuilder.GetSortOptions(_activeTabId, _grouping);

    private static Guid GenerateDeterministicGuid(string value)
    {
        var bytes = MD5.HashData(Encoding.UTF8.GetBytes(value));
        return new Guid(bytes);
    }

