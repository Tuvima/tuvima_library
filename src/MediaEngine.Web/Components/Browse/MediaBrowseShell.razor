@namespace MediaEngine.Web.Components.Browse
@using System.Security.Cryptography
@using System.Text
@using MediaEngine.Contracts.Display
@using MediaEngine.Web.Components.Listen
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.MediaTiles
@using MediaEngine.Web.Services.Editing
@using MediaEngine.Web.Services.Integration
@using MediaEngine.Web.Services.Navigation
@using MediaEngine.Web.Services.Playback

@implements IDisposable

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject MediaEditorLauncherService MediaEditorLauncher
@inject CollectionEditorLauncherService CollectionEditorLauncher
@inject FavoriteService Favorites
@inject PlaybackSessionController Playback
@inject ListenAudioDragService AudioDrag
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<MediaBrowseShell> Logger
@inject UniverseStateContainer StateContainer

<BrowseShellStyles />

<div class="@RootClass">
    <div class="browse-shell__toolbar-anchor">
        <div class="browse-shell__toolbar-panel">
            @if (ShowHeaderRow)
            {
                <div class="browse-shell__tab-row">
                    @if (ShowTitleBlock)
                    {
                        <div class="browse-shell__title-block">
                            <div class="browse-shell__title-eyebrow">@Preset.Title</div>
                            <div class="browse-shell__title-text">@CurrentTab.Label</div>
                        </div>
                    }

                    @if (ShowTabs)
                    {
                        <div class="browse-shell__tabs-frame">
                            <AppTabs ActivePanelIndex="@ActiveBrowseTabIndex"
                                     ActivePanelIndexChanged="OnBrowseTabChanged"
                                     Rounded="false"
                                     Border="false"
                                     Elevation="0"
                                     Class="browse-shell__tabs">
                                @foreach (var tab in Preset.Tabs)
                                {
                                    <MudTabPanel @key="tab.Id" Text="@tab.Label" />
                                }
                            </AppTabs>
                        </div>
                    }
                </div>
            }

            <div class="browse-shell__filter-surface">
                <div class="browse-shell__filter-search-row">
                    <AppTextField @key="_searchInputVersion"
                                  T="string"
                                  @bind-Value="_searchText"
                                  Placeholder="@SearchPlaceholder"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Outlined.Search"
                                  Immediate="true"
                                  DebounceInterval="250"
                                  OnDebounceIntervalElapsed="OnSearchChanged"
                                  Class="browse-shell__search" />
                </div>

                <div class="browse-shell__filter-lower-row">
                    <div class="browse-shell__control-group browse-shell__control-group--browse">
                        <span class="browse-shell__control-label">Browse as</span>
                        <AppBrowseModeSelector Options="@CurrentTab.GroupingOptions"
                                               Value="@_grouping"
                                               ValueChanged="SwitchGroupingAsync"
                                               AriaLabel="@($"Browse {CurrentTab.Label} as")" />
                    </div>

                    <div class="browse-shell__control-group browse-shell__control-group--filters">
                        <span class="browse-shell__control-label">Filter by</span>
                        <div class="browse-shell__filter-row">
                            <div class="browse-shell__filter-selects">
                                @if (GenreFacets.Count > 0 && SupportsFacetFilters)
                                {
                                    <BrowseMultiSelect Label="Filters"
                                                       ButtonLabel="Genres"
                                                       Icon="@Icons.Material.Outlined.LocalOffer"
                                                       Options="GenreFacets"
                                                       SelectedValues="SelectedGenres"
                                                       SelectedValuesChanged="OnGenresChanged"
                                                       SearchPlaceholder="Search genres..."
                                                       AllLabel="All genres"
                                                       AllHelpText="No genre filter applied"
                                                       EmptyText="No matching genres"
                                                       HelpText="Select one or more genres to filter results."
                                                       ShowLabel="false"
                                                       Class="browse-shell__multi-select browse-shell__multi-select--genres" />
                                }

                                @if (SupportsFacetFilters)
                                {
                                    <BrowseMultiSelect Label="@CreatorFilterLabel"
                                                       ButtonLabel="@AllCreatorLabel"
                                                       Icon="@Icons.Material.Outlined.PersonOutline"
                                                       Options="CreatorFacets"
                                                       SelectedValues="SelectedCreators"
                                                       SelectedValuesChanged="OnCreatorsChanged"
                                                       SearchPlaceholder="@CreatorSearchPlaceholder"
                                                       AllLabel="@AllCreatorLabel"
                                                       AllHelpText="No creator filter applied"
                                                       EmptyText="No matching creators"
                                                       ShowLabel="false"
                                                       Class="browse-shell__multi-select browse-shell__multi-select--creator" />

                                    <BrowseMultiSelect Label="Year"
                                                       ButtonLabel="All years"
                                                       Icon="@Icons.Material.Outlined.CalendarMonth"
                                                       Options="YearFacets"
                                                       SelectedValues="SelectedYears"
                                                       SelectedValuesChanged="OnYearsChanged"
                                                       SearchPlaceholder="Search years..."
                                                       AllLabel="All years"
                                                       AllHelpText="No year filter applied"
                                                       EmptyText="No matching years"
                                                       ShowLabel="false"
                                                       Class="browse-shell__multi-select browse-shell__multi-select--year" />
                                }
                            </div>

                            @if (SupportsFacetFilters)
                            {
                                <div class="browse-shell__toggle-row">
                                    @if (!IsMusicTab)
                                    {
                                        <AppQuickFilterToggle Label="In progress"
                                                              Selected="@IsInProgressOnly"
                                                              SelectedChanged="OnInProgressChanged" />
                                    }
                                    <AppQuickFilterToggle Label="@SecondaryQuickFilterLabel"
                                                          Selected="@IsSecondaryQuickFilterSelected"
                                                          SelectedChanged="OnSecondaryQuickFilterChanged" />
                                    @if (IsAudiobookTab)
                                    {
                                        <AppQuickFilterToggle Label="Finished"
                                                              Selected="@IsFinishedOnly"
                                                              SelectedChanged="OnFinishedChanged" />
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="browse-shell__display-controls">
                        <span class="browse-shell__sort-label">Sort</span>
                        <span class="browse-shell__display-label">Display</span>
                        <AppSelect T="string"
                                   Value="@_sortBy"
                                   ValueChanged="OnSortChanged"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Class="browse-shell__sort">
                            @foreach (var option in GetSortOptions())
                            {
                                <MudSelectItem T="string" @key="option.Value" Value="@option.Value">@option.Label</MudSelectItem>
                            }
                        </AppSelect>
                        @if (!UseListLayout)
                        {
                            <label class="browse-shell__tile-size" title="Adjust tile size">
                                <span>Tile size</span>
                                <span class="browse-shell__tile-size-control">
                                    <MudIcon Icon="@Icons.Material.Outlined.PhotoSizeSelectSmall" />
                                    <AppNativeInput Type="range"
                                                    Value="@TileSizePx"
                                                    Min="@TileSizeMinPx"
                                                    Max="@TileSizeMaxPx"
                                                    Step="8"
                                                    AriaLabel="Tile size"
                                                    OnInput="OnTileSizeChanged" />
                                </span>
                            </label>
                        }

                        @if (SupportsLayoutToggle)
                        {
                            <div class="browse-shell__layout-toggle" role="group" aria-label="View mode">
                                <AppNativeButton Type="button"
                                                 Class="@LayoutToggleClass(LibraryLayoutMode.Card)"
                                                 AriaLabel="Show cards"
                                                 Title="Show cards"
                                                 aria-pressed="@(_layout == LibraryLayoutMode.Card ? "true" : "false")"
                                                 OnClick="@(_ => SwitchLayoutAsync(LibraryLayoutMode.Card))">
                                    <MudIcon Icon="@Icons.Material.Outlined.GridView" />
                                    <span>Cards</span>
                                </AppNativeButton>
                                <AppNativeButton Type="button"
                                                 Class="@LayoutToggleClass(LibraryLayoutMode.List)"
                                                 AriaLabel="Show list"
                                                 Title="Show list"
                                                 aria-pressed="@(_layout == LibraryLayoutMode.List ? "true" : "false")"
                                                 OnClick="@(_ => SwitchLayoutAsync(LibraryLayoutMode.List))">
                                    <MudIcon Icon="@Icons.Material.Outlined.ViewList" />
                                    <span>List</span>
                                </AppNativeButton>
                            </div>
                        }

                        @if (UseListLayout && _selectedItems.Count > 1 && !IsContainerGrouping)
                        {
                            <AppButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       StartIcon="@Icons.Material.Outlined.Edit"
                                       OnClick="OpenBatchEditorAsync"
                                       Class="browse-shell__batch-edit">
                                Edit @_selectedItems.Count
                            </AppButton>
                        }
                    </div>
                </div>

                <AppActiveFilterSummary Items="@ActiveFilterChips"
                                        Remove="RemoveFilterAsync"
                                        ClearAll="ClearFiltersAsync" />
            </div>
        </div>
    </div>

    @if (!_loading || _hasLoadedOnce)
    {
        <div class="browse-shell__result-summary">
            <div>
                <h2>@ActiveGroupingLabel</h2>
                <span>@ResultCountLabel</span>
            </div>
            @if (IsPlaylistGrouping)
            {
                <div class="browse-shell__playlist-actions">
                    <AppButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Outlined.AutoAwesome"
                               OnClick="@(() => OpenPlaylistBuilderAsync(smart: true))">
                        New Smart Playlist
                    </AppButton>
                    <AppButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="@(() => OpenPlaylistBuilderAsync(smart: false))">
                        New Playlist
                    </AppButton>
                </div>
            }
        </div>

        <CompactContinueStrip Title="@ContinueTitle" Items="@_continueCards" />
    }

    @if (_loading && !_hasLoadedOnce)
    {
        <div class="browse-shell__loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Class="tl-u-color-tl-text-faint" />
        </div>
    }
    else if (_loadFailed)
    {
        <AppErrorState Title="Library view failed to load"
                       Message="The Dashboard could not load this library view from the Engine."
                       Details="@_loadError"
                       Retry="ReloadAsync" />
    }
    else if (UseListLayout && IsMusicSongsGrouping)
    {
        <div class="browse-shell__list">
            <ListenSongTable Tracks="@SongTracks"
                             FavoriteIds="@SongFavoriteIds"
                             SourceLabel="All Songs"
                             AriaLabel="Songs"
                             ShowGenre="false"
                             ShowPlays="true"
                             ShowDateAdded="true"
                             ShowEditDelete="false"
                             CurrentWorkId="@Playback.CurrentItem?.WorkId"
                             OnPlayRequested="PlaySongTracksAsync"
                             OnFavoriteToggled="ToggleSongFavoriteAsync"
                             OnQueueRequested="QueueSongAsync"
                             OnDragStarted="BeginSongDragAsync"
                             OnDragEnded="EndSongDragAsync" />
        </div>
    }
    else if (UseListLayout)
    {
        <div class="browse-shell__list">
            <LibraryConfigurableTable Columns="@ActiveColumns"
                                      VisibleColumnKeys="@VisibleColumnKeys"
                                      Items="@ActiveTableItems"
                                      Loading="@_loading"
                                      PosterSize="56"
                                      SelectedItems="@_selectedItems"
                                      SelectedItemsChanged="OnSelectionChanged"
                                      OnEditClicked="OpenItemEditorAsync"
                                      OnFavoriteToggled="ToggleFavoriteAsync"
                                      OnRowClicked="HandleTableRowClicked" />
        </div>
    }
    else if (_cards.Count == 0)
    {
        <div class="browse-shell__empty">
            <MudIcon Icon="@Icons.Material.Outlined.Inbox" Class="tl-u-font-size-52px tl-u-opacity-0-16" />
            <h3>@EmptyStateTitle</h3>
            <p>@EmptyStateMessage</p>
            @if (string.IsNullOrWhiteSpace(_searchText) && !IsPlaylistGrouping)
            {
                <AppButton Variant="Variant.Text"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Outlined.PendingActions"
                           Href="/settings/ingestion">
                    Open Ingestion
                </AppButton>
            }
        </div>
    }
    else if (IsTimelineGrouping)
    {
        <AppTimelineResults Items="@_cards"
                            TileSizePx="@TileSizePx"
                            YearSemantic="@CurrentTab.YearSemantic" />
    }
    else
    {
        <MediaTileGrid Items="@_cards"
                       HoverMode="@GridHoverMode"
                       HideMediaKindBadges="true"
                       HideSourceBadges="true"
                       HideGroupIndicators="true"
                       ShowCompactCaptions="true"
                       TileSizePx="@TileSizePx"
                       Class="browse-shell__grid" />
    }

    @if (_hasMore && !IsContainerGrouping)
    {
        <div class="browse-shell__load-more">
            <AppButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="LoadMoreAsync"
                       Class="browse-shell__load-more-button">
                Load more
            </AppButton>
        </div>
    }
</div>

@code {
    [Parameter] public string? Tab { get; set; }
    [Parameter, EditorRequired] public LibraryBrowsePreset Preset { get; set; } = default!;
    [Parameter] public bool Embedded { get; set; }
    [Parameter] public bool ShowTitleBlock { get; set; } = true;
    [Parameter] public bool ShowTabNavigation { get; set; } = true;

    private const int PageSize = 72;

    private readonly HashSet<Guid> _selectedItems = [];
    private readonly List<MediaTileViewModel> _cards = [];
    private readonly Dictionary<string, int> _tileSizes = new(StringComparer.OrdinalIgnoreCase);

    private string _activeTabId = string.Empty;
    private string _grouping = "all";
    private string _searchText = string.Empty;
    private int _searchInputVersion;
    private string _sortBy = "newest";
    private readonly HashSet<string> _selectedGenres = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedCreators = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _selectedYears = new(StringComparer.OrdinalIgnoreCase);
    private string _status = string.Empty;
    private DisplayBrowseFacetsDto? _facets;
    private int _totalCount;
    private readonly List<MediaTileViewModel> _continueCards = [];
    private LibraryLayoutMode _layout = LibraryLayoutMode.Card;
    private bool _loading;
    private bool _hasLoadedOnce;
    private bool _hasMore;
    private bool _navigatingInternally;
    private bool _loadFailed;
    private string? _loadError;
    private Guid? _activeProfileId;
    private bool _activeProfileResolved;

    private List<LibraryItemViewModel> _items = [];
    private List<ContentGroupViewModel> _groups = [];

    private BrowseTabPreset CurrentTab =>
        Preset.Tabs.FirstOrDefault(tab => string.Equals(tab.Id, _activeTabId, StringComparison.OrdinalIgnoreCase))
        ?? Preset.Tabs[0];

    private string RootClass =>
        $"browse-shell {(Embedded ? "browse-shell--embedded" : string.Empty)}".Trim();
    private bool ShowTabs => ShowTabNavigation && Preset.Tabs.Count > 1;
    private bool ShowHeaderRow => ShowTitleBlock || ShowTabs;
    private int ActiveBrowseTabIndex => GetSelectedIndex(Preset.Tabs.Select(tab => tab.Id), _activeTabId);
    private bool IsContainerGrouping => BrowseQueryBuilder.IsContainerGrouping(_grouping);
    private bool IsMusicTab => string.Equals(CurrentTab.MediaType, "Music", StringComparison.OrdinalIgnoreCase);
    private bool IsAudiobookTab => string.Equals(CurrentTab.MediaType, "Audiobooks", StringComparison.OrdinalIgnoreCase);
    private bool IsMusicTimelineGrouping => IsMusicTab
                                            && string.Equals(_grouping, "timeline", StringComparison.OrdinalIgnoreCase);
    private bool IsPlaylistGrouping => IsMusicTab
                                       && string.Equals(_grouping, "playlists", StringComparison.OrdinalIgnoreCase);
    private bool IsMusicSongsGrouping => IsMusicTab
                                         && _grouping is "tracks" or "songs";
    private bool IsTvShowsGrouping =>
        string.Equals(_activeTabId, "tv", StringComparison.OrdinalIgnoreCase)
        && string.Equals(_grouping, "shows", StringComparison.OrdinalIgnoreCase)
        && string.Equals(CurrentTab.MediaType, "TV", StringComparison.OrdinalIgnoreCase);
    private bool SupportsFacetFilters => true;
    private bool UseListLayout => !IsPlaylistGrouping
                                  && (_layout == LibraryLayoutMode.List || _grouping is "tracks" or "songs");
    private bool SupportsLayoutToggle => _grouping is not ("tracks" or "songs" or "playlists");
    private bool IsTimelineGrouping => string.Equals(_grouping, "timeline", StringComparison.OrdinalIgnoreCase);
    private bool IsInProgressOnly => string.Equals(_status, "in-progress", StringComparison.OrdinalIgnoreCase);
    private bool IsSecondaryQuickFilterSelected => string.Equals(_status, SecondaryQuickFilterValue, StringComparison.OrdinalIgnoreCase);
    private bool IsFinishedOnly => string.Equals(_status, "finished", StringComparison.OrdinalIgnoreCase);
    private string SecondaryQuickFilterValue => CurrentTab.MediaType == "Music" ? "favorite" : "not-started";
    private string SecondaryQuickFilterLabel => CurrentTab.MediaType switch
    {
        "Movies" or "TV" => "Unwatched",
        "Music" => "Favorites",
        "Audiobooks" => "Not started",
        _ => "Unread",
    };
    private IReadOnlyList<string> GenreFacets => _facets?.Genres ?? [];
    private IReadOnlyList<string> CreatorFacets => _facets?.Creators ?? [];
    private IReadOnlyList<string> YearFacets => _facets?.Years ?? [];
    private IReadOnlyList<string> SelectedGenres => _selectedGenres.OrderBy(value => value, StringComparer.OrdinalIgnoreCase).ToList();
    private IReadOnlyList<string> SelectedCreators => _selectedCreators.OrderBy(value => value, StringComparer.OrdinalIgnoreCase).ToList();
    private IReadOnlyList<string> SelectedYears => _selectedYears.OrderByDescending(value => value, StringComparer.OrdinalIgnoreCase).ToList();
    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_searchText)
                                     || _selectedGenres.Count > 0
                                     || _selectedCreators.Count > 0
                                     || !string.IsNullOrWhiteSpace(_status)
                                     || _selectedYears.Count > 0;
    private string CreatorFilterLabel => CurrentTab.MediaType switch
    {
        "Books" or "Comics" => "Author / creator",
        "Music" or "Audiobooks" => "Artist / author",
        "TV" => "Creator / network",
        _ => "Director / creator",
    };
    private string AllCreatorLabel => CurrentTab.MediaType switch
    {
        "Books" or "Comics" => "All authors",
        "Music" or "Audiobooks" => "All artists",
        _ => "All creators",
    };
    private string CreatorSearchPlaceholder => CurrentTab.MediaType switch
    {
        "Books" or "Comics" or "Audiobooks" => "Search authors...",
        "Music" => "Search artists...",
        "TV" => "Search creators or networks...",
        _ => "Search directors or creators...",
    };
    private string SearchPlaceholder => (CurrentTab.MediaType, _grouping) switch
    {
        ("Music", "songs" or "tracks") => "Search songs, artists, or albums...",
        ("Music", "artists") => "Search artists...",
        ("Music", "playlists") => "Search playlists...",
        ("Music", _) => "Search albums or artists...",
        ("Books", _) => "Search books or authors...",
        ("Comics", _) => "Search comics or creators...",
        ("Movies", _) => "Search movies or directors...",
        ("TV", _) => "Search TV shows or creators...",
        ("Audiobooks", _) => "Search audiobooks or authors...",
        _ => $"Search {CurrentTab.Label.ToLowerInvariant()}...",
    };
    private string ContinueTitle => Preset.HeroVariant switch
    {
        BrowseHeroVariant.Read => "Continue Reading",
        BrowseHeroVariant.Listen => "Continue Listening",
        _ => "Continue Watching",
    };
    private string ResultCountLabel => _totalCount == 1 ? "1 item" : $"{_totalCount} items";
    private IReadOnlyList<ActiveFilterChip> ActiveFilterChips =>
        [
            .. _selectedGenres.OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
                .Select(value => new ActiveFilterChip($"genre:{value}", value)),
            .. _selectedCreators.OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
                .Select(value => new ActiveFilterChip($"person:{value}", value)),
            .. _selectedYears.OrderByDescending(value => value, StringComparer.OrdinalIgnoreCase)
                .Select(value => new ActiveFilterChip($"year:{value}", value)),
            .. string.IsNullOrWhiteSpace(_status)
                ? []
                : new[] { new ActiveFilterChip("status", StatusDisplayLabel) },
        ];
    private string StatusDisplayLabel => _status switch
    {
        "in-progress" => "In progress",
        "not-started" => SecondaryQuickFilterLabel,
        "favorite" => "Favorites",
        "finished" => "Finished",
        _ => _status,
    };
    private MediaTileHoverMode GridHoverMode => MediaTileHoverMode.GlowOnly;
    private int TileSizePx => _tileSizes.TryGetValue(_activeTabId, out var size) ? size : DefaultTileSizePx;
    private int TileSizeMinPx => string.Equals(CurrentTab.MediaType, "Music", StringComparison.OrdinalIgnoreCase) ? 96 : 128;
    private int TileSizeMaxPx => string.Equals(CurrentTab.MediaType, "Music", StringComparison.OrdinalIgnoreCase) ? 208 : 248;
    private int DefaultTileSizePx => CurrentTab.MediaType switch
    {
        "Music" => 136,
        "Audiobooks" => 176,
        "Books" or "Comics" => 168,
        _ => 176,
    };
    private string EmptyStateTitle =>
        HasQualifyingFilters
            ? $"No {ActiveGroupingLabel.ToLowerInvariant()} match these filters"
            : IsContainerGrouping
                ? $"No {ActiveGroupingLabel.ToLowerInvariant()} yet"
                : $"No {CurrentTab.Label.ToLowerInvariant()} in your library yet";

    private string EmptyStateMessage =>
        HasQualifyingFilters
            ? "Remove a filter or clear all filters to broaden the results."
            : IsPlaylistGrouping
                ? "Create a playlist or smart playlist to organize music for later."
            : IsContainerGrouping
                ? $"{ActiveGroupingLabel} appear when matching library metadata is available."
                : $"Once supported {CurrentTab.Label.ToLowerInvariant()} files are ingested, they will appear here.";

    private bool HasQualifyingFilters =>
        !string.IsNullOrWhiteSpace(_searchText)
        || _selectedGenres.Count > 0
        || _selectedCreators.Count > 0
        || _selectedYears.Count > 0
        || !string.IsNullOrWhiteSpace(_status);

    private string ActiveGroupingLabel => CurrentTab.GroupingOptions
        .FirstOrDefault(option => string.Equals(option.Value, _grouping, StringComparison.OrdinalIgnoreCase))?.Label
        ?? CurrentTab.Label;

    private async Task OnBrowseTabChanged(int index)
    {
        if (index < 0 || index >= Preset.Tabs.Count)
        {
            return;
        }

        await SwitchTabAsync(Preset.Tabs[index].Id);
    }

    private string LayoutToggleClass(LibraryLayoutMode mode) =>
        $"browse-shell__layout-button {(_layout == mode ? "is-active" : string.Empty)}";

    private string GroupingChipClass(string value) =>
        $"browse-shell__grouping-button {(string.Equals(_grouping, value, StringComparison.OrdinalIgnoreCase) ? "is-active" : string.Empty)}";

    private List<LibraryColumnDef> ActiveColumns =>
        IsContainerGrouping
            ? LibraryColumnDefinitions.GetColumnsByTab(_activeTabId, _grouping)
            : LibraryColumnDefinitions.GetColumnsByTab(_activeTabId);

    private List<string> VisibleColumnKeys =>
        ActiveColumns
            .Where(column => column.DefaultVisible && !string.Equals(column.Key, "checkbox", StringComparison.OrdinalIgnoreCase))
            .Select(column => column.Key)
            .ToList();

    private List<LibraryItemViewModel> ActiveTableItems =>
        IsContainerGrouping ? BuildContainerDisplayItems() : _items;
    private IReadOnlyList<WorkViewModel> SongTracks =>
        ActiveTableItems.Select(ToSongWork).ToList();
    private IReadOnlySet<Guid> SongFavoriteIds =>
        ActiveTableItems.Where(item => item.IsFavorite).Select(item => item.EntityId).ToHashSet();

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        StateContainer.MediaAddedReceived += OnMediaAdded;
        Playback.Changed += OnPlaybackChanged;
    }

    private void OnPlaybackChanged(PlaybackChangeKind kind)
    {
        if (kind != PlaybackChangeKind.TransportTick)
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_activeProfileResolved)
        {
            _activeProfileId = (await Orchestrator.GetActiveProfileAsync())?.Id;
            _activeProfileResolved = true;
        }

        ReadUrlState();
        await LoadBrowseContentAsync();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            if (_navigatingInternally)
            {
                _navigatingInternally = false;
                return;
            }

            ReadUrlState();
            await InvokeAsync(async () =>
            {
                await LoadBrowseContentAsync();
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to handle browse route change");
        }
    }

    private void ReadUrlState()
    {
        var state = BrowseQueryBuilder.Read(Preset, Tab, Nav.Uri);
        _activeTabId = state.ActiveTabId;
        _grouping = state.Grouping;
        _layout = state.Layout;
        if (!string.Equals(_searchText, state.SearchText, StringComparison.Ordinal))
        {
            _searchInputVersion++;
        }
        _searchText = state.SearchText;
        _sortBy = state.SortBy;
        _selectedGenres.Clear();
        _selectedGenres.UnionWith(state.Genres);
        _selectedCreators.Clear();
        _selectedCreators.UnionWith(state.Creators);
        _status = state.Status;
        _selectedYears.Clear();
        _selectedYears.UnionWith(state.Years);
        if (state.TileSize is int tileSize)
        {
            _tileSizes[_activeTabId] = Math.Clamp(tileSize, TileSizeMinPx, TileSizeMaxPx);
        }

        ClearActiveGroupState();
    }

    private static string ResolveGrouping(string? requestedGrouping, BrowseTabPreset tab) =>
        BrowseQueryBuilder.ResolveGrouping(requestedGrouping, tab);

    private static LibraryLayoutMode ResolveLayout(string? requestedLayout, BrowseTabPreset tab, string grouping) =>
        BrowseQueryBuilder.ResolveLayout(requestedLayout, tab, grouping);

    private string ResolveSort(string? requestedSort) =>
        BrowseQueryBuilder.ResolveSort(requestedSort, _activeTabId, _grouping);

    private async Task LoadBrowseContentAsync(bool append = false)
    {
        _loadFailed = false;
        _loadError = null;
        _loading = true;
        if (!_hasLoadedOnce)
            StateHasChanged();

        try
        {
            if (IsPlaylistGrouping)
            {
                await LoadPlaylistsAsync();
            }
            else if (IsContainerGrouping || IsMusicTimelineGrouping)
            {
                if (IsTvShowsGrouping && !UseListLayout)
                {
                    if (!await LoadDisplayCardsAsync(append))
                    {
                        throw new InvalidOperationException("Display API did not return a TV browse page.");
                    }
                }
                else
                {
                    await LoadGroupsAsync();
                    _cards.Clear();
                    _cards.AddRange(_groups.Select(ToGroupCard));
                }
            }
            else
            {
                if (!UseListLayout)
                {
                    if (!await LoadDisplayCardsAsync(append))
                    {
                        throw new InvalidOperationException("Display API did not return a browse page.");
                    }
                }
                else
                {
                    await LoadItemsAsync(append);
                }
            }
        }
        catch (Exception ex)
        {
            _loadFailed = true;
            _loadError = ApiClient.LastError ?? ex.Message;
        }
        finally
        {
            _loading = false;
            _hasLoadedOnce = true;
        }
    }

    private Task ReloadAsync() => LoadBrowseContentAsync();

    private void OnMediaAdded(MediaAddedEvent ev)
    {
        _ = InvokeAsync(async () =>
        {
            Snackbar.Add($"Added to library: {ev.Title}", Severity.Success);
            await LoadBrowseContentAsync();
            StateHasChanged();
        });
    }

    private async Task<bool> LoadDisplayCardsAsync(bool append)
    {
        var requestedOffset = append ? _cards.Count : 0;
        var page = await ApiClient.GetDisplayBrowseAsync(
            mediaType: CurrentTab.MediaType,
            grouping: _grouping,
            search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
            offset: requestedOffset,
            limit: PageSize,
            genres: _selectedGenres.Count == 0 ? null : string.Join(',', _selectedGenres),
            creator: _selectedCreators.Count == 0 ? null : string.Join(',', _selectedCreators),
            status: string.IsNullOrWhiteSpace(_status) ? null : _status,
            year: _selectedYears.Count == 0 ? null : string.Join(',', _selectedYears),
            profileId: _activeProfileId,
            sort: _sortBy);

        if (page is null)
        {
            return false;
        }

        var incoming = SortCards(page.Catalog.Select(MediaTileComposerService.FromDisplayCard)).ToList();
        if (append)
        {
            _cards.AddRange(incoming);
            var sorted = SortCards(_cards).ToList();
            _cards.Clear();
            _cards.AddRange(sorted);
        }
        else
        {
            _cards.Clear();
            _cards.AddRange(incoming);
            _facets = page.Facets;
            _totalCount = page.TotalCount > 0 ? page.TotalCount : page.Catalog.Count;
            await LoadContinueAsync();
        }

        _items = [];
        _groups = [];
        _hasMore = page.Catalog.Count >= PageSize;
        return true;
    }

    private async Task LoadItemsAsync(bool append)
    {
        var requestedOffset = append ? _items.Count : 0;
        var response = await ApiClient.GetDisplayBrowseAsync(
            mediaType: CurrentTab.MediaType,
            grouping: _grouping,
            search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
            offset: requestedOffset,
            limit: PageSize,
            genres: _selectedGenres.Count == 0 ? null : string.Join(',', _selectedGenres),
            creator: _selectedCreators.Count == 0 ? null : string.Join(',', _selectedCreators),
            status: string.IsNullOrWhiteSpace(_status) ? null : _status,
            year: _selectedYears.Count == 0 ? null : string.Join(',', _selectedYears),
            profileId: _activeProfileId,
            sort: _sortBy);

        var incoming = response?.Catalog.Select(ToLibraryItem).ToList() ?? [];
        if (response is null && !string.IsNullOrWhiteSpace(ApiClient.LastError))
        {
            _loadFailed = true;
            _loadError = ApiClient.LastError;
            return;
        }

        if (append)
        {
            _items.AddRange(incoming);
        }
        else
        {
            _items = incoming;
            _totalCount = response?.TotalCount ?? incoming.Count;
            _facets = response?.Facets;
            await LoadContinueAsync();
        }

        _cards.Clear();
        _groups.Clear();
        _hasMore = response is not null
                   && requestedOffset + incoming.Count < response.TotalCount;
    }

    private async Task LoadContinueAsync()
    {
        var page = await ApiClient.GetDisplayContinueAsync(
            lane: Preset.Title.ToLowerInvariant(),
            mediaType: CurrentTab.MediaType,
            limit: 3);

        _continueCards.Clear();
        if (page is not null)
        {
            _continueCards.AddRange(page.Catalog
                .Select(MediaTileComposerService.FromDisplayCard)
                .Where(item => item.ProgressPct is > 0 and < 100)
                .Take(3));
        }
    }

    private async Task LoadGroupsAsync()
    {
        var systemGroupField = GetSystemViewGroupField();
        var mediaType = CurrentTab.MediaType;

        var groups = systemGroupField is not null
            ? await ApiClient.GetSystemViewGroupsAsync(mediaType, systemGroupField)
            : await ApiClient.GetContentGroupsAsync();
        if (groups.Count == 0 && !string.IsNullOrWhiteSpace(ApiClient.LastError))
        {
            _loadFailed = true;
            _loadError = ApiClient.LastError;
            return;
        }

        if (systemGroupField is null)
        {
            groups = groups
                .Where(group => MediaTypeMatches(group.PrimaryMediaType, mediaType))
                .ToList();
        }

        if (!string.IsNullOrWhiteSpace(_searchText)
            || _selectedGenres.Count > 0
            || _selectedCreators.Count > 0
            || _selectedYears.Count > 0
            || !string.IsNullOrWhiteSpace(_status))
        {
            var qualifyingPage = await ApiClient.GetDisplayBrowseAsync(
                mediaType: CurrentTab.MediaType,
                grouping: "all",
                search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
                offset: 0,
                limit: 200,
                genres: _selectedGenres.Count == 0 ? null : string.Join(',', _selectedGenres),
                creator: _selectedCreators.Count == 0 ? null : string.Join(',', _selectedCreators),
                status: string.IsNullOrWhiteSpace(_status) ? null : _status,
                year: _selectedYears.Count == 0 ? null : string.Join(',', _selectedYears),
                profileId: _activeProfileId,
                sort: _sortBy);

            if (qualifyingPage is not null)
            {
                _facets = qualifyingPage.Facets;
                groups = FilterGroupsToQualifyingCards(groups, qualifyingPage.Catalog, systemGroupField);
            }
        }

        if (_selectedCreators.Count > 0)
        {
            groups = groups.Where(group => _selectedCreators.Any(selected =>
                    string.Equals(group.Creator, selected, StringComparison.OrdinalIgnoreCase)
                    || string.Equals(group.Network, selected, StringComparison.OrdinalIgnoreCase)))
                .ToList();
        }

        if (_selectedYears.Count > 0)
        {
            groups = groups.Where(group => _selectedYears.Contains(group.Year ?? string.Empty))
                .ToList();
        }

        _groups = await SortGroupsAsync(groups);
        _totalCount = _groups.Count;
        await EnsureFacetOptionsAsync();
        await LoadContinueAsync();
        _hasMore = false;
    }

    private async Task LoadPlaylistsAsync()
    {
        var playlists = (await ApiClient.GetManagedCollectionsAsync(_activeProfileId))
            .Where(IsUserVisiblePlaylist)
            .Where(playlist => string.IsNullOrWhiteSpace(_searchText)
                               || playlist.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                               || (playlist.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false))
            .ToList();

        playlists = _sortBy switch
        {
            "title" => playlists.OrderBy(playlist => playlist.Name, StringComparer.OrdinalIgnoreCase).ToList(),
            "oldest" => playlists.OrderBy(playlist => playlist.CreatedAt).ToList(),
            _ => playlists.OrderByDescending(playlist => playlist.ModifiedAt ?? playlist.CreatedAt)
                .ThenBy(playlist => playlist.Name, StringComparer.OrdinalIgnoreCase)
                .ToList(),
        };

        _cards.Clear();
        _cards.AddRange(playlists.Select(ToPlaylistCard));
        _items = playlists.Select(playlist => new LibraryItemViewModel
        {
            EntityId = playlist.Id,
            Title = playlist.Name,
            MediaType = "Music",
            CoverUrl = playlist.SquareArtworkUrl,
            Album = playlist.TypeLabel,
            CreatedAt = playlist.CreatedAt,
        }).ToList();
        _groups = [];
        _totalCount = playlists.Count;
        _facets = null;
        _continueCards.Clear();
        _hasMore = false;
    }

    private static List<ContentGroupViewModel> FilterGroupsToQualifyingCards(
        IEnumerable<ContentGroupViewModel> groups,
        IReadOnlyList<DisplayCardDto> cards,
        string? groupField)
    {
        var workIds = cards
            .Select(card => card.WorkId)
            .Where(id => id.HasValue)
            .Select(id => id!.Value)
            .ToHashSet();
        var collectionIds = cards
            .Select(card => card.CollectionId)
            .Where(id => id.HasValue)
            .Select(id => id!.Value)
            .ToHashSet();
        var people = cards
            .Select(card => card.Subtitle)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Cast<string>()
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return groups.Where(group =>
        {
            if (groupField is "author" or "artist" or "director" or "narrator" or "network")
                return people.Contains(group.DisplayName);

            return collectionIds.Contains(group.CollectionId)
                   || group.PreviewItems.Any(item => workIds.Contains(item.WorkId));
        }).ToList();
    }

    private async Task EnsureFacetOptionsAsync()
    {
        if (!SupportsFacetFilters || _facets is not null)
        {
            return;
        }

        var facetPage = await ApiClient.GetDisplayBrowseAsync(
            mediaType: CurrentTab.MediaType,
            grouping: "all",
            offset: 0,
            limit: 1,
            profileId: _activeProfileId);
        _facets = facetPage?.Facets;
    }

    private LibraryItemViewModel ToLibraryItem(DisplayCardDto card)
    {
        var metadata = card.ListMetadata;
        var isMusic = string.Equals(card.MediaType, "Music", StringComparison.OrdinalIgnoreCase);
        var managedAssetCoverUrl = card.AssetId.HasValue
            ? ApiClient.ToAbsoluteEngineUrl($"/stream/{card.AssetId.Value:D}/cover")
            : null;
        var coverUrl = isMusic
            ? FirstValue(card.Artwork.SquareUrl, card.Artwork.SquareMediumUrl, card.Artwork.CoverUrl, card.Artwork.CoverMediumUrl, managedAssetCoverUrl)
            : FirstValue(card.Artwork.CoverUrl, card.Artwork.CoverMediumUrl, card.Artwork.SquareUrl, card.Artwork.SquareMediumUrl, managedAssetCoverUrl);
        var thumbnailUrl = isMusic
            ? FirstValue(card.Artwork.SquareSmallUrl, card.Artwork.SquareUrl, card.Artwork.CoverSmallUrl, coverUrl)
            : FirstValue(card.Artwork.CoverSmallUrl, card.Artwork.CoverUrl, card.Artwork.SquareSmallUrl, coverUrl);
        var durationSeconds = NormalizeListDurationSeconds(metadata?.Duration, isMusic);

        return new LibraryItemViewModel
        {
            EntityId = card.WorkId ?? card.Id,
            AssetId = card.AssetId,
            CollectionId = card.CollectionId,
            Title = card.Title,
            Author = metadata?.Author,
            Director = metadata?.Director,
            Artist = isMusic
                ? FirstValue(metadata?.Artist, metadata?.Author, card.Subtitle)
                : metadata?.Artist,
            Series = metadata?.Series,
            Narrator = metadata?.Narrator,
            Genre = FirstValue(metadata?.Genre, card.Genres.Count == 0 ? null : string.Join(", ", card.Genres)),
            Album = metadata?.Album,
            TrackNumber = metadata?.TrackNumber,
            Season = metadata?.SeasonNumber,
            Episode = metadata?.EpisodeNumber,
            Duration = LibraryHelpers.FormatDuration(durationSeconds, metadata?.Duration),
            DurationSeconds = durationSeconds,
            ShowName = metadata?.ShowName,
            Year = metadata?.Year,
            MediaType = card.MediaType,
            CoverUrl = coverUrl,
            CoverThumbUrl = thumbnailUrl,
            BackgroundUrl = FirstValue(card.Artwork.BackgroundUrl, card.Artwork.BackgroundMediumUrl),
            BannerUrl = FirstValue(card.Artwork.BannerUrl, card.Artwork.BannerMediumUrl),
            CreatedAt = card.SortTimestamp,
            LastPlayedAt = metadata?.LastPlayedAt ?? card.Progress?.LastAccessed,
            PlayCount = metadata?.PlayCount,
            IsFavorite = card.Flags.IsFavorite,
            Status = "Ready",
            IsReadyForLibrary = true,
            LibraryVisibility = "visible",
            ArtworkState = string.IsNullOrWhiteSpace(coverUrl) ? "missing" : "settled",
        };
    }

    private static WorkViewModel ToSongWork(LibraryItemViewModel item)
    {
        var values = new List<CanonicalValueViewModel>();

        AddCanonical(values, "title", item.Title);
        AddCanonical(values, "artist", item.Artist ?? item.Author);
        AddCanonical(values, "album", item.Album);
        AddCanonical(values, "genre", item.Genre);
        AddCanonical(values, "track_number", item.TrackNumber);
        AddCanonical(values, "release_year", item.Year);
        AddCanonical(values, "duration_seconds", item.DurationSeconds?.ToString(System.Globalization.CultureInfo.InvariantCulture));
        AddCanonical(values, "play_count", item.PlayCount?.ToString(System.Globalization.CultureInfo.InvariantCulture));

        return new WorkViewModel
        {
            Id = item.EntityId,
            AssetId = item.AssetId,
            CollectionId = item.CollectionId,
            MediaType = "Music",
            CreatedAt = item.CreatedAt,
            ResolvedCoverUrl = item.CoverUrl,
            CanonicalValues = values,
        };
    }

    private static void AddCanonical(List<CanonicalValueViewModel> values, string key, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            values.Add(new CanonicalValueViewModel { Key = key, Value = value });
        }
    }

    private static long? NormalizeListDurationSeconds(string? value, bool isMusic)
    {
        if (isMusic
            && !string.IsNullOrWhiteSpace(value)
            && !value.Contains(':', StringComparison.Ordinal)
            && double.TryParse(
                value,
                System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture,
                out var rawDuration)
            && rawDuration >= 10_000)
        {
            return Math.Max(0, (long)Math.Round(rawDuration / 1000d, MidpointRounding.AwayFromZero));
        }

        return LibraryHelpers.NormalizeDurationSeconds(value);
    }

    private static string? FirstValue(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private List<LibraryItemViewModel> SortItems(IEnumerable<LibraryItemViewModel> source)
    {
        return _sortBy switch
        {
            "title" => source.OrderBy(item => item.Title, StringComparer.OrdinalIgnoreCase).ToList(),
            "oldest" => source.OrderBy(item => item.CreatedAt).ToList(),
            "creator" => source.OrderBy(item => item.Creator ?? item.ContextLabel ?? item.Title, StringComparer.OrdinalIgnoreCase).ToList(),
            "year" => source.OrderByDescending(item => ParseYear(item.Year)).ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase).ToList(),
            _ => source.OrderByDescending(item => item.CreatedAt).ToList(),
        };
    }

    private async Task<List<ContentGroupViewModel>> SortGroupsAsync(IEnumerable<ContentGroupViewModel> source)
    {
        if (IsMusicTab
            && string.Equals(_grouping, "albums", StringComparison.OrdinalIgnoreCase)
            && string.Equals(_sortBy, "recently-played", StringComparison.OrdinalIgnoreCase))
        {
            var recent = await ApiClient.GetDisplayContinueAsync(
                lane: "listen",
                mediaType: "Music",
                limit: 200);
            var recentOrder = (recent?.Catalog ?? [])
                .Where(card => card.CollectionId.HasValue)
                .GroupBy(card => card.CollectionId!.Value)
                .ToDictionary(
                    group => group.Key,
                    group => group.Max(card => card.SortTimestamp));
            return source
                .Where(group => recentOrder.ContainsKey(group.CollectionId))
                .OrderByDescending(group => recentOrder[group.CollectionId])
                .ThenBy(group => group.DisplayName, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }

        return _sortBy switch
        {
            "title" => source.OrderBy(group => group.DisplayName, StringComparer.OrdinalIgnoreCase).ToList(),
            "newest" => source.OrderByDescending(group => group.CreatedAt).ThenBy(group => group.DisplayName, StringComparer.OrdinalIgnoreCase).ToList(),
            "creator" => source.OrderBy(group => group.Creator ?? group.DisplayName, StringComparer.OrdinalIgnoreCase).ToList(),
            "year" => source.OrderByDescending(group => ParseYear(group.Year))
                .ThenBy(group => group.DisplayName, StringComparer.OrdinalIgnoreCase)
                .ToList(),
            _ => source.OrderByDescending(group => group.WorkCount).ThenBy(group => group.DisplayName, StringComparer.OrdinalIgnoreCase).ToList(),
        };
    }

    private IEnumerable<MediaTileViewModel> SortCards(IEnumerable<MediaTileViewModel> source)
    {
        return _sortBy switch
        {
            "title" => source.OrderBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            "oldest" => source.OrderBy(card => card.SortTimestamp),
            "creator" => source.OrderBy(card => card.Creator ?? card.Subtitle ?? card.Title, StringComparer.OrdinalIgnoreCase),
            "year" => source.OrderByDescending(card => card.SortYear).ThenBy(card => card.Title, StringComparer.OrdinalIgnoreCase),
            _ => source.OrderByDescending(card => card.SortTimestamp),
        };
    }

    private MediaTileViewModel ToGroupCard(ContentGroupViewModel group)
    {
        if (IsPersonGrouping)
        {
            return ToPersonGroupCard(group);
        }

        var presentation = (_activeTabId, _grouping) switch
        {
            ("tv", "shows") => "tvSeries",
            ("movies", "series") => "movieSeries",
            ("books", "series") => "bookSeries",
            ("comics", "series") => "comicSeries",
            ("audiobooks", "series") => "audiobookSeries",
            ("music", "albums" or "timeline") => "album",
            ("music", "artists") => "artist",
            _ => "default",
        };

        var wideArtwork = BrowseArtworkRules.ResolveWideArtwork(group.BackgroundUrl, group.BannerUrl);
        var navigationUrl = BuildGroupNavigationUrl(group);
        var displayMediaType = FormatMediaLabel(group.PrimaryMediaType);
        var coverUrl = string.Equals(presentation, "artist", StringComparison.OrdinalIgnoreCase)
            ? group.ArtistPhotoUrl
            : group.CoverUrl;
        var coverSmallUrl = MediaTileArtworkUrl.Sized(coverUrl, "s");
        var coverMediumUrl = MediaTileArtworkUrl.Sized(coverUrl, "m");
        var coverLargeUrl = MediaTileArtworkUrl.Sized(coverUrl, "l");
        var artistSmallUrl = MediaTileArtworkUrl.Sized(group.ArtistPhotoUrl, "s");
        var artistMediumUrl = MediaTileArtworkUrl.Sized(group.ArtistPhotoUrl, "m");
        var artistLargeUrl = MediaTileArtworkUrl.Sized(group.ArtistPhotoUrl, "l");
        var bannerSmallUrl = MediaTileArtworkUrl.Sized(group.BannerUrl, "s");
        var bannerMediumUrl = MediaTileArtworkUrl.Sized(group.BannerUrl, "m");
        var bannerLargeUrl = MediaTileArtworkUrl.Sized(group.BannerUrl, "l");
        var backgroundSmallUrl = MediaTileArtworkUrl.Sized(wideArtwork, "s");
        var backgroundMediumUrl = MediaTileArtworkUrl.Sized(wideArtwork, "m");
        var backgroundLargeUrl = MediaTileArtworkUrl.Sized(wideArtwork, "l");
        var card = new DisplayCardDto(
            Id: GetGroupNavigationId(group),
            WorkId: null,
            AssetId: null,
            CollectionId: group.CollectionId,
            MediaType: displayMediaType,
            GroupingType: string.Equals(presentation, "default", StringComparison.OrdinalIgnoreCase) ? "collection" : presentation,
            Title: group.DisplayName,
            Subtitle: group.Creator ?? group.Network,
            Facts: BrowseArtworkRules.CompactFacts(group.Year, GroupCountLabel(group)),
            Artwork: new DisplayArtworkDto(coverUrl, coverSmallUrl, coverMediumUrl, coverLargeUrl, group.ArtistPhotoUrl, artistSmallUrl, artistMediumUrl, artistLargeUrl, group.BannerUrl, bannerSmallUrl, bannerMediumUrl, bannerLargeUrl, wideArtwork, backgroundSmallUrl, backgroundMediumUrl, backgroundLargeUrl, group.LogoUrl, group.CoverWidthPx, group.CoverHeightPx, group.SquareWidthPx, group.SquareHeightPx, group.BannerWidthPx, group.BannerHeightPx, group.BackgroundWidthPx, group.BackgroundHeightPx, group.MediaTypeColor ?? AccentForMedia(group.PrimaryMediaType)),
            PreferredShape: BrowseArtworkRules.PreferredDisplayShape(group.PrimaryMediaType, wideArtwork, group.ArtistPhotoUrl),
            Presentation: presentation,
            TileTextMode: "caption",
            PreviewPlacement: "smart",
            Progress: null,
            Actions: [new DisplayActionDto("openCollection", "Explore", null, null, group.CollectionId, navigationUrl)],
            Flags: new DisplayCardFlagsDto(IsPlayableMedia(group.PrimaryMediaType), IsReadMedia(group.PrimaryMediaType), false, true, false),
            SortTimestamp: group.CreatedAt)
        {
            PreviewItems = group.PreviewItems
                .Select(item => new DisplayCardPreviewItemDto(
                    item.WorkId,
                    null,
                    item.Title,
                    item.ImageUrl,
                    item.Shape,
                    item.Position,
                    group.PrimaryMediaType,
                    BuildGroupPreviewNavigationUrl(group, item.WorkId),
                    item.Description,
                    item.Facts))
                .ToList(),
            PreviewTotalCount = group.WorkCount,
            GroupSummary = new DisplayGroupSummaryDto
            {
                OwnedCount = group.WorkCount,
                EarliestYear = group.EarliestYear,
                LatestYear = group.LatestYear,
                MediaCounts = [new DisplayGroupMediaCountDto(displayMediaType, group.WorkCount)],
            },
        };

        return WithCardOverrides(
            MediaTileComposerService.FromDisplayCard(card),
            description: BuildGroupDescription(group),
            heroUrl: null,
            previewImages: BuildGroupPreviewImages(group, wideArtwork, presentation),
            creator: group.Creator,
            collectionKey: group.DisplayName,
            sortYear: group.LatestYear ?? group.EarliestYear ?? ParseYear(group.Year));
    }

    private static IReadOnlyList<string> BuildGroupPreviewImages(ContentGroupViewModel group, string? wideArtwork, string presentation)
    {
        IEnumerable<string?> candidates = string.Equals(presentation, "artist", StringComparison.OrdinalIgnoreCase)
            ? new[] { group.ArtistPhotoUrl, group.CoverUrl, group.BannerUrl, group.BackgroundUrl }
            : new[] { wideArtwork, group.BannerUrl, group.BackgroundUrl, group.CoverUrl };

        return candidates
            .Select(value => MediaTileArtworkUrl.Sized(value, "s") ?? value)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Cast<string>()
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(5)
            .ToList();
    }

    private static string GroupCountLabel(ContentGroupViewModel group)
    {
        if (string.Equals(group.PrimaryMediaType, "TV", StringComparison.OrdinalIgnoreCase)
            && group.SeasonCount is int seasonCount
            && seasonCount > 0)
        {
            return seasonCount == 1 ? "1 season" : $"{seasonCount} seasons";
        }

        var noun = group.PrimaryMediaType switch
        {
            "Comic" => group.WorkCount == 1 ? "issue" : "issues",
            "Music" => group.WorkCount == 1 ? "track" : "tracks",
            _ => group.WorkCount == 1 ? "title" : "titles",
        };

        return $"{group.WorkCount} {noun}";
    }

    private List<LibraryItemViewModel> BuildContainerDisplayItems()
    {
        var isSystemGroup = GetSystemViewGroupField() is not null;
        return _groups.Select(group => new LibraryItemViewModel
        {
            EntityId = isSystemGroup ? GenerateDeterministicGuid(group.DisplayName) : group.CollectionId,
            Title = group.DisplayName,
            MediaType = group.PrimaryMediaType,
            CoverUrl = group.ArtistPhotoUrl ?? group.CoverUrl,
            ArtistPhotoUrl = group.ArtistPhotoUrl,
            BackgroundUrl = group.BackgroundUrl,
            BannerUrl = group.BannerUrl,
            Author = group.Creator,
            Artist = group.Creator,
            Network = group.Network,
            Year = group.Year,
            SeasonCount = group.SeasonCount?.ToString(),
            AlbumCount = group.AlbumCount?.ToString(),
            TrackCount = group.WorkCount.ToString(),
        }).ToList();
    }

    private async Task SwitchTabAsync(string tabId)
    {
        if (string.Equals(_activeTabId, tabId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _activeTabId = tabId;
        var tab = CurrentTab;
        _grouping = tab.DefaultGrouping;
        _layout = ResolveLayout(null, tab, _grouping);
        _sortBy = ResolveSort(null);
        _searchText = string.Empty;
        _selectedGenres.Clear();
        _selectedCreators.Clear();
        _status = string.Empty;
        _selectedYears.Clear();
        ClearActiveGroupState();
        await NavigateAndReloadAsync();
    }

    private async Task SwitchGroupingAsync(string grouping)
    {
        if (string.Equals(_grouping, grouping, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _grouping = grouping;
        _layout = ResolveLayout(null, CurrentTab, _grouping);
        _sortBy = ResolveSort(null);
        ClearActiveGroupState();
        await NavigateAndReloadAsync();
    }

    private async Task SwitchLayoutAsync(LibraryLayoutMode layout)
    {
        if (_layout == layout || !SupportsLayoutToggle)
        {
            return;
        }

        _layout = layout;
        _selectedItems.Clear();
        await NavigateAndReloadAsync(reloadData: true);
    }

    private void OnTileSizeChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var requestedSize))
        {
            _tileSizes[_activeTabId] = Math.Clamp(requestedSize, TileSizeMinPx, TileSizeMaxPx);
            _ = NavigateAndReloadAsync(reloadData: false, replace: true);
        }
    }

    private async Task OnSearchChanged(string _)
    {
        ClearActiveGroupState();
