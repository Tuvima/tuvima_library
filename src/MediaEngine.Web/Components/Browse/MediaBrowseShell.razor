    private async Task OpenPlaylistBuilderAsync(bool smart)
    {
        var activeProfile = await Orchestrator.GetActiveProfileAsync();
        if (activeProfile is null)
        {
            Snackbar.Add("Choose an active profile before creating a playlist.", Severity.Warning);
            return;
        }

        var changed = await CollectionEditorLauncher.OpenAsync(new CollectionEditorLaunchRequest
        {
            ActiveProfileId = activeProfile.Id,
            CanManageSharedCollections = activeProfile.Role is "Administrator" or "Curator",
            Mode = smart ? "SmartPlaylist" : "Playlist",
            InitialCollectionType = smart ? "Smart" : "Playlist",
            InitialRulesEnabled = smart,
            InitialTitle = string.Empty,
        });

        if (changed)
        {
            await LoadBrowseContentAsync();
        }
    }

    private async Task RemoveFilterAsync(string key)
    {
        if (key.StartsWith("genre:", StringComparison.Ordinal))
            _selectedGenres.Remove(key[6..]);
        else if (key.StartsWith("person:", StringComparison.Ordinal))
            _selectedCreators.Remove(key[7..]);
        else if (key.StartsWith("year:", StringComparison.Ordinal))
            _selectedYears.Remove(key[5..]);
        else if (key == "status")
            _status = string.Empty;

        await NavigateAndReloadAsync();
    }

