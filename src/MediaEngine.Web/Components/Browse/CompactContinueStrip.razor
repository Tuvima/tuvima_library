@namespace MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Models.ViewDTOs

@if (Items.Count > 0)
{
    <section class="compact-continue" aria-label="@Title">
        <div class="compact-continue__heading">
            <MudIcon Icon="@Icon" />
            <div>
                <strong>@Title</strong>
                <span>@ItemCountLabel</span>
            </div>
        </div>

        <div class="compact-continue__items">
            @foreach (var item in Items.Take(3))
            {
                <a @key="item.Id" class="compact-continue__item" href="@ContinueUrl(item)">
                    <div class="compact-continue__art">
                        @if (!string.IsNullOrWhiteSpace(ArtworkUrl(item)))
                        {
                            <img src="@ArtworkUrl(item)" alt="" loading="lazy" decoding="async" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icon" />
                        }
                    </div>
                    <div class="compact-continue__copy">
                        <strong>@item.Title</strong>
                        @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                        {
                            <span>@item.Subtitle</span>
                        }
                        <div class="compact-continue__progress" aria-label="@ProgressLabel(item)">
                            <AppCssElement Tag="span" Css="@ProgressStyle(item)" />
                        </div>
                    </div>
                    <span class="compact-continue__percent">@Percent(item)</span>
                </a>
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "Continue";
    [Parameter, EditorRequired] public IReadOnlyList<MediaTileViewModel> Items { get; set; } = [];

    private string ItemCountLabel => Items.Count == 1 ? "1 item" : $"{Items.Count} items";

    private string Icon => Title.Contains("Read", StringComparison.OrdinalIgnoreCase)
        ? Icons.Material.Outlined.MenuBook
        : Title.Contains("Listen", StringComparison.OrdinalIgnoreCase)
            ? Icons.Material.Outlined.Headphones
            : Icons.Material.Outlined.PlayCircle;

    private static string? ArtworkUrl(MediaTileViewModel item) =>
        item.TileImageUrl ?? item.CoverUrl ?? item.PreviewImageUrl;

    private static string ContinueUrl(MediaTileViewModel item) =>
        item.PrimaryNavigationUrl ?? item.NavigationUrl;

    private static int Percent(MediaTileViewModel item) =>
        (int)Math.Round(Math.Clamp(item.ProgressPct ?? 0, 0, 100));

    private static string ProgressStyle(MediaTileViewModel item) =>
        $"width: {Percent(item).ToString(System.Globalization.CultureInfo.InvariantCulture)}%;";

    private static string ProgressLabel(MediaTileViewModel item) =>
        $"{Percent(item)} percent complete";
}
