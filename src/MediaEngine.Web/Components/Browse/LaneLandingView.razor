@namespace MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Components.Discovery
@using MediaEngine.Web.Components.MediaTiles
@using MediaEngine.Web.Components.Universe
@using MediaEngine.Web.Models.ViewDTOs

<GlobalBackground Color="#05070C" />

<section class="lane-landing">
    <div class="lane-landing__hero">
        @if (Page.Spotlights.Count > 1)
        {
            <DiscoverySpotlightCarousel Items="@Page.Spotlights" AriaLabel="@($"{Title} spotlight")" />
        }
        else if (Page.Hero is not null)
        {
            <DiscoveryHero Hero="@Page.Hero" />
        }
    </div>

    <div class="lane-landing__content-shell">
        <div class="lane-landing__header">
            <div class="lane-landing__copy">
                <div class="lane-landing__eyebrow">@Title</div>
                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <p>@Subtitle</p>
                }
            </div>

            <AppButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.GridView"
                       Href="@BrowseAllRoute"
                       Class="lane-landing__browse-button">
                Browse all
            </AppButton>
        </div>

        <div class="lane-landing__shelves">
            @foreach (var shelf in Page.Shelves)
            {
                <MediaTileShelf Shelf="@shelf" />
            }
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public DiscoveryPageViewModel Page { get; set; } = default!;
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter, EditorRequired] public string BrowseAllRoute { get; set; } = "/";
}
