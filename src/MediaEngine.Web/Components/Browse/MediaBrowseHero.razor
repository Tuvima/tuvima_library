@namespace MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Models.ViewDTOs

@inject NavigationManager Nav

@if (Hero is not null)
{
    <section class="browse-hero browse-hero--@Hero.Variant.ToString().ToLowerInvariant()">
        @if (!string.IsNullOrWhiteSpace(Hero.BackgroundUrl))
        {
            <div class="browse-hero__background">
                <img src="@Hero.BackgroundUrl" alt="" />
            </div>
        }
        <div class="browse-hero__overlay"></div>
        <div class="browse-hero__sheen"></div>

        <div class="browse-hero__inner">
            @if (Hero.Variant == BrowseHeroVariant.Listen)
            {
                <div class="browse-hero__art browse-hero__art--square">
                    @RenderCover()
                </div>
                <div class="browse-hero__copy browse-hero__copy--listen">
                    @RenderCopy()
                </div>
            }
            else if (Hero.Variant == BrowseHeroVariant.Read)
            {
                <div class="browse-hero__art browse-hero__art--portrait">
                    @RenderCover()
                </div>
                <div class="browse-hero__copy browse-hero__copy--read">
                    @RenderCopy()
                </div>
            }
            else
            {
                <div class="browse-hero__copy browse-hero__copy--watch">
                    @RenderCopy()
                </div>
                <div class="browse-hero__art browse-hero__art--watch">
                    @RenderCover()
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter] public BrowseHeroViewModel? Hero { get; set; }

    private RenderFragment RenderCopy() => @<div>
        <div class="browse-hero__eyebrow">@Hero!.Eyebrow</div>
        <h1 class="browse-hero__title">@Hero.Title</h1>

        @if (!string.IsNullOrWhiteSpace(Hero.Subtitle))
        {
            <div class="browse-hero__subtitle">@Hero.Subtitle</div>
        }

        @if (!string.IsNullOrWhiteSpace(Hero.MetaLine))
        {
            <div class="browse-hero__meta">@Hero.MetaLine</div>
        }

        @if (!string.IsNullOrWhiteSpace(Hero.Description))
        {
            <p class="browse-hero__description">@Hero.Description</p>
        }

        @if (!string.IsNullOrWhiteSpace(Hero.SupportingLine))
        {
            <div class="browse-hero__supporting">@Hero.SupportingLine</div>
        }

        @if (Hero.ProgressPct is > 0)
        {
            <div class="browse-hero__progress-wrap">
                <div class="browse-hero__progress-track">
                    <div class="browse-hero__progress-fill" style="width: @($"{Math.Clamp(Hero.ProgressPct.Value, 0, 100):F0}%");"></div>
                </div>
                <div class="browse-hero__progress-label">@($"{Math.Clamp(Hero.ProgressPct.Value, 0, 100):F0}% complete")</div>
            </div>
        }

        <div class="browse-hero__actions">
            <button type="button" class="browse-hero__button browse-hero__button--primary" @onclick="OpenPrimary">
                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Style="font-size: 18px;" />
                <span>@Hero.PrimaryActionLabel</span>
            </button>
            @if (!string.IsNullOrWhiteSpace(Hero.SecondaryNavigationUrl))
            {
                <button type="button" class="browse-hero__button browse-hero__button--secondary" @onclick="OpenSecondary">
                    <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="font-size: 18px;" />
                    <span>@(Hero.SecondaryActionLabel ?? "Details")</span>
                </button>
            }
        </div>
    </div>;

    private RenderFragment RenderCover() => @<div class="browse-hero__cover-frame" style="@($"--browse-hero-cover-aspect: {Hero?.CoverAspectRatioCss ?? "2 / 3"};")">
        @if (!string.IsNullOrWhiteSpace(Hero?.CoverUrl))
        {
            <img src="@Hero.CoverUrl" alt="@Hero.Title" class="browse-hero__cover" />
        }
        else
        {
            <div class="browse-hero__cover-placeholder">
                <MudIcon Icon="@GetFallbackIcon()" Style="font-size: 46px; opacity: 0.22;" />
            </div>
        }
    </div>;

    private void OpenPrimary()
    {
        if (!string.IsNullOrWhiteSpace(Hero?.PrimaryNavigationUrl))
        {
            Nav.NavigateTo(Hero.PrimaryNavigationUrl);
        }
    }

    private void OpenSecondary()
    {
        if (!string.IsNullOrWhiteSpace(Hero?.SecondaryNavigationUrl))
        {
            Nav.NavigateTo(Hero.SecondaryNavigationUrl!);
        }
    }

    private string GetFallbackIcon() => Hero?.Variant switch
    {
        BrowseHeroVariant.Listen => Icons.Material.Outlined.Album,
        BrowseHeroVariant.Watch => Icons.Material.Outlined.Movie,
        _ => Icons.Material.Outlined.MenuBook,
    };
}

<style>
    .browse-hero {
        position: relative;
        overflow: hidden;
        border-radius: var(--tl-radius-xl);
        min-height: 380px;
        margin: 0 0 24px;
        background:
            radial-gradient(circle at top right, var(--tl-accent-primary-soft), transparent 34%),
            var(--tl-gradient-surface);
        border: 1px solid var(--tl-border-subtle);
        box-shadow: var(--tl-shadow-raised);
    }

    .browse-hero__background,
    .browse-hero__background img,
    .browse-hero__overlay,
    .browse-hero__sheen {
        position: absolute;
        inset: 0;
    }

    .browse-hero__background img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transform: scale(1.04);
        filter: saturate(0.95);
    }

    .browse-hero__overlay {
        background:
            linear-gradient(90deg, rgba(7, 10, 18, 0.92) 0%, rgba(7, 10, 18, 0.72) 36%, rgba(7, 10, 18, 0.36) 70%, rgba(7, 10, 18, 0.85) 100%);
    }

    .browse-hero__sheen {
        background: linear-gradient(180deg, rgba(245, 247, 251, 0.03), transparent 34%);
        pointer-events: none;
    }

    .browse-hero--listen .browse-hero__overlay {
        background:
            linear-gradient(135deg, rgba(7, 10, 18, 0.94) 0%, rgba(7, 10, 18, 0.82) 32%, rgba(7, 10, 18, 0.66) 100%),
            radial-gradient(circle at 18% 20%, var(--tl-accent-primary-soft), transparent 32%),
            radial-gradient(circle at 88% 26%, var(--tl-accent-secondary-soft), transparent 28%);
    }

    .browse-hero--read .browse-hero__overlay {
        background:
            linear-gradient(90deg, rgba(7, 10, 18, 0.90) 0%, rgba(7, 10, 18, 0.78) 44%, rgba(7, 10, 18, 0.64) 100%),
            radial-gradient(circle at 12% 22%, var(--tl-accent-primary-soft), transparent 28%);
    }

    .browse-hero__inner {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 28px;
        align-items: center;
        min-height: 380px;
        padding: 34px 38px;
    }

    .browse-hero--listen .browse-hero__inner,
    .browse-hero--read .browse-hero__inner {
        grid-template-columns: auto minmax(0, 1fr);
    }

    .browse-hero__copy {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-width: 760px;
    }

    .browse-hero__eyebrow {
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--tl-text-secondary);
    }

    .browse-hero__title {
        margin: 0;
        font-size: clamp(2.4rem, 5vw, 4.7rem);
        line-height: 0.94;
        letter-spacing: -0.04em;
        color: var(--tl-text-primary);
        font-weight: 900;
    }

    .browse-hero--listen .browse-hero__title {
        font-size: clamp(2.2rem, 4.2vw, 4rem);
        line-height: 0.98;
    }

    .browse-hero--read .browse-hero__title {
        font-size: clamp(2.1rem, 3.8vw, 3.4rem);
    }

    .browse-hero__subtitle {
        font-size: 1rem;
        font-weight: 700;
        color: var(--tl-text-secondary);
    }

    .browse-hero__meta,
    .browse-hero__supporting,
    .browse-hero__progress-label {
        font-size: 0.86rem;
        color: var(--tl-text-muted);
    }

    .browse-hero__description {
        margin: 4px 0 0;
        max-width: 60ch;
        font-size: 0.95rem;
        line-height: 1.65;
        color: var(--tl-text-secondary);
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 4;
        overflow: hidden;
    }

    .browse-hero__progress-wrap {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: 4px;
        max-width: 320px;
    }

    .browse-hero__progress-track {
        height: 6px;
        border-radius: var(--app-radius-sm);
        overflow: hidden;
        background: var(--tl-bg-surface-raised);
    }

    .browse-hero__progress-fill {
        height: 100%;
        border-radius: inherit;
        background: var(--tl-gradient-primary);
    }

    .browse-hero__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 8px;
    }

    .browse-hero__button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 46px;
        padding: 0 18px;
        border: 0;
        border-radius: var(--app-radius-md);
        font-size: 0.9rem;
        font-weight: 800;
        cursor: pointer;
        transition: transform 0.16s ease, opacity 0.16s ease, background 0.16s ease;
    }

    .browse-hero__button:hover {
        transform: translateY(-1px);
    }

    .browse-hero__button--primary {
        background: var(--tl-gradient-primary);
        color: var(--tl-text-on-accent);
    }

    .browse-hero__button--secondary {
        background: var(--tl-bg-surface-raised);
        color: var(--tl-text-primary);
        border: 1px solid var(--tl-border-default);
    }

    .browse-hero__art {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .browse-hero__cover-frame {
        overflow: hidden;
        border-radius: var(--app-radius-md);
        border: 1px solid var(--tl-border-default);
        box-shadow: var(--tl-shadow-md);
        background: var(--tl-bg-surface-raised);
    }

    .browse-hero__art--watch .browse-hero__cover-frame,
    .browse-hero__art--portrait .browse-hero__cover-frame {
        width: clamp(188px, 20vw, 270px);
        aspect-ratio: var(--browse-hero-cover-aspect, 2 / 3);
    }

    .browse-hero__art--square .browse-hero__cover-frame {
        width: clamp(196px, 24vw, 280px);
        aspect-ratio: var(--browse-hero-cover-aspect, 1 / 1);
    }

    .browse-hero__cover,
    .browse-hero__cover-placeholder {
        width: 100%;
        height: 100%;
    }

    .browse-hero__cover {
        display: block;
        object-fit: cover;
    }

    .browse-hero__cover-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--tl-gradient-surface);
        color: var(--tl-text-muted);
    }

    @@media (max-width: 900px) {
        .browse-hero__inner,
        .browse-hero--listen .browse-hero__inner,
        .browse-hero--read .browse-hero__inner {
            grid-template-columns: 1fr;
            justify-items: start;
            padding: 28px 24px;
        }

        .browse-hero {
            min-height: unset;
        }

        .browse-hero__copy {
            order: 2;
        }

        .browse-hero__art {
            order: 1;
        }

        .browse-hero__description {
            -webkit-line-clamp: 5;
        }
    }
</style>
