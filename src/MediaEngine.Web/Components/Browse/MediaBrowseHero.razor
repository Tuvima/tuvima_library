@namespace MediaEngine.Web.Components.Browse
@using MediaEngine.Web.Models.ViewDTOs

@inject NavigationManager Nav

@if (Hero is not null)
{
    <section class="browse-hero browse-hero--@Hero.Variant.ToString().ToLowerInvariant()">
        @if (!string.IsNullOrWhiteSpace(Hero.BackgroundUrl))
        {
            <div class="browse-hero__background">
                <img src="@Hero.BackgroundUrl" alt="" />
            </div>
        }
        <div class="browse-hero__overlay"></div>
        <div class="browse-hero__sheen"></div>

        <div class="browse-hero__inner">
            @if (Hero.Variant == BrowseHeroVariant.Listen)
            {
                <div class="browse-hero__art browse-hero__art--square">
                    @RenderCover()
                </div>
                <div class="browse-hero__copy browse-hero__copy--listen">
                    @RenderCopy()
                </div>
            }
            else if (Hero.Variant == BrowseHeroVariant.Read)
            {
                <div class="browse-hero__art browse-hero__art--portrait">
                    @RenderCover()
                </div>
                <div class="browse-hero__copy browse-hero__copy--read">
                    @RenderCopy()
                </div>
            }
            else
            {
                <div class="browse-hero__copy browse-hero__copy--watch">
                    @RenderCopy()
                </div>
                <div class="browse-hero__art browse-hero__art--watch">
                    @RenderCover()
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter] public BrowseHeroViewModel? Hero { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }

    private RenderFragment RenderCopy() => @<div>
        <div class="browse-hero__eyebrow">@Hero!.Eyebrow</div>
        <h1 class="browse-hero__title">@Hero.Title</h1>

        @if (!string.IsNullOrWhiteSpace(Hero.Subtitle))
        {
            <div class="browse-hero__subtitle">@Hero.Subtitle</div>
        }

        @if (!string.IsNullOrWhiteSpace(Hero.MetaLine))
        {
            <div class="browse-hero__meta">@Hero.MetaLine</div>
        }

        @if (!string.IsNullOrWhiteSpace(Hero.Description))
        {
            <p class="browse-hero__description">@Hero.Description</p>
        }

        @if (!string.IsNullOrWhiteSpace(Hero.SupportingLine))
        {
            <div class="browse-hero__supporting">@Hero.SupportingLine</div>
        }

        @if (Hero.ProgressPct is > 0)
        {
            <div class="browse-hero__progress-wrap">
                <div class="browse-hero__progress-track">
                    <div class="browse-hero__progress-fill" style="width: @($"{Math.Clamp(Hero.ProgressPct.Value, 0, 100):F0}%");"></div>
                </div>
                <div class="browse-hero__progress-label">@($"{Math.Clamp(Hero.ProgressPct.Value, 0, 100):F0}% complete")</div>
            </div>
        }

        <div class="browse-hero__actions">
            <AppNativeButton Type="button" Class="browse-hero__button browse-hero__button--primary" OnClick="OpenPrimary">
                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Style="font-size: 18px;" />
                <span>@Hero.PrimaryActionLabel</span>
            </AppNativeButton>
            @if (!string.IsNullOrWhiteSpace(Hero.SecondaryNavigationUrl))
            {
                <AppNativeButton Type="button" Class="browse-hero__button browse-hero__button--secondary" OnClick="OpenSecondary">
                    <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="font-size: 18px;" />
                    <span>@(Hero.SecondaryActionLabel ?? "Details")</span>
                </AppNativeButton>
            }
        </div>

        @if (FooterContent is not null)
        {
            @FooterContent
        }
    </div>;

    private RenderFragment RenderCover() => @<div class="browse-hero__cover-frame" style="@($"--browse-hero-cover-aspect: {Hero?.CoverAspectRatioCss ?? "2 / 3"};")">
        @if (!string.IsNullOrWhiteSpace(Hero?.CoverUrl))
        {
            <img src="@Hero.CoverUrl" alt="@Hero.Title" class="browse-hero__cover" />
        }
        else
        {
            <div class="browse-hero__cover-placeholder">
                <MudIcon Icon="@GetFallbackIcon()" Style="font-size: 46px; opacity: 0.22;" />
            </div>
        }
    </div>;

    private void OpenPrimary()
    {
        if (!string.IsNullOrWhiteSpace(Hero?.PrimaryNavigationUrl))
        {
            Nav.NavigateTo(Hero.PrimaryNavigationUrl);
        }
    }

    private void OpenSecondary()
    {
        if (!string.IsNullOrWhiteSpace(Hero?.SecondaryNavigationUrl))
        {
            Nav.NavigateTo(Hero.SecondaryNavigationUrl!);
        }
    }

    private string GetFallbackIcon() => Hero?.Variant switch
    {
        BrowseHeroVariant.Listen => Icons.Material.Outlined.Album,
        BrowseHeroVariant.Watch => Icons.Material.Outlined.Movie,
        _ => Icons.Material.Outlined.MenuBook,
    };
}