@using MediaEngine.Web.Components.Registry

<div class="sidebar-item @(IsSelected ? "sidebar-item--selected" : "")"
     @onclick="OnClick">
    @if (!string.IsNullOrEmpty(Item.CoverUrl))
    {
        <img src="@Item.CoverUrl" alt="" class="sidebar-item-cover" loading="lazy" />
    }
    else
    {
        <div class="sidebar-item-cover-placeholder">
            <MudIcon Icon="@RegistryHelpers.GetMediaTypeIcon(Item.MediaType)" Size="Size.Small"
                     Style="opacity: 0.3;" />
        </div>
    }
    <div class="sidebar-item-text">
        <span class="sidebar-item-title">@Item.Title</span>
        <span class="sidebar-item-meta">
            @RegistryHelpers.FormatMediaType(Item.MediaType)
            @if (!string.IsNullOrEmpty(Item.Year))
            {
                <text> · @Item.Year</text>
            }
        </span>
        @{
            // Priority 1: review trigger badge
            if (!string.IsNullOrEmpty(Item.ReviewTrigger))
            {
                var (label, color, _) = RegistryHelpers.FormatReviewTrigger(Item.ReviewTrigger);
                var bgColor = $"rgba({HexToRgbInline(color)},0.15)";
                <span class="sidebar-item-badge" style="background: @bgColor; color: @color;">@label</span>
            }
            // Priority 2: confidence badge with traffic-light color
            else if (Item.Confidence > 0)
            {
                var hexColor = RegistryHelpers.GetConfidenceHexColor(Item.Confidence);
                var pct = (int)(Item.Confidence * 100);
                var bgColor = $"rgba({HexToRgbInline(hexColor)},0.15)";
                <span class="sidebar-item-badge" style="background: @bgColor; color: @hexColor;">@pct%</span>
            }
            // Priority 3: status badge fallback
            else
            {
                var (badgeText, badgeStyle) = RegistryHelpers.GetPrimaryStatusBadge(Item);
                <span class="sidebar-item-badge" style="@badgeStyle">@badgeText</span>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public RegistryItemViewModel Item { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    // Inline hex-to-RGB helper to avoid calling a static method in Razor expressions
    private static string HexToRgbInline(string hex)
    {
        hex = hex.TrimStart('#');
        if (hex.Length < 6) return "255,255,255";
        var r = Convert.ToInt32(hex[..2], 16);
        var g = Convert.ToInt32(hex[2..4], 16);
        var b = Convert.ToInt32(hex[4..6], 16);
        return $"{r},{g},{b}";
    }
}

<style>
    .sidebar-item {
        display: flex;
        gap: 10px;
        padding: 8px 12px;
        cursor: pointer;
        border-left: 3px solid transparent;
        transition: background 0.15s ease;
        align-items: center;
    }

    .sidebar-item:hover {
        background: rgba(255,255,255,0.03);
    }

    .sidebar-item--selected {
        background: rgba(201,146,46,0.08);
        border-left-color: #C9922E;
    }

    .sidebar-item-cover {
        width: 40px;
        height: 60px;
        object-fit: cover;
        border-radius: 4px;
        flex-shrink: 0;
    }

    .sidebar-item-cover-placeholder {
        width: 40px;
        height: 60px;
        background: rgba(255,255,255,0.04);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .sidebar-item-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
        flex: 1;
    }

    .sidebar-item-title {
        font-size: 0.8rem;
        color: #fff;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sidebar-item-meta {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.35);
    }

    .sidebar-item-badge {
        font-size: 0.6rem;
        font-weight: 600;
        padding: 1px 6px;
        border-radius: 4px;
        width: fit-content;
        margin-top: 2px;
    }

    /* Hide badge on hover to make room for actions */
    .sidebar-item:hover .sidebar-item-badge {
        display: none;
    }

    /* Quick-action hover icons */
    .sidebar-item-actions {
        display: none;
        align-items: center;
        gap: 2px;
        flex-shrink: 0;
    }

    .sidebar-item:hover .sidebar-item-actions {
        display: flex;
    }

    .sidebar-item-action {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 2px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        transition: all 0.15s ease;
    }

    .sidebar-item-action--approve {
        color: rgba(76,175,80,0.5);
    }

    .sidebar-item-action--approve:hover {
        color: #4CAF50;
        background: rgba(76,175,80,0.12);
    }

    .sidebar-item-action--reject {
        color: rgba(239,83,80,0.5);
    }

    .sidebar-item-action--reject:hover {
        color: #EF5350;
        background: rgba(239,83,80,0.12);
    }
</style>
