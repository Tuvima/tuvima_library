@using MediaEngine.Web.Components.Registry

<div class="sidebar-item @(IsSelected ? "sidebar-item--selected" : "")"
     @onclick="OnClick">
    @if (!string.IsNullOrEmpty(Item.CoverUrl))
    {
        <img src="@Item.CoverUrl" alt="" class="sidebar-item-cover" loading="lazy" />
    }
    else
    {
        <div class="sidebar-item-cover-placeholder">
            <MudIcon Icon="@RegistryHelpers.GetMediaTypeIcon(Item.MediaType)" Size="Size.Small"
                     Style="opacity: 0.3;" />
        </div>
    }
    <div class="sidebar-item-text">
        <span class="sidebar-item-title">@Item.Title</span>
        <span class="sidebar-item-meta">
            @RegistryHelpers.FormatMediaType(Item.MediaType)
            @if (!string.IsNullOrEmpty(Item.Year))
            {
                <text> · @Item.Year</text>
            }
        </span>
        @{
            var (badgeText, badgeStyle) = RegistryHelpers.GetPrimaryStatusBadge(Item);
        }
        <span class="sidebar-item-badge" style="@badgeStyle">@badgeText</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public RegistryItemViewModel Item { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
}

<style>
    .sidebar-item {
        display: flex;
        gap: 10px;
        padding: 8px 12px;
        cursor: pointer;
        border-left: 3px solid transparent;
        transition: background 0.15s ease;
    }

    .sidebar-item:hover {
        background: rgba(255,255,255,0.03);
    }

    .sidebar-item--selected {
        background: rgba(201,146,46,0.08);
        border-left-color: #C9922E;
    }

    .sidebar-item-cover {
        width: 40px;
        height: 60px;
        object-fit: cover;
        border-radius: 4px;
        flex-shrink: 0;
    }

    .sidebar-item-cover-placeholder {
        width: 40px;
        height: 60px;
        background: rgba(255,255,255,0.04);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .sidebar-item-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
        flex: 1;
    }

    .sidebar-item-title {
        font-size: 0.8rem;
        color: #fff;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sidebar-item-meta {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.35);
    }

    .sidebar-item-badge {
        font-size: 0.6rem;
        font-weight: 600;
        padding: 1px 6px;
        border-radius: 4px;
        width: fit-content;
        margin-top: 2px;
    }
</style>
