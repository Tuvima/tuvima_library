@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator

@if (Item is null)
{
    <div class="inspector-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size: 32px; color: rgba(255,255,255,0.12); margin-bottom: 10px;" />
        <span class="inspector-empty-text">Select an item to inspect</span>
    </div>
}
else
{
    <div class="inspector-panel">

        <!-- Close button -->
        <div class="inspector-topbar">
            <button class="inspector-close" @onclick="OnClose" type="button" title="Close inspector">
                <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 16px;" />
            </button>
        </div>

        <!-- FROM YOUR FILE section -->
        <div class="inspector-section">
            <span class="inspector-section-label">FROM YOUR FILE</span>

            <div class="inspector-file-row">
                <!-- Cover thumbnail -->
                <div class="inspector-cover-wrap">
                    @if (!string.IsNullOrEmpty(Item.CoverUrl))
                    {
                        <img src="@Item.CoverUrl" alt="Cover" class="inspector-cover" />
                    }
                    else
                    {
                        <div class="inspector-cover inspector-cover--placeholder">
                            <MudIcon Icon="@Icons.Material.Outlined.Image"
                                     Style="font-size: 18px; color: rgba(255,255,255,0.18);" />
                        </div>
                    }
                </div>

                <!-- Title, author, file meta -->
                <div class="inspector-file-meta">
                    <span class="inspector-title">@Item.Title</span>
                    @if (!string.IsNullOrWhiteSpace(Item.Author))
                    {
                        <span class="inspector-author">@Item.Author</span>
                    }
                    <div class="inspector-type-row">
                        <MudIcon Icon="@RegistryHelpers.GetMediaTypeIcon(Item.MediaType)"
                                 Style="font-size: 13px; color: rgba(255,255,255,0.40);" />
                        <span class="inspector-format-label">@RegistryHelpers.FormatMediaType(Item.MediaType)</span>
                    </div>
                </div>
            </div>

            <!-- State chip -->
            @{
                var state = ComputeState();
                var stateColor = RegistryHelpers.GetStateColor(state);
                var stateLabel = RegistryHelpers.GetStateLabel(state);
                var stateIcon  = RegistryHelpers.GetStateIcon(state);
            }
            <div class="inspector-chips-row">
                <div class="inspector-state-chip" style="border-color: @stateColor; color: @stateColor;">
                    <MudIcon Icon="@stateIcon" Style="font-size: 11px;" />
                    <span>@stateLabel</span>
                </div>

                <!-- Review trigger chip -->
                @if (!string.IsNullOrEmpty(Item.ReviewTrigger))
                {
                    var (trigLabel, trigColor, trigIcon) = RegistryHelpers.FormatReviewTrigger(Item.ReviewTrigger);
                    <div class="inspector-trigger-chip" style="background: @HexToRgba(trigColor, 0.12); color: @trigColor;">
                        <MudIcon Icon="@trigIcon" Style="font-size: 11px;" />
                        <span>@trigLabel</span>
                    </div>
                }
            </div>
        </div>

        <!-- Confidence indicator -->
        @{
            var confColor = RegistryHelpers.GetConfidenceHexColor(Item.Confidence);
            var confPct   = (int)(Item.Confidence * 100);
        }
        <div class="inspector-section inspector-section--conf">
            <span class="inspector-section-label">CONFIDENCE</span>
            <div class="inspector-conf-bar-wrap">
                <div class="inspector-conf-bar" style="width: @(confPct)%; background: @confColor;"></div>
            </div>
            <span class="inspector-conf-pct" style="color: @confColor;">@(confPct)%</span>
        </div>

        <!-- Wikidata section (for registered items) -->
        @if (!string.IsNullOrEmpty(Item.WikidataQid)
             && !Item.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase))
        {
            <div class="inspector-section">
                <span class="inspector-section-label">WIKIDATA IDENTITY</span>
                <div class="inspector-qid-row">
                    <MudIcon Icon="@Icons.Material.Outlined.Link"
                             Style="font-size: 13px; color: rgba(201,146,46,0.7); flex-shrink: 0;" />
                    <span class="inspector-qid-value">@Item.WikidataQid</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Item.MatchMethod))
                {
                    <span class="inspector-provenance">Matched via @Item.MatchMethod</span>
                }
            </div>
        }

        <!-- Wikidata search + candidates + actions (F6) -->
        <InspectorSearchSection Item="Item"
                                OnRegistered="HandleRegistered"
                                OnSkipped="HandleSkipped"
                                OnMarkedProvisional="HandleProvisional" />

        <!-- Collapsible sections -->
        @if (_reports.Count > 0)
        {
            <InspectorReportSection Reports="_reports" Loading="_reportsLoading"
                                     OnResolve="HandleResolveReport"
                                     OnDismiss="HandleDismissReport" />
        }
        <InspectorHistorySection History="_history" Loading="_historyLoading" />
        <InspectorMetadataSection Fields="_fields" Loading="_fieldsLoading" />

    </div>
}

@code {
    [Parameter] public RegistryItemViewModel? Item { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnItemChanged { get; set; }

    private List<RegistryItemHistoryDto>  _history       = [];
    private List<CanonicalFieldViewModel> _fields        = [];
    private List<ReportEntryDto>          _reports       = [];
    private bool                          _historyLoading;
    private bool                          _fieldsLoading;
    private bool                          _reportsLoading;
    private Guid?                         _loadedEntityId;

    protected override async Task OnParametersSetAsync()
    {
        if (Item is null || Item.EntityId == _loadedEntityId)
            return;

        _loadedEntityId = Item.EntityId;
        _historyLoading = true;
        _fieldsLoading  = true;
        _reportsLoading = true;
        StateHasChanged();

        var historyTask = ApiClient.GetItemHistoryAsync(Item.EntityId);
        var fieldsTask  = Orchestrator.GetCanonicalValuesAsync(Item.EntityId);
        var reportsTask = Orchestrator.GetReportsForEntityAsync(Item.EntityId);

        try { _history = await historyTask; } catch { _history = []; }
        _historyLoading = false;

        try { _fields = await fieldsTask; } catch { _fields = []; }
        _fieldsLoading = false;

        try { _reports = await reportsTask; } catch { _reports = []; }
        _reportsLoading = false;
    }

    private string ComputeState()
    {
        if (Item is null) return "NoMatch";
        if (!string.IsNullOrEmpty(Item.ReviewTrigger)) return "NeedsReview";
        if (!string.IsNullOrEmpty(Item.WikidataQid)
            && !Item.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase))
            return "Registered";
        if (Item.MissingUniverse) return "NoMatch";
        return "NoMatch";
    }

    private async Task HandleRegistered()
    {
        // Reload data after registration
        if (Item is not null)
        {
            _loadedEntityId = null; // Force reload
            await OnParametersSetAsync();
        }
        await OnItemChanged.InvokeAsync();
    }

    private async Task HandleSkipped() => await OnItemChanged.InvokeAsync();
    private async Task HandleProvisional() => await OnItemChanged.InvokeAsync();

    private async Task HandleResolveReport(long activityId)
    {
        await ApiClient.ResolveReportAsync(activityId);
        _reports.RemoveAll(r => r.Id == activityId);
        StateHasChanged();
        await OnItemChanged.InvokeAsync();
    }

    private async Task HandleDismissReport(long activityId)
    {
        await ApiClient.DismissReportAsync(activityId);
        _reports.RemoveAll(r => r.Id == activityId);
        StateHasChanged();
        await OnItemChanged.InvokeAsync();
    }

    private static string HexToRgba(string hex, double alpha)
    {
        hex = hex.TrimStart('#');
        if (hex.Length < 6) return $"rgba(255,255,255,{alpha})";
        var r = Convert.ToInt32(hex[..2], 16);
        var g = Convert.ToInt32(hex[2..4], 16);
        var b = Convert.ToInt32(hex[4..6], 16);
        return $"rgba({r},{g},{b},{alpha})";
    }
}

<style>
    /* ── Panel container ── */
    .inspector-panel {
        width: 350px;
        height: 100%;
        background: rgba(6, 6, 14, 0.95);
        border-left: 1px solid rgba(255, 255, 255, 0.06);
        backdrop-filter: blur(12px);
        overflow-y: auto;
        font-family: 'Montserrat', sans-serif;
        display: flex;
        flex-direction: column;
    }

    /* ── Empty state ── */
    .inspector-empty {
        width: 350px;
        height: 100%;
        background: rgba(6, 6, 14, 0.95);
        border-left: 1px solid rgba(255, 255, 255, 0.06);
        backdrop-filter: blur(12px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: 'Montserrat', sans-serif;
    }

    .inspector-empty-text {
        font-size: 12px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.20);
        letter-spacing: 0.3px;
    }

    /* ── Top bar with close button ── */
    .inspector-topbar {
        display: flex;
        justify-content: flex-end;
        padding: 10px 12px 4px;
    }

    .inspector-close {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 4px;
        cursor: pointer;
        color: rgba(255, 255, 255, 0.35);
        transition: color 0.15s ease, border-color 0.15s ease;
    }

    .inspector-close:hover {
        color: rgba(255, 255, 255, 0.65);
        border-color: rgba(255, 255, 255, 0.18);
    }

    /* ── Generic section block ── */
    .inspector-section {
        padding: 12px 16px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .inspector-section:first-of-type {
        border-top: none;
    }

    .inspector-section-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
        margin-bottom: 10px;
    }

    /* ── File row: cover + meta ── */
    .inspector-file-row {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        margin-bottom: 10px;
    }

    .inspector-cover-wrap {
        flex-shrink: 0;
    }

    .inspector-cover {
        width: 52px;
        height: 76px;
        border-radius: 4px;
        object-fit: cover;
        display: block;
    }

    .inspector-cover--placeholder {
        background: rgba(255, 255, 255, 0.03);
        border: 1px dashed rgba(255, 255, 255, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .inspector-file-meta {
        display: flex;
        flex-direction: column;
        gap: 3px;
        min-width: 0;
        flex: 1;
        padding-top: 2px;
    }

    .inspector-title {
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.88);
        line-height: 1.35;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .inspector-author {
        font-size: 12px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.50);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .inspector-type-row {
        display: flex;
        align-items: center;
        gap: 4px;
        margin-top: 3px;
    }

    .inspector-format-label {
        font-size: 11px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.38);
    }

    /* ── Chips row (state + review trigger) ── */
    .inspector-chips-row {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .inspector-state-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        border-radius: 20px;
        border: 1px solid;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    .inspector-trigger-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
    }

    /* ── Confidence bar ── */
    .inspector-section--conf {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .inspector-conf-bar-wrap {
        height: 4px;
        width: 100%;
        background: rgba(255, 255, 255, 0.07);
        border-radius: 2px;
        overflow: hidden;
    }

    .inspector-conf-bar {
        height: 100%;
        border-radius: 2px;
        transition: width 0.3s ease;
    }

    .inspector-conf-pct {
        font-size: 11px;
        font-weight: 500;
        font-variant-numeric: tabular-nums;
        align-self: flex-end;
    }

    /* ── Wikidata identity ── */
    .inspector-qid-row {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 4px;
    }

    .inspector-qid-value {
        font-size: 12px;
        font-weight: 500;
        color: rgba(201, 146, 46, 0.85);
        font-variant-numeric: tabular-nums;
    }

    .inspector-provenance {
        display: block;
        font-size: 11px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.30);
        font-style: italic;
    }

</style>
