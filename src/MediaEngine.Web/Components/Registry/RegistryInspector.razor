@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@if (Item is null)
{
    <div class="inspector-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size: 32px; color: rgba(140,120,180,0.18); margin-bottom: 10px;" />
        <span class="inspector-empty-text">Select an item to inspect</span>
    </div>
}
else
{

    <div class="inspector-panel">

        <!-- Close button + Tabs (always at the very top) -->
        <div class="inspector-topbar">
            <div class="inspector-tabs">
                @if (IsPersonOrUniverse)
                {
                    <button class="inspector-tab @(_inspectorTab == "details" ? "inspector-tab--active" : "")"
                            @onclick='() => _inspectorTab = "details"'>Details</button>
                    <button class="inspector-tab @(_inspectorTab == "history" ? "inspector-tab--active" : "")"
                            @onclick='() => _inspectorTab = "history"'>History</button>
                    <button class="inspector-tab @(_inspectorTab == "metadata" ? "inspector-tab--active" : "")"
                            @onclick='() => _inspectorTab = "metadata"'>Metadata</button>
                }
                else if (IsInReview)
                {
                    <button class="inspector-tab @(_inspectorTab == "resolve" ? "inspector-tab--active" : "")"
                            @onclick='() => _inspectorTab = "resolve"'>Resolve</button>
                    <button class="inspector-tab @(_inspectorTab == "history" ? "inspector-tab--active" : "")"
                            @onclick='() => _inspectorTab = "history"'>History</button>
                    <button class="inspector-tab @(_inspectorTab == "metadata" ? "inspector-tab--active" : "")"
                            @onclick='() => _inspectorTab = "metadata"'>Metadata</button>
                }
                else
                {
                    <button class="inspector-tab @(_inspectorTab == "details" ? "inspector-tab--active" : "")"
                            @onclick='() => _inspectorTab = "details"'>Details</button>
                    <button class="inspector-tab @(_inspectorTab == "resolve" ? "inspector-tab--active" : "")"
                            @onclick='() => _inspectorTab = "resolve"'>Resolve</button>
                    <button class="inspector-tab @(_inspectorTab == "history" ? "inspector-tab--active" : "")"
                            @onclick='() => _inspectorTab = "history"'>History</button>
                    <button class="inspector-tab @(_inspectorTab == "metadata" ? "inspector-tab--active" : "")"
                            @onclick='() => _inspectorTab = "metadata"'>Metadata</button>
                }
            </div>
            <button class="inspector-close" @onclick="OnClose" type="button" title="Close inspector">
                <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 16px;" />
            </button>
        </div>

        <!-- Tab content -->
        @if (_inspectorTab == "details")
        {
            <!-- Compact header for Details tab -->
            <div class="inspector-tab-header">
                <div class="inspector-tab-header-title">@Item.Title</div>
                <div class="inspector-tab-header-sub">@Item.Author &middot; @RegistryHelpers.FormatMediaType(Item.MediaType)</div>
            </div>
            <InspectorDetailsSection Item="Item" Detail="_detail" Loading="_detailLoading" />
        }
        else if (_inspectorTab == "resolve")
        {
            <!-- File context (flat, no container) -->
            <div class="inspector-file-context">
                <div class="inspector-file-meta">
                    <span class="inspector-title">@Item.Title</span>
                    <span class="inspector-meta-line">@BuildMetaLine()</span>
                </div>

                <!-- Trigger chip -->
                @if (!string.IsNullOrEmpty(Item.ReviewTrigger))
                {
                    <div class="inspector-chips-row">
                        @{
                            var (trigLabel, trigColor, trigIcon) = RegistryHelpers.FormatReviewTrigger(Item.ReviewTrigger);
                        }
                        <div class="inspector-trigger-chip" style="background: @HexToRgba(trigColor, 0.12); color: @trigColor;">
                            <MudIcon Icon="@trigIcon" Style="font-size: 11px;" />
                            <span>@trigLabel</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Resolve tab content wrapper (relative anchor for provisional overlay) -->
            <div class="inspector-resolve-content">
                @if (_showProvisionalForm)
                {
                    <div class="inspector-provisional-overlay">
                        <ProvisionalFormPanel Item="Item"
                                              OnSaved="HandleProvisionalSaved"
                                              OnCancelled="HandleProvisionalCancelled" />
                    </div>
                }

                @if (Item.Status == "Rejected")
                {
                    <div class="inspector-rejected-banner">
                        <div class="inspector-rejected-info">
                            <MudIcon Icon="@Icons.Material.Outlined.Block" Style="font-size: 16px; color: #E24B4A;" />
                            <div class="inspector-rejected-text">
                                <span class="inspector-rejected-label">This item has been rejected</span>
                                <span class="inspector-rejected-sub">It will be purged after the retention period.</span>
                            </div>
                        </div>
                        <button class="inspector-unreject-btn" @onclick="HandleUnreject">
                            <MudIcon Icon="@Icons.Material.Outlined.Restore" Style="font-size: 16px;" />
                            <span>Recover Item</span>
                        </button>
                    </div>
                }

                <!-- Wikidata search + candidates + actions -->
                <InspectorSearchSection Item="Item"
                                        Detail="_detail"
                                        SelectedCoverUrl="@_selectedCoverUrl"
                                        OnIdentified="HandleIdentified"
                                        OnMarkedProvisional="HandleShowProvisionalForm"
                                        OnRejected="HandleRejected"
                                        OnCandidateSelected="HandleCandidateSelected" />

                <!-- Report section (always shown in resolve tab when present) -->
                @if (_reports.Count > 0)
                {
                    <InspectorReportSection Reports="_reports" Loading="_reportsLoading"
                                             OnResolve="HandleResolveReport"
                                             OnDismiss="HandleDismissReport" />
                }
            </div>
        }
        else if (_inspectorTab == "history")
        {
            <!-- Compact header for History tab -->
            <div class="inspector-tab-header">
                <div class="inspector-tab-header-title">@Item.Title</div>
                <div class="inspector-tab-header-sub">@Item.Author &middot; @RegistryHelpers.FormatMediaType(Item.MediaType)</div>
            </div>
            <InspectorHistorySection History="_history" Loading="_historyLoading" />
        }
        else if (_inspectorTab == "metadata")
        {
            <!-- Compact header for Metadata tab -->
            <div class="inspector-tab-header">
                <div class="inspector-tab-header-title">@Item.Title</div>
                <div class="inspector-tab-header-sub">@Item.Author &middot; @RegistryHelpers.FormatMediaType(Item.MediaType)</div>
            </div>
            <InspectorMetadataSection Fields="_fields" Loading="_fieldsLoading" />
        }

    </div>
}

@code {
    [Parameter] public RegistryItemViewModel? Item { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnItemChanged { get; set; }

    private List<RegistryItemHistoryDto>  _history       = [];
    private List<CanonicalFieldViewModel> _fields        = [];
    private List<ReportEntryDto>          _reports       = [];
    private bool                          _historyLoading;
    private bool                          _fieldsLoading;
    private bool                          _reportsLoading;
    private Guid?                         _loadedEntityId;
    private string                        _inspectorTab  = "resolve";
    private bool                          _showProvisionalForm;
    private string?                       _selectedCandidateTitle;
    private string?                       _selectedCandidateAuthor;
    private string?                       _selectedCandidateQid;
    private string?                       _selectedCoverUrl;
    private RegistryItemDetailViewModel?  _detail;
    private bool                          _detailLoading;

    protected override async Task OnParametersSetAsync()
    {
        if (Item is null || Item.EntityId == _loadedEntityId)
            return;

        _loadedEntityId = Item.EntityId;
        var isPerson = Item.MediaType is "Person" or "Universe";
        var inReview = Item.Status == "InReview" || !string.IsNullOrEmpty(Item.ReviewTrigger);
        _inspectorTab   = isPerson ? "details" : inReview ? "resolve" : "details";
        _showProvisionalForm = false;
        _selectedCandidateTitle = null;
        _selectedCandidateAuthor = null;
        _selectedCandidateQid = null;
        _selectedCoverUrl = null;
        _historyLoading = true;
        _fieldsLoading  = true;
        _reportsLoading = true;
        _detailLoading  = true;
        StateHasChanged();

        var historyTask = ApiClient.GetItemHistoryAsync(Item.EntityId);
        var fieldsTask  = Orchestrator.GetCanonicalValuesAsync(Item.EntityId);
        var reportsTask = Orchestrator.GetReportsForEntityAsync(Item.EntityId);
        var detailTask  = ApiClient.GetRegistryItemDetailAsync(Item.EntityId);

        try { _history = await historyTask; } catch { _history = []; }
        _historyLoading = false;

        try { _fields = await fieldsTask; } catch { _fields = []; }
        _fieldsLoading = false;

        try { _reports = await reportsTask; } catch { _reports = []; }
        _reportsLoading = false;

        try { _detail = await detailTask; } catch { _detail = null; }
        _detailLoading = false;
    }

    private bool IsPersonOrUniverse => Item?.MediaType is "Person" or "Universe";
    private bool IsInReview => Item?.Status == "InReview" || !string.IsNullOrEmpty(Item?.ReviewTrigger);
    private bool IsConfirmed => Item?.Status == "Confirmed";

    private string ComputeState()
    {
        if (Item is null) return "NoMatch";
        if (Item.Status == "Confirmed") return "Confirmed";
        if (!string.IsNullOrEmpty(Item.ReviewTrigger)) return "NeedsReview";
        if (!string.IsNullOrEmpty(Item.WikidataQid)
            && !Item.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase))
            return "Identified";
        if (Item.MissingUniverse) return "NoMatch";
        return "NoMatch";
    }

    private async Task HandleIdentified()
    {
        // Reload data after identification — switch to Details tab.
        // We force-refresh the detail from the API and use its status
        // to determine the correct tab, because the list-level Item
        // still carries the stale ReviewTrigger/Status until the list
        // itself refreshes.
        if (Item is not null)
        {
            _detailLoading = true;
            StateHasChanged();

            try { _detail = await ApiClient.GetRegistryItemDetailAsync(Item.EntityId); }
            catch { _detail = null; }
            _detailLoading = false;

            // Use the fresh detail status (not the stale list Item) to pick tab
            var freshStatus = _detail?.Status ?? "";
            var stillInReview = freshStatus is "InReview" or "Review";
            _inspectorTab = stillInReview ? "resolve" : "details";
            _loadedEntityId = Item.EntityId; // prevent OnParametersSetAsync re-run
        }
        await OnItemChanged.InvokeAsync();
    }

    private void HandleShowProvisionalForm()
    {
        _showProvisionalForm = true;
    }

    private async Task HandleProvisionalSaved()
    {
        _showProvisionalForm = false;
        await OnItemChanged.InvokeAsync();
    }

    private void HandleProvisionalCancelled()
    {
        _showProvisionalForm = false;
    }

    private async Task HandleRejected()
    {
        if (Item is null) return;
        try
        {
            var result = await ApiClient.RejectRegistryItemAsync(Item.EntityId);
            if (result is not null)
            {
                Snackbar.Add("Item rejected.", Severity.Success);
                await OnItemChanged.InvokeAsync();
            }
            else
            {
                Snackbar.Add("Could not reject item.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleUnreject()
    {
        if (Item is null) return;
        try
        {
            var ok = await ApiClient.RecoverRegistryItemAsync(Item.EntityId);
            if (ok)
            {
                Snackbar.Add("Item recovered and returned to review.", Severity.Success);
                await OnItemChanged.InvokeAsync();
            }
            else
            {
                Snackbar.Add("Could not recover item.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void HandleCandidateSelected((string? title, string? author, string? qid) candidate)
    {
        _selectedCandidateTitle = candidate.title;
        _selectedCandidateAuthor = candidate.author;
        _selectedCandidateQid = candidate.qid;
    }

    private void HandleCoverSelected(string? coverUrl)
    {
        _selectedCoverUrl = coverUrl;
    }

    private async Task HandleResolveReport(long activityId)
    {
        await ApiClient.ResolveReportAsync(activityId);
        _reports.RemoveAll(r => r.Id == activityId);
        StateHasChanged();
        await OnItemChanged.InvokeAsync();
    }

    private async Task HandleDismissReport(long activityId)
    {
        await ApiClient.DismissReportAsync(activityId);
        _reports.RemoveAll(r => r.Id == activityId);
        StateHasChanged();
        await OnItemChanged.InvokeAsync();
    }

    private static string HexToRgba(string hex, double alpha)
    {
        hex = hex.TrimStart('#');
        if (hex.Length < 6) return $"rgba(255,255,255,{alpha})";
        var r = Convert.ToInt32(hex[..2], 16);
        var g = Convert.ToInt32(hex[2..4], 16);
        var b = Convert.ToInt32(hex[4..6], 16);
        return $"rgba({r},{g},{b},{alpha})";
    }

    private string BuildMetaLine()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(Item?.Author)) parts.Add(Item.Author);
        if (!string.IsNullOrWhiteSpace(Item?.MediaType)) parts.Add(RegistryHelpers.FormatMediaType(Item.MediaType));
        if (!string.IsNullOrWhiteSpace(Item?.Year)) parts.Add(Item.Year);
        parts.Add("From file");
        return string.Join(" · ", parts);
    }
}

<style>
    /* Panel container */
    .inspector-panel {
        width: 100%;
        height: 100%;
        background: rgba(20, 16, 42, 0.6);
        backdrop-filter: blur(8px);
        overflow-y: auto;
        font-family: 'Montserrat', sans-serif;
        display: flex;
        flex-direction: column;
    }

    /* Empty state */
    .inspector-empty {
        width: 100%;
        height: 100%;
        background: rgba(20, 16, 42, 0.6);
        backdrop-filter: blur(8px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: 'Montserrat', sans-serif;
    }

    .inspector-empty-text {
        font-size: 12px;
        font-weight: 400;
        color: rgba(200, 190, 220, 0.20);
        letter-spacing: 0.3px;
    }

    /* Top bar: close button + tabs inline */
    .inspector-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        padding: 12px 16px;
        background: transparent;
        flex-shrink: 0;
    }

    .inspector-close {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        flex-shrink: 0;
        background: transparent;
        border: 1px solid rgba(140, 120, 180, 0.12);
        border-radius: 4px;
        cursor: pointer;
        color: rgba(200, 190, 220, 0.35);
        transition: color 0.15s ease, border-color 0.15s ease;
    }

    .inspector-close:hover {
        color: rgba(200, 190, 220, 0.65);
        border-color: rgba(140, 120, 180, 0.25);
    }

    /* Tab toggle (inline in topbar) */
    .inspector-tabs {
        display: flex;
        gap: 2px;
        flex: 1;
    }

    .inspector-tab {
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        padding: 6px 14px;
        border-radius: 6px;
        border: none;
        background: transparent;
        color: rgba(200, 190, 220, 0.35);
        cursor: pointer;
        font-weight: 400;
        transition: all 0.15s ease;
    }

    .inspector-tab--active {
        background: rgba(140, 120, 180, 0.12);
        color: #c0b8e0;
        font-weight: 500;
    }

    /* Generic section block */
    .inspector-section {
        padding: 18px 20px;
    }

    /* File context (flat, no borders, no background) */
    .inspector-file-context {
        padding: 18px 20px;
    }

    /* ── Provisional form overlay ── */
    .inspector-resolve-content {
        position: relative;
    }

    .inspector-provisional-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 10;
        background: #0c0a14;
        border-bottom: 1px solid rgba(140, 120, 180, 0.12);
        overflow-y: auto;
    }

    .inspector-file-meta {
        display: flex;
        flex-direction: column;
        gap: 3px;
        min-width: 0;
        flex: 1;
        padding-top: 2px;
    }

    .inspector-title {
        font-size: 20px;
        font-weight: 600;
        color: #e0dce8;
        line-height: 1.3;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .inspector-meta-line {
        font-size: 13px;
        font-weight: 400;
        color: rgba(200, 190, 220, 0.50);
        line-height: 1.5;
        margin-top: 2px;
    }

    /* Chips row (state + review trigger) */
    .inspector-chips-row {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .inspector-state-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        border-radius: 20px;
        border: 1px solid;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    .inspector-trigger-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
    }

    /* Compact header for History / Metadata tabs */
    .inspector-tab-header {
        padding: 14px 20px 12px;
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .inspector-tab-header-title {
        font-size: 14px;
        font-weight: 500;
        color: #e0dce8;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        line-height: 1.35;
    }

    .inspector-tab-header-sub {
        font-size: 12px;
        font-weight: 400;
        color: rgba(200, 190, 220, 0.55);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* ── Rejected banner ── */
    .inspector-rejected-banner {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 14px 16px;
        margin: 8px 12px;
        background: rgba(226, 75, 74, 0.08);
        border: 1px solid rgba(226, 75, 74, 0.20);
        border-radius: 8px;
    }

    .inspector-rejected-info {
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

    .inspector-rejected-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .inspector-rejected-label {
        font-size: 12px;
        font-weight: 600;
        color: #E24B4A;
    }

    .inspector-rejected-sub {
        font-size: 11px;
        color: rgba(226, 75, 74, 0.65);
    }

    .inspector-unreject-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 10px 16px;
        background: rgba(140, 120, 180, 0.10);
        border: 1px solid rgba(140, 120, 180, 0.25);
        border-radius: 8px;
        color: #e0dce8;
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease;
    }

    .inspector-unreject-btn:hover {
        background: rgba(140, 120, 180, 0.20);
        border-color: rgba(140, 120, 180, 0.40);
    }
</style>
