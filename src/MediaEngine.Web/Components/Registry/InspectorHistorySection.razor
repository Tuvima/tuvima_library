@using MediaEngine.Web.Models.ViewDTOs
@using MudBlazor

<div class="ihs-panel">
    @if (Loading)
    {
        <div class="ihs-loading">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ihs-spinner" />
        </div>
    }
    else if (History == null || History.Count == 0)
    {
        <div class="ihs-empty">No history yet</div>
    }
    else
    {
        var displayed = History.Take(MaxEntries).ToList();

        <div class="ihs-timeline">
            @for (int i = 0; i < displayed.Count; i++)
            {
                var entry = displayed[i];
                var isLast = i == displayed.Count - 1;
                var (dotBg, dotCore) = GetDotColors(entry.EventType);

                <div class="ihs-entry">
                    <div class="ihs-track">
                        <div class="ihs-dot" style="background: @dotBg;">
                            <div class="ihs-dot-inner" style="background: @dotCore;"></div>
                        </div>
                        @if (!isLast)
                        {
                            <div class="ihs-connector"></div>
                        }
                    </div>
                    <div class="ihs-content @(isLast ? "ihs-content--last" : "")">
                        <span class="ihs-label">@entry.Label</span>
                        @{
                            var friendly = SimplifyDetail(entry.Detail, entry.EventType);
                        }
                        @if (!string.IsNullOrWhiteSpace(friendly))
                        {
                            <span class="ihs-detail">@friendly</span>
                        }
                        <span class="ihs-time">@FormatTimestamp(entry.OccurredAt)</span>
                    </div>
                </div>
            }
        </div>

        @if (History.Count > MaxEntries)
        {
            <button class="ihs-load-more" @onclick="() => OnLoadMore.InvokeAsync()" type="button">
                Load more
            </button>
        }
    }
</div>

@code {
    [Parameter] public List<RegistryItemHistoryDto> History { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public int MaxEntries { get; set; } = 100;
    [Parameter] public EventCallback OnLoadMore { get; set; }

    private static string FormatTimestamp(DateTimeOffset time)
    {
        var local = time.ToLocalTime();
        var today = DateTimeOffset.Now.ToLocalTime().Date;
        if (local.Date == today)
            return $"Today, {local:h:mm tt}";
        if (local.Date == today.AddDays(-1))
            return $"Yesterday, {local:h:mm tt}";
        return local.ToString("MMM d, h:mm tt");
    }

    /// <summary>Strips technical jargon from detail strings, returning plain-English summaries.</summary>
    private static string? SimplifyDetail(string? detail, string eventType)
    {
        if (string.IsNullOrWhiteSpace(detail)) return null;

        // Strip common technical prefixes/patterns
        var d = detail.Trim();

        // Remove GUIDs
        d = System.Text.RegularExpressions.Regex.Replace(d, @"[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}", "").Trim();

        // Remove file paths (Windows or Unix)
        d = System.Text.RegularExpressions.Regex.Replace(d, @"[A-Z]:\\[^\s,;]+", "").Trim();
        d = System.Text.RegularExpressions.Regex.Replace(d, @"/[^\s,;]+/[^\s,;]+", "").Trim();

        // Remove "Entity:" or "Asset:" prefixes
        d = System.Text.RegularExpressions.Regex.Replace(d, @"^(Entity|Asset|Work|Edition|Hub|MediaAsset)\s*:\s*", "", System.Text.RegularExpressions.RegexOptions.IgnoreCase).Trim();

        // Clean up leftover punctuation
        d = System.Text.RegularExpressions.Regex.Replace(d, @"^[,;:\s]+", "").Trim();
        d = System.Text.RegularExpressions.Regex.Replace(d, @"[,;:\s]+$", "").Trim();

        // If nothing meaningful remains, return null
        if (d.Length < 3) return null;

        // Cap length
        if (d.Length > 120) d = d[..117] + "...";

        return d;
    }

    private static (string bg, string core) GetDotColors(string eventType) => eventType switch
    {
        "ReviewItemCreated" or "ReviewItemResolved" => ("rgba(239,159,39,0.15)", "#EF9F27"),
        "MetadataHydrated" or "MetadataHarvested" or "FileIngested" or
        "MetadataExtracted" or "HydrationStarted" or "HydrationCompleted" or
        "WikidataMatched" or "RetailEnriched" => ("rgba(55,138,221,0.15)", "#85B7EB"),
        "FileRejected" => ("rgba(229,115,115,0.15)", "#E57373"),
        _ => ("rgba(140,120,180,0.12)", "rgba(200,190,220,0.35)"),
    };
}

<style>
    .ihs-panel {
        font-family: 'Montserrat', sans-serif;
        padding: 14px 14px 14px 28px;
    }

    .ihs-loading {
        display: flex;
        justify-content: center;
        padding: 24px 0;
    }

    .ihs-spinner {
        color: rgba(200, 190, 220, 0.5) !important;
    }

    .ihs-empty {
        font-size: 11px;
        font-weight: 400;
        font-style: italic;
        color: rgba(200, 190, 220, 0.30);
        text-align: center;
        padding: 24px 0;
    }

    .ihs-timeline {
        display: flex;
        flex-direction: column;
    }

    .ihs-entry {
        display: flex;
        gap: 10px;
    }

    .ihs-track {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
        width: 18px;
    }

    .ihs-dot {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .ihs-dot-inner {
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }

    .ihs-connector {
        width: 1px;
        flex: 1;
        min-height: 6px;
        background: rgba(140, 120, 180, 0.1);
        margin: 4px 0;
    }

    .ihs-content {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding-bottom: 16px;
        flex: 1;
        min-width: 0;
    }

    .ihs-content--last {
        padding-bottom: 0;
    }

    .ihs-label {
        font-size: 11px;
        font-weight: 500;
        color: rgba(200, 190, 220, 0.70);
        line-height: 1.3;
    }

    .ihs-detail {
        font-size: 11px;
        font-weight: 300;
        color: rgba(200, 190, 220, 0.30);
        line-height: 1.3;
    }

    .ihs-time {
        font-size: 11px;
        font-weight: 300;
        color: rgba(200, 190, 220, 0.25);
        margin-top: 2px;
    }

    .ihs-load-more {
        display: block;
        width: 100%;
        margin-top: 8px;
        padding: 5px 0;
        background: transparent;
        border: 1px solid rgba(140, 120, 180, 0.12);
        border-radius: 4px;
        font-family: 'Montserrat', sans-serif;
        font-size: 10px;
        font-weight: 500;
        color: rgba(200, 190, 220, 0.35);
        cursor: pointer;
        text-align: center;
        transition: color 0.15s ease, border-color 0.15s ease;
    }

    .ihs-load-more:hover {
        color: rgba(200, 190, 220, 0.65);
        border-color: rgba(140, 120, 180, 0.25);
    }
</style>
