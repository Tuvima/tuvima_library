@using MediaEngine.Web.Models.ViewDTOs
@using MudBlazor

<div class="ihs-panel">
    @if (Loading)
    {
        <div class="ihs-loading">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ihs-spinner" />
        </div>
    }
    else if (History == null || History.Count == 0)
    {
        <div class="ihs-empty">No history available</div>
    }
    else
    {
        var displayed = History.Take(MaxEntries).ToList();

        <div class="ihs-timeline">
            @for (int i = 0; i < displayed.Count; i++)
            {
                var entry = displayed[i];
                var isLast = i == displayed.Count - 1;
                var dotColor = GetDotColor(entry.EventType);

                <div class="ihs-entry">
                    <div class="ihs-track">
                        <div class="ihs-dot" style="background: @dotColor;">
                            <div class="ihs-dot-inner" style="background: @dotColor;"></div>
                        </div>
                        @if (!isLast)
                        {
                            <div class="ihs-connector"></div>
                        }
                    </div>
                    <div class="ihs-content @(isLast ? "ihs-content--last" : "")">
                        <span class="ihs-label">@entry.Label</span>
                        @if (!string.IsNullOrWhiteSpace(entry.Detail))
                        {
                            <span class="ihs-detail">@entry.Detail</span>
                        }
                        <span class="ihs-time">@FormatTimestamp(entry.OccurredAt)</span>
                    </div>
                </div>
            }
        </div>

        @if (History.Count > MaxEntries)
        {
            <button class="ihs-load-more" @onclick="() => OnLoadMore.InvokeAsync()" type="button">
                Load more
            </button>
        }
    }
</div>

@code {
    [Parameter] public List<RegistryItemHistoryDto> History { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public int MaxEntries { get; set; } = 100;
    [Parameter] public EventCallback OnLoadMore { get; set; }

    private static string FormatTimestamp(DateTimeOffset time)
    {
        var local = time.ToLocalTime();
        var today = DateTimeOffset.Now.ToLocalTime().Date;
        if (local.Date == today)
            return $"Today, {local:h:mm tt}";
        return local.ToString("MMM d, h:mm tt");
    }

    private static string GetDotColor(string eventType) => eventType switch
    {
        "ReviewItemCreated"  => "#EF9F27",
        "ReviewItemResolved" => "#EF9F27",
        "MetadataHydrated"   => "#85B7EB",
        "MetadataHarvested"  => "#85B7EB",
        "FileIngested"       => "#85B7EB",
        _                    => "rgba(200,190,220,0.35)",
    };
}

<style>
    .ihs-panel {
        font-family: 'Montserrat', sans-serif;
        padding: 14px;
        padding-left: 28px;
    }

    .ihs-loading {
        display: flex;
        justify-content: center;
        padding: 24px 0;
    }

    .ihs-spinner {
        color: rgba(200, 190, 220, 0.5) !important;
    }

    .ihs-empty {
        font-size: 11px;
        font-weight: 400;
        font-style: italic;
        color: rgba(200, 190, 220, 0.35);
        text-align: center;
        padding: 24px 0;
    }

    .ihs-timeline {
        display: flex;
        flex-direction: column;
    }

    .ihs-entry {
        display: flex;
        gap: 10px;
        align-items: flex-start;
    }

    .ihs-track {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
        width: 16px;
    }

    .ihs-dot {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        opacity: 0.35;
        margin-top: 1px;
    }

    .ihs-dot-inner {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        opacity: 1;
        filter: brightness(2.5);
    }

    .ihs-connector {
        width: 1px;
        flex: 1;
        min-height: 8px;
        background: rgba(140, 120, 180, 0.1);
        margin: 2px 0;
    }

    .ihs-content {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding-bottom: 14px;
        flex: 1;
        min-width: 0;
    }

    .ihs-content--last {
        padding-bottom: 0;
    }

    .ihs-label {
        font-size: 11px;
        font-weight: 500;
        color: rgba(200, 190, 220, 0.7);
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ihs-detail {
        font-size: 11px;
        font-weight: 300;
        color: rgba(200, 190, 220, 0.3);
        line-height: 1.4;
        word-break: break-word;
    }

    .ihs-time {
        font-size: 11px;
        font-weight: 300;
        color: rgba(200, 190, 220, 0.25);
        margin-top: 1px;
    }

    .ihs-load-more {
        display: block;
        width: 100%;
        margin-top: 8px;
        padding: 6px 0;
        background: transparent;
        border: 1px solid rgba(140, 120, 180, 0.15);
        border-radius: 4px;
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 500;
        color: rgba(200, 190, 220, 0.45);
        cursor: pointer;
        text-align: center;
        transition: color 0.15s ease, border-color 0.15s ease;
    }

    .ihs-load-more:hover {
        color: rgba(200, 190, 220, 0.75);
        border-color: rgba(140, 120, 180, 0.35);
    }
</style>
