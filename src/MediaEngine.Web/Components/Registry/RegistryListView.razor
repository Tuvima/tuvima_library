@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Models.ViewDTOs

@if (Loading && (Items == null || Items.Count == 0))
{
    <div class="rlv-loading">
        <MudProgressLinear Indeterminate="true" Color="Color.Warning"
                           Style="width: 160px; border-radius: 4px;" />
    </div>
}
else if (Items == null || Items.Count == 0)
{
    <div class="rlv-empty">
        <MudIcon Icon="@Icons.Material.Outlined.SearchOff"
                 Style="font-size: 2.5rem; opacity: 0.2; color: #fff;" />
        <span class="rlv-empty-text">No items found</span>
    </div>
}
else
{
    <div class="rlv-list">
        @foreach (var item in Items)
        {
            var (badgeText, badgeStyle) = RegistryHelpers.GetPrimaryStatusBadge(item);

            <div class="rlv-row" @onclick="() => OnItemSelected.InvokeAsync(item.EntityId)">

                @* Cover thumbnail *@
                @if (!string.IsNullOrEmpty(item.CoverUrl))
                {
                    <img src="@item.CoverUrl" alt="" class="rlv-cover" loading="lazy" />
                }
                else
                {
                    <div class="rlv-cover-placeholder">
                        <MudIcon Icon="@RegistryHelpers.GetMediaTypeIcon(item.MediaType)"
                                 Style="font-size: 1.4rem; opacity: 0.25; color: #fff;" />
                    </div>
                }

                @* Text stack *@
                <div class="rlv-body">
                    <span class="rlv-title">@item.Title</span>

                    <span class="rlv-meta">
                        @if (!string.IsNullOrEmpty(item.Author))
                        {
                            <text>@item.Author</text>
                            @if (!string.IsNullOrEmpty(item.Year))
                            {
                                <text> · @item.Year</text>
                            }
                        }
                        else if (!string.IsNullOrEmpty(item.Year))
                        {
                            <text>@item.Year</text>
                        }
                    </span>

                    <span class="rlv-badge" style="@badgeStyle">@badgeText</span>
                </div>
            </div>
        }

        @if (HasMore)
        {
            <div class="rlv-load-more">
                @if (Loading)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                         Style="color: rgba(255,255,255,0.3);" />
                }
                else
                {
                    <MudButton Variant="Variant.Text"
                               OnClick="OnLoadMore"
                               Style="color: rgba(255,255,255,0.45); font-size: 0.78rem; font-family: 'Montserrat', sans-serif; letter-spacing: 0.02em;">
                        Load more...
                    </MudButton>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public List<RegistryItemViewModel>? Items { get; set; }
    [Parameter] public bool HasMore { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<Guid> OnItemSelected { get; set; }
    [Parameter] public EventCallback OnLoadMore { get; set; }
}

<style>
    .rlv-list {
        display: flex;
        flex-direction: column;
        flex: 1;
        overflow-y: auto;
        font-family: 'Montserrat', sans-serif;
    }

    .rlv-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 20px;
        cursor: pointer;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        transition: background 0.12s ease;
    }

    .rlv-row:hover {
        background: rgba(255,255,255,0.03);
    }

    .rlv-cover {
        width: 48px;
        height: 72px;
        object-fit: cover;
        border-radius: 6px;
        flex-shrink: 0;
        background: rgba(255,255,255,0.04);
    }

    .rlv-cover-placeholder {
        width: 48px;
        height: 72px;
        border-radius: 6px;
        flex-shrink: 0;
        background: rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .rlv-body {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
        min-width: 0;
    }

    .rlv-title {
        font-size: 0.9rem;
        font-weight: 500;
        color: #fff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.3;
    }

    .rlv-meta {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.4);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .rlv-badge {
        font-size: 0.65rem;
        font-weight: 600;
        padding: 2px 7px;
        border-radius: 4px;
        width: fit-content;
        line-height: 1.5;
        white-space: nowrap;
        margin-top: 2px;
    }

    .rlv-load-more {
        display: flex;
        justify-content: center;
        padding: 20px 0 16px;
    }

    .rlv-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
        flex: 1;
    }

    .rlv-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        padding: 64px 24px;
        flex: 1;
        font-family: 'Montserrat', sans-serif;
    }

    .rlv-empty-text {
        font-size: 0.82rem;
        color: rgba(255,255,255,0.25);
        text-align: center;
    }
</style>
