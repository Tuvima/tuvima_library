@using MediaEngine.Web.Components.Registry

<div class="registry-sidebar">
    @* ── Category Filters ── *@
    <div class="sidebar-categories">
        <button class="sidebar-category @(SelectedCategory == null ? "sidebar-category--active" : "")"
                @onclick="@(() => OnCategorySelected.InvokeAsync(null))">
            <MudIcon Icon="@Icons.Material.Outlined.FactCheck" Size="Size.Small" />
            <span class="sidebar-category-label">All</span>
            <span class="sidebar-category-count">@(Counts?.Total ?? 0)</span>
        </button>
        <button class="sidebar-category @(SelectedCategory == "Approved" ? "sidebar-category--active" : "")"
                @onclick="@(() => OnCategorySelected.InvokeAsync("Approved"))">
            <MudIcon Icon="@Icons.Material.Outlined.VerifiedUser" Size="Size.Small" />
            <span class="sidebar-category-label">Approved</span>
            <span class="sidebar-category-count">@((Counts?.AutoApproved ?? 0) + (Counts?.Edited ?? 0))</span>
        </button>
        <button class="sidebar-category @(SelectedCategory == "Unmatched" ? "sidebar-category--active" : "")"
                @onclick="@(() => OnCategorySelected.InvokeAsync("Unmatched"))">
            <MudIcon Icon="@Icons.Material.Outlined.HelpOutline" Size="Size.Small" />
            <span class="sidebar-category-label">Unmatched</span>
            <span class="sidebar-category-count sidebar-category-count--warn">@(Counts?.NeedsReview ?? 0)</span>
        </button>
        <button class="sidebar-category @(SelectedCategory == "LowConfidence" ? "sidebar-category--active" : "")"
                @onclick="@(() => OnCategorySelected.InvokeAsync("LowConfidence"))">
            <MudIcon Icon="@Icons.Material.Outlined.TrendingDown" Size="Size.Small" />
            <span class="sidebar-category-label">Low Confidence</span>
            <span class="sidebar-category-count">0</span>
        </button>
        <button class="sidebar-category @(SelectedCategory == "MissingArt" ? "sidebar-category--active" : "")"
                @onclick="@(() => OnCategorySelected.InvokeAsync("MissingArt"))">
            <MudIcon Icon="@Icons.Material.Outlined.BrokenImage" Size="Size.Small" />
            <span class="sidebar-category-label">Missing Art</span>
            <span class="sidebar-category-count">0</span>
        </button>
        <button class="sidebar-category @(SelectedCategory == "UpdatedData" ? "sidebar-category--active" : "")"
                @onclick="@(() => OnCategorySelected.InvokeAsync("UpdatedData"))">
            <MudIcon Icon="@Icons.Material.Outlined.Update" Size="Size.Small" />
            <span class="sidebar-category-label">Updated Data</span>
            <span class="sidebar-category-count">0</span>
        </button>
    </div>

    @* ── Search ── *@
    <div class="sidebar-search">
        <MudTextField @bind-Value="SearchText" Placeholder="Search..."
                      Variant="Variant.Outlined" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="400"
                      OnDebounceIntervalElapsed="OnSearchDebounced"
                      Margin="Margin.Dense"
                      Style="font-size: 0.8rem;" />
    </div>

    @* ── Media Type Chips ── *@
    <div class="sidebar-media-chips">
        @foreach (var mt in _mediaTypes)
        {
            var isActive = SelectedMediaType == mt.Value;
            <MudChip T="string" Size="Size.Small"
                     Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                     Color="@(isActive ? Color.Warning : Color.Default)"
                     Style="@(isActive ? "" : "border-color: rgba(255,255,255,0.12); color: rgba(255,255,255,0.5);")"
                     OnClick="@(() => ToggleMediaType(mt.Value))">
                @mt.Label
            </MudChip>
        }
    </div>

    @* ── Divider ── *@
    <div class="sidebar-divider"></div>

    @* ── Item List ── *@
    <div class="sidebar-items">
        @if (Items is not null)
        {
            @foreach (var item in Items)
            {
                <RegistrySidebarItem Item="@item"
                                     IsSelected="@(SelectedEntityId == item.EntityId)"
                                     OnClick="@(() => OnItemSelected.InvokeAsync(item.EntityId))" />
            }
        }

        @if (HasMore)
        {
            <div class="sidebar-load-more">
                <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                           OnClick="OnLoadMore" FullWidth="true">
                    Load more...
                </MudButton>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public RegistryStatusCountsDto? Counts { get; set; }
    [Parameter] public string? SelectedCategory { get; set; }
    [Parameter] public string? SelectedMediaType { get; set; }
    [Parameter] public Guid? SelectedEntityId { get; set; }
    [Parameter] public List<RegistryItemViewModel>? Items { get; set; }
    [Parameter] public bool HasMore { get; set; }
    [Parameter] public EventCallback<string?> OnCategorySelected { get; set; }
    [Parameter] public EventCallback<string?> OnMediaTypeChanged { get; set; }
    [Parameter] public EventCallback<string?> OnSearchChanged { get; set; }
    [Parameter] public EventCallback<Guid> OnItemSelected { get; set; }
    [Parameter] public EventCallback OnLoadMore { get; set; }

    private string? SearchText { get; set; }

    private static readonly (string Label, string? Value)[] _mediaTypes =
    [
        ("Books", "Epub"),
        ("Audio", "Audiobook"),
        ("Movies", "Movies"),
        ("TV", "TV"),
        ("Comics", "Comics"),
        ("Podcasts", "Podcasts"),
        ("Universe", "Universe"),
    ];

    private async Task OnSearchDebounced()
    {
        await OnSearchChanged.InvokeAsync(SearchText);
    }

    private async Task ToggleMediaType(string? value)
    {
        var newValue = SelectedMediaType == value ? null : value;
        await OnMediaTypeChanged.InvokeAsync(newValue);
    }
}

<style>
    .registry-sidebar {
        display: flex;
        flex-direction: column;
        background: rgba(8,13,30,0.92);
        backdrop-filter: blur(12px);
        border-right: 1px solid rgba(255,255,255,0.06);
        height: 100%;
        overflow: hidden;
    }

    /* Categories */
    .sidebar-categories {
        display: flex;
        flex-direction: column;
        padding: 12px 8px;
        gap: 2px;
    }

    .sidebar-category {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        background: transparent;
        border: none;
        border-left: 3px solid transparent;
        border-radius: 0 6px 6px 0;
        color: rgba(255,255,255,0.5);
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .sidebar-category:hover {
        background: rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.8);
    }

    .sidebar-category--active {
        border-left-color: #C9922E;
        color: #C9922E;
        background: rgba(201,146,46,0.08);
    }

    .sidebar-category-label {
        flex: 1;
        text-align: left;
    }

    .sidebar-category-count {
        font-size: 0.7rem;
        background: rgba(255,255,255,0.08);
        padding: 2px 8px;
        border-radius: 10px;
        color: rgba(255,255,255,0.5);
    }

    .sidebar-category-count--warn {
        background: rgba(234,179,8,0.2);
        color: #EAB308;
    }

    /* Search */
    .sidebar-search {
        padding: 0 12px 8px;
    }

    /* Media Chips */
    .sidebar-media-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        padding: 0 12px 12px;
    }

    /* Divider */
    .sidebar-divider {
        height: 1px;
        background: rgba(255,255,255,0.06);
        margin: 0 12px;
    }

    /* Item List */
    .sidebar-items {
        flex: 1;
        overflow-y: auto;
        padding: 8px 0;
    }

    .sidebar-items::-webkit-scrollbar {
        width: 4px;
    }

    .sidebar-items::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.1);
        border-radius: 2px;
    }

    .sidebar-load-more {
        padding: 8px 12px;
    }
</style>
