@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Registry

<div class="rbl-container">

    @* ── Amber attention banner ── *@
    @if (AttentionCount > 0)
    {
        <div class="rbl-attention-banner">
            <div class="rbl-attention-inner">
                <span class="rbl-attention-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L2 20h20L12 2z" stroke="#EF9F27" stroke-width="1.5" stroke-linejoin="round"/>
                        <path d="M12 9v5" stroke="#EF9F27" stroke-width="1.5" stroke-linecap="round"/>
                        <circle cx="12" cy="17" r="0.75" fill="#EF9F27"/>
                    </svg>
                </span>
                <span class="rbl-attention-text">
                    <strong>@AttentionCount @(AttentionCount == 1 ? "item needs" : "items need") your attention</strong>
                </span>
                <button class="rbl-attention-link" @onclick="() => OnAttentionClicked.InvokeAsync()">
                    Review now
                </button>
            </div>
        </div>
    }

    @* ── Batch cards ── *@
    @if (Batches.Count > 0)
    {
        @foreach (var batch in Batches)
        {
            var duration = RegistryHelpers.FormatBatchDuration(batch.StartedAt, batch.CompletedAt);
            var timestamp = RegistryHelpers.FormatBatchTimestamp(batch.StartedAt);
            var subtitle = RegistryHelpers.FormatBatchSubtitle(batch.FilesTotal, batch.Category, batch.SourcePath);
            var isInProgress = batch.CompletedAt is null;

            <div class="rbl-card @(isInProgress ? "rbl-card--active" : "")"
                 @onclick="() => OnBatchSelected.InvokeAsync(batch.Id)"
                 role="button"
                 tabindex="0"
                 @onkeydown="@(async (e) => { if (e.Key is "Enter" or " ") await OnBatchSelected.InvokeAsync(batch.Id); })">

                @* ── Card header row: timestamp + subtitle + duration ── *@
                <div class="rbl-card-header">
                    <div class="rbl-card-meta">
                        <span class="rbl-timestamp">@timestamp</span>
                        <span class="rbl-subtitle">@subtitle</span>
                    </div>
                    <span class="rbl-duration @(isInProgress ? "rbl-duration--active" : "")">
                        @if (isInProgress)
                        {
                            <span class="rbl-pulse-dot"></span>
                        }
                        @duration
                    </span>
                </div>

                @* ── Progress bar (active batches only) ── *@
                @if (isInProgress && ActiveProgress is not null && ActiveProgress.BatchId == batch.Id)
                {
                    <div class="rbl-progress-section">
                        <div class="rbl-progress-bar-track">
                            <div class="rbl-progress-bar-fill"
                                 style="width: @(ActiveProgress.ProgressPercent)%;">
                            </div>
                        </div>
                        <div class="rbl-progress-meta">
                            <span class="rbl-progress-count">
                                @ActiveProgress.FilesProcessed / @ActiveProgress.FilesTotal files
                            </span>
                            @if (ActiveProgress.EstimatedSecondsRemaining is { } eta)
                            {
                                <span class="rbl-progress-eta">
                                    ~@FormatEta(eta) remaining
                                </span>
                            }
                        </div>
                        @if (ActiveProgress?.RecentTitles is { Count: > 0 })
                        {
                            <div class="rbl-title-summary">
                                @{
                                    var titles = ActiveProgress.RecentTitles;
                                    var displayTitles = string.Join(", ", titles.Take(3));
                                    var moreCount = ActiveProgress.FilesTotal - titles.Count;
                                }
                                @displayTitles
                                @if (moreCount > 0)
                                {
                                    <span class="rbl-more-count">and @moreCount more</span>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(ActiveProgress?.CurrentStage))
                        {
                            <div class="rbl-stage-indicator">
                                @(ActiveProgress.CurrentStage switch
                                {
                                    "RetailIdentification" => "Identifying covers…",
                                    "WikidataBridge" => "Resolving catalogue links…",
                                    _ => ActiveProgress.CurrentStage
                                })
                            </div>
                        }
                    </div>
                }

                @* ── Four KPI chips ── *@
                <div class="rbl-kpi-row">
                    <div class="rbl-kpi-chip">
                        <span class="rbl-kpi-number" style="color: #5DCAA5;">@batch.FilesIdentified</span>
                        <span class="rbl-kpi-label">Identified</span>
                    </div>
                    <div class="rbl-kpi-chip">
                        <span class="rbl-kpi-number" style="color: #EF9F27;">@batch.FilesReview</span>
                        <span class="rbl-kpi-label">Review</span>
                    </div>
                    <div class="rbl-kpi-chip">
                        <span class="rbl-kpi-number" style="color: #B4B2A9;">@batch.FilesNoMatch</span>
                        <span class="rbl-kpi-label">No Match</span>
                    </div>
                    <div class="rbl-kpi-chip">
                        <span class="rbl-kpi-number" style="color: #EF5350;">@batch.FilesFailed</span>
                        <span class="rbl-kpi-label">Failed</span>
                    </div>
                </div>

            </div>
        }
    }
    else
    {
        @* ── Empty state ── *@
        <div class="rbl-empty">
            <svg class="rbl-empty-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="3" width="18" height="18" rx="3" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
                <path d="M8 12h8M12 8v8" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="rbl-empty-title">No ingestion batches yet</span>
            <span class="rbl-empty-subtitle">Files processed by the Engine will appear here.</span>
        </div>
    }

</div>

@code {
    [Parameter] public IReadOnlyList<IngestionBatchViewModel> Batches { get; set; } = [];
    [Parameter] public int AttentionCount { get; set; }
    [Parameter] public BatchProgressEvent? ActiveProgress { get; set; }
    [Parameter] public EventCallback<Guid> OnBatchSelected { get; set; }
    [Parameter] public EventCallback OnAttentionClicked { get; set; }

    private static string FormatEta(int totalSeconds)
    {
        if (totalSeconds < 60) return $"{totalSeconds}s";
        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;
        return seconds > 0 ? $"{minutes}m {seconds}s" : $"{minutes}m";
    }
}

<style>
    /* ── Container ── */
    .rbl-container {
        display: flex;
        flex-direction: column;
        gap: 0;
        width: 100%;
        font-family: 'Montserrat', sans-serif;
    }

    /* ── Attention banner ── */
    .rbl-attention-banner {
        margin-bottom: 12px;
        border-radius: 10px;
        background: rgba(239, 159, 39, 0.08);
        border: 0.5px solid rgba(239, 159, 39, 0.3);
        padding: 10px 14px;
    }

    .rbl-attention-inner {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .rbl-attention-icon {
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }

    .rbl-attention-text {
        flex: 1;
        font-size: 12px;
        font-weight: 400;
        color: rgba(239, 159, 39, 0.9);
        line-height: 1.4;
    }

    .rbl-attention-text strong {
        font-weight: 600;
        color: #EF9F27;
    }

    .rbl-attention-link {
        flex-shrink: 0;
        background: none;
        border: 0.5px solid rgba(239, 159, 39, 0.45);
        border-radius: 6px;
        padding: 4px 10px;
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 600;
        color: #EF9F27;
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease;
        white-space: nowrap;
    }

    .rbl-attention-link:hover {
        background: rgba(239, 159, 39, 0.12);
        border-color: rgba(239, 159, 39, 0.65);
    }

    /* ── Batch card ── */
    .rbl-card {
        background: rgba(10, 10, 18, 0.85);
        border: 0.5px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 14px 16px 12px;
        margin-bottom: 8px;
        cursor: pointer;
        transition: border-color 0.18s ease, background 0.18s ease;
        outline: none;
    }

    .rbl-card:hover {
        background: rgba(16, 16, 28, 0.92);
        border-color: rgba(255, 255, 255, 0.13);
    }

    .rbl-card:focus-visible {
        border-color: rgba(201, 146, 46, 0.55);
        box-shadow: 0 0 0 2px rgba(201, 146, 46, 0.18);
    }

    .rbl-card--active {
        border-color: rgba(93, 202, 165, 0.22);
    }

    .rbl-card--active:hover {
        border-color: rgba(93, 202, 165, 0.38);
    }

    /* ── Card header row ── */
    .rbl-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 12px;
    }

    .rbl-card-meta {
        display: flex;
        flex-direction: column;
        gap: 3px;
        min-width: 0;
    }

    .rbl-timestamp {
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.88);
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .rbl-subtitle {
        font-size: 12px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.42);
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* ── Duration badge ── */
    .rbl-duration {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 9px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.05);
        border: 0.5px solid rgba(255, 255, 255, 0.08);
        font-size: 11px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.45);
        white-space: nowrap;
        margin-top: 1px;
    }

    .rbl-duration--active {
        background: rgba(93, 202, 165, 0.08);
        border-color: rgba(93, 202, 165, 0.2);
        color: rgba(93, 202, 165, 0.75);
    }

    /* ── Pulse dot (in-progress indicator) ── */
    .rbl-pulse-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #5DCAA5;
        flex-shrink: 0;
        animation: rbl-pulse 1.8s ease-in-out infinite;
    }

    @@keyframes rbl-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.75); }
    }

    /* ── Progress bar ── */
    .rbl-progress-section {
        margin-bottom: 12px;
    }

    .rbl-progress-bar-track {
        width: 100%;
        height: 4px;
        border-radius: 2px;
        background: rgba(255, 255, 255, 0.06);
        overflow: hidden;
        margin-bottom: 6px;
    }

    .rbl-progress-bar-fill {
        height: 100%;
        border-radius: 2px;
        background: linear-gradient(90deg, #5DCAA5, #4CAF50);
        transition: width 0.4s ease-out;
        min-width: 2px;
    }

    .rbl-progress-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .rbl-progress-count {
        font-size: 11px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.5);
        font-variant-numeric: tabular-nums;
    }

    .rbl-progress-eta {
        font-size: 11px;
        font-weight: 500;
        color: rgba(93, 202, 165, 0.7);
        font-variant-numeric: tabular-nums;
    }

    .rbl-title-summary {
        font-size: 0.72rem;
        color: rgba(255,255,255,0.5);
        margin-top: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .rbl-more-count {
        color: rgba(255,255,255,0.3);
        font-style: italic;
    }

    .rbl-stage-indicator {
        font-size: 0.65rem;
        color: rgba(201,146,46,0.7);
        margin-top: 2px;
        letter-spacing: 0.02em;
    }

    /* ── KPI chip row ── */
    .rbl-kpi-row {
        display: flex;
        gap: 8px;
    }

    .rbl-kpi-chip {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
        padding: 8px 4px 6px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.03);
        border: 0.5px solid rgba(255, 255, 255, 0.05);
        min-width: 0;
    }

    .rbl-kpi-number {
        font-size: 16px;
        font-weight: 600;
        line-height: 1;
        font-variant-numeric: tabular-nums;
    }

    .rbl-kpi-label {
        font-size: 11px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.32);
        line-height: 1;
        white-space: nowrap;
    }

    /* ── Empty state ── */
    .rbl-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 48px 24px;
        text-align: center;
    }

    .rbl-empty-icon {
        opacity: 0.4;
        margin-bottom: 4px;
    }

    .rbl-empty-title {
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.35);
    }

    .rbl-empty-subtitle {
        font-size: 12px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.2);
        line-height: 1.5;
    }
</style>
