@namespace MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Services.Integration
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Shared
@inject IEngineApiClient ApiClient
@inject IDialogService DialogService

@* ── Reject Confirmation ── *@
<MudMessageBox @ref="_rejectBox"
               Title="Reject Item"
               CancelText="Cancel">
    <MessageContent>
        <MudText>Reject "@(Item?.Title)"? It will be moved to a holding pen and deleted after 30 days unless recovered.</MudText>
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error">Reject</MudButton>
    </YesButton>
</MudMessageBox>

<div class="registry-detail-panel @(_visible ? "open" : "")" @onclick:stopPropagation="true">
    @if (Item is not null)
    {
        @* Header *@
        <div class="detail-header">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="flex: 1; min-width: 0;">
                @if (!string.IsNullOrEmpty(Item.CoverUrl))
                {
                    <MudImage Src="@Item.CoverUrl" Width="48" Height="72"
                              ObjectFit="ObjectFit.Cover" Class="rounded"
                              Style="flex-shrink: 0;" />
                }
                <MudStack Spacing="0" Style="min-width: 0; flex: 1;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        @Item.Title
                    </MudText>
                    @if (!string.IsNullOrEmpty(Item.Author))
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                            @Item.Author
                        </MudText>
                    }
                </MudStack>
            </MudStack>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(async () => await OnClose())" Style="flex-shrink: 0;" />
        </div>

        @* Status + Confidence *@
        <div class="detail-section">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudChip T="string" Size="Size.Small"
                         Color="@GetStatusColor(Item.Status)"
                         Variant="Variant.Filled">
                    @Item.Status
                </MudChip>
                @if (Item.Confidence > 0)
                {
                    <MudProgressLinear Value="@(Item.Confidence * 100)" Color="@GetConfidenceColor(Item.Confidence)"
                                       Size="Size.Small" Rounded="true" Style="flex: 1;" />
                    <MudText Typo="Typo.caption">@($"{Item.Confidence:P0}")</MudText>
                }
            </MudStack>
            @if (!string.IsNullOrEmpty(Item.ReviewTrigger))
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="mt-1"
                         Color="Color.Warning">
                    @FormatTrigger(Item.ReviewTrigger)
                </MudChip>
            }
        </div>

        @* Quick Actions *@
        <div class="detail-section">
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Actions</MudText>
            <MudStack Spacing="1">
                @if (Item.Status == "NeedsReview" || Item.ReviewTrigger is not null)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               FullWidth="true" StartIcon="@Icons.Material.Filled.ManageSearch"
                               OnClick="OnFindMatch">Find Match</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               FullWidth="true" StartIcon="@Icons.Material.Filled.RemoveCircleOutline"
                               OnClick="OnReject">Reject</MudButton>
                }
                else if (Item.ReviewTrigger == "Rejected")
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                               FullWidth="true" StartIcon="@Icons.Material.Filled.Restore"
                               OnClick="OnRecover">Recover</MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               FullWidth="true" StartIcon="@Icons.Material.Filled.OpenInNew"
                               OnClick="OnFindMatch">Find Match</MudButton>
                }
            </MudStack>
        </div>

        @* Item History Timeline *@
        <div class="detail-section detail-section--grow">
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">Processing History</MudText>
            @if (_loadingHistory)
            {
                <MudStack AlignItems="AlignItems.Center" Class="py-4">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
                </MudStack>
            }
            else if (_history.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="text-align: center; padding: 16px;">
                    No processing history available yet.
                </MudText>
            }
            else
            {
                <div class="history-timeline">
                    @foreach (var entry in _history)
                    {
                        <div class="timeline-entry">
                            <div class="timeline-dot" style="background: @GetEventColor(entry.EventType);"></div>
                            <div class="timeline-content">
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">@entry.Label</MudText>
                                @if (!string.IsNullOrEmpty(entry.Detail))
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@entry.Detail</MudText>
                                }
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.35); font-size: 0.7rem; margin-top: 2px;">
                                    @FormatTimeAgo(entry.OccurredAt)
                                </MudText>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        @* Empty state *@
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; opacity: 0.4;">
            <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Large" />
            <MudText Typo="Typo.body2" Class="mt-2">Click an item to see details</MudText>
        </div>
    }
</div>

<style>
    .registry-detail-panel {
        position: fixed;
        top: 56px;
        right: 0;
        bottom: 0;
        width: 380px;
        background: rgba(10, 14, 26, 0.95);
        backdrop-filter: blur(16px);
        border-left: 1px solid rgba(255, 255, 255, 0.06);
        display: flex;
        flex-direction: column;
        z-index: 1100;
        transform: translateX(100%);
        transition: transform 0.25s ease;
        overflow: hidden;
    }

    .registry-detail-panel.open {
        transform: translateX(0);
    }

    .detail-header {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        flex-shrink: 0;
    }

    .detail-section {
        padding: 12px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        flex-shrink: 0;
    }

    .detail-section--grow {
        flex: 1;
        overflow-y: auto;
        flex-shrink: 1;
    }

    .history-timeline {
        position: relative;
        padding-left: 20px;
    }

    .history-timeline::before {
        content: '';
        position: absolute;
        left: 6px;
        top: 8px;
        bottom: 8px;
        width: 2px;
        background: rgba(255, 255, 255, 0.08);
    }

    .timeline-entry {
        position: relative;
        padding-bottom: 16px;
    }

    .timeline-entry:last-child {
        padding-bottom: 0;
    }

    .timeline-dot {
        position: absolute;
        left: -17px;
        top: 4px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid rgba(10, 14, 26, 0.95);
    }

    .timeline-content {
        padding-left: 4px;
    }
</style>

@code {
    [Parameter] public RegistryItemViewModel? Item { get; set; }
    [Parameter] public EventCallback OnCloseRequested { get; set; }
    [Parameter] public EventCallback OnItemChanged { get; set; }

    private bool _visible;
    private bool _loadingHistory;
    private List<RegistryItemHistoryDto> _history = [];
    private Guid? _lastLoadedEntityId;
    private MudMessageBox? _rejectBox;

    protected override async Task OnParametersSetAsync()
    {
        _visible = Item is not null;

        if (Item is not null && Item.EntityId != _lastLoadedEntityId)
        {
            _lastLoadedEntityId = Item.EntityId;
            await LoadHistoryAsync();
        }
    }

    private async Task LoadHistoryAsync()
    {
        if (Item is null) return;

        _loadingHistory = true;
        StateHasChanged();

        try
        {
            _history = await ApiClient.GetItemHistoryAsync(Item.EntityId);
        }
        catch
        {
            _history = [];
        }

        _loadingHistory = false;
        StateHasChanged();
    }

    private async Task OnClose()
    {
        _visible = false;
        StateHasChanged();
        await OnCloseRequested.InvokeAsync();
    }

    private async Task OnFindMatch()
    {
        if (Item is null) return;

        var parameters = new DialogParameters<FindMatchDialog>
        {
            { x => x.EntityId, Item.EntityId },
            { x => x.CurrentTitle, Item.Title },
            { x => x.CurrentAuthor, Item.Author },
            { x => x.InitialMediaType, Item.MediaType }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            BackdropClick = false,
            NoHeader = true
        };

        var dialog = await DialogService.ShowAsync<FindMatchDialog>("Find Match", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadHistoryAsync();
            await OnItemChanged.InvokeAsync();
        }
    }

    private async Task OnReject()
    {
        if (Item is null || _rejectBox is null) return;

        var confirmed = await _rejectBox.ShowAsync();
        if (confirmed != true) return;

        try
        {
            await ApiClient.RejectRegistryItemAsync(Item.EntityId);
            await LoadHistoryAsync();
            await OnItemChanged.InvokeAsync();
        }
        catch { }
    }

    private async Task OnRecover()
    {
        if (Item is null) return;

        try
        {
            await ApiClient.RecoverRegistryItemAsync(Item.EntityId);
            await LoadHistoryAsync();
            await OnItemChanged.InvokeAsync();
        }
        catch { }
    }

    private static string FormatTrigger(string trigger) => trigger switch
    {
        "AuthorityMatchFailed"  => "No Match Found",
        "MultipleQidMatches"    => "Multiple Matches",
        "LowConfidence"         => "Low Confidence",
        "AmbiguousMediaType"    => "Ambiguous Type",
        "Rejected"              => "Rejected",
        "UserFixMatch"          => "Re-review Requested",
        "ContentMatchFailed"    => "Content Match Failed",
        "MissingQid"            => "Missing QID",
        "StagedUnidentifiable"  => "Unidentifiable",
        "PlaceholderTitle"      => "Placeholder Title",
        "ArtworkUnconfirmed"    => "Artwork Unconfirmed",
        "LanguageMismatch"      => "Language Mismatch",
        "MetadataConflict"      => "Metadata Conflict",
        _                       => trigger
    };

    private static Color GetStatusColor(string status) => status switch
    {
        "NeedsReview"   => Color.Warning,
        "Rejected"      => Color.Error,
        "Edited"        => Color.Info,
        "Staging"       => Color.Default,
        _               => Color.Success
    };

    private static Color GetConfidenceColor(double confidence) => confidence switch
    {
        >= 0.85 => Color.Success,
        >= 0.60 => Color.Warning,
        _       => Color.Error
    };

    private static string GetEventColor(string eventType) => eventType switch
    {
        "FileDetected"         => "#4A90D9",
        "MetadataExtracted"    => "#4A90D9",
        "ConfidenceScored"     => "#C9922E",
        "WikidataMatched"      => "#4CAF50",
        "WikidataMatchFailed"  => "#EF5350",
        "CoverArtFound"        => "#4CAF50",
        "CoverArtNotFound"     => "#EF5350",
        "PersonLinked"         => "#4CAF50",
        "Staged"               => "#C9922E",
        "Promoted"             => "#4CAF50",
        "MetadataUpdated"      => "#4CAF50",
        "UserEdited"           => "#4A90D9",
        "Rejected"             => "#EF5350",
        "Recovered"            => "#4CAF50",
        "ReviewCreated"        => "#C9922E",
        "ReviewResolved"       => "#4CAF50",
        "HydrationStarted"     => "#4A90D9",
        "HydrationCompleted"   => "#4CAF50",
        "RetailEnriched"       => "#4CAF50",
        "RetailEnrichFailed"   => "#EF5350",
        _                      => "rgba(255,255,255,0.3)"
    };

    private static string FormatTimeAgo(DateTimeOffset occurredAt)
    {
        var diff = DateTimeOffset.UtcNow - occurredAt;
        if (diff.TotalSeconds < 60) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return occurredAt.ToString("MMM d, yyyy");
    }
}
