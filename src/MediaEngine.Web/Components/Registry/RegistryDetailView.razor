@using MediaEngine.Web.Components.Registry
@inject IJSRuntime JS

@if (Loading)
{
    <div class="rdv-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
        <span>Loading detail…</span>
    </div>
}
else if (Detail is null)
{
    <div class="rdv-empty">
        <MudIcon Icon="@Icons.Material.Outlined.InsertDriveFile" Style="font-size: 3rem; opacity: 0.15;" />
        <span style="color: rgba(255,255,255,0.25); font-size: 0.85rem; margin-top: 8px;">Select an item to inspect</span>
    </div>
}
else
{
    <div class="rdv-hero" style="@GetHeroStyle(Detail.HeroUrl, Detail.CoverUrl)">
        <div class="rdv-hero-overlay"></div>
    </div>

    @* ── Metadata Header ── *@
    <div class="rdv-header">
        @* Cover + title side by side *@
        <div class="rdv-header-top">
            @* Cover art thumbnail *@
            @if (!string.IsNullOrEmpty(Detail.CoverUrl))
            {
                <img src="@Detail.CoverUrl" alt="Cover art" class="rdv-cover-thumb" loading="lazy" />
            }
            else
            {
                <div class="rdv-cover-thumb-placeholder">
                    <MudIcon Icon="@RegistryHelpers.GetMediaTypeIcon(Detail.MediaType)"
                             Style="font-size: 2rem; opacity: 0.2; color: #fff;" />
                </div>
            }

            @* Title + sub-row stacked next to the thumbnail *@
            <div class="rdv-header-text">
                <div class="rdv-title-row">
                    <span class="rdv-title">@Detail.Title</span>
                    @if (!string.IsNullOrEmpty(Detail.WikidataQid))
                    {
                        <span class="rdv-qid-chip">@Detail.WikidataQid</span>
                    }
                </div>

                <div class="rdv-sub-row">
                    <MudIcon Icon="@RegistryHelpers.GetMediaTypeIcon(Detail.MediaType)"
                             Size="Size.Small"
                             Style="color: rgba(255,255,255,0.4); margin-right: 4px;" />
                    <span class="rdv-sub-text">@RegistryHelpers.FormatMediaType(Detail.MediaType)</span>
                    @if (!string.IsNullOrEmpty(Detail.Year))
                    {
                        <span class="rdv-sub-sep">·</span>
                        <span class="rdv-sub-text">@Detail.Year</span>
                    }
                    @if (!string.IsNullOrEmpty(Detail.Author))
                    {
                        <span class="rdv-sub-sep">·</span>
                        <span class="rdv-sub-text">@Detail.Author</span>
                    }
                </div>

                <div class="rdv-confidence-row">
                    <div class="rdv-confidence-bar-track">
                        <div class="rdv-confidence-bar-fill"
                             style="width: @((int)(Detail.Confidence * 100))%; background: @RegistryHelpers.GetConfidenceHexColor(Detail.Confidence);"></div>
                    </div>
                    <span class="rdv-confidence-label" style="color: @RegistryHelpers.GetConfidenceHexColor(Detail.Confidence);">
                        @RegistryHelpers.GetConfidenceLabel(Detail.Confidence) @((int)(Detail.Confidence * 100))%
                    </span>
                </div>
            </div>
        </div>

        @* ── Threshold Indicator ── *@
        <div class="rdv-threshold-row">
            @if (Detail.Confidence >= 0.85)
            {
                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small"
                         Style="color: #4CAF50; font-size: 0.85rem;" />
                <span style="color: #4CAF50; font-size: 0.72rem; font-weight: 500;">Above threshold</span>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Outlined.Warning" Size="Size.Small"
                         Style="color: #EAB308; font-size: 0.85rem;" />
                <span style="color: #EAB308; font-size: 0.72rem; font-weight: 500;">Review required — Below threshold (85%)</span>
            }
        </div>

        @* ── Match Signals ── *@
        <div class="rdv-match-signals">
            @foreach (var signal in GetMatchSignals())
            {
                <span class="rdv-signal-chip" style="@signal.Style">
                    <MudIcon Icon="@signal.Icon" Style="font-size: 0.7rem;" />
                    @signal.Label
                </span>
            }
        </div>

        <div class="rdv-actions-row">
            @if (Item?.ReviewItemId is not null)
            {
                <button class="rdv-btn rdv-btn-approve" @onclick="OnApprove">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small" />
                    Approve
                </button>
            }
            <button class="rdv-btn rdv-btn-rematch" @onclick="OnRematch">
                <MudIcon Icon="@Icons.Material.Outlined.Refresh" Size="Size.Small" />
                Re-match
            </button>
            <button class="rdv-btn rdv-btn-remove" @onclick="OnRemove">
                <MudIcon Icon="@Icons.Material.Outlined.DeleteOutline" Size="Size.Small" />
                Remove
            </button>
        </div>
    </div>

    @* ── Tab Bar ── *@
    <div class="rdv-tab-bar">
        <button class="rdv-tab @(_activeTab == "metadata" ? "rdv-tab-active" : "")"
                @onclick="@(() => _activeTab = "metadata")">
            <MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" Style="margin-right: 4px;" />
            Metadata
        </button>
        <button class="rdv-tab @(_activeTab == "claims" ? "rdv-tab-active" : "")"
                @onclick="@(() => _activeTab = "claims")">
            <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Size="Size.Small" Style="margin-right: 4px;" />
            Sources
            @if (Detail?.ClaimHistory?.Count > 0)
            {
                <span class="rdv-tab-badge">@Detail.ClaimHistory.Count</span>
            }
        </button>
        <button class="rdv-tab @(_activeTab == "images" ? "rdv-tab-active" : "")"
                @onclick="@(() => _activeTab = "images")">
            <MudIcon Icon="@Icons.Material.Outlined.Image" Size="Size.Small" Style="margin-right: 4px;" />
            Images
        </button>
    </div>

    @* ── Tab Content ── *@
    <div class="rdv-tab-content">

        @if (_activeTab == "metadata")
        {
            @* ── Section header: unverified vs confirmed ── *@
            @if (IsUnmatched)
            {
                <div class="rdv-unverified-banner">
                    <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Style="color: #EAB308;" />
                    <span>File Metadata (unverified) — use search to link to Wikidata</span>
                </div>
            }

            @* ── Core Metadata Fields ── *@
            <div class="rdv-section">
                @MetaRow("Author",          Detail!.Author)
                @MetaRow("Narrator",        Detail.Narrator)
                @MetaRow("Director",        Detail.Director)
                @MetaRow("Cast",            Detail.Cast)
                @MetaRow("Language",        Detail.Language)
                @MetaRow("Release",         Detail.Year)
                @MetaRow("Runtime",         Detail.Runtime)
                @MetaRow("Genre",           Detail.Genre)
                @MetaRow("Rating",          Detail.Rating)
                @if (!string.IsNullOrEmpty(Detail.Series))
                {
                    <div class="rdv-field-row">
                        <span class="rdv-field-label">Series</span>
                        <span class="rdv-field-value">
                            @Detail.Series
                            @if (!string.IsNullOrEmpty(Detail.SeriesPosition))
                            {
                                <text> <span class="rdv-series-pos">#@Detail.SeriesPosition</span></text>
                            }
                        </span>
                    </div>
                }
                @MetaRow("Match Source",    Detail.MatchSource)
                @MetaRow("Match Method",    Detail.MatchMethod)
            </div>

            @* ── Bridge Identifiers ── *@
            @if (Detail.BridgeIds.Count > 0)
            {
                <div class="rdv-section-header">Bridge Identifiers</div>
                <div class="rdv-section">
                    <div class="rdv-bridge-chips">
                        @foreach (var kv in Detail.BridgeIds)
                        {
                            <div class="rdv-bridge-chip">
                                <span class="rdv-bridge-key">@RegistryHelpers.FormatBridgeKey(kv.Key)</span>
                                <span class="rdv-bridge-val">@kv.Value</span>
                                <button class="rdv-copy-btn" @onclick="@(() => CopyToClipboard(kv.Value))"
                                        title="Copy">
                                    <MudIcon Icon="@Icons.Material.Outlined.ContentCopy" Style="font-size: 0.7rem;" />
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }

            @* ── Review Reason ── *@
            @if (!string.IsNullOrEmpty(Detail.ReviewTrigger))
            {
                <div class="rdv-section-header">Review Reason</div>
                <div class="rdv-section rdv-review-reason" style="border-left: 3px solid @RegistryHelpers.FormatReviewTrigger(Detail.ReviewTrigger).Color;">
                    <div class="rdv-review-trigger-row">
                        <MudIcon Icon="@RegistryHelpers.FormatReviewTrigger(Detail.ReviewTrigger).Icon"
                                 Style="@($"color: {RegistryHelpers.FormatReviewTrigger(Detail.ReviewTrigger).Color}; font-size: 1rem;")" />
                        <span style="color: @RegistryHelpers.FormatReviewTrigger(Detail.ReviewTrigger).Color; font-weight: 600; font-size: 0.8rem;">
                            @RegistryHelpers.FormatReviewTrigger(Detail.ReviewTrigger).Label
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(Detail.ReviewDetail))
                    {
                        <p class="rdv-review-detail">@Detail.ReviewDetail</p>
                    }
                </div>
            }

            @* ── Description ── *@
            @if (!string.IsNullOrEmpty(Detail.Description))
            {
                <div class="rdv-section-header">Description</div>
                <div class="rdv-section">
                    <p class="rdv-description">@Detail.Description</p>
                </div>
            }

            @* ── Original Input ── *@
            <div class="rdv-section-header">Original Input</div>
            <div class="rdv-section">
                @MetaRow("Filename",    Detail.FileName)
                @MetaRow("Path",        Detail.FilePath)
                @if (!string.IsNullOrEmpty(Detail.ContentHash))
                {
                    <div class="rdv-field-row">
                        <span class="rdv-field-label">Hash</span>
                        <span class="rdv-field-value rdv-mono">
                            @Detail.ContentHash[..Math.Min(16, Detail.ContentHash.Length)]…
                        </span>
                    </div>
                }
                @if (Detail.FileSizeBytes.HasValue)
                {
                    <div class="rdv-field-row">
                        <span class="rdv-field-label">Size</span>
                        <span class="rdv-field-value">@FormatBytes(Detail.FileSizeBytes.Value)</span>
                    </div>
                }
            </div>

        }
        else if (_activeTab == "claims")
        {
            @* ── Metadata Sources (Claims) Tab ── *@
            @if (Detail?.ClaimHistory is null || Detail.ClaimHistory.Count == 0)
            {
                <div class="rdv-images-placeholder">
                    <MudIcon Icon="@Icons.Material.Outlined.HorizontalRule"
                             Style="font-size: 2.5rem; opacity: 0.2; margin-bottom: 12px;" />
                    <span>No claim records found for this item</span>
                </div>
            }
            else
            {
                @* Group claims by provider, then render each group as an expansion panel *@
                var grouped = Detail.ClaimHistory
                    .GroupBy(c => c.ProviderId)
                    .OrderBy(g => GetProviderSortOrder(g.Key))
                    .ToList();

                foreach (var group in grouped)
                {
                    var providerName = GetProviderName(group.Key);
                    var providerIcon = GetProviderIcon(group.Key);
                    var providerColor = GetProviderColor(group.Key);
                    var claimsInGroup = group.OrderBy(c => c.ClaimKey).ToList();

                    <div class="rdv-claims-group">
                        <div class="rdv-claims-group-header">
                            <MudIcon Icon="@providerIcon"
                                     Style="@($"font-size: 0.9rem; color: {providerColor};")" />
                            <span class="rdv-claims-group-name" style="color: @providerColor;">@providerName</span>
                            <span class="rdv-claims-group-count">@claimsInGroup.Count field@(claimsInGroup.Count == 1 ? "" : "s")</span>
                        </div>

                        <div class="rdv-claims-table">
                            @foreach (var claim in claimsInGroup)
                            {
                                var truncatedValue = claim.ClaimValue.Length > 80
                                    ? claim.ClaimValue[..80] + "…"
                                    : claim.ClaimValue;
                                var confidencePct = (int)(claim.Confidence * 100);
                                var confidenceColor = claim.Confidence >= 0.85 ? "#4CAF50"
                                    : claim.Confidence >= 0.60 ? "#EAB308"
                                    : "#EF5350";

                                <div class="rdv-claim-row @(claim.IsUserLocked ? "rdv-claim-row--locked" : "")">
                                    <span class="rdv-claim-key">@FormatClaimKey(claim.ClaimKey)</span>
                                    <span class="rdv-claim-value" title="@claim.ClaimValue">@truncatedValue</span>
                                    <span class="rdv-claim-confidence" style="color: @confidenceColor; border-color: @confidenceColor + '40';">
                                        @confidencePct%
                                    </span>
                                    @if (claim.IsUserLocked)
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.Lock"
                                                 Style="font-size: 0.75rem; color: #C9922E; flex-shrink: 0;"
                                                 Title="User locked" />
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        }
        else
        {
            <div class="rdv-images-placeholder">
                <MudIcon Icon="@Icons.Material.Outlined.ImageSearch"
                         Style="font-size: 2.5rem; opacity: 0.2; margin-bottom: 12px;" />
                <span>Image management coming in Phase 4</span>
            </div>
        }

    </div>
}

@code {
    [Parameter] public RegistryItemDetailViewModel? Detail { get; set; }
    [Parameter] public RegistryItemViewModel?       Item   { get; set; }
    [Parameter] public bool                         Loading { get; set; }
    [Parameter] public Guid?                        SearchPanelEntityId { get; set; }
    [Parameter] public EventCallback                OnApprove    { get; set; }
    [Parameter] public EventCallback                OnRemove     { get; set; }
    [Parameter] public EventCallback<ApplyMatchResponseDto> OnMatchApplied { get; set; }
    [Parameter] public EventCallback                OnRematch    { get; set; }

    private string _activeTab = "metadata";

    /// <summary>True when the item has no Wikidata QID — shows the "unverified" banner.</summary>
    private bool IsUnmatched => Item?.ReviewItemId is not null
        || string.IsNullOrEmpty(Detail?.WikidataQid);

    private static string GetHeroStyle(string? heroUrl, string? coverUrl)
    {
        var url = heroUrl ?? coverUrl;
        return string.IsNullOrEmpty(url)
            ? "background: linear-gradient(135deg, #0a0a0a, #1a1a2e);"
            : $"background-image: url('{url}'); background-size: cover; background-position: center;";
    }

    private static RenderFragment MetaRow(string label, string? value) => builder =>
    {
        if (string.IsNullOrEmpty(value)) return;
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "rdv-field-row");
            builder.OpenElement(2, "span");
            builder.AddAttribute(3, "class", "rdv-field-label");
            builder.AddContent(4, label);
            builder.CloseElement();
            builder.OpenElement(5, "span");
            builder.AddAttribute(6, "class", "rdv-field-value");
            builder.AddContent(7, value);
            builder.CloseElement();
        builder.CloseElement();
    };

    private async Task CopyToClipboard(string text)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", text); }
        catch { /* clipboard may be unavailable in some browsers */ }
    }

    private static string FormatBytes(long bytes) => bytes switch
    {
        >= 1_073_741_824 => $"{bytes / 1_073_741_824.0:F1} GB",
        >= 1_048_576     => $"{bytes / 1_048_576.0:F1} MB",
        >= 1_024         => $"{bytes / 1_024.0:F1} KB",
        _                => $"{bytes} B"
    };

    // ── Claims / Metadata Sources helpers ───────────────────────────────────────

    // Known provider GUIDs mapped to display names
    private static readonly Dictionary<Guid, string> ProviderNames = new()
    {
        { Guid.Parse("a1b2c3d4-e5f6-4700-8900-0a1b2c3d4e5f"), "File Metadata" },
        { Guid.Parse("b3000003-d000-4000-8000-000000000004"), "Wikidata" },
        { Guid.Parse("b1000001-e000-4000-8000-000000000001"), "Apple API" },
        { Guid.Parse("b2000002-f000-4000-8000-000000000002"), "Open Library" },
        { Guid.Parse("b4000004-1000-4000-8000-000000000003"), "Google Books" },
    };

    private static string GetProviderName(Guid providerId)
        => ProviderNames.TryGetValue(providerId, out var name) ? name : "Provider";

    private static string GetProviderIcon(Guid providerId) => GetProviderName(providerId) switch
    {
        "File Metadata"  => Icons.Material.Outlined.InsertDriveFile,
        "Wikidata"       => Icons.Material.Outlined.Public,
        "Apple API"      => Icons.Material.Outlined.PhoneIphone,
        "Open Library"   => Icons.Material.Outlined.MenuBook,
        "Google Books"   => Icons.Material.Outlined.Book,
        _                => Icons.Material.Outlined.Source,
    };

    private static string GetProviderColor(Guid providerId) => GetProviderName(providerId) switch
    {
        "File Metadata" => "rgba(255,255,255,0.55)",
        "Wikidata"      => "#42A5F5",
        "Apple API"     => "#A8A8A8",
        "Open Library"  => "#81C784",
        "Google Books"  => "#EF5350",
        _               => "rgba(255,255,255,0.4)",
    };

    private static int GetProviderSortOrder(Guid providerId) => GetProviderName(providerId) switch
    {
        "File Metadata" => 0,
        "Wikidata"      => 1,
        "Apple API"     => 2,
        "Open Library"  => 3,
        "Google Books"  => 4,
        _               => 99,
    };

    /// <summary>Converts a snake_case claim key to a human-readable label.</summary>
    private static string FormatClaimKey(string key)
    {
        if (string.IsNullOrEmpty(key)) return key;
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo
            .ToTitleCase(key.Replace('_', ' ').Replace('-', ' '));
    }

    private record MatchSignal(string Label, string Icon, string Style);

    private List<MatchSignal> GetMatchSignals()
    {
        if (Detail is null) return [];
        var signals = new List<MatchSignal>();

        // Title always exists
        signals.Add(new("Title match", Icons.Material.Outlined.Check,
            "background: rgba(76,175,80,0.12); color: #4CAF50; border: 1px solid rgba(76,175,80,0.25);"));

        // Author/Director
        if (!string.IsNullOrEmpty(Detail.Author))
            signals.Add(new("Author match", Icons.Material.Outlined.Check,
                "background: rgba(76,175,80,0.12); color: #4CAF50; border: 1px solid rgba(76,175,80,0.25);"));
        else if (!string.IsNullOrEmpty(Detail.Director))
            signals.Add(new("Director match", Icons.Material.Outlined.Check,
                "background: rgba(76,175,80,0.12); color: #4CAF50; border: 1px solid rgba(76,175,80,0.25);"));
        else
            signals.Add(new("Author missing", Icons.Material.Outlined.Remove,
                "background: rgba(239,83,80,0.12); color: #EF5350; border: 1px solid rgba(239,83,80,0.25);"));

        // Year
        if (!string.IsNullOrEmpty(Detail.Year))
            signals.Add(new("Year match", Icons.Material.Outlined.Check,
                "background: rgba(76,175,80,0.12); color: #4CAF50; border: 1px solid rgba(76,175,80,0.25);"));
        else
            signals.Add(new("Year missing", Icons.Material.Outlined.Remove,
                "background: rgba(234,179,8,0.12); color: #EAB308; border: 1px solid rgba(234,179,8,0.25);"));

        // Format confidence based on match method
        if (!string.IsNullOrEmpty(Detail.MatchMethod))
            signals.Add(new($"Format: {Detail.MatchMethod}", Icons.Material.Outlined.Info,
                "background: rgba(66,165,245,0.12); color: #42A5F5; border: 1px solid rgba(66,165,245,0.25);"));

        // Cover art
        if (!string.IsNullOrEmpty(Detail.CoverUrl))
            signals.Add(new("Has cover", Icons.Material.Outlined.Image,
                "background: rgba(76,175,80,0.12); color: #4CAF50; border: 1px solid rgba(76,175,80,0.25);"));
        else
            signals.Add(new("No cover", Icons.Material.Outlined.BrokenImage,
                "background: rgba(239,83,80,0.12); color: #EF5350; border: 1px solid rgba(239,83,80,0.25);"));

        // Wikidata QID
        if (!string.IsNullOrEmpty(Detail.WikidataQid) && !Detail.WikidataQid.StartsWith("NF", StringComparison.Ordinal))
            signals.Add(new("Wikidata linked", Icons.Material.Outlined.Public,
                "background: rgba(76,175,80,0.12); color: #4CAF50; border: 1px solid rgba(76,175,80,0.25);"));
        else if (!string.IsNullOrEmpty(Detail.WikidataQid) && Detail.WikidataQid.StartsWith("NF", StringComparison.Ordinal))
            signals.Add(new("Needs Wikidata link", Icons.Material.Outlined.LinkOff,
                "background: rgba(255,152,0,0.12); color: #FF9800; border: 1px solid rgba(255,152,0,0.25);"));

        return signals;
    }
}

<style>
    /* ── Shell ── */
    .rdv-loading,
    .rdv-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        gap: 8px;
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
    }

    /* ── Hero ── */
    .rdv-hero {
        width: 100%;
        height: 200px;
        position: relative;
        flex-shrink: 0;
    }

    .rdv-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.95));
    }

    /* ── Header (overlaps hero bottom) ── */
    .rdv-header {
        margin-top: -60px;
        padding: 0 18px 14px;
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    /* Cover + title row */
    .rdv-header-top {
        display: flex;
        align-items: flex-end;
        gap: 14px;
    }

    .rdv-cover-thumb {
        width: 72px;
        height: 108px;
        object-fit: cover;
        border-radius: 6px;
        flex-shrink: 0;
        box-shadow: 0 4px 16px rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .rdv-cover-thumb-placeholder {
        width: 72px;
        height: 108px;
        border-radius: 6px;
        flex-shrink: 0;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .rdv-header-text {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 5px;
        padding-bottom: 4px;
    }

    .rdv-title-row {
        display: flex;
        align-items: baseline;
        gap: 8px;
        flex-wrap: wrap;
    }

    .rdv-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #fff;
        line-height: 1.2;
    }

    .rdv-qid-chip {
        font-size: 0.65rem;
        font-family: monospace;
        color: rgba(255,255,255,0.4);
        background: rgba(255,255,255,0.06);
        padding: 2px 6px;
        border-radius: 4px;
        white-space: nowrap;
        align-self: center;
    }

    .rdv-sub-row {
        display: flex;
        align-items: center;
        gap: 0;
        flex-wrap: wrap;
    }

    .rdv-sub-text {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.5);
    }

    .rdv-sub-sep {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.2);
        padding: 0 5px;
    }

    /* ── Confidence ── */
    .rdv-confidence-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 2px;
    }

    .rdv-confidence-bar-track {
        flex: 1;
        height: 3px;
        background: rgba(255,255,255,0.08);
        border-radius: 2px;
        overflow: hidden;
        max-width: 160px;
    }

    .rdv-confidence-bar-fill {
        height: 100%;
        border-radius: 2px;
