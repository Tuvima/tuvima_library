    .rtl-card {
        background: rgba(10, 10, 18, 0.85);
        border: 0.5px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 10px 12px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .rtl-card--report {
        border-left: 3px solid rgba(239, 83, 80, 0.40);
    }

    .rtl-card-title {
        font-size: 13px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.80);
        line-height: 1.3;
    }

    .rtl-card-detail-quote {
        font-size: 11px;
        font-weight: 400;
        font-style: italic;
        color: rgba(255, 255, 255, 0.35);
        line-height: 1.5;
        padding-left: 8px;
        border-left: 2px solid rgba(255, 255, 255, 0.08);
    }

    /* ── Link button ── */
    .rtl-link-btn {
        background: none;
        border: 0.5px solid rgba(74, 144, 217, 0.35);
        border-radius: 6px;
        padding: 2px 8px;
        font-family: 'Montserrat', sans-serif;
        font-size: 10px;
        font-weight: 500;
        color: rgba(74, 144, 217, 0.80);
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.15s ease, border-color 0.15s ease;
        align-self: flex-start;
    }

    .rtl-link-btn:hover {
        background: rgba(74, 144, 217, 0.08);
        border-color: rgba(74, 144, 217, 0.55);
    }
</style>
