        font-size: 13px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.20);
    }

    /* ── Timeline ── */
    .rtl-timeline {
        display: flex;
        flex-direction: column;
    }

    .rtl-day-header {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        color: rgba(255, 255, 255, 0.30);
        margin: 20px 0 12px 38px;
    }

    .rtl-day-header:first-child {
        margin-top: 0;
    }

    /* ── Event row ── */
    .rtl-event {
        display: flex;
        gap: 12px;
        min-height: 48px;
    }

    .rtl-event-rail {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 22px;
        flex-shrink: 0;
    }

    .rtl-dot {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        border: 2px solid;
    }

