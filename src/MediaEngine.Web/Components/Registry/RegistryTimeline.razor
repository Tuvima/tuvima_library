@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject UIOrchestratorService Orchestrator

<div class="rtl-container">

    @* ── Filter chips ── *@
    <div class="rtl-filters">
        @foreach (var filter in _filterOptions)
        {
            var isActive = _activeFilter == filter.Key;
            <button class="rtl-filter-chip @(isActive ? "rtl-filter-chip--active" : "")"
                    style="@(isActive ? $"background: {filter.Value.Color}20; border-color: {filter.Value.Color}55; color: {filter.Value.Color};" : "")"
                    @onclick="() => SetFilter(filter.Key)">
                <MudIcon Icon="@filter.Value.Icon" Style="font-size: 12px;" />
                <span>@filter.Value.Label</span>
            </button>
        }
    </div>

    @* ── Timeline ── *@
    @if (_loading)
    {
        <div class="rtl-loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                 Style="width: 20px; height: 20px; color: rgba(255,255,255,0.25);" />
        </div>
    }
    else if (_timelineGroups.Count == 0)
    {
        <div class="rtl-empty">
            <MudIcon Icon="@Icons.Material.Outlined.Timeline" Style="font-size: 32px; color: rgba(255,255,255,0.12);" />
            <span class="rtl-empty-text">No activity yet</span>
        </div>
    }
    else
    {
        <div class="rtl-timeline">
            @foreach (var group in _timelineGroups)
            {
                <div class="rtl-day-header">@group.Label</div>

                @foreach (var item in group.Items)
                {
                    @if (item.Type == TimelineItemType.Batch)
                    {
                        @* ── Batch card ── *@
                        var batch = item.Batch!;
                        var reviewCount = batch.FilesReview + batch.FilesNoMatch + batch.FilesFailed;
                        <div class="rtl-event">
                            <div class="rtl-event-rail">
                                <div class="rtl-dot" style="background: #4A90D920; border-color: #4A90D955;">
                                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Style="font-size: 10px; color: #4A90D9;" />
                                </div>
                                <div class="rtl-connector"></div>
                            </div>
                            <div class="rtl-event-content">
                                <div class="rtl-event-header">
                                    <span class="rtl-event-title" style="color: #4A90D9;">
                                        @RegistryHelpers.FormatBatchSubtitle(batch.FilesTotal, batch.Category, batch.SourcePath)
                                    </span>
                                    <span class="rtl-event-time">
                                        @RegistryHelpers.FormatBatchTimestamp(batch.StartedAt)
                                        @if (batch.CompletedAt is not null)
                                        {
                                            <text> · @RegistryHelpers.FormatBatchDuration(batch.StartedAt, batch.CompletedAt)</text>
                                        }
                                    </span>
                                </div>
                                <div class="rtl-batch-card">
                                    <div class="rtl-batch-kpis">
                                        <div class="rtl-batch-kpi">
                                            <span class="rtl-batch-kpi-number" style="color: #5DCAA5;">@batch.FilesRegistered</span>
                                            <span class="rtl-batch-kpi-label">Registered</span>
                                        </div>
                                        @if (reviewCount > 0)
                                        {
                                            <div class="rtl-batch-kpi">
                                                <span class="rtl-batch-kpi-number" style="color: #EF9F27;">@reviewCount</span>
                                                <span class="rtl-batch-kpi-label">In Review</span>
                                            </div>
                                        }
                                    </div>
                                    @if (reviewCount > 0)
                                    {
                                        <div class="rtl-batch-footer">
                                            <span class="rtl-batch-review-hint">
                                                @reviewCount @(reviewCount == 1 ? "item" : "items") still @(reviewCount == 1 ? "needs" : "need") review
                                            </span>
                                            <button class="rtl-link-btn" @onclick="() => OnOpenInListView.InvokeAsync(batch.Id)">
                                                View activity →
                                            </button>
                                        </div>
                                    }
                                    else if (batch.CompletedAt is not null)
                                    {
                                        <div class="rtl-batch-footer">
                                            <span class="rtl-batch-resolved">
                                                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 11px; color: #5DCAA5;" />
                                                All items resolved
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else if (item.Type == TimelineItemType.AggregatedBatches)
                    {
                        @* ── Aggregated batch summary (weekly/monthly) ── *@
                        var agg = item.Aggregation!;
                        var aggReview = agg.TotalReview + agg.TotalNoMatch + agg.TotalFailed;
                        <div class="rtl-event">
                            <div class="rtl-event-rail">
                                <div class="rtl-dot" style="background: #4A90D920; border-color: #4A90D955;">
                                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Style="font-size: 10px; color: #4A90D9;" />
                                </div>
                                <div class="rtl-connector"></div>
                            </div>
                            <div class="rtl-event-content">
                                <div class="rtl-event-header">
                                    <span class="rtl-event-title" style="color: #4A90D9;">
                                        @($"{agg.TotalFiles:N0}") items added across @agg.BatchCount @(agg.BatchCount == 1 ? "batch" : "batches")
                                    </span>
                                </div>
                                <div class="rtl-batch-card">
                                    <div class="rtl-batch-kpis">
                                        <div class="rtl-batch-kpi">
                                            <span class="rtl-batch-kpi-number" style="color: #5DCAA5;">@agg.TotalRegistered</span>
                                            <span class="rtl-batch-kpi-label">Registered</span>
                                        </div>
                                        @if (aggReview > 0)
                                        {
                                            <div class="rtl-batch-kpi">
                                                <span class="rtl-batch-kpi-number" style="color: #EF9F27;">@aggReview</span>
                                                <span class="rtl-batch-kpi-label">In Review</span>
                                            </div>
                                        }
                                    </div>
                                    @if (aggReview > 0)
                                    {
                                        <div class="rtl-batch-footer">
                                            <span class="rtl-batch-review-hint">
                                                @aggReview @(aggReview == 1 ? "item" : "items") still @(aggReview == 1 ? "needs" : "need") review
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else if (item.Type == TimelineItemType.Report)
                    {
                        @* ── Report (always full detail) ── *@
                        var evt = item.Event!;
                        <div class="rtl-event">
                            <div class="rtl-event-rail">
                                <div class="rtl-dot" style="background: #EF535020; border-color: #EF535055;">
                                    <MudIcon Icon="@Icons.Material.Outlined.Flag" Style="font-size: 10px; color: #EF5350;" />
                                </div>
                                <div class="rtl-connector"></div>
                            </div>
                            <div class="rtl-event-content">
                                <div class="rtl-event-header">
                                    <span class="rtl-event-title" style="color: #EF5350;">Problem reported</span>
                                    <span class="rtl-event-time">@evt.RelativeTime</span>
                                </div>
                                <div class="rtl-card rtl-card--report">
                                    <span class="rtl-card-title">@(evt.HubName ?? "Report")</span>
                                    @if (!string.IsNullOrWhiteSpace(evt.Detail))
                                    {
                                        <span class="rtl-card-detail-quote">@evt.Detail</span>
                                    }
                                    <button class="rtl-link-btn" @onclick="() => OnOpenInListView.InvokeAsync(null)">
                                        Fix match
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                    else if (item.Type == TimelineItemType.CuratorAction)
                    {
                        @* ── Curator action ── *@
                        var evt = item.Event!;
                        <div class="rtl-event">
                            <div class="rtl-event-rail">
                                <div class="rtl-dot" style="background: #5DCAA520; border-color: #5DCAA555;">
                                    <MudIcon Icon="@Icons.Material.Outlined.Verified" Style="font-size: 10px; color: #5DCAA5;" />
                                </div>
                                <div class="rtl-connector"></div>
                            </div>
                            <div class="rtl-event-content">
                                <div class="rtl-event-header">
                                    <span class="rtl-event-title" style="color: #5DCAA5;">@FormatCuratorVerb(evt)</span>
                                    <span class="rtl-event-time">@evt.RelativeTime</span>
                                </div>
                                <span class="rtl-event-detail">@(evt.Detail ?? evt.HubName ?? "Action completed")</span>
                            </div>
                        </div>
                    }
                }
            }
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<Guid?> OnOpenInListView { get; set; }
    [Parameter] public string? FilterCategory { get; set; }

    private bool _loading;
    private string _activeFilter = "all";
    private List<TimelineGroup> _timelineGroups = [];
    private List<IngestionBatchViewModel> _allBatches = [];
    private List<ActivityEntryViewModel> _allCuratorActions = [];
    private List<ActivityEntryViewModel> _allReports = [];

    private readonly Dictionary<string, FilterOption> _filterOptions = new()
    {
        ["all"]       = new("All events",      Icons.Material.Outlined.Timeline,  "rgba(255,255,255,0.55)"),
        ["ingestion"] = new("Ingestion",       Icons.Material.Outlined.Upload,    "#4A90D9"),
        ["reports"]   = new("Reports",         Icons.Material.Outlined.Warning,   "#EF5350"),
        ["curator"]   = new("Curator actions", Icons.Material.Outlined.Verified,  "#5DCAA5"),
    };

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(FilterCategory) && FilterCategory != _activeFilter)
        {
            _activeFilter = FilterCategory;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            // Load batches (primary data source)
            _allBatches = (await Orchestrator.GetIngestionBatchesAsync(200)).ToList();

            // Load only manual curator actions and reports from activity log
            var curatorTypes = new[] {
                "ReviewItemResolved", "MetadataManualOverride",
                "UserReportResolved", "UserReportDismissed"
            };
            var rawCuratorActions = await Orchestrator.GetActivityByTypesAsync(curatorTypes, 200);
            // Filter out auto-resolved events — only show genuinely manual curator actions
            _allCuratorActions = rawCuratorActions
                .Where(a => a.Detail is null || !a.Detail.StartsWith("Auto-resolved", StringComparison.OrdinalIgnoreCase))
                .ToList();

            var reportTypes = new[] { "UserReportSubmitted" };
            _allReports = await Orchestrator.GetActivityByTypesAsync(reportTypes, 200);
        }
        catch
        {
            _allBatches = [];
            _allCuratorActions = [];
            _allReports = [];
        }

        RebuildTimeline();
        _loading = false;
    }

    private void SetFilter(string filter)
    {
        _activeFilter = filter;
        RebuildTimeline();
        StateHasChanged();
    }

    private void RebuildTimeline()
    {
        var now = DateTimeOffset.Now;
        var today = now.Date;
        var sevenDaysAgo = today.AddDays(-7);
        var thirtyDaysAgo = today.AddDays(-30);

        var items = new List<TimelineEntry>();

        // ── Add batches ──
        if (_activeFilter is "all" or "ingestion")
        {
            foreach (var batch in _allBatches)
            {
                var batchDate = batch.StartedAt.ToLocalTime().Date;

                if (batchDate >= sevenDaysAgo)
                {
                    // Last 7 days: individual batch cards
                    items.Add(new TimelineEntry
                    {
                        SortTime = batch.StartedAt,
                        Type = TimelineItemType.Batch,
                        Batch = batch,
                    });
                }
                // Weekly/monthly batches are aggregated below
            }

            // ── Weekly aggregation (8-30 days ago) ──
            var weeklyBatches = _allBatches
                .Where(b => {
                    var d = b.StartedAt.ToLocalTime().Date;
                    return d < sevenDaysAgo && d >= thirtyDaysAgo;
                })
                .GroupBy(b => GetWeekStart(b.StartedAt.ToLocalTime().Date))
                .OrderByDescending(g => g.Key);

            foreach (var weekGroup in weeklyBatches)
            {
                var batchList = weekGroup.ToList();
                items.Add(new TimelineEntry
                {
                    SortTime = new DateTimeOffset(weekGroup.Key, TimeSpan.Zero),
                    Type = TimelineItemType.AggregatedBatches,
                    Aggregation = new BatchAggregation
                    {
                        BatchCount = batchList.Count,
                        TotalFiles = batchList.Sum(b => b.FilesTotal),
                        TotalRegistered = batchList.Sum(b => b.FilesRegistered),
                        TotalReview = batchList.Sum(b => b.FilesReview),
                        TotalNoMatch = batchList.Sum(b => b.FilesNoMatch),
                        TotalFailed = batchList.Sum(b => b.FilesFailed),
                    },
                    GroupLabel = $"WEEK OF {weekGroup.Key:MMMM d}".ToUpperInvariant(),
                });
            }

            // ── Monthly aggregation (older than 30 days) ──
            var monthlyBatches = _allBatches
                .Where(b => b.StartedAt.ToLocalTime().Date < thirtyDaysAgo)
                .GroupBy(b => new DateTime(b.StartedAt.ToLocalTime().Year, b.StartedAt.ToLocalTime().Month, 1))
                .OrderByDescending(g => g.Key);

            foreach (var monthGroup in monthlyBatches)
            {
                var batchList = monthGroup.ToList();
                items.Add(new TimelineEntry
                {
                    SortTime = new DateTimeOffset(monthGroup.Key, TimeSpan.Zero),
                    Type = TimelineItemType.AggregatedBatches,
                    Aggregation = new BatchAggregation
                    {
                        BatchCount = batchList.Count,
                        TotalFiles = batchList.Sum(b => b.FilesTotal),
                        TotalRegistered = batchList.Sum(b => b.FilesRegistered),
                        TotalReview = batchList.Sum(b => b.FilesReview),
                        TotalNoMatch = batchList.Sum(b => b.FilesNoMatch),
                        TotalFailed = batchList.Sum(b => b.FilesFailed),
                    },
                    GroupLabel = monthGroup.Key.ToString("MMMM yyyy").ToUpperInvariant(),
                });
            }
        }

        // ── Add reports (always full detail, regardless of age) ──
        if (_activeFilter is "all" or "reports")
        {
            foreach (var report in _allReports)
            {
                if (DateTimeOffset.TryParse(report.OccurredAt, out var ts))
                {
                    items.Add(new TimelineEntry
                    {
                        SortTime = ts,
                        Type = TimelineItemType.Report,
                        Event = report,
                    });
                }
            }
        }

        // ── Add curator actions (only shown in detail for last 7 days) ──
        if (_activeFilter is "all" or "curator")
        {
            foreach (var action in _allCuratorActions)
            {
                if (DateTimeOffset.TryParse(action.OccurredAt, out var ts))
                {
                    var actionDate = ts.ToLocalTime().Date;
                    if (actionDate >= sevenDaysAgo)
                    {
                        items.Add(new TimelineEntry
                        {
                            SortTime = ts,
                            Type = TimelineItemType.CuratorAction,
                            Event = action,
                        });
                    }
                    // Older curator actions are not shown (low-value historical noise)
                }
            }
        }

        // ── Build groups ──
        _timelineGroups = items
            .OrderByDescending(e => e.SortTime)
            .GroupBy(e => GetGroupKey(e, today, sevenDaysAgo, thirtyDaysAgo))
            .Select(g => new TimelineGroup
            {
                Label = g.First().GroupLabel ?? FormatGroupLabel(g.Key, today),
                Items = g.OrderByDescending(e => e.SortTime)
                         .Select(e => new TimelineItem { Type = e.Type, Batch = e.Batch, Event = e.Event, Aggregation = e.Aggregation })
                         .ToList(),
            })
            .ToList();
    }

    private static string GetGroupKey(TimelineEntry entry, DateTime today, DateTime sevenDaysAgo, DateTime thirtyDaysAgo)
    {
        // Aggregated items provide their own group label
        if (entry.GroupLabel is not null)
            return entry.GroupLabel;

        var date = entry.SortTime.ToLocalTime().Date;
        if (date == today) return "TODAY";
        if (date == today.AddDays(-1)) return "YESTERDAY";
        if (date >= sevenDaysAgo) return date.DayOfWeek.ToString().ToUpperInvariant();
        if (date >= thirtyDaysAgo) return $"WEEK OF {GetWeekStart(date):MMMM d}".ToUpperInvariant();
        return new DateTime(date.Year, date.Month, 1).ToString("MMMM yyyy").ToUpperInvariant();
    }

    private static string FormatGroupLabel(string key, DateTime today) => key;

    private static DateTime GetWeekStart(DateTime date)
    {
        // Monday-based weeks
        var diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.AddDays(-diff);
    }

    private static string FormatCuratorVerb(ActivityEntryViewModel evt) => evt.ActionType switch
    {
        "ReviewItemResolved" => "Review resolved",
        "MetadataManualOverride" => "Metadata updated",
        "UserReportResolved" => "Report resolved",
        "UserReportDismissed" => "Report dismissed",
        _ => "Curator action",
    };

    // ── Data models ──

    private record FilterOption(string Label, string Icon, string Color);

    private enum TimelineItemType { Batch, AggregatedBatches, Report, CuratorAction }

    private sealed class TimelineEntry
    {
        public DateTimeOffset SortTime { get; set; }
        public TimelineItemType Type { get; set; }
        public IngestionBatchViewModel? Batch { get; set; }
        public ActivityEntryViewModel? Event { get; set; }
        public BatchAggregation? Aggregation { get; set; }
        public string? GroupLabel { get; set; }
    }

    private sealed class TimelineItem
    {
        public TimelineItemType Type { get; set; }
        public IngestionBatchViewModel? Batch { get; set; }
        public ActivityEntryViewModel? Event { get; set; }
        public BatchAggregation? Aggregation { get; set; }
    }

    private sealed class TimelineGroup
    {
        public string Label { get; set; } = "";
        public List<TimelineItem> Items { get; set; } = [];
    }

    private sealed class BatchAggregation
    {
        public int BatchCount { get; set; }
        public int TotalFiles { get; set; }
        public int TotalRegistered { get; set; }
        public int TotalReview { get; set; }
        public int TotalNoMatch { get; set; }
        public int TotalFailed { get; set; }
    }
}

<style>
    .rtl-container {
        display: flex;
        flex-direction: column;
        padding: 16px 20px;
        font-family: 'Montserrat', sans-serif;
        max-width: 800px;
    }

    /* ── Filter chips ── */
    .rtl-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 20px;
    }

    .rtl-filter-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: transparent;
        color: rgba(255, 255, 255, 0.45);
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s ease;
        white-space: nowrap;
    }

    .rtl-filter-chip:hover {
        border-color: rgba(255, 255, 255, 0.18);
        color: rgba(255, 255, 255, 0.65);
    }

    .rtl-filter-chip--active {
        font-weight: 500;
    }

