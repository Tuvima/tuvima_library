    .rtl-loading {
        display: flex;
        justify-content: flex-start;
        padding: 48px 0;
    }

    .rtl-empty {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
        padding: 64px 0;
    }

