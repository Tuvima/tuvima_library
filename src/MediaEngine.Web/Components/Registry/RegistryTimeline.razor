@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject UIOrchestratorService Orchestrator

<div class="rtl-container">

    @* ── Filter chips ── *@
    <div class="rtl-filters">
        @foreach (var filter in _filterOptions)
        {
            var isActive = _activeFilter == filter.Key;
            <button class="rtl-filter-chip @(isActive ? "rtl-filter-chip--active" : "")"
                    style="@(isActive ? $"background: {filter.Value.Color}20; border-color: {filter.Value.Color}55; color: {filter.Value.Color};" : "")"
                    @onclick="() => SetFilter(filter.Key)">
                <MudIcon Icon="@filter.Value.Icon" Style="font-size: 12px;" />
                <span>@filter.Value.Label (@filter.Value.Count)</span>
            </button>
        }
    </div>

    @* ── Timeline ── *@
    @if (_loading)
    {
        <div class="rtl-loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                 Style="width: 20px; height: 20px; color: rgba(255,255,255,0.25);" />
        </div>
    }
    else if (_dayGroups.Count == 0)
    {
        <div class="rtl-empty">
            <MudIcon Icon="@Icons.Material.Outlined.Timeline" Style="font-size: 32px; color: rgba(255,255,255,0.12);" />
            <span class="rtl-empty-text">No activity yet</span>
        </div>
    }
    else
    {
        <div class="rtl-timeline">
            @foreach (var dayGroup in _dayGroups)
            {
                <div class="rtl-day-header">@dayGroup.Label</div>

                @foreach (var item in dayGroup.Items)
                {
                    @if (item.IsBatchSummary)
                    {
                        @* ── Batch summary card ── *@
                        var batchEvts = item.BatchEvents!;
                        var mediaAdded = batchEvts.Where(e => e.ActionType == "MediaAdded").ToList();
                        var reviewCreated = batchEvts.Count(e => e.ActionType == "ReviewItemCreated");
                        var hydrated = batchEvts.Count(e => e.ActionType is "HydrationCompleted" or "MetadataHydrated");
                        var firstEvt = batchEvts.First();

                        <div class="rtl-event">
                            <div class="rtl-event-rail">
                                <div class="rtl-dot" style="background: #4A90D920; border-color: #4A90D955;">
                                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Style="font-size: 10px; color: #4A90D9;" />
                                </div>
                                <div class="rtl-connector"></div>
                            </div>
                            <div class="rtl-event-content">
                                <div class="rtl-event-header">
                                    <span class="rtl-event-title" style="color: #4A90D9;">Ingestion batch</span>
                                    <span class="rtl-event-time">@firstEvt.RelativeTime</span>
                                </div>
                                <div class="rtl-batch-summary">
                                    <div class="rtl-batch-counts">
                                        <span class="rtl-batch-stat" style="color: #5DCAA5;">@mediaAdded.Count registered</span>
                                        @if (reviewCreated > 0)
                                        {
                                            <span class="rtl-batch-stat" style="color: #EF9F27;">@reviewCreated need review</span>
                                        }
                                        @if (hydrated > 0)
                                        {
                                            <span class="rtl-batch-stat" style="color: #534AB7;">@hydrated enriched</span>
                                        }
                                    </div>
                                    @* Show up to 4 cover thumbnails *@
                                    <div class="rtl-batch-covers">
                                        @foreach (var added in mediaAdded.Take(6))
                                        {
                                            var rd = added.RichData;
                                            var coverSrc = rd?.CoverUrl ?? rd?.Cover;
                                            @if (!string.IsNullOrEmpty(coverSrc))
                                            {
                                                <img src="@coverSrc" alt="" class="rtl-batch-thumb" loading="lazy"
                                                     onerror="this.style.display='none'" />
                                            }
                                            else
                                            {
                                                <div class="rtl-batch-thumb rtl-batch-thumb--placeholder">
                                                    <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 12px; color: rgba(255,255,255,0.15);" />
                                                </div>
                                            }
                                        }
                                        @if (mediaAdded.Count > 6)
                                        {
                                            <span class="rtl-batch-more">+@(mediaAdded.Count - 6)</span>
                                        }
                                    </div>
                                    @if (reviewCreated > 0)
                                    {
                                        <button class="rtl-link-btn" @onclick="() => OnOpenInListView.InvokeAsync(null)">
                                            Open in list view
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        @* ── Single event ── *@
                        var evt = item.Event!;
                        var category = CategorizeEvent(evt);
                        var catInfo = GetEventInfo(evt);

                        <div class="rtl-event">
                            <div class="rtl-event-rail">
                                <div class="rtl-dot" style="background: @(catInfo.Color)20; border-color: @(catInfo.Color)55;">
                                    <MudIcon Icon="@catInfo.Icon" Style="@($"font-size: 10px; color: {catInfo.Color};")" />
                                </div>
                                <div class="rtl-connector"></div>
                            </div>
                            <div class="rtl-event-content">
                                <div class="rtl-event-header">
                                    <span class="rtl-event-title" style="color: @catInfo.Color;">@catInfo.Verb</span>
                                    <span class="rtl-event-time">@evt.RelativeTime</span>
                                </div>

                                @switch (category)
                                {
                                    case EventCategory.Ingestion:
                                        @RenderIngestionEvent(evt)
                                        break;
                                    case EventCategory.Enrichment:
                                        @RenderEnrichmentEvent(evt)
                                        break;
                                    case EventCategory.Report:
                                        @RenderReportEvent(evt)
                                        break;
                                    case EventCategory.System:
                                        @RenderSystemEvent(evt)
                                        break;
                                    case EventCategory.Curator:
                                        @RenderCuratorEvent(evt)
                                        break;
                                }
                            </div>
                        </div>
                    }
                }
            }
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<Guid?> OnOpenInListView { get; set; }

    private bool _loading;
    private string _activeFilter = "all";
    private List<ActivityEntryViewModel> _allEntries = [];
    private List<DayGroup> _dayGroups = [];

    private Dictionary<string, FilterOption> _filterOptions = new()
    {
        ["all"]         = new("All events",       Icons.Material.Outlined.Timeline,   "rgba(255,255,255,0.55)", 0),
        ["ingestion"]   = new("Ingestion",        Icons.Material.Outlined.Upload,     "#4A90D9", 0),
        ["enrichment"]  = new("Universe",         Icons.Material.Outlined.Public,     "#534AB7", 0),
        ["reports"]     = new("Reports",          Icons.Material.Outlined.Warning,    "#EF5350", 0),
        ["curator"]     = new("Curator actions",  Icons.Material.Outlined.Verified,   "#5DCAA5", 0),
    };

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _allEntries = await Orchestrator.GetRecentActivityAsync(500);
        }
        catch { _allEntries = []; }

        UpdateFilterCounts();
        RebuildDayGroups();
        _loading = false;
    }

    private void SetFilter(string filter)
    {
        _activeFilter = filter;
        RebuildDayGroups();
        StateHasChanged();
    }

    private void UpdateFilterCounts()
    {
        foreach (var key in _filterOptions.Keys.ToList())
        {
            var cat = ParseFilterCategory(key);
            var count = key == "all"
                ? _allEntries.Count
                : _allEntries.Count(e => CategorizeEvent(e) == cat);
            var existing = _filterOptions[key];
            _filterOptions[key] = existing with { Count = count };
        }
    }

    private void RebuildDayGroups()
    {
        var filtered = _activeFilter == "all"
            ? _allEntries
            : _allEntries.Where(e => CategorizeEvent(e) == ParseFilterCategory(_activeFilter)).ToList();

        var now = DateTimeOffset.Now;
        _dayGroups = filtered
            .Where(e => DateTimeOffset.TryParse(e.OccurredAt, out _))
            .GroupBy(e => DateTimeOffset.Parse(e.OccurredAt).LocalDateTime.Date)
            .OrderByDescending(g => g.Key)
            .Select(g => BuildDayGroup(g.Key, g.OrderByDescending(e => e.OccurredAt).ToList(), now.LocalDateTime.Date))
            .ToList();
    }

    private DayGroup BuildDayGroup(DateTime date, List<ActivityEntryViewModel> events, DateTime today)
    {
        var items = new List<TimelineItem>();

        // Group consecutive events by IngestionRunId for batch consolidation
        var batchGroups = new Dictionary<string, List<ActivityEntryViewModel>>();
        var standaloneEvents = new List<ActivityEntryViewModel>();

        foreach (var evt in events)
        {
            if (!string.IsNullOrEmpty(evt.IngestionRunId))
            {
                if (!batchGroups.ContainsKey(evt.IngestionRunId))
                    batchGroups[evt.IngestionRunId] = [];
                batchGroups[evt.IngestionRunId].Add(evt);
            }
            else
            {
                standaloneEvents.Add(evt);
            }
        }

        // Build timeline items: batch summaries for groups with 3+ events, individual otherwise
        var batchSummaryTimes = new Dictionary<string, DateTimeOffset>();
        foreach (var (batchId, batchEvents) in batchGroups)
        {
            if (batchEvents.Count >= 3)
            {
                // Consolidate into a summary card
                items.Add(new TimelineItem
                {
                    IsBatchSummary = true,
                    BatchEvents = batchEvents,
                    SortTime = batchEvents.First().OccurredAt
                });
                batchSummaryTimes[batchId] = DateTimeOffset.TryParse(batchEvents.First().OccurredAt, out var ts)
                    ? ts : DateTimeOffset.UtcNow;
            }
            else
            {
                // Too few to summarize — show individually
                foreach (var evt in batchEvents)
                    standaloneEvents.Add(evt);
            }
        }

        // Add standalone events
        foreach (var evt in standaloneEvents)
        {
            items.Add(new TimelineItem { Event = evt, SortTime = evt.OccurredAt });
        }

        // Sort by time descending
        items.Sort((a, b) => string.Compare(b.SortTime, a.SortTime, StringComparison.Ordinal));

        return new DayGroup
        {
            Label = FormatDayLabel(date, today),
            Items = items
        };
    }

    private static string FormatDayLabel(DateTime date, DateTime today)
    {
        if (date == today) return "TODAY";
        if (date == today.AddDays(-1)) return "YESTERDAY";
        if (date >= today.AddDays(-6)) return date.DayOfWeek.ToString().ToUpperInvariant();
        return date.ToString("MMMM d").ToUpperInvariant();
    }

    // ── Event categorization ──

    private enum EventCategory { Ingestion, Enrichment, Report, Curator, System }

    private static EventCategory CategorizeEvent(ActivityEntryViewModel evt) => evt.ActionType switch
    {
        "FileIngested" or "MediaAdded" or "MediaFailed" or "MediaRemoved"
            or "BatchCreated" or "BatchCompleted" or "BatchFailed"
            or "FileDetected" or "FileHashed" or "FileProcessed" or "FileScored"
            or "EntityChainCreated" or "CoverArtSaved" or "HeroBannerGenerated"
            or "MovedToStaging" or "FileRejected" or "FileExpired"
            or "HydrationEnqueued" or "HydrationStage1Completed" or "HydrationStage2Completed"
            or "MetadataHydrated" or "HydrationCompleted"
            => EventCategory.Ingestion,

        "CharacterEnriched" or "LocationEnriched" or "OrganizationEnriched"
            or "RelationshipDiscovered" or "PersonHydrated" or "NarrativeRootResolved"
            or "LoreDeltaChecked" or "CanonDiscrepancyDetected"
            or "PersonEnriched" or "FictionalEntityEnriched"
            => EventCategory.Enrichment,

        "UserReportSubmitted" or "UserReportResolved" or "UserReportDismissed"
            => EventCategory.Report,

        "ReviewItemResolved" or "MetadataManualOverride" or "ReviewItemCreated"
            or "ReconciliationCompleted"
            => EventCategory.Curator,

        "ServerStarted" or "ActivityPruned" or "SyncCompleted"
            or "CrawlStarted" or "CrawlFinished" or "MetadataRefreshed"
            => EventCategory.System,

        // Default: categorize by heuristic rather than dumping into Curator
        _ => evt.ActionType.Contains("Review") || evt.ActionType.Contains("Manual")
             ? EventCategory.Curator
             : evt.ActionType.Contains("Enrich") || evt.ActionType.Contains("Person") || evt.ActionType.Contains("Universe")
               ? EventCategory.Enrichment
               : EventCategory.System
    };

    private static EventCategory ParseFilterCategory(string filter) => filter switch
    {
        "ingestion"  => EventCategory.Ingestion,
        "enrichment" => EventCategory.Enrichment,
        "reports"    => EventCategory.Report,
        "curator"    => EventCategory.Curator,
        _            => EventCategory.Ingestion // "all" never reaches here
    };

    // ── Per-event info (verb + icon + color) — context-aware labels ──

    private record CategoryInfo(string Verb, string Icon, string Color);

    private static CategoryInfo GetEventInfo(ActivityEntryViewModel evt) => evt.ActionType switch
    {
        "MediaAdded"               => new("File registered",             Icons.Material.Outlined.AddCircleOutline,  "#5DCAA5"),
        "MediaFailed"              => new("File failed",                 Icons.Material.Outlined.ErrorOutline,      "#EF5350"),
        "MediaRemoved"             => new("File removed",                Icons.Material.Outlined.RemoveCircle,      "#B4B2A9"),
        "BatchCreated"             => new("Batch started",               Icons.Material.Outlined.Inventory2,        "#4A90D9"),
        "BatchCompleted"           => new("Batch completed",             Icons.Material.Outlined.CheckCircle,       "#5DCAA5"),
        "HydrationCompleted"       => new("Enrichment complete",         Icons.Material.Outlined.AutoAwesome,       "#534AB7"),
        "MetadataHydrated"         => new("Metadata enriched",           Icons.Material.Outlined.AutoAwesome,       "#534AB7"),
        "HydrationEnqueued"        => new("Queued for enrichment",       Icons.Material.Outlined.Queue,             "#4A90D9"),
        "CoverArtSaved"            => new("Cover art saved",             Icons.Material.Outlined.Image,             "#4A90D9"),
        "HeroBannerGenerated"      => new("Hero banner generated",       Icons.Material.Outlined.Panorama,          "#4A90D9"),
        "MovedToStaging"           => new("Moved to staging",            Icons.Material.Outlined.MoveToInbox,       "#EF9F27"),
        "ReviewItemCreated"        => new("Flagged for review",          Icons.Material.Outlined.RateReview,        "#EF9F27"),
        "ReviewItemResolved"       => new("Review resolved",             Icons.Material.Outlined.CheckCircle,       "#5DCAA5"),
        "PersonHydrated"           => new("Person enriched",             Icons.Material.Outlined.Person,            "#534AB7"),
        "PersonEnriched"           => new("Person enriched",             Icons.Material.Outlined.Person,            "#534AB7"),
        "NarrativeRootResolved"    => new("Universe identified",         Icons.Material.Outlined.AccountTree,       "#534AB7"),
        "UserReportSubmitted"      => new("Problem reported",            Icons.Material.Outlined.Flag,              "#EF5350"),
        "UserReportResolved"       => new("Report resolved",             Icons.Material.Outlined.CheckCircle,       "#5DCAA5"),
        "UserReportDismissed"      => new("Report dismissed",            Icons.Material.Outlined.Close,             "#B4B2A9"),
        "ServerStarted"            => new("Server started",              Icons.Material.Outlined.PowerSettingsNew,   "rgba(255,255,255,0.35)"),
        "ActivityPruned"           => new("Activity pruned",             Icons.Material.Outlined.CleaningServices,  "rgba(255,255,255,0.35)"),
        "ReconciliationCompleted"  => new("Library reconciled",          Icons.Material.Outlined.Sync,              "#5DCAA5"),
        _                          => new(HumanizeActionType(evt.ActionType), Icons.Material.Outlined.Info,          "rgba(255,255,255,0.40)")
    };

    private static string HumanizeActionType(string actionType)
    {
        // Convert "SomeActionType" → "Some action type"
        var sb = new System.Text.StringBuilder();
        foreach (var c in actionType)
        {
            if (char.IsUpper(c) && sb.Length > 0) sb.Append(' ');
            sb.Append(sb.Length == 0 ? char.ToUpper(c) : char.ToLower(c));
        }
        return sb.ToString();
    }

    // ── Render fragments ──

    private RenderFragment RenderIngestionEvent(ActivityEntryViewModel evt) => __builder =>
    {
        var rich = evt.RichData;
        if (rich is not null && !string.IsNullOrWhiteSpace(rich.Title))
        {
            <div class="rtl-card">
                <div class="rtl-card-row">
                    @if (!string.IsNullOrEmpty(rich.CoverUrl ?? rich.Cover))
                    {
                        <img src="@(rich.CoverUrl ?? rich.Cover)" alt="" class="rtl-card-thumb" loading="lazy"
                             onerror="this.style.display='none';this.nextElementSibling&&this.nextElementSibling.classList.contains('rtl-card-placeholder')&&(this.nextElementSibling.style.display='flex')" />
                        <div class="rtl-card-placeholder" style="display: none;">
                            <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 14px; color: rgba(255,255,255,0.12);" />
                        </div>
                    }
                    else
                    {
                        <div class="rtl-card-placeholder">
                            <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 14px; color: rgba(255,255,255,0.12);" />
                        </div>
                    }
                    <div class="rtl-card-meta">
                        <span class="rtl-card-title">@rich.Title</span>
                        @if (!string.IsNullOrWhiteSpace(rich.Author))
                        {
                            <span class="rtl-card-sub">@rich.Author</span>
                        }
                    </div>
                </div>
                @if (rich.NeedsReview)
                {
                    <div class="rtl-card-alert">
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 11px; color: #EF9F27;" />
                        <span>Needs review</span>
                    </div>
                }
            </div>
        }
        else
        {
            <span class="rtl-event-detail">@(evt.Detail ?? HumanizeActionType(evt.ActionType))</span>
        }
    };

    private RenderFragment RenderEnrichmentEvent(ActivityEntryViewModel evt) => __builder =>
    {
        <div class="rtl-card rtl-card--enrichment">
            <span class="rtl-card-title">@(evt.HubName ?? "Entity enriched")</span>
            @if (!string.IsNullOrWhiteSpace(evt.Detail))
            {
                <span class="rtl-card-sub">@evt.Detail</span>
            }
        </div>
    };

    private RenderFragment RenderReportEvent(ActivityEntryViewModel evt) => __builder =>
    {
        <div class="rtl-card rtl-card--report">
            <span class="rtl-card-title">@(evt.HubName ?? "Report")</span>
            @if (!string.IsNullOrWhiteSpace(evt.Detail))
            {
                <span class="rtl-card-detail-quote">@evt.Detail</span>
            }
            @if (evt.EntityId is not null && Guid.TryParse(evt.EntityId, out _))
            {
                <button class="rtl-link-btn" @onclick="() => OnOpenInListView.InvokeAsync(null)">
                    Fix match
                </button>
            }
        </div>
    };

    private RenderFragment RenderCuratorEvent(ActivityEntryViewModel evt) => __builder =>
    {
        var review = evt.ReviewData;
        if (review is not null)
        {
            <div class="rtl-card rtl-card--curator">
                <span class="rtl-card-title">@(review.Title ?? evt.HubName ?? "Review resolved")</span>
                @if (!string.IsNullOrWhiteSpace(review.Action))
                {
                    <span class="rtl-card-sub">@review.Action</span>
                }
                @if (!string.IsNullOrWhiteSpace(review.Qid))
                {
                    <span class="rtl-card-hint" style="color: rgba(201,146,46,0.70);">@review.Qid</span>
                }
            </div>
        }
        else
        {
            <div class="rtl-card rtl-card--curator">
                <span class="rtl-card-title">@(evt.HubName ?? HumanizeActionType(evt.ActionType))</span>
                @if (!string.IsNullOrWhiteSpace(evt.Detail))
                {
                    <span class="rtl-card-sub">@evt.Detail</span>
                }
            </div>
        }
    };

    private RenderFragment RenderSystemEvent(ActivityEntryViewModel evt) => __builder =>
    {
        <span class="rtl-event-detail">@(evt.Detail ?? HumanizeActionType(evt.ActionType))</span>
    };

    // ── Data models ──

    private record FilterOption(string Label, string Icon, string Color, int Count);

    private sealed class TimelineItem
    {
        public bool IsBatchSummary { get; set; }
        public ActivityEntryViewModel? Event { get; set; }
        public List<ActivityEntryViewModel>? BatchEvents { get; set; }
        public string SortTime { get; set; } = "";
    }

    private sealed class DayGroup
    {
        public string Label { get; set; } = "";
        public List<TimelineItem> Items { get; set; } = [];
    }
}

<style>
    .rtl-container {
        display: flex;
        flex-direction: column;
        padding: 16px 20px;
        font-family: 'Montserrat', sans-serif;
        max-width: 800px;
        /* Left-aligned — no centering to avoid visual shift when filtering */
    }

    /* ── Filter chips ── */
    .rtl-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 20px;
    }

    .rtl-filter-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: transparent;
        color: rgba(255, 255, 255, 0.45);
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s ease;
        white-space: nowrap;
    }

    .rtl-filter-chip:hover {
        border-color: rgba(255, 255, 255, 0.18);
        color: rgba(255, 255, 255, 0.65);
    }

    .rtl-filter-chip--active {
        font-weight: 500;
    }

    /* ── Loading / empty ── */
    .rtl-loading {
        display: flex;
        justify-content: flex-start;
        padding: 48px 0;
    }

    .rtl-empty {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
        padding: 64px 0;
    }

    .rtl-empty-text {
        font-size: 13px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.20);
    }

    /* ── Timeline ── */
    .rtl-timeline {
        display: flex;
        flex-direction: column;
    }

    /* ── Day group header ── */
    .rtl-day-header {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        color: rgba(255, 255, 255, 0.30);
        margin: 20px 0 12px 38px;
    }

    .rtl-day-header:first-child {
        margin-top: 0;
    }

    /* ── Event row ── */
    .rtl-event {
        display: flex;
        gap: 12px;
        min-height: 48px;
    }

    /* ── Rail (dot + connector) ── */
    .rtl-event-rail {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 22px;
        flex-shrink: 0;
    }

    .rtl-dot {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        border: 2px solid;
    }

    .rtl-connector {
        width: 1px;
        flex: 1;
        min-height: 12px;
        background: rgba(255, 255, 255, 0.06);
    }

    /* ── Event content ── */
    .rtl-event-content {
        flex: 1;
        min-width: 0;
        padding-bottom: 16px;
    }

    .rtl-event-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
    }

    .rtl-event-title {
        font-size: 12px;
        font-weight: 500;
    }

    .rtl-event-time {
        font-size: 11px;
        font-weight: 300;
        color: rgba(255, 255, 255, 0.25);
    }

    .rtl-event-detail {
        font-size: 11px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.40);
        line-height: 1.5;
    }

    /* ── Event cards ── */
    .rtl-card {
        background: rgba(10, 10, 18, 0.85);
        border: 0.5px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 10px 12px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .rtl-card--enrichment {
        border-left: 3px solid rgba(83, 74, 183, 0.40);
    }

    .rtl-card--report {
        border-left: 3px solid rgba(239, 83, 80, 0.40);
    }

    .rtl-card--curator {
        border-left: 3px solid rgba(93, 202, 165, 0.40);
    }

    .rtl-card-row {
