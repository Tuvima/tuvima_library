@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav

<div class="rtl-container">

    @* ── Search results mode ── *@
    @if (!string.IsNullOrWhiteSpace(SearchTerm))
    {
        @if (_searchLoading)
        {
            <div class="rtl-loading">
                <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                     Style="width: 20px; height: 20px; color: rgba(255,255,255,0.25);" />
            </div>
        }
        else if (_searchResults.Count == 0)
        {
            <div class="rtl-empty">
                <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Style="font-size: 32px; color: rgba(255,255,255,0.12);" />
                <span class="rtl-empty-text">No results for "@SearchTerm"</span>
            </div>
        }
        else
        {
            <div class="rtl-search-results">
                <div class="rtl-search-results-header">
                    @_searchResults.Count result@(_searchResults.Count == 1 ? "" : "s") for "@SearchTerm"
                </div>
                @foreach (var item in _searchResults)
                {
                    <div class="rtl-search-card" @onclick="() => NavigateToItem(item.EntityId)">
                        @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                        {
                            <img class="rtl-search-cover" src="@item.CoverUrl" alt="" loading="lazy" />
                        }
                        else
                        {
                            <div class="rtl-search-cover-placeholder">
                                <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 16px; color: rgba(255,255,255,0.15);" />
                            </div>
                        }
                        <div class="rtl-search-info">
                            <div class="rtl-search-title-row">
                                <span class="rtl-search-title">@item.Title</span>
                                <span class="rtl-search-status" style="color: @RegistryHelpers.GetStatusColor(item.Status);">
                                    @RegistryHelpers.GetStatusLabel(item.Status)
                                </span>
                            </div>
                            <div class="rtl-search-meta">
                                @if (!string.IsNullOrWhiteSpace(item.Author))
                                {
                                    <span>@item.Author</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.Year))
                                {
                                    <span class="registry-stat-sep">·</span>
                                    <span>@item.Year</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.MediaType))
                                {
                                    <span class="registry-stat-sep">·</span>
                                    <span>@item.MediaType</span>
                                }
                            </div>
                            <div class="rtl-search-date">
                                Added @item.CreatedAt.ToLocalTime().ToString("MMMM d, yyyy")
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
    @* ── Timeline ── *@
    else if (_loading)
    {
        <div class="rtl-loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                 Style="width: 20px; height: 20px; color: rgba(255,255,255,0.25);" />
        </div>
    }
    else if (_timelineGroups.Count == 0)
    {
        <div class="rtl-empty">
            <MudIcon Icon="@Icons.Material.Outlined.Timeline" Style="font-size: 32px; color: rgba(255,255,255,0.12);" />
            <span class="rtl-empty-text">No activity yet</span>
        </div>
    }
    else
    {
        <div class="rtl-timeline">
            @foreach (var group in _timelineGroups)
            {
                <div class="rtl-day-header">
                    <span>@group.Label</span>
                </div>

                @foreach (var item in group.Items)
                {
                    @if (item.Type == TimelineItemType.Batch)
                    {
                        @* ── Batch card ── *@
                        var batch = item.Batch!;
                        var reviewCount = batch.FilesReview + batch.FilesNoMatch + batch.FilesFailed;
                        <div class="rtl-event">
                            <div class="rtl-event-rail">
                                <div class="rtl-dot" style="background: #4A90D920; border-color: #4A90D955;">
                                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Style="font-size: 10px; color: #4A90D9;" />
                                </div>
                                <div class="rtl-connector"></div>
                            </div>
                            <div class="rtl-event-content">
                                <div class="rtl-event-header">
                                    <span class="rtl-event-title" style="color: #4A90D9;">
                                        Media Ingested — @batch.Category
                                    </span>
                                    <span class="rtl-event-time">
                                        @RegistryHelpers.FormatBatchTimestamp(batch.StartedAt)
                                        @if (batch.CompletedAt is not null)
                                        {
                                            <text> · @RegistryHelpers.FormatBatchDuration(batch.StartedAt, batch.CompletedAt)</text>
                                        }
                                    </span>
                                </div>
                                <div class="rtl-batch-card">
                                    <div class="rtl-batch-card-body">
                                        <div class="rtl-batch-summary">
                                            <span class="rtl-batch-summary-total">@($"{batch.FilesTotal:N0}") items created</span>
                                            <div class="rtl-batch-summary-breakdown">
                                                <span style="color: #5DCAA5;">@batch.FilesIdentified automatically identified</span>
                                                @if (reviewCount > 0)
                                                {
                                                    <span class="registry-stat-sep">·</span>
                                                    <span style="color: #EF9F27;">@reviewCount sent to review</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else if (item.Type == TimelineItemType.AggregatedBatches)
                    {
                        @* ── Aggregated batch summary (weekly/monthly) ── *@
                        var agg = item.Aggregation!;
                        var aggReview = agg.TotalReview + agg.TotalNoMatch + agg.TotalFailed;
                        var isExpanded = item.GroupLabel is not null && _expandedPeriods.Contains(item.GroupLabel);
                        <div class="rtl-event">
                            <div class="rtl-event-rail">
                                <div class="rtl-dot" style="background: #4A90D920; border-color: #4A90D955;">
                                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Style="font-size: 10px; color: #4A90D9;" />
                                </div>
                                <div class="rtl-connector"></div>
                            </div>
                            <div class="rtl-event-content">
                                <div class="rtl-event-header">
                                    <span class="rtl-event-title" style="color: #4A90D9;">
                                        @($"{agg.TotalFiles:N0}") items added across @agg.BatchCount @(agg.BatchCount == 1 ? "batch" : "batches")
                                    </span>
                                </div>
                                <div class="rtl-batch-card">
                                    <div class="rtl-batch-summary">
                                        <span class="rtl-batch-summary-total">@($"{agg.TotalIdentified:N0}") automatically identified</span>
                                        <div class="rtl-batch-summary-breakdown">
                                            @if (aggReview > 0)
                                            {
                                                <span style="color: #EF9F27;">@aggReview sent to review</span>
                                            }
                                        </div>
                                    </div>
                                    @if (item.GroupLabel is not null)
                                    {
                                        <div class="rtl-batch-footer">
                                            <button class="rtl-link-btn" @onclick="() => ToggleExpand(item.GroupLabel)">
                                                @(isExpanded ? "Collapse" : "Expand") →
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else if (item.Type == TimelineItemType.Report)
                    {
                        @* ── Report (always full detail) ── *@
                        var evt = item.Event!;
                        <div class="rtl-event">
                            <div class="rtl-event-rail">
                                <div class="rtl-dot" style="background: #EF535020; border-color: #EF535055;">
                                    <MudIcon Icon="@Icons.Material.Outlined.Flag" Style="font-size: 10px; color: #EF5350;" />
                                </div>
                                <div class="rtl-connector"></div>
                            </div>
                            <div class="rtl-event-content">
                                <div class="rtl-event-header">
                                    <span class="rtl-event-title" style="color: #EF5350;">Problem reported</span>
                                    <span class="rtl-event-time">@evt.RelativeTime</span>
                                </div>
                                <div class="rtl-card rtl-card--report">
                                    <span class="rtl-card-title">@(evt.CollectionName ?? "Report")</span>
                                    @if (!string.IsNullOrWhiteSpace(evt.Detail))
                                    {
                                        <span class="rtl-card-detail-quote">@evt.Detail</span>
                                    }
                                    <button class="rtl-link-btn" @onclick="() => OnOpenInListView.InvokeAsync(null)">
                                        Fix match
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                    else if (item.Type == TimelineItemType.CuratorAction)
                    {
                        @* ── Curator action ── *@
                        var evt = item.Event!;
                        @if (evt.ActionType == "ReviewItemResolved")
                        {
                            @* ── Review resolved: rich card with title + QID badge ── *@
                            var rd = evt.ReviewData;
                            var resolvedTitle = rd?.Title ?? evt.CollectionName ?? "Resolved";
                            var resolvedQid = rd?.Qid ?? ExtractQid(evt.Detail);
                            var isRegistered = string.Equals(rd?.Action, "resolved", StringComparison.OrdinalIgnoreCase);
                            var isDismissed = string.Equals(rd?.Action, "dismissed", StringComparison.OrdinalIgnoreCase);
                            var actionVerb = isRegistered ? "Registered" : isDismissed ? "Dismissed" : "Resolved";
                            var actionColor = isRegistered ? "#5DCAA5" : isDismissed ? "rgba(200,190,220,0.55)" : "#5DCAA5";
                            var dotBg = isRegistered ? "#5DCAA520" : isDismissed ? "rgba(200,190,220,0.08)" : "#5DCAA520";
                            var dotBorder = isRegistered ? "#5DCAA555" : isDismissed ? "rgba(200,190,220,0.20)" : "#5DCAA555";
                            var actionIcon = isRegistered ? Icons.Material.Outlined.Verified : isDismissed ? Icons.Material.Outlined.RemoveCircleOutline : Icons.Material.Outlined.Verified;
                            <div class="rtl-event">
                                <div class="rtl-event-rail">
                                    <div class="rtl-dot" style="background: @dotBg; border-color: @dotBorder;">
                                        <MudIcon Icon="@actionIcon" Style="@($"font-size: 10px; color: {actionColor};")" />
                                    </div>
                                    <div class="rtl-connector"></div>
                                </div>
                                <div class="rtl-event-content">
                                    <div class="rtl-event-header">
                                        <span class="rtl-event-title" style="color: @actionColor;">@actionVerb</span>
                                        <span class="rtl-event-time">@evt.RelativeTime</span>
                                    </div>
                                    <div class="rtl-card @(isRegistered ? "rtl-card--review" : "")">
                                        <div class="rtl-card-row">
                                            <div class="rtl-review-info">
                                                @if (isRegistered)
                                                {
                                                    var coverUrl = evt.ReviewData?.CoverUrl;
                                                    @if (!string.IsNullOrWhiteSpace(coverUrl))
                                                    {
                                                        <div class="cover-hover-wrap">
                                                            <img class="rtl-review-thumb" src="@coverUrl" alt="" loading="lazy" />
                                                            <div class="cover-hover-popup">
                                                                <img src="@coverUrl" class="cover-hover-img" alt="" />
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                <div class="rtl-review-text">
                                                    <span class="rtl-card-title">@resolvedTitle</span>
                                                    @if (!string.IsNullOrWhiteSpace(resolvedQid) && isRegistered)
                                                    {
                                                        <span class="rtl-qid-badge">→ QID @resolvedQid</span>
                                                    }
                                                    @if (rd is not null && rd.FieldOverrides > 0)
                                                    {
                                                        <span class="rtl-event-detail">@rd.FieldOverrides field@(rd.FieldOverrides == 1 ? "" : "s") updated</span>
                                                    }
                                                </div>
                                            </div>
                                            @{
                                                var viewEntityId = rd?.EntityId ?? evt.EntityId;
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            @* ── Other curator actions (dismiss, manual override, etc.) ── *@
                            <div class="rtl-event">
                                <div class="rtl-event-rail">
                                    <div class="rtl-dot" style="background: #5DCAA520; border-color: #5DCAA555;">
                                        <MudIcon Icon="@Icons.Material.Outlined.Verified" Style="font-size: 10px; color: #5DCAA5;" />
                                    </div>
                                    <div class="rtl-connector"></div>
                                </div>
                                <div class="rtl-event-content">
                                    <div class="rtl-event-header">
                                        <span class="rtl-event-title" style="color: #5DCAA5;">@FormatCuratorVerb(evt)</span>
                                        <span class="rtl-event-time">@evt.RelativeTime</span>
                                    </div>
                                    <div class="rtl-card-row">
                                        <span class="rtl-event-detail">@FormatPlainEnglishDetail(evt)</span>
                                        @{
                                            var otherEntityId = evt.EntityId;
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else if (item.Type == TimelineItemType.PersonEnrichment)
                    {
                        @* ── Person enrichment batch ── *@
                        var pg = item.PersonGroup!;
                        <div class="rtl-event">
                            <div class="rtl-event-rail">
                                <div class="rtl-dot" style="background: #B39DDB20; border-color: #B39DDB55;">
                                    <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size: 10px; color: #B39DDB;" />
                                </div>
                                <div class="rtl-connector"></div>
                            </div>
                            <div class="rtl-event-content">
                                <div class="rtl-event-header">
                                    <span class="rtl-event-title" style="color: #B39DDB;">
                                        @pg.Count @(pg.Count == 1 ? "person" : "people") enriched
                                    </span>
                                    <span class="rtl-event-time">
                                        @RegistryHelpers.FormatBatchTimestamp(pg.EarliestAt)
                                    </span>
                                </div>
                                @if (pg.Thumbs.Count > 0)
                                {
                                    <div class="rtl-headshot-row">
                                        @foreach (var thumb in pg.Thumbs)
                                        {
                                            @if (!string.IsNullOrWhiteSpace(thumb.HeadshotUrl))
                                            {
                                                <div class="cover-hover-wrap">
                                                    <img class="rtl-person-headshot" src="@thumb.HeadshotUrl" alt="@thumb.Name" title="@thumb.Name" loading="lazy" />
                                                    <div class="cover-hover-popup">
                                                        <img src="@thumb.HeadshotUrl" class="cover-hover-img" alt="@thumb.Name" style="width: 160px;" />
                                                        <div style="padding: 4px 6px; font-size: 11px; color: rgba(255,255,255,0.7); text-align: center;">@thumb.Name</div>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="rtl-person-avatar" title="@thumb.Name">
                                                    @(thumb.Name.Length > 0 ? thumb.Name[..1].ToUpperInvariant() : "?")
                                                </div>
                                            }
                                        }
                                        @if (pg.Count > pg.Thumbs.Count)
                                        {
                                            <div class="rtl-person-avatar rtl-person-avatar--more">
                                                +@(pg.Count - pg.Thumbs.Count)
                                            </div>
                                        }
                                    </div>
                                }
                                @if (pg.Names.Count > 0)
                                {
                                    <div class="rtl-person-names">
                                        @foreach (var name in pg.Names)
                                        {
                                            <span class="rtl-person-chip">@name</span>
                                        }
                                        @if (pg.Count > pg.Names.Count)
                                        {
                                            <span class="rtl-person-chip rtl-person-chip--more">
                                                +@(pg.Count - pg.Names.Count) more
                                            </span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            }
        </div>

        @if (_hasMore)
        {
            <div class="rtl-load-more">
                <button class="rtl-load-more-btn" @onclick="LoadMore">Load more</button>
            </div>
        }
    }
</div>

@code {
    [Parameter] public EventCallback<string?> OnOpenInListView { get; set; }
    [Parameter] public string? SearchTerm { get; set; }

    private bool _loading;
    private bool _searchLoading;
    private List<RegistryItemViewModel> _searchResults = [];
    private string? _lastSearchTerm;
    private List<TimelineGroup> _timelineGroups = [];
    private List<IngestionBatchViewModel> _allBatches = [];
    private List<ActivityEntryViewModel> _allCuratorActions = [];
    private List<ActivityEntryViewModel> _allReports = [];
    private List<ActivityEntryViewModel> _allPersonEnrichments = [];
    private HashSet<string> _expandedPeriods = [];
    private int _batchLimit = 200;
    private bool _hasMore;

    protected override async Task OnParametersSetAsync()
    {
        if (SearchTerm != _lastSearchTerm)
        {
            _lastSearchTerm = SearchTerm;
            if (!string.IsNullOrWhiteSpace(SearchTerm))
            {
                await RunSearchAsync(SearchTerm);
            }
            else
            {
                _searchResults = [];
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        StateHasChanged();

        await LoadData();

        RebuildTimeline();
        _loading = false;
    }

    private async Task LoadData()
    {
        try
        {
            // Load batches (primary data source)
            _allBatches = (await Orchestrator.GetIngestionBatchesAsync(_batchLimit)).ToList();
            _hasMore = _allBatches.Count >= _batchLimit;

            // Load only manual curator actions and reports from activity log
            var curatorTypes = new[] {
                "ReviewItemResolved", "MetadataManualOverride",
                "UserReportResolved", "UserReportDismissed"
            };
            _allCuratorActions = await Orchestrator.GetActivityByTypesAsync(curatorTypes, 200);

            var reportTypes = new[] { "UserReportSubmitted" };
            _allReports = await Orchestrator.GetActivityByTypesAsync(reportTypes, 200);

            var personTypes = new[] { "PersonHydrated" };
            _allPersonEnrichments = await Orchestrator.GetActivityByTypesAsync(personTypes, 200);

        }
        catch
        {
            _allBatches = [];
            _allCuratorActions = [];
            _allReports = [];
            _allPersonEnrichments = [];
            _hasMore = false;
        }
    }

    private async Task RunSearchAsync(string term)
    {
        _searchLoading = true;
        StateHasChanged();

        try
        {
            var response = await Orchestrator.GetRegistryItemsAsync(search: term, limit: 20);
            _searchResults = response?.Items ?? [];
        }
        catch
        {
            _searchResults = [];
        }

        _searchLoading = false;
    }

    private void NavigateToItem(Guid entityId)
    {
        Nav.NavigateTo($"/registry/activity?entity={entityId}");
    }

    private async Task LoadMore()
    {
        _batchLimit += 200;
        _loading = true;
        StateHasChanged();

        await LoadData();

        RebuildTimeline();
        _loading = false;
    }

    private void ToggleExpand(string groupLabel)
    {
        if (_expandedPeriods.Contains(groupLabel))
            _expandedPeriods.Remove(groupLabel);
        else
            _expandedPeriods.Add(groupLabel);

        RebuildTimeline();
        StateHasChanged();
    }

    private void RebuildTimeline()
    {
        var now = DateTimeOffset.Now;
        var today = now.Date;
        var sevenDaysAgo = today.AddDays(-7);
        var thirtyDaysAgo = today.AddDays(-30);

        var items = new List<TimelineEntry>();

        // ── Add batches ──
        foreach (var batch in _allBatches)
        {
            var batchDate = batch.StartedAt.ToLocalTime().Date;

            if (batchDate >= sevenDaysAgo)
            {
                // Last 7 days: individual batch cards
                items.Add(new TimelineEntry
                {
                    SortTime = batch.StartedAt,
                    Type = TimelineItemType.Batch,
                    Batch = batch,
                });
            }
            // Weekly/monthly batches are aggregated below
        }

        // ── Weekly aggregation (8-30 days ago) ──
        var weeklyBatches = _allBatches
            .Where(b => {
                var d = b.StartedAt.ToLocalTime().Date;
                return d < sevenDaysAgo && d >= thirtyDaysAgo;
            })
            .GroupBy(b => GetWeekStart(b.StartedAt.ToLocalTime().Date))
            .OrderByDescending(g => g.Key);

        foreach (var weekGroup in weeklyBatches)
        {
            var batchList = weekGroup.ToList();
            var weekLabel = $"WEEK OF {weekGroup.Key:MMMM d}".ToUpperInvariant();

            if (_expandedPeriods.Contains(weekLabel))
            {
                // Emit individual batch cards for expanded week
                foreach (var batch in batchList.OrderByDescending(b => b.StartedAt))
                {
                    items.Add(new TimelineEntry
                    {
                        SortTime = batch.StartedAt,
                        Type = TimelineItemType.Batch,
                        Batch = batch,
                        GroupLabel = weekLabel,
                    });
                }
            }
            else
            {
                items.Add(new TimelineEntry
                {
                    SortTime = new DateTimeOffset(weekGroup.Key, TimeSpan.Zero),
                    Type = TimelineItemType.AggregatedBatches,
                    Aggregation = new BatchAggregation
                    {
                        BatchCount = batchList.Count,
                        TotalFiles = batchList.Sum(b => b.FilesTotal),
                        TotalIdentified = batchList.Sum(b => b.FilesIdentified),
                        TotalReview = batchList.Sum(b => b.FilesReview),
                        TotalNoMatch = batchList.Sum(b => b.FilesNoMatch),
                        TotalFailed = batchList.Sum(b => b.FilesFailed),
                    },
                    GroupLabel = weekLabel,
                });
            }
        }

        // ── Monthly aggregation (older than 30 days) ──
        var monthlyBatches = _allBatches
            .Where(b => b.StartedAt.ToLocalTime().Date < thirtyDaysAgo)
            .GroupBy(b => new DateTime(b.StartedAt.ToLocalTime().Year, b.StartedAt.ToLocalTime().Month, 1))
            .OrderByDescending(g => g.Key);

        foreach (var monthGroup in monthlyBatches)
        {
            var batchList = monthGroup.ToList();
            var monthLabel = monthGroup.Key.ToString("MMMM yyyy").ToUpperInvariant();

            if (_expandedPeriods.Contains(monthLabel))
            {
                // Emit individual batch cards for expanded month
                foreach (var batch in batchList.OrderByDescending(b => b.StartedAt))
                {
                    items.Add(new TimelineEntry
                    {
                        SortTime = batch.StartedAt,
                        Type = TimelineItemType.Batch,
                        Batch = batch,
                        GroupLabel = monthLabel,
                    });
                }
            }
            else
            {
                items.Add(new TimelineEntry
                {
                    SortTime = new DateTimeOffset(monthGroup.Key, TimeSpan.Zero),
                    Type = TimelineItemType.AggregatedBatches,
                    Aggregation = new BatchAggregation
                    {
                        BatchCount = batchList.Count,
                        TotalFiles = batchList.Sum(b => b.FilesTotal),
                        TotalIdentified = batchList.Sum(b => b.FilesIdentified),
                        TotalReview = batchList.Sum(b => b.FilesReview),
                        TotalNoMatch = batchList.Sum(b => b.FilesNoMatch),
                        TotalFailed = batchList.Sum(b => b.FilesFailed),
                    },
                    GroupLabel = monthLabel,
                });
            }
        }

        // ── Add reports (always full detail, regardless of age) ──
        foreach (var report in _allReports)
        {
            if (DateTimeOffset.TryParse(report.OccurredAt, out var ts))
            {
                items.Add(new TimelineEntry
                {
                    SortTime = ts,
                    Type = TimelineItemType.Report,
                    Event = report,
                });
            }
        }

        // ── Add person enrichment batches (grouped by hour) ──
        var personGroups = _allPersonEnrichments
            .Where(a => DateTimeOffset.TryParse(a.OccurredAt, out _))
            .GroupBy(a =>
            {
                var ts = DateTimeOffset.Parse(a.OccurredAt).ToLocalTime();
                return new DateTime(ts.Year, ts.Month, ts.Day, ts.Hour, 0, 0);
            })
            .OrderByDescending(g => g.Key);

        foreach (var group in personGroups)
        {
            var events = group.ToList();
            var names = events
                .Select(e => e.CollectionName ?? e.Detail)
                .Where(n => !string.IsNullOrWhiteSpace(n))
                .Select(n => n!.Length > 40 ? n[..37] + "…" : n)
                .Distinct()
                .Take(5)
                .ToList();

            var thumbs = events
                .Select(e =>
                {
                    var name = e.CollectionName ?? e.Detail ?? "?";
                    string? headshot = null;
                    if (!string.IsNullOrWhiteSpace(e.ChangesJson))
                    {
                        try
                        {
                            var doc = System.Text.Json.JsonDocument.Parse(e.ChangesJson);
                            if (doc.RootElement.TryGetProperty("headshot", out var hp) && hp.ValueKind == System.Text.Json.JsonValueKind.String)
                                headshot = hp.GetString();
                        }
                        catch { }
                    }
                    return new PersonThumb(name, headshot);
                })
                .Where(t => !string.IsNullOrWhiteSpace(t.Name))
                .DistinctBy(t => t.Name)
                .Take(5)
                .ToList();

            var earliest = events
                .Select(e => DateTimeOffset.Parse(e.OccurredAt))
                .Min();

            items.Add(new TimelineEntry
            {
                SortTime = earliest,
                Type = TimelineItemType.PersonEnrichment,
                PersonGroup = new PersonEnrichmentGroup
                {
                    Count = events.Count,
                    Names = names!,
                    Thumbs = thumbs,
                    EarliestAt = earliest,
                },
            });
        }

        // ── Add curator actions ──
        foreach (var action in _allCuratorActions)
        {
            if (DateTimeOffset.TryParse(action.OccurredAt, out var ts))
            {
                items.Add(new TimelineEntry
                {
                    SortTime = ts,
                    Type = TimelineItemType.CuratorAction,
                    Event = action,
                });
            }
        }

        // ── Build groups ──
        _timelineGroups = items
            .OrderByDescending(e => e.SortTime)
            .GroupBy(e => GetGroupKey(e, today, sevenDaysAgo, thirtyDaysAgo))
            .Select(g => new TimelineGroup
            {
                Label = g.First().GroupLabel ?? FormatGroupLabel(g.Key, today),
                Date = g.OrderByDescending(e => e.SortTime).First().SortTime.ToLocalTime().DateTime,
                Items = g.OrderByDescending(e => e.SortTime)
                         .Select(e => new TimelineItem { Type = e.Type, Batch = e.Batch, Event = e.Event, Aggregation = e.Aggregation, PersonGroup = e.PersonGroup, GroupLabel = e.GroupLabel })
                         .ToList(),
            })
            .ToList();
    }

    private static string GetGroupKey(TimelineEntry entry, DateTime today, DateTime sevenDaysAgo, DateTime thirtyDaysAgo)
    {
        // Aggregated items provide their own group label
        if (entry.GroupLabel is not null)
            return entry.GroupLabel;

        var date = entry.SortTime.ToLocalTime().Date;
        if (date == today) return "TODAY";
        if (date == today.AddDays(-1)) return "YESTERDAY";
        if (date >= sevenDaysAgo) return date.DayOfWeek.ToString().ToUpperInvariant();
        if (date >= thirtyDaysAgo) return $"WEEK OF {GetWeekStart(date):MMMM d}".ToUpperInvariant();
        return new DateTime(date.Year, date.Month, 1).ToString("MMMM yyyy").ToUpperInvariant();
    }

    private static string FormatGroupLabel(string key, DateTime today) => key;

    private static DateTime GetWeekStart(DateTime date)
    {
        // Monday-based weeks
        var diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.AddDays(-diff);
    }

    private static string FormatCuratorVerb(ActivityEntryViewModel evt) => evt.ActionType switch
    {
        "ReviewItemResolved" => "Review Resolved",
        "ReviewItemCreated" => "Sent to Review",
        "MetadataManualOverride" => "Metadata Updated",
        "UserReportResolved" => "Report Resolved",
        "UserReportDismissed" => "Report Dismissed",
        _ => "Action Completed",
    };

    private static string FormatPlainEnglishDetail(ActivityEntryViewModel evt)
    {
        // Prefer collection name as a human-readable anchor
        var name = evt.CollectionName;

        return evt.ActionType switch
        {
            "MetadataManualOverride" => !string.IsNullOrWhiteSpace(name)
                ? $"Metadata for \"{name}\" was manually updated"
                : "Metadata was manually updated",
            "UserReportResolved" => !string.IsNullOrWhiteSpace(name)
                ? $"Problem report for \"{name}\" resolved"
                : "Problem report resolved",
            "UserReportDismissed" => !string.IsNullOrWhiteSpace(name)
                ? $"Problem report for \"{name}\" dismissed"
                : "Problem report dismissed",
            _ => !string.IsNullOrWhiteSpace(name)
                ? name
                : evt.Detail ?? "Action completed",
        };
    }

    // ── Data models ──

    private enum TimelineItemType { Batch, AggregatedBatches, Report, CuratorAction, PersonEnrichment }

    private sealed class TimelineEntry
    {
        public DateTimeOffset SortTime { get; set; }
        public TimelineItemType Type { get; set; }
        public IngestionBatchViewModel? Batch { get; set; }
        public ActivityEntryViewModel? Event { get; set; }
        public BatchAggregation? Aggregation { get; set; }
        public PersonEnrichmentGroup? PersonGroup { get; set; }
        public string? GroupLabel { get; set; }
    }

    private sealed class TimelineItem
    {
        public TimelineItemType Type { get; set; }
        public IngestionBatchViewModel? Batch { get; set; }
        public ActivityEntryViewModel? Event { get; set; }
        public BatchAggregation? Aggregation { get; set; }
        public PersonEnrichmentGroup? PersonGroup { get; set; }
        public string? GroupLabel { get; set; }
    }

    private sealed class TimelineGroup
    {
        public string Label { get; set; } = "";
        public List<TimelineItem> Items { get; set; } = [];
        public DateTime? Date { get; set; }
    }

    private sealed class BatchAggregation
    {
        public int BatchCount { get; set; }
        public int TotalFiles { get; set; }
        public int TotalIdentified { get; set; }
        public int TotalReview { get; set; }
        public int TotalNoMatch { get; set; }
        public int TotalFailed { get; set; }
    }

    private sealed class PersonEnrichmentGroup
    {
        public int Count { get; set; }
        public List<string> Names { get; set; } = [];
        public List<PersonThumb> Thumbs { get; set; } = [];
        public DateTimeOffset EarliestAt { get; set; }
    }

    private sealed record PersonThumb(string Name, string? HeadshotUrl);


    private static string? ExtractQid(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return null;
        var match = System.Text.RegularExpressions.Regex.Match(text, @"Q\d+");
        return match.Success ? match.Value : null;
    }
}

