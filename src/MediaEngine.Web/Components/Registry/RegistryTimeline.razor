        width: 1px;
        flex: 1;
        min-height: 12px;
        background: rgba(255, 255, 255, 0.06);
    }

    .rtl-event-content {
        flex: 1;
        min-width: 0;
        padding-bottom: 16px;
    }

    .rtl-event-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
    }

    .rtl-event-title {
        font-size: 12px;
        font-weight: 500;
    }

    .rtl-event-time {
        font-size: 11px;
        font-weight: 300;
        color: rgba(255, 255, 255, 0.25);
    }

    .rtl-event-detail {
        font-size: 11px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.40);
        line-height: 1.5;
    }

    /* ── Batch card ── */
    .rtl-batch-card {
        background: rgba(10, 10, 18, 0.85);
        border: 0.5px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 12px 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .rtl-batch-kpis {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .rtl-batch-kpi {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        min-width: 50px;
    }

    .rtl-batch-kpi-number {
        font-size: 16px;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
    }

