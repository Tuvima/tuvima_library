@using MediaEngine.Web.Models.ViewDTOs
@using MudBlazor

<div class="aic-row @(IsSelected ? "aic-row--selected" : "")"
     style="border-left: 3px solid @RegistryHelpers.GetStatusColor(Item.Status);"
     @onclick="HandleRowClick">

    @* ── Cover thumbnail ── *@
    <div class="aic-thumb-wrap">
        @if (!string.IsNullOrEmpty(Item.CoverUrl))
        {
            <img src="@Item.CoverUrl" alt="@Item.Title" class="aic-thumb-img" loading="lazy" />
        }
        else
        {
            <div class="aic-thumb-fallback">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="aic-thumb-svg">
                    <rect x="3" y="2" width="14" height="20" rx="1.5"
                          fill="none" stroke="rgba(200,190,220,0.18)" stroke-width="1.2"
                          stroke-dasharray="3 2" />
                    <rect x="5" y="5" width="8" height="1" rx="0.5" fill="rgba(200,190,220,0.14)" />
                    <rect x="5" y="8" width="10" height="1" rx="0.5" fill="rgba(200,190,220,0.10)" />
                    <rect x="5" y="11" width="7" height="1" rx="0.5" fill="rgba(200,190,220,0.10)" />
                    <rect x="5" y="14" width="9" height="1" rx="0.5" fill="rgba(200,190,220,0.08)" />
                </svg>
            </div>
        }
    </div>

    @* ── Main content ── *@
    <div class="aic-body">
        <div class="aic-title-row">
            <span class="aic-title">@Item.Title</span>

        </div>

        <div class="aic-meta-row">
            @* Author / year subtitle *@
            @if (!string.IsNullOrEmpty(SubtitleText))
            {
                <span class="aic-subtitle">@SubtitleText</span>
            }

            @* Review trigger chip — only shown when ShowTriggerChip is true *@
            @if (ShowTriggerChip && !string.IsNullOrEmpty(Item.ReviewTrigger))
            {
                var (trigLabel, trigColor, trigIcon) = RegistryHelpers.FormatReviewTrigger(Item.ReviewTrigger);
                <span class="aic-trigger-chip"
                      style="color: @trigColor; border-color: @(trigColor + "44");"
                      title="@GetTriggerTooltip(Item.ReviewTrigger)">
                    <MudIcon Icon="@trigIcon" Style="@($"font-size: 0.6rem; color: {trigColor};")" />
                    @trigLabel
                </span>
            }
        </div>

        @* Rejected: purge countdown + un-reject ── *@
        @if (Item.Status == "Rejected")
        {
            <div class="aic-rejected-row" @onclick:stopPropagation="true">
                <span class="aic-purge-badge">
                    <MudIcon Icon="@Icons.Material.Outlined.Timer" Style="font-size: 0.6rem;" />
                    Purge in @PurgeCountdown
                </span>
                <button class="aic-unreject-btn"
                        @onclick="HandleUnreject"
                        title="Un-reject this item">
                    <MudIcon Icon="@Icons.Material.Outlined.Restore" Style="font-size: 0.65rem;" />
                    Un-reject
                </button>
            </div>
        }
    </div>

    @* ── Timestamp ── *@
    <div class="aic-timestamp">@RelativeTime</div>
</div>

@code {
    [Parameter, EditorRequired] public RegistryItemViewModel Item { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback<RegistryItemViewModel> OnSelect { get; set; }
    [Parameter] public EventCallback<Guid> OnUnreject { get; set; }
    [Parameter] public bool ShowTriggerChip { get; set; } = true;

    // ── Computed display values ────────────────────────────────────────────

    private string SubtitleText
    {
        get
        {
            var parts = new List<string>();
            if (!string.IsNullOrEmpty(Item.Author))   parts.Add(Item.Author);
            if (!string.IsNullOrEmpty(Item.Year))     parts.Add(Item.Year);
            return string.Join(" · ", parts);
        }
    }

    private string RelativeTime
    {
        get
        {
            var diff = DateTimeOffset.Now - Item.CreatedAt;
            return diff switch
            {
                { TotalSeconds: < 60 }  => "just now",
                { TotalMinutes: < 60 }  => $"{(int)diff.TotalMinutes}m ago",
                { TotalHours: < 24 }    => $"{(int)diff.TotalHours}h ago",
                { TotalDays: < 7 }      => $"{(int)diff.TotalDays}d ago",
                _                       => Item.CreatedAt.ToLocalTime().ToString("MMM d"),
            };
        }
    }

    /// <summary>Mock purge countdown — 7 days from ingestion for Rejected items.</summary>
    private string PurgeCountdown
    {
        get
        {
            var purgeAt = Item.CreatedAt.AddDays(7);
            var remaining = purgeAt - DateTimeOffset.Now;
            if (remaining <= TimeSpan.Zero) return "soon";
            if (remaining.TotalHours < 24)  return $"{(int)remaining.TotalHours}h";
            return $"{(int)remaining.TotalDays}d";
        }
    }

    // ── Event handlers ─────────────────────────────────────────────────────

    private static string GetTriggerTooltip(string trigger) => trigger switch
    {
        "MultipleQidMatches"    => "Pick the correct Wikidata entity",
        "LowConfidence"         => "Below the confidence threshold",
        "AuthorityMatchFailed"  => "No match found in Wikidata",
        "ContentMatchFailed"    => "No cover art found",
        "AmbiguousMediaType"    => "Unclear media type — needs classification",
        "MissingQid"            => "Needs a manual match to Wikidata",
        "PlaceholderTitle"      => "Missing title metadata",
        "StagedUnidentifiable"  => "Cannot identify this file",
        "ArtworkUnconfirmed"    => "Verify the cover art is correct",
        "MetadataConflict"      => "Conflicting metadata from different sources",
        "UserFixMatch"          => "User requested correction",
        "ArbiterNeedsReview"    => "Review how this was grouped",
        "LanguageMismatch"      => "Foreign language — may need different provider",
        "UserReport"            => "Users flagged a problem with this item",
        _                       => string.Empty
    };

    private async Task HandleRowClick()
    {
        await OnSelect.InvokeAsync(Item);
    }

    private async Task HandleUnreject()
    {
        await OnUnreject.InvokeAsync(Item.EntityId);
    }
}

<style>
    /* ── Row ───────────────────────────────────────────────────────────────── */
    .aic-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px 10px 8px;
        cursor: pointer;
        transition: background 0.12s ease;
        position: relative;
        min-height: 54px;
        box-sizing: border-box;
        font-family: 'Montserrat', sans-serif;
        /* left border set inline — semantic color per status */
    }

    .aic-row:hover {
        background: rgba(140, 120, 180, 0.1);
    }

    .aic-row--selected {
        background: rgba(140, 120, 180, 0.06);
    }

    .aic-row--selected:hover {
        background: rgba(140, 120, 180, 0.12);
    }

    /* ── Thumbnail ─────────────────────────────────────────────────────────── */
    .aic-thumb-wrap {
        position: relative;
        width: 32px;
        height: 46px;
        flex-shrink: 0;
        border-radius: 3px;
        overflow: hidden;
        background: rgba(20, 16, 42, 0.9);
        border: 1px solid rgba(140, 120, 180, 0.12);
    }

    .aic-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .aic-thumb-fallback {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(20, 16, 42, 0.6);
        border: 1px dashed rgba(140, 120, 180, 0.18);
        border-radius: 2px;
        box-sizing: border-box;
    }

    .aic-thumb-svg {
        width: 20px;
        height: 28px;
        flex-shrink: 0;
    }

    /* ── Body ──────────────────────────────────────────────────────────────── */
    .aic-body {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .aic-title-row {
        display: flex;
        align-items: baseline;
        gap: 6px;
        min-width: 0;
    }

    .aic-title {
        font-size: 0.78rem;
        font-weight: 500;
        color: #e0dce8;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
        min-width: 0;
        letter-spacing: 0.01em;
        font-family: 'Montserrat', sans-serif;
    }

    /* ── Meta row ──────────────────────────────────────────────────────────── */
    .aic-meta-row {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
        min-width: 0;
    }

    .aic-subtitle {
        font-size: 0.68rem;
        color: rgba(200, 190, 220, 0.55);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-family: 'Montserrat', sans-serif;
    }

    /* ── Review trigger chip ───────────────────────────────────────────────── */
    .aic-trigger-chip {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        font-size: 0.60rem;
        font-weight: 500;
        padding: 1px 5px;
        border-radius: 8px;
        border: 1px solid;
        background: transparent;
        white-space: nowrap;
        letter-spacing: 0.01em;
        font-family: 'Montserrat', sans-serif;
        flex-shrink: 0;
        /* color + border-color set inline */
    }

    /* ── Rejected row ──────────────────────────────────────────────────────── */
    .aic-rejected-row {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 1px;
    }

    .aic-purge-badge {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        font-size: 0.60rem;
        color: rgba(226, 75, 74, 0.75);
        font-family: 'Montserrat', sans-serif;
    }

    .aic-unreject-btn {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        font-size: 0.62rem;
        font-family: 'Montserrat', sans-serif;
        font-weight: 500;
        color: rgba(200, 190, 220, 0.75);
        background: rgba(140, 120, 180, 0.06);
        border: 1px solid rgba(140, 120, 180, 0.12);
        border-radius: 4px;
        padding: 1px 7px;
        cursor: pointer;
        transition: background 0.12s ease, color 0.12s ease, border-color 0.12s ease;
        line-height: 1.5;
    }

    .aic-unreject-btn:hover {
        background: rgba(140, 120, 180, 0.15);
        color: #e0dce8;
        border-color: rgba(140, 120, 180, 0.30);
    }

    /* ── Timestamp ─────────────────────────────────────────────────────────── */
    .aic-timestamp {
        font-size: 0.60rem;
        color: rgba(200, 190, 220, 0.40);
        white-space: nowrap;
        flex-shrink: 0;
        font-family: 'Montserrat', sans-serif;
        align-self: flex-start;
        padding-top: 2px;
    }
</style>
