@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="registry-layout @(_selectedItem is not null ? "detail-open" : "")">
    <div class="registry-main">
        @* ── Filter Bar (sticky top) ── *@
        <RegistryFilterBar Counts="_counts"
                           ActiveTab="@ActiveTab"
                           ActiveTabChanged="OnTabChanged"
                           SearchText="@_searchText"
                           SearchTextChanged="OnSearchChanged"
                           GroupBy="_groupBy"
                           GroupByChanged="OnGroupByChanged"
                           SelectionMode="_selectionMode"
                           SelectionModeChanged="OnSelectionModeChanged"
                           SortBy="@_sortBy"
                           SortByChanged="OnSortChanged"
                           MaxDays="_maxDays"
                           MaxDaysChanged="OnMaxDaysChanged"
                           CardSize="_cardSize"
                           CardSizeChanged="OnCardSizeChanged" />

        @* ── Bulk Bar (only when items selected in selection mode) ── *@
        @if (_selectionMode && _selectedIds.Count > 0)
        {
            <RegistryBulkBar SelectedCount="_selectedIds.Count"
                             TotalCount="_items.Count"
                             Processing="_processing"
                             OnApprove="BatchApproveAsync"
                             OnReject="BatchRejectAsync"
                             OnDelete="BatchDeleteAsync"
                             OnSelectAll="SelectAll"
                             OnDeselectAll="DeselectAll" />
        }

        @* ── Grid ── *@
        <RegistryGrid Items="_items"
                      SelectedIds="_selectedIds"
                      FocusedEntityId="@_selectedItem?.EntityId"
                      NeedsReviewFilter="@(ActiveTab == "review")"
                      GroupBy="_groupBy"
                      CardSize="_cardSize"
                      SelectionModeActive="_selectionMode"
                      HasMore="_hasMore"
                      Loading="_loading"
                      OnSelectionToggled="ToggleSelection"
                      OnCardClicked="OnCardClicked"
                      OnApproveClicked="QuickApproveAsync"
                      OnRejectClicked="QuickRejectAsync"
                      OnNavigate="OnCardClicked"
                      OnLoadMore="LoadMoreAsync"
                      OnApproveGroup="GroupApproveAsync"
                      OnRejectGroup="GroupRejectAsync" />
    </div>

    @* ── Detail Panel (right side) ── *@
    <RegistryDetailPanel Item="_selectedItem"
                         OnCloseRequested="CloseDetailPanel"
                         OnItemChanged="OnDetailItemChanged" />
</div>

@* ── Confirmation Dialogs ── *@
<MudMessageBox @ref="_deleteConfirmBox" Title="Delete from Library" CancelText="Cancel">
    <MessageContent>
        This will permanently delete <strong>@_selectedIds.Count</strong> file(s) from your library. This cannot be undone.
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error">Delete</MudButton>
    </YesButton>
</MudMessageBox>

<MudMessageBox @ref="_rejectConfirmBox" Title="Reject Items" CancelText="Cancel">
    <MessageContent>
        Reject <strong>@_pendingRejectCount</strong> item(s)? They will be moved to the rejected folder and automatically deleted after 30 days.
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error">Reject</MudButton>
    </YesButton>
</MudMessageBox>

<MudMessageBox @ref="_approveConfirmBox" Title="Approve Items" CancelText="Cancel">
    <MessageContent>
        Approve <strong>@_pendingApproveCount</strong> item(s)?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success">Approve</MudButton>
    </YesButton>
</MudMessageBox>

<style>
    .registry-layout {
        display: flex;
        min-height: 100%;
        position: relative;
    }
    .registry-main {
        flex: 1;
        min-width: 0;
        transition: padding-right 0.25s ease;
    }
    .registry-layout.detail-open .registry-main {
        padding-right: 384px;
    }
</style>

@code {
    // ── State ──
    private MudMessageBox? _deleteConfirmBox;
    private MudMessageBox? _rejectConfirmBox;
    private MudMessageBox? _approveConfirmBox;
    private List<RegistryItemViewModel> _items = [];
    private HashSet<Guid> _selectedIds = [];
    private RegistryStatusCountsDto? _counts;
    private RegistryItemViewModel? _selectedItem;

    private bool _loading;
    private bool _hasMore;
    private bool _processing;

    // Grouping / UI state
    private string _groupBy = "date";
    private bool _selectionMode;
    private int _cardSize = 80;

    // Filters
    private string? _searchText;
    private string _sortBy = "newest";
    private int _maxDays = 60;

    // Pending counts for confirmation dialogs
    private int _pendingRejectCount;
    private int _pendingApproveCount;

    // ── URL-driven tab ──
    private string ActiveTab => Nav.Uri.Contains("/review", StringComparison.OrdinalIgnoreCase) ? "review" : "all";

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        Orchestrator.OnActivityChanged += HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged += HandleIntercomEvent;

        _loading = true;
        await LoadCountsAsync();
        await LoadItemsAsync(reset: true);
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var stored = await JSRuntime.InvokeAsync<int>("registrySettings.getCardSize");
                if (stored >= 64 && stored <= 112)
                {
                    _cardSize = stored;
                    StateHasChanged();
                }
            }
            catch { /* ignore */ }
        }
    }

    // ── Data Loading ──

    private async Task LoadItemsAsync(bool reset = false)
    {
        if (reset) _items.Clear();

        var statusFilter = ActiveTab == "review" ? "Review" : (string?)null;
        var maxDaysParam = _maxDays > 0 ? _maxDays : (int?)null;

        var result = await Orchestrator.GetRegistryItemsAsync(
            offset: _items.Count,
            limit: 50,
            search: _searchText,
            type: null,
            status: statusFilter,
            minConfidence: null,
            matchSource: null,
            duplicatesOnly: false,
            missingUniverseOnly: ActiveTab == "review",
            sort: _sortBy,
            maxDays: maxDaysParam);

        if (result is not null)
        {
            var existingIds = new HashSet<Guid>(_items.Select(i => i.EntityId));
            var dedupedItems = result.Items
                .GroupBy(i => i.EntityId)
                .Select(g => g.OrderByDescending(i => i.Confidence).First())
                .Where(i => !existingIds.Contains(i.EntityId))
                .ToList();
            _items.AddRange(dedupedItems);
            _hasMore = result.HasMore;
        }
    }

    private async Task LoadCountsAsync()
    {
        _counts = await Orchestrator.GetRegistryStatusCountsAsync();
    }

    private async Task LoadMoreAsync()
    {
        if (_loading || !_hasMore) return;
        _loading = true;
        StateHasChanged();
        await LoadItemsAsync(reset: false);
        _loading = false;
        StateHasChanged();
    }

    // ── Tab / Filter Handlers ──

    private async Task OnTabChanged(string tab)
    {
        _selectedIds.Clear();
        _selectedItem = null;
        Nav.NavigateTo(tab == "review" ? "/registry/review" : "/registry");
        await ReloadItems();
    }

    private async Task OnSearchChanged(string? search)
    {
        _searchText = search;
        await ReloadItems();
    }

    private async Task OnGroupByChanged(string groupBy)
    {
        _groupBy = groupBy;
        StateHasChanged();
    }

    private void OnSelectionModeChanged(bool active)
    {
        _selectionMode = active;
        if (!active) _selectedIds.Clear();
        StateHasChanged();
    }

    private async Task OnSortChanged(string sort)
    {
        _sortBy = sort;
        await ReloadItems();
    }

    private async Task OnMaxDaysChanged(int days)
    {
        _maxDays = days;
        await ReloadItems();
    }

    private async Task OnCardSizeChanged(int size)
    {
        _cardSize = size;
        try
        {
            await JSRuntime.InvokeVoidAsync("registrySettings.setCardSize", size);
        }
        catch { /* ignore */ }
        StateHasChanged();
    }

    private async Task ReloadItems()
    {
        _loading = true;
        StateHasChanged();
        await LoadItemsAsync(reset: true);
        _loading = false;
        StateHasChanged();
    }

    // ── Card Click → Detail Panel ──

    private void OnCardClicked(Guid entityId)
    {
        if (_selectionMode)
        {
            ToggleSelection(entityId);
            return;
        }

        var item = _items.FirstOrDefault(i => i.EntityId == entityId);
        if (item is null) return;

        // Toggle: click same card closes panel
        if (_selectedItem?.EntityId == entityId)
        {
            _selectedItem = null;
        }
        else
        {
            _selectedItem = item;
        }
        StateHasChanged();
    }

    private void CloseDetailPanel()
    {
        _selectedItem = null;
        StateHasChanged();
    }

    private async Task OnDetailItemChanged()
    {
        // Refresh the list and counts after an action in the detail panel
        await LoadCountsAsync();
        await ReloadItems();

        // Re-select the updated item if it's still in the list
        if (_selectedItem is not null)
        {
            _selectedItem = _items.FirstOrDefault(i => i.EntityId == _selectedItem.EntityId);
        }
        StateHasChanged();
    }

    // ── Selection ──

    private void ToggleSelection(Guid entityId)
    {
        if (!_selectionMode) return;
        if (!_selectedIds.Remove(entityId))
            _selectedIds.Add(entityId);
        StateHasChanged();
    }

    private void SelectAll()
    {
        foreach (var item in _items)
            _selectedIds.Add(item.EntityId);
        StateHasChanged();
    }

    private void DeselectAll()
    {
        _selectedIds.Clear();
        StateHasChanged();
    }

    // ── Quick Approve (single card) ──

    private async Task QuickApproveAsync(Guid entityId)
    {
        var result = await Orchestrator.BatchApproveRegistryItemsAsync([entityId]);
        if (result is not null)
        {
            Snackbar.Add("Item approved", Severity.Success);
            await LoadCountsAsync();
            await ReloadItems();
        }
        else
        {
            Snackbar.Add("Failed to approve item", Severity.Error);
        }
    }

    // ── Quick Reject (single card) ──

    private async Task QuickRejectAsync(Guid entityId)
    {
        var result = await Orchestrator.RejectRegistryItemAsync(entityId);
        if (result is not null)
        {
            Snackbar.Add("Item rejected", Severity.Warning);
            await LoadCountsAsync();
            await ReloadItems();
        }
        else
        {
            Snackbar.Add("Failed to reject item", Severity.Error);
        }
    }

    // ── Batch Approve ──

    private async Task BatchApproveAsync()
    {
        if (_selectedIds.Count == 0) return;
        _processing = true;
        StateHasChanged();

        var ids = _selectedIds.ToArray();
        var result = await Orchestrator.BatchApproveRegistryItemsAsync(ids);
        if (result is not null)
        {
            Snackbar.Add($"Approved {result.ProcessedCount} of {result.TotalRequested} items", Severity.Success);
            _selectedIds.Clear();
            await LoadCountsAsync();
            await ReloadItems();
        }
        else
        {
            Snackbar.Add("Batch approve failed", Severity.Error);
        }

        _processing = false;
        StateHasChanged();
    }

    // ── Batch Reject ──

    private async Task BatchRejectAsync()
    {
        if (_selectedIds.Count == 0) return;

        _pendingRejectCount = _selectedIds.Count;
        var confirmed = await _rejectConfirmBox!.ShowAsync();
        if (confirmed != true) return;

        _processing = true;
        StateHasChanged();

        var ids = _selectedIds.ToArray();
        var result = await Orchestrator.BatchRejectRegistryItemsAsync(ids);
        if (result is not null)
        {
            Snackbar.Add($"Rejected {result.ProcessedCount} of {result.TotalRequested} items", Severity.Warning);
            _selectedIds.Clear();
            await LoadCountsAsync();
            await ReloadItems();
        }
        else
        {
            Snackbar.Add("Batch reject failed", Severity.Error);
        }

        _processing = false;
        StateHasChanged();
    }

    // ── Batch Delete ──

    private async Task BatchDeleteAsync()
    {
        if (_selectedIds.Count == 0) return;

        var confirmed = await _deleteConfirmBox!.ShowAsync();
        if (confirmed != true) return;

        _processing = true;
        StateHasChanged();

        var ids = _selectedIds.ToArray();
        var result = await Orchestrator.BatchDeleteRegistryItemsAsync(ids);
        if (result is not null)
        {
            Snackbar.Add($"Deleted {result.ProcessedCount} of {result.TotalRequested} items", Severity.Warning);
            _selectedIds.Clear();
            await LoadCountsAsync();
            await ReloadItems();
        }
        else
        {
            Snackbar.Add("Batch delete failed", Severity.Error);
        }

        _processing = false;
        StateHasChanged();
    }

    // ── Group Approve ──

    private async Task GroupApproveAsync(List<Guid> ids)
    {
        if (ids.Count == 0) return;

        _pendingApproveCount = ids.Count;
        var confirmed = await _approveConfirmBox!.ShowAsync();
        if (confirmed != true) return;

        _processing = true;
        StateHasChanged();

        var result = await Orchestrator.BatchApproveRegistryItemsAsync(ids.ToArray());
        if (result is not null)
        {
            Snackbar.Add($"Approved {result.ProcessedCount} items", Severity.Success);
            await LoadCountsAsync();
            await ReloadItems();
        }
        else
        {
            Snackbar.Add("Group approve failed", Severity.Error);
        }

        _processing = false;
        StateHasChanged();
    }

    // ── Group Reject ──

    private async Task GroupRejectAsync(List<Guid> ids)
    {
        if (ids.Count == 0) return;

        _pendingRejectCount = ids.Count;
        var confirmed = await _rejectConfirmBox!.ShowAsync();
        if (confirmed != true) return;

        _processing = true;
        StateHasChanged();

        var result = await Orchestrator.BatchRejectRegistryItemsAsync(ids.ToArray());
        if (result is not null)
        {
            Snackbar.Add($"Rejected {result.ProcessedCount} items", Severity.Warning);
            await LoadCountsAsync();
            await ReloadItems();
        }
        else
        {
            Snackbar.Add("Group reject failed", Severity.Error);
        }

        _processing = false;
        StateHasChanged();
    }

    // ── Navigation (from detail panel View Details link) ──

    private void NavigateToItem(Guid entityId)
    {
        Nav.NavigateTo($"/book/{entityId}");
    }

    // ── SignalR ──

    private async void HandleIntercomEvent()
    {
        await InvokeAsync(async () =>
        {
            await LoadCountsAsync();
            StateHasChanged();
        });
    }

    // ── Dispose ──

    public void Dispose()
    {
        Orchestrator.OnActivityChanged -= HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged -= HandleIntercomEvent;
    }
}
