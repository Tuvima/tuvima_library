    // ── Auto-Register ──

    private int ComputeAutoRegisterEligible()
    {
        var threshold = _autoRegisterPct / 100.0;
        return _items.Count(i =>
            i.Confidence >= threshold
            && string.IsNullOrEmpty(i.ReviewTrigger)
            && (string.IsNullOrEmpty(i.WikidataQid) || i.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase)));
    }

    private async Task AutoRegisterAsync()
    {
        var threshold = _autoRegisterPct / 100.0;
        var eligibleIds = _items
            .Where(i => i.Confidence >= threshold
                     && string.IsNullOrEmpty(i.ReviewTrigger)
                     && (string.IsNullOrEmpty(i.WikidataQid) || i.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase)))
            .Select(i => i.EntityId)
            .ToArray();

        if (eligibleIds.Length == 0) return;

        _processing = true;
        StateHasChanged();

        var result = await Orchestrator.BatchApproveRegistryItemsAsync(eligibleIds);
        if (result is not null)
            Snackbar.Add($"Auto-registered {result.ProcessedCount} items above {(_autoRegisterPct / 100.0).ToString("F2")}", Severity.Success);
        else
            Snackbar.Add("Auto-register failed", Severity.Error);

        await LoadCountsAsync();
        await ReloadItems();
        _processing = false;
        StateHasChanged();
    }

    // ── Retry Failed ──

    private async Task RetryFailedAsync()
    {
        var failedIds = _items
            .Where(i => i.WikidataStatus is "failed")
            .Select(i => i.EntityId)
            .ToArray();

        if (failedIds.Length == 0) return;

        _processing = true;
        StateHasChanged();

        var retried = 0;
        foreach (var id in failedIds)
        {
            try
            {
                await Orchestrator.TriggerHydrationAsync(id);
                retried++;
            }
            catch { /* individual failure is ok */ }
        }

        Snackbar.Add($"Retried hydration for {retried} items", Severity.Info);
        await LoadCountsAsync();
        await ReloadItems();
        _processing = false;
        StateHasChanged();
    }

    // ── Inspector Item Changed ──

    private async Task HandleInspectorItemChanged()
    {
        await LoadCountsAsync();
        await ReloadItems();
    }

    // ── Timeline → List deep-link ──

    private async Task HandleTimelineOpenInList(Guid? batchId)
    {
        _viewMode = "list";
        if (batchId.HasValue)
            await SelectBatch(batchId.Value);
        else
            await OpenAttentionQueue();
        StateHasChanged();
    }

    // ── SignalR ──

    private async void HandleIntercomEvent()
    {
        await InvokeAsync(async () =>
        {
            await LoadCountsAsync();
            StateHasChanged();
        });
    }

    // ── Dispose ──

    public void Dispose()
    {
        Orchestrator.OnActivityChanged -= HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged -= HandleIntercomEvent;
    }
