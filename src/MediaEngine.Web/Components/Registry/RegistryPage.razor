@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@implements IDisposable

<div class="registry-layout">

    @* ── Attention Banner (persistent across both views) ── *@
    @if (_bannerReviewCount > 0 || _bannerFailedCount > 0 || _bannerReportCount > 0)
    {
        <div class="registry-attention-banner">
            <div class="registry-attention-items">
                @if (_bannerReportCount > 0)
                {
                    <button class="registry-attention-item registry-attention-item--reports"
                            @onclick='() => GoToListFiltered("reports")'>
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 13px;" />
                        <span>@_bannerReportCount unresolved @(_bannerReportCount == 1 ? "report" : "reports")</span>
                    </button>
                }
                @if (_bannerReviewCount > 0)
                {
                    <button class="registry-attention-item registry-attention-item--review"
                            @onclick='() => GoToListFiltered("review")'>
                        <span>@_bannerReviewCount pending review</span>
                    </button>
                }
                @if (_bannerFailedCount > 0)
                {
                    <button class="registry-attention-item registry-attention-item--failed"
                            @onclick='() => GoToListFiltered("failed")'>
                        <span>@_bannerFailedCount failed</span>
                    </button>
                }
            </div>
            @if (!string.IsNullOrEmpty(_bannerOldestAge))
            {
                <span class="registry-attention-age">Oldest: @_bannerOldestAge</span>
            }
        </div>
    }

    @* ── Header ── *@
    <div class="registry-header">
        <span class="registry-title">Registry</span>
        <div class="registry-view-toggle">
            <button class="registry-toggle-btn @(_viewMode == "list" ? "active" : "")"
                    @onclick='() => SetViewMode("list")'>
                List
            </button>
            <button class="registry-toggle-btn @(_viewMode == "timeline" ? "active" : "")"
                    @onclick='() => SetViewMode("timeline")'>
                Timeline
            </button>
        </div>
    </div>

    @* ── Content ── *@
    @if (_viewMode == "timeline")
    {
        <RegistryTimeline OnOpenInListView="HandleTimelineOpenInList" />
    }
    else
    {
        <div class="registry-list-zone" @onkeydown="HandleKeyDown" tabindex="0">
            <div class="registry-main">
                @if (_selectedBatchId is null && _selectedBatchTimestamp != "All batches")
                {
                    @* ── Mode 1: Batch List ── *@
                    <RegistryBatchList Batches="_batches"
                                       AttentionCount="_attentionCount"
                                       OnBatchSelected="SelectBatch"
                                       OnAttentionClicked="OpenAttentionQueue" />
                }
                else
                {
                    @* ── Mode 2: Batch Item List ── *@
                    @* Back to batch list + batch header *@
                    <div class="registry-batch-header">
                        <button class="registry-back-btn" @onclick="ClearBatchSelection">
                            <MudIcon Icon="@Icons.Material.Outlined.ArrowBack" Style="font-size: 1.1rem;" />
                        </button>
                        <div class="registry-batch-info">
                            <span class="registry-batch-timestamp">@_selectedBatchTimestamp</span>
                            @if (!string.IsNullOrEmpty(_selectedBatchCategory))
                            {
                                <span class="registry-batch-category">@_selectedBatchCategory</span>
                            }
                        </div>
                        @if (_selectedBatchKpis is not null)
                        {
                            <div class="registry-batch-kpis">
                                <span class="registry-kpi" style="color: #5DCAA5;">@_selectedBatchKpis.FilesRegistered</span>
                                <span class="registry-kpi" style="color: #EF9F27;">@_selectedBatchKpis.FilesReview</span>
                                <span class="registry-kpi" style="color: #B4B2A9;">@_selectedBatchKpis.FilesNoMatch</span>
                                <span class="registry-kpi" style="color: #EF5350;">@_selectedBatchKpis.FilesFailed</span>
                            </div>
                        }
                    </div>

                    @* ── Filter Bar ── *@
                    <RegistryFilterBar Counts="_counts"
                                       FourStateCounts="_fourStateCounts"
                                       ActiveTab="@ActiveTab"
                                       ActiveTabChanged="OnTabChanged"
                                       SearchText="@_searchText"
                                       SearchTextChanged="OnSearchChanged"
                                       GroupBy="@_groupBy"
                                       GroupByChanged="OnGroupByChanged"
                                       SelectionMode="@_selectionMode"
                                       SelectionModeChanged="OnSelectionModeChanged"
                                       SortBy="@_sortBy"
                                       SortByChanged="OnSortChanged" />

                    @* ── Actions Bar (persistent: auto-register + retry failed) ── *@
                    <RegistryActionsBar ThresholdPct="_autoRegisterPct"
                                        ThresholdPctChanged="val => { _autoRegisterPct = val; StateHasChanged(); }"
                                        EligibleCount="ComputeAutoRegisterEligible()"
                                        FailedCount="_fourStateCounts?.Failed ?? 0"
                                        Processing="_processing"
                                        OnAutoRegister="AutoRegisterAsync"
                                        OnRetryFailed="RetryFailedAsync" />

                    @* ── Bulk Bar (selection mode) ── *@
                    @if (_selectionMode && _selectedIds.Count > 0)
                    {
                        <RegistryBulkBar SelectedCount="_selectedIds.Count"
                                         TotalCount="_items.Count"
                                         Processing="_processing"
                                         OnApprove="BatchApproveAsync"
                                         OnReject="BatchRejectAsync"
                                         OnDelete="BatchDeleteAsync"
                                         OnSelectAll="SelectAll"
                                         OnDeselectAll="DeselectAll" />
                    }

                    @* ── Grid ── *@
                    <RegistryGrid Items="@_items"
                                  SelectedIds="@_selectedIds"
                                  FocusedEntityId="@_inspectorItem?.EntityId"
                                  NeedsReviewFilter="@(ActiveTab == "review")"
                                  GroupBy="@_groupBy"
                                  CardSize="@_cardSize"
                                  SelectionModeActive="@_selectionMode"
                                  HasMore="_hasMore"
                                  Loading="_loading"
                                  OnSelectionToggled="ToggleSelection"
                                  OnCardClicked="OnCardClicked"
                                  OnApproveClicked="QuickApproveAsync"
                                  OnRejectClicked="QuickRejectAsync"
                                  OnNavigate="OnCardClicked"
                                  OnLoadMore="LoadMoreAsync"
                                  OnApproveGroup="GroupApproveAsync"
                                  OnRejectGroup="GroupRejectAsync" />
                }
            </div>

            @* ── Inspector Panel (350px, right side) ── *@
            @if (_inspectorOpen)
            {
                <RegistryInspector Item="_inspectorItem"
                                   OnClose="CloseInspector"
                                   OnItemChanged="HandleInspectorItemChanged" />
            }
        </div>
    }
</div>

@* ── Confirmation Dialogs ── *@
<MudMessageBox @ref="_deleteConfirmBox" Title="Delete from Library" CancelText="Cancel">
    <MessageContent>
        This will permanently delete <strong>@_selectedIds.Count</strong> file(s) from your library. This cannot be undone.
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error">Delete</MudButton>
    </YesButton>
</MudMessageBox>

<MudMessageBox @ref="_rejectConfirmBox" Title="Reject Items" CancelText="Cancel">
    <MessageContent>
        Reject <strong>@_pendingRejectCount</strong> item(s)? They will be moved to the rejected folder and automatically deleted after 30 days.
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error">Reject</MudButton>
    </YesButton>
</MudMessageBox>

<MudMessageBox @ref="_approveConfirmBox" Title="Approve Items" CancelText="Cancel">
    <MessageContent>
        Approve <strong>@_pendingApproveCount</strong> item(s)?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success">Approve</MudButton>
    </YesButton>
</MudMessageBox>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@@400;500;600&display=swap');

    /* Override MudContainer max-width for full-bleed registry */
    .registry-layout {
        display: flex;
        flex-direction: column;
        min-height: calc(100vh - 64px);
        background: #000000;
        position: relative;
        /* Break out of MudContainer padding */
        margin: -24px -16px -24px -16px;
        padding: 0;
    }

    @@media (min-width: 960px) {
        .registry-layout {
            /* Compensate for MudContainer padding + clear dock */
            margin: -24px -32px -24px -32px;
            padding-left: 84px;
        }
    }

    /* ── Header ── */
    .registry-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        flex-shrink: 0;
    }

    .registry-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 20px;
        font-weight: 500;
        color: #ffffff;
        letter-spacing: 0.01em;
    }

    /* ── View toggle (pill segmented control) ── */
    .registry-view-toggle {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 20px;
        padding: 3px;
        gap: 0;
    }

    .registry-toggle-btn {
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.45);
        background: transparent;
        border: none;
        border-radius: 17px;
        padding: 5px 16px;
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease;
        white-space: nowrap;
        line-height: 1.4;
    }

    .registry-toggle-btn:hover:not(.active) {
        color: rgba(255, 255, 255, 0.70);
        background: rgba(255, 255, 255, 0.05);
    }

    .registry-toggle-btn.active {
        background: #C9922E;
        color: #ffffff;
    }

    /* ── Attention Banner ── */
    .registry-attention-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 20px;
        background: rgba(201, 146, 46, 0.08);
        border-bottom: 1px solid rgba(201, 146, 46, 0.20);
        flex-shrink: 0;
        gap: 16px;
    }

    .registry-attention-items {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
    }

    .registry-attention-item {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        background: none;
        border: none;
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: opacity 0.15s ease;
        white-space: nowrap;
    }

    .registry-attention-item:hover {
        opacity: 0.8;
    }

    .registry-attention-item--reports {
        color: #EF9F27;
    }

    .registry-attention-item--review {
        color: rgba(255, 255, 255, 0.65);
    }

    .registry-attention-item--failed {
        color: rgba(255, 255, 255, 0.50);
    }

    .registry-attention-item + .registry-attention-item::before {
        content: '/';
        margin-right: 4px;
        color: rgba(255, 255, 255, 0.15);
        font-weight: 300;
    }

    .registry-attention-age {
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 300;
        color: rgba(255, 255, 255, 0.30);
        white-space: nowrap;
    }

    /* ── Three-zone layout (list + inspector) ── */
    .registry-list-zone {
        display: flex;
        flex: 1;
        min-height: 0;
        outline: none;
    }

    .registry-list-zone .registry-main {
        flex: 1;
        min-width: 0;
        overflow-y: auto;
    }

    /* ── Main content zone ── */
    .registry-main {
        flex: 1;
        min-width: 0;
    }

    /* ── Timeline placeholder ── */
    .registry-timeline-placeholder {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 300px;
        color: rgba(255, 255, 255, 0.35);
        font-family: 'Montserrat', sans-serif;
        font-size: 14px;
        font-weight: 500;
        letter-spacing: 0.03em;
    }

    /* ── Batch header (Mode 2) ── */
    .registry-batch-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        font-family: 'Montserrat', sans-serif;
    }

    .registry-back-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 0.5px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.04);
        color: rgba(255, 255, 255, 0.6);
        cursor: pointer;
        transition: all 0.15s ease;
        flex-shrink: 0;
    }

    .registry-back-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.2);
    }

    .registry-batch-info {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 1;
        min-width: 0;
    }

    .registry-batch-timestamp {
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.88);
        white-space: nowrap;
    }

    .registry-batch-category {
        font-size: 11px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.45);
        background: rgba(255, 255, 255, 0.06);
        padding: 2px 8px;
        border-radius: 4px;
        white-space: nowrap;
    }

    .registry-batch-kpis {
        display: flex;
        gap: 12px;
        flex-shrink: 0;
    }

    .registry-kpi {
        font-family: 'Montserrat', sans-serif;
        font-size: 14px;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
    }
</style>

@code {
    // ── State ──
    private MudMessageBox? _deleteConfirmBox;
    private MudMessageBox? _rejectConfirmBox;
    private MudMessageBox? _approveConfirmBox;
    private List<RegistryItemViewModel> _items = [];
    private HashSet<Guid> _selectedIds = [];
    private RegistryStatusCountsDto? _counts;
    private RegistryFourStateCountsDto? _fourStateCounts;
    private List<IngestionBatchViewModel> _batches = [];
    private int _attentionCount;

    // Batch selection state (Mode 2)
    private Guid? _selectedBatchId;
    private string _selectedBatchTimestamp = "";
    private string? _selectedBatchCategory;
    private IngestionBatchViewModel? _selectedBatchKpis;

    // Inspector state
    private RegistryItemViewModel? _inspectorItem;
    private bool _inspectorOpen => _inspectorItem is not null;

    private bool _loading;
    private bool _hasMore;
    private bool _processing;

    // Grouping / UI state
    private string _groupBy = "date";
    private bool _selectionMode;
    private int _cardSize = 80;

    // Filters
    private string? _searchText;
    private string _sortBy = "newest";

    // Pending counts for confirmation dialogs
    private int _pendingRejectCount;
    private int _pendingApproveCount;

    // Auto-register threshold
    private int _autoRegisterPct = 90;

    // ── URL-driven tab ──
    private string _activeTab = "all";
    private string ActiveTab => _activeTab;

    // ── View mode (list / timeline) ──
    private string _viewMode = "list";

    // ── Attention banner ──
    private int _bannerReviewCount;
    private int _bannerFailedCount;
    private int _bannerReportCount;
    private string? _bannerOldestAge;

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        Orchestrator.OnActivityChanged += HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged += HandleIntercomEvent;

        _activeTab = Nav.Uri.Contains("/review", StringComparison.OrdinalIgnoreCase) ? "review" : "all";
        _viewMode = Nav.Uri.Contains("/timeline", StringComparison.OrdinalIgnoreCase) ? "timeline" : "list";

        _loading = true;
        await LoadBatchesAsync();
        await LoadCountsAsync();
        _loading = false;
        await LoadBannerDataAsync();
    }

    // ── Attention Banner ──

    private async Task LoadBannerDataAsync()
    {
        try
        {
            // Get four-state counts (no batch filter = all items)
            var counts = await Orchestrator.GetRegistryFourStateCountsAsync();
            if (counts is not null)
            {
                _bannerReviewCount = counts.NeedsReview;
                _bannerFailedCount = counts.Failed;
            }

            // Get unresolved report count from activity entries
            var reportEntries = await Orchestrator.GetActivityByTypesAsync(
                ["UserReportSubmitted"], 500);
            _bannerReportCount = reportEntries.Count; // Simplified — reports are rare, count all submitted

            // Calculate oldest unresolved item age
            var oldestDates = new List<DateTimeOffset>();
            if (_bannerReviewCount > 0 || _bannerFailedCount > 0)
            {
                var batches = await Orchestrator.GetIngestionBatchesAsync(100);
                var oldestBatch = batches
                    .Where(b => b.FilesReview > 0 || b.FilesFailed > 0)
                    .OrderBy(b => b.StartedAt)
                    .FirstOrDefault();
                if (oldestBatch is not null)
                    oldestDates.Add(oldestBatch.StartedAt);
            }
            if (reportEntries.Count > 0)
            {
                var oldest = reportEntries
                    .Where(e => DateTimeOffset.TryParse(e.OccurredAt, out _))
                    .OrderBy(e => e.OccurredAt)
                    .FirstOrDefault();
                if (oldest is not null && DateTimeOffset.TryParse(oldest.OccurredAt, out var dt))
                    oldestDates.Add(dt);
            }

            if (oldestDates.Count > 0)
            {
                var oldest = oldestDates.Min();
                var age = DateTimeOffset.Now - oldest;
                _bannerOldestAge = age switch
                {
                    { TotalMinutes: < 60 } => $"{(int)age.TotalMinutes} minutes ago",
                    { TotalHours: < 24 } => $"{(int)age.TotalHours} hours ago",
                    { TotalDays: < 7 } => $"{(int)age.TotalDays} days ago",
                    { TotalDays: < 30 } => $"{(int)(age.TotalDays / 7)} weeks ago",
                    _ => $"{(int)(age.TotalDays / 30)} months ago",
                };
            }
        }
        catch { /* Banner is non-critical */ }
    }

    private void GoToListFiltered(string filter)
    {
        _viewMode = "list";
        _selectedBatchId = null;
        _selectedBatchTimestamp = "All batches";
        _activeTab = filter == "reports" ? "review" : filter;
        _ = LoadItemsAsync();
        StateHasChanged();
    }

    // ── View Mode ──

    private void SetViewMode(string mode)
    {
        _viewMode = mode;
        Nav.NavigateTo(mode == "timeline" ? "/registry/timeline" : "/registry");
    }

    // ── Data Loading ──

    private async Task LoadItemsAsync(bool reset = false)
    {
        if (reset) _items.Clear();

        var statusFilter = ActiveTab switch
        {
            "review" => "Review",
            "nomatch" => "NoMatch",
            "failed" => "Failed",
            _ => (string?)null,
        };

        var result = await Orchestrator.GetRegistryItemsAsync(
            offset: _items.Count,
            limit: 50,
            search: _searchText,
            type: null,
            status: statusFilter,
            minConfidence: null,
            matchSource: null,
            duplicatesOnly: false,
            missingUniverseOnly: ActiveTab == "review",
            sort: _sortBy,
            maxDays: null);

        if (result is not null)
        {
            var existingIds = new HashSet<Guid>(_items.Select(i => i.EntityId));
            var dedupedItems = result.Items
                .GroupBy(i => i.EntityId)
                .Select(g => g.OrderByDescending(i => i.Confidence).First())
                .Where(i => !existingIds.Contains(i.EntityId))
                .ToList();
            _items.AddRange(dedupedItems);
            _hasMore = result.HasMore;
        }
    }

    private async Task LoadCountsAsync()
    {
        _counts = await Orchestrator.GetRegistryStatusCountsAsync();
        if (_selectedBatchId is not null)
            _fourStateCounts = await Orchestrator.GetRegistryFourStateCountsAsync(_selectedBatchId);
    }

    private async Task LoadMoreAsync()
    {
        if (_loading || !_hasMore) return;
        _loading = true;
        StateHasChanged();
        await LoadItemsAsync(reset: false);
        _loading = false;
        StateHasChanged();
    }

    private async Task LoadBatchesAsync()
    {
        try
        {
            _batches = (await Orchestrator.GetIngestionBatchesAsync(20)).ToList();
            _attentionCount = await Orchestrator.GetBatchAttentionCountAsync();
        }
        catch { /* Engine offline — empty batch list is fine */ }
    }

    private async Task SelectBatch(Guid batchId)
    {
        _selectedBatchId = batchId;
        _selectedBatchKpis = _batches.FirstOrDefault(b => b.Id == batchId);
        if (_selectedBatchKpis is not null)
        {
            _selectedBatchTimestamp = RegistryHelpers.FormatBatchTimestamp(_selectedBatchKpis.StartedAt);
            _selectedBatchCategory = _selectedBatchKpis.Category;
        }

        // Load four-state counts for this batch
        _fourStateCounts = await Orchestrator.GetRegistryFourStateCountsAsync(_selectedBatchId);

        // Load items for this batch
        _activeTab = "all";
        await LoadItemsAsync(reset: true);
        StateHasChanged();
    }

    private async Task ClearBatchSelection()
    {
        _selectedBatchId = null;
        _selectedBatchKpis = null;
        _selectedBatchTimestamp = "";
        _selectedBatchCategory = null;
        _fourStateCounts = null;
        _items.Clear();
        _selectedIds.Clear();
        await LoadBatchesAsync();
        StateHasChanged();
    }

    private async Task OpenAttentionQueue()
    {
        // Cross-batch review queue: load all items needing review without batch scope
        _selectedBatchId = null; // null means cross-batch
        _fourStateCounts = await Orchestrator.GetRegistryFourStateCountsAsync(null);
        _activeTab = "review";
        _selectedBatchTimestamp = "All batches";
        _selectedBatchCategory = null;
        _selectedBatchKpis = null;
        await LoadItemsAsync(reset: true);
        StateHasChanged();
    }

    // ── Tab / Filter Handlers ──

    private async Task OnTabChanged(string tab)
    {
        _selectedIds.Clear();
        _activeTab = tab;
        // Only navigate URL if no batch selected (top-level tabs)
        if (_selectedBatchId is null && _selectedBatchTimestamp != "All batches")
            Nav.NavigateTo(tab == "review" ? "/registry/review" : "/registry");
        await ReloadItems();
    }

    private async Task OnSearchChanged(string? search)
    {
        _searchText = search;
        await ReloadItems();
    }

    private async Task OnGroupByChanged(string groupBy)
    {
        _groupBy = groupBy;
        StateHasChanged();
    }

    private void OnSelectionModeChanged(bool active)
    {
        _selectionMode = active;
        if (!active) _selectedIds.Clear();
        StateHasChanged();
    }

    private async Task OnSortChanged(string sort)
    {
        _sortBy = sort;
        await ReloadItems();
    }

    private async Task ReloadItems()
    {
        _loading = true;
        StateHasChanged();
        await LoadItemsAsync(reset: true);
        _loading = false;
        StateHasChanged();
    }

    // ── Card Click → Inspector ──

    private Task OnCardClicked(Guid entityId)
    {
        if (_selectionMode)
        {
            ToggleSelection(entityId);
            return Task.CompletedTask;
        }

        var item = _items.FirstOrDefault(i => i.EntityId == entityId);
        if (item is null) return Task.CompletedTask;

        _inspectorItem = item;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void CloseInspector()
    {
        _inspectorItem = null;
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape":
                CloseInspector();
                break;
            case "ArrowDown":
                NavigateItems(1);
                break;
            case "ArrowUp":
                NavigateItems(-1);
                break;
            case "r" or "R":
                if (_inspectorItem is not null)
                    _ = QuickApproveAsync(_inspectorItem.EntityId);
                break;
            case "s" or "S":
                if (_inspectorItem is not null)
                    NavigateItems(1); // Skip = move to next item
                break;
        }
    }

    private void NavigateItems(int direction)
    {
        if (_items.Count == 0) return;

        if (_inspectorItem is null)
        {
            _inspectorItem = _items[0];
        }
        else
        {
            var idx = _items.FindIndex(i => i.EntityId == _inspectorItem.EntityId);
            if (idx < 0) return;
            var newIdx = Math.Clamp(idx + direction, 0, _items.Count - 1);
            _inspectorItem = _items[newIdx];
        }
        StateHasChanged();
    }

    // ── Selection ──

    private void ToggleSelection(Guid entityId)
    {
        if (!_selectionMode) return;
        if (!_selectedIds.Remove(entityId))
            _selectedIds.Add(entityId);
        StateHasChanged();
    }

    private void SelectAll()
    {
        foreach (var item in _items)
            _selectedIds.Add(item.EntityId);
        StateHasChanged();
    }

    private void DeselectAll()
    {
        _selectedIds.Clear();
        StateHasChanged();
    }

