@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@implements IDisposable

<div class="registry-layout">

    @* ── Attention Banner (only when stale items exist) ── *@
    @if (_bannerReviewCount > 0 || _bannerReportCount > 0)
    {
        <div class="registry-attention-banner">
            <div class="registry-attention-items">
                @if (_bannerReportCount > 0)
                {
                    <button class="registry-attention-item registry-attention-item--reports"
                            @onclick='() => Nav.NavigateTo("/registry/activity?state=review")'>
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 13px;" />
                        <span>@_bannerReportCount unresolved @(_bannerReportCount == 1 ? "report" : "reports")</span>
                    </button>
                }
                @if (_bannerReviewCount > 0)
                {
                    <button class="registry-attention-item registry-attention-item--review"
                            @onclick='() => Nav.NavigateTo("/registry/activity?state=review")'>
                        <span>@_bannerReviewCount items in review</span>
                    </button>
                }
            </div>
            @if (!string.IsNullOrEmpty(_bannerOldestAge))
            {
                <span class="registry-attention-age">Oldest: @_bannerOldestAge</span>
            }
        </div>
    }

    @* ── Header ── *@
    <div class="registry-header">
        <span class="registry-title">Registry</span>
    </div>

    @* ── Stats Bar (3 clickable cards) ── *@
    <div class="registry-stats-bar">
        <button class="registry-stat-card registry-stat-card--registered"
                @onclick='() => Nav.NavigateTo("/registry/activity?state=registered")'>
            <span class="registry-stat-value">@(_fourStateCounts?.Registered ?? 0)</span>
            <span class="registry-stat-label">Registered</span>
            @if ((_fourStateCounts?.Provisional ?? 0) > 0)
            {
                <span class="registry-stat-footnote">@(_fourStateCounts?.Provisional ?? 0) provisional</span>
            }
        </button>
        <button class="registry-stat-card registry-stat-card--review"
                @onclick='() => Nav.NavigateTo("/registry/activity?state=review")'>
            <span class="registry-stat-value">@(_fourStateCounts?.InReview ?? 0)</span>
            <span class="registry-stat-label">In Review</span>
        </button>
        <button class="registry-stat-card registry-stat-card--rejected"
                @onclick='() => Nav.NavigateTo("/registry/activity?state=rejected")'>
            <span class="registry-stat-value">@(_fourStateCounts?.Rejected ?? 0)</span>
            <span class="registry-stat-label">Rejected</span>
        </button>
    </div>

    @* ── Filter Chips ── *@
    <div class="registry-filter-chips">
        @foreach (var chip in _filterChips)
        {
            <button class="registry-chip @(chip.Key == _activeFilter ? "registry-chip--active" : "")"
                    @onclick="() => SetFilter(chip.Key)">
                @chip.Label
            </button>
        }
    </div>

    @* ── Timeline (always shown, full-width) ── *@
    <RegistryTimeline OnOpenInListView="HandleTimelineNavigate" FilterCategory="@_activeFilter" />

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@@400;500;600&display=swap');

    .registry-layout {
        display: flex;
        flex-direction: column;
        min-height: calc(100vh - 64px);
        background: #000000;
        position: relative;
        margin: -24px -16px -24px -16px;
        padding: 0;
    }

    @@media (min-width: 960px) {
        .registry-layout {
            margin: -24px -32px -24px -32px;
            padding-left: 84px;
        }
    }

    /* ── Header ── */
    .registry-header {
        display: flex;
        align-items: center;
        padding: 16px 20px 8px 20px;
        flex-shrink: 0;
    }

    .registry-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 20px;
        font-weight: 500;
        color: #ffffff;
        letter-spacing: 0.01em;
    }

    /* ── Attention Banner ── */
    .registry-attention-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 20px;
        background: rgba(201, 146, 46, 0.08);
        border-bottom: 1px solid rgba(201, 146, 46, 0.20);
        flex-shrink: 0;
        gap: 16px;
    }

    .registry-attention-items {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
    }

    .registry-attention-item {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        background: none;
        border: none;
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: opacity 0.15s ease;
        white-space: nowrap;
    }

    .registry-attention-item:hover { opacity: 0.8; }
    .registry-attention-item--reports { color: #EF9F27; }
    .registry-attention-item--review { color: rgba(255, 255, 255, 0.65); }

    .registry-attention-item + .registry-attention-item::before {
        content: '/';
        margin-right: 4px;
        color: rgba(255, 255, 255, 0.15);
        font-weight: 300;
    }

    .registry-attention-age {
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 300;
        color: rgba(255, 255, 255, 0.30);
        white-space: nowrap;
    }

    /* ── Stats Bar ── */
    .registry-stats-bar {
        display: flex;
        gap: 10px;
        padding: 0 20px 12px 20px;
        flex-shrink: 0;
    }

    .registry-stat-card {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 14px 12px 10px 12px;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.02);
        cursor: pointer;
        transition: border-color 0.15s ease, background 0.15s ease;
        font-family: 'Montserrat', sans-serif;
    }

    .registry-stat-card:hover { background: rgba(255, 255, 255, 0.04); }

    .registry-stat-card--registered:hover { border-color: #5DCAA5; }
    .registry-stat-card--review:hover { border-color: #EF9F27; }
    .registry-stat-card--rejected:hover { border-color: #E24B4A; }

    .registry-stat-value {
        font-size: 24px;
        font-weight: 600;
        color: #ffffff;
        font-variant-numeric: tabular-nums;
    }

    .registry-stat-label {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: rgba(255, 255, 255, 0.40);
        margin-top: 2px;
    }

    .registry-stat-footnote {
        font-size: 10px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.25);
        margin-top: 4px;
    }

    /* ── Filter Chips ── */
    .registry-filter-chips {
        display: flex;
        gap: 6px;
        padding: 0 20px 12px 20px;
        flex-shrink: 0;
        overflow-x: auto;
    }

    .registry-chip {
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.40);
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        padding: 5px 14px;
        cursor: pointer;
        transition: all 0.15s ease;
        white-space: nowrap;
    }

    .registry-chip:hover {
        color: rgba(255, 255, 255, 0.65);
        background: rgba(255, 255, 255, 0.06);
    }

    .registry-chip--active {
        color: #C9922E;
        background: rgba(201, 146, 46, 0.12);
        border-color: rgba(201, 146, 46, 0.30);
    }
</style>

@code {
    private RegistryFourStateCountsDto? _fourStateCounts;

    // Attention banner
    private int _bannerReviewCount;
    private int _bannerReportCount;
    private string? _bannerOldestAge;

    // Filter chips
    private string _activeFilter = "all";
    private static readonly (string Key, string Label)[] _filterChips =
    [
        ("all", "All events"),
        ("ingestion", "Ingestion"),
        ("universe", "Universe"),
        ("reports", "Reports"),
        ("curator", "Curator actions"),
    ];

    protected override async Task OnInitializedAsync()
    {
        Orchestrator.OnActivityChanged += HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged += HandleIntercomEvent;

        await LoadCountsAsync();
        await LoadBannerDataAsync();
    }

    private async Task LoadCountsAsync()
    {
        _fourStateCounts = await Orchestrator.GetRegistryFourStateCountsAsync();
    }

    private async Task LoadBannerDataAsync()
    {
        try
        {
            if (_fourStateCounts is not null)
                _bannerReviewCount = _fourStateCounts.InReview;

            var reportEntries = await Orchestrator.GetActivityByTypesAsync(
                ["UserReportSubmitted"], 500);
            _bannerReportCount = reportEntries.Count;

            var oldestDates = new List<DateTimeOffset>();
            if (_bannerReviewCount > 0)
            {
                var batches = await Orchestrator.GetIngestionBatchesAsync(100);
                var oldestBatch = batches
                    .Where(b => b.FilesReview > 0)
                    .OrderBy(b => b.StartedAt)
                    .FirstOrDefault();
                if (oldestBatch is not null)
                    oldestDates.Add(oldestBatch.StartedAt);
            }
            if (reportEntries.Count > 0)
            {
                var oldest = reportEntries
                    .Where(e => DateTimeOffset.TryParse(e.OccurredAt, out _))
                    .OrderBy(e => e.OccurredAt)
                    .FirstOrDefault();
                if (oldest is not null && DateTimeOffset.TryParse(oldest.OccurredAt, out var dt))
                    oldestDates.Add(dt);
            }

            if (oldestDates.Count > 0)
            {
                var oldest = oldestDates.Min();
                var age = DateTimeOffset.Now - oldest;
                _bannerOldestAge = age switch
                {
                    { TotalMinutes: < 60 } => $"{(int)age.TotalMinutes} minutes ago",
                    { TotalHours: < 24 } => $"{(int)age.TotalHours} hours ago",
                    { TotalDays: < 7 } => $"{(int)age.TotalDays} days ago",
                    { TotalDays: < 30 } => $"{(int)(age.TotalDays / 7)} weeks ago",
                    _ => $"{(int)(age.TotalDays / 30)} months ago",
                };
            }
        }
        catch { /* Banner is non-critical */ }
    }

    private void SetFilter(string filter)
    {
        _activeFilter = filter;
        StateHasChanged();
    }

    private void HandleTimelineNavigate(Guid? batchId)
    {
        var target = batchId.HasValue ? $"?source=batch-{batchId.Value}" : "";
        Nav.NavigateTo($"/registry/activity{target}");
    }

    private async void HandleIntercomEvent()
    {
        await InvokeAsync(async () =>
        {
            await LoadCountsAsync();
            await LoadBannerDataAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Orchestrator.OnActivityChanged -= HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged -= HandleIntercomEvent;
    }
}
