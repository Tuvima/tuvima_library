@using MediaEngine.Web.Components.Registry
@inject UIOrchestratorService Orchestrator
@inject IJSRuntime JS
@implements IDisposable

<div class="rp-shell @(_selectedItem is not null ? "rp-shell--search-open" : "")">
    @* ── Left Sidebar ── *@
    <RegistrySidebar Counts="@_counts"
                     SelectedCategory="@_selectedCategory"
                     SelectedMediaType="@_mediaTypeFilter"
                     SelectedEntityId="@_selectedEntityId"
                     Items="@_items"
                     HasMore="@_hasMore"
                     OnCategorySelected="OnCategoryChanged"
                     OnMediaTypeChanged="OnMediaTypeChanged"
                     OnSearchChanged="OnSearchChanged"
                     OnItemSelected="OnSidebarItemClicked"
                     OnLoadMore="LoadMoreAsync"
 />

    @* ── Center Panel ── *@
    <div class="rp-center">
        @if (_selectedIds.Count > 0)
        {
            <RegistryBulkBar SelectedCount="@_selectedIds.Count"
                             Processing="@_bulkProcessing"
                             OnApprove="BulkApprove"
                             OnEditMatch="BulkEditMatch"
                             OnRemove="BulkRemove" />
        }

        @if (_selectedEntityId is null)
        {
            @* No item selected → show spacious list *@
            <RegistryListView Items="@_items"
                              HasMore="@_hasMore"
                              Loading="@_loading"
                              OnItemSelected="OnListItemClicked"
                              OnLoadMore="LoadMoreAsync" />
        }
        else
        {
            @* Item selected → show detail view *@
            <RegistryDetailView Detail="@_selectedDetail"
                                Item="@_selectedItem"
                                Loading="@_loadingDetail"
                                OnApprove="ApproveSelectedMatch"
                                OnRematch="TriggerRematch"
                                OnRemove="RemoveSelectedItem"
                                OnMatchApplied="OnMatchApplied" />
        }
    </div>

    @if (_selectedItem is not null)
    {
        <div class="rp-search-column">
            <div class="rp-search-header">
                <MudIcon Icon="@Icons.Material.Outlined.ManageSearch" Size="Size.Small" Style="color: #C9922E;" />
                <span>Find Metadata Match</span>
            </div>
            <MediaSearchPanel EntityId="@_selectedItem.EntityId"
                              InitialQuery="@_selectedItem.Title"
                              InitialMediaType="@_selectedItem.MediaType"
                              CurrentTitle="@(_selectedDetail?.Title)"
                              CurrentAuthor="@(_selectedDetail?.Author)"
                              CurrentYear="@(_selectedDetail?.Year)"
                              CurrentNarrator="@(_selectedDetail?.Narrator)"
                              CurrentCoverUrl="@(_selectedDetail?.CoverUrl)"
                              CurrentMediaType="@(_selectedItem.MediaType)"
                              OnMatchApplied="@OnMatchApplied" />
        </div>
    }
</div>

@code {
    // ── State ──────────────────────────────────────────────────────────────
    private List<RegistryItemViewModel> _items = [];
    private HashSet<Guid> _selectedIds = [];
    private Guid? _selectedEntityId;
    private RegistryItemViewModel? _selectedItem;
    private RegistryItemDetailViewModel? _selectedDetail;
    private RegistryStatusCountsDto? _counts;

    private bool _loading;
    private bool _loadingDetail;
    private bool _bulkProcessing;
    private bool _hasMore;
    private Guid? _searchPanelEntityId;

    // Filters
    private string? _selectedCategory;
    private string? _mediaTypeFilter;
    private string? _searchText;

    // ── Lifecycle ──────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        Orchestrator.OnActivityChanged += HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged += HandleIntercomEvent;

        _loading = true;
        await LoadCountsAsync();
        await LoadItemsAsync(reset: true);
        _loading = false;
    }

    // ── Data Loading ───────────────────────────────────────────────────────

    private async Task LoadItemsAsync(bool reset = false)
    {
        if (reset)
        {
            _items.Clear();
            _selectedIds.Clear();
            if (reset && _selectedEntityId is not null)
            {
                _selectedEntityId = null;
                _selectedDetail = null;
                _selectedItem = null;
            }
        }

        // Map sidebar category → API status filter
        var statusFilter = _selectedCategory switch
        {
            "Unmatched" => "Review",
            "Approved"  => "Approved",
            _ => (string?)null,
        };

        var result = await Orchestrator.GetRegistryItemsAsync(
            offset: _items.Count,
            limit: 50,
            search: _searchText,
            type: _mediaTypeFilter,
            status: statusFilter,
            minConfidence: _selectedCategory == "LowConfidence" ? 0.40 : null,
            matchSource: null,
            duplicatesOnly: false,
            missingUniverseOnly: _selectedCategory == "Unmatched");

        if (result is not null)
        {
            var existingIds = new HashSet<Guid>(_items.Select(i => i.EntityId));
            var dedupedItems = result.Items
                .GroupBy(i => i.EntityId)
                .Select(g => g.OrderByDescending(i => i.Confidence).First())
                .Where(i => !existingIds.Contains(i.EntityId))
                .ToList();
            _items.AddRange(dedupedItems);
            _hasMore = result.HasMore;
        }
    }

    private async Task LoadCountsAsync()
    {
        _counts = await Orchestrator.GetRegistryStatusCountsAsync();
    }

    private async Task LoadMoreAsync()
    {
        if (_loading || !_hasMore) return;
        _loading = true;
        StateHasChanged();
        await LoadItemsAsync(reset: false);
        _loading = false;
        StateHasChanged();
    }

    // ── Filter Handlers ────────────────────────────────────────────────────

    private async Task OnCategoryChanged(string? category)
    {
        _selectedCategory = category;
        await ReloadItems();
    }

    private async Task OnMediaTypeChanged(string? mediaType)
    {
        _mediaTypeFilter = mediaType;
        await ReloadItems();
    }

    private async Task OnSearchChanged(string? search)
    {
        _searchText = search;
        await ReloadItems();
    }

    private async Task ReloadItems()
    {
        _loading = true;
        StateHasChanged();
        await LoadItemsAsync(reset: true);
        _loading = false;
        StateHasChanged();
    }

    // ── Item Selection ─────────────────────────────────────────────────────

    private async Task OnSidebarItemClicked(Guid entityId)
    {
        await SelectItem(entityId);
    }

    private async Task OnListItemClicked(Guid entityId)
    {
        await SelectItem(entityId);
    }

    private async Task SelectItem(Guid entityId)
    {
        if (_selectedEntityId == entityId)
        {
            // Clicking same item deselects
            _selectedEntityId = null;
            _selectedDetail = null;
            _selectedItem = null;
            StateHasChanged();
            return;
        }

        _selectedEntityId = entityId;
        _selectedItem = _items.FirstOrDefault(i => i.EntityId == entityId);
        _loadingDetail = true;
        StateHasChanged();

        _selectedDetail = await Orchestrator.GetRegistryItemDetailAsync(entityId);
        _loadingDetail = false;
        StateHasChanged();
    }

    // ── Multi-Select ───────────────────────────────────────────────────────

    private void OnCheckboxToggled((Guid EntityId, bool Selected) args)
    {
        if (args.Selected)
            _selectedIds.Add(args.EntityId);
        else
            _selectedIds.Remove(args.EntityId);
        StateHasChanged();
    }

    // ── Actions ────────────────────────────────────────────────────────────

    private async Task ApproveSelectedMatch()
    {
        if (_selectedItem?.ReviewItemId is null) return;
        var ok = await Orchestrator.ResolveReviewAsync(_selectedItem.ReviewItemId.Value, new ReviewResolveRequestDto());
        if (ok)
        {
            _selectedItem.Status = "Auto";
            _selectedItem.ReviewItemId = null;
            _selectedEntityId = null;
            _selectedDetail = null;
            _selectedItem = null;
            await LoadCountsAsync();
            StateHasChanged();
        }
    }

    private void TriggerRematch()
    {
        if (_selectedItem is null) return;
        // Open search panel (or close and reopen to reset state)
        _searchPanelEntityId = null;
        StateHasChanged();
        _searchPanelEntityId = _selectedItem.EntityId;
        StateHasChanged();
    }

    private async Task OnMatchApplied(ApplyMatchResponseDto result)
    {
        if (_selectedItem is null) return;
        _selectedItem.WikidataStatus = result.WikidataStatus;
        _searchPanelEntityId = null;
        _selectedDetail = await Orchestrator.GetRegistryItemDetailAsync(_selectedItem.EntityId);
        await LoadCountsAsync();
        StateHasChanged();
    }

    private async Task RemoveSelectedItem()
    {
        if (_selectedItem is null) return;
        if (_selectedItem.ReviewItemId.HasValue)
            await Orchestrator.DismissReviewAsync(_selectedItem.ReviewItemId.Value);

        _items.Remove(_selectedItem);
        _selectedEntityId = null;
        _selectedDetail = null;
        _selectedItem = null;
        await LoadCountsAsync();
        StateHasChanged();
    }

    // ── Bulk Actions ───────────────────────────────────────────────────────

    private async Task BulkApprove()
    {
        _bulkProcessing = true;
        StateHasChanged();

        foreach (var id in _selectedIds.ToList())
        {
            var item = _items.FirstOrDefault(i => i.EntityId == id);
            if (item?.ReviewItemId is not null)
            {
                var ok = await Orchestrator.ResolveReviewAsync(item.ReviewItemId.Value, new ReviewResolveRequestDto());
                if (ok)
                {
                    item.Status = "Auto";
                    item.ReviewItemId = null;
                }
            }
        }

        _selectedIds.Clear();
        _bulkProcessing = false;
        await LoadCountsAsync();
        StateHasChanged();
    }

    private Task BulkEditMatch()
    {
        // Future: open bulk edit dialog
        return Task.CompletedTask;
    }

    private async Task BulkRemove()
    {
        _bulkProcessing = true;
        StateHasChanged();

        foreach (var id in _selectedIds.ToList())
        {
            await Orchestrator.DeleteRegistryItemAsync(id);
            var item = _items.FirstOrDefault(i => i.EntityId == id);
            if (item is not null)
                _items.Remove(item);
        }

        _selectedIds.Clear();
        _bulkProcessing = false;
        await LoadCountsAsync();
        StateHasChanged();
    }

    // ── SignalR ────────────────────────────────────────────────────────────

    private async void HandleIntercomEvent()
    {
        await InvokeAsync(async () =>
        {
            await LoadCountsAsync();
            StateHasChanged();
        });
    }

    // ── Dispose ────────────────────────────────────────────────────────────

    public void Dispose()
    {
        Orchestrator.OnActivityChanged -= HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged -= HandleIntercomEvent;
    }
}

<style>
    .rp-shell {
        display: grid;
        grid-template-columns: 280px 1fr;
        height: calc(100vh - 56px);
        overflow: hidden;
        font-family: 'Montserrat', sans-serif;
        margin-left: 88px; /* clear the floating left dock (12px offset + 64px width + 12px gap) */
    }

    .rp-center {
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        background: #000;
    }

    .rp-center::-webkit-scrollbar {
        width: 6px;
    }

    .rp-center::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.08);
        border-radius: 3px;
    }

    .rp-shell--search-open {
        grid-template-columns: 280px 1fr 1fr;
    }

    .rp-search-column {
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        background: #000;
        border-left: 1px solid rgba(255,255,255,0.06);
    }

    .rp-search-column::-webkit-scrollbar {
        width: 6px;
    }

    .rp-search-column::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.08);
        border-radius: 3px;
    }

    .rp-search-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.7);
        font-size: 0.85rem;
        font-weight: 600;
        flex-shrink: 0;
    }

    .rp-search-close {
        margin-left: auto;
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.4);
        cursor: pointer;
        padding: 4px;
        display: flex;
        align-items: center;
        border-radius: 4px;
        transition: all 0.15s ease;
    }

    .rp-search-close:hover {
        color: rgba(255,255,255,0.8);
        background: rgba(255,255,255,0.08);
    }
</style>
