@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@implements IDisposable

<div class="registry-layout">

    @* ── Header ── *@
    <div class="registry-header">
        <span class="registry-title">Registry</span>
    </div>

    @* ── Search Bar ── *@
    <div class="registry-search-bar">
        <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 16px; color: rgba(255,255,255,0.30);" />
        <input class="registry-search-input"
               type="text"
               placeholder="Search activity, titles, batches..."
               @oninput="OnSearchInput"
               @onkeydown="HandleSearchKeyDown" />
    </div>

    @* ── Inline Stats ── *@
    <div class="registry-stats-inline">
        <div class="registry-stats-row">
            <button class="registry-stat-link registry-stat-link--warning" @onclick='() => Nav.NavigateTo("/registry/activity?state=review")'>
                <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 12px;" />
                <span>0 unresolved reports</span>@* TODO: wire up unresolved reports count *@
            </button>
            <span class="registry-stat-sep">•</span>
            <button class="registry-stat-link registry-stat-link--amber" @onclick='() => Nav.NavigateTo("/registry/activity?state=review")'>
                @(_fourStateCounts?.InReview ?? 0) in review
            </button>
            <span class="registry-stat-sep">•</span>
            <button class="registry-stat-link registry-stat-link--red" @onclick='() => Nav.NavigateTo("/registry/activity?state=rejected")'>
                @(_fourStateCounts?.Rejected ?? 0) rejected
            </button>
        </div>
        <div class="registry-stats-row registry-stats-row--muted">
            <span>@(_fourStateCounts?.All ?? 0) items</span>
            <span class="registry-stat-sep">•</span>
            <button class="registry-stat-link" @onclick='() => Nav.NavigateTo("/registry/activity?state=registered")'>
                @(_fourStateCounts?.Registered ?? 0) registered
            </button>
            <span class="registry-stat-sep">•</span>
            <span>@InPipelineCount in pipeline</span>
        </div>
    </div>

    @* ── Timeline (always shown, full-width) ── *@
    <RegistryTimeline OnOpenInListView="HandleTimelineNavigate" SearchTerm="@_debouncedSearchTerm" />

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@@400;500;600&display=swap');

    .registry-layout {
        display: flex;
        flex-direction: column;
        min-height: calc(100vh - 64px);
        background: transparent;
        position: relative;
        margin: -24px -16px -24px -16px;
        padding: 0;
    }

    @@media (min-width: 960px) {
        .registry-layout {
            margin: -24px -32px -24px -32px;
            padding-left: 84px;
        }
    }

    /* ── Header ── */
    .registry-header {
        display: flex;
        align-items: center;
        padding: 16px 20px 8px 20px;
        flex-shrink: 0;
    }

    .registry-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 20px;
        font-weight: 500;
        color: #ffffff;
        letter-spacing: 0.01em;
    }

    /* ── Search Bar ── */
    .registry-search-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0 20px 12px 20px;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.03);
        transition: border-color 0.15s ease, background 0.15s ease;
    }

    .registry-search-bar:focus-within {
        border-color: rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.05);
    }

    .registry-search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: rgba(255, 255, 255, 0.85);
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        font-weight: 400;
    }

    .registry-search-input::placeholder {
        color: rgba(255, 255, 255, 0.25);
    }

    /* ── Inline Stats ── */
    .registry-stats-inline {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 0 20px 16px 20px;
    }

    .registry-stats-row {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        font-weight: 400;
    }

    .registry-stats-row--muted {
        color: rgba(255, 255, 255, 0.30);
    }

    .registry-stat-link {
        background: none;
        border: none;
        padding: 0;
        margin: 0;
        font-family: inherit;
        font-size: inherit;
        font-weight: inherit;
        cursor: pointer;
        transition: opacity 0.15s ease;
        color: inherit;
    }

    .registry-stat-link:hover {
        opacity: 0.80;
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .registry-stat-link--warning {
        color: #EF9F27;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .registry-stat-link--amber {
        color: #EF9F27;
    }

    .registry-stat-link--red {
        color: #E24B4A;
    }

    .registry-stat-sep {
        color: rgba(255, 255, 255, 0.12);
        user-select: none;
    }
</style>

@code {
    private RegistryFourStateCountsDto? _fourStateCounts;

    private string _searchTerm = "";
    private string _debouncedSearchTerm = "";
    private Timer? _debounceTimer;

    private int InPipelineCount =>
        (_fourStateCounts?.All ?? 0) - (_fourStateCounts?.Registered ?? 0) - (_fourStateCounts?.Rejected ?? 0);

    protected override async Task OnInitializedAsync()
    {
        Orchestrator.OnActivityChanged += HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged += HandleIntercomEvent;

        await LoadCountsAsync();
    }

    private async Task LoadCountsAsync()
    {
        _fourStateCounts = await Orchestrator.GetRegistryFourStateCountsAsync();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? "";
        _debounceTimer?.Dispose();
        _debounceTimer = new Timer(_ =>
        {
            InvokeAsync(() =>
            {
                _debouncedSearchTerm = _searchTerm;
                StateHasChanged();
            });
        }, null, 300, Timeout.Infinite);
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _debounceTimer?.Dispose();
            _debouncedSearchTerm = _searchTerm;
            StateHasChanged();
        }
    }

    private void HandleTimelineNavigate(Guid? batchId)
    {
        var target = batchId.HasValue ? $"?source=batch-{batchId.Value}" : "";
        Nav.NavigateTo($"/registry/activity{target}");
    }

    private async void HandleIntercomEvent()
    {
        await InvokeAsync(async () =>
        {
            await LoadCountsAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
        Orchestrator.OnActivityChanged -= HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged -= HandleIntercomEvent;
    }
}
