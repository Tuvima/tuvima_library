@using MediaEngine.Web.Components.Registry
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@implements IDisposable

<div class="registry-layout">

    @* ── Header ── *@
    <div class="registry-header">
        <span class="registry-title">Registry</span>
    </div>

    @* ── Search Bar ── *@
    <div class="registry-search-bar">
        <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 16px; color: rgba(255,255,255,0.30);" />
        <input class="registry-search-input"
               type="text"
               placeholder="Search activity, titles, batches..."
               value="@_searchTerm"
               @oninput="OnSearchInput"
               @onkeydown="HandleSearchKeyDown" />
    </div>

    @* ── Row 1: Action Stats ── *@
    <div class="registry-stat-cards">
        <button class="registry-stat-card registry-stat-card--blue"
                @onclick='() => Nav.NavigateTo("/registry/activity?state=reports")'>
            <MudIcon Icon="@Icons.Material.Outlined.Feedback" Style="font-size: 18px; color: #4A90D9;" />
            <span class="registry-stat-number" style="color: #4A90D9;">0</span>
            <span class="registry-stat-label">reports</span>
        </button>
        <button class="registry-stat-card registry-stat-card--amber"
                @onclick='() => Nav.NavigateTo("/registry/activity?state=review")'>
            <MudIcon Icon="@Icons.Material.Outlined.RateReview" Style="font-size: 18px; color: #EF9F27;" />
            <span class="registry-stat-number" style="color: #EF9F27;">@(_fourStateCounts?.InReview ?? 0)</span>
            <span class="registry-stat-label">in review</span>
        </button>
        <button class="registry-stat-card registry-stat-card--red"
                @onclick='() => Nav.NavigateTo("/registry/activity?state=rejected")'>
            <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 18px; color: #E24B4A;" />
            <span class="registry-stat-number" style="color: #E24B4A;">@(_fourStateCounts?.Rejected ?? 0)</span>
            <span class="registry-stat-label">rejected</span>
        </button>
    </div>

    @* ── Row 2: Library Overview ── *@
    <div class="registry-library-row">
        <span class="registry-library-label">Library</span>
        <div class="registry-library-cards">
            @* ── Total box with nested registered + provisional ── *@
            <div class="registry-total-box">
                <span class="registry-total-number">@(_fourStateCounts?.All ?? 0)</span>
                <span class="registry-total-label">items</span>
                <div class="registry-total-breakdown">
                    <button class="registry-breakdown-chip registry-breakdown-chip--green"
                            @onclick='() => Nav.NavigateTo("/registry/activity?state=registered")'>
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 12px; color: #5DCAA5;" />
                        <span>@(_fourStateCounts?.Registered ?? 0) registered</span>
                    </button>
                    <button class="registry-breakdown-chip registry-breakdown-chip--gray"
                            @onclick='() => Nav.NavigateTo("/registry/activity?state=provisional")'>
                        <MudIcon Icon="@Icons.Material.Outlined.EditNote" Style="font-size: 12px; color: #B4B2A9;" />
                        <span>@(_fourStateCounts?.Provisional ?? 0) provisional</span>
                    </button>
                </div>
            </div>

            @* ── People count ── *@
            <div class="registry-meta-card">
                <MudIcon Icon="@Icons.Material.Outlined.People" Style="font-size: 20px; color: rgba(255,255,255,0.45);" />
                <span class="registry-meta-number">@(_fourStateCounts?.PersonCount ?? 0)</span>
                <span class="registry-meta-label">people</span>
            </div>

            @* ── Universes count ── *@
            <div class="registry-meta-card">
                <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Style="font-size: 20px; color: rgba(255,255,255,0.45);" />
                <span class="registry-meta-number">@(_fourStateCounts?.HubCount ?? 0)</span>
                <span class="registry-meta-label">universes</span>
            </div>
        </div>
    </div>

    @* ── Tab Bar ── *@
    <div class="registry-tab-bar">
        <button class="registry-tab @(_activeTab == "activity" ? "registry-tab--active" : "")"
                @onclick='() => SwitchTab("activity")'>
            Activity
        </button>
        <button class="registry-tab @(_activeTab == "library" ? "registry-tab--active" : "")"
                @onclick='() => SwitchTab("library")'>
            Library
        </button>
    </div>

    @* ── Tab Content ── *@
    @if (_activeTab == "activity")
    {
        <RegistryTimeline OnOpenInListView="HandleTimelineNavigate" SearchTerm="@_debouncedSearchTerm" />
    }
    else
    {
        <div class="registry-batch-wrapper">
            <RegistryBatchList Batches="@_batches"
                               AttentionCount="@(_fourStateCounts?.InReview ?? 0)"
                               OnBatchSelected="HandleBatchSelected"
                               OnAttentionClicked="HandleAttentionClicked" />
        </div>
    }

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@@400;500;600&display=swap');

    .registry-layout {
        display: flex;
        flex-direction: column;
        min-height: calc(100vh - 64px);
        background: transparent;
        position: relative;
        margin: -24px -16px -24px -16px;
        padding: 0;
    }

    @@media (min-width: 960px) {
        .registry-layout {
            margin: -24px -32px -24px -32px;
            padding-left: 84px;
        }
    }

    /* ── Header ── */
    .registry-header {
        display: flex;
        align-items: center;
        padding: 16px 20px 8px 20px;
        flex-shrink: 0;
    }

    .registry-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 20px;
        font-weight: 500;
        color: #ffffff;
        letter-spacing: 0.01em;
    }

    /* ── Search Bar ── */
    .registry-search-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0 20px 12px 20px;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.03);
        transition: border-color 0.15s ease, background 0.15s ease;
    }

    .registry-search-bar:focus-within {
        border-color: rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.05);
    }

    .registry-search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: rgba(255, 255, 255, 0.85);
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        font-weight: 400;
    }

    .registry-search-input::placeholder {
        color: rgba(255, 255, 255, 0.25);
    }

    /* ── Row 1: Action Stat Cards ── */
    .registry-stat-cards {
        display: flex;
        gap: 10px;
        padding: 0 20px 10px 20px;
    }

    .registry-stat-card {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        cursor: pointer;
        transition: border-color 0.18s ease, background 0.18s ease;
        font-family: 'Montserrat', sans-serif;
    }

    .registry-stat-card:hover {
        background: rgba(255, 255, 255, 0.06);
    }

    .registry-stat-card--blue {
        border-color: rgba(74, 144, 217, 0.25);
    }

    .registry-stat-card--blue:hover {
        border-color: rgba(74, 144, 217, 0.45);
        background: rgba(74, 144, 217, 0.06);
    }

    .registry-stat-card--amber {
        border-color: rgba(239, 159, 39, 0.25);
    }

    .registry-stat-card--amber:hover {
        border-color: rgba(239, 159, 39, 0.45);
        background: rgba(239, 159, 39, 0.06);
    }

    .registry-stat-card--red {
        border-color: rgba(226, 75, 74, 0.25);
    }

    .registry-stat-card--red:hover {
        border-color: rgba(226, 75, 74, 0.45);
        background: rgba(226, 75, 74, 0.06);
    }

    .registry-stat-number {
        font-size: 18px;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        line-height: 1;
    }

    .registry-stat-label {
        font-size: 12px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.45);
    }

    /* ── Row 2: Library Overview ── */
    .registry-library-row {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 0 20px 14px 20px;
    }

    .registry-library-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.30);
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .registry-library-cards {
        display: flex;
        gap: 10px;
        align-items: stretch;
    }

    /* ── Total box (nested breakdown) ── */
    .registry-total-box {
        flex: 2;
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 10px 14px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        font-family: 'Montserrat', sans-serif;
    }

    .registry-total-number {
        font-size: 20px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
        font-variant-numeric: tabular-nums;
        line-height: 1;
    }

    .registry-total-label {
        font-size: 11px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.30);
    }

    .registry-total-breakdown {
        display: flex;
        gap: 8px;
        margin-top: 2px;
    }

    .registry-breakdown-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        border-radius: 6px;
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 500;
        background: none;
        border: none;
        cursor: pointer;
        transition: background 0.15s ease;
    }

    .registry-breakdown-chip:hover {
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .registry-breakdown-chip--green {
        color: #5DCAA5;
        background: rgba(93, 202, 165, 0.08);
    }

    .registry-breakdown-chip--green:hover {
        background: rgba(93, 202, 165, 0.14);
    }

    .registry-breakdown-chip--gray {
        color: #B4B2A9;
        background: rgba(180, 178, 169, 0.08);
    }

    .registry-breakdown-chip--gray:hover {
        background: rgba(180, 178, 169, 0.14);
    }

    /* ── People / Universes meta cards ── */
    .registry-meta-card {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        padding: 10px 14px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        font-family: 'Montserrat', sans-serif;
    }

    .registry-meta-number {
        font-size: 18px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.75);
        font-variant-numeric: tabular-nums;
        line-height: 1;
    }

    .registry-meta-label {
        font-size: 11px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.30);
    }

    /* ── Tab Bar ── */
    .registry-tab-bar {
        display: flex;
        gap: 0;
        padding: 0 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        margin-bottom: 0;
    }

    .registry-tab {
        position: relative;
        background: none;
        border: none;
        padding: 10px 20px;
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.35);
        cursor: pointer;
        transition: color 0.15s ease;
    }

    .registry-tab:hover {
        color: rgba(255, 255, 255, 0.55);
    }

    .registry-tab--active {
        color: #C9922E;
    }

    .registry-tab--active::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 20px;
        right: 20px;
        height: 2px;
        background: #C9922E;
        border-radius: 1px;
    }

    /* ── Batch list wrapper ── */
    .registry-batch-wrapper {
        padding: 16px 20px;
    }
</style>

@code {
    private RegistryFourStateCountsDto? _fourStateCounts;
    private IReadOnlyList<IngestionBatchViewModel> _batches = [];

    private string _activeTab = "activity";
    private string _searchTerm = "";
    private string _debouncedSearchTerm = "";
    private Timer? _debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        Orchestrator.OnActivityChanged += HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged += HandleIntercomEvent;
        Nav.LocationChanged += OnLocationChanged;

        SyncTabFromUrl();
        await LoadDataAsync();
    }

    protected override void OnParametersSet()
    {
        SyncTabFromUrl();
    }

    private void SyncTabFromUrl()
    {
        var uri = new Uri(Nav.Uri);
        var path = uri.AbsolutePath.TrimEnd('/').ToLowerInvariant();

        _activeTab = path switch
        {
            "/registry/library" => "library",
            _ => "activity",
        };

        // Parse ?q= query param for search
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var q = query["q"];
        if (!string.IsNullOrEmpty(q) && q != _searchTerm)
        {
            _searchTerm = q;
            _debouncedSearchTerm = q;
        }
    }

    private void SwitchTab(string tab)
    {
        if (tab == _activeTab) return;
        var route = tab == "library" ? "/registry/library" : "/registry";
        if (!string.IsNullOrEmpty(_debouncedSearchTerm))
            route += $"?q={Uri.EscapeDataString(_debouncedSearchTerm)}";
        Nav.NavigateTo(route);
    }

    private async Task LoadDataAsync()
    {
        _fourStateCounts = await Orchestrator.GetRegistryFourStateCountsAsync();
        if (_activeTab == "library")
            _batches = await Orchestrator.GetIngestionBatchesAsync();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? "";
        _debounceTimer?.Dispose();
        _debounceTimer = new Timer(_ =>
        {
            InvokeAsync(() =>
            {
                _debouncedSearchTerm = _searchTerm;
                UpdateUrlWithSearch();
                StateHasChanged();
            });
        }, null, 300, Timeout.Infinite);
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _debounceTimer?.Dispose();
            _debouncedSearchTerm = _searchTerm;
            UpdateUrlWithSearch();
            StateHasChanged();
        }
    }

    private void UpdateUrlWithSearch()
    {
        var basePath = _activeTab == "library" ? "/registry/library" : "/registry";
        var url = string.IsNullOrEmpty(_debouncedSearchTerm)
            ? basePath
            : $"{basePath}?q={Uri.EscapeDataString(_debouncedSearchTerm)}";
        Nav.NavigateTo(url, replace: true);
    }

    private void HandleTimelineNavigate(Guid? batchId)
    {
        var target = batchId.HasValue ? $"?source=batch-{batchId.Value}" : "";
        Nav.NavigateTo($"/registry/activity{target}");
    }

    private void HandleBatchSelected(Guid batchId)
    {
        Nav.NavigateTo($"/registry/activity?source=batch-{batchId}");
    }

    private void HandleAttentionClicked()
    {
        Nav.NavigateTo("/registry/activity?state=review");
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var previousTab = _activeTab;
        SyncTabFromUrl();

        // Load batches if switching to library tab
        if (_activeTab == "library" && previousTab != "library")
            _batches = await Orchestrator.GetIngestionBatchesAsync();

        await InvokeAsync(StateHasChanged);
    }

    private async void HandleIntercomEvent()
    {
        await InvokeAsync(async () =>
        {
            await LoadDataAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
        Nav.LocationChanged -= OnLocationChanged;
        Orchestrator.OnActivityChanged -= HandleIntercomEvent;
        Orchestrator.OnReviewCountChanged -= HandleIntercomEvent;
    }
}
