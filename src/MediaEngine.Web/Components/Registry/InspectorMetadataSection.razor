@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Registry
@using MudBlazor

<div class="ims-container">
    <button class="ims-header" @onclick="ToggleExpanded" aria-expanded="@_expanded">
        <span class="ims-header-label">METADATA DETAIL</span>
        <MudIcon Icon="@(_expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                 Class="ims-chevron" />
    </button>

    @if (_expanded)
    {
        <div class="ims-body">
            @if (Loading)
            {
                <div class="ims-loading">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Default" />
                </div>
            }
            else if (Fields == null || !Fields.Any(f => !string.IsNullOrEmpty(f.Value)))
            {
                <div class="ims-empty">No metadata available</div>
            }
            else
            {
                @foreach (var field in Fields.Where(f => !string.IsNullOrEmpty(f.Value)))
                {
                    <div class="ims-field">
                        <div class="ims-field-header">
                            <span class="ims-field-key">@FormatFieldKey(field.Key)</span>
                            @if (field.IsUserLocked)
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.Lock"
                                         Style="font-size: 0.7rem; color: #C9922E;" />
                            }
                            @if (field.IsConflicted)
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.Warning"
                                         Style="font-size: 0.7rem; color: #EF9F27;" />
                            }
                            <span class="ims-field-conf"
                                  style="color: @RegistryHelpers.GetConfidenceHexColor(field.Confidence);">
                                @((int)(field.Confidence * 100))%
                            </span>
                        </div>
                        <div class="ims-field-value">@field.Value</div>
                        @if (!string.IsNullOrEmpty(field.ProviderName))
                        {
                            <span class="ims-field-provider">via @field.ProviderName</span>
                        }
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<CanonicalFieldViewModel> Fields { get; set; } = [];
    [Parameter] public bool Loading { get; set; }

    private bool _expanded = false;

    private void ToggleExpanded() => _expanded = !_expanded;

    private static string FormatFieldKey(string key) => key switch
    {
        "title"           => "Title",
        "author"          => "Author",
        "year"            => "Year",
        "genre"           => "Genre",
        "series"          => "Series",
        "series_position" => "Series #",
        "description"     => "Description",
        "narrator"        => "Narrator",
        "director"        => "Director",
        "cast"            => "Cast",
        "language"        => "Language",
        "rating"          => "Rating",
        "page_count"      => "Pages",
        "publisher"       => "Publisher",
        "cover"           => "Cover Art",
        "wikidata_qid"    => "Wikidata QID",
        _                 => RegistryHelpers.FormatBridgeKey(key),
    };
}

<style>
    .ims-container {
        font-family: 'Montserrat', sans-serif;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .ims-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        padding: 10px 14px;
        background: transparent;
        border: none;
        cursor: pointer;
        color: rgba(255, 255, 255, 0.45);
        transition: color 0.15s ease;
    }

    .ims-header:hover {
        color: rgba(255, 255, 255, 0.70);
    }

    .ims-header-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .ims-chevron {
        font-size: 1rem !important;
        color: inherit;
        flex-shrink: 0;
    }

    .ims-body {
        padding: 0 14px 12px;
    }

    .ims-loading {
        display: flex;
        justify-content: center;
        padding: 16px 0;
    }

    .ims-empty {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.30);
        text-align: center;
        padding: 12px 0;
        font-style: italic;
    }

    .ims-field {
        padding: 8px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .ims-field:last-child {
        border-bottom: none;
    }

    .ims-field-header {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 2px;
    }

    .ims-field-key {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.40);
        flex: 1;
    }

    .ims-field-conf {
        font-size: 10px;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        margin-left: auto;
    }

    .ims-field-value {
        font-size: 12px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.4;
        word-break: break-word;
    }

    .ims-field-provider {
        display: block;
        font-size: 10px;
        color: rgba(255, 255, 255, 0.28);
        margin-top: 2px;
        font-style: italic;
    }
</style>
