@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.Registry
@using MudBlazor

<div class="ims-panel">
    @if (Loading)
    {
        <div class="ims-loading">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Default" />
        </div>
    }
    else if (Fields == null || !Fields.Any(f => !string.IsNullOrEmpty(f.Value)))
    {
        <div class="ims-empty">No metadata available</div>
    }
    else
    {
        @foreach (var field in Fields.Where(f => !string.IsNullOrEmpty(f.Value)))
        {
            <div class="ims-field">
                <div class="ims-field-header">
                    <span class="ims-field-key">@FormatFieldKey(field.Key)</span>
                    @if (field.IsUserLocked)
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Lock"
                                 Style="font-size: 0.7rem; color: #C9922E;" />
                    }
                    @if (field.IsConflicted)
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Warning"
                                 Style="font-size: 0.7rem; color: #EF9F27;" />
                    }
                    <span class="ims-field-conf"
                          style="color: @RegistryHelpers.GetConfidenceHexColor(field.Confidence);">
                        @((int)(field.Confidence * 100))%
                    </span>
                </div>
                @if (field.Key == "wikidata_qid" && !string.IsNullOrEmpty(field.Value))
                {
                    <span class="ims-qid-chip">@field.Value</span>
                }
                else
                {
                    <div class="ims-field-value">@field.Value</div>
                }
                @if (!string.IsNullOrEmpty(field.ProviderName))
                {
                    <span class="ims-field-provider">via @field.ProviderName</span>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public List<CanonicalFieldViewModel> Fields { get; set; } = [];
    [Parameter] public bool Loading { get; set; }

    private static string FormatFieldKey(string key) => key switch
    {
        "title"           => "Title",
        "author"          => "Author",
        "year"            => "Year",
        "genre"           => "Genre",
        "series"          => "Series",
        "series_position" => "Series #",
        "description"     => "Description",
        "narrator"        => "Narrator",
        "director"        => "Director",
        "cast"            => "Cast",
        "language"        => "Language",
        "rating"          => "Rating",
        "page_count"      => "Pages",
        "publisher"       => "Publisher",
        "cover"           => "Cover Art",
        "wikidata_qid"    => "Wikidata QID",
        _                 => RegistryHelpers.FormatBridgeKey(key),
    };
}

<style>
    .ims-panel {
        font-family: 'Montserrat', sans-serif;
        padding: 14px;
    }

    .ims-loading {
        display: flex;
        justify-content: center;
        padding: 24px 0;
    }

    .ims-empty {
        font-size: 11px;
        font-weight: 400;
        font-style: italic;
        color: rgba(200, 190, 220, 0.35);
        text-align: center;
        padding: 24px 0;
    }

    .ims-field {
        padding: 8px 0;
        border-bottom: 1px solid rgba(140, 120, 180, 0.08);
    }

    .ims-field:last-child {
        border-bottom: none;
    }

    .ims-field-header {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 3px;
    }

    .ims-field-key {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: rgba(200, 190, 220, 0.40);
        flex: 1;
    }

    .ims-field-conf {
        font-size: 10px;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        margin-left: auto;
    }

    .ims-field-value {
        font-size: 12px;
        font-weight: 500;
        color: rgba(200, 190, 220, 0.85);
        line-height: 1.4;
        word-break: break-word;
    }

    .ims-field-provider {
        display: block;
        font-size: 10px;
        font-style: italic;
        color: rgba(200, 190, 220, 0.28);
        margin-top: 2px;
    }

    .ims-qid-chip {
        display: inline-block;
        font-size: 11px;
        font-weight: 600;
        font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
        color: #5DCAA5;
        background: rgba(93, 202, 165, 0.10);
        border: 1px solid rgba(93, 202, 165, 0.20);
        padding: 2px 8px;
        border-radius: 4px;
        letter-spacing: 0.02em;
    }
</style>
