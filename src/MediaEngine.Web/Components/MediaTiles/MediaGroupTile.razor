@namespace MediaEngine.Web.Components.MediaTiles
@using MediaEngine.Web.Components.Shared
@inject NavigationManager Nav

<AppCssElement Tag="div" Css="@($"display: contents; {TileStyle}")">
    <article class="media-group-tile @(UsesGlowOnlyHover ? "is-glow-only" : null) @(ShowCompactCaption ? "has-compact-caption" : null)" aria-label="@Item.Title">
        <a class="media-group-tile__surface"
           href="@GroupNavigationUrl"
           aria-label="@($"Open {GroupKindLabel} {Item.Title}")"
           @onclick="OpenGroupAsync"
           @onclick:preventDefault="true">
            <div class="media-group-tile__atmosphere" aria-hidden="true"></div>

            @if (RepresentativeItems.Count > 0)
            {
                <div class="media-group-tile__artwork">
                    <MediaArtworkGroupPreview Items="@RepresentativeItems"
                                              TotalCount="@ResolvedTotalCount"
                                              Layout="MediaArtworkGroupPreviewLayout.Cluster"
                                              ShowOverflowCount="false"
                                              AriaLabel="@($"Representative artwork from {Item.Title}")" />
                </div>
            }
            else
            {
                <div class="media-group-tile__fallback" role="img" aria-label="@($"No artwork available for {Item.Title}")">
                    <MudIcon Icon="@GroupKindIcon" />
                </div>
            }

            @if (ShowSummary)
            {
                <section class="media-group-tile__overlay" aria-hidden="true">
                    <span class="media-group-tile__kind">
                        <MudIcon Icon="@GroupKindIcon" />
                        <span>@GroupKindLabel</span>
                    </span>
                    <h3>@Item.Title</h3>
                    <p>@GroupStatusLabel</p>
                </section>
            }

            @if (ShowCompactCaption)
            {
                <section class="media-group-tile__embedded-identity" aria-hidden="true">
                    <div>
                        <h3>@Item.Title</h3>
                        @if (Item.SortYear is >= 1800 and <= 2200)
                        {
                            <span class="media-group-tile__embedded-year">@Item.SortYear</span>
                        }
                        <span class="media-group-tile__embedded-count">
                            <MudIcon Icon="@GroupKindIcon" />
                            <span>@($"{ResolvedTotalCount} {GroupCountNoun}")</span>
                        </span>
                    </div>
                    <span class="media-group-tile__open-cue">
                        <span>Open @GroupActionNoun</span>
                        <MudIcon Icon="@Icons.Material.Outlined.ArrowForward" />
                    </span>
                </section>
            }
        </a>
    </article>
</AppCssElement>

@code {
    [Parameter, EditorRequired] public MediaTileViewModel Item { get; set; } = default!;
    [Parameter] public MediaTileHoverMode? HoverMode { get; set; }
    [Parameter] public bool ShowCompactCaption { get; set; }

    private MediaTileHoverMode EffectiveHoverMode => HoverMode ?? Item.HoverMode;
    private bool UsesGlowOnlyHover => EffectiveHoverMode == MediaTileHoverMode.GlowOnly;
    private bool ShowSummary => EffectiveHoverMode is not (MediaTileHoverMode.None or MediaTileHoverMode.GlowOnly);
    private int ResolvedTotalCount => Math.Max(Item.GroupSummary?.OwnedCount ?? Item.PreviewTotalCount ?? RepresentativeItems.Count, RepresentativeItems.Count);

    // The API orders series previews by progress and canonical position and already caps
    // the result at four. Preserve that order here instead of applying a second selection pass.
    private IReadOnlyList<ArtworkStackItem> RepresentativeItems => BuildRepresentativeItems();

    private bool IsSeries => Item.Presentation is MediaTilePresentation.MovieSeries
        or MediaTilePresentation.BookSeries
        or MediaTilePresentation.ComicSeries
        or MediaTilePresentation.AudiobookSeries;

    private string GroupNavigationUrl =>
        FirstNonBlank(Item.DetailsNavigationUrl, Item.NavigationUrl, Item.PrimaryNavigationUrl) ?? "/";

    private string TileStyle
    {
        get
        {
            var atmosphere = FirstNonBlank(
                RepresentativeItems.FirstOrDefault(item => !string.IsNullOrWhiteSpace(item.ImageUrl))?.ImageUrl,
                Item.HeroBackgroundImageUrl,
                Item.BackgroundUrl,
                Item.HoverImageUrl,
                Item.TileImageUrl);
            var imageVariable = string.IsNullOrWhiteSpace(atmosphere)
                ? string.Empty
                : $"--media-group-image: url(\"{EscapeCssString(atmosphere)}\");";
            return $"{Item.ArtworkPalette?.CssVariableStyle} --media-group-accent: {Item.AccentColor}; --media-group-secondary: {Item.SecondaryAccentColor}; {imageVariable}";
        }
    }

    private string GroupKindLabel
    {
        get
        {
            if (Item.Presentation == MediaTilePresentation.Default)
            {
                if (Item.GroupSummary?.RelationshipLabel?.Contains("Ordered", StringComparison.OrdinalIgnoreCase) == true)
                {
                    return "Ordered Collection";
                }

                if (string.Equals(Item.GroupSummary?.RelationshipLabel, "Smart collection", StringComparison.OrdinalIgnoreCase))
                {
                    return "Automated Collection";
                }

                if (Item.MediaCounts.Count > 1)
                {
                    return "Mixed-Media Collection";
                }

                if (string.Equals(Item.GroupSummary?.RelationshipLabel, "Curated collection", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(Item.GroupSummary?.RelationshipLabel, "Curated list", StringComparison.OrdinalIgnoreCase))
                {
                    return "Curated Collection";
                }
            }

            return Item.Presentation switch
            {
                MediaTilePresentation.MovieSeries => "Movie Series",
                MediaTilePresentation.BookSeries => "Book Series",
                MediaTilePresentation.ComicSeries => "Comic Series",
                MediaTilePresentation.AudiobookSeries => "Audiobook Series",
                _ => "Collection",
            };
        }
    }

    private string GroupKindIcon => Item.Presentation switch
    {
        MediaTilePresentation.BookSeries or MediaTilePresentation.ComicSeries => Icons.Material.Outlined.AutoStories,
        MediaTilePresentation.MovieSeries => Icons.Material.Outlined.VideoLibrary,
        MediaTilePresentation.AudiobookSeries => Icons.Material.Outlined.Headphones,
        _ => Icons.Material.Outlined.CollectionsBookmark,
    };

    private string GroupStatusLabel
    {
        get
        {
            var summary = Item.GroupSummary;
            if (IsSeries && summary?.InProgressCount > 0)
            {
                var current = RepresentativeItems.FirstOrDefault();
                if (current is not null && !string.IsNullOrWhiteSpace(current.Title))
                {
                    return $"Continue with {current.Title}";
                }
            }

            if (summary?.KnownTotalCount is > 0 && summary.KnownTotalCount >= summary.OwnedCount)
            {
                return $"{summary.OwnedCount} of {summary.KnownTotalCount} owned";
            }

            if (IsSeries && summary is not null && summary.OwnedCount > 0 && summary.CompletedCount >= summary.OwnedCount)
            {
                return "Series complete";
            }

            if (!IsSeries && Item.MediaCounts.Count > 1)
            {
                return $"{ResolvedTotalCount} items · {Item.MediaCounts.Count} media types";
            }

            return $"{ResolvedTotalCount} {GroupCountNoun}";
        }
    }

    private string GroupCountNoun => Item.Presentation switch
    {
        MediaTilePresentation.BookSeries => ResolvedTotalCount == 1 ? "book" : "books",
        MediaTilePresentation.ComicSeries => ResolvedTotalCount == 1 ? "owned issue" : "owned issues",
        MediaTilePresentation.MovieSeries => ResolvedTotalCount == 1 ? "movie" : "movies",
        MediaTilePresentation.AudiobookSeries => ResolvedTotalCount == 1 ? "audiobook" : "audiobooks",
        _ => ResolvedTotalCount == 1 ? "item" : "items",
    };

    private string GroupActionNoun => IsSeries ? "Series" : "Collection";

    private IReadOnlyList<ArtworkStackItem> BuildRepresentativeItems()
    {
        var available = new List<ArtworkStackItem>();
        var ids = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var imageUrls = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var item in Item.ArtworkStackItems)
        {
            if (string.IsNullOrWhiteSpace(item.Id)
                || string.IsNullOrWhiteSpace(item.ImageUrl)
                || !ids.Add(item.Id))
            {
                continue;
            }

            if (!string.IsNullOrWhiteSpace(item.ImageUrl) && !imageUrls.Add(item.ImageUrl))
            {
                continue;
            }

            available.Add(item);
        }

        if (available.Count <= 4 || IsSeries || Item.GroupSummary?.RelationshipLabel?.Contains("Ordered", StringComparison.OrdinalIgnoreCase) == true)
        {
            return available.Take(4).ToList();
        }

        if (Item.MediaCounts.Count > 1)
        {
            return available
                .GroupBy(item => item.MediaType, StringComparer.OrdinalIgnoreCase)
                .Select(group => group.First())
                .Concat(available)
                .DistinctBy(item => item.Id)
                .Take(4)
                .ToList();
        }

        return available.Take(4).ToList();
    }

    private Task OpenGroupAsync(MouseEventArgs _)
    {
        Nav.NavigateTo(GroupNavigationUrl);
        return Task.CompletedTask;
    }

    private static string EscapeCssString(string value) =>
        value.Replace("\\", "\\\\", StringComparison.Ordinal).Replace("\"", "\\\"", StringComparison.Ordinal);

    private static string? FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));
}
