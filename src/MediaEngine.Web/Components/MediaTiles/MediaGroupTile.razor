@namespace MediaEngine.Web.Components.MediaTiles
@using MediaEngine.Web.Components.Shared
@inject NavigationManager Nav

<AppCssElement Tag="div" Css="@($"display: contents; {TileStyle}")">
    <article class="media-group-tile" aria-label="@Item.Title">
        <div class="media-group-tile__frame">
            <a class="media-group-tile__base"
               href="@GroupNavigationUrl"
               aria-label="@($"Open {GroupKindLabel} {Item.Title}")"
               @onclick="OpenGroupAsync"
               @onclick:preventDefault="true">
                <div class="media-group-tile__atmosphere" aria-hidden="true"></div>

                @if (RepresentativeItems.Count > 0)
                {
                    <div class="media-group-tile__base-artwork">
                        <MediaArtworkGroupPreview Items="@RepresentativeItems"
                                                  TotalCount="@ResolvedTotalCount"
                                                  Layout="MediaArtworkGroupPreviewLayout.Strip"
                                                  ShowOverflowCount="false"
                                                  AriaLabel="@($"Artwork from {Item.Title}")" />
                    </div>
                }
                else
                {
                    <div class="media-group-tile__fallback">
                        <MudIcon Icon="@GroupKindIcon" />
                    </div>
                }

                <div class="media-group-tile__base-copy">
                    <span class="media-group-tile__kind">
                        <MudIcon Icon="@GroupKindIcon" />
                        <span>@GroupKindLabel</span>
                    </span>
                    <strong>@Item.Title</strong>
                    <span class="media-group-tile__base-summary">@GroupSummaryLabel</span>
                    @if (Item.MediaCounts.Count > 0)
                    {
                        <div class="media-group-tile__base-counts">
                            @foreach (var count in Item.MediaCounts.Take(4))
                            {
                                <span @key="count.Label">
                                    <MudIcon Icon="@count.Icon" />
                                    <span>@count.Count @count.Label</span>
                                </span>
                            }
                        </div>
                    }
                </div>
            </a>

            @if (ShowSummary)
            {
                <div class="media-group-tile__hover">
                    <div class="media-group-tile__hover-atmosphere" aria-hidden="true"></div>

                    <div class="@SummaryArtworkClass">
                        @if (RepresentativeItems.Count > 0)
                        {
                            <MediaArtworkGroupPreview Items="@RepresentativeItems"
                                                      TotalCount="@ResolvedTotalCount"
                                                      Layout="MediaArtworkGroupPreviewLayout.Strip"
                                                      ShowOverflowCount="false"
                                                      AriaLabel="@($"Representative artwork from {Item.Title}")" />
                        }
                        else
                        {
                            <div class="media-group-tile__fallback">
                                <MudIcon Icon="@GroupKindIcon" />
                            </div>
                        }
                    </div>

                    <section class="media-group-tile__identity" aria-label="@($"About {Item.Title}")">
                        <span class="media-group-tile__kind">
                            <MudIcon Icon="@GroupKindIcon" />
                            <span>@GroupKindLabel</span>
                        </span>

                        <h3>@Item.Title</h3>

                        @if (!string.IsNullOrWhiteSpace(GroupDescription))
                        {
                            <p class="media-group-tile__description">@GroupDescription</p>
                        }

                        <p class="media-group-tile__summary-line" aria-label="@GroupSummaryLabel">
                            <strong>@GroupSummaryLabel</strong>
                            @if (!string.IsNullOrWhiteSpace(Item.GroupSummary?.RelationshipLabel))
                            {
                                <span>@Item.GroupSummary?.RelationshipLabel</span>
                            }
                        </p>

                        @if (OverviewRows.Count > 0)
                        {
                            <div class="media-group-tile__overview">
                                <span>At a glance</span>
                                <ul>
                                    @foreach (var row in OverviewRows)
                                    {
                                        <li @key="@($"{row.Label}:{row.Value}")">
                                            <MudIcon Icon="@row.Icon" />
                                            <span>@row.Label</span>
                                            @if (!string.IsNullOrWhiteSpace(row.Value))
                                            {
                                                <strong>@row.Value</strong>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        }

                        <div class="media-group-tile__actions">
                            <AppNativeButton Type="button"
                                             Class="tl-media-action tl-media-action--primary tl-media-action--compact media-group-tile__group-action"
                                             AriaLabel="@($"Open {GroupKindLabel} {Item.Title}")"
                                             Title="@($"Open {GroupKindLabel} {Item.Title}")"
                                             StopPropagation="true"
                                             OnClick="OpenGroupAsync">
                                <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" />
                                <span>Open @ShortGroupKindLabel</span>
                            </AppNativeButton>
                        </div>
                    </section>
                </div>
            }
        </div>
    </article>
</AppCssElement>

@code {
    [Parameter, EditorRequired] public MediaTileViewModel Item { get; set; } = default!;
    [Parameter] public MediaTileHoverMode? HoverMode { get; set; }

    private MediaTileHoverMode EffectiveHoverMode => HoverMode ?? Item.HoverMode;
    private bool ShowSummary => EffectiveHoverMode != MediaTileHoverMode.None;
    private int ResolvedTotalCount => Math.Max(Item.GroupSummary?.OwnedCount ?? Item.PreviewTotalCount ?? RepresentativeItems.Count, RepresentativeItems.Count);

    private IReadOnlyList<ArtworkStackItem> RepresentativeItems => SelectRepresentativeItems(Item.ArtworkStackItems);

    private IReadOnlyList<GroupOverviewRow> OverviewRows => BuildOverviewRows();

    private string SummaryArtworkClass => RepresentativeItems.Count >= 3
        ? "media-group-tile__summary-artwork is-dense"
        : "media-group-tile__summary-artwork";

    private bool IsSeries => Item.Presentation is MediaTilePresentation.MovieSeries
        or MediaTilePresentation.BookSeries
        or MediaTilePresentation.ComicSeries
        or MediaTilePresentation.AudiobookSeries;

    private string GroupNavigationUrl =>
        FirstNonBlank(Item.PrimaryNavigationUrl, Item.NavigationUrl, Item.DetailsNavigationUrl) ?? "/";

    private string TileStyle
    {
        get
        {
            var atmosphere = FirstNonBlank(
                RepresentativeItems.FirstOrDefault()?.ImageUrl,
                Item.HeroBackgroundImageUrl,
                Item.BackgroundUrl,
                Item.HoverImageUrl,
                Item.TileImageUrl);
            var imageVariable = string.IsNullOrWhiteSpace(atmosphere)
                ? string.Empty
                : $"--media-group-image: url(\"{EscapeCssString(atmosphere)}\");";
            return $"{Item.ArtworkPalette?.CssVariableStyle} --media-group-accent: {Item.AccentColor}; --media-group-secondary: {Item.SecondaryAccentColor}; {imageVariable}";
        }
    }

    private string? GroupDescription => FirstNonBlank(Item.Description, Item.Tldr);

    private string GroupKindLabel => Item.Presentation switch
    {
        MediaTilePresentation.MovieSeries => "Movie Series",
        MediaTilePresentation.BookSeries => "Book Series",
        MediaTilePresentation.ComicSeries => "Comic Series",
        MediaTilePresentation.AudiobookSeries => "Audiobook Series",
        _ => "Collection",
    };

    private string ShortGroupKindLabel => IsSeries ? "Series" : "Collection";

    private string GroupKindIcon => Item.Presentation switch
    {
        MediaTilePresentation.BookSeries or MediaTilePresentation.ComicSeries => Icons.Material.Outlined.AutoStories,
        MediaTilePresentation.MovieSeries => Icons.Material.Outlined.VideoLibrary,
        MediaTilePresentation.AudiobookSeries => Icons.Material.Outlined.Headphones,
        _ => Icons.Material.Outlined.CollectionsBookmark,
    };

    private string GroupCountNoun => Item.Presentation switch
    {
        MediaTilePresentation.BookSeries => ResolvedTotalCount == 1 ? "book" : "books",
        MediaTilePresentation.ComicSeries => ResolvedTotalCount == 1 ? "owned issue" : "owned issues",
        MediaTilePresentation.MovieSeries => ResolvedTotalCount == 1 ? "movie" : "movies",
        MediaTilePresentation.AudiobookSeries => ResolvedTotalCount == 1 ? "audiobook" : "audiobooks",
        _ => ResolvedTotalCount == 1 ? "item" : "items",
    };

    private string GroupCountLabel => $"{ResolvedTotalCount} {GroupCountNoun}";

    private string GroupSummaryLabel
    {
        get
        {
            var summary = Item.GroupSummary;
            if (summary?.KnownTotalCount is > 0 && summary.KnownTotalCount >= summary.OwnedCount)
            {
                return $"{summary.OwnedCount} of {summary.KnownTotalCount} owned";
            }

            if (!IsSeries && Item.MediaCounts.Count > 1)
            {
                return $"{ResolvedTotalCount} items across {Item.MediaCounts.Count} media types";
            }

            return GroupCountLabel;
        }
    }

    private IReadOnlyList<GroupOverviewRow> BuildOverviewRows()
    {
        var rows = new List<GroupOverviewRow>();
        if (!IsSeries && Item.MediaCounts.Count > 0)
        {
            rows.AddRange(Item.MediaCounts
                .Where(count => count.Count > 0)
                .Take(4)
                .Select(count => new GroupOverviewRow(count.Icon, count.Label, count.Count.ToString())));
            return rows;
        }

        if (!string.IsNullOrWhiteSpace(Item.GroupSummary?.SequenceRange))
        {
            rows.Add(new GroupOverviewRow(Icons.Material.Outlined.FormatListNumbered, Item.GroupSummary.SequenceRange, null));
        }

        var status = GroupProgressSummary;
        if (!string.IsNullOrWhiteSpace(status))
        {
            rows.Add(new GroupOverviewRow(Icons.Material.Outlined.DonutLarge, "Library status", status));
        }

        if (rows.Count == 0 && Item.MediaCounts.Count == 1)
        {
            var count = Item.MediaCounts[0];
            rows.Add(new GroupOverviewRow(count.Icon, count.Label, count.Count.ToString()));
        }

        return rows.Take(3).ToList();
    }

    private string? GroupProgressSummary
    {
        get
        {
            var summary = Item.GroupSummary;
            if (summary is null || summary.CompletedCount == 0 && summary.InProgressCount == 0)
            {
                return null;
            }

            var values = new List<string>();
            if (summary.CompletedCount > 0)
            {
                values.Add($"{summary.CompletedCount} complete");
            }

            if (summary.InProgressCount > 0)
            {
                values.Add($"{summary.InProgressCount} in progress");
            }

            return string.Join(" \u00b7 ", values);
        }
    }

    private static IReadOnlyList<ArtworkStackItem> SelectRepresentativeItems(IReadOnlyList<ArtworkStackItem> items)
    {
        var available = items
            .Where(item => !string.IsNullOrWhiteSpace(item.ImageUrl))
            .DistinctBy(item => item.Id)
            .DistinctBy(item => item.ImageUrl, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (available.Count <= 4)
        {
            return available;
        }

        var byMediaType = available
            .GroupBy(item => item.MediaType, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .Take(4)
            .ToList();
        if (byMediaType.Count > 1)
        {
            return byMediaType
                .Concat(available)
                .DistinctBy(item => item.Id)
                .Take(4)
                .ToList();
        }

        return new[] { available[0], available[1], available[^2], available[^1] }
            .DistinctBy(item => item.Id)
            .Take(4)
            .ToList();
    }

    private Task OpenGroupAsync(MouseEventArgs _)
    {
        Nav.NavigateTo(GroupNavigationUrl);
        return Task.CompletedTask;
    }

    private static string EscapeCssString(string value) =>
        value.Replace("\\", "\\\\", StringComparison.Ordinal).Replace("\"", "\\\"", StringComparison.Ordinal);

    private static string? FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private sealed record GroupOverviewRow(string Icon, string Label, string? Value);
}
