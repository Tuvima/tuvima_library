@namespace MediaEngine.Web.Components.MediaTiles

<AppCssElement Tag="div" Class="@GridClass" Css="@GridStyle">
    @foreach (var item in Items)
    {
        @if (item.UseLandscapeGroupTile)
        {
            <MediaGroupTile Item="@item"
                            HoverMode="@HoverMode"
                            ShowCompactCaption="@ShowCompactCaptions"
                            @key="item.Id" />
        }
        else
        {
            <MediaTile Item="@item"
                       HoverMode="@HoverMode"
                       HideMediaKindBadge="@HideMediaKindBadges"
                       HideSourceBadge="@HideSourceBadges"
                       ShowCompactCaption="@ShowCompactCaptions"
                       @key="item.Id" />
        }
    }
</AppCssElement>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<MediaTileViewModel> Items { get; set; } = [];
    [Parameter] public MediaTileHoverMode? HoverMode { get; set; } = MediaTileHoverMode.GlowOnly;
    [Parameter] public bool HideMediaKindBadges { get; set; }
    [Parameter] public bool HideSourceBadges { get; set; }
    [Parameter] public bool ShowCompactCaptions { get; set; }
    [Parameter] public int? TileSizePx { get; set; }
    [Parameter] public string? Class { get; set; }

    private string GridClass =>
        $"media-tile-grid {(TileSizePx is > 0 ? "is-size-controlled" : string.Empty)} {Class}".Trim();

    private string? GridStyle
    {
        get
        {
            if (TileSizePx is not > 0)
            {
                return null;
            }

            var tileSize = Math.Clamp(TileSizePx.Value, 88, 280);
            var groupWidth = (tileSize * 3) + 40;
            var groupHeight = (int)Math.Round(groupWidth * 0.52, MidpointRounding.AwayFromZero);
            return $"--media-grid-tile-size: {tileSize}px; --media-grid-group-width: {groupWidth}px; --media-grid-group-height: {groupHeight}px;";
        }
    }
}
