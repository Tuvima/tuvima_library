@namespace MediaEngine.Web.Components.MediaTiles

<div class="@GridClass">
    @foreach (var item in Items)
    {
        @if (item.UseLandscapeGroupTile)
        {
            <MediaGroupTile Item="@item"
                            HoverMode="@HoverMode"
                            ShowCompactCaption="@ShowCompactCaptions"
                            @key="item.Id" />
        }
        else
        {
            <MediaTile Item="@item"
                       HoverMode="@HoverMode"
                       HideMediaKindBadge="@HideMediaKindBadges"
                       HideSourceBadge="@HideSourceBadges"
                       HideGroupIndicators="@HideGroupIndicators"
                       ShowCompactCaption="@ShowCompactCaptions"
                       @key="item.Id" />
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<MediaTileViewModel> Items { get; set; } = [];
    [Parameter] public MediaTileHoverMode? HoverMode { get; set; } = MediaTileHoverMode.GlowOnly;
    [Parameter] public bool HideMediaKindBadges { get; set; }
    [Parameter] public bool HideSourceBadges { get; set; }
    [Parameter] public bool HideGroupIndicators { get; set; }
    [Parameter] public bool ShowCompactCaptions { get; set; }
    [Parameter] public int? TileSizePx { get; set; }
    [Parameter] public string? Class { get; set; }

    private int? ResolvedTileSizePx => TileSizePx is > 0
        ? Math.Clamp((int)Math.Round(TileSizePx.Value / 8d, MidpointRounding.AwayFromZero) * 8, 96, 248)
        : null;

    private string GridClass =>
        $"media-tile-grid {(ResolvedTileSizePx.HasValue ? $"is-size-controlled media-tile-grid--size-{ResolvedTileSizePx.Value}" : string.Empty)} {Class}".Trim();
}
