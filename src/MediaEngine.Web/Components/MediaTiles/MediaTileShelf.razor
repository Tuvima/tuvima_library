@namespace MediaEngine.Web.Components.MediaTiles
@inject IJSRuntime JS
@inject ILogger<MediaTileShelf> Logger
@implements IAsyncDisposable

@if (Shelf.Items.Count > 0)
{
    <section class="media-tile-shelf @RowClass">
        @if (ShowHeader)
        {
            <div class="media-tile-shelf-header">
                <div class="media-tile-shelf-copy">
                    <h2 class="media-tile-shelf-title">@Shelf.Title</h2>
                    @if (!string.IsNullOrWhiteSpace(Shelf.Subtitle))
                    {
                        <p class="media-tile-shelf-subtitle">@Shelf.Subtitle</p>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Shelf.SeeAllRoute))
                {
                    <a href="@Shelf.SeeAllRoute" class="media-tile-shelf-link">View all</a>
                }
            </div>
        }

        <div class="media-tile-shelf-track">
            <div class="media-tile-shelf-arrow-slot media-tile-shelf-arrow-slot-left">
                @if (Shelf.Items.Count > 1 && !_atStart)
                {
                    <AppIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                   Color="Color.Inherit"
                                   Class="media-tile-shelf-arrow media-tile-shelf-arrow-left"
                                   aria-label="Scroll left"
                                   OnClick="ScrollLeftAsync" />
                }
            </div>

            <div class="media-tile-shelf-window">
                <div class="media-tile-shelf-scroll" @ref="_scrollRef">
                    @foreach (var item in Shelf.Items)
                    {
                        @if (UseContinueWatchingOrListeningTiles)
                        {
                            <ContinueWatchingOrListeningTile Item="@item"
                                                             HoverMode="@HoverMode"
                                                             OnPrimaryClicked="@OnPrimaryClicked"
                                                             HideMediaKindBadge="@HideMediaKindBadges"
                                                             HideSourceBadge="@HideSourceBadges" />
                        }
                        else
                        {
                            <MediaTile Item="@item"
                                       HoverMode="@HoverMode"
                                       OnPrimaryClicked="@OnPrimaryClicked"
                                       HideMediaKindBadge="@HideMediaKindBadges"
                                       HideSourceBadge="@HideSourceBadges" />
                        }
                    }
                </div>
            </div>

            <div class="media-tile-shelf-arrow-slot media-tile-shelf-arrow-slot-right">
                @if (Shelf.Items.Count > 1 && !_atEnd)
                {
                    <AppIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                   Color="Color.Inherit"
                                   Class="media-tile-shelf-arrow media-tile-shelf-arrow-right"
                                   aria-label="Scroll right"
                                   OnClick="ScrollRightAsync" />
                }
            </div>
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public MediaTileShelfViewModel Shelf { get; set; } = default!;
    [Parameter] public MediaTileHoverMode? HoverMode { get; set; }
    [Parameter] public bool HideMediaKindBadges { get; set; }
    [Parameter] public bool HideSourceBadges { get; set; }
    [Parameter] public bool ShowHeader { get; set; } = true;
    [Parameter] public bool UseContinueWatchingOrListeningTiles { get; set; }
    [Parameter] public EventCallback<MediaTileViewModel> OnPrimaryClicked { get; set; }

    private ElementReference _scrollRef;
    private bool _atStart = true;
    private bool _atEnd;
    private bool _scrollGuardRegistered;

    private string RowClass => Shelf.Items.FirstOrDefault()?.Shape switch
    {
        MediaTileShape.Landscape => "is-landscape-row",
        MediaTileShape.Square => "is-square-row",
        MediaTileShape.Portrait => "is-portrait-row",
        _ => string.Empty,
    };

    protected override void OnParametersSet()
    {
        _atStart = true;
        _atEnd = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if ((firstRender || Shelf.Items.Count > 1) && Shelf.Items.Count > 1)
        {
            var state = await JS.InvokeAsync<ScrollBoundary?>("getSwimlaneScrollState", _scrollRef);
            _atStart = state?.AtStart ?? true;
            _atEnd = state?.AtEnd ?? false;

            if (firstRender)
            {
                await RegisterScrollGuardAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task RegisterScrollGuardAsync()
    {
        if (_scrollGuardRegistered)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("registerMediaTileShelfScrollGuard", _scrollRef);
            _scrollGuardRegistered = true;
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not register media tile shelf scroll guard.");
        }
    }

    private async Task ScrollLeftAsync()
    {
        var state = await JS.InvokeAsync<ScrollBoundary>("scrollSwimlaneEx", _scrollRef, "left");
        _atStart = state.AtStart;
        _atEnd = state.AtEnd;
    }

    private async Task ScrollRightAsync()
    {
        var state = await JS.InvokeAsync<ScrollBoundary>("scrollSwimlaneEx", _scrollRef, "right");
        _atStart = state.AtStart;
        _atEnd = state.AtEnd;
    }

    private sealed class ScrollBoundary
    {
        public bool AtStart { get; set; }
        public bool AtEnd { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        if (!_scrollGuardRegistered)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("unregisterMediaTileShelfScrollGuard", _scrollRef);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not unregister media tile shelf scroll guard.");
        }
    }
}
