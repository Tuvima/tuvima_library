@namespace MediaEngine.Web.Components.MediaTiles
@using MediaEngine.Web.Components.Shared
@using MediaEngine.Web.Models.ViewDTOs
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject ILogger<MediaTile> Logger
@implements IAsyncDisposable

<div class='@($"media-tile tl-card-hover--media {ShapeClass} {MediaKindClass} {PresentationClass} {HoverLayoutClass} {SurfaceClass} {HoverPlacementClass} {HoverModeClass} {(Item.IsCollection ? "is-collection-card" : "")} {(UsesOrderedSeriesStack ? "is-ordered-series-card" : "")} {(_expanded ? "is-expanded" : "")} {(_dismissedFromContinue ? "is-dismissed" : "")}")'
     @ref="_cardRef"
     tabindex="0"
     @onkeydown="@HandleKeyDown">
    <div class="media-tile-frame">
        <div class="media-tile-media @(HasArtworkSurface ? "has-artwork-surface" : null)" @onclick="OpenDetails">
            @if (ShowCollectionBanner)
            {
                @if (!string.IsNullOrWhiteSpace(CardImageUrl))
                {
                    <img src="@CardImageUrl"
                         srcset="@Item.TileImageSrcSet"
                         sizes="@Item.TileImageSizes"
                         alt=""
                         class="media-tile-collection-backdrop @TileImageFitClass"
                         loading="lazy"
                         decoding="async" />
                }
                <div class="media-tile-collection-wash"></div>
                @if (ShowCollectionArtworkStack)
                {
                    <TuvimaArtworkStack Items="@CollectionArtworkStackItems"
                                        Seed="@CollectionStackSeed"
                                        Variant="@(UsesOrderedSeriesStack ? ArtworkStackVariant.SeriesStrip : ArtworkStackVariant.Card)"
                                        MaxVisible="4"
                                        IsDecorative="true"
                                        PreserveOrder="@UsesOrderedSeriesStack"
                                        Palette="@Item.ArtworkPalette"
                                        Class="@ArtworkStackClass" />
                }
            }
            else if (ShowPreviewStack)
            {
                <div class="media-tile-stack" aria-hidden="true">
                    @for (var index = 0; index < PreviewImages.Count; index++)
                    {
                        <img src="@PreviewImages[index]"
                             alt=""
                             class="@GetStackImageClass(index)"
                             loading="lazy"
                             decoding="async" />
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(CardImageUrl))
            {
                <img src="@CardImageUrl"
                     srcset="@Item.TileImageSrcSet"
                     sizes="@Item.TileImageSizes"
                     alt="@Item.Title"
                     class="media-tile-image @TileImageFitClass"
                     loading="lazy"
                     decoding="async" />
            }
            else
            {
                <div class="media-tile-fallback">
                    <MudIcon Icon="@FallbackIcon" Class="tl-u-font-size-44px tl-u-color-rgba-255-255-255--18" />
                    <span>@Item.Title</span>
                </div>
            }

            <div class="media-tile-gradient @(ShowTileLogo ? "is-banner-gradient" : "is-cover-gradient")"></div>

            @if (ShowTileLogo)
            {
                <img src="@Item.LogoUrl" alt="@Item.Title" class="media-tile-logo" />
            }

            @if (ShowMediaKindBadge)
            {
                <div class="media-tile-badge" title="@MediaKindLabel">
                    <MudIcon Icon="@MediaKindMudIcon" />
                    <span class="media-tile-visually-hidden">@MediaKindLabel</span>
                </div>
            }

            @if (ShowQualityBadge)
            {
                <div class="media-tile-quality-badge" title="@Item.QualityBadge">
                    @Item.QualityBadge
                </div>
            }

            @if (ShowSourceBadge)
            {
                <div class="media-tile-source-badge" title="@Item.SourceBadgeLabel">
                    @if (!string.IsNullOrWhiteSpace(Item.SourceLogoUrl))
                    {
                        <img src="@Item.SourceLogoUrl" alt="@Item.SourceBadgeLabel" class="media-tile-source-logo" loading="lazy" decoding="async" />
                    }
                    else
                    {
                        <span>@Item.SourceBadgeLabel</span>
                    }
                </div>
            }

            @if (Item.ProgressPct is > 0)
            {
                <div class="media-tile-progress-strip" aria-label="@ProgressAccessibleLabel">
                    <span class="media-tile-progress-percent">@ProgressPercentLabel</span>
                    <progress class="media-tile-progress"
                              value="@ProgressValue"
                              max="100"></progress>
                </div>
            }

            @if (ShowCollectionBanner && (ShowCollectionTitleOverlay || CollectionMediaCounts.Count > 0))
            {
                <div class="media-tile-collection-copy">
                    @if (ShowCollectionMediaIcon)
                    {
                        <MudIcon Icon="@MediaKindMudIcon"
                                 Class="media-tile-collection-kind-icon"
                                 title="@MediaKindLabel"
                                 aria-label="@MediaKindLabel" />
                    }
                    @if (ShowCollectionTitleOverlay)
                    {
                        <div class="media-tile-collection-title">@Item.Title</div>
                    }
                    @if (ShowCollectionSubtitle)
                    {
                        <div class="media-tile-collection-subtitle">
                            <span>@Item.Subtitle</span>
                            @if (!string.IsNullOrWhiteSpace(SeriesOverflowLabel))
                            {
                                <span>@SeriesOverflowLabel</span>
                            }
                        </div>
                    }
                    @if (CollectionMediaCounts.Count > 0)
                    {
                        <div class="media-tile-collection-counts">
                            @foreach (var count in CollectionMediaCounts)
                            {
                                <span class="media-tile-collection-count" title="@count.Label">
                                    <MudIcon Icon="@count.Icon" />
                                    <span>@count.Count</span>
                                </span>
                            }
                        </div>
                    }
                </div>
            }

        </div>
    </div>

    @if (IsHoverEnabled)
    {
        <MediaTileOverlay>
            <div class="@HoverPanelClass"
                 @onclick="OpenDetails"
                 @onclick:stopPropagation="true">
                <div class="media-tile-hover-art @(string.IsNullOrWhiteSpace(ActiveHoverImageUrl) ? "is-empty" : null)"
                     @onclick="OpenDetails"
                     @onclick:stopPropagation="true">
                    @if (!string.IsNullOrWhiteSpace(ActiveHoverImageUrl))
                    {
                        <img src="@ActiveHoverImageUrl"
                             srcset="@Item.HoverImageSrcSet"
                             sizes="@Item.HoverImageSizes"
                             alt="@Item.Title"
                             class="media-tile-hover-image @HoverImageFitClass"
                             loading="lazy"
                             decoding="async"
                             @onerror="HandleHoverImageError" />
                    }
                    else
                    {
                        <div class="media-tile-hover-fallback">
                            <MudIcon Icon="@FallbackIcon" />
                        </div>
                    }

                    @if (ShowHoverLogo)
                    {
                        <img src="@Item.LogoUrl" alt="@Item.Title" class="media-tile-hover-logo" />
                    }

                    @if (ShowHoverSeriesStack)
                    {
                        <TuvimaArtworkStack Items="@CollectionArtworkStackItems"
                                            Seed="@CollectionStackSeed"
                                            Variant="ArtworkStackVariant.SeriesStrip"
                                            MaxVisible="4"
                                            IsDecorative="false"
                                            AriaLabel="@($"{Item.Title} series preview")"
                                            PreserveOrder="true"
                                            Palette="@Item.ArtworkPalette"
                                            Class="media-tile-hover-series-stack" />
                    }

                    @if (CanRemoveFromContinue)
                    {
                        <AppNativeButton Type="button"
                                         Class="media-tile-hover-remove-corner media-tile-hover-control"
                                         AriaLabel="Remove from continue row"
                                         Title="Remove from continue row"
                                         OnClick="DismissFromContinue"
                                         StopPropagation="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Close" />
                            <span class="media-tile-visually-hidden">Remove from continue row</span>
                        </AppNativeButton>
                    }
                </div>

                @if (ShowExpandedHoverBody)
                {
                    <div class="media-tile-hover-body">
                        <div class="media-tile-hover-actions">
                            <div class="media-tile-hover-actions-left">
                                <div class="media-tile-hover-action-unit media-tile-hover-action-unit-primary">
                                    <AppNativeButton Type="button" Class="media-tile-hover-control media-tile-hover-control-primary" AriaLabel="@PrimaryActionDisplayLabel" Title="@PrimaryActionDisplayLabel" OnClick="OpenPrimary" StopPropagation="true">
                                        <MudIcon Icon="@PrimaryMudIcon" />
                                        <span class="media-tile-visually-hidden">@PrimaryActionDisplayLabel</span>
                                    </AppNativeButton>
                                    <span class="media-tile-hover-action-label">@PrimaryActionShortLabel</span>
                                </div>

                                <div class="media-tile-hover-action-unit">
                                    <AppNativeButton Type="button" Class="media-tile-hover-control media-tile-hover-control-secondary media-tile-add-action" AriaLabel="Add to collection" Title="Add to collection" Disabled="@(!Item.CanAddToCollection)" OnClick="OpenAddToCollectionAsync" StopPropagation="true">
                                        <MudIcon Icon="@Icons.Material.Outlined.Add" />
                                        <span class="media-tile-visually-hidden">Add to Collection</span>
                                    </AppNativeButton>
                                    <span class="media-tile-hover-action-label">Add</span>
                                </div>

                                <div class="media-tile-hover-action-unit">
                                    <div class="media-tile-feedback-control" aria-label="Feedback actions">
                                        <AppNativeButton Type="button" Class="media-tile-feedback-button media-tile-like-action" AriaLabel="Like" Title="Like" StopPropagation="true">
                                            <MudIcon Icon="@Icons.Material.Outlined.ThumbUp" />
                                            <span class="media-tile-visually-hidden">Like</span>
                                        </AppNativeButton>
                                        <AppNativeButton Type="button" Class="media-tile-feedback-button media-tile-dislike-action" AriaLabel="Dislike" Title="Dislike" StopPropagation="true">
                                            <MudIcon Icon="@Icons.Material.Outlined.ThumbDown" />
                                            <span class="media-tile-visually-hidden">Dislike</span>
                                        </AppNativeButton>
                                    </div>
                                    <span class="media-tile-hover-action-label">Like</span>
                                </div>
                            </div>

                            <div class="media-tile-hover-action-unit media-tile-hover-action-unit-details">
                                <AppNativeButton Type="button" Class="media-tile-hover-control media-tile-hover-control-secondary media-tile-details-action" AriaLabel="Details" Title="Details" OnClick="OpenDetails" StopPropagation="true">
                                    <MudIcon Icon="@Icons.Material.Outlined.ArrowForward" />
                                    <span class="media-tile-visually-hidden">Details</span>
                                </AppNativeButton>
                                <span class="media-tile-hover-action-label">Details</span>
                            </div>
                        </div>

                        @if (ShowHoverProgressRow)
                        {
                            <div class="media-tile-hover-progress" aria-label="@ProgressCompleteLabel">
                                <progress class="media-tile-hover-progress-track"
                                          value="@ProgressValue"
                                          max="100"></progress>
                                <span>@ProgressCompleteLabel</span>
                            </div>
                        }

                        @if (!UseCompactHover && !string.IsNullOrWhiteSpace(HoverStatusLabel))
                        {
                            <div class="media-tile-hover-status">@HoverStatusLabel</div>
                        }

                        @if (ShowHoverHeading)
                        {
                            <div class="media-tile-hover-heading">
                                <div class="media-tile-hover-title">@Item.Title</div>
                                @if (ShowHoverSubtitle)
                                {
                                    <div class="media-tile-hover-subtitle">@DisplaySubtitle</div>
                                }
                            </div>
                        }

                        @if (UseCompactHover || ShowRichHoverFacts)
                        {
                            <div class="media-tile-hover-facts">
                                @if (!string.IsNullOrWhiteSpace(RatingFact))
                                {
                                    <span class="media-tile-rating-pill">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" />
                                        <span>@RatingFactDisplay</span>
                                    </span>
                                }
                                @foreach (var fact in DisplayHoverFacts)
                                {
                                    <span class="@HoverFactClass(fact)">@fact</span>
                                }
                            </div>
                        }

                        @if (!UseCompactHover && ShowHoverDescription)
                        {
                            <p class="media-tile-hover-description">@DisplaySummary</p>
                        }

                        @if (!UseCompactHover && ShowMetaRow)
                        {
                            <div class="media-tile-hover-meta-row">
                                <div class="media-tile-hover-meta">@HoverMetaDisplay</div>
                            </div>
                        }

                        @if (!UseCompactHover && ShowHoverContextLines)
                        {
                            <div class="media-tile-hover-context-list">
                                @foreach (var line in Item.ContextLines)
                                {
                                    <div class="media-tile-hover-context">@line</div>
                                }
                            </div>
                        }

                        @if (!UseCompactHover && DisplayChips.Count > 0)
                        {
                            <div class="media-tile-hover-chips">
                                @foreach (var chip in DisplayChips)
                                {
                                    <span class="media-tile-chip">@chip</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </MediaTileOverlay>
    }

    @if (ShowCaption)
    {
        <div class="media-tile-caption">
            <div class="media-tile-title">@Item.Title</div>
            @if (!string.IsNullOrWhiteSpace(Item.Subtitle))
            {
                <div class="media-tile-subtitle">@Item.Subtitle</div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public MediaTileViewModel Item { get; set; } = default!;
    [Parameter] public EventCallback<MediaTileViewModel> OnEditClicked { get; set; }
    [Parameter] public MediaTileHoverMode? HoverMode { get; set; }
    [Parameter] public bool HideMediaKindBadge { get; set; }
    [Parameter] public bool HideSourceBadge { get; set; }

    private bool _expanded;
    private bool _hoverRegistered;
    private bool _lastExpandedState;
    private bool _dismissedFromContinue;
    private int _hoverImageIndex;
    private ElementReference _cardRef;
    private ElementReference CardElement => _cardRef;

    private MediaTileHoverMode EffectiveHoverMode => HoverMode ?? Item.HoverMode;

    private bool IsHoverEnabled => EffectiveHoverMode != MediaTileHoverMode.None;

    private bool SupportsRichGroupHover =>
        Item.IsCollection
        && Item.Presentation is MediaTilePresentation.TvSeries
            or MediaTilePresentation.MovieSeries
            or MediaTilePresentation.BookSeries
            or MediaTilePresentation.ComicSeries
            or MediaTilePresentation.AudiobookSeries
            or MediaTilePresentation.Album;

    private bool ShowExpandedHoverBody => EffectiveHoverMode == MediaTileHoverMode.Expanded && (!Item.IsCollection || SupportsRichGroupHover);

    private string HoverModeClass => EffectiveHoverMode switch
    {
        MediaTileHoverMode.None => "is-hover-none",
        MediaTileHoverMode.Preview => "is-hover-preview",
        _ => "is-hover-expanded",
    };

    private string HoverPanelClass => $"media-tile-hover-panel {ShapeClass} {PresentationClass} {HoverLayoutClass} {SurfaceClass} {HoverPlacementClass} {HoverModeClass} {(Item.IsCollection ? "is-collection-hover" : "")} {(UsesOrderedSeriesStack ? "is-ordered-series-hover" : "")}";

    private string ShapeClass => Item.Shape switch
    {
        MediaTileShape.Landscape => "is-landscape",
        MediaTileShape.Square => "is-square",
        _ => "is-portrait",
    };

    private string MediaKindClass => MediaKindLabel switch
    {
        "Book" => "is-media-book",
        "Comic" => "is-media-comic",
        "Audiobook" or "Music" => "is-media-audio",
        "Movie" => "is-media-movie",
        "TV" => "is-media-tv",
        _ => "is-media-default",
    };

    private string PresentationClass => Item.Presentation switch
    {
        MediaTilePresentation.TvSeries => "is-tv-series",
        MediaTilePresentation.MovieSeries => "is-movie-series",
        MediaTilePresentation.BookSeries => "is-book-series",
        MediaTilePresentation.ComicSeries => "is-comic-series",
        MediaTilePresentation.AudiobookSeries => "is-audiobook-series",
        MediaTilePresentation.Album => "is-album",
        MediaTilePresentation.Artist => "is-artist",
        _ => "is-default",
    };

    private string HoverLayoutClass => Item.HoverLayout == MediaTileHoverLayout.BannerPopover ? "is-banner-popover" : "is-art-popover";

    private string HoverPlacementClass => Item.PreviewPlacement == MediaTilePreviewPlacement.Bottom ? "is-placement-bottom" : "is-placement-smart";

    private string SurfaceClass => Item.SurfaceKind switch
    {
        MediaTileSurfaceKind.BannerLandscape => "is-banner-surface",
        MediaTileSurfaceKind.CoverSquare => "is-cover-square",
        MediaTileSurfaceKind.ArtistPhotoSquare => "is-artist-photo-square",
        _ => "is-cover-portrait",
    };

    private bool ShowCollectionBanner => Item.IsCollection && Item.SurfaceKind == MediaTileSurfaceKind.BannerLandscape;

    private bool UsesOrderedSeriesStack =>
        Item.ArtworkStackItems.Count > 0
        && Item.Presentation is MediaTilePresentation.BookSeries
            or MediaTilePresentation.ComicSeries
            or MediaTilePresentation.MovieSeries;

    private bool ShowCollectionArtworkStack => ShowCollectionBanner
        && Item.Presentation is not MediaTilePresentation.TvSeries
        && CollectionArtworkStackItems.Count > 0;

    private bool ShowHoverSeriesStack => UsesOrderedSeriesStack && CollectionArtworkStackItems.Count > 0;

    private string ArtworkStackClass => UsesOrderedSeriesStack
        ? "media-tile-artwork-stack media-tile-artwork-stack--collection-tile media-tile-artwork-stack--series-tile"
        : "media-tile-artwork-stack media-tile-artwork-stack--collection-tile";

    private bool ShowMediaKindBadge => !HideMediaKindBadge && !ShowCollectionBanner && !string.IsNullOrWhiteSpace(MediaKindMudIcon);

    private bool ShowQualityBadge => !ShowCollectionBanner && !string.IsNullOrWhiteSpace(Item.QualityBadge);

    private bool ShowSourceBadge => !HideSourceBadge && !ShowCollectionBanner && !string.IsNullOrWhiteSpace(Item.SourceBadgeLabel);

    private bool ShowPreviewStack => !ShowCollectionBanner && string.IsNullOrWhiteSpace(CardImageUrl) && PreviewImages.Count > 0;

    private string CardImageUrl => Item.TileImageUrl ?? string.Empty;

    private bool HasArtworkSurface => ShowCollectionBanner || !string.IsNullOrWhiteSpace(CardImageUrl) || ShowPreviewStack;

    private IReadOnlyList<string> HoverImageCandidates => new[]
        {
            Item.HoverImageUrl,
            Item.TileImageUrl,
            PreviewImages.FirstOrDefault(),
        }
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Cast<string>()
        .ToList();

    private string? ActiveHoverImageUrl => HoverImageCandidates.Skip(_hoverImageIndex).FirstOrDefault();

    private bool ShowTileLogo => Item.SurfaceKind == MediaTileSurfaceKind.BannerLandscape && !ShowPreviewStack && !string.IsNullOrWhiteSpace(Item.LogoUrl);

    private bool ShowHoverLogo => Item.HoverLayout == MediaTileHoverLayout.BannerPopover && !string.IsNullOrWhiteSpace(Item.LogoUrl);

    private bool ShowCollectionTitleOverlay => ShowCollectionBanner && !ShowTileLogo;

    private string ProgressPercentLabel => $"{Math.Clamp(Item.ProgressPct ?? 0, 0, 100):F0}%";

    private double ProgressValue => Math.Clamp(Item.ProgressPct ?? 0, 0, 100);

    private string ProgressCompleteLabel => $"{ProgressPercentLabel} complete";

    private string ProgressAccessibleLabel => Item.ProgressLabel ?? ProgressCompleteLabel;

    private string ProgressLabel => Item.ProgressLabel ?? ProgressPercentLabel;

    private IReadOnlyList<string> PreviewImages => Item.PreviewImages
        .Where(image => !string.IsNullOrWhiteSpace(image))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Take(5)
        .ToList();

    private IReadOnlyList<ArtworkStackItem> CollectionArtworkStackItems =>
        Item.ArtworkStackItems.Count > 0
            ? Item.ArtworkStackItems
            : CollectionStackPreviewImages.Select((image, index) => new ArtworkStackItem
            {
                Id = $"{Item.Id:D}:{index}",
                Title = Item.Title,
                ImageUrl = image,
                MediaType = Item.MediaKind,
                Shape = ArtworkShape.Portrait,
                Position = null,
            }).ToList();

    private IReadOnlyList<string> CollectionStackPreviewImages => PreviewImages
        .Where(IsCollectionStackImage)
        .Take(4)
        .ToList();

    private bool IsCollectionStackImage(string image)
    {
        var backdropImages = new[]
        {
            CardImageUrl,
            Item.HoverImageUrl,
            Item.BackgroundUrl,
            Item.BannerUrl,
            Item.HeroBackgroundImageUrl,
        };

        return backdropImages.All(candidate => !string.Equals(candidate, image, StringComparison.OrdinalIgnoreCase));
    }

    private string CollectionStackSeed => Item.CollectionId?.ToString("D") ?? Item.Id.ToString("D");

    private IReadOnlyList<MediaTileMediaCountViewModel> CollectionMediaCounts => Item.MediaCounts
        .Where(count => count.Count > 0)
        .Take(4)
        .ToList();

    private bool ShowCollectionMediaIcon =>
        UsesOrderedSeriesStack
        && !string.IsNullOrWhiteSpace(MediaKindMudIcon);

    private bool ShowCollectionSubtitle =>
        UsesOrderedSeriesStack
        && !string.IsNullOrWhiteSpace(Item.Subtitle);

    private string? SeriesOverflowLabel
    {
        get
        {
            if (!UsesOrderedSeriesStack || Item.PreviewTotalCount is not > 0)
            {
                return null;
            }

            var overflow = Item.PreviewTotalCount.Value - CollectionArtworkStackItems.Count;
            return overflow > 0 ? $"+{overflow} more" : null;
        }
    }

    private IReadOnlyList<string> DisplayChips => (Item.VibeTags.Count > 0 ? Item.VibeTags : Item.Genres)
        .Where(chip => !string.IsNullOrWhiteSpace(chip))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Take(3)
        .ToList();

    private string? DisplaySummary => NormalizeHoverDescription(Item.Description);

    private static string? NormalizeHoverDescription(string? description)
    {
        if (string.IsNullOrWhiteSpace(description))
        {
            return null;
        }

        var value = string.Join(' ', description.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
        const int maxLength = 220;
        const int maxWords = 42;

        var words = value.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (value.Length <= maxLength && words.Length <= maxWords)
        {
            return value;
        }

        var shortened = string.Join(' ', words.Take(maxWords));
        if (shortened.Length > maxLength)
        {
            shortened = shortened[..maxLength].TrimEnd();
        }

        return string.IsNullOrWhiteSpace(shortened) ? null : $"{shortened}...";
    }

    private string TileImageFitClass => Item.TileImageFitMode == MediaTileImageFitMode.Contain ? "is-contained" : "is-fill";

    private string HoverImageFitClass => Item.HoverImageFitMode == MediaTileImageFitMode.Contain ? "is-contained" : "is-fill";

    private bool ShowHoverContextLines => EffectiveHoverMode == MediaTileHoverMode.Expanded && Item.ContextLines.Count > 0;

    private bool ShowHoverDescription => EffectiveHoverMode == MediaTileHoverMode.Expanded && !string.IsNullOrWhiteSpace(DisplaySummary);

    private bool ShowHoverProgressRow => Item.ProgressPct is > 0;

    private bool CanRemoveFromContinue => Item.ProgressPct is > 0 && !Item.IsCollection;

    private string? HoverStatusLabel
    {
        get
        {
            if (Item.ProgressPct is > 0)
            {
                return Item.MediaKind switch
                {
                    "Book" or "Comic" => "Continue Reading",
                    "Music" or "Audiobook" => "Resume Listening",
                    "TV" => "Resume Episode",
                    "Movie" => "Resume",
                    _ => "Continue",
                };
            }

            return Item.StatusText;
        }
    }

    private bool ShowCaption => Item.TileTextMode != MediaTileTextMode.CoverOnly && !ShowTileLogo;

    private bool ShowHoverHeading => !(Item.IsCollection && ShowHoverLogo);

    private bool ShowHoverSubtitle =>
        !UseCompactHover
        && !string.IsNullOrWhiteSpace(DisplaySubtitle)
        && !CompactHoverFacts.Any(fact => string.Equals(fact, DisplaySubtitle, StringComparison.OrdinalIgnoreCase));

    private IReadOnlyList<string> RawHoverFacts => Item.HoverFacts
        .Where(fact => !string.IsNullOrWhiteSpace(fact))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IReadOnlyList<string> CompactHoverFacts => RawHoverFacts
        .Where(fact => !DuplicatesHoverSubtitle(fact))
        .Take(4)
        .ToList();

    private string? RatingFact => CompactHoverFacts.FirstOrDefault(IsRatingFact);

    private string RatingFactDisplay => FormatRatingFactForDisplay(RatingFact);

    private IReadOnlyList<string> DisplayHoverFacts => CompactHoverFacts
        .Where(fact => !IsRatingFact(fact))
        .Take(3)
        .ToList();

    private bool UseCompactHover => EffectiveHoverMode == MediaTileHoverMode.Preview && CompactHoverFacts.Count > 0 && !SupportsRichGroupHover;

    private bool ShowRichHoverFacts => EffectiveHoverMode == MediaTileHoverMode.Expanded && CompactHoverFacts.Count > 0;

    private static string HoverFactClass(string fact) =>
        IsRatingFact(fact)
            ? "media-tile-hover-fact is-rating"
            : "media-tile-hover-fact";

    private static bool IsRatingFact(string? fact)
    {
        if (string.IsNullOrWhiteSpace(fact))
        {
            return false;
        }

        return fact.Contains('\u2605')
            || fact.Contains("IMDb", StringComparison.OrdinalIgnoreCase)
            || fact.Contains("/10", StringComparison.OrdinalIgnoreCase)
            || fact.StartsWith("rating", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatRatingFactForDisplay(string? fact)
    {
        if (string.IsNullOrWhiteSpace(fact))
        {
            return string.Empty;
        }

        var value = fact.Trim();
        if (value.StartsWith('\u2605'))
        {
            value = value[1..].Trim();
        }

        if (value.StartsWith("Rating:", StringComparison.OrdinalIgnoreCase))
        {
            value = value["Rating:".Length..].Trim();
        }
        else if (value.StartsWith("Rating", StringComparison.OrdinalIgnoreCase))
        {
            value = value["Rating".Length..].Trim();
        }

        return value;
    }

    private string PrimaryMudIcon => Item.MediaKind switch
    {
        "Movie" or "TV" => Icons.Material.Filled.PlayArrow,
        "Music" or "Audiobook" => Icons.Material.Filled.PlayArrow,
        "Comic" or "Book" => Icons.Material.Filled.MenuBook,
        _ => Icons.Material.Filled.PlayArrow,
    };

    private string PrimaryActionShortLabel
    {
        get
        {
            var label = PrimaryActionDisplayLabel;
            if (label.Contains("Resume", StringComparison.OrdinalIgnoreCase))
            {
                return "Resume";
            }

            if (label.Contains("Continue", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind is "Book" or "Comic" ? "Read" : "Resume";
            }

            if (label.Contains("Reading", StringComparison.OrdinalIgnoreCase)
                || label.Contains("Read", StringComparison.OrdinalIgnoreCase))
            {
                return "Read";
            }

            if (label.Contains("Play", StringComparison.OrdinalIgnoreCase))
            {
                return "Play";
            }

            return label.Length <= 12 ? label : "Open";
        }
    }

    private string PrimaryActionDisplayLabel
    {
        get
        {
            var label = Item.PrimaryActionLabel?.Trim();
            if (string.IsNullOrWhiteSpace(label))
            {
                return Item.MediaKind switch
                {
                    "Book" or "Comic" => "Read",
                    "Movie" or "TV" or "Music" or "Audiobook" => "Play",
                    _ => "Open",
                };
            }

            if (label.Contains("Resume", StringComparison.OrdinalIgnoreCase))
            {
                return "Resume";
            }

            if (label.Contains("Continue", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind switch
                {
                    "Book" or "Comic" => "Continue Reading",
                    "Movie" or "TV" or "Music" or "Audiobook" => "Resume",
                    _ => "Continue",
                };
            }

            if (label.Equals("Open Show", StringComparison.OrdinalIgnoreCase)
                || label.Equals("Open Movie", StringComparison.OrdinalIgnoreCase)
                || label.Equals("Watch", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind is "Movie" or "TV" ? "Play" : label;
            }

            if (label.Equals("Listen", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind is "Music" or "Audiobook" ? "Play" : label;
            }

            if (label.Equals("Open Book", StringComparison.OrdinalIgnoreCase)
                || label.Equals("Open Comic", StringComparison.OrdinalIgnoreCase))
            {
                return "Read";
            }

            if (label.Equals("Open", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind switch
                {
                    "Book" or "Comic" => "Read",
                    "Movie" or "TV" or "Music" or "Audiobook" => "Play",
                    _ => label,
                };
            }

            return label;
        }
    }

