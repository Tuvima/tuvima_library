        _dismissedFromContinue = true;
    }

    private async Task OpenAddToCollectionAsync()
    {
        if (Item.WorkId is null)
        {
            return;
        }

        var parameters = new DialogParameters
        {
            { nameof(AddToCollectionDialog.WorkId), Item.WorkId.Value },
            { nameof(AddToCollectionDialog.WorkTitle), Item.Title }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = false, BackdropClick = true, CloseButton = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<AddToCollectionDialog>("Add to collection", parameters, options);
        await dialog.Result;
        _expanded = false;
    }

    private async Task OpenEditorAsync()
    {
        if (!CanEdit)
        {
            return;
        }

        _expanded = false;
        await OnEditClicked.InvokeAsync(Item);
    }

    private void HandleCardKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "ArrowDown" && IsHoverEnabled)
        {
            _expanded = true;
        }
        else if (args.Key == "Escape")
        {
            _expanded = false;
        }
    }

    private static string GetStackImageClass(int index) => $"media-tile-stack-image media-tile-stack-image-{Math.Min(index, 2)}";

    private static string? FirstNonBlank(params string?[] values) => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private void HandleHoverImageError()
    {
        if (_hoverImageIndex < HoverImageCandidates.Count - 1)
        {
            _hoverImageIndex++;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_collageRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("unregisterMediaTileCollages", CardElement);
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Could not unregister media tile collage behavior.");
            }
        }

        if (_hoverRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("unregisterMediaTileHover", CardElement);
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Could not unregister media tile hover behavior.");
            }
        }
    }
