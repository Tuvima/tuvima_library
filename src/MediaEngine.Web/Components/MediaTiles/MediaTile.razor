    private string PrimaryActionShortLabel
    {
        get
        {
            var label = PrimaryActionDisplayLabel;
            if (label.Contains("Resume", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind == "TV" && HasEpisodeActionLabel ? label : "Resume";
            }

            if (label.Contains("Continue", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind is "Book" or "Comic" ? "Read" : "Resume";
            }

            if (label.Contains("Play Again", StringComparison.OrdinalIgnoreCase))
            {
                return "Play Again";
            }

            if (label.Contains("Reading", StringComparison.OrdinalIgnoreCase)
                || label.Contains("Read", StringComparison.OrdinalIgnoreCase))
            {
                return "Read";
            }

            if (label.Contains("Play", StringComparison.OrdinalIgnoreCase))
            {
                if (Item.Presentation == MediaTilePresentation.Album)
                {
                    return "Play Album";
                }

                return Item.MediaKind is "Music" or "Audiobook" ? "Listen" : "Play";
            }

            if (Item.MediaKind == "TV"
                && label.StartsWith("Watch ", StringComparison.OrdinalIgnoreCase)
                && HasEpisodeActionLabel)
            {
                return label;
            }

            return label.Length <= 12 ? label : "Open";
        }
    }

    private string PrimaryActionDisplayLabel
    {
        get
        {
            var label = Item.PrimaryActionLabel?.Trim();
            if (string.IsNullOrWhiteSpace(label))
            {
                return Item.MediaKind switch
                {
                    "Book" or "Comic" => "Read",
                    "Movie" or "TV" => "Play",
                    "Music" or "Audiobook" => "Listen",
                    _ => "Open",
                };
            }

            if (label.Contains("Resume", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind == "TV" && HasEpisodeActionLabel ? label : "Resume";
            }

            if (label.Contains("Continue", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind switch
                {
                    "Book" or "Comic" => "Continue Reading",
                    "Movie" or "TV" or "Music" or "Audiobook" => "Resume",
                    _ => "Continue",
                };
            }

            if (label.Equals("Open Show", StringComparison.OrdinalIgnoreCase)
                || label.Equals("Open Movie", StringComparison.OrdinalIgnoreCase)
                || label.Equals("Watch", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind is "Movie" or "TV" ? "Play" : label;
            }

            if (label.Equals("Listen", StringComparison.OrdinalIgnoreCase))
            {
                return label;
            }

            if (label.Equals("Play", StringComparison.OrdinalIgnoreCase)
                && Item.MediaKind is "Music" or "Audiobook")
            {
                return "Listen";
            }

            if (label.Equals("Open Book", StringComparison.OrdinalIgnoreCase)
                || label.Equals("Open Comic", StringComparison.OrdinalIgnoreCase))
            {
                return "Read";
            }

            if (label.Equals("Open", StringComparison.OrdinalIgnoreCase))
            {
                return Item.MediaKind switch
                {
                    "Book" or "Comic" => "Read",
                    "Movie" or "TV" => "Play",
                    "Music" or "Audiobook" => "Listen",
                    _ => label,
                };
            }

            return label;
        }
    }

