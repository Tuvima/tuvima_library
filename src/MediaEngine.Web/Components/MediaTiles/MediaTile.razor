    private async Task OpenPrimary()
    {
        _expanded = false;
        if (OnPrimaryClicked.HasDelegate)
        {
            await OnPrimaryClicked.InvokeAsync(Item);
            return;
        }

        if (TryGetDirectAssetPlayerRoute(out var directPlayerRoute))
        {
            Nav.NavigateTo(directPlayerRoute);
            return;
        }

        if (Item.Presentation == MediaTilePresentation.Album)
        {
            var tracks = Item.ArtworkStackItems
                .Where(track => track.WorkId.HasValue)
                .Select(track => new ListenQueueItem
                {
                    WorkId = track.WorkId!.Value,
                    AssetId = track.AssetId,
                    CollectionId = Item.CollectionId,
                    MediaType = "Music",
                    Title = track.Title,
                    Subtitle = Item.Subtitle,
                    Album = Item.Title,
                    CoverUrl = FirstNonBlank(Item.CoverUrl, Item.TileImageUrl, track.ImageUrl),
                    Duration = PreviewDuration(track),
                    StreamUrl = track.AssetId.HasValue ? $"/media/assets/{track.AssetId.Value:D}/stream" : null,
                })
                .ToList();
            if (tracks.Count > 0)
            {
                await Playback.ReplaceQueueItemsAsync(tracks, 0, Item.Title, shuffle: false);
                return;
            }
        }

        if (IsListenMedia && !Item.IsCollection && Item.WorkId.HasValue)
        {
            await Playback.PlayQueueItemAsync(new ListenQueueItem
            {
                WorkId = Item.WorkId.Value,
                AssetId = Item.AssetId,
                CollectionId = Item.CollectionId,
                MediaType = Item.MediaKind,
                Title = Item.Title,
                Subtitle = Item.Subtitle,
                Album = Item.Presentation == MediaTilePresentation.Album ? Item.Title : null,
                CoverUrl = FirstNonBlank(Item.CoverUrl, Item.TileImageUrl),
                StreamUrl = Item.AssetId.HasValue ? $"/media/assets/{Item.AssetId.Value:D}/stream" : null,
            }, Item.Subtitle ?? Item.Title);
            return;
        }

        Nav.NavigateTo(Item.PrimaryNavigationUrl ?? Item.NavigationUrl);
    }

    private bool TryGetDirectAssetPlayerRoute(out string route)
    {
        route = string.Empty;
        if (!Item.AssetId.HasValue || Item.IsCollection)
        {
            return false;
        }

        var mediaKind = Item.MediaKind.Trim().ToLowerInvariant();
        if (mediaKind.Contains("book") || mediaKind.Contains("comic") || mediaKind.Contains("epub"))
        {
            route = $"/read/{Item.AssetId.Value:D}";
            return true;
        }

        if (mediaKind.Contains("movie") || mediaKind.Contains("video") || mediaKind == "tv")
        {
            route = $"/watch/player/{Item.AssetId.Value:D}";
            return true;
        }

        return false;
    }

    private bool IsListenMedia
    {
        get
        {
            var mediaKind = Item.MediaKind.Trim().ToLowerInvariant();
            return mediaKind.Contains("music")
                   || mediaKind.Contains("audio")
                   || mediaKind.Contains("m4a")
                   || mediaKind.Contains("m4b")
                   || mediaKind.Contains("mp3");
        }
    }

