    private string HoverMetaDisplay
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Item.MetaText))
            {
                return string.Empty;
            }

            var parts = Item.MetaText.Split('/', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList();
            if (parts.Count > 0 && string.Equals(parts[0], MediaKindLabel, StringComparison.OrdinalIgnoreCase))
            {
                parts.RemoveAt(0);
            }

            parts = parts
                .Where(part => !string.Equals(part, DisplaySubtitle, StringComparison.OrdinalIgnoreCase))
                .Where(part => !DuplicatesHoverSubtitle(part))
                .Where(part => !RawHoverFacts.Any(fact => string.Equals(fact, part, StringComparison.OrdinalIgnoreCase)))
                .Where(part => !CompactHoverFacts.Any(fact => string.Equals(fact, part, StringComparison.OrdinalIgnoreCase)))
                .ToList();

            return string.Join(" / ", parts);
        }
    }

    private bool ShowMetaRow => !string.IsNullOrWhiteSpace(HoverMetaDisplay);

    private bool DuplicatesHoverSubtitle(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || string.IsNullOrWhiteSpace(DisplaySubtitle))
        {
            return false;
        }

        var normalizedValue = NormalizeComparableText(value);
        var normalizedSubtitle = NormalizeComparableText(DisplaySubtitle);
        if (normalizedValue.Length == 0 || normalizedSubtitle.Length == 0)
        {
            return false;
        }

        if (string.Equals(normalizedValue, normalizedSubtitle, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return normalizedValue.Length >= 4
            && normalizedSubtitle.Contains(normalizedValue, StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeComparableText(string value)
    {
        var chars = value.Trim().ToLowerInvariant()
            .Select(character => char.IsLetterOrDigit(character) ? character : ' ')
            .ToArray();

        return string.Join(' ', new string(chars).Split(' ', StringSplitOptions.RemoveEmptyEntries));
    }

    protected override void OnParametersSet() => _hoverImageIndex = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!UsesCinematicHover)
        {
            return;
        }

        if (!_hoverRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("registerMediaTileHover", CardElement);
                _hoverRegistered = true;
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Could not register media tile hover behavior.");
            }
        }
    }

    private string DetailsNavigationUrl => Item.DetailsNavigationUrl ?? Item.NavigationUrl;

    private string DetailsActionAriaLabel => $"View details for {Item.Title}";

    private void OpenDetails()
    {
        Nav.NavigateTo(Item.DetailsNavigationUrl ?? Item.NavigationUrl);
    }

    private static string GetStackImageClass(int index) => $"media-tile-stack-image media-tile-stack-image-{Math.Min(index, 2)}";

    private static string? FirstNonBlank(params string?[] values) => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private void HandleHoverImageError()
    {
        if (_hoverImageIndex < HoverImageCandidates.Count - 1)
        {
            _hoverImageIndex++;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hoverRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("unregisterMediaTileHover", CardElement);
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Could not unregister media tile hover behavior.");
            }
        }
    }
