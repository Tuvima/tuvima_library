@namespace MediaEngine.Web.Components.MediaTiles
@using MediaEngine.Web.Components.Shared
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@using MediaEngine.Web.Services.Playback
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject ILogger<MediaTile> Logger
@inject ActiveProfileSessionService ActiveProfileSession
@inject MediaReactionService Reactions
@inject FavoriteService Favorites
@inject PlaybackSessionController Playback
@implements IAsyncDisposable

<AppCssElement Tag="div"
               Css="@PaletteScopeStyle">
<article class='@($"media-tile tl-card-hover--media {ShapeClass} {MediaKindClass} {PresentationClass} {HoverLayoutClass} {SurfaceClass} {HoverPlacementClass} {HoverModeClass} {(UsesCollectionVisualTreatment ? "is-collection-card" : "")} {(UsesOrderedSeriesStack ? "is-ordered-series-card" : "")} {(_expanded ? "is-expanded" : "")} {(_dismissedFromContinue ? "is-dismissed" : "")}")'
         @ref="_cardRef"
         aria-label="@Item.Title"
         @onkeydown="HandleCardKeyDown">
    <div class="media-tile-frame">
        <a class="media-tile-media @(HasArtworkSurface ? "has-artwork-surface" : null)"
           href="@DetailsNavigationUrl"
           aria-label="@DetailsActionAriaLabel"
           @onclick="OpenDetails"
           @onclick:preventDefault="true">
            @if (ShowGroupCollage)
            {
                <div class="media-tile-static-group-preview" aria-hidden="true">
                    <MediaArtworkGroupPreview Items="@GroupCollageItems"
                                              TotalCount="@Item.PreviewTotalCount"
                                              AriaLabel="@($"Artwork from {Item.Title}")" />
                </div>
            }
            else if (ShowCollectionBanner)
            {
                @if (!string.IsNullOrWhiteSpace(CardImageUrl))
                {
                    <img src="@CardImageUrl"
                         srcset="@Item.TileImageSrcSet"
                         sizes="@Item.TileImageSizes"
                         alt=""
                         class="media-tile-collection-backdrop @TileImageFitClass"
                         loading="lazy"
                         decoding="async" />
                }
                <div class="media-tile-collection-wash"></div>
                @if (ShowCollectionArtworkStack)
                {
                    <TuvimaArtworkStack Items="@CollectionArtworkStackItems"
                                        Seed="@CollectionStackSeed"
                                        Variant="@(UsesOrderedSeriesStack ? ArtworkStackVariant.SeriesStrip : ArtworkStackVariant.Card)"
                                        MaxVisible="4"
                                        IsDecorative="true"
                                        PreserveOrder="@UsesOrderedSeriesStack"
                                        Palette="@Item.ArtworkPalette"
                                        Class="@ArtworkStackClass" />
                }
            }
            else if (ShowPreviewStack)
            {
                <div class="media-tile-stack" aria-hidden="true">
                    @for (var index = 0; index < PreviewImages.Count; index++)
                    {
                        <img src="@PreviewImages[index]"
                             alt=""
                             class="@GetStackImageClass(index)"
                             loading="lazy"
                             decoding="async" />
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(CardImageUrl))
            {
                <img src="@CardImageUrl"
                     srcset="@Item.TileImageSrcSet"
                     sizes="@Item.TileImageSizes"
                     alt="@Item.Title"
                     class="media-tile-image @TileImageFitClass"
                     loading="lazy"
                     decoding="async" />
            }
            else
            {
                <div class="media-tile-fallback">
                    <MudIcon Icon="@FallbackIcon" Class="tl-u-font-size-44px tl-u-color-rgba-255-255-255--18" />
                    <span>@Item.Title</span>
                </div>
            }

            @if (Item.IsCollection)
            {
                <div class="media-tile-group-indicators">
                    <span class="media-tile-group-kind">
                        <MudIcon Icon="@GroupKindIcon" />
                        <span>@GroupKindLabel</span>
                    </span>
                    @if (Item.PreviewTotalCount is > 0)
                    {
                        <span class="media-tile-group-count" aria-label="@GroupCountAriaLabel" title="@GroupCountAriaLabel">
                            <MudIcon Icon="@GroupCountIcon" />
                            <span>@Item.PreviewTotalCount</span>
                        </span>
                    }
                </div>
            }
        </a>
    </div>

    @if (IsHoverEnabled)
    {
        <div class="@HoverPanelClass"
                 @onclick="OpenDetails"
                 @onclick:stopPropagation="true">
                <div class="media-tile-hover-art @(!ShowGroupCollage && string.IsNullOrWhiteSpace(ActiveHoverImageUrl) ? "is-empty" : null)"
                     @onclick="OpenDetails"
                     @onclick:stopPropagation="true">
                    @if (ShowGroupCollage)
                    {
                        <div class="media-tile-static-group-preview">
                            <MediaArtworkGroupPreview Items="@GroupCollageItems"
                                                      TotalCount="@Item.PreviewTotalCount"
                                                      AriaLabel="@($"Representative artwork from {Item.Title}")" />
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(ActiveHoverImageUrl))
                    {
                        <div class="@HoverCoverStageClass">
                            @if (UseBookPageTreatment)
                            {
                                <span class="media-tile-book-pages" aria-hidden="true"></span>
                                <span class="media-tile-book-spine" aria-hidden="true"></span>
                            }
                            <img src="@ActiveHoverImageUrl"
                                 srcset="@Item.HoverImageSrcSet"
                                 sizes="@Item.HoverImageSizes"
                                 alt="@Item.Title"
                                 class="media-tile-hover-image @HoverImageFitClass"
                                 loading="lazy"
                                 decoding="async"
                                 @onerror="HandleHoverImageError" />
                        </div>
                    }
                    else
                    {
                        <div class="media-tile-hover-fallback">
                            <MudIcon Icon="@FallbackIcon" />
                        </div>
                    }

                    @if (ShowHoverLogo)
                    {
                        <img src="@Item.LogoUrl" alt="@Item.Title" class="media-tile-hover-logo" />
                    }

                    @if (ShowHoverSeriesStack)
                    {
                        <TuvimaArtworkStack Items="@CollectionArtworkStackItems"
                                            Seed="@CollectionStackSeed"
                                            Variant="ArtworkStackVariant.SeriesStrip"
                                            MaxVisible="4"
                                            IsDecorative="false"
                                            AriaLabel="@($"{Item.Title} series preview")"
                                            PreserveOrder="true"
                                            Palette="@Item.ArtworkPalette"
                                            Class="media-tile-hover-series-stack" />
                    }

                    @if (CanRemoveFromContinue)
                    {
                        <AppNativeButton Type="button"
                                         Class="media-tile-hover-remove-corner media-tile-hover-control"
                                         AriaLabel="Remove from continue row"
                                         Title="Remove from continue row"
                                         OnClick="DismissFromContinue"
                                         StopPropagation="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Close" />
                            <span class="media-tile-visually-hidden">Remove from continue row</span>
                        </AppNativeButton>
                    }
                </div>

                @if (ShowExpandedHoverBody)
                {
                    <div class="media-tile-hover-body">
                        <div class="media-tile-hover-actions">
                            <div class="media-tile-hover-actions-left">
                                <div class="media-tile-hover-action-unit media-tile-hover-action-unit-primary">
                                    <AppNativeButton Type="button" Class="tl-media-action tl-media-action--primary tl-media-action--compact media-tile-hover-control media-tile-hover-control-primary" AriaLabel="@PrimaryActionDisplayLabel" Title="@PrimaryActionDisplayLabel" OnClick="OpenPrimary" StopPropagation="true">
                                        <MudIcon Icon="@PrimaryMudIcon" />
                                        <span>@PrimaryActionShortLabel</span>
                                    </AppNativeButton>
                                </div>

                                <div class="media-tile-hover-action-unit">
                                    <AppNativeButton Type="button" Class="@MyListButtonClass" AriaLabel="@MyListActionLabel" Title="@MyListActionLabel" Disabled="@(!Item.WorkId.HasValue)" OnClick="ToggleMyListAsync" StopPropagation="true">
                                        <MudIcon Icon="@(_isInMyList ? Icons.Material.Outlined.Check : Icons.Material.Outlined.Add)" />
                                        <span class="media-tile-visually-hidden">@MyListActionLabel</span>
                                    </AppNativeButton>
                                </div>

                                <div class="media-tile-hover-action-unit media-tile-reaction-swap"
                                     @onmouseenter="BeginDislikeIntent"
                                     @onmouseleave="EndDislikeIntent"
                                     @onfocusin="BeginDislikeIntent"
                                     @onfocusout="EndDislikeIntent">
                                    <AppNativeButton Type="button"
                                                     Class="@ReactionTriggerButtonClass"
                                                     AriaLabel="@DisplayedReactionLabel"
                                                     Title="@DisplayedReactionLabel"
                                                     StopPropagation="true"
                                                     OnClick="ToggleDisplayedReactionAsync">
                                        <MudIcon Icon="@DisplayedReactionIcon" />
                                        <span class="media-tile-visually-hidden">@DisplayedReactionLabel</span>
                                    </AppNativeButton>
                                </div>
                            </div>

                            <div class="media-tile-hover-action-unit media-tile-hover-action-unit-details">
                                <AppNativeButton Type="button" Class="tl-media-action tl-media-action--flat tl-media-action--compact media-tile-hover-control media-tile-hover-control-secondary media-tile-details-action" AriaLabel="Details" Title="Details" OnClick="OpenDetails" StopPropagation="true">
                                    <MudIcon Icon="@Icons.Material.Outlined.ArrowForward" />
                                    <span class="media-tile-visually-hidden">Details</span>
                                </AppNativeButton>
                            </div>
                        </div>

                        @if (ShowHoverProgressRow)
                        {
                            <div class="media-tile-hover-progress" aria-label="@ProgressCompleteLabel">
                                @if (IsCoverLedHover)
                                {
                                    <div class="media-tile-hover-section-label">
                                        <MudIcon Icon="@ProgressSectionIcon" />
                                        <span>@ProgressSectionLabel</span>
                                    </div>
                                }
                                <progress class="media-tile-hover-progress-track"
                                          value="@ProgressValue"
                                          max="100"></progress>
                                <span>@ProgressCompleteLabel</span>
                            </div>
                        }

                        @if (ShowHoverHeading)
                        {
                            <div class="media-tile-hover-heading">
                                <div class="media-tile-hover-title">@Item.Title</div>
                                @if (ShowHoverSubtitle)
                                {
                                    <div class="media-tile-hover-subtitle">@DisplaySubtitle</div>
                                }
                            </div>
                        }

                        @if (UseCompactHover || ShowRichHoverFacts)
                        {
                            <div class="media-tile-hover-facts">
                                @if (!string.IsNullOrWhiteSpace(RatingFact))
                                {
                                    <span class="media-tile-rating-pill">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" />
                                        <span>@RatingFactDisplay</span>
                                    </span>
                                }
                                @if (!string.IsNullOrWhiteSpace(HoverKindFact))
                                {
                                    <span class="media-tile-hover-fact media-tile-hover-kind">@HoverKindFact</span>
                                }
                                @foreach (var fact in DisplayHoverFacts)
                                {
                                    <span class="@HoverFactClass(fact)">@fact</span>
                                }
                            </div>
                        }

                        @if (IsCoverLedHover && HoverPreviewItems.Count > 0)
                        {
                            <section class="media-tile-hover-context" aria-label="@HoverPreviewLabel">
                                <div class="media-tile-hover-section-label">
                                    <MudIcon Icon="@HoverPreviewIcon" />
                                    <span>@HoverPreviewLabel</span>
                                </div>
                                <ol>
                                    @foreach (var preview in HoverPreviewItems)
                                    {
                                        <li @key="preview.Id">
                                            @if (!string.IsNullOrWhiteSpace(preview.Position))
                                            {
                                                <span class="media-tile-hover-context-position">@preview.Position</span>
                                            }
                                            <strong>@preview.Title</strong>
                                            @if (!string.IsNullOrWhiteSpace(PreviewDuration(preview)))
                                            {
                                                <span class="media-tile-hover-context-duration">@PreviewDuration(preview)</span>
                                            }
                                        </li>
                                    }
                                </ol>
                            </section>
                        }

                        @if (IsCoverLedHover && ShowHoverDescription)
                        {
                            <section class="media-tile-hover-description-block">
                                <div class="media-tile-hover-section-label">
                                    <MudIcon Icon="@DescriptionIcon" />
                                    <span>@DescriptionLabel</span>
                                </div>
                                <p class="media-tile-hover-description">@DisplaySummary</p>
                            </section>
                        }

                    </div>
                }
        </div>
    }
</article>
</AppCssElement>

@code {
    [Parameter, EditorRequired] public MediaTileViewModel Item { get; set; } = default!;
    [Parameter] public EventCallback<MediaTileViewModel> OnEditClicked { get; set; }
    [Parameter] public EventCallback<MediaTileViewModel> OnPrimaryClicked { get; set; }
    [Parameter] public MediaTileHoverMode? HoverMode { get; set; }
    [Parameter] public bool HideMediaKindBadge { get; set; }
    [Parameter] public bool HideSourceBadge { get; set; }

    private bool _expanded;
    private bool _hoverRegistered;
    private bool _lastExpandedState;
    private bool _dismissedFromContinue;
    private int _hoverImageIndex;
    private bool _reactionLoaded;
    private MediaReaction _reaction;
    private bool _showDislikeIntent;
    private bool _myListLoaded;
    private bool _isInMyList;
    private ElementReference _cardRef;
    private ElementReference CardElement => _cardRef;

    private MediaTileHoverMode EffectiveHoverMode => HoverMode ?? Item.HoverMode;

    private bool IsHoverEnabled => EffectiveHoverMode != MediaTileHoverMode.None;

    private bool SupportsRichGroupHover =>
        Item.IsCollection
        && Item.Presentation is MediaTilePresentation.TvSeries
            or MediaTilePresentation.MovieSeries
            or MediaTilePresentation.BookSeries
            or MediaTilePresentation.ComicSeries
            or MediaTilePresentation.AudiobookSeries
            or MediaTilePresentation.Album;

    private bool ShowExpandedHoverBody => EffectiveHoverMode == MediaTileHoverMode.Expanded && (!Item.IsCollection || SupportsRichGroupHover);

    private string HoverModeClass => EffectiveHoverMode switch
    {
        MediaTileHoverMode.None => "is-hover-none",
        MediaTileHoverMode.Preview => "is-hover-preview",
        _ => "is-hover-expanded",
    };

    private string HoverPanelClass => $"media-tile-hover-panel {ShapeClass} {HoverArtworkShapeClass} {MediaKindClass} {PresentationClass} {HoverLayoutClass} {HoverPresentationClass} {SurfaceClass} {HoverPlacementClass} {HoverModeClass} {(UsesCollectionVisualTreatment ? "is-collection-hover" : "")} {(UsesOrderedSeriesStack ? "is-ordered-series-hover" : "")}";

    private bool IsCoverLedHover => Item.HoverLayout == MediaTileHoverLayout.ArtOnlyPopover && !UsesCollectionVisualTreatment;

    private string HoverPresentationClass => IsCoverLedHover ? "is-cover-led" : "is-cinematic";

    private string HoverArtworkShapeClass => (Item.HoverArtworkShape ?? Item.Shape) switch
    {
        MediaTileShape.Landscape => "has-hover-landscape-art",
        MediaTileShape.Square => "has-hover-square-art",
        _ => "has-hover-portrait-art",
    };

    private bool UsesCollectionVisualTreatment =>
        Item.IsCollection && Item.Presentation is not (MediaTilePresentation.TvSeries or MediaTilePresentation.Album);

    private string TileStyle => $"{Item.ArtworkPalette?.CssVariableStyle} --media-tile-accent: {Item.AccentColor}; --media-tile-secondary-accent: {Item.SecondaryAccentColor}; {HoverAtmosphereStyle}";

    private string HoverAtmosphereStyle => string.IsNullOrWhiteSpace(HoverAtmosphereImageUrl)
        ? string.Empty
        : $"--media-tile-hover-image: url(\"{EscapeCssString(HoverAtmosphereImageUrl)}\");";

    private string? HoverAtmosphereImageUrl => FirstNonBlank(
        Item.HeroBackgroundImageUrl,
        Item.HoverImageUrl,
        Item.TileImageUrl,
        Item.CoverUrl);

    private string PaletteScopeStyle => $"display: contents; {TileStyle}";

    private static string EscapeCssString(string value) =>
        value.Replace("\\", "\\\\", StringComparison.Ordinal).Replace("\"", "\\\"", StringComparison.Ordinal);

    private bool UseBookPageTreatment =>
        Item.MediaKind == "Book"
        && Item.HoverLayout == MediaTileHoverLayout.ArtOnlyPopover
        && !Item.IsCollection;

    private string HoverCoverStageClass =>
        $"media-tile-hover-cover-stage {(UseBookPageTreatment ? "is-book-stage" : string.Empty)}";

    private string? HoverKindFact => Item.MediaKind switch
    {
        "Book" => "Book",
        "Comic" => "Comic",
        "Audiobook" => "Audiobook",
        "Music" => "Music",
        _ => null,
    };

    private string ShapeClass => Item.Shape switch
    {
        MediaTileShape.Landscape => "is-landscape",
        MediaTileShape.Square => "is-square",
        _ => "is-portrait",
    };

    private string MediaKindClass => MediaKindLabel switch
    {
        "Book" => "is-media-book",
        "Comic" => "is-media-comic",
        "Audiobook" or "Music" => "is-media-audio",
        "Movie" => "is-media-movie",
        "TV" => "is-media-tv",
        _ => "is-media-default",
    };

    private string PresentationClass => Item.Presentation switch
    {
        MediaTilePresentation.TvSeries => "is-tv-series",
        MediaTilePresentation.MovieSeries => "is-movie-series",
        MediaTilePresentation.BookSeries => "is-book-series",
        MediaTilePresentation.ComicSeries => "is-comic-series",
        MediaTilePresentation.AudiobookSeries => "is-audiobook-series",
        MediaTilePresentation.Album => "is-album",
        MediaTilePresentation.Artist => "is-artist",
        _ => "is-default",
    };

    private string HoverLayoutClass => Item.HoverLayout == MediaTileHoverLayout.BannerPopover ? "is-banner-popover" : "is-art-popover";

    private string HoverPlacementClass => Item.PreviewPlacement == MediaTilePreviewPlacement.Bottom ? "is-placement-bottom" : "is-placement-smart";

    private string SurfaceClass => Item.SurfaceKind switch
    {
        MediaTileSurfaceKind.BannerLandscape => "is-banner-surface",
        MediaTileSurfaceKind.CoverSquare => "is-cover-square",
        MediaTileSurfaceKind.ArtistPhotoSquare => "is-artist-photo-square",
        _ => "is-cover-portrait",
    };

    private bool ShowCollectionBanner => Item.IsCollection && Item.SurfaceKind == MediaTileSurfaceKind.BannerLandscape;

    private bool UsesOrderedSeriesStack =>
        Item.ArtworkStackItems.Count > 0
        && Item.Presentation is MediaTilePresentation.BookSeries
            or MediaTilePresentation.ComicSeries
            or MediaTilePresentation.MovieSeries
            or MediaTilePresentation.AudiobookSeries;

    private bool ShowCollectionArtworkStack => ShowCollectionBanner
        && Item.Presentation is not MediaTilePresentation.TvSeries
        && CollectionArtworkStackItems.Count > 0;

    private bool ShowHoverSeriesStack => !ShowGroupCollage && UsesOrderedSeriesStack && CollectionArtworkStackItems.Count > 0;

    private IReadOnlyList<ArtworkStackItem> GroupCollageItems => CollectionArtworkStackItems
        .Where(item => !string.IsNullOrWhiteSpace(item.ImageUrl))
        .DistinctBy(item => item.Id)
        .DistinctBy(item => item.ImageUrl, StringComparer.OrdinalIgnoreCase)
        .Take(4)
        .ToList();

    private bool ShowGroupCollage =>
        Item.IsCollection
        && Item.Presentation is not (MediaTilePresentation.TvSeries or MediaTilePresentation.Album)
        && GroupCollageItems.Count >= 2;

    private string GroupKindLabel => Item.Presentation switch
    {
        MediaTilePresentation.TvSeries => "TV Show",
        MediaTilePresentation.MovieSeries => "Movie Series",
        MediaTilePresentation.BookSeries => "Book Series",
        MediaTilePresentation.ComicSeries => "Comic Series",
        MediaTilePresentation.AudiobookSeries => "Audiobook Series",
        MediaTilePresentation.Album => "Album",
        _ => "Collection",
    };

    private string GroupKindIcon => Item.Presentation switch
    {
        MediaTilePresentation.TvSeries => Icons.Material.Outlined.LiveTv,
        MediaTilePresentation.Album => Icons.Material.Outlined.Album,
        MediaTilePresentation.BookSeries or MediaTilePresentation.ComicSeries => Icons.Material.Outlined.AutoStories,
        MediaTilePresentation.MovieSeries => Icons.Material.Outlined.VideoLibrary,
        MediaTilePresentation.AudiobookSeries => Icons.Material.Outlined.Headphones,
        _ => Icons.Material.Outlined.CollectionsBookmark,
    };

    private string GroupCountIcon => Item.Presentation switch
    {
        MediaTilePresentation.TvSeries => Icons.Material.Outlined.VideoLibrary,
        MediaTilePresentation.Album => Icons.Material.Outlined.MusicNote,
        MediaTilePresentation.ComicSeries => Icons.Material.Outlined.AutoStories,
        MediaTilePresentation.AudiobookSeries => Icons.Material.Outlined.Headphones,
        _ => Icons.Material.Outlined.Inventory2,
    };

    private string GroupCountAriaLabel
    {
        get
        {
            var count = Item.PreviewTotalCount ?? 0;
            var noun = Item.Presentation switch
            {
                MediaTilePresentation.TvSeries => count == 1 ? "episode" : "episodes",
                MediaTilePresentation.ComicSeries => count == 1 ? "issue" : "issues",
                MediaTilePresentation.Album => count == 1 ? "track" : "tracks",
                _ => count == 1 ? "item" : "items",
            };

            return $"{count} {noun} owned";
        }
    }

    private string ArtworkStackClass => UsesOrderedSeriesStack
        ? "media-tile-artwork-stack media-tile-artwork-stack--collection-tile media-tile-artwork-stack--series-tile"
        : "media-tile-artwork-stack media-tile-artwork-stack--collection-tile";

    private bool ShowSourceBadge => !HideSourceBadge && !ShowCollectionBanner && !string.IsNullOrWhiteSpace(Item.SourceBadgeLabel);

    private bool ShowPreviewStack => !ShowCollectionBanner && string.IsNullOrWhiteSpace(CardImageUrl) && PreviewImages.Count > 0;

    private string CardImageUrl => Item.TileImageUrl ?? string.Empty;

    private bool HasArtworkSurface => ShowCollectionBanner || !string.IsNullOrWhiteSpace(CardImageUrl) || ShowPreviewStack;

    private IReadOnlyList<string> HoverImageCandidates => new[]
        {
            Item.HoverImageUrl,
            Item.TileImageUrl,
            PreviewImages.FirstOrDefault(),
        }
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Cast<string>()
        .ToList();

    private string? ActiveHoverImageUrl => HoverImageCandidates.Skip(_hoverImageIndex).FirstOrDefault();

    private bool ShowTileLogo => Item.SurfaceKind == MediaTileSurfaceKind.BannerLandscape && !ShowPreviewStack && !string.IsNullOrWhiteSpace(Item.LogoUrl);

    private bool ShowHoverLogo => Item.HoverLayout == MediaTileHoverLayout.BannerPopover && !string.IsNullOrWhiteSpace(Item.LogoUrl);

    private bool ShowCollectionTitleOverlay => ShowCollectionBanner && !ShowTileLogo;

    private string ProgressPercentLabel => $"{Math.Clamp(Item.ProgressPct ?? 0, 0, 100):F0}%";

    private double ProgressValue => Math.Clamp(Item.ProgressPct ?? 0, 0, 100);

    private string ProgressCompleteLabel => $"{ProgressPercentLabel} complete";

    private string ProgressAccessibleLabel => Item.ProgressLabel ?? ProgressCompleteLabel;

    private string ProgressLabel => Item.ProgressLabel ?? ProgressPercentLabel;

    private IReadOnlyList<string> PreviewImages => Item.PreviewImages
        .Where(image => !string.IsNullOrWhiteSpace(image))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Take(5)
        .ToList();

    private IReadOnlyList<ArtworkStackItem> CollectionArtworkStackItems =>
        Item.ArtworkStackItems.Count > 0
            ? Item.ArtworkStackItems
            : CollectionStackPreviewImages.Select((image, index) => new ArtworkStackItem
            {
                Id = $"{Item.Id:D}:{index}",
                Title = Item.Title,
                ImageUrl = image,
                MediaType = Item.MediaKind,
                Shape = ArtworkShape.Portrait,
                Position = null,
            }).ToList();

    private IReadOnlyList<string> CollectionStackPreviewImages => PreviewImages
        .Where(IsCollectionStackImage)
        .Take(4)
        .ToList();

    private bool IsCollectionStackImage(string image)
    {
        var backdropImages = new[]
        {
            CardImageUrl,
            Item.HoverImageUrl,
            Item.BackgroundUrl,
            Item.BannerUrl,
            Item.HeroBackgroundImageUrl,
        };

        return backdropImages.All(candidate => !string.Equals(candidate, image, StringComparison.OrdinalIgnoreCase));
    }

    private string CollectionStackSeed => Item.CollectionId?.ToString("D") ?? Item.Id.ToString("D");

    private IReadOnlyList<MediaTileMediaCountViewModel> CollectionMediaCounts => Item.MediaCounts
        .Where(count => count.Count > 0)
        .Take(4)
        .ToList();

    private bool ShowCollectionMediaIcon =>
        UsesOrderedSeriesStack
        && !string.IsNullOrWhiteSpace(MediaKindMudIcon);

    private bool ShowCollectionSubtitle =>
        UsesOrderedSeriesStack
        && !string.IsNullOrWhiteSpace(Item.Subtitle);

    private string? SeriesOverflowLabel
    {
        get
        {
            if (!UsesOrderedSeriesStack || Item.PreviewTotalCount is not > 0)
            {
                return null;
            }

            var overflow = Item.PreviewTotalCount.Value - CollectionArtworkStackItems.Count;
            return overflow > 0 ? $"+{overflow} more" : null;
        }
    }

    private IReadOnlyList<string> DisplayChips => (Item.VibeTags.Count > 0 ? Item.VibeTags : Item.Genres)
        .Where(chip => !string.IsNullOrWhiteSpace(chip))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Take(3)
        .ToList();

    private string? DisplaySummary => NormalizeHoverDescription(Item.Description);

    private static string? NormalizeHoverDescription(string? description)
    {
        if (string.IsNullOrWhiteSpace(description))
        {
            return null;
        }

        var value = string.Join(' ', description.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
        const int maxLength = 220;
        const int maxWords = 42;

        var words = value.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (value.Length <= maxLength && words.Length <= maxWords)
        {
            return value;
        }

        var shortened = string.Join(' ', words.Take(maxWords));
        if (shortened.Length > maxLength)
        {
            shortened = shortened[..maxLength].TrimEnd();
        }

        return string.IsNullOrWhiteSpace(shortened) ? null : $"{shortened}...";
    }

