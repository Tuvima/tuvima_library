    {
        MediaReaction.Dislike => Icons.Material.Outlined.ThumbDownOffAlt,
        MediaReaction.Love => Icons.Material.Filled.Favorite,
        _ => Icons.Material.Outlined.ThumbUpOffAlt
    };

    private string MyListButtonClass =>
        $"tl-media-action tl-media-action--flat tl-media-action--compact media-tile-hover-control media-tile-hover-control-secondary media-tile-my-list-action {(_isInMyList ? "is-selected" : string.Empty)}";

    private string MyListActionLabel => _isInMyList ? "Remove from My List" : "Add to My List";

    private string DetailsNavigationUrl => Item.DetailsNavigationUrl ?? Item.NavigationUrl;

    private string DetailsActionAriaLabel => $"View details for {Item.Title}";

    private async Task LoadMyListAsync()
    {
        if (!Item.WorkId.HasValue)
        {
            return;
        }

        try
        {
            var profile = await ActiveProfileSession.GetActiveProfileAsync();
            var membership = await Favorites.GetMembershipAsync(Item.WorkId.Value, profile?.Id);
            _isInMyList = membership?.IsFavorite == true;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not load My List state for {WorkId}.", Item.WorkId);
        }
    }

    private async Task ToggleMyListAsync()
    {
        if (!Item.WorkId.HasValue)
        {
            return;
        }

        try
        {
            var profile = await ActiveProfileSession.GetActiveProfileAsync();
            var membership = await Favorites.ToggleAsync(Item.WorkId.Value, profile?.Id);
            _isInMyList = membership?.IsFavorite == true;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not update My List for {WorkId}.", Item.WorkId);
        }
    }

    private async Task OpenPrimary()
    {
        _expanded = false;
        if (OnPrimaryClicked.HasDelegate)
        {
            await OnPrimaryClicked.InvokeAsync(Item);
            return;
        }

        Nav.NavigateTo(Item.PrimaryNavigationUrl ?? Item.NavigationUrl);
    }

