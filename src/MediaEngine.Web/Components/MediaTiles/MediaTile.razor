    private string? DisplaySummary => NormalizeHoverDescription(Item.Description);

    private static string? NormalizeHoverDescription(string? description)
    {
        if (string.IsNullOrWhiteSpace(description))
        {
            return null;
        }

        var value = string.Join(' ', description.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
        const int maxLength = 220;
        const int maxWords = 42;

        var words = value.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (value.Length <= maxLength && words.Length <= maxWords)
        {
            return value;
        }

        var shortened = string.Join(' ', words.Take(maxWords));
        if (shortened.Length > maxLength)
        {
            shortened = shortened[..maxLength].TrimEnd();
        }

        return string.IsNullOrWhiteSpace(shortened) ? null : $"{shortened}...";
    }

