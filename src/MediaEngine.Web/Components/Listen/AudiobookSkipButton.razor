@namespace MediaEngine.Web.Components.Listen

<span class="@RootClass">
    <AppNativeButton Type="button"
                     Class="@ButtonClass"
                     OnClick="@HandleClickAsync"
                     AriaLabel="@AriaLabel"
                     data-listen-seek-delta="@SeekDelta">
        <svg class="@RingClass" viewBox="0 0 64 64" focusable="false" aria-hidden="true">
            <path class="audiobook-skip-button__arc" d="M24.4 12.2A22 22 0 1 1 13.2 31.4" />
            <path class="audiobook-skip-button__arrow" d="M24.2 5.8l1.8 10.4-10.3-1.9" />
        </svg>
        <span class="audiobook-skip-button__number" aria-hidden="true">@Seconds</span>
    </AppNativeButton>
</span>

@code {
    [Parameter] public int Seconds { get; set; }
    [Parameter] public bool IsForward { get; set; }
    [Parameter] public string Variant { get; set; } = "bar";
    [Parameter] public EventCallback OnClick { get; set; }

    private int SeekDelta => IsForward ? Seconds : -Seconds;
    private string Direction => IsForward ? "forward" : "back";
    private string AriaLabel => IsForward ? $"Forward {Seconds} seconds" : $"Back {Seconds} seconds";
    private string NormalizedVariant => Variant switch
    {
        "panel" => "panel",
        "popup" => "popup",
        _ => "bar",
    };

    private string RootClass => NormalizedVariant switch
    {
        "panel" => $"listen-now-panel__skip audiobook-skip-control audiobook-skip-control--panel audiobook-skip-control--{Direction} {(IsForward ? "listen-now-panel__skip--forward" : "listen-now-panel__skip--back")}",
        "popup" => $"listen-popup__skip audiobook-skip-control audiobook-skip-control--popup audiobook-skip-control--{Direction} {(IsForward ? "listen-popup__skip--forward" : "listen-popup__skip--back")}",
        _ => $"listen-player__skip audiobook-skip-control audiobook-skip-control--bar audiobook-skip-control--{Direction} {(IsForward ? "listen-player__skip--forward" : "listen-player__skip--back")}",
    };

    private string ButtonClass => $"audiobook-skip-button audiobook-skip-button--{Direction}";
    private string RingClass => $"audiobook-skip-button__ring audiobook-skip-button__ring--{Direction}";
    private Task HandleClickAsync(MouseEventArgs _) => OnClick.InvokeAsync();
}
