@namespace MediaEngine.Web.Components.Listen
@using System.Globalization
@using MediaEngine.Contracts.Playback
@using MediaEngine.Web.Services.Playback
@inject ListenAudioDragService AudioDrag
@inject ListenPlaybackService Playback
@implements IDisposable

<aside class="@PanelClass" aria-label="Now playing" @ondragover:preventDefault="true" @ondrop="QueueDraggedItemsAsync">
    <div class="listen-now-panel__header">
        <span>Now Playing</span>
        <MudIcon Icon="@Icons.Material.Outlined.ExpandLess" Class="tl-u-font-size-18px" />
    </div>

    @if (Playback.HasQueue && Playback.CurrentItem is not null)
    {
        var current = Playback.CurrentItem;
        <div class="listen-now-panel__body">
            <div class="listen-now-panel__cover">
                @if (!string.IsNullOrWhiteSpace(current.CoverUrl))
                {
                    <img src="@current.CoverUrl" alt="@current.Title" />
                }
                else
                {
                    <MudIcon Icon="@FallbackIconFor(current)" Class="tl-u-font-size-64px" />
                }
            </div>

            <div class="listen-now-panel__meta">
                <h2>@current.Title</h2>
                <p>@PlayerSubtitle(current)</p>
                @if (!Playback.IsAudiobookMode
                    && !string.IsNullOrWhiteSpace(current.Album)
                    && !string.Equals(current.Album, current.Title, StringComparison.OrdinalIgnoreCase)
                    && !string.Equals(current.Album, current.Subtitle, StringComparison.OrdinalIgnoreCase))
                {
                    <span>@current.Album</span>
                }
            </div>

            <div class="listen-now-panel__progress">
                @if (Playback.IsAudiobookMode && !string.IsNullOrWhiteSpace(CurrentChapterProgressLabel))
                {
                    <div class="listen-now-panel__chapter-row">
                        <span>
                            <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Class="tl-u-font-size-20px" />
                            <strong>@CurrentChapterProgressLabel</strong>
                        </span>
                        <span>@ProgressPercentLabel</span>
                    </div>
                }
                <AppNativeInput Type="range"
                                Min="0"
                                Max="@ProgressMax"
                                Step="1"
                                Value="@Math.Min(Playback.CurrentTimeSeconds, ProgressMax)"
                                Class="listen-now-panel__slider"
                                OnInput="SeekAsync" />
                <div class="listen-now-panel__time">
                    <span>@FormatTimestamp(Playback.CurrentTimeSeconds)</span>
                    <span>@FormatTimestamp(Math.Max(0, Playback.DurationSeconds - Playback.CurrentTimeSeconds))</span>
                </div>
            </div>

            @if (Playback.IsAudiobookMode)
            {
                <div class="listen-now-panel__controls listen-now-panel__controls--audiobook" aria-label="Audiobook playback controls">
                    <AppNativeButton Type="button" Class="listen-now-panel__icon" OnClick="PlayPreviousChapterAsync" Disabled="@(!HasChapters)" AriaLabel="Previous chapter" title="Previous chapter">
                        <MudIcon Icon="@Icons.Material.Filled.SkipPrevious" Class="tl-u-font-size-32px" />
                    </AppNativeButton>
                    <AppNativeButton Type="button" Class="listen-now-panel__icon" OnClick="@(() => Playback.SkipBackAsync())" AriaLabel="Back 15 seconds" title="Back 15 seconds">
                        <MudIcon Icon="@Icons.Material.Outlined.Replay" Class="tl-u-font-size-38px" />
                    </AppNativeButton>
                    <AppNativeButton Type="button" Class="listen-now-panel__play" OnClick="TogglePlayAsync" AriaLabel="Play or pause" title="Play or pause">
                        <MudIcon Icon="@(Playback.IsPlaying && !Playback.NeedsUserGestureToStart ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)" Class="tl-u-font-size-42px" />
                    </AppNativeButton>
                    <AppNativeButton Type="button" Class="listen-now-panel__icon" OnClick="@(() => Playback.SkipForwardAsync())" AriaLabel="Forward 15 seconds" title="Forward 15 seconds">
                        <MudIcon Icon="@Icons.Material.Outlined.Forward" Class="tl-u-font-size-38px" />
                    </AppNativeButton>
                    <AppNativeButton Type="button" Class="listen-now-panel__icon" OnClick="PlayNextChapterAsync" Disabled="@(!HasChapters)" AriaLabel="Next chapter" title="Next chapter">
                        <MudIcon Icon="@Icons.Material.Filled.SkipNext" Class="tl-u-font-size-32px" />
                    </AppNativeButton>
                </div>
            }
            else
            {
                <div class="listen-now-panel__controls" aria-label="Playback controls">
                    <AppNativeButton Type="button" Class="listen-now-panel__mini" OnClick="@(() => Playback.CyclePlaybackRateAsync())" AriaLabel="Playback speed">@FormatSpeed(Playback.PlaybackRate)</AppNativeButton>
                    <AppNativeButton Type="button" Class="listen-now-panel__icon" OnClick="PreviousAsync" Disabled="@(Playback.CurrentIndex <= 0)" AriaLabel="Previous">
                        <MudIcon Icon="@Icons.Material.Outlined.SkipPrevious" Class="tl-u-font-size-20px" />
                    </AppNativeButton>
                    <AppNativeButton Type="button" Class="listen-now-panel__play" OnClick="TogglePlayAsync" AriaLabel="Play or pause">
                        <MudIcon Icon="@(Playback.IsPlaying && !Playback.NeedsUserGestureToStart ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)" Class="tl-u-font-size-30px" />
                    </AppNativeButton>
                    <AppNativeButton Type="button" Class="listen-now-panel__icon" OnClick="NextAsync" Disabled="@(Playback.CurrentIndex >= Playback.Queue.Count - 1)" AriaLabel="Next">
                        <MudIcon Icon="@Icons.Material.Outlined.SkipNext" Class="tl-u-font-size-20px" />
                    </AppNativeButton>
                    <AppNativeButton Type="button" Class="listen-now-panel__icon" AriaLabel="Queue options" title="Queue options">
                        <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Class="tl-u-font-size-18px" />
                    </AppNativeButton>
                </div>
            }

            <div class="listen-now-panel__volume">
                <AppNativeButton Type="button" Class="listen-now-panel__volume-button" OnClick="ToggleMuteAsync" AriaLabel="Mute">
                    <MudIcon Icon="@(Playback.IsMuted || Playback.Volume <= 0 ? Icons.Material.Outlined.VolumeOff : Icons.Material.Outlined.VolumeUp)" Class="tl-u-font-size-18px" />
                </AppNativeButton>
                <AppNativeInput Type="range"
                                Min="0"
                                Max="1"
                                Step="0.05"
                                Value="@Playback.Volume"
                                Class="listen-now-panel__slider"
                                OnInput="SetVolumeAsync" />
            </div>

            @if (Playback.IsAudiobookMode)
            {
                <div class="listen-now-panel__audiobook-actions" aria-label="Audiobook tools">
                    @AudiobookActionButton("speed", $"Speed {FormatSpeed(Playback.PlaybackRate)}", Icons.Material.Outlined.Speed)
                    @AudiobookActionButton("chapters", "Chapters", Icons.Material.Outlined.FormatListBulleted)
                    @AudiobookActionButton("history", "History", Icons.Material.Outlined.History)
                    @AudiobookActionButton("bookmarks", "Bookmark", Icons.Material.Outlined.BookmarkBorder)
                    @AudiobookActionButton("sleep", "Sleep timer", Icons.Material.Outlined.Timer)
                </div>

                @if (_activeAudiobookSheet is not null)
                {
                    <section class="listen-now-panel__sheet" aria-label="@AudiobookSheetTitle">
                        <div class="listen-now-panel__sheet-grabber"></div>
                        <div class="listen-now-panel__sheet-header">
                            <div>
                                <span>@AudiobookSheetTitle</span>
                                <p>@AudiobookSheetSubtitle</p>
                            </div>
                            <div class="listen-now-panel__sheet-actions">
                                <span class="listen-now-panel__sheet-status">@SheetStatus</span>
                                <AppNativeButton Type="button" Class="listen-now-panel__sheet-close" OnClick="CloseAudiobookSheet" AriaLabel="Close sheet" title="Close sheet">
                                    <MudIcon Icon="@Icons.Material.Outlined.Close" Class="tl-u-font-size-28px" />
                                </AppNativeButton>
                            </div>
                        </div>

                        @switch (_activeAudiobookSheet)
                        {
                            case "speed":
                                <div class="listen-now-panel__sheet-list listen-now-panel__sheet-list--speed">
                                    @foreach (var rate in SpeedRates)
                                    {
                                        <AppNativeButton Type="button" Class="@($"listen-now-panel__sheet-row listen-now-panel__sheet-row--speed {(Math.Abs(rate - Playback.PlaybackRate) < 0.01d ? "is-active" : null)}")" OnClick="@(() => SetSpeedAsync(rate))" AriaLabel="@($"Set speed to {FormatSpeed(rate)}")" title="@($"Set speed to {FormatSpeed(rate)}")">
                                            <span class="listen-now-panel__radio"></span>
                                            <strong>@FormatSpeed(rate)</strong>
                                        </AppNativeButton>
                                    }
                                </div>
                                break;
                            case "chapters":
                                <div class="listen-now-panel__sheet-list">
                                    @if (CurrentChapters.Count == 0)
                                    {
                                        <div class="listen-now-panel__empty">No timed chapters were found for this audiobook.</div>
                                    }
                                    else
                                    {
                                        @foreach (var chapter in CurrentChapters)
                                        {
                                            var isActive = IsCurrentChapter(chapter);
                                            <AppNativeButton Type="button" Class="@($"listen-now-panel__sheet-row {(isActive ? "is-active" : null)}")" OnClick="@(() => PlayChapterAsync(chapter))" AriaLabel="@($"Play {chapter.Title}")" title="@($"Play {chapter.Title}")">
                                                <span class="listen-now-panel__queue-copy">
                                                    <strong>@chapter.Title</strong>
                                                    <span>@ChapterDuration(chapter)</span>
                                                </span>
                                                <MudIcon Icon="@(isActive ? Icons.Material.Filled.VolumeUp : Icons.Material.Filled.ChevronRight)" Class="tl-u-font-size-22px" />
                                            </AppNativeButton>
                                        }
                                    }
                                </div>
                                break;
                            case "history":
                                <div class="listen-now-panel__sheet-list">
                                    @if (Playback.AudiobookHistory.Count == 0)
                                    {
                                        <div class="listen-now-panel__empty">Recent listening positions will appear here.</div>
                                    }
                                    else
                                    {
                                        @foreach (var item in Playback.AudiobookHistory)
                                        {
                                            <AppNativeButton Type="button" Class="listen-now-panel__sheet-row" OnClick="@(() => PlayHistoryAsync(item))" AriaLabel="@($"Resume from {HistoryTitle(item)}")" title="@($"Resume from {HistoryTitle(item)}")">
                                                <span class="listen-now-panel__queue-copy">
                                                    <strong>@HistoryTitle(item)</strong>
                                                    <span>@HistorySubtitle(item)</span>
                                                </span>
                                                <span class="listen-now-panel__queue-duration">Resume</span>
                                            </AppNativeButton>
                                        }
                                    }
                                </div>
                                break;
                            case "bookmarks":
                                <div class="listen-now-panel__sheet-toolbar">
                                    <AppNativeButton Type="button" Class="listen-now-panel__sheet-primary" OnClick="AddBookmarkAsync" AriaLabel="Add bookmark at current position" title="Add bookmark at current position">
                                        <MudIcon Icon="@Icons.Material.Outlined.BookmarkAdd" Class="tl-u-font-size-20px" />
                                        <span>Add bookmark at @FormatTimestamp(Playback.CurrentTimeSeconds)</span>
                                    </AppNativeButton>
                                </div>
                                <div class="listen-now-panel__sheet-list">
                                    @if (Playback.AudiobookBookmarks.Count == 0)
                                    {
                                        <div class="listen-now-panel__empty">No bookmarks yet.</div>
                                    }
                                    else
                                    {
                                        @foreach (var bookmark in Playback.AudiobookBookmarks)
                                        {
                                            <div class="listen-now-panel__bookmark-row">
                                                <AppNativeButton Type="button" Class="listen-now-panel__sheet-row listen-now-panel__sheet-row--bookmark" OnClick="@(() => PlayBookmarkAsync(bookmark))" AriaLabel="@($"Resume bookmark {BookmarkTitle(bookmark)}")" title="@($"Resume bookmark {BookmarkTitle(bookmark)}")">
                                                    <span class="listen-now-panel__queue-copy">
                                                        <strong>@BookmarkTitle(bookmark)</strong>
                                                        <span>@bookmark.CreatedAt.LocalDateTime.ToString("g", CultureInfo.CurrentCulture)</span>
                                                    </span>
                                                    <span class="listen-now-panel__queue-duration">Resume</span>
                                                </AppNativeButton>
                                                <AppNativeButton Type="button" Class="listen-now-panel__delete" OnClick="@(() => DeleteBookmarkAsync(bookmark.Id))" AriaLabel="Delete bookmark" title="Delete bookmark">
                                                    <MudIcon Icon="@Icons.Material.Outlined.Delete" Class="tl-u-font-size-20px" />
                                                </AppNativeButton>
                                            </div>
                                        }
                                    }
                                </div>
                                break;
                            case "sleep":
                                <div class="listen-now-panel__timer-grid">
                                    @TimerButton("Off", null, null)
                                    @TimerButton("5 min", 5, null)
                                    @TimerButton("10 min", 10, null)
                                    @TimerButton("15 min", 15, null)
                                    @TimerButton("30 min", 30, null)
                                    @TimerButton("45 min", 45, null)
                                    @TimerButton("60 min", 60, null)
                                    @TimerButton("End of chapter", null, ListenSleepTimerModes.EndOfChapter)
                                </div>
                                break;
                        }
                    </section>
                }
            }
            else
            {
                <div class="listen-now-panel__queue-header">
                    <span>Up Next</span>
                    <AppNativeButton Type="button" Class="listen-now-panel__clear" OnClick="Playback.ClearUpcoming">Clear</AppNativeButton>
                </div>

                @if (Playback.UpcomingQueue.Count == 0)
                {
                    <div class="listen-now-panel__empty">The queue ends with the current item.</div>
                }
                else
                {
                    <div class="listen-now-panel__queue">
                        @for (var index = Playback.CurrentIndex + 1; index < Playback.Queue.Count; index++)
                        {
                            var item = Playback.Queue[index];
                            <div class="listen-now-panel__queue-row">
                                <MudIcon Icon="@Icons.Material.Outlined.DragIndicator" Class="listen-now-panel__drag tl-u-font-size-18px" />
                                <AppNativeButton Type="button" Class="listen-now-panel__queue-main" OnClick="@(() => PlayFromQueueAsync(index))">
                                    <span class="listen-now-panel__queue-cover">
                                        @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                                        {
                                            <img src="@item.CoverUrl" alt="" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@FallbackIconFor(item)" Class="tl-u-font-size-16px" />
                                        }
                                    </span>
                                    <span class="listen-now-panel__queue-copy">
                                        <strong>@item.Title</strong>
                                        <span>@FirstNonBlank(item.Subtitle, item.Album, item.MediaType)</span>
                                    </span>
                                    <span class="listen-now-panel__queue-duration">@item.Duration</span>
                                </AppNativeButton>
                            </div>
                        }
                    </div>
                }

                <div class="listen-now-panel__drop" @ondragover:preventDefault="true" @ondrop:stopPropagation="true" @ondrop="QueueDraggedItemsAsync">
                    <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Class="tl-u-font-size-30px" />
                    <span>Drag tracks here to queue or into playlists</span>
                </div>
            }
        </div>
    }
    else
    {
        <div class="listen-now-panel__placeholder">
            <MudIcon Icon="@Icons.Material.Outlined.LibraryMusic" Class="tl-u-font-size-48px" />
            <p>Choose music or an audiobook to start listening.</p>
        </div>
    }
</aside>

@code {
    private static readonly IReadOnlyList<double> SpeedRates = Enumerable.Range(5, 26).Select(value => value / 10d).ToList();
    private string? _activeAudiobookSheet = "history";

    private double ProgressMax => Playback.DurationSeconds > 0 ? Playback.DurationSeconds : 1;
    private IReadOnlyList<PlaybackChapterDto> CurrentChapters =>
        Playback.CurrentItem is { Chapters.Count: > 1 } item ? item.Chapters : [];
    private bool HasChapters => CurrentChapters.Count > 0;
    private string PanelClass => Playback.IsAudiobookMode ? "listen-now-panel listen-now-panel--audiobook" : "listen-now-panel";
    private string AudiobookSheetTitle => _activeAudiobookSheet switch
    {
        "speed" => "Speed",
        "chapters" => "Chapters",
        "history" => "History",
        "bookmarks" => "Bookmarks",
        "sleep" => "Sleep Timer",
        _ => "Audiobook",
    };
    private string AudiobookSheetSubtitle => _activeAudiobookSheet switch
    {
        "speed" => "Choose playback speed",
        "chapters" => "Jump to a chapter",
        "history" => "Recent listening positions",
        "bookmarks" => "Saved audiobook positions",
        "sleep" => "Stop playback automatically",
        _ => string.Empty,
    };
    private string SheetStatus => _activeAudiobookSheet switch
    {
        "speed" => FormatSpeed(Playback.PlaybackRate),
        "chapters" => CurrentChapters.Count == 1 ? "1 chapter" : $"{CurrentChapters.Count} chapters",
        "history" => Playback.AudiobookHistory.Count == 1 ? "1 item" : $"{Playback.AudiobookHistory.Count} items",
        "bookmarks" => Playback.AudiobookBookmarks.Count == 1 ? "1 saved" : $"{Playback.AudiobookBookmarks.Count} saved",
        "sleep" => SleepTimerDisplay,
        _ => string.Empty,
    };
    private string SleepTimerDisplay => Playback.SleepTimerMode switch
    {
        ListenSleepTimerModes.EndOfChapter => "End of chapter",
        ListenSleepTimerModes.Timer when Playback.SleepTimerEndsAtUtc.HasValue => $"{Math.Max(1, (int)Math.Ceiling((Playback.SleepTimerEndsAtUtc.Value - DateTimeOffset.UtcNow).TotalMinutes))} min",
        _ => "Off",
    };
    private string CurrentChapterProgressLabel =>
        Playback.CurrentChapter is { } chapter && CurrentChapters.Count > 1
            ? $"{chapter.Title} of {CurrentChapters.Count}"
            : string.Empty;
    private string ProgressPercentLabel =>
        $"{Math.Clamp((int)Math.Round(Playback.CurrentTimeSeconds / ProgressMax * 100d, MidpointRounding.AwayFromZero), 0, 100)}%";

    protected override void OnInitialized()
    {
        Playback.OnChanged += HandlePlaybackChanged;
    }

    private void HandlePlaybackChanged() => _ = InvokeAsync(StateHasChanged);

    private RenderFragment AudiobookActionButton(string sheet, string label, string icon) => @<AppNativeButton Type="button" Class="@($"listen-now-panel__action {(_activeAudiobookSheet == sheet ? "is-active" : null)}")" OnClick="@(() => ToggleAudiobookSheet(sheet))" AriaLabel="@label" title="@label">
        <MudIcon Icon="@icon" Class="tl-u-font-size-38px" />
    </AppNativeButton>;

    private void ToggleAudiobookSheet(string sheet) =>
        _activeAudiobookSheet = _activeAudiobookSheet == sheet ? null : sheet;

    private void CloseAudiobookSheet() => _activeAudiobookSheet = null;

    private RenderFragment TimerButton(string label, int? minutes, string? mode) => @<AppNativeButton Type="button" Class="@($"listen-now-panel__timer {(IsTimerActive(minutes, mode) ? "is-active" : null)}")" OnClick="@(() => SetTimerAsync(minutes, mode))" AriaLabel="@($"Set sleep timer to {label}")" title="@($"Set sleep timer to {label}")">@label</AppNativeButton>;

    private Task TogglePlayAsync() => Playback.RequestTransportCommandAsync(new("toggle-play"));

    private Task NextAsync() =>
        Playback.RequestTransportCommandAsync(new("play-next"));

    private Task PreviousAsync() =>
        Playback.RequestTransportCommandAsync(new("play-previous"));

    private Task PlayNextChapterAsync() => Playback.PlayNextChapterAsync();

    private Task PlayPreviousChapterAsync() => Playback.PlayPreviousChapterAsync();

    private Task PlayChapterAsync(PlaybackChapterDto chapter) =>
        Playback.PlayAudiobookChapterAsync(chapter.Index);

    private Task ToggleMuteAsync() => Playback.RequestTransportCommandAsync(new("toggle-mute"));

    private Task PlayFromQueueAsync(int index) => Playback.PlayIndexAsync(index);

    private Task PlayHistoryAsync(AudiobookListenHistoryItemDto item) => Playback.PlayAudiobookHistoryAsync(item);

    private Task SetSpeedAsync(double rate) => Playback.SetPlaybackRateAsync(rate);

    private Task AddBookmarkAsync() => Playback.AddAudiobookBookmarkAsync();

    private Task PlayBookmarkAsync(AudiobookBookmarkDto bookmark) => Playback.PlayAudiobookBookmarkAsync(bookmark);

    private Task DeleteBookmarkAsync(Guid bookmarkId) => Playback.DeleteAudiobookBookmarkAsync(bookmarkId);

    private Task SetTimerAsync(int? minutes, string? mode)
    {
        if (string.Equals(mode, ListenSleepTimerModes.EndOfChapter, StringComparison.Ordinal))
        {
            return Playback.SetSleepTimerEndOfChapterAsync();
        }

        return minutes.HasValue
            ? Playback.SetSleepTimerAsync(TimeSpan.FromMinutes(minutes.Value))
            : Playback.CancelSleepTimerAsync();
    }

    private Task SeekAsync(ChangeEventArgs args)
    {
        if (!double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var seconds))
        {
            return Task.CompletedTask;
        }

        return Playback.RequestTransportCommandAsync(new("seek", seconds));
    }

    private Task SetVolumeAsync(ChangeEventArgs args)
    {
        if (!double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var volume))
        {
            return Task.CompletedTask;
        }

        return Playback.RequestTransportCommandAsync(new("set-volume", Math.Clamp(volume, 0d, 1d)));
    }

    private async Task QueueDraggedItemsAsync()
    {
        if (!AudioDrag.HasItems)
        {
            return;
        }

        foreach (var item in AudioDrag.Items)
        {
            await Playback.AddQueueItemAsync(item);
        }

        AudioDrag.Clear();
    }

    private static string FormatTimestamp(double seconds)
    {
        var span = TimeSpan.FromSeconds(Math.Max(0, seconds));
        return span.TotalHours >= 1
            ? span.ToString(@"h\:mm\:ss", CultureInfo.InvariantCulture)
            : span.ToString(@"m\:ss", CultureInfo.InvariantCulture);
    }

    private static string FormatSpeed(double rate) =>
        $"{Math.Clamp(rate, 0.5d, 3d).ToString("0.##", CultureInfo.InvariantCulture)}x";

    private string PlayerSubtitle(ListenQueueItem item) =>
        Playback.IsAudiobookMode
            ? FirstDistinctFrom(item.Title, item.Subtitle, item.Album, item.MediaType)
            : FirstNonBlank(item.Subtitle, item.Album, item.MediaType);

    private bool IsTimerActive(int? minutes, string? mode)
    {
        if (string.Equals(mode, ListenSleepTimerModes.EndOfChapter, StringComparison.Ordinal))
        {
            return Playback.SleepTimerMode == ListenSleepTimerModes.EndOfChapter;
        }

        if (!minutes.HasValue)
        {
            return Playback.SleepTimerMode == ListenSleepTimerModes.Off;
        }

        return Playback.SleepTimerMode == ListenSleepTimerModes.Timer
            && Playback.SleepTimerEndsAtUtc.HasValue
            && Math.Abs((Playback.SleepTimerEndsAtUtc.Value - DateTimeOffset.UtcNow).TotalMinutes - minutes.Value) < 1.2d;
    }

    private bool IsCurrentChapter(PlaybackChapterDto chapter) =>
        Playback.CurrentTimeSeconds >= chapter.StartSeconds - 0.5d
        && (!chapter.EndSeconds.HasValue || Playback.CurrentTimeSeconds < chapter.EndSeconds.Value - 0.5d);

    private static string ChapterDuration(PlaybackChapterDto chapter) =>
        chapter.EndSeconds is > 0 && chapter.EndSeconds.Value > chapter.StartSeconds
            ? FormatTimestamp(chapter.EndSeconds.Value - chapter.StartSeconds)
            : string.Empty;

    private static string HistoryTitle(AudiobookListenHistoryItemDto item) =>
        item.EndedAt.LocalDateTime.ToString("g", CultureInfo.CurrentCulture);

    private static string HistorySubtitle(AudiobookListenHistoryItemDto item) =>
        $"Left off at {FormatTimestamp(item.PositionSeconds)}";

    private static string BookmarkTitle(AudiobookBookmarkDto item) =>
        FirstNonBlank(item.Label, item.ChapterTitle, $"Bookmark at {FormatTimestamp(item.PositionSeconds)}");

    private static string FallbackIconFor(ListenQueueItem item) =>
        item.MediaType.Contains("Audiobook", StringComparison.OrdinalIgnoreCase)
            ? Icons.Material.Outlined.Headphones
            : Icons.Material.Outlined.Album;

    private static string FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? "Library audio";

    private static string FirstDistinctFrom(string? primary, params string?[] values)
        => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)
            && !string.Equals(value, primary, StringComparison.OrdinalIgnoreCase)) ?? "Audiobook";

    public void Dispose()
    {
        Playback.OnChanged -= HandlePlaybackChanged;
    }
}
