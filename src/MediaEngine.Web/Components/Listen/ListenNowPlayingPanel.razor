@namespace MediaEngine.Web.Components.Listen
@using System.Globalization
@using MediaEngine.Contracts.Playback
@using MediaEngine.Web.Components.Shared
@using MediaEngine.Web.Services.Playback
@using Microsoft.JSInterop
@inject ListenAudioDragService AudioDrag
@inject PlaybackSessionController Playback
@inject IJSRuntime JS
@implements IDisposable

<aside class="@PanelClass" aria-label="Now playing" @ondragover:preventDefault="true" @ondrop="QueueDraggedItemsAsync">
    <div class="listen-now-panel__header">
        <span>Now Playing</span>
        <div class="listen-now-panel__top-actions">
            <AppNativeButton Type="button" Class="listen-now-panel__top-icon" Disabled="true" AriaLabel="Playback device" title="Playback device">
                <MudIcon Icon="@Icons.Material.Outlined.Cast" Class="tl-u-font-size-24px" />
            </AppNativeButton>
            <AppNativeButton Type="button" Class="listen-now-panel__top-icon" OnClick="TogglePopupAsync" AriaLabel="Pop out player" title="Pop out player" data-listen-popup-route="@(Playback.IsPopupOpen ? null : PopupRoute)">
                <MudIcon Icon="@(Playback.IsPopupOpen ? Icons.Material.Outlined.OpenInNewOff : Icons.Material.Outlined.OpenInNew)" Class="tl-u-font-size-24px" />
            </AppNativeButton>
        </div>
    </div>

    @if (Playback.IsPopupOpen)
    {
        <div class="listen-now-panel__popped-out">
            <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Class="tl-u-font-size-42px" />
            <strong>Player popped out</strong>
            <span>Playback is active in the popup window.</span>
            <AppNativeButton Type="button" Class="listen-now-panel__dock-button" OnClick="TogglePopupAsync" AriaLabel="Dock player" title="Dock player">
                Dock player
            </AppNativeButton>
        </div>
    }
    else if (Playback.HasQueue && Playback.CurrentItem is not null)
    {
        var current = Playback.CurrentItem;
        <div class="listen-now-panel__body">
            <div class="listen-now-panel__cover">
                @if (!string.IsNullOrWhiteSpace(current.CoverUrl))
                {
                    <img src="@current.CoverUrl" alt="@current.Title" />
                }
                else
                {
                    <MudIcon Icon="@FallbackIconFor(current)" Class="tl-u-font-size-64px" />
                }
            </div>

            <div class="listen-now-panel__meta">
                <h2>@current.Title</h2>
                @if (!Playback.IsAudiobookMode)
                {
                    <p>@PlayerSubtitle(current)</p>
                    @if (!string.IsNullOrWhiteSpace(current.Album)
                        && !string.Equals(current.Album, current.Title, StringComparison.OrdinalIgnoreCase)
                        && !string.Equals(current.Album, current.Subtitle, StringComparison.OrdinalIgnoreCase))
                    {
                        <span>@current.Album</span>
                    }
                }
            </div>

            <div class="listen-now-panel__progress">
                @if (Playback.IsAudiobookMode && !string.IsNullOrWhiteSpace(CurrentChapterProgressLabel))
                {
                    <PlaybackTimelineMetaRow Icon="@Icons.Material.Outlined.MenuBook"
                                             Label="@CurrentChapterProgressLabel"
                                             TrailingText="@ProgressPercentLabel"
                                             Size="standard"
                                             Class="listen-now-panel__chapter-row" />
                }
                <AppNativeInput Type="range"
                                Min="0"
                                Max="@ProgressMax"
                                 Step="1"
                                 Value="@Math.Min(Playback.CurrentTimeSeconds, ProgressMax)"
                                 Class="listen-now-panel__slider"
                                 OnChange="SeekAsync"
                                 AriaLabel="Playback position"
                                 aria-valuetext="@ProgressValueText" />
                <div class="listen-now-panel__time">
                    <span>@FormatTimestamp(Playback.CurrentTimeSeconds)</span>
                    <span>@FormatTimestamp(Math.Max(0, Playback.DurationSeconds - Playback.CurrentTimeSeconds))</span>
                </div>
            </div>

            <ListenTransportControls Variant="panel"
                                     IsAudiobookMode="@Playback.IsAudiobookMode"
                                     IsPlaying="@Playback.IsPlaying"
                                     NeedsUserGestureToStart="@Playback.NeedsUserGestureToStart"
                                     IsMuted="@Playback.IsMuted"
                                     HasChapters="@HasChapters"
                                     CanPreviousTrack="@(Playback.CurrentIndex > 0)"
                                     CanNextTrack="@(Playback.CurrentIndex < Playback.Queue.Count - 1)"
                                     ShowSpeedButton="true"
                                     ShowQueueButton="true"
                                     SkipBackSeconds="@Playback.SkipBackSeconds"
                                     SkipForwardSeconds="@Playback.SkipForwardSeconds"
                                     CurrentBrowserStreamUrl="@Playback.CurrentBrowserStreamUrl"
                                     CurrentTimeSeconds="@Playback.CurrentTimeSeconds"
                                     PlaybackRate="@Playback.PlaybackRate"
                                     Volume="@Playback.Volume"
                                     OnTogglePlay="TogglePlayAsync"
                                     OnPreviousTrack="PreviousAsync"
                                     OnNextTrack="NextAsync"
                                     OnPreviousChapter="PlayPreviousChapterAsync"
                                     OnNextChapter="PlayNextChapterAsync"
                                     OnSkipBack="SkipBackAsync"
                                     OnSkipForward="SkipForwardAsync"
                                     OnSpeed="CyclePlaybackRateAsync"
                                     OnQueue="ShowQueueAsync" />

            <div class="listen-now-panel__volume">
                <AppNativeButton Type="button" Class="listen-now-panel__volume-button" OnClick="ToggleMuteAsync" AriaLabel="Mute or unmute" title="Mute or unmute">
                    <MudIcon Icon="@(Playback.IsMuted || Playback.Volume <= 0 ? Icons.Material.Outlined.VolumeOff : Icons.Material.Outlined.VolumeUp)" Class="tl-u-font-size-18px" />
                </AppNativeButton>
                <AppNativeInput Type="range"
                                Min="0"
                                Max="1"
                                Step="@VolumeStep"
                                 Value="@Playback.Volume"
                                 Class="listen-now-panel__slider"
                                 OnChange="SetVolumeAsync"
                                 AriaLabel="Volume"
                                 aria-valuetext="@VolumeValueText" />
            </div>

            @if (Playback.IsAudiobookMode)
            {
                <PlaybackControlStrip Controls="@AudiobookToolControls"
                                      Size="standard"
                                      Class="listen-now-panel__audiobook-actions"
                                      AriaLabel="Audiobook tools"
                                      OnControl="HandleAudiobookToolControl" />
            }
            else
            {
                <div class="listen-now-panel__queue-header">
                    <span>Up Next</span>
                    <AppNativeButton Type="button" Class="listen-now-panel__clear" OnClick="Playback.ClearUpcoming">Clear</AppNativeButton>
                </div>

                @if (Playback.UpcomingQueue.Count == 0)
                {
                    <div class="listen-now-panel__empty">The queue ends with the current item.</div>
                }
                else
                {
                    <div class="listen-now-panel__queue">
                        @for (var index = Playback.CurrentIndex + 1; index < Playback.Queue.Count; index++)
                        {
                            var item = Playback.Queue[index];
                            <div class="listen-now-panel__queue-row">
                                <MudIcon Icon="@Icons.Material.Outlined.DragIndicator" Class="listen-now-panel__drag tl-u-font-size-18px" />
                                <AppNativeButton Type="button" Class="listen-now-panel__queue-main" OnClick="@(() => PlayFromQueueAsync(index))">
                                    <span class="listen-now-panel__queue-cover">
                                        @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                                        {
                                            <img src="@item.CoverUrl" alt="" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@FallbackIconFor(item)" Class="tl-u-font-size-16px" />
                                        }
                                    </span>
                                    <span class="listen-now-panel__queue-copy">
                                        <strong>@item.Title</strong>
                                        <span>@FirstNonBlank(item.Subtitle, item.Album, item.MediaType)</span>
                                    </span>
                                    <span class="listen-now-panel__queue-duration">@item.Duration</span>
                                </AppNativeButton>
                            </div>
                        }
                    </div>
                }

                <div class="listen-now-panel__drop" @ondragover:preventDefault="true" @ondrop:stopPropagation="true" @ondrop="QueueDraggedItemsAsync">
                    <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Class="tl-u-font-size-30px" />
                    <span>Drag tracks here to queue or into playlists</span>
                </div>
            }
        </div>

        @if (Playback.IsAudiobookMode && _activeAudiobookSheet is not null)
        {
            <PlaybackToolSheet Title="@AudiobookSheetTitle"
                               Subtitle="@AudiobookSheetSubtitle"
                               Surface="panel"
                               Class="listen-now-panel__sheet"
                               OnClose="CloseAudiobookSheet">
                @switch (_activeAudiobookSheet)
                {
                    case "speed":
                        <PlaybackSpeedControl Value="@Playback.PlaybackRate"
                                              ValueChanged="SetSpeedAsync"
                                              Class="listen-now-panel__speed-control" />
                        break;
                    case "chapters":
                        <div class="listen-now-panel__sheet-list listen-now-panel__sheet-list--simple">
                            @if (CurrentChapters.Count == 0)
                            {
                                <div class="listen-now-panel__empty">No timed chapters were found for this audiobook.</div>
                            }
                            else
                            {
                                @foreach (var chapter in CurrentChapters)
                                {
                                    var isActive = IsCurrentChapter(chapter);
                                    <AppNativeButton Type="button" Class="@($"listen-now-panel__sheet-row listen-now-panel__sheet-row--chapter {(isActive ? "is-active" : null)}")" OnClick="@(() => PlayChapterAsync(chapter))" AriaLabel="@($"Play {chapter.Title}")" title="@($"Play {chapter.Title}")">
                                        <span class="listen-now-panel__queue-copy">
                                            <strong>@chapter.Title</strong>
                                        </span>
                                        <span class="listen-now-panel__queue-duration">@ChapterDuration(chapter)</span>
                                    </AppNativeButton>
                                }
                            }
                        </div>
                        break;
                    case "history":
                        <div class="listen-now-panel__sheet-list listen-now-panel__sheet-list--history">
                            @if (Playback.AudiobookHistory.Count == 0)
                            {
                                <div class="listen-now-panel__empty">Recent listening positions will appear here.</div>
                            }
                            else
                            {
                                <PlaybackPositionList Class="listen-now-panel__position-list">
                                    @foreach (var item in Playback.AudiobookHistory)
                                    {
                                        <PlaybackPositionRow Class="listen-now-panel__history-row"
                                                             Presentation="list"
                                                             Title="@HistoryTitle(item)"
                                                             PositionText="@HistoryPositionText(item)"
                                                             TimestampText="@HistorySubtitle(item)"
                                                             OnClick="@(() => PlayHistoryAsync(item))"
                                                             AriaLabel="@($"Resume {HistoryTitle(item)} from {HistoryPositionText(item)}")" />
                                    }
                                </PlaybackPositionList>
                            }
                        </div>
                        break;
                    case "bookmarks":
                        <div class="listen-now-panel__sheet-toolbar">
                            <PlaybackPositionRow Class="listen-now-panel__bookmark-add"
                                                 Kind="add"
                                                 Size="compact"
                                                 Title="@($"Add bookmark at {FormatTimestamp(Playback.CurrentTimeSeconds)}")"
                                                 LeadingIcon="@Icons.Material.Outlined.BookmarkAdd"
                                                 ActionIcon="@Icons.Material.Outlined.ChevronRight"
                                                 ActionLabel=""
                                                 ActionVariant="plain"
                                                 OnClick="AddBookmarkAsync"
                                                 AriaLabel="Add bookmark at current position" />
                        </div>
                        <div class="listen-now-panel__sheet-list">
                            @if (Playback.AudiobookBookmarks.Count == 0)
                            {
                                <div class="listen-now-panel__empty">No bookmarks yet.</div>
                            }
                            else
                            {
                                <PlaybackPositionList Class="listen-now-panel__position-list">
                                    @foreach (var bookmark in Playback.AudiobookBookmarks)
                                    {
                                        <PlaybackPositionRow Class="listen-now-panel__bookmark-row"
                                                             Presentation="list"
                                                             Title="@BookmarkTitle(bookmark)"
                                                             PositionText="@BookmarkPositionText(bookmark)"
                                                             TimestampText="@BookmarkSubtitle(bookmark)"
                                                             LeadingIcon="@Icons.Material.Outlined.BookmarkBorder"
                                                             ActionLabel="Go to"
                                                             OnClick="@(() => PlayBookmarkAsync(bookmark))"
                                                             AriaLabel="@($"Go to bookmark {BookmarkTitle(bookmark)} at {BookmarkPositionText(bookmark)}")" />
                                    }
                                </PlaybackPositionList>
                            }
                        </div>
                        break;
                    case "sleep":
                        <PlaybackSleepTimerControl OptionsMinutes="@Playback.SleepTimerOptionsMinutes"
                                                   Mode="@Playback.SleepTimerMode"
                                                   TimerMode="@ListenSleepTimerModes.Timer"
                                                   OffMode="@ListenSleepTimerModes.Off"
                                                   EndOfSectionMode="@ListenSleepTimerModes.EndOfChapter"
                                                   EndsAtUtc="@Playback.SleepTimerEndsAtUtc"
                                                   AllowEndOfSection="@Playback.AllowEndOfChapterSleepTimer"
                                                   TimerMinutesChanged="SetTimerMinutesAsync"
                                                   EndOfSectionChanged="SetTimerEndOfChapterAsync"
                                                   Class="listen-now-panel__sleep-control" />
                        break;
                }
            </PlaybackToolSheet>
        }
    }
    else
    {
        <div class="listen-now-panel__placeholder">
            <MudIcon Icon="@Icons.Material.Outlined.LibraryMusic" Class="tl-u-font-size-48px" />
            <p>Choose music or an audiobook to start listening.</p>
        </div>
    }
</aside>

@code {
    private const string PopupRoute = "/listen/player-popup";
    private string? _activeAudiobookSheet;

    private double ProgressMax => Playback.DurationSeconds > 0 ? Playback.DurationSeconds : 1;
    private string VolumeStep => Playback.ClientSettings.VolumeStep.ToString("0.###", CultureInfo.InvariantCulture);
    private string ProgressValueText => $"{FormatTimestamp(Playback.CurrentTimeSeconds)} of {FormatTimestamp(ProgressMax)}";
    private string VolumeValueText => $"{Math.Clamp((int)Math.Round(Playback.Volume * 100d), 0, 100)}%";
    private IReadOnlyList<PlaybackChapterDto> CurrentChapters =>
        Playback.CurrentItem is { Chapters.Count: > 1 } item ? item.Chapters : [];
    private bool HasChapters => CurrentChapters.Count > 0;
    private string PanelClass
    {
        get
        {
            var classes = Playback.IsAudiobookMode ? "listen-now-panel listen-now-panel--audiobook" : "listen-now-panel";
            return Playback.IsPopupOpen ? $"{classes} listen-now-panel--popped-out" : classes;
        }
    }
    private string AudiobookSheetTitle => _activeAudiobookSheet switch
    {
        "speed" => "Speed",
        "chapters" => "Chapters",
        "history" => "History",
        "bookmarks" => "Bookmarks",
        "sleep" => "Sleep Timer",
        _ => "Audiobook",
    };
    private string AudiobookSheetSubtitle => _activeAudiobookSheet switch
    {
        "speed" => "Adjust playback speed",
        "chapters" => string.Empty,
        "history" => "Recent listening positions",
        "bookmarks" => "Saved audiobook positions",
        "sleep" => "Stop playback automatically",
        _ => string.Empty,
    };
    private IReadOnlyList<PlaybackControlDefinition> AudiobookToolControls =>
        PlaybackControlCatalog.BuildToolStrip(
            PlaybackExperience.Audiobook,
            PlaybackControlSurface.SidePanel,
            new PlaybackControlState(
                ActiveSheet: _activeAudiobookSheet,
                PlaybackRate: Playback.PlaybackRate,
                HasChapters: HasChapters,
                IsSleepTimerActive: Playback.SleepTimerMode != ListenSleepTimerModes.Off,
                HistoryCount: Playback.AudiobookHistory.Count,
                BookmarkCount: Playback.AudiobookBookmarks.Count));
    private string CurrentChapterProgressLabel =>
        Playback.CurrentChapter is { } chapter && CurrentChapters.Count > 1
            ? $"{chapter.Title} of {CurrentChapters.Count}"
            : string.Empty;
    private string ProgressPercentLabel =>
        $"{Math.Clamp((int)Math.Round(Playback.CurrentTimeSeconds / ProgressMax * 100d, MidpointRounding.AwayFromZero), 0, 100)}%";

    protected override void OnInitialized()
    {
        Playback.Changed += HandlePlaybackChanged;
    }

    private void HandlePlaybackChanged(PlaybackChangeKind changeKind) => _ = InvokeAsync(StateHasChanged);

    private void HandleAudiobookToolControl(PlaybackControlDefinition control)
    {
        if (control.IsDisabled || string.IsNullOrWhiteSpace(control.Sheet))
        {
            return;
        }

        ToggleAudiobookSheet(control.Sheet);
    }

    private void ToggleAudiobookSheet(string sheet) =>
        _activeAudiobookSheet = _activeAudiobookSheet == sheet ? null : sheet;

    private void CloseAudiobookSheet() => _activeAudiobookSheet = null;

    private async Task TogglePlayAsync()
    {
        if (await ConsumeImmediateToggleAsync())
        {
            return;
        }

        await Playback.RequestTransportCommandAsync(new("toggle-play"));
    }

    private Task SkipBackAsync() => SkipRelativeAsync(-Playback.SkipBackSeconds);

    private Task SkipForwardAsync() => SkipRelativeAsync(Playback.SkipForwardSeconds);

    private async Task SkipRelativeAsync(double deltaSeconds)
    {
        if (await ConsumeImmediateSeekAsync(deltaSeconds))
        {
            return;
        }

        await Playback.SeekRelativeAsync(deltaSeconds);
    }

    private async Task<bool> ConsumeImmediateToggleAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("listenPlayback.consumeImmediateToggleHandled");
        }
        catch
        {
            return false;
        }
    }

    private async Task<bool> ConsumeImmediateSeekAsync(double deltaSeconds)
    {
        try
        {
            if (!await JS.InvokeAsync<bool>("listenPlayback.consumeImmediateSeekHandled"))
            {
                return false;
            }

            var max = Playback.DurationSeconds > 0 ? Playback.DurationSeconds : double.MaxValue;
            var next = Math.Clamp(Playback.CurrentTimeSeconds + deltaSeconds, 0, max);
            Playback.UpdateTransportState(currentTimeSeconds: next);
            await Playback.ReportHeartbeatAsync(force: true);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private async Task TogglePopupAsync()
    {
        if (Playback.IsPopupOpen)
        {
            await JS.InvokeVoidAsync("listenPlayback.closePopup");
            Playback.SetPopupOpen(false);
            return;
        }

        var opened = await JS.InvokeAsync<bool>("listenPlayback.openPopup", PopupRoute);
        Playback.SetPopupOpen(opened);
    }

    private Task NextAsync() =>
        Playback.RequestTransportCommandAsync(new("play-next"));

    private Task PreviousAsync() =>
        Playback.RequestTransportCommandAsync(new("play-previous"));

    private Task PlayNextChapterAsync() => Playback.PlayNextChapterAsync();

    private Task PlayPreviousChapterAsync() => Playback.PlayPreviousChapterAsync();

    private Task CyclePlaybackRateAsync() => Playback.CyclePlaybackRateAsync();

    private Task ShowQueueAsync()
    {
        Playback.SetActiveTab(ListenPlaybackTabs.Queue);
        return Task.CompletedTask;
    }

    private async Task PlayChapterAsync(PlaybackChapterDto chapter)
    {
        await Playback.PlayAudiobookChapterAsync(chapter.Index);
        CloseAudiobookSheet();
    }

    private Task ToggleMuteAsync() => Playback.RequestTransportCommandAsync(new("toggle-mute"));

    private Task PlayFromQueueAsync(int index) => Playback.PlayIndexAsync(index);

    private async Task PlayHistoryAsync(AudiobookListenHistoryItemDto item)
    {
        await Playback.PlayAudiobookHistoryAsync(item);
        CloseAudiobookSheet();
    }

    private async Task SetSpeedAsync(double rate)
    {
        await Playback.SetPlaybackRateAsync(rate);
    }

    private async Task AddBookmarkAsync()
    {
        await Playback.AddAudiobookBookmarkAsync();
        CloseAudiobookSheet();
    }

    private async Task PlayBookmarkAsync(AudiobookBookmarkDto bookmark)
    {
        await Playback.PlayAudiobookBookmarkAsync(bookmark);
        CloseAudiobookSheet();
    }

    private Task DeleteBookmarkAsync(Guid bookmarkId) => Playback.DeleteAudiobookBookmarkAsync(bookmarkId);

    private Task SetTimerMinutesAsync(int? minutes) =>
        SetTimerAsync(minutes, null);

    private Task SetTimerEndOfChapterAsync() =>
        SetTimerAsync(null, ListenSleepTimerModes.EndOfChapter);

    private async Task SetTimerAsync(int? minutes, string? mode)
    {
        if (string.Equals(mode, ListenSleepTimerModes.EndOfChapter, StringComparison.Ordinal))
        {
            await Playback.SetSleepTimerEndOfChapterAsync();
            return;
        }

        if (minutes.HasValue)
        {
            await Playback.SetSleepTimerAsync(TimeSpan.FromMinutes(minutes.Value));
        }
        else
        {
            await Playback.CancelSleepTimerAsync();
        }
    }

    private Task SeekAsync(ChangeEventArgs args)
    {
        if (!double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var seconds))
        {
            return Task.CompletedTask;
        }

        return Playback.RequestTransportCommandAsync(new("seek", seconds));
    }

    private Task SetVolumeAsync(ChangeEventArgs args)
    {
        if (!double.TryParse(args.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var volume))
        {
            return Task.CompletedTask;
        }

        return Playback.RequestTransportCommandAsync(new("set-volume", Math.Clamp(volume, 0d, 1d)));
    }

    private async Task QueueDraggedItemsAsync()
    {
        if (!AudioDrag.HasItems)
        {
            return;
        }

        foreach (var item in AudioDrag.Items)
        {
            await Playback.AddQueueItemAsync(item);
        }

        AudioDrag.Clear();
    }

    private static string FormatTimestamp(double seconds)
    {
        var span = TimeSpan.FromSeconds(Math.Max(0, seconds));
        return span.TotalHours >= 1
            ? span.ToString(@"h\:mm\:ss", CultureInfo.InvariantCulture)
            : span.ToString(@"m\:ss", CultureInfo.InvariantCulture);
    }

    private static string FormatSpeed(double rate) =>
        $"{Math.Clamp(rate, 0.5d, 3d).ToString("0.##", CultureInfo.InvariantCulture)}x";

    private string PlayerSubtitle(ListenQueueItem item) =>
        Playback.IsAudiobookMode
            ? FirstDistinctFrom(item.Title, item.Subtitle, item.Album, item.MediaType)
            : FirstNonBlank(item.Subtitle, item.Album, item.MediaType);

    private bool IsCurrentChapter(PlaybackChapterDto chapter) =>
        Playback.CurrentTimeSeconds >= chapter.StartSeconds - 0.5d
        && (!chapter.EndSeconds.HasValue || Playback.CurrentTimeSeconds < chapter.EndSeconds.Value - 0.5d);

    private static string ChapterDuration(PlaybackChapterDto chapter) =>
        chapter.EndSeconds is > 0 && chapter.EndSeconds.Value > chapter.StartSeconds
            ? FormatTimestamp(chapter.EndSeconds.Value - chapter.StartSeconds)
            : string.Empty;

    private static string HistoryTitle(AudiobookListenHistoryItemDto item)
        => FirstNonBlank(item.ChapterTitle, $"Position {FormatTimestamp(item.PositionSeconds)}");

    private static string HistoryPositionText(AudiobookListenHistoryItemDto item) =>
        $"Left off at {FormatTimestamp(item.PositionSeconds)}";

    private static string HistorySubtitle(AudiobookListenHistoryItemDto item) =>
        $"{item.EndedAt.LocalDateTime.ToString("MMM d, yyyy", CultureInfo.CurrentCulture)} - {item.EndedAt.LocalDateTime.ToString("h:mm tt", CultureInfo.CurrentCulture)}";

    private static string BookmarkTitle(AudiobookBookmarkDto item) =>
        FirstNonBlank(item.Label, item.ChapterTitle, $"Bookmark at {FormatTimestamp(item.PositionSeconds)}");

    private static string BookmarkPositionText(AudiobookBookmarkDto item) =>
        $"Position {FormatTimestamp(item.PositionSeconds)}";

    private static string BookmarkSubtitle(AudiobookBookmarkDto item) =>
        $"{item.CreatedAt.LocalDateTime.ToString("MMM d, yyyy", CultureInfo.CurrentCulture)} - {item.CreatedAt.LocalDateTime.ToString("h:mm tt", CultureInfo.CurrentCulture)}";

    private static string FallbackIconFor(ListenQueueItem item) =>
        MediaKindClassifier.IsAudiobook(item.MediaType)
            ? Icons.Material.Outlined.Headphones
            : Icons.Material.Outlined.Album;

    private static string FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? "Library audio";

    private static string FirstDistinctFrom(string? primary, params string?[] values)
        => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)
            && !string.Equals(value, primary, StringComparison.OrdinalIgnoreCase)) ?? "Audiobook";

    public void Dispose()
    {
        Playback.Changed -= HandlePlaybackChanged;
    }
}
