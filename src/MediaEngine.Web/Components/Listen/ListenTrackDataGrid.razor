@using System.Globalization
@using Microsoft.AspNetCore.Components.Web
@using MediaEngine.Web.Components.Library
@using MediaEngine.Web.Models.ViewDTOs
@using MudBlazor
@inject IJSRuntime JS
@inject ILogger<ListenTrackDataGrid> Logger

<div class="listen-track-grid">
    <MudDataGrid T="LibraryItemViewModel"
                 @ref="_grid"
                 Items="@Items"
                 ReadOnly="true"
                 Dense="true"
                 Hover="true"
                 Square="true"
                 Bordered="false"
                 Striped="false"
                 Filterable="true"
                 Hideable="true"
                 ShowColumnOptions="true"
                 DragDropColumnReordering="true"
                 Virtualize="true"
                 SortMode="SortMode.Multiple"
                 FilterMode="DataGridFilterMode.ColumnFilterMenu"
                 FixedHeader="true"
                 Height="@GridHeight"
                 RowsPerPage="@(Math.Max(Items.Count, 1))"
                 HorizontalScrollbar="true"
                 ColumnResizeMode="ResizeMode.Column"
                 Loading="@Loading"
                 RowClassFunc="GetRowClass"
                 RowClick="HandleRowClickAsync"
                 RowContextMenuClick="HandleRowContextMenuAsync">
        <Columns>
            <TemplateColumn
                            Title=""
                            HeaderStyle="@FixedColumnStyle(56)"
                            CellStyle="@FixedColumnStyle(56)"
                            Sortable="false"
                            Filterable="false"
                            Hideable="false"
                            ShowColumnOptions="false"
                            Resizable="false"
                            DragAndDropEnabled="false">
                <CellTemplate Context="cell">
                    <div class="listen-track-grid__play-cell"
                         draggable="true"
                         title="Play or drag this song"
                         @ondragstart="@(() => HandleDragStartAsync(cell.Item.EntityId))"
                         @ondragend="HandleDragEndAsync">
                        <button type="button"
                                class="listen-track-grid__icon-button"
                                @onclick:stopPropagation="true"
                                @onclick="@(() => ActivateRowAsync(cell.Item.EntityId))">
                            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Style="font-size: 18px;" />
                        </button>
                    </div>
                </CellTemplate>
            </TemplateColumn>

            <PropertyColumn
                            Property="item => item.Title"
                            Title="Title"
                            HeaderStyle="@TrackColumnStyle(320, 220)"
                            CellStyle="@TrackColumnStyle(320, 220)"
                            SortBy="item => item.SortTitle ?? item.Title"
                            Hidden="@IsHidden(TrackColumnKeys.Title)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Title, hidden))">
                <CellTemplate Context="cell">
                    <div class="listen-track-grid__title-cell"
                         draggable="true"
                         @ondragstart="@(() => HandleDragStartAsync(cell.Item.EntityId))"
                         @ondragend="HandleDragEndAsync">
                        <div class="listen-track-grid__art">
                            @if (!string.IsNullOrWhiteSpace(cell.Item.CoverThumbUrl ?? cell.Item.CoverUrl))
                            {
                                <img src="@(cell.Item.CoverThumbUrl ?? cell.Item.CoverUrl)" alt="" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Style="font-size: 16px;" />
                            }
                            <button type="button"
                                    class="listen-track-grid__art-play"
                                    title="Play song"
                                    aria-label="@($"Play {cell.Item.Title}")"
                                    @onclick:stopPropagation="true"
                                    @onclick="@(() => ActivateRowAsync(cell.Item.EntityId))">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Style="font-size: 16px;" />
                            </button>
                        </div>
                        <div class="listen-track-grid__title-text">@cell.Item.Title</div>
                    </div>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn
                            Property="item => item.Duration ?? string.Empty"
                            Title="Time"
                            HeaderStyle="@TrackColumnStyle(96, 76)"
                            CellStyle="@TrackColumnStyle(96, 76)"
                            SortBy="item => item.DurationSeconds ?? 0"
                            Hidden="@IsHidden(TrackColumnKeys.Time)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Time, hidden))">
                <CellTemplate Context="cell">
                    <span class="listen-track-grid__mono">@FormatDuration(cell.Item)</span>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn
                            Property="item => item.Artist ?? string.Empty"
                            Title="Artist"
                            HeaderStyle="@TrackColumnStyle(220, 160)"
                            CellStyle="@TrackColumnStyle(220, 160)"
                            SortBy="item => item.SortArtist ?? item.Artist ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.Artist)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Artist, hidden))">
                <CellTemplate Context="cell">
                    @if (OnArtistClicked.HasDelegate && !string.IsNullOrWhiteSpace(cell.Item.Artist))
                    {
                        <button type="button"
                                class="listen-track-grid__link"
                                @onclick:stopPropagation="true"
                                @onclick="@(() => OnArtistClicked.InvokeAsync(cell.Item.Artist!))">
                            @cell.Item.Artist
                        </button>
                    }
                    else
                    {
                        <span>@DisplayOrDash(cell.Item.Artist)</span>
                    }
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn
                            Property="item => item.Album ?? string.Empty"
                            Title="Album"
                            HeaderStyle="@TrackColumnStyle(220, 160)"
                            CellStyle="@TrackColumnStyle(220, 160)"
                            SortBy="item => item.SortAlbum ?? item.Album ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.Album)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Album, hidden))" />

            <PropertyColumn
                            Property="item => item.Genre ?? string.Empty"
                            Title="Genre"
                            HeaderStyle="@TrackColumnStyle(160, 120)"
                            CellStyle="@TrackColumnStyle(160, 120)"
                            SortBy="item => item.Genre ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.Genre)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Genre, hidden))" />

            <PropertyColumn
                            Property="item => item.IsFavorite"
                            Title="Favorite"
                            HeaderStyle="@TrackColumnStyle(96, 82)"
                            CellStyle="@TrackColumnStyle(96, 82)"
                            SortBy="item => item.IsFavorite"
                            Hidden="@IsHidden(TrackColumnKeys.Favorite)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Favorite, hidden))">
                <CellTemplate Context="cell">
                    <button type="button"
                            class="listen-track-grid__favorite @(cell.Item.IsFavorite ? "is-active" : null)"
                            aria-label="Toggle favorite"
                            title="Toggle favorite"
                            @onclick:stopPropagation="true"
                            @onclick="@(() => ToggleFavoriteAsync(cell.Item.EntityId))">
                        <MudIcon Icon="@(cell.Item.IsFavorite ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                 Style="font-size: 16px;" />
                    </button>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn
                            Property="item => item.PlayCount"
                            Title="Plays"
                            HeaderStyle="@TrackColumnStyle(92, 76)"
                            CellStyle="@TrackColumnStyle(92, 76)"
                            SortBy="item => item.PlayCount ?? 0"
                            Hidden="@IsHidden(TrackColumnKeys.Plays)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Plays, hidden))">
                <CellTemplate Context="cell">
                    <span class="listen-track-grid__mono">@DisplayNumber(cell.Item.PlayCount)</span>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn
                            Property="item => item.CreatedAt"
                            Title="Date Added"
                            HeaderStyle="@TrackColumnStyle(180, 150)"
                            CellStyle="@TrackColumnStyle(180, 150)"
                            SortBy="item => item.CreatedAt"
                            Hidden="@IsHidden(TrackColumnKeys.DateAdded)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.DateAdded, hidden))">
                <CellTemplate Context="cell">
                    <span class="listen-track-grid__muted">@FormatDateTime(cell.Item.CreatedAt)</span>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn
                            Property="item => item.AlbumArtist ?? string.Empty"
                            Title="Album Artist"
                            HeaderStyle="@TrackColumnStyle(220, 160)"
                            CellStyle="@TrackColumnStyle(220, 160)"
                            SortBy="item => item.AlbumArtist ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.AlbumArtist)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.AlbumArtist, hidden))" />

            <PropertyColumn
                            Property="item => item.Composer ?? string.Empty"
                            Title="Composer"
                            HeaderStyle="@TrackColumnStyle(220, 160)"
                            CellStyle="@TrackColumnStyle(220, 160)"
                            SortBy="item => item.Composer ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.Composer)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Composer, hidden))" />

            <PropertyColumn
                            Property="item => item.Comments ?? string.Empty"
                            Title="Comments"
                            HeaderStyle="@TrackColumnStyle(260, 180)"
                            CellStyle="@TrackColumnStyle(260, 180)"
                            SortBy="item => item.Comments ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.Comments)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Comments, hidden))" />

            <PropertyColumn
                            Property="item => item.DateModified"
                            Title="Date Modified"
                            HeaderStyle="@TrackColumnStyle(190, 160)"
                            CellStyle="@TrackColumnStyle(190, 160)"
                            SortBy="item => item.DateModified ?? DateTimeOffset.MinValue"
                            Hidden="@IsHidden(TrackColumnKeys.DateModified)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.DateModified, hidden))">
                <CellTemplate Context="cell">
                    <span class="listen-track-grid__muted">@FormatOptionalDateTime(cell.Item.DateModified)</span>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn
                            Property="item => item.DiscNumber ?? string.Empty"
                            Title="Disc Number"
                            HeaderStyle="@TrackColumnStyle(130, 110)"
                            CellStyle="@TrackColumnStyle(130, 110)"
                            SortBy="item => ParseInteger(item.DiscNumber)"
                            Hidden="@IsHidden(TrackColumnKeys.DiscNumber)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.DiscNumber, hidden))" />

            <PropertyColumn
                            Property="item => item.Kind ?? string.Empty"
                            Title="Kind"
                            HeaderStyle="@TrackColumnStyle(140, 120)"
                            CellStyle="@TrackColumnStyle(140, 120)"
                            SortBy="item => item.Kind ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.Kind)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Kind, hidden))" />

            <PropertyColumn
                            Property="item => item.LastPlayedAt"
                            Title="Last Played"
                            HeaderStyle="@TrackColumnStyle(190, 160)"
                            CellStyle="@TrackColumnStyle(190, 160)"
                            SortBy="item => item.LastPlayedAt ?? DateTimeOffset.MinValue"
                            Hidden="@IsHidden(TrackColumnKeys.LastPlayed)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.LastPlayed, hidden))">
                <CellTemplate Context="cell">
                    <span class="listen-track-grid__muted">@FormatOptionalDateTime(cell.Item.LastPlayedAt)</span>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn
                            Property="item => item.Rating ?? string.Empty"
                            Title="Rating"
                            HeaderStyle="@TrackColumnStyle(110, 90)"
                            CellStyle="@TrackColumnStyle(110, 90)"
                            SortBy="item => item.Rating ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.Rating)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Rating, hidden))" />

            <PropertyColumn
                            Property="item => item.ReleaseDate"
                            Title="Release Date"
                            HeaderStyle="@TrackColumnStyle(160, 140)"
                            CellStyle="@TrackColumnStyle(160, 140)"
                            SortBy="item => item.ReleaseDate ?? DateTimeOffset.MinValue"
                            Hidden="@IsHidden(TrackColumnKeys.ReleaseDate)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.ReleaseDate, hidden))">
                <CellTemplate Context="cell">
                    <span class="listen-track-grid__muted">@FormatOptionalDateTime(cell.Item.ReleaseDate)</span>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn
                            Property="item => item.FileSizeBytes"
                            Title="Size"
                            HeaderStyle="@TrackColumnStyle(120, 96)"
                            CellStyle="@TrackColumnStyle(120, 96)"
                            SortBy="item => item.FileSizeBytes ?? 0"
                            Hidden="@IsHidden(TrackColumnKeys.Size)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Size, hidden))">
                <CellTemplate Context="cell">
                    <span class="listen-track-grid__mono">@LibraryHelpers.FormatFileSize(cell.Item.FileSizeBytes)</span>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn
                            Property="item => item.SortAlbum ?? string.Empty"
                            Title="Sort Album"
                            HeaderStyle="@TrackColumnStyle(220, 160)"
                            CellStyle="@TrackColumnStyle(220, 160)"
                            SortBy="item => item.SortAlbum ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.SortAlbum)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.SortAlbum, hidden))" />

            <PropertyColumn
                            Property="item => item.SortArtist ?? string.Empty"
                            Title="Sort Artist"
                            HeaderStyle="@TrackColumnStyle(220, 160)"
                            CellStyle="@TrackColumnStyle(220, 160)"
                            SortBy="item => item.SortArtist ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.SortArtist)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.SortArtist, hidden))" />

            <PropertyColumn
                            Property="item => item.SortTitle ?? string.Empty"
                            Title="Sort Title"
                            HeaderStyle="@TrackColumnStyle(220, 180)"
                            CellStyle="@TrackColumnStyle(220, 180)"
                            SortBy="item => item.SortTitle ?? string.Empty"
                            Hidden="@IsHidden(TrackColumnKeys.SortTitle)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.SortTitle, hidden))" />

            <PropertyColumn
                            Property="item => item.TrackNumber ?? string.Empty"
                            Title="Track Number"
                            HeaderStyle="@TrackColumnStyle(132, 112)"
                            CellStyle="@TrackColumnStyle(132, 112)"
                            SortBy="item => ParseInteger(item.TrackNumber)"
                            Hidden="@IsHidden(TrackColumnKeys.TrackNumber)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.TrackNumber, hidden))" />

            <PropertyColumn
                            Property="item => item.Year ?? string.Empty"
                            Title="Year"
                            HeaderStyle="@TrackColumnStyle(100, 84)"
                            CellStyle="@TrackColumnStyle(100, 84)"
                            SortBy="item => ParseInteger(item.Year)"
                            Hidden="@IsHidden(TrackColumnKeys.Year)"
                            HiddenChanged="@((bool hidden) => SetColumnHiddenAsync(TrackColumnKeys.Year, hidden))" />

            <TemplateColumn
                            Title=""
                            HeaderStyle="@FixedColumnStyle(56)"
                            CellStyle="@FixedColumnStyle(56)"
                            Sortable="false"
                            Filterable="false"
                            Hideable="false"
                            ShowColumnOptions="false"
                            Resizable="false"
                            DragAndDropEnabled="false">
                <CellTemplate Context="cell">
                    <button type="button"
                            class="listen-track-grid__icon-button"
                            aria-label="Open track menu"
                            title="Track menu"
                            @onclick:stopPropagation="true"
                            @onclick="@(e => OpenContextMenuFromButtonAsync(cell.Item.EntityId, e))">
                        <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Style="font-size: 18px;" />
                    </button>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
</div>

@code
{
    private const string DefaultGridHeight = "min(68vh, 780px)";

    [Parameter] public IReadOnlyList<LibraryItemViewModel> Items { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public HashSet<Guid> SelectedIds { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedIdsChanged { get; set; }
    [Parameter] public EventCallback<Guid> OnRowActivated { get; set; }
    [Parameter] public EventCallback<LibraryRowContextMenuRequest> OnRowContextRequested { get; set; }
    [Parameter] public EventCallback<Guid> OnFavoriteToggled { get; set; }
    [Parameter] public EventCallback<string> OnArtistClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnRowDragStarted { get; set; }
    [Parameter] public EventCallback OnRowDragEnded { get; set; }
    [Parameter] public string ViewKey { get; set; } = "listen-tracks";
    [Parameter] public string GridHeight { get; set; } = DefaultGridHeight;

    private MudDataGrid<LibraryItemViewModel>? _grid;
    private readonly HashSet<string> _hiddenColumns = new(DefaultHiddenColumns(), StringComparer.OrdinalIgnoreCase);
    private int? _selectionAnchorIndex;
    private bool _columnsLoaded;

    private static HashSet<string> DefaultHiddenColumns() =>
    [
        TrackColumnKeys.AlbumArtist,
        TrackColumnKeys.Composer,
        TrackColumnKeys.Comments,
        TrackColumnKeys.DateModified,
        TrackColumnKeys.DiscNumber,
        TrackColumnKeys.Kind,
        TrackColumnKeys.LastPlayed,
        TrackColumnKeys.Rating,
        TrackColumnKeys.ReleaseDate,
        TrackColumnKeys.Size,
        TrackColumnKeys.SortAlbum,
        TrackColumnKeys.SortArtist,
        TrackColumnKeys.SortTitle,
        TrackColumnKeys.TrackNumber,
        TrackColumnKeys.Year,
    ];

    public Task OpenColumnsPanelAsync(MouseEventArgs args)
    {
        _grid?.ShowColumnsPanel(args);
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _columnsLoaded)
        {
            return;
        }

        _columnsLoaded = true;

        try
        {
            var json = await JS.InvokeAsync<string?>("listenUi.getTrackGridColumns", ViewKey);
            _hiddenColumns.Clear();
            foreach (var key in ListenGridColumnState.ResolveHiddenColumns(json, TrackColumnKeys.All, DefaultHiddenColumns()))
            {
                _hiddenColumns.Add(key);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not restore listen track grid columns for {ViewKey}.", ViewKey);
        }
    }

    private bool IsHidden(string key) => _hiddenColumns.Contains(key);

    private async Task SetColumnHiddenAsync(string key, bool hidden)
    {
        if (hidden)
        {
            _hiddenColumns.Add(key);
        }
        else
        {
            _hiddenColumns.Remove(key);
        }

        await PersistColumnsAsync();
    }

    private async Task PersistColumnsAsync()
    {
        try
        {
            var visibleColumns = TrackColumnKeys.All.Where(key => !_hiddenColumns.Contains(key)).ToList();
            var json = System.Text.Json.JsonSerializer.Serialize(visibleColumns);
            await JS.InvokeVoidAsync("listenUi.setTrackGridColumns", ViewKey, json);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not persist listen track grid columns for {ViewKey}.", ViewKey);
        }
    }

    private async Task HandleRowClickAsync(DataGridRowClickEventArgs<LibraryItemViewModel> args)
    {
        if (args.Item is null)
        {
            return;
        }

        await UpdateSelectionAsync(args.Item, args.MouseEventArgs);
    }

    private async Task HandleRowContextMenuAsync(DataGridRowClickEventArgs<LibraryItemViewModel> args)
    {
        if (args.Item is null || !OnRowContextRequested.HasDelegate)
        {
            return;
        }

        await OnRowContextRequested.InvokeAsync(new LibraryRowContextMenuRequest(
            args.Item.EntityId,
            args.MouseEventArgs.ClientX,
            args.MouseEventArgs.ClientY));
    }

    private async Task OpenContextMenuFromButtonAsync(Guid entityId, MouseEventArgs args)
    {
        if (!OnRowContextRequested.HasDelegate)
        {
            return;
        }

        await OnRowContextRequested.InvokeAsync(new LibraryRowContextMenuRequest(entityId, args.ClientX, args.ClientY));
    }

    private async Task UpdateSelectionAsync(LibraryItemViewModel item, MouseEventArgs args)
    {
        var orderedItems = CurrentVisibleItems;
        var clickedIndex = orderedItems.FindIndex(candidate => candidate.EntityId == item.EntityId);
        var nextSelection = SelectedIds.ToHashSet();

        if (args.ShiftKey && _selectionAnchorIndex.HasValue && clickedIndex >= 0)
        {
            if (!(args.CtrlKey || args.MetaKey))
            {
                nextSelection.Clear();
            }

            var start = Math.Min(_selectionAnchorIndex.Value, clickedIndex);
            var end = Math.Max(_selectionAnchorIndex.Value, clickedIndex);
            for (var index = start; index <= end && index < orderedItems.Count; index++)
            {
                nextSelection.Add(orderedItems[index].EntityId);
            }
        }
        else if (args.CtrlKey || args.MetaKey)
        {
            if (!nextSelection.Add(item.EntityId))
            {
                nextSelection.Remove(item.EntityId);
            }

            if (clickedIndex >= 0)
            {
                _selectionAnchorIndex = clickedIndex;
            }
        }
        else
        {
            nextSelection.Clear();
            nextSelection.Add(item.EntityId);
            if (clickedIndex >= 0)
            {
                _selectionAnchorIndex = clickedIndex;
            }
        }

        await SelectedIdsChanged.InvokeAsync(nextSelection);
    }

    private async Task ActivateRowAsync(Guid entityId)
    {
        if (OnRowActivated.HasDelegate)
        {
            await OnRowActivated.InvokeAsync(entityId);
        }
    }

    private async Task ToggleFavoriteAsync(Guid entityId)
    {
        if (OnFavoriteToggled.HasDelegate)
        {
            await OnFavoriteToggled.InvokeAsync(entityId);
        }
    }

    private async Task HandleDragStartAsync(Guid entityId)
    {
        if (OnRowDragStarted.HasDelegate)
        {
            await OnRowDragStarted.InvokeAsync(entityId);
        }
    }

    private async Task HandleDragEndAsync()
    {
        if (OnRowDragEnded.HasDelegate)
        {
            await OnRowDragEnded.InvokeAsync();
        }
    }

    private string GetRowClass(LibraryItemViewModel item, int rowIndex)
        => SelectedIds.Contains(item.EntityId)
            ? "listen-track-grid__row listen-track-grid__row--selected"
            : "listen-track-grid__row";

    private List<LibraryItemViewModel> CurrentVisibleItems
        => _grid?.FilteredItems?.ToList() ?? Items.ToList();

    private static int ParseInteger(string? value)
        => int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed) ? parsed : 0;

    private static string FormatDuration(LibraryItemViewModel item)
        => LibraryHelpers.FormatDuration(item.DurationSeconds, item.Duration ?? "0:00");

    private static string FormatDateTime(DateTimeOffset value)
        => value == default
            ? "-"
            : value.LocalDateTime.ToString("M/d/yyyy, h:mm tt", CultureInfo.CurrentCulture);

    private static string FormatOptionalDateTime(DateTimeOffset? value)
        => value.HasValue ? FormatDateTime(value.Value) : "-";

    private static string DisplayOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string DisplayNumber(int? value)
        => value is > 0 ? value.Value.ToString(CultureInfo.CurrentCulture) : "-";

    private static string TrackColumnStyle(int widthPixels, int minWidthPixels)
        => $"width:{widthPixels}px; min-width:{minWidthPixels}px;";

    private static string FixedColumnStyle(int widthPixels)
        => $"width:{widthPixels}px; min-width:{widthPixels}px; max-width:{widthPixels}px;";

    private static class TrackColumnKeys
    {
        public const string Title = "title";
        public const string Time = "time";
        public const string Artist = "artist";
        public const string Album = "album";
        public const string Genre = "genre";
        public const string Favorite = "favorite";
        public const string Plays = "plays";
        public const string DateAdded = "date_added";
        public const string AlbumArtist = "album_artist";
        public const string Composer = "composer";
        public const string Comments = "comments";
        public const string DateModified = "date_modified";
        public const string DiscNumber = "disc_number";
        public const string Kind = "kind";
        public const string LastPlayed = "last_played";
        public const string Rating = "rating";
        public const string ReleaseDate = "release_date";
        public const string Size = "size";
        public const string SortAlbum = "sort_album";
        public const string SortArtist = "sort_artist";
        public const string SortTitle = "sort_title";
        public const string TrackNumber = "track_number";
        public const string Year = "year";

        public static readonly string[] All =
        [
            Title,
            Time,
            Artist,
            Album,
            Genre,
            Favorite,
            Plays,
            DateAdded,
            AlbumArtist,
            Composer,
            Comments,
            DateModified,
            DiscNumber,
            Kind,
            LastPlayed,
            Rating,
            ReleaseDate,
            Size,
            SortAlbum,
            SortArtist,
            SortTitle,
            TrackNumber,
            Year,
        ];
    }
}
