    [JSInvokable]
    public async Task HandlePlaybackCommand(string json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return;
        }

        var command = JsonSerializer.Deserialize<PopupCommand>(json, _jsonOptions);
        if (command is null)
        {
            return;
        }

        switch (command.Action)
        {
            case "toggle-play":
                await TogglePlayPauseAsync();
                break;
            case "pause":
                await PauseAudioAsync();
                break;
            case "play-next":
                await PlayNextAsync();
                break;
            case "play-previous":
                await PlayPreviousAsync();
                break;
            case "play-next-chapter":
                await Playback.PlayNextChapterAsync();
                break;
            case "play-previous-chapter":
                await Playback.PlayPreviousChapterAsync();
                break;
            case "skip-back":
                await SkipBackAsync();
                break;
            case "skip-forward":
                await SkipForwardAsync();
                break;
            case "play-chapter" when command.ChapterIndex.HasValue:
                await Playback.PlayAudiobookChapterAsync(command.ChapterIndex.Value);
                break;
            case "toggle-panel":
                Playback.TogglePanel();
                break;
            case "show-queue":
                Playback.SetActiveTab(ListenPlaybackTabs.Queue);
                Playback.TogglePanel();
                break;
            case "clear-upcoming":
                Playback.ClearUpcoming();
                break;
            case "remove-upcoming" when command.Index.HasValue:
                Playback.RemoveUpcomingAt(command.Index.Value);
                break;
            case "play-index" when command.Index.HasValue:
                await Playback.PlayIndexAsync(command.Index.Value);
                break;
            case "play-history" when command.Item is not null:
                await Playback.PlayQueueItemAsync(command.Item, command.Item.Album ?? command.Item.Title);
                break;
            case "play-audiobook-history" when command.AudiobookHistoryItem is not null:
                await Playback.PlayAudiobookHistoryAsync(command.AudiobookHistoryItem);
                break;
            case "play-audiobook-bookmark" when command.AudiobookBookmark is not null:
                await Playback.PlayAudiobookBookmarkAsync(command.AudiobookBookmark);
                break;
            case "add-audiobook-bookmark":
                await Playback.AddAudiobookBookmarkAsync();
                break;
            case "delete-audiobook-bookmark" when command.BookmarkId.HasValue:
                await Playback.DeleteAudiobookBookmarkAsync(command.BookmarkId.Value);
                break;
            case "set-tab" when !string.IsNullOrWhiteSpace(command.Tab):
                Playback.SetActiveTab(command.Tab);
                break;
            case "seek" when command.Value.HasValue:
                await SeekOnHostAsync(command.Value.Value);
                break;
            case "set-volume" when command.Value.HasValue:
                Playback.UpdateTransportState(volume: command.Value.Value, isMuted: command.Value.Value <= 0);
                await Playback.ReportHeartbeatAsync(force: true);
                break;
            case "set-speed" when command.Value.HasValue:
                await ApplyPlaybackRateAsync(command.Value.Value);
                break;
            case "set-sleep-timer" when string.Equals(command.TimerMode, ListenSleepTimerModes.EndOfChapter, StringComparison.Ordinal):
                await Playback.SetSleepTimerEndOfChapterAsync();
                break;
            case "set-sleep-timer" when command.TimerMinutes.HasValue:
                await Playback.SetSleepTimerAsync(TimeSpan.FromMinutes(command.TimerMinutes.Value));
                break;
            case "cancel-sleep-timer":
                await Playback.CancelSleepTimerAsync();
                break;
            case "toggle-mute":
                Playback.UpdateTransportState(isMuted: !Playback.IsMuted);
                await Playback.ReportHeartbeatAsync(force: true);
                break;
            case "close-player":
                await ClosePlayerAsync();
                break;
            case "popup-closed":
                Playback.SetPopupOpen(false);
                break;
        }
    }

    private async Task HandleTransportCommandAsync(PlaybackTransportCommand command)
    {
        switch (command.Action)
        {
            case "toggle-play":
                await TogglePlayPauseAsync();
                break;
            case "pause":
                await PauseAudioAsync();
                break;
            case "play-next":
                await PlayNextAsync();
                break;
            case "play-previous":
                await PlayPreviousAsync();
                break;
            case "play-next-chapter":
                await Playback.PlayNextChapterAsync();
                break;
            case "play-previous-chapter":
                await Playback.PlayPreviousChapterAsync();
                break;
            case "skip-back":
                await SkipBackAsync();
                break;
            case "skip-forward":
                await SkipForwardAsync();
                break;
            case "seek" when command.Value.HasValue:
                await SeekOnHostAsync(command.Value.Value);
                break;
            case "start":
                await StartAudioAsync(command);
                break;
            case "set-volume" when command.Value.HasValue:
                Playback.UpdateTransportState(volume: command.Value.Value, isMuted: command.Value.Value <= 0);
                await Playback.ReportHeartbeatAsync(force: true);
                break;
            case "set-speed" when command.Value.HasValue:
                await ApplyPlaybackRateAsync(command.Value.Value);
                break;
            case "toggle-mute":
                Playback.UpdateTransportState(isMuted: !Playback.IsMuted);
                await Playback.ReportHeartbeatAsync(force: true);
                break;
            case "toggle-panel":
                Playback.TogglePanel();
                break;
            case "close-player":
                await ClosePlayerAsync();
                break;
        }
    }

