    private RenderFragment SleepTimerRow(string label, int? minutes, string? mode) => @<AppNativeButton Type="button" Class="@($"listen-player-panel__tool-row listen-player-panel__tool-row--timer {(IsTimerActive(minutes, mode) ? "is-active" : null)}")" OnClick="@(() => SetAudiobookSleepTimerAsync(minutes, mode))" AriaLabel="@($"Set sleep timer to {label}")" title="@($"Set sleep timer to {label}")">
        <span class="listen-player-panel__tool-copy">
            <strong>@label</strong>
        </span>
        @if (IsTimerActive(minutes, mode))
        {
            <span class="listen-player-panel__resume">Active</span>
        }
    </AppNativeButton>;

    private async Task SetAudiobookSleepTimerAsync(int? minutes, string? mode)
    {
        if (string.Equals(mode, ListenSleepTimerModes.EndOfChapter, StringComparison.Ordinal))
        {
            await Playback.SetSleepTimerEndOfChapterAsync();
            Playback.ClosePanel();
            return;
        }

        if (minutes.HasValue)
        {
            await Playback.SetSleepTimerAsync(TimeSpan.FromMinutes(minutes.Value));
        }
        else
        {
            await Playback.CancelSleepTimerAsync();
        }

        Playback.ClosePanel();
    }

    private bool IsTimerActive(int? minutes, string? mode)
    {
        if (string.Equals(mode, ListenSleepTimerModes.EndOfChapter, StringComparison.Ordinal))
        {
            return Playback.SleepTimerMode == ListenSleepTimerModes.EndOfChapter;
        }

        if (!minutes.HasValue)
        {
            return Playback.SleepTimerMode == ListenSleepTimerModes.Off;
        }

        return Playback.SleepTimerMode == ListenSleepTimerModes.Timer
            && Playback.SleepTimerEndsAtUtc.HasValue
            && Math.Abs((Playback.SleepTimerEndsAtUtc.Value - DateTimeOffset.UtcNow).TotalMinutes - minutes.Value) < 1.2d;
    }

    private bool IsCurrentChapter(PlaybackChapterDto chapter) =>
        Playback.CurrentTimeSeconds >= chapter.StartSeconds - 0.5d
        && (!chapter.EndSeconds.HasValue || Playback.CurrentTimeSeconds < chapter.EndSeconds.Value - 0.5d);

