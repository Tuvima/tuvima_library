@namespace MediaEngine.Web.Components.Listen
@using System.Globalization
@using System.Text.Json
@using System.Text.RegularExpressions
@using Microsoft.JSInterop
@using MediaEngine.Contracts.Playback
@using MediaEngine.Web.Components.Shared
@using MediaEngine.Web.Services.Playback
@using MediaEngine.Web.Services.Integration
@inject PlaybackSessionController Playback
@inject IEngineApiClient ApiClient
@inject IJSRuntime JS
@inject ILogger<ListenNowPlayingBar> Logger
@inject NavigationManager Nav
@implements IAsyncDisposable

<audio @ref="_audioRef"
       id="listen-audio-engine"
       class="listen-player__audio-native"
       src="@Playback.CurrentBrowserStreamUrl"
       @onloadedmetadata="HandleAudioMetricsChangedAsync"
       @ondurationchange="HandleAudioMetricsChangedAsync"
       @onplay="HandleAudioStarted"
       @onpause="HandleAudioPaused"
       @onerror="HandleAudioErrorAsync"
       @onended="HandleAudioEndedAsync">
</audio>

@if (Playback.HasQueue && Playback.CurrentItem is not null)
{
    <div class="@PlayerShellClass" @ref="_playerShellRef" tabindex="0">
        @if (Playback.IsPanelOpen)
        {
            <div class="listen-player-panel-backdrop" @onclick="Playback.ClosePanel"></div>
            <aside class="listen-player-panel">
                @if (Playback.IsAudiobookMode)
                {
                    <div class="listen-player-panel__sheet-header">
                        <PlaybackSheetHandleButton Class="listen-player-panel__handle" Label="Close audiobook tools" OnClick="CloseBottomPanelAsync" />
                        <div class="listen-player-panel__sheet-title">Audiobook tools</div>
                    </div>
                }
                else
                {
                    <div class="listen-player-panel__header">
                        <div class="listen-player-panel__summary">
                            <div class="listen-player-panel__thumb">
                                @if (!string.IsNullOrWhiteSpace(Playback.CurrentItem.CoverUrl))
                                {
                                    <img src="@Playback.CurrentItem.CoverUrl" alt="@Playback.CurrentItem.Title" />
                                }
                                else
                                {
                                    <MudIcon Icon="@FallbackIconFor(Playback.CurrentItem)" Class="tl-u-font-size-18px" />
                                }
                            </div>
                            <div class="listen-player-panel__copy">
                                <div class="listen-player-panel__title">@Playback.CurrentItem.Title</div>
                                <div class="listen-player-panel__subtitle">@PlayerSubtitleFor(Playback.CurrentItem, Playback.SourceLabel)</div>
                            </div>
                        </div>
                        <div class="listen-player-panel__actions">
                            <AppNativeButton Type="button" Class="listen-player-panel__close" OnClick="Playback.ClosePanel">
                                <MudIcon Icon="@Icons.Material.Outlined.Close" Class="tl-u-font-size-18px" />
                            </AppNativeButton>
                        </div>
                    </div>
                }

                @if (Playback.IsAudiobookMode)
                {
                    <div class="listen-player-panel__audiobook-tools">
                        <PlaybackControlStrip Controls="@AudiobookPanelControls"
                                              Size="compact"
                                              Class="listen-player-panel__audiobook-actions"
                                              AriaLabel="Audiobook tools"
                                              OnControl="HandleAudiobookPanelControl" />
                    </div>

                    @switch (_activeAudiobookPanelTool)
                    {
                        case "speed":
                            <div class="listen-player-panel__tool-list">
                                @foreach (var rate in SpeedRates)
                                {
                                    <AppNativeButton Type="button" Class="@($"listen-player-panel__tool-row listen-player-panel__tool-row--speed {(Math.Abs(rate - Playback.PlaybackRate) < 0.01d ? "is-active" : null)}")" OnClick="@(() => SetAudiobookSpeedAsync(rate))" AriaLabel="@($"Set speed to {FormatSpeed(rate)}")" title="@($"Set speed to {FormatSpeed(rate)}")">
                                        <span class="listen-player-panel__radio"></span>
                                        <strong>@FormatSpeed(rate)</strong>
                                    </AppNativeButton>
                                }
                            </div>
                            break;
                        case "chapters":
                            <div class="listen-player-panel__tool-list">
                                @if (CurrentChapters.Count == 0)
                                {
                                    <div class="listen-player-panel__empty">No timed chapters were found for this audiobook.</div>
                                }
                                else
                                {
                                    @foreach (var chapter in CurrentChapters)
                                    {
                                        var isActive = IsCurrentChapter(chapter);
                                        <AppNativeButton Type="button" Class="@($"listen-player-panel__tool-row listen-player-panel__tool-row--chapter {(isActive ? "is-active" : null)}")" OnClick="@(() => PlayAudiobookChapterFromPanelAsync(chapter.Index))" AriaLabel="@($"Play {chapter.Title}")" title="@($"Play {chapter.Title}")">
                                            <span class="listen-player-panel__tool-copy">
                                                <strong>@chapter.Title</strong>
                                            </span>
                                            <span class="listen-player-panel__tool-duration">@ChapterDuration(chapter)</span>
                                        </AppNativeButton>
                                    }
                                }
                            </div>
                            break;
                        case "history":
                            <div class="listen-player-panel__tool-list">
                                @if (Playback.AudiobookHistory.Count == 0)
                                {
                                    <div class="listen-player-panel__empty">Recent listening positions will appear here.</div>
                                }
                                else
                                {
                                    @for (var index = 0; index < Playback.AudiobookHistory.Count; index++)
                                    {
                                        var item = Playback.AudiobookHistory[index];
                                        <AppNativeButton Type="button" Class="listen-player-panel__tool-row listen-player-panel__tool-row--history" OnClick="@(() => PlayAudiobookHistoryFromPanelAsync(item))" AriaLabel="@($"Resume from {HistoryTitle(item)}")" title="@($"Resume from {HistoryTitle(item)}")">
                                            <span class="listen-player-panel__history-index">@($"{index + 1}")</span>
                                            <span class="listen-player-panel__tool-copy">
                                                <strong>@HistoryTitle(item)</strong>
                                                <span>@HistorySubtitle(item)</span>
                                            </span>
                                            <span class="listen-player-panel__resume">Resume</span>
                                        </AppNativeButton>
                                    }
                                }
                            </div>
                            break;
                        case "bookmarks":
                            <div class="listen-player-panel__sheet-toolbar">
                                <AppNativeButton Type="button" Class="listen-player-panel__tool-primary" OnClick="AddAudiobookBookmarkFromPanelAsync" AriaLabel="Add bookmark at current position" title="Add bookmark at current position">
                                    <MudIcon Icon="@Icons.Material.Outlined.BookmarkAdd" Class="tl-u-font-size-20px" />
                                    <span>Add bookmark at @FormatTimestamp(Playback.CurrentTimeSeconds)</span>
                                </AppNativeButton>
                            </div>
                            <div class="listen-player-panel__tool-list">
                                @if (Playback.AudiobookBookmarks.Count == 0)
                                {
                                    <div class="listen-player-panel__empty">No bookmarks yet.</div>
                                }
                                else
                                {
                                    @foreach (var bookmark in Playback.AudiobookBookmarks)
                                    {
                                        <div class="listen-player-panel__bookmark-row">
                                            <AppNativeButton Type="button" Class="listen-player-panel__tool-row listen-player-panel__tool-row--bookmark" OnClick="@(() => PlayAudiobookBookmarkFromPanelAsync(bookmark))" AriaLabel="@($"Resume bookmark {BookmarkTitle(bookmark)}")" title="@($"Resume bookmark {BookmarkTitle(bookmark)}")">
                                                <span class="listen-player-panel__tool-copy">
                                                    <strong>@BookmarkTitle(bookmark)</strong>
                                                    <span>@bookmark.CreatedAt.LocalDateTime.ToString("g", CultureInfo.CurrentCulture)</span>
                                                </span>
                                                <span class="listen-player-panel__resume">Resume</span>
                                            </AppNativeButton>
                                            <AppNativeButton Type="button" Class="listen-player-panel__item-remove" OnClick="@(() => DeleteAudiobookBookmarkFromPanelAsync(bookmark.Id))" AriaLabel="Delete bookmark" title="Delete bookmark">
                                                <MudIcon Icon="@Icons.Material.Outlined.Delete" Class="tl-u-font-size-18px" />
                                            </AppNativeButton>
                                        </div>
                                    }
                                }
                            </div>
                            break;
                        case "sleep":
                            <div class="listen-player-panel__tool-list">
                                @SleepTimerRow("Off", null, null)
                                @foreach (var minutes in Playback.SleepTimerOptionsMinutes)
                                {
                                    @SleepTimerRow($"{minutes} min", minutes, null)
                                }
                                @if (Playback.AllowEndOfChapterSleepTimer)
                                {
                                    @SleepTimerRow("End of chapter", null, ListenSleepTimerModes.EndOfChapter)
                                }
                                <div class="listen-player-panel__empty listen-player-panel__empty--compact">Current timer: @Playback.SleepTimerLabel</div>
                            </div>
                            break;
                    }
                }
                else
                {
                <div class="listen-player-panel__tabs" role="tablist" aria-label="Queue panel">
                    <AppNativeButton Type="button" Class='@($"listen-player-panel__tab {(Playback.ActiveTab == ListenPlaybackTabs.Queue ? " is-active" : null)}")' OnClick="@(() => Playback.SetActiveTab(ListenPlaybackTabs.Queue))">
                        Playing Next
                    </AppNativeButton>
                    <AppNativeButton Type="button" Class='@($"listen-player-panel__tab {(Playback.ActiveTab == ListenPlaybackTabs.History ? " is-active" : null)}")' OnClick="@(() => Playback.SetActiveTab(ListenPlaybackTabs.History))">
                        History
                    </AppNativeButton>
                    <AppNativeButton Type="button" Class='@($"listen-player-panel__tab {(Playback.ActiveTab == ListenPlaybackTabs.Lyrics ? " is-active" : null)}")' OnClick="@(() => Playback.SetActiveTab(ListenPlaybackTabs.Lyrics))">
                        Lyrics
                    </AppNativeButton>
                </div>

                @if (Playback.ActiveTab == ListenPlaybackTabs.Queue)
                {
                    <div class="listen-player-panel__subheader">
                        <span>Playing Next</span>
                        <AppNativeButton Type="button" Class="listen-player-panel__text-action" OnClick="ClearUpcoming">
                            Clear
                        </AppNativeButton>
                    </div>

                    @if (Playback.UpcomingQueue.Count == 0)
                    {
                        <div class="listen-player-panel__empty">The queue ends with the current track.</div>
                    }
                    else
                    {
                        <div class="listen-player-panel__list">
                            @for (var index = Playback.CurrentIndex + 1; index < Playback.Queue.Count; index++)
                            {
                                var item = Playback.Queue[index];
                                <div class="listen-player-panel__item">
                                    <AppNativeButton Type="button" Class="listen-player-panel__item-main" OnClick="@(() => PlayFromQueueAsync(index))">
                                        <div class="listen-player-panel__item-thumb">
                                            @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                                            {
                                                <img src="@item.CoverUrl" alt="@item.Title" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@FallbackIconFor(item)" Class="tl-u-font-size-16px" />
                                            }
                                        </div>
                                        <div class="listen-player-panel__item-copy">
                                            <div class="listen-player-panel__item-title">@item.Title</div>
                                            <div class="listen-player-panel__item-subtitle">@FirstNonBlank(item.Subtitle, item.Album, item.MediaType)</div>
                                        </div>
                                        <div class="listen-player-panel__item-duration">@item.Duration</div>
                                    </AppNativeButton>
                                    <AppNativeButton Type="button" Class="listen-player-panel__item-remove" AriaLabel="Remove from queue" OnClick="@(() => RemoveUpcoming(index))">
                                        <MudIcon Icon="@Icons.Material.Outlined.Close" Class="tl-u-font-size-16px" />
                                    </AppNativeButton>
                                </div>
                            }
                        </div>
                    }
                }
                else if (Playback.ActiveTab == ListenPlaybackTabs.History)
                {
                    <div class="listen-player-panel__subheader">
                        <span>History</span>
                    </div>

                    @if (Playback.History.Count == 0)
                    {
                        <div class="listen-player-panel__empty">Played tracks will appear here for this session.</div>
                    }
                    else
                    {
                        <div class="listen-player-panel__list">
                            @foreach (var item in Playback.History)
                            {
                                <AppNativeButton Type="button" Class="listen-player-panel__item-main" OnClick="@(() => PlayHistoryItemAsync(item))">
                                    <div class="listen-player-panel__item-thumb">
                                        @if (!string.IsNullOrWhiteSpace(item.CoverUrl))
                                        {
                                            <img src="@item.CoverUrl" alt="@item.Title" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@FallbackIconFor(item)" Class="tl-u-font-size-16px" />
                                        }
                                    </div>
                                    <div class="listen-player-panel__item-copy">
                                        <div class="listen-player-panel__item-title">@item.Title</div>
                                        <div class="listen-player-panel__item-subtitle">@FirstNonBlank(item.Subtitle, item.Album, FormatHistoryStamp(item.PlayedAt))</div>
                                    </div>
                                    <div class="listen-player-panel__item-duration">@item.Duration</div>
                                </AppNativeButton>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="listen-player-panel__subheader">
                        <span>Lyrics</span>
                    </div>

                    @if (_lyricsLoading)
                    {
                        <div class="listen-player-panel__empty">Loading lyrics...</div>
                    }
                    else if (_lyricsLines.Count == 0)
                    {
                        <div class="listen-player-panel__empty">No synced lyrics available for this track.</div>
                    }
                    else
                    {
                        <div class="listen-player-panel__lyrics">
                            @foreach (var line in _lyricsLines)
                            {
                                <div class="listen-player-panel__lyric-line @(line == ActiveLyricLine ? "is-active" : null)">
                                    @line.Text
                                </div>
                            }
                        </div>
                    }
                }
                }
            </aside>
        }

        <PlaybackMiniPlayer Experience="@CurrentMiniPlayerExperience" Class="listen-player" AriaLabel="Now playing mini player">
            <div class="listen-player__meta">
                <div class="listen-player__thumb">
                    @if (!string.IsNullOrWhiteSpace(Playback.CurrentItem.CoverUrl))
                    {
                        <img src="@Playback.CurrentItem.CoverUrl" alt="@Playback.CurrentItem.Title" />
                    }
                    else
                    {
                        <MudIcon Icon="@FallbackIconFor(Playback.CurrentItem)" Class="tl-u-font-size-18px" />
                    }
                </div>

                <div class="listen-player__copy">
                    <div class="listen-player__title">@Playback.CurrentItem.Title</div>
                    <div class="listen-player__subtitle">@PlayerSubtitleFor(Playback.CurrentItem, Playback.SourceLabel)</div>
                    @if (!string.IsNullOrWhiteSpace(Playback.CurrentError))
                    {
                        <div class="listen-player__error">@Playback.CurrentError</div>
                    }
                </div>
            </div>

            <div class="listen-player__transport">
                <ListenTransportControls Variant="bar"
                                         IsAudiobookMode="@Playback.IsAudiobookMode"
                                         IsPlaying="@Playback.IsPlaying"
                                         NeedsUserGestureToStart="@Playback.NeedsUserGestureToStart"
                                         IsMuted="@Playback.IsMuted"
                                         HasChapters="@(Playback.CurrentItem?.Chapters.Count is > 0)"
                                         CanPreviousTrack="@(Playback.CurrentIndex > 0)"
                                         CanNextTrack="@(Playback.CurrentIndex < Playback.Queue.Count - 1)"
                                         SkipBackSeconds="@Playback.SkipBackSeconds"
                                         SkipForwardSeconds="@Playback.SkipForwardSeconds"
                                         CurrentBrowserStreamUrl="@Playback.CurrentBrowserStreamUrl"
                                         CurrentTimeSeconds="@Playback.CurrentTimeSeconds"
                                         PlaybackRate="@Playback.PlaybackRate"
                                         Volume="@Playback.Volume"
                                         OnTogglePlay="TogglePlayPauseAsync"
                                         OnPreviousTrack="PlayPreviousAsync"
                                         OnNextTrack="PlayNextAsync"
                                         OnPreviousChapter="PlayPreviousChapterAsync"
                                         OnNextChapter="PlayNextChapterAsync"
                                         OnSkipBack="SkipBackAsync"
                                         OnSkipForward="SkipForwardAsync" />

                <div class="listen-player__progress">
                    <span>@FormatTimestamp(Playback.CurrentTimeSeconds)</span>
                    <AppNativeInput Type="range" Min="0" Max="@ProgressMax" Step="1" Value="@Math.Min(Playback.CurrentTimeSeconds, ProgressMax)" Class="listen-player__progress-slider" OnChange="SeekAsync" AriaLabel="Playback position" aria-valuetext="@ProgressValueText" />
                    <span>@FormatTimestamp(Math.Max(0, Playback.DurationSeconds - Playback.CurrentTimeSeconds))</span>
                </div>
            </div>

            <div class="listen-player__actions">
                <AppNativeButton Type="button" Class="listen-player__icon" OnClick="ToggleMuteAsync" AriaLabel="Mute or unmute" title="Mute or unmute">
                    <AppMaterialIcon Icon="@(Playback.IsMuted || Playback.Volume <= 0 ? Icons.Material.Outlined.VolumeOff : Icons.Material.Outlined.VolumeUp)" Css="font-size: 18px;"  />
                </AppNativeButton>
                <AppNativeInput Type="range" Min="0" Max="1" Step="@VolumeStep" Value="@Playback.Volume" Class="listen-player__volume-slider" OnChange="SetVolumeAsync" AriaLabel="Volume" aria-valuetext="@VolumeValueText" />
                @if (Playback.IsAudiobookMode)
                {
                    <PlaybackValueToolButton Class="listen-player__tool-pill"
                                             Icon="@Icons.Material.Outlined.Speed"
                                             Label="Speed"
                                             ValueText="@FormatSpeed(Playback.PlaybackRate)"
                                             OnClick="@(() => OpenAudiobookPanelAsync("speed"))"
                                             AriaLabel="Open audiobook speed and tools" />
                }
                else
                {
                    <AppNativeButton Type="button" Class="listen-player__icon" OnClick="ToggleMusicPanelAsync" AriaLabel="Open queue panel" title="Open queue panel">
                        <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Class="tl-u-font-size-18px" />
                    </AppNativeButton>
                }
                <AppNativeButton Type="button" Class="listen-player__icon" OnClick="TogglePopupAsync" AriaLabel="Pop out player" title="Pop out player" data-listen-popup-route="@(Playback.IsPopupOpen ? null : PopupRoute)">
                    <MudIcon Icon="@(Playback.IsPopupOpen ? Icons.Material.Outlined.OpenInNewOff : Icons.Material.Outlined.OpenInNew)" Class="tl-u-font-size-18px" />
                </AppNativeButton>
                <AppNativeButton Type="button" Class="listen-player__icon" OnClick="ClosePlayerAsync" AriaLabel="Close player" title="Close player">
                    <MudIcon Icon="@Icons.Material.Outlined.Close" Class="tl-u-font-size-18px" />
                </AppNativeButton>
            </div>
        </PlaybackMiniPlayer>
    </div>
}

@code {
    private const string PopupRoute = "/listen/player-popup";

    private readonly JsonSerializerOptions _jsonOptions = new(JsonSerializerDefaults.Web);
    private static readonly IReadOnlyList<double> SpeedRates = Enumerable.Range(5, 26).Select(value => value / 10d).ToList();
    private ElementReference _audioRef;
    private ElementReference _playerShellRef;
    private DotNetObjectReference<ListenNowPlayingBar>? _selfReference;
    private bool _restored;
    private string? _lastAppliedStreamUrl;
    private string? _lastSeekedStreamUrl;
    private double? _lastSeekedPositionSeconds;
    private long _lastAppliedStartVersion = -1;
    private bool? _lastAppliedPlayingState;
    private double? _lastAppliedVolume;
    private bool? _lastAppliedMuteState;
    private double? _lastAppliedPlaybackRate;
    private Guid? _lyricsAssetId;
    private bool _lyricsLoading;
    private bool _shortcutsRegistered;
    private string _activeAudiobookPanelTool = "speed";
    private List<LrcDisplayLine> _lyricsLines = [];

    private string PlayerShellClass
    {
        get
        {
            var classes = IsListenRoute
                ? "listen-player-shell listen-player-shell--listen-route"
                : "listen-player-shell";

            if (Playback.IsPopupOpen)
            {
                classes = $"{classes} listen-player-shell--popped-out";
            }

            return Playback.IsAudiobookMode
                ? $"{classes} listen-player-shell--audiobook"
                : classes;
        }
    }

    private bool IsListenRoute => Nav.ToAbsoluteUri(Nav.Uri).AbsolutePath.StartsWith("/listen", StringComparison.OrdinalIgnoreCase);

    private double ProgressMax => Playback.DurationSeconds > 0 ? Playback.DurationSeconds : 1;
    private string VolumeStep => Playback.ClientSettings.VolumeStep.ToString("0.###", CultureInfo.InvariantCulture);
    private string ProgressValueText => $"{FormatTimestamp(Playback.CurrentTimeSeconds)} of {FormatTimestamp(ProgressMax)}";
    private string VolumeValueText => $"{Math.Clamp((int)Math.Round(Playback.Volume * 100d), 0, 100)}%";
    private PlaybackExperience CurrentMiniPlayerExperience => Playback.IsAudiobookMode ? PlaybackExperience.Audiobook : PlaybackExperience.Music;
    private IReadOnlyList<PlaybackChapterDto> CurrentChapters =>
        Playback.CurrentItem is { Chapters.Count: > 1 } item ? item.Chapters : [];
    private IReadOnlyList<PlaybackControlDefinition> AudiobookPanelControls =>
        PlaybackControlCatalog.BuildToolStrip(
            PlaybackExperience.Audiobook,
            PlaybackControlSurface.Bottom,
            new PlaybackControlState(
                ActiveSheet: _activeAudiobookPanelTool,
                PlaybackRate: Playback.PlaybackRate,
                HasChapters: CurrentChapters.Count > 0,
                IsSleepTimerActive: Playback.SleepTimerMode != ListenSleepTimerModes.Off,
                HistoryCount: Playback.AudiobookHistory.Count,
                BookmarkCount: Playback.AudiobookBookmarks.Count));

    private LrcDisplayLine? ActiveLyricLine => _lyricsLines.LastOrDefault(line => line.StartSeconds <= Playback.CurrentTimeSeconds + 0.25);

    protected override void OnInitialized()
    {
        Playback.SetTransportHostNotReady();
        Playback.Changed += HandlePlaybackChanged;
        Playback.TransportCommandRequested += HandleTransportCommandAsync;
        Nav.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs args) =>
        _ = InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfReference = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("listenPlayback.configure", Playback.ClientSettings);
            await ConfigurePlaybackClientContextAsync();
            await JS.InvokeVoidAsync("listenPlayback.registerCommandHandler", _selfReference);
            await JS.InvokeVoidAsync(
                "listenPlayback.registerAudioStateObserver",
                _audioRef,
                _selfReference,
                Playback.ClientSettings.AudioObserverIntervalMilliseconds);

            try
            {
                var json = await JS.InvokeAsync<string?>("listenPlayback.getState");
                if (!string.IsNullOrWhiteSpace(json))
                {
                    var snapshot = JsonSerializer.Deserialize<ListenPlaybackSnapshot>(json, _jsonOptions);
                    if (snapshot is not null)
                    {
                        Playback.RestoreState(snapshot);
                    }
                }
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Could not restore listen playback state from browser storage.");
            }

            _restored = true;
            await Playback.SetTransportHostReadyAsync();
        }

        if (Playback.HasQueue && !_shortcutsRegistered && _selfReference is not null)
        {
            await JS.InvokeVoidAsync("listenPlayback.registerPlayerShortcuts", _playerShellRef, _selfReference);
            _shortcutsRegistered = true;
        }

        if (Playback.CurrentItem is not null && !string.IsNullOrWhiteSpace(Playback.CurrentBrowserStreamUrl))
        {
            await SyncAudioAsync();
        }
    }

    private async Task ConfigurePlaybackClientContextAsync()
    {
        try
        {
            var deviceId = await JS.InvokeAsync<string>("listenPlayback.getOrCreateDeviceId");
            Playback.SetClientContext(PlaybackClientContext.WebDefault with
            {
                DeviceId = deviceId,
            });
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not load playback device identity from browser storage.");
        }
    }

    private void HandlePlaybackChanged(PlaybackChangeKind changeKind)
    {
        _ = InvokeAsync(async () =>
        {
            if (_restored)
            {
                try
                {
                    if (Playback.HasQueue)
                    {
                        await JS.InvokeVoidAsync("listenPlayback.setState", JsonSerializer.Serialize(Playback.CreateSnapshot(), _jsonOptions));
                    }
                    else
                    {
                        await JS.InvokeVoidAsync("listenPlayback.clearState");
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogDebug(ex, "Could not persist listen playback state to browser storage.");
                }
            }

            StateHasChanged();
            _ = EnsureLyricsLoadedAsync();
        });
    }

    private async Task EnsureLyricsLoadedAsync()
    {
        var assetId = Playback.CurrentItem?.AssetId;
        if (!assetId.HasValue || _lyricsAssetId == assetId)
            return;

        _lyricsAssetId = assetId;
        _lyricsLines = [];
        _lyricsLoading = true;
        await InvokeAsync(StateHasChanged);

        var lyrics = await ApiClient.GetLyricsAsync(assetId.Value);
        _lyricsLines = ParseLyrics(lyrics).ToList();
        _lyricsLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SyncAudioAsync()
    {
        var browserStreamUrl = Playback.CurrentBrowserStreamUrl;
        var targetPositionSeconds = Playback.CurrentTimeSeconds;
        var targetPlaybackRate = Playback.PlaybackRate;
        var startVersionChanged = _lastAppliedStartVersion != Playback.PlaybackStartVersion;
        if (startVersionChanged)
        {
            _lastAppliedStartVersion = Playback.PlaybackStartVersion;
            _lastSeekedStreamUrl = null;
            _lastSeekedPositionSeconds = null;
            _lastAppliedPlayingState = null;
        }

        if (!string.Equals(_lastAppliedStreamUrl, browserStreamUrl, StringComparison.Ordinal))
        {
            _lastAppliedStreamUrl = browserStreamUrl;
            _lastSeekedStreamUrl = null;
            _lastSeekedPositionSeconds = null;
            _lastAppliedPlayingState = null;
            await JS.InvokeVoidAsync("listenPlayback.ensureAudioSource", _audioRef, browserStreamUrl);
        }

        if (_lastAppliedVolume != Playback.Volume)
        {
            await JS.InvokeVoidAsync("listenPlayback.setVolume", _audioRef, Playback.Volume);
            _lastAppliedVolume = Playback.Volume;
        }

        if (_lastAppliedMuteState != Playback.IsMuted)
        {
            await JS.InvokeVoidAsync("listenPlayback.setMuted", _audioRef, Playback.IsMuted);
            _lastAppliedMuteState = Playback.IsMuted;
        }

        if (!_lastAppliedPlaybackRate.HasValue || Math.Abs(_lastAppliedPlaybackRate.Value - targetPlaybackRate) >= 0.01d)
        {
            await JS.InvokeVoidAsync("listenPlayback.setPlaybackRate", _audioRef, targetPlaybackRate);
            _lastAppliedPlaybackRate = targetPlaybackRate;
        }

        var shouldSeek = targetPositionSeconds > 0
            && (!string.Equals(_lastSeekedStreamUrl, browserStreamUrl, StringComparison.Ordinal)
                || startVersionChanged);
        if (shouldSeek)
        {
            await JS.InvokeVoidAsync("listenPlayback.seekAudio", _audioRef, targetPositionSeconds);
            _lastSeekedStreamUrl = browserStreamUrl;
            _lastSeekedPositionSeconds = targetPositionSeconds;
        }

        if (_lastAppliedPlayingState != Playback.IsPlaying)
        {
            if (Playback.IsPlaying)
            {
                var started = await JS.InvokeAsync<bool>("listenPlayback.playAudio", _audioRef);
                if (!started)
                {
                    Playback.MarkNeedsUserGestureToStart();
                }
            }
            else
            {
                await JS.InvokeVoidAsync("listenPlayback.pauseAudio", _audioRef);
            }

            _lastAppliedPlayingState = Playback.IsPlaying;
        }
    }

    private async Task HandleAudioMetricsChangedAsync()
    {
        var state = await JS.InvokeAsync<AudioMetrics>("listenPlayback.readAudioState", _audioRef);
        await ApplyAudioMetricsAsync(state);
    }

    [JSInvokable]
    public Task HandleObservedAudioState(AudioMetrics state) => ApplyAudioMetricsAsync(state);

    [JSInvokable]
    public async Task HandlePlayerShortcut(string action)
    {
        switch (action)
        {
            case "toggle-play":
                await TogglePlayPauseAsync();
                break;
            case "skip-back":
                await SkipBackAsync();
                break;
            case "skip-forward":
                await SkipForwardAsync();
                break;
            case "volume-up":
                await SetVolumeOnHostAsync(Playback.Volume + Playback.ClientSettings.VolumeStep);
                break;
            case "volume-down":
                await SetVolumeOnHostAsync(Playback.Volume - Playback.ClientSettings.VolumeStep);
                break;
        }
    }

    private async Task ApplyAudioMetricsAsync(AudioMetrics state)
    {
        Playback.UpdateTransportState(
            currentTimeSeconds: state.CurrentTime,
            durationSeconds: state.Duration,
            isPlaying: !state.Paused,
            volume: state.Volume,
            isMuted: state.Muted,
            playbackRate: state.PlaybackRate);
        await Playback.ReportHeartbeatAsync();
    }

    private async Task HandleAudioStarted()
    {
        Playback.MarkPlaybackStarted();
        await Playback.ReportHeartbeatAsync(force: true);
    }

    private async Task HandleAudioPaused()
    {
        Playback.UpdateTransportState(isPlaying: false);
        await Playback.ReportHeartbeatAsync(force: true);
    }

    private async Task HandleAudioEndedAsync()
    {
        await Playback.CompleteCurrentAsync();
    }

    private Task HandleAudioErrorAsync()
    {
        Playback.MarkCurrentFailed("This audio source failed to load or play.");
        return Task.CompletedTask;
    }

    private async Task TogglePlayPauseAsync()
    {
        if (await ConsumeImmediateToggleAsync())
        {
            return;
        }

        if (Playback.IsPlaying && !Playback.NeedsUserGestureToStart)
        {
            await PauseAudioAsync();
            return;
        }

        if (!string.IsNullOrWhiteSpace(Playback.CurrentBrowserStreamUrl))
        {
            await StartAudioAsync(new PlaybackTransportCommand(
                "start",
                Value: Playback.CurrentTimeSeconds,
                StreamUrl: Playback.CurrentBrowserStreamUrl,
                PositionSeconds: Playback.CurrentTimeSeconds,
                PlaybackRate: Playback.PlaybackRate,
                RequestId: Playback.PlaybackStartVersion));
            return;
        }

        var started = await JS.InvokeAsync<bool>("listenPlayback.playAudio", _audioRef);
        if (started)
        {
            Playback.MarkPlaybackStarted();
        }
        else
        {
            Playback.MarkNeedsUserGestureToStart();
        }
    }

    private async Task StartAudioAsync(PlaybackTransportCommand command)
    {
        var streamUrl = FirstNonBlank(command.StreamUrl, Playback.CurrentBrowserStreamUrl);
        var positionSeconds = Math.Max(0, command.PositionSeconds ?? command.Value ?? Playback.CurrentTimeSeconds);
        var playbackRate = command.PlaybackRate ?? Playback.PlaybackRate;
        var started = await JS.InvokeAsync<bool>(
            "listenPlayback.startAudio",
            _audioRef,
            new
            {
                streamUrl,
                positionSeconds,
                playbackRate,
                volume = Playback.Volume,
                muted = Playback.IsMuted,
            });

        if (!string.IsNullOrWhiteSpace(streamUrl))
        {
            _lastAppliedStreamUrl = streamUrl;
            _lastSeekedStreamUrl = streamUrl;
        }

        _lastSeekedPositionSeconds = positionSeconds;
        _lastAppliedPlaybackRate = playbackRate;
        _lastAppliedVolume = Playback.Volume;
        _lastAppliedMuteState = Playback.IsMuted;
        _lastAppliedPlayingState = started;

        if (started)
        {
            Playback.UpdateTransportState(
                currentTimeSeconds: positionSeconds,
                isPlaying: true,
                playbackRate: playbackRate,
                needsUserGestureToStart: false);
            Playback.MarkPlaybackStarted();
            await Playback.ReportHeartbeatAsync(force: true);
        }
        else
        {
            Playback.MarkNeedsUserGestureToStart();
        }
    }

    private async Task PauseAudioAsync()
    {
        await JS.InvokeVoidAsync("listenPlayback.pauseAudio", _audioRef);
        Playback.UpdateTransportState(isPlaying: false);
        await Playback.ReportHeartbeatAsync(force: true);
    }

    private async Task ApplyPlaybackRateAsync(double rate)
    {
        var next = Math.Clamp(rate, 0.5d, 3d);
        await JS.InvokeVoidAsync("listenPlayback.setPlaybackRate", _audioRef, next);
        Playback.UpdateTransportState(playbackRate: next);
        await Playback.ReportHeartbeatAsync(force: true);
    }

