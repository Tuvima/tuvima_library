@namespace MediaEngine.Web.Components.Bento

@* A single tile in the BentoGrid.
   GlowColor drives the accent box-shadow; ColSpan/RowSpan control grid placement. *@

<div class="bento-item @Class" style="@_computedStyle">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public int             ColSpan      { get; set; } = 1;
    [Parameter] public int             RowSpan      { get; set; } = 1;
    [Parameter] public string          GlowColor    { get; set; } = "#EAB308";
    [Parameter] public string?         Class        { get; set; }
    [Parameter] public string?         Style        { get; set; }

    private string _computedStyle =>
        $"grid-column: span {ColSpan}; " +
        $"grid-row:    span {RowSpan}; " +
        $"--bento-glow:       {HexToRgba(GlowColor, 0.12)}; " +
        $"--bento-glow-hover: {HexToRgba(GlowColor, 0.28)}; " +
        $"--bento-border:     {HexToRgba(GlowColor, 0.20)}; " +
        (Style ?? string.Empty);

    private static string HexToRgba(string hex, double alpha)
    {
        try
        {
            hex = hex.TrimStart('#');
            if (hex.Length == 3)
                hex = $"{hex[0]}{hex[0]}{hex[1]}{hex[1]}{hex[2]}{hex[2]}";
            if (hex.Length != 6)
                return $"rgba(234,179,8,{alpha:F2})";

            var r = Convert.ToInt32(hex[..2], 16);
            var g = Convert.ToInt32(hex[2..4], 16);
            var b = Convert.ToInt32(hex[4..6], 16);
            return $"rgba({r},{g},{b},{alpha:F2})";
        }
        catch
        {
            return $"rgba(234,179,8,{alpha:F2})"; // fallback: golden amber
        }
    }
}

<style>
    .bento-item {
        position:               relative;
        min-height:             160px;
        border-radius:          8px;
        overflow:               hidden;

        background:             var(--app-glass-inner-bg);
        border:                 1px solid var(--app-glass-inner-border);
        backdrop-filter:        blur(12px);
        -webkit-backdrop-filter: blur(12px);

        box-shadow:
            0 2px 12px  rgba(0, 0, 0, 0.20),
            0 0  0 1px  rgba(255, 255, 255, 0.03) inset,
            0 4px 20px  var(--bento-glow, rgba(234,179,8,0.12));

        transition:
            box-shadow   0.25s ease,
            border-color 0.25s ease,
            transform    0.20s ease;
    }

    .bento-item:hover {
        transform:    scale(1.02) translateY(-2px);
        border-color: var(--bento-border, rgba(234,179,8,0.20));
        box-shadow:
            0 6px 28px  rgba(0, 0, 0, 0.30),
            0 0  0 1px  rgba(255, 255, 255, 0.05) inset,
            0 10px 36px var(--bento-glow-hover, rgba(234,179,8,0.28));
    }
</style>
