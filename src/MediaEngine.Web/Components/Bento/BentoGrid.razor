@namespace MediaEngine.Web.Components.Bento

@* Asymmetric Bento-grid container (Section 2.2 of the UI ASD).
   Renders child BentoItems inside a CSS grid with variable column/row spans.
   Supports a dynamic Columns parameter driven by device context. *@

<div class="bento-grid @Class" style="@ComputedStyle">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string?         Class        { get; set; }
    [Parameter] public string?         Style        { get; set; }
    [Parameter] public int Columns { get; set; }
    [Parameter] public string TileStyle { get; set; } = "normal";

    private string ComputedStyle
    {
        get
        {
            if (Columns > 0)
            {
                var gridCols = $"grid-template-columns: repeat({Columns}, 1fr);";
                return string.IsNullOrWhiteSpace(Style) ? gridCols : $"{Style} {gridCols}";
            }

            return Style ?? string.Empty;
        }
    }
}