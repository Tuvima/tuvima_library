@namespace MediaEngine.Web.Components.MediaHub
@using MediaEngine.Web.Models.ViewDTOs

@if (Shelf.Items.Count == 0)
{
    <EmptyShelfState Title="@Shelf.Title" Message="@Shelf.Subtitle" />
}
else
{
    <section class="@RootClass" data-media-hub-shelf="@Shelf.Key">
        <ShelfHeader Title="@Shelf.Title"
                     Subtitle="@Shelf.Subtitle"
                     Count="@Shelf.Items.Count"
                     Route="@Shelf.SeeAllRoute" />

        <MediaTileShelf Shelf="@Shelf.ToMediaTileShelf()"
                        HoverMode="@HoverMode"
                        HideSourceBadges="@HideSourceBadges"
                        ShowHeader="false"
                        OnPrimaryClicked="@OnPrimaryClicked"
                        UseContinueWatchingOrListeningTiles="@UseContinueWatchingOrListeningTiles" />
    </section>
}

@code {
    [Parameter, EditorRequired] public MediaHubShelfViewModel Shelf { get; set; } = default!;
    [Parameter, EditorRequired] public MediaHubSectionType SectionType { get; set; }
    [Parameter] public bool HideSourceBadges { get; set; }
    [Parameter] public EventCallback<MediaTileViewModel> OnPrimaryClicked { get; set; }

    private string RootClass => $"media-hub-shelf media-hub-shelf--{SectionType.ToString().ToLowerInvariant()} {(Shelf.IsContinueShelf ? "media-hub-shelf--continue" : null)}";

    private MediaTileHoverMode HoverMode => MediaTileHoverMode.Expanded;

    private bool UseContinueWatchingOrListeningTiles =>
        Shelf.IsContinueShelf
        && SectionType is MediaHubSectionType.Watch or MediaHubSectionType.Listen;
}
