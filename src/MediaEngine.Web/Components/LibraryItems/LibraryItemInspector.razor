@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.LibraryItems
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject IEngineApiClient ApiClient
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<LibraryItemInspector> Logger

@if (Item is null)
{
    <div class="inspector-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="tl-u-font-size-32px tl-u-color-rgba-140-120-180-0-18 tl-u-margin-bottom-10px" />
        <span class="inspector-empty-text">Select an item to inspect</span>
    </div>
}
else
{

    <div class="inspector-panel">

        <!-- Close button + Tabs (always at the very top) -->
        <div class="inspector-topbar">
            <div class="inspector-tabs">
                @if (IsPersonOrUniverse)
                {
                    <AppNativeButton Class='@($"inspector-tab {(_inspectorTab == "details" ? "inspector-tab--active" : "")}")' OnClick='() => _inspectorTab = "details"'>Details</AppNativeButton>
                    <AppNativeButton Class='@($"inspector-tab {(_inspectorTab == "history" ? "inspector-tab--active" : "")}")' OnClick='() => _inspectorTab = "history"'>History</AppNativeButton>
                    <AppNativeButton Class='@($"inspector-tab {(_inspectorTab == "metadata" ? "inspector-tab--active" : "")}")' OnClick='() => _inspectorTab = "metadata"'>Metadata</AppNativeButton>
                }
                else if (IsInReview)
                {
                    <AppNativeButton Class='@($"inspector-tab {(_inspectorTab == "resolve" ? "inspector-tab--active" : "")}")' OnClick='() => _inspectorTab = "resolve"'>Resolve</AppNativeButton>
                    <AppNativeButton Class='@($"inspector-tab {(_inspectorTab == "history" ? "inspector-tab--active" : "")}")' OnClick='() => _inspectorTab = "history"'>History</AppNativeButton>
                    <AppNativeButton Class='@($"inspector-tab {(_inspectorTab == "metadata" ? "inspector-tab--active" : "")}")' OnClick='() => _inspectorTab = "metadata"'>Metadata</AppNativeButton>
                }
                else
                {
                    <AppNativeButton Class='@($"inspector-tab {(_inspectorTab == "details" ? "inspector-tab--active" : "")}")' OnClick='() => _inspectorTab = "details"'>Details</AppNativeButton>
                    <AppNativeButton Class='@($"inspector-tab {(_inspectorTab == "resolve" ? "inspector-tab--active" : "")}")' OnClick='() => _inspectorTab = "resolve"'>Resolve</AppNativeButton>
                    <AppNativeButton Class='@($"inspector-tab {(_inspectorTab == "history" ? "inspector-tab--active" : "")}")' OnClick='() => _inspectorTab = "history"'>History</AppNativeButton>
                    <AppNativeButton Class='@($"inspector-tab {(_inspectorTab == "metadata" ? "inspector-tab--active" : "")}")' OnClick='() => _inspectorTab = "metadata"'>Metadata</AppNativeButton>
                }
            </div>
            <AppNativeButton Class="inspector-close" OnClick="OnClose" Type="button" Title="Close inspector">
                <MudIcon Icon="@Icons.Material.Outlined.Close" Class="tl-u-font-size-16px" />
            </AppNativeButton>
        </div>

        <!-- Tab content -->
        @if (_inspectorTab == "details")
        {
            <!-- Compact header for Details tab -->
            <div class="inspector-tab-header">
                <div class="inspector-tab-header-title">@Item.Title</div>
                <div class="inspector-tab-header-sub">@Item.Author &middot; @LibraryItemHelpers.FormatMediaType(Item.MediaType)</div>
            </div>
            <InspectorDetailsSection Item="Item" Detail="_detail" Loading="_detailLoading" />
        }
        else if (_inspectorTab == "resolve")
        {
            <!-- File context (flat, no container) -->
            <div class="inspector-file-context">
                <div class="inspector-file-meta">
                    <span class="inspector-title">@Item.Title</span>
                    <span class="inspector-meta-line">@BuildMetaLine()</span>
                </div>

                <!-- Trigger chip -->
                @if (!string.IsNullOrEmpty(Item.ReviewTrigger))
                {
                    <div class="inspector-chips-row">
                        @{
                            var (trigLabel, trigColor, trigIcon) = LibraryItemHelpers.FormatReviewTrigger(Item.ReviewTrigger);
                        }
                        <AppCssElement Tag="div" Class="inspector-trigger-chip" Css="@($"background: {HexToRgba(trigColor, 0.12)}; color: {trigColor};")">
                            <MudIcon Icon="@trigIcon" Class="tl-u-font-size-11px" />
                            <span>@trigLabel</span>
                        </AppCssElement>
                    </div>
                }
            </div>

            <!-- Resolve tab content wrapper (relative anchor for provisional overlay) -->
            <div class="inspector-resolve-content">
                @if (_showProvisionalForm)
                {
                    <div class="inspector-provisional-overlay">
                        <ProvisionalFormPanel Item="Item"
                                              OnSaved="HandleProvisionalSaved"
                                              OnCancelled="HandleProvisionalCancelled" />
                    </div>
                }

                @if (Item.Status == "Rejected")
                {
                    <div class="inspector-rejected-banner">
                        <div class="inspector-rejected-info">
                            <MudIcon Icon="@Icons.Material.Outlined.Block" Class="tl-u-font-size-16px tl-u-color-tl-status-danger" />
                            <div class="inspector-rejected-text">
                                <span class="inspector-rejected-label">This item has been rejected</span>
                                <span class="inspector-rejected-sub">It will be purged after the retention period.</span>
                            </div>
                        </div>
                        <AppNativeButton Class="inspector-unreject-btn" OnClick="HandleUnreject">
                            <MudIcon Icon="@Icons.Material.Outlined.Restore" Class="tl-u-font-size-16px" />
                            <span>Recover Item</span>
                        </AppNativeButton>
                    </div>
                }

                <!-- Wikidata search + candidates + actions -->
                <InspectorSearchSection Item="Item"
                                        Detail="_detail"
                                        SelectedCoverUrl="@_selectedCoverUrl"
                                        OnIdentified="HandleIdentified"
                                        OnMarkedProvisional="HandleShowProvisionalForm"
                                        OnRejected="HandleRejected"
                                        OnCandidateSelected="HandleCandidateSelected" />

                <!-- Report section (always shown in resolve tab when present) -->
                @if (_reports.Count > 0)
                {
                    <InspectorReportSection Reports="_reports" Loading="_reportsLoading"
                                             OnResolve="HandleResolveReport"
                                             OnDismiss="HandleDismissReport" />
                }
            </div>
        }
        else if (_inspectorTab == "history")
        {
            <!-- Compact header for History tab -->
            <div class="inspector-tab-header">
                <div class="inspector-tab-header-title">@Item.Title</div>
                <div class="inspector-tab-header-sub">@Item.Author &middot; @LibraryItemHelpers.FormatMediaType(Item.MediaType)</div>
            </div>
            <InspectorHistorySection History="_history" Loading="_historyLoading" />
        }
        else if (_inspectorTab == "metadata")
        {
            <!-- Compact header for Metadata tab -->
            <div class="inspector-tab-header">
                <div class="inspector-tab-header-title">@Item.Title</div>
                <div class="inspector-tab-header-sub">@Item.Author &middot; @LibraryItemHelpers.FormatMediaType(Item.MediaType)</div>
            </div>
            <InspectorMetadataSection Fields="_fields" Loading="_fieldsLoading" />
        }

    </div>
}

@code {
    [Parameter] public LibraryCatalogItemViewModel? Item { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnItemChanged { get; set; }

    private List<LibraryItemHistoryDto>  _history       = [];
    private List<CanonicalFieldViewModel> _fields        = [];
    private List<ReportEntryDto>          _reports       = [];
    private bool                          _historyLoading;
    private bool                          _fieldsLoading;
    private bool                          _reportsLoading;
    private Guid?                         _loadedEntityId;
    private string                        _inspectorTab  = "resolve";
    private bool                          _showProvisionalForm;
    private string?                       _selectedCandidateTitle;
    private string?                       _selectedCandidateAuthor;
    private string?                       _selectedCandidateQid;
    private string?                       _selectedCoverUrl;
    private LibraryItemDetailViewModel?  _detail;
    private bool                          _detailLoading;

    protected override async Task OnParametersSetAsync()
    {
        if (Item is null || Item.EntityId == _loadedEntityId)
            return;

        _loadedEntityId = Item.EntityId;
        var isPerson = Item.MediaType is "Person" or "Universe";
        var inReview = Item.Status == "InReview" || !string.IsNullOrEmpty(Item.ReviewTrigger);
        _inspectorTab   = isPerson ? "details" : inReview ? "resolve" : "details";
        _showProvisionalForm = false;
        _selectedCandidateTitle = null;
        _selectedCandidateAuthor = null;
        _selectedCandidateQid = null;
        _selectedCoverUrl = null;
        _historyLoading = true;
        _fieldsLoading  = true;
        _reportsLoading = true;
        _detailLoading  = true;
        StateHasChanged();

        var historyTask = ApiClient.GetItemHistoryAsync(Item.EntityId);
        var fieldsTask  = Orchestrator.GetCanonicalValuesAsync(Item.EntityId);
        var reportsTask = Orchestrator.GetReportsForEntityAsync(Item.EntityId);
        var detailTask  = ApiClient.GetLibraryItemDetailAsync(Item.EntityId);

        try { _history = await historyTask; }
        catch (Exception ex) { Logger.LogDebug(ex, "Inspector history load failed for {EntityId}", Item.EntityId); _history = []; }
        _historyLoading = false;

        try { _fields = await fieldsTask; }
        catch (Exception ex) { Logger.LogDebug(ex, "Inspector canonical field load failed for {EntityId}", Item.EntityId); _fields = []; }
        _fieldsLoading = false;

        try { _reports = await reportsTask; }
        catch (Exception ex) { Logger.LogDebug(ex, "Inspector report load failed for {EntityId}", Item.EntityId); _reports = []; }
        _reportsLoading = false;

        try { _detail = await detailTask; }
        catch (Exception ex) { Logger.LogDebug(ex, "Inspector detail load failed for {EntityId}", Item.EntityId); _detail = null; }
        _detailLoading = false;
    }

    private bool IsPersonOrUniverse => Item?.MediaType is "Person" or "Universe";
    private bool IsInReview => Item?.Status == "InReview" || !string.IsNullOrEmpty(Item?.ReviewTrigger);
    private bool IsConfirmed => Item?.Status == "Confirmed";

    private string ComputeState()
    {
        if (Item is null) return "NoMatch";
        if (Item.Status == "Confirmed") return "Confirmed";
        if (!string.IsNullOrEmpty(Item.ReviewTrigger)) return "NeedsReview";
        if (!string.IsNullOrEmpty(Item.WikidataQid)
            && !Item.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase))
            return "Identified";
        if (Item.MissingUniverse) return "NoMatch";
        return "NoMatch";
    }

    private async Task HandleIdentified()
    {
        if (Item is not null)
        {
            _detailLoading = true;
            StateHasChanged();

            try { _detail = await ApiClient.GetLibraryItemDetailAsync(Item.EntityId); }
            catch (Exception ex) { Logger.LogDebug(ex, "Inspector detail refresh failed for {EntityId}", Item.EntityId); _detail = null; }
            _detailLoading = false;
            var freshStatus = _detail?.Status ?? "";
            var stillInReview = freshStatus is "InReview" or "Review";
            _inspectorTab = stillInReview ? "resolve" : "details";
            _loadedEntityId = Item.EntityId; // prevent OnParametersSetAsync re-run
        }
        await OnItemChanged.InvokeAsync();
    }

    private void HandleShowProvisionalForm()
    {
        _showProvisionalForm = true;
    }

    private async Task HandleProvisionalSaved()
    {
        _showProvisionalForm = false;
        await OnItemChanged.InvokeAsync();
    }

    private void HandleProvisionalCancelled()
    {
        _showProvisionalForm = false;
    }

    private async Task HandleRejected()
    {
        if (Item is null) return;
        try
        {
            var result = await ApiClient.RejectLibraryCatalogItemAsync(Item.EntityId);
            if (result is not null)
            {
                Snackbar.Add("Item rejected.", Severity.Success);
                await OnItemChanged.InvokeAsync();
            }
            else
            {
                Snackbar.Add("Could not reject item.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleUnreject()
    {
        if (Item is null) return;
        try
        {
            var ok = await ApiClient.RecoverLibraryCatalogItemAsync(Item.EntityId);
            if (ok)
            {
                Snackbar.Add("Item recovered and returned to review.", Severity.Success);
                await OnItemChanged.InvokeAsync();
            }
            else
            {
                Snackbar.Add("Could not recover item.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void HandleCandidateSelected((string? title, string? author, string? qid) candidate)
    {
        _selectedCandidateTitle = candidate.title;
        _selectedCandidateAuthor = candidate.author;
        _selectedCandidateQid = candidate.qid;
    }

    private void HandleCoverSelected(string? coverUrl)
    {
        _selectedCoverUrl = coverUrl;
    }

    private async Task HandleResolveReport(long activityId)
    {
        await ApiClient.ResolveReportAsync(activityId);
        _reports.RemoveAll(r => r.Id == activityId);
        StateHasChanged();
        await OnItemChanged.InvokeAsync();
    }

    private async Task HandleDismissReport(long activityId)
    {
        await ApiClient.DismissReportAsync(activityId);
        _reports.RemoveAll(r => r.Id == activityId);
        StateHasChanged();
        await OnItemChanged.InvokeAsync();
    }

    private static string HexToRgba(string hex, double alpha)
    {
        hex = hex.TrimStart('#');
        if (hex.Length < 6) return $"rgba(255,255,255,{alpha})";
        var r = Convert.ToInt32(hex[..2], 16);
        var g = Convert.ToInt32(hex[2..4], 16);
        var b = Convert.ToInt32(hex[4..6], 16);
        return $"rgba({r},{g},{b},{alpha})";
    }

    private string BuildMetaLine()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(Item?.Author)) parts.Add(Item.Author);
        if (!string.IsNullOrWhiteSpace(Item?.MediaType)) parts.Add(LibraryItemHelpers.FormatMediaType(Item.MediaType));
        if (!string.IsNullOrWhiteSpace(Item?.Year)) parts.Add(Item.Year);
        parts.Add("From file");
        return string.Join("  -  ", parts);
    }
}
