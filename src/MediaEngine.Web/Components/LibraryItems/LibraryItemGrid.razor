@using MediaEngine.Web.Models.ViewDTOs

@if (Items.Count == 0 && !Loading)
{
    <div class="rg-empty">
        <MudIcon Icon="@Icons.Material.Outlined.Inbox" Class="tl-u-font-size-3rem tl-u-opacity-0-2 tl-u-margin-bottom-12px" />
        <p class="tl-u-color-tl-text-muted tl-u-font-size-0-85rem">No items match your filters.</p>
    </div>
}
else
{
    <AppCssElement Tag="div" Class="rg-container" Css="@($"--rc-card-width: {CardSize}px;")">
        @foreach (var group in _groups)
        {
            var isExpanded = IsExpanded(group.Key);
            <div class="rg-section" @key="group.Key">
                <AppCssElement Tag="div" Class='@($"rg-section-header {(group.IsReviewGroup ? "rg-section-header--review" : "")}")'
                     Css="@(group.HeaderColor is not null ? $"--rg-header-accent: {group.HeaderColor};" : "")"
                     @onclick="@(() => ToggleSection(group.Key))">
                    <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                             Size="Size.Small" Class="tl-u-font-size-1rem tl-u-opacity-0-4" />
                    @if (!string.IsNullOrEmpty(group.HeaderIcon))
                    {
                        <AppMaterialIcon Icon="@group.HeaderIcon" Size="Size.Small" Css="@($"font-size: 0.9rem; color: {group.HeaderColor ?? "var(--tl-text-secondary)"}; opacity: 0.6;")"  />
                    }
                    <span class="rg-section-label">@group.Label</span>
                    <span class="rg-section-count">@group.Items.Count</span>

                    @if (group.IsReviewGroup && group.Items.Count > 0)
                    {
                        <div class="rg-section-actions" @onclick:stopPropagation="true">
                            <AppButton Variant="Variant.Text" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Block"
                                       OnClick="@(() => OnRejectGroup.InvokeAsync(group.Items.Select(i => i.EntityId).ToList()))"
                                       Class="tl-u-font-size-0-68rem tl-u-color-tl-status-danger tl-u-padding-2px-6px tl-u-min-width-0 tl-u-height-22px">
                                Reject All
                            </AppButton>
                        </div>
                    }
                </AppCssElement>

                @if (isExpanded)
                {
                    <div class="rg-grid">
                        @foreach (var item in group.Items)
                        {
                            <LibraryItemCard Item="@item"
                                          @key="item.EntityId"
                                          IsSelected="@SelectedIds.Contains(item.EntityId)"
                                          IsFocused="@(FocusedEntityId == item.EntityId)"
                                          SelectionModeActive="@SelectionModeActive"
                                          OnSelectionToggled="OnSelectionToggled"
                                          OnCardClicked="OnCardClicked"
                                          OnApproveClicked="OnApproveClicked"
                                          OnRejectClicked="OnRejectClicked"
                                          OnNavigate="OnNavigate" />
                        }
                    </div>
                }
            </div>
        }

        @if (HasMore)
        {
            <div class="rg-load-more">
                <AppButton Variant="Variant.Text" Size="Size.Small"
                           OnClick="OnLoadMore" FullWidth="true"
                           Class="tl-u-color-tl-text-muted tl-u-font-size-0-75rem">
                    Load more...
                </AppButton>
            </div>
        }

        @if (Loading)
        {
            <div class="rg-loading">
                <MudProgressCircular Indeterminate="true" Size="Size.Small"
                                     Class="tl-u-color-tl-text-faint" />
            </div>
        }
    </AppCssElement>
}

@code {
    [Parameter] public List<LibraryCatalogItemViewModel> Items { get; set; } = [];
    [Parameter] public HashSet<Guid> SelectedIds { get; set; } = [];
    [Parameter] public Guid? FocusedEntityId { get; set; }
    [Parameter] public bool NeedsReviewFilter { get; set; }
    [Parameter] public string GroupBy { get; set; } = "date";
    [Parameter] public int CardSize { get; set; } = 80;
    [Parameter] public bool SelectionModeActive { get; set; }
    [Parameter] public bool HasMore { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<Guid> OnSelectionToggled { get; set; }
    [Parameter] public EventCallback<Guid> OnCardClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnApproveClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnRejectClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnNavigate { get; set; }
    [Parameter] public EventCallback OnLoadMore { get; set; }
    [Parameter] public EventCallback<List<Guid>> OnApproveGroup { get; set; }
    [Parameter] public EventCallback<List<Guid>> OnRejectGroup { get; set; }

    private readonly Dictionary<string, bool> _expandedSections = new();
    private List<SectionGroup> _groups = [];

    private record SectionGroup(
        string Key,
        string Label,
        List<LibraryCatalogItemViewModel> Items,
        bool IsReviewGroup = false,
        string? HeaderIcon = null,
        string? HeaderColor = null);

    private bool IsExpanded(string key)
    {
        if (_expandedSections.TryGetValue(key, out var expanded))
            return expanded;
        if (NeedsReviewFilter)
            return true;

        return _groups.Count > 0 && _groups[0].Key == key;
    }

    private void ToggleSection(string key)
    {
        var current = IsExpanded(key);
        _expandedSections[key] = !current;
    }

    protected override void OnParametersSet()
    {
        _groups = BuildGroups();
    }

    private List<SectionGroup> BuildGroups()
    {
        if (NeedsReviewFilter)
            return GetReviewGroups();

        return GroupBy switch
        {
            "media_type" => GetMediaTypeGroups(),
            "confidence" => GetConfidenceGroups(),
            "status"     => GetStatusGroups(),
            _            => GetDateGroups(),
        };
    }

    private List<SectionGroup> GetReviewGroups()
    {
        var order = new (string Key, string Label, string[] Triggers)[]
        {
            ("AuthorityMatchFailed", "No Match Found",       ["AuthorityMatchFailed"]),
            ("RetailMatchFailed",   "No Retail Match",      ["RetailMatchFailed"]),
            ("ContentMatchFailed",   "No Cover Art Found",   ["ContentMatchFailed"]),
            ("MissingQid",           "Needs Manual Match",   ["MissingQid"]),
            ("MultipleQidMatches",   "Multiple Matches",     ["MultipleQidMatches"]),
            ("LowConfidence",        "Low Confidence",       ["LowConfidence"]),
            ("PlaceholderTitle",     "Missing Title",        ["PlaceholderTitle"]),
            ("StagedUnidentifiable", "Cannot Identify",      ["StagedUnidentifiable"]),
            ("AmbiguousMediaType",   "Ambiguous Type",       ["AmbiguousMediaType"]),
            ("ArtworkUnconfirmed",   "Verify Cover Art",     ["ArtworkUnconfirmed"]),
            ("MetadataConflict",     "Conflicting Data",     ["MetadataConflict"]),
            ("ForeignLanguage",      "Foreign Language",     ["LanguageMismatch"]),
            ("ArbiterNeedsReview",   "Review Grouping",      ["ArbiterNeedsReview"]),
            ("UserFixMatch",         "User Correction",      ["UserFixMatch"]),
            ("Rejected",             "Rejected",             ["Rejected"]),
        };

        var allKnownTriggers = order.SelectMany(o => o.Triggers).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var result = new List<SectionGroup>();

        foreach (var (key, label, triggers) in order)
        {
            var grpItems = Items
                .Where(i => triggers.Any(t => string.Equals(i.ReviewTrigger, t, StringComparison.OrdinalIgnoreCase)))
                .OrderBy(i => i.Title != null && i.Title.Length > 0 && char.IsDigit(i.Title[0]) ? 0 : 1)
                .ThenBy(i => i.Title, StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (grpItems.Count == 0) continue;

            var (_, color, icon) = LibraryItemHelpers.FormatReviewTrigger(triggers[0]);
            result.Add(new SectionGroup(key, label, grpItems,
                IsReviewGroup: true, HeaderIcon: icon, HeaderColor: color));
        }
        var remaining = Items
            .Where(i => !allKnownTriggers.Contains(i.ReviewTrigger ?? ""))
            .OrderBy(i => i.Title != null && i.Title.Length > 0 && char.IsDigit(i.Title[0]) ? 0 : 1)
            .ThenBy(i => i.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (remaining.Count > 0)
            result.Add(new SectionGroup("other", "Other", remaining, IsReviewGroup: true));

        return result;
    }

    private List<SectionGroup> GetDateGroups()
    {
        var today = DateTimeOffset.Now.Date;
        var groups = new Dictionary<string, (string Label, List<LibraryCatalogItemViewModel> Items)>(StringComparer.Ordinal);

        foreach (var item in Items)
        {
            var itemDate = item.CreatedAt.LocalDateTime.Date;
            string key, label;

            if (itemDate == today)
            {
                key = "today"; label = "Today";
            }
            else if (itemDate == today.AddDays(-1))
            {
                key = "yesterday"; label = "Yesterday";
            }
            else if (itemDate > today.AddDays(-7))
            {
                key = itemDate.ToString("yyyy-MM-dd");
                label = itemDate.ToString("dddd");
            }
            else
            {
                key = itemDate.ToString("yyyy-MM");
                label = itemDate.ToString("MMMM d");
            }

            if (!groups.TryGetValue(key, out var g))
            {
                g = (label, []);
                groups[key] = g;
            }
            g.Items.Add(item);
        }

        return groups
            .OrderByDescending(kvp => kvp.Value.Items[0].CreatedAt)
            .Select(kvp => new SectionGroup(kvp.Key, kvp.Value.Label, kvp.Value.Items))
            .ToList();
    }

    private List<SectionGroup> GetMediaTypeGroups()
    {
        var order = new[] { "Books", "Audiobooks", "Movies", "TV", "Comics", "Music" };
        var byType = Items.GroupBy(i => i.MediaType ?? "Unknown").ToDictionary(g => g.Key, g => g.ToList());

        var result = new List<SectionGroup>();
        foreach (var mt in order)
        {
            if (byType.TryGetValue(mt, out var items) && items.Count > 0)
                result.Add(new SectionGroup(mt, mt, items));
        }
        foreach (var kvp in byType)
        {
            if (!order.Contains(kvp.Key) && kvp.Value.Count > 0)
                result.Add(new SectionGroup(kvp.Key, kvp.Key, kvp.Value));
        }
        return result;
    }

    private List<SectionGroup> GetConfidenceGroups()
    {
        var high   = Items.Where(i => i.Confidence >= 0.85).ToList();
        var medium = Items.Where(i => i.Confidence >= 0.60 && i.Confidence < 0.85).ToList();
        var low    = Items.Where(i => i.Confidence < 0.60).ToList();

        var result = new List<SectionGroup>();
        if (high.Count > 0)
            result.Add(new SectionGroup("high", "High Confidence (>=85%)", high,
                HeaderIcon: Icons.Material.Filled.VerifiedUser, HeaderColor: "#5A8A5E"));
        if (medium.Count > 0)
            result.Add(new SectionGroup("medium", "Medium Confidence (60-85%)", medium,
                HeaderIcon: Icons.Material.Filled.Info, HeaderColor: "#B08940"));
        if (low.Count > 0)
            result.Add(new SectionGroup("low", "Low Confidence (<60%)", low,
                HeaderIcon: Icons.Material.Filled.Warning, HeaderColor: "var(--tl-status-danger)"));
        return result;
    }

    private List<SectionGroup> GetStatusGroups()
    {
        var statuses = new[]
        {
            ("Auto",     "Auto-matched"),
            ("Review",   "Needs Review"),
            ("Edited",   "Edited"),
            ("Rejected", "Rejected"),
        };

        var result = new List<SectionGroup>();
        foreach (var (statusKey, label) in statuses)
        {
            var items = Items.Where(i => string.Equals(i.Status, statusKey, StringComparison.OrdinalIgnoreCase)).ToList();
            if (items.Count > 0)
                result.Add(new SectionGroup(statusKey, label, items));
        }
        return result;
    }
}