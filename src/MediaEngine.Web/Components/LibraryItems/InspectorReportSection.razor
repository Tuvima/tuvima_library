@using MediaEngine.Web.Models.ViewDTOs
@using MudBlazor

<div class="irpt-section">
    <AppNativeButton Class="irpt-toggle" OnClick="() => _expanded = !_expanded">
        <MudIcon Icon="@(_expanded ? Icons.Material.Outlined.ExpandLess : Icons.Material.Outlined.ExpandMore)"
                 Style="font-size: 14px; color: rgba(255,255,255,0.30);" />
        <span class="irpt-label">REPORTS (@Reports.Count)</span>
        <span class="irpt-badge" style="background: var(--tl-status-danger-soft); color: var(--tl-status-danger);">@Reports.Count</span>
    </AppNativeButton>

    @if (_expanded)
    {
        @if (Loading)
        {
            <div class="irpt-loading">
                <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                     Style="width: 16px; height: 16px; color: var(--tl-text-faint);" />
            </div>
        }
        else if (Reports.Count == 0)
        {
            <span class="irpt-empty">No reports for this item</span>
        }
        else
        {
            <div class="irpt-list">
                @foreach (var report in Reports)
                {
                    <div class="irpt-card">
                        <div class="irpt-card-header">
                            <span class="irpt-category">@report.Category</span>
                            <span class="irpt-time">@FormatTime(report.OccurredAt)</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(report.Note))
                        {
                            <span class="irpt-note">"@report.Note"</span>
                        }
                        <div class="irpt-card-footer">
                            <span class="irpt-reporter">@report.ReporterName</span>
                            <div class="irpt-actions">
                                <AppNativeButton Class="irpt-action-btn irpt-action-btn--resolve" OnClick="() => OnResolve.InvokeAsync(report.Id)">
                                    Resolve
                                </AppNativeButton>
                                <AppNativeButton Class="irpt-action-btn irpt-action-btn--dismiss" OnClick="() => OnDismiss.InvokeAsync(report.Id)">
                                    Dismiss
                                </AppNativeButton>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public List<ReportEntryDto> Reports { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<long> OnResolve { get; set; }
    [Parameter] public EventCallback<long> OnDismiss { get; set; }

    private bool _expanded;

    private static string FormatTime(string occurredAt)
    {
        if (DateTimeOffset.TryParse(occurredAt, out var dt))
        {
            var diff = DateTimeOffset.Now - dt;
            if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
            if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
            return $"{(int)diff.TotalDays}d ago";
        }
        return occurredAt;
    }
}