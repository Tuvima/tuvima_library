@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.LibraryItems

<div class="rbl-container">
@if (AttentionCount > 0)
    {
        <div class="rbl-attention-banner">
            <div class="rbl-attention-inner">
                <span class="rbl-attention-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L2 20h20L12 2z" stroke="var(--tl-status-warning)" stroke-width="1.5" stroke-linejoin="round"/>
                        <path d="M12 9v5" stroke="var(--tl-status-warning)" stroke-width="1.5" stroke-linecap="round"/>
                        <circle cx="12" cy="17" r="0.75" fill="var(--tl-status-warning)"/>
                    </svg>
                </span>
                <span class="rbl-attention-text">
                    <strong>@AttentionCount @(AttentionCount == 1 ? "item needs" : "items need") your attention</strong>
                </span>
                <AppNativeButton Class="rbl-attention-link" OnClick="() => OnAttentionClicked.InvokeAsync()">
                    Review now
                </AppNativeButton>
            </div>
        </div>
    }
@if (Batches.Count > 0)
    {
        @foreach (var batch in Batches)
        {
            var duration = LibraryItemHelpers.FormatBatchDuration(batch.StartedAt, batch.CompletedAt);
            var timestamp = LibraryItemHelpers.FormatBatchTimestamp(batch.StartedAt);
            var subtitle = LibraryItemHelpers.FormatBatchSubtitle(batch.FilesTotal, batch.Category, batch.SourcePath);
            var isInProgress = batch.CompletedAt is null;

            <div class="rbl-card @(isInProgress ? "rbl-card--active" : "")"
                 @onclick="() => OnBatchSelected.InvokeAsync(batch.Id)"
                 role="button"
                 tabindex="0"
                 @onkeydown="@(async (e) => { if (e.Key is "Enter" or " ") await OnBatchSelected.InvokeAsync(batch.Id); })">
<div class="rbl-card-header">
                    <div class="rbl-card-meta">
                        <span class="rbl-timestamp">@timestamp</span>
                        <span class="rbl-subtitle">@subtitle</span>
                    </div>
                    <span class="rbl-duration @(isInProgress ? "rbl-duration--active" : "")">
                        @if (isInProgress)
                        {
                            <span class="rbl-pulse-dot"></span>
                        }
                        @duration
                    </span>
                </div>
@if (isInProgress && ActiveProgress is not null && ActiveProgress.BatchId == batch.Id)
                {
                    <div class="rbl-progress-section">
                        <div class="rbl-progress-bar-track">
                            <AppCssElement Tag="div" Class="rbl-progress-bar-fill"
                                 Css="@($"width: {ActiveProgress.ProgressPercent}%;")">
                            </AppCssElement>
                        </div>
                        <div class="rbl-progress-meta">
                            <span class="rbl-progress-count">
                                @ActiveProgress.FilesProcessed / @ActiveProgress.FilesTotal files
                            </span>
                            @if (ActiveProgress.EstimatedSecondsRemaining is { } eta)
                            {
                                <span class="rbl-progress-eta">
                                    ~@FormatEta(eta) remaining
                                </span>
                            }
                        </div>
                        @if (ActiveProgress?.RecentTitles is { Count: > 0 })
                        {
                            <div class="rbl-title-summary">
                                @{
                                    var titles = ActiveProgress.RecentTitles;
                                    var displayTitles = string.Join(", ", titles.Take(3));
                                    var moreCount = ActiveProgress.FilesTotal - titles.Count;
                                }
                                @displayTitles
                                @if (moreCount > 0)
                                {
                                    <span class="rbl-more-count">and @moreCount more</span>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(ActiveProgress?.CurrentStage))
                        {
                            <div class="rbl-stage-indicator">
                                @(ActiveProgress.CurrentStage switch
                                {
                                    "RetailIdentification" => "Identifying covers...",
                                    "WikidataBridge" => "Resolving catalogue links...",
                                    _ => ActiveProgress.CurrentStage
                                })
                            </div>
                        }
                    </div>
                }
<div class="rbl-kpi-row">
                    <div class="rbl-kpi-chip">
                        <span class="rbl-kpi-number tl-u-color-tl-status-success" >@batch.FilesIdentified</span>
                        <span class="rbl-kpi-label">Identified</span>
                    </div>
                    <div class="rbl-kpi-chip">
                        <span class="rbl-kpi-number tl-u-color-tl-status-warning" >@batch.FilesReview</span>
                        <span class="rbl-kpi-label">Review</span>
                    </div>
                    <div class="rbl-kpi-chip">
                        <span class="rbl-kpi-number tl-u-color-hex-b4b2a9" >@batch.FilesNoMatch</span>
                        <span class="rbl-kpi-label">No Match</span>
                    </div>
                    <div class="rbl-kpi-chip">
                        <span class="rbl-kpi-number tl-u-color-tl-status-danger" >@batch.FilesFailed</span>
                        <span class="rbl-kpi-label">Failed</span>
                    </div>
                </div>

            </div>
        }
    }
    else
    {
<div class="rbl-empty">
            <svg class="rbl-empty-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="3" width="18" height="18" rx="3" stroke="var(--tl-border-strong)" stroke-width="1.5"/>
                <path d="M8 12h8M12 8v8" stroke="var(--tl-border-strong)" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="rbl-empty-title">No ingestion batches yet</span>
            <span class="rbl-empty-subtitle">Files processed by the Engine will appear here.</span>
        </div>
    }

</div>

@code {
    [Parameter] public IReadOnlyList<IngestionBatchViewModel> Batches { get; set; } = [];
    [Parameter] public int AttentionCount { get; set; }
    [Parameter] public BatchProgressEvent? ActiveProgress { get; set; }
    [Parameter] public EventCallback<Guid> OnBatchSelected { get; set; }
    [Parameter] public EventCallback OnAttentionClicked { get; set; }

    private static string FormatEta(int totalSeconds)
    {
        if (totalSeconds < 60) return $"{totalSeconds}s";
        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;
        return seconds > 0 ? $"{minutes}m {seconds}s" : $"{minutes}m";
    }
}