@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.LibraryItems

<div class="rc-wrap tl-card-hover--media @(IsFocused ? "rc-wrap--focused" : "") @(IsSelected ? "rc-wrap--selected" : "") @(NeedsReview ? "rc-wrap--review" : "")"
     @onclick="HandleClick"
     @onclick:stopPropagation="true"
     style="@CardStateStyle">
@{
        var isAudiobookThumb = string.Equals(Item.MediaType, "Audiobooks", StringComparison.OrdinalIgnoreCase);
    }
    <div class="rc-thumb @(isAudiobookThumb ? "rc-thumb--square" : "")">
        @if (!string.IsNullOrEmpty(Item.CoverUrl))
        {
            <img src="@Item.CoverUrl" alt="@Item.Title" class="rc-thumb-img" loading="lazy" />
        }
        else
        {
            <div class="rc-thumb-fallback">
                <MudIcon Icon="@LibraryItemHelpers.GetMediaTypeIcon(Item.MediaType)"
                         Style="font-size: 1.4rem; opacity: 0.25;" />
            </div>
        }
@if (NeedsReview)
        {
            var (_, trigColor, trigIcon) = LibraryItemHelpers.FormatReviewTrigger(Item.ReviewTrigger);
            <span class="rc-corner-badge" style="--badge-color: @trigColor;">
                <MudIcon Icon="@trigIcon" Style="font-size: 0.55rem; color: #fff;" />
            </span>
        }
@if (SelectionModeActive)
        {
            <span class="rc-sel-mark @(IsSelected ? "rc-sel-mark--on" : "")"></span>
        }
<span class="rc-type-badge">
            <MudIcon Icon="@LibraryItemHelpers.GetMediaTypeIcon(Item.MediaType)"
                     Style="font-size: 0.7rem; color: var(--tl-text-primary);" />
        </span>
@if (!SelectionModeActive && NeedsReview)
        {
            <div class="rc-quick-actions">
                <button class="rc-quick-btn rc-quick-btn--approve"
                        @onclick="HandleApprove" @onclick:stopPropagation="true"
                        title="Approve">
                    <MudIcon Icon="@Icons.Material.Outlined.Check" Style="font-size: 0.65rem;" />
                </button>
                <button class="rc-quick-btn rc-quick-btn--reject"
                        @onclick="HandleReject" @onclick:stopPropagation="true"
                        title="Reject">
                    <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 0.65rem;" />
                </button>
            </div>
        }
    </div>
<div class="rc-title">
        <span class="rc-type-icon" title="@Item.MediaType">
            <MudIcon Icon="@LibraryItemHelpers.GetMediaTypeIcon(Item.MediaType)"
                     Style="font-size: 0.65rem; opacity: 0.4;" />
        </span>@Item.Title</div>
</div>

@code {
    [Parameter, EditorRequired] public LibraryCatalogItemViewModel Item { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsFocused { get; set; }
    [Parameter] public bool SelectionModeActive { get; set; }
    [Parameter] public EventCallback<Guid> OnSelectionToggled { get; set; }
    [Parameter] public EventCallback<Guid> OnCardClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnApproveClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnRejectClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnNavigate { get; set; }

    private bool NeedsReview =>
        !string.IsNullOrEmpty(Item.ReviewTrigger) ||
        (Item.Confidence > 0 && Item.Confidence < 0.85 && !Item.HasUserLocks);
    private string CardStateStyle
    {
        get
        {
            var isIdentified = !string.IsNullOrEmpty(Item.WikidataQid)
                && !Item.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase)
                && string.IsNullOrEmpty(Item.ReviewTrigger);

            if (Item.ReviewTrigger == "Rejected")
                return "border-left: 3px solid var(--tl-status-danger); border-radius: 0; opacity: 0.55;";

            if (NeedsReview)
                return "border-left: 3px solid var(--tl-status-warning); border-radius: 0;";

            if (Item.MissingUniverse && string.IsNullOrEmpty(Item.ReviewTrigger))
                return "border-left: 3px solid #B4B2A9; border-radius: 0;";

            if (isIdentified)
                return "border-left: 3px solid var(--tl-status-success); border-radius: 0; opacity: 0.55;";

            return "";
        }
    }

    private async Task HandleClick()
    {
        if (SelectionModeActive)
            await OnSelectionToggled.InvokeAsync(Item.EntityId);
        else
            await OnCardClicked.InvokeAsync(Item.EntityId);
    }

    private async Task HandleApprove() => await OnApproveClicked.InvokeAsync(Item.EntityId);
    private async Task HandleReject() => await OnRejectClicked.InvokeAsync(Item.EntityId);
}

<style>
    .rc-wrap {
        position: relative;
        width: var(--rc-card-width, 80px);
        cursor: pointer;
        z-index: 1;
        border-radius: 4px;
    }
    .rc-wrap--focused {
        z-index: 10;
    }
    .rc-wrap--focused .rc-thumb {
        border-color: rgba(74,144,217,0.7);
        box-shadow: 0 0 0 1.5px rgba(74,144,217,0.5);
    }
    .rc-wrap--selected .rc-thumb {
        border-color: var(--tl-accent-primary);
    }


    .rc-thumb {
        position: relative;
        width: var(--rc-card-width, 80px);
        height: calc(var(--rc-card-width, 80px) * 1.5);
        border-radius: 4px;
        overflow: hidden;
        background: #0D1230;
        border: 2px solid var(--tl-border-subtle);
        transition: border-color var(--tl-motion-duration-medium) var(--tl-motion-ease-standard), box-shadow var(--tl-motion-duration-medium) var(--tl-motion-ease-standard);
    }

    .rc-thumb::after {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 1;
        opacity: 0;
        pointer-events: none;
        background: var(--tl-hover-overlay-bg);
        transition: opacity var(--tl-motion-duration-medium) var(--tl-motion-ease-standard);
    }

    .rc-thumb--square {
        height: var(--rc-card-width, 80px);
    }
    .rc-wrap--review .rc-thumb {
        border-color: rgba(176,137,64,0.35);
    }
    .rc-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        background: #0D1230;
        transition: transform var(--tl-motion-duration-slow) var(--tl-motion-ease-emphasized), filter var(--tl-motion-duration-medium) var(--tl-motion-ease-standard);
        transform-origin: center;
    }
    .rc-thumb-fallback {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0D1230 0%, #1a1a3e 100%);
    }


    .rc-type-icon {
        display: inline-flex;
        align-items: center;
        margin-right: 4px;
        vertical-align: middle;
    }
    .rc-title {
        font-size: 0.65rem;
        color: var(--tl-text-secondary);
        margin-top: 4px;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-align: center;
        max-width: var(--rc-card-width, 80px);
    }


    .rc-corner-badge {
        position: absolute;
        top: 0;
        left: 0;
        width: 22px;
        height: 22px;
        overflow: hidden;
        z-index: 3;
        display: flex;
        align-items: flex-start;
        justify-content: flex-start;
        pointer-events: none;
    }
    .rc-corner-badge::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        border-style: solid;
        border-width: 22px 22px 0 0;
        border-color: var(--badge-color, #B08940) transparent transparent transparent;
        opacity: 0.85;
    }
    .rc-corner-badge :deep(.mud-icon-root) {
        position: relative;
        z-index: 1;
        margin: 2px 0 0 2px;
    }


    .rc-sel-mark {
        position: absolute;
        top: 3px;
        right: 3px;
        width: 18px;
        height: 18px;
        border-radius: 3px;
        border: 1.5px solid var(--tl-text-secondary);
        background: rgba(0,0,0,0.6);
        transition: all 0.15s ease;
        z-index: 3;
    }
    .rc-sel-mark--on {
        background: var(--tl-accent-primary);
        border-color: var(--tl-accent-primary);
    }
    .rc-sel-mark--on::after {
        content: '';
        display: block;
        width: 5px;
        height: 9px;
        border: solid #000;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
        margin: 1px 0 0 5px;
    }


    .rc-type-badge {
        position: absolute;
        bottom: 3px;
        right: 3px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: rgba(0,0,0,0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--tl-border-default);
        z-index: 3;
    }


    .rc-quick-actions {
        position: absolute;
        bottom: 3px;
        left: 3px;
        display: flex;
        gap: 3px;
        opacity: 0;
        transition: opacity 0.15s ease;
        z-index: 4;
    }

    .rc-wrap:hover .rc-quick-actions {
        opacity: 1;
    }

    .rc-quick-btn {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: 1px solid var(--tl-border-strong);
        transition: background 0.12s ease, border-color 0.12s ease;
    }

    .rc-quick-btn--approve {
        background: rgba(93, 202, 165, 0.65);
        color: #fff;
    }

    .rc-quick-btn--approve:hover {
        background: rgba(93, 202, 165, 0.90);
        border-color: rgba(93, 202, 165, 0.60);
    }

    .rc-quick-btn--reject {
        background: rgba(239, 83, 80, 0.55);
        color: #fff;
    }

    .rc-quick-btn--reject:hover {
        background: rgba(239, 83, 80, 0.85);
        border-color: rgba(239, 83, 80, 0.60);
    }
</style>
