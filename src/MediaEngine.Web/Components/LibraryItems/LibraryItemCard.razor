@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.LibraryItems

<div class="rc-wrap tl-card-hover--media @(IsFocused ? "rc-wrap--focused" : "") @(IsSelected ? "rc-wrap--selected" : "") @(NeedsReview ? "rc-wrap--review" : "")"
     @onclick="HandleClick"
     @onclick:stopPropagation="true"
     style="@CardStateStyle">
@{
        var isAudiobookThumb = string.Equals(Item.MediaType, "Audiobooks", StringComparison.OrdinalIgnoreCase);
    }
    <div class="rc-thumb @(isAudiobookThumb ? "rc-thumb--square" : "")">
        @if (!string.IsNullOrEmpty(Item.CoverUrl))
        {
            <img src="@Item.CoverUrl" alt="@Item.Title" class="rc-thumb-img" loading="lazy" />
        }
        else
        {
            <div class="rc-thumb-fallback">
                <MudIcon Icon="@LibraryItemHelpers.GetMediaTypeIcon(Item.MediaType)"
                         Style="font-size: 1.4rem; opacity: 0.25;" />
            </div>
        }
@if (NeedsReview)
        {
            var (_, trigColor, trigIcon) = LibraryItemHelpers.FormatReviewTrigger(Item.ReviewTrigger);
            <span class="rc-corner-badge" style="--badge-color: @trigColor;">
                <MudIcon Icon="@trigIcon" Style="font-size: 0.55rem; color: #fff;" />
            </span>
        }
@if (SelectionModeActive)
        {
            <span class="rc-sel-mark @(IsSelected ? "rc-sel-mark--on" : "")"></span>
        }
<span class="rc-type-badge">
            <MudIcon Icon="@LibraryItemHelpers.GetMediaTypeIcon(Item.MediaType)"
                     Style="font-size: 0.7rem; color: var(--tl-text-primary);" />
        </span>
@if (!SelectionModeActive && NeedsReview)
        {
            <div class="rc-quick-actions">
                <AppNativeButton Class="rc-quick-btn rc-quick-btn--approve" OnClick="HandleApprove" StopPropagation="true" Title="Approve">
                    <MudIcon Icon="@Icons.Material.Outlined.Check" Style="font-size: 0.65rem;" />
                </AppNativeButton>
                <AppNativeButton Class="rc-quick-btn rc-quick-btn--reject" OnClick="HandleReject" StopPropagation="true" Title="Reject">
                    <MudIcon Icon="@Icons.Material.Outlined.Close" Style="font-size: 0.65rem;" />
                </AppNativeButton>
            </div>
        }
    </div>
<div class="rc-title">
        <span class="rc-type-icon" title="@Item.MediaType">
            <MudIcon Icon="@LibraryItemHelpers.GetMediaTypeIcon(Item.MediaType)"
                     Style="font-size: 0.65rem; opacity: 0.4;" />
        </span>@Item.Title</div>
</div>

@code {
    [Parameter, EditorRequired] public LibraryCatalogItemViewModel Item { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsFocused { get; set; }
    [Parameter] public bool SelectionModeActive { get; set; }
    [Parameter] public EventCallback<Guid> OnSelectionToggled { get; set; }
    [Parameter] public EventCallback<Guid> OnCardClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnApproveClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnRejectClicked { get; set; }
    [Parameter] public EventCallback<Guid> OnNavigate { get; set; }

    private bool NeedsReview =>
        !string.IsNullOrEmpty(Item.ReviewTrigger) ||
        (Item.Confidence > 0 && Item.Confidence < 0.85 && !Item.HasUserLocks);
    private string CardStateStyle
    {
        get
        {
            var isIdentified = !string.IsNullOrEmpty(Item.WikidataQid)
                && !Item.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase)
                && string.IsNullOrEmpty(Item.ReviewTrigger);

            if (Item.ReviewTrigger == "Rejected")
                return "border-left: 3px solid var(--tl-status-danger); border-radius: 0; opacity: 0.55;";

            if (NeedsReview)
                return "border-left: 3px solid var(--tl-status-warning); border-radius: 0;";

            if (Item.MissingUniverse && string.IsNullOrEmpty(Item.ReviewTrigger))
                return "border-left: 3px solid #B4B2A9; border-radius: 0;";

            if (isIdentified)
                return "border-left: 3px solid var(--tl-status-success); border-radius: 0; opacity: 0.55;";

            return "";
        }
    }

    private async Task HandleClick()
    {
        if (SelectionModeActive)
            await OnSelectionToggled.InvokeAsync(Item.EntityId);
        else
            await OnCardClicked.InvokeAsync(Item.EntityId);
    }

    private async Task HandleApprove() => await OnApproveClicked.InvokeAsync(Item.EntityId);
    private async Task HandleReject() => await OnRejectClicked.InvokeAsync(Item.EntityId);
}