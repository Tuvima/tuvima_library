    private static string TruncateDescription(string desc)
    {
        var plain = System.Text.RegularExpressions.Regex.Replace(desc, "<[^>]+>", " ");
        plain = System.Text.RegularExpressions.Regex.Replace(plain, @"\s+", " ").Trim();
        return plain.Length > 120 ? plain[..117] + "..." : plain;
    }

    private static string TruncateTitle(string title)
        => title.Length > 30 ? title[..27] + "..." : title;

    private void ToggleDescription(string descId)
    {
        if (!_expandedDescriptions.Remove(descId))
            _expandedDescriptions.Add(descId);
        StateHasChanged();
    }
    private static string SanitizeDescription(string html)
    {
        var result = html.Replace("\n", "<br />");
        var allowedTags = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
            { "b", "i", "em", "strong", "p", "br", "br /" };

        result = System.Text.RegularExpressions.Regex.Replace(result, @"</?(\w+)[^>]*>", match =>
        {
            var tag = match.Groups[1].Value;
            return allowedTags.Contains(tag) ? match.Value : "";
        });

        return result;
    }
    private static string StripHtml(string html)
    {
        var plain = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]+>", " ");
        plain = System.Text.RegularExpressions.Regex.Replace(plain, @"\s+", " ").Trim();
        plain = plain.Replace("\\n", "\n");
        return plain;
    }
    private string CreatorLabel => (Item.MediaType ?? "") switch
    {
        "Movies" or "TV" => "Director",
        "Music" => "Artist",
        _ => "Author"
    };
    private (bool titleMatch, bool authorMatch, string yearMatch) ComputeMatchSignals(CandidateViewModel candidate)
    {
        var titleMatch = !string.IsNullOrWhiteSpace(candidate.Title)
            && !string.IsNullOrWhiteSpace(Item.Title)
            && (candidate.Title.Contains(Item.Title, StringComparison.OrdinalIgnoreCase)
               || (Item.Title?.Contains(candidate.Title ?? "", StringComparison.OrdinalIgnoreCase) ?? false));

        var authorMatch = !string.IsNullOrWhiteSpace(candidate.Author)
            && !string.IsNullOrWhiteSpace(Item.Author)
            && (candidate.Author.Contains(Item.Author, StringComparison.OrdinalIgnoreCase)
                || Item.Author.Contains(candidate.Author, StringComparison.OrdinalIgnoreCase));

        string yearMatch;
        if (string.IsNullOrWhiteSpace(candidate.Year) || string.IsNullOrWhiteSpace(Item.Year))
            yearMatch = "miss"; // no data to compare
        else if (candidate.Year == Item.Year)
            yearMatch = "match";
        else
            yearMatch = "warn"; // mismatch

        return (titleMatch, authorMatch, yearMatch);
    }
    private Dictionary<string, string> BuildFileHints(string mediaType)
    {
        var hints = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var narrator = Detail?.Narrator ?? "";
        if (!string.IsNullOrWhiteSpace(narrator))
            hints["narrator"] = narrator;
        var series = Detail?.Series ?? "";
        if (!string.IsNullOrWhiteSpace(series))
            hints["series"] = series;
        var director = Detail?.Director ?? "";
        if (!string.IsNullOrWhiteSpace(director))
            hints["director"] = director;
        var cast = Detail?.Cast ?? "";
        if (!string.IsNullOrWhiteSpace(cast))
            hints["cast"] = cast;
        var language = Detail?.Language ?? "";
        if (!string.IsNullOrWhiteSpace(language))
            hints["language"] = language;
        var genre = Detail?.Genre ?? "";
        if (!string.IsNullOrWhiteSpace(genre))
            hints["genre"] = genre;

        return hints;
    }
