@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Components.LibraryItems
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer StateContainer
@inject IJSRuntime JS

@if (IsAlreadyMatched)
{
<div class="isearch-section">
        <span class="isearch-section-label">QUICK SEARCH</span>

        <div class="isearch-matched-banner">
            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 13px; color: var(--tl-status-success);" />
            <span>Already matched - search to update the canonical choice</span>
        </div>

        @* Search input row *@
        <div class="isearch-input-row">
            <input class="isearch-input isearch-input--muted"
                   type="text"
                   placeholder="Search to update the canonical choice..."
                   @bind="_query"
                   @bind:event="oninput"
                   @onkeydown="HandleSearchKeyDown" />
            <select class="isearch-type-select" @bind="_mediaType">
                <option value="">Any</option>
                <option value="Books">Book</option>
                <option value="Audiobooks">Audiobook</option>
                <option value="Movies">Movie</option>
                <option value="TV">TV</option>
                <option value="Music">Music</option>
                <option value="Comics">Comic</option>
            </select>
            <button class="isearch-btn" @onclick="RunSearch" disabled="@(_searching || string.IsNullOrWhiteSpace(_query))">
                @if (_searching)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                         Style="width: 14px; height: 14px; color: var(--tl-text-muted);" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 14px;" />
                }
            </button>
        </div>

        @* Hint *@
        @if (!_hasSearched)
        {
            <span class="isearch-hint">Press Enter to quick search</span>
        }
        else if (_candidates.Count > 0)
        {
            <span class="isearch-hint">@_candidates.Count @(_candidates.Count == 1 ? "result" : "results")  -  Edit query to search again</span>
        }
        else if (!_searching)
        {
            <span class="isearch-hint isearch-hint--empty">No results found  -  Try a different query</span>
        }
@if (_candidates.Count > 0 && _fileHintsForDisplay.Count > 0)
        {
            <div class="isearch-file-hints">
                <span class="isearch-file-hints-label">Your file:</span>
                @foreach (var hint in _fileHintsForDisplay)
                {
                    <span class="isearch-file-hint-pill">
                        <span class="isearch-file-hint-key">@hint.Key</span>
                        <span class="isearch-file-hint-val">@hint.Value</span>
                    </span>
                }
            </div>
        }

        @* Candidate cards *@
        @if (_candidates.Count > 0)
        {
            <div class="isearch-candidates">
                @foreach (var c in _candidates)
                {
                    var isSelected = _selectedCandidate == c;
                    <div class="isearch-card @(isSelected ? "isearch-card--selected" : "")"
                         @onclick="() => SelectCandidate(c)">

                        @{
                            var isAudiobookCard = string.Equals(Item.MediaType, "Audiobooks", StringComparison.OrdinalIgnoreCase);
                        }
                        @if (!string.IsNullOrWhiteSpace(c.CoverUrl))
                        {
                            <div class="isearch-cover-hover-wrap"
                                 @onmouseenter="e => ShowCoverPopup(c.CoverUrl, e)"
                                 @onmouseleave="HideCoverPopup">
                                <img src="@c.CoverUrl" alt="" class="isearch-card-cover @(isAudiobookCard ? "isearch-card-cover--square" : "")"
                                     loading="lazy" />
                            </div>
                        }
                        else
                        {
                            <div class="isearch-card-cover isearch-card-cover--placeholder @(isAudiobookCard ? "isearch-card-cover--square" : "")">
                                <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 20px; color: var(--tl-text-faint);" />
                            </div>
                        }

                        <div class="isearch-card-body">
                            <span class="isearch-card-title">@c.Title</span>
                            @if (!string.IsNullOrWhiteSpace(c.Author))
                            {
                                <span class="isearch-card-author">@c.Author</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(c.Description))
                            {
                                <div class="isearch-card-desc-row">
                                    <span class="isearch-card-desc">@TruncateDescription(c.Description)</span>
                                    @if (c.Description.Length > 120)
                                    {
                                        <MudTooltip Text="@StripHtml(c.Description)" Placement="Placement.Left"
                                                    RootStyle="max-width: 400px;"
                                                    Style="white-space: pre-line; overflow-wrap: break-word; font-size: 12px; max-width: 400px; word-break: break-word;">
                                            <MudIcon Icon="@Icons.Material.Outlined.Info"
                                                     Style="font-size: 14px; color: var(--tl-text-muted); cursor: help; flex-shrink: 0;"
                                                     @onclick:stopPropagation="true" />
                                        </MudTooltip>
                                    }
                                </div>
                            }
@if (c.DescriptionFieldMatches is { Count: > 0 })
                            {
                                <div class="isearch-card-matches">
                                    @foreach (var fm in c.DescriptionFieldMatches)
                                    {
                                        var matchColor = fm.Matched ? "var(--tl-status-success)" : "rgba(200,190,220,0.3)";
                                        <span class="isearch-card-match-pill" style="border-color: @matchColor; color: @matchColor;"
                                              title="@(fm.Matched ? $"{fm.FieldKey}: \"{fm.FileValue}\" found (score: {fm.RawScore:P0})" : $"{fm.FieldKey}: \"{fm.FileValue}\" not found")">
                                            @if (fm.Matched)
                                            {
                                                <MudIcon Icon="@Icons.Material.Outlined.Check" Style="font-size: 10px;" />
                                            }
                                            @fm.FieldKey
                                        </span>
                                    }
                                </div>
                            }
                            <div class="isearch-card-footer">
                                @if (!string.IsNullOrWhiteSpace(c.Year))
                                {
                                    <span class="isearch-card-year">@c.Year</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(c.Qid))
                                {
                                    <a href="https://www.wikidata.org/wiki/@c.Qid"
                                       target="_blank" rel="noopener"
                                       class="isearch-card-wiki"
                                       title="View on Wikidata"
                                       @onclick:stopPropagation="true">
                                        <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 11px;" />
                                        <span>@c.Qid</span>
                                    </a>
                                }
                                @if (c.CompositeScore > 0)
                                {
                                    var confColor = LibraryItemHelpers.GetConfidenceHexColor(c.CompositeScore);
                                    <span class="isearch-card-conf" style="color: @confColor;">
                                        @((int)(c.CompositeScore * 100))%
                                    </span>
                                }
                            </div>
                        </div>

                        @if (isSelected)
                        {
                            <span class="isearch-card-check">
                                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 16px; color: var(--tl-status-info);" />
                            </span>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @* Actions section for already-matched *@
    <div class="isearch-actions-section">
        @if (_selectedCandidate is not null)
        {
            <button class="isearch-btn-register" @onclick="RegisterSelected" disabled="@_registering">
                @if (_registering)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                         Style="width: 14px; height: 14px; color: var(--tl-status-success);" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Refresh" Style="font-size: 14px;" />
                }
                <span>Apply '@TruncateTitle(_selectedCandidate.Title)' as canonical</span>
            </button>
        }
        else
        {
            <button class="isearch-btn-register isearch-btn-register--disabled" disabled>
                <MudIcon Icon="@Icons.Material.Outlined.Refresh" Style="font-size: 14px;" />
                <span>Select a candidate to apply canonically</span>
            </button>
        }

        <button class="isearch-btn-unmatch @(_confirmingUnmatch ? "isearch-btn-unmatch--confirming" : "")"
                @onclick="HandleUnmatchClick" disabled="@_registering">
            <MudIcon Icon="@(_confirmingUnmatch ? Icons.Material.Outlined.Warning : Icons.Material.Outlined.LinkOff)"
                     Style="font-size: 14px;" />
            <span>@(_confirmingUnmatch ? "Are you sure?" : "Unmatch")</span>
        </button>

        @* Registration result *@
        @if (!string.IsNullOrEmpty(_resultMessage))
        {
            <div class="isearch-result @(_resultSuccess ? "isearch-result--ok" : "isearch-result--err")">
                <MudIcon Icon="@(_resultSuccess ? Icons.Material.Outlined.CheckCircle : Icons.Material.Outlined.Error)"
                         Style="font-size: 13px;" />
                <span>@_resultMessage</span>
            </div>
        }
    </div>
}
else
{
<div class="isearch-workspace">
        <h3 class="isearch-heading">Find Match</h3>
<div class="isearch-search-row">
            <input class="isearch-input isearch-input--primary"
                   type="text"
                   placeholder="Search title, author, ISBN..."
                   @bind="_query"
                   @bind:event="oninput"
                   @onkeydown="HandleSearchKeyDown" />
            <select class="isearch-type-select isearch-type-select--primary" @bind="_mediaType">
                <option value="">Any</option>
                <option value="Books">Book</option>
                <option value="Audiobooks">Audiobook</option>
                <option value="Movies">Movie</option>
                <option value="TV">TV</option>
                <option value="Music">Music</option>
                <option value="Comics">Comic</option>
            </select>
            <button class="isearch-search-btn" @onclick="RunSearch" disabled="@(_searching || string.IsNullOrWhiteSpace(_query))">
                @if (_searching)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                         Style="width: 16px; height: 16px; color: var(--tl-text-muted);" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Search" Style="font-size: 16px;" />
                    <span>Search</span>
                }
            </button>
        </div>
<span class="isearch-search-hint">
            @if (!_hasSearched)
            {
                @("Search by title, author, ISBN, or narrator")
            }
            else if (_candidates.Count > 0)
            {
                @($"{_candidates.Count} {(_candidates.Count == 1 ? "result" : "results")}  -  Edit query to search again")
            }
            else if (!_searching)
            {
                <span class="isearch-search-hint--empty">No results found  -  Try a different query</span>
            }
        </span>
@if (_hasSearched && _candidates.Count > 0)
        {
            <div class="isearch-file-banner">
                <MudIcon Icon="@Icons.Material.Outlined.InsertDriveFile" Style="font-size: 12px; color: var(--tl-text-muted); flex-shrink: 0;" />
                <span class="isearch-file-banner-label">Your file:</span>
                <span class="isearch-file-banner-val">@(Item.Title ?? "-")</span>
                @if (!string.IsNullOrWhiteSpace(Item.Author))
                {
                    <span class="isearch-file-banner-sep"> - </span>
                    <span class="isearch-file-banner-val">@Item.Author</span>
                }
                @{
                    var narratorHint = Detail?.Narrator;
                }
                @if (!string.IsNullOrWhiteSpace(narratorHint))
                {
                    <span class="isearch-file-banner-sep"> - </span>
                    <span class="isearch-file-banner-narrator">Narrated by @narratorHint</span>
                }
                @if (!string.IsNullOrWhiteSpace(Item.Year))
                {
                    <span class="isearch-file-banner-sep"> - </span>
                    <span class="isearch-file-banner-val">@Item.Year</span>
                }
            </div>
        }
@if (_candidates.Count > 0)
        {
            <div class="isearch-results-list">
                @foreach (var c in _candidates)
                {
                    var isSelected = _selectedCandidate == c;
                    <div class="isearch-result-item @(isSelected ? "isearch-result-item--selected" : "")"
                         @onclick="() => SelectCandidate(c)">

                        @{
                            var isAudiobookResult = string.Equals(Item.MediaType, "Audiobooks", StringComparison.OrdinalIgnoreCase);
                        }
                        @if (!string.IsNullOrWhiteSpace(c.CoverUrl))
                        {
                            <div class="isearch-cover-hover-wrap"
                                 @onmouseenter="e => ShowCoverPopup(c.CoverUrl, e)"
                                 @onmouseleave="HideCoverPopup">
                                <img src="@c.CoverUrl" alt="" class="isearch-result-cover @(isAudiobookResult ? "isearch-result-cover--square" : "")"
                                     loading="lazy" />
                            </div>
                        }
                        else
                        {
                            <div class="isearch-result-cover isearch-result-cover--placeholder @(isAudiobookResult ? "isearch-result-cover--square" : "")">
                                <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Style="font-size: 20px; color: var(--tl-text-faint);" />
                            </div>
                        }

                        @* Text content *@
                        <div class="isearch-result-body">
                            <span class="isearch-result-title">@c.Title</span>
                            @if (!string.IsNullOrWhiteSpace(c.Description))
                            {
                                <div class="isearch-card-desc-row">
                                    <span class="isearch-result-desc">@TruncateDescription(c.Description)</span>
                                    @if (c.Description.Length > 120)
                                    {
                                        <MudTooltip Text="@StripHtml(c.Description)" Placement="Placement.Left"
                                                    RootStyle="max-width: 400px;"
                                                    Style="white-space: pre-line; overflow-wrap: break-word; font-size: 12px; max-width: 400px; word-break: break-word;">
                                            <MudIcon Icon="@Icons.Material.Outlined.Info"
                                                     Style="font-size: 14px; color: var(--tl-text-muted); cursor: help; flex-shrink: 0;"
                                                     @onclick:stopPropagation="true" />
                                        </MudTooltip>
                                    }
                                </div>
                            }
                            <div class="isearch-result-meta">
                                @if (!string.IsNullOrWhiteSpace(c.Qid))
                                {
                                    <span class="isearch-result-qid">@c.Qid</span>
                                    <a href="https://www.wikidata.org/wiki/@c.Qid"
                                       target="_blank" rel="noopener"
                                       class="isearch-result-wiki"
                                       title="View on Wikidata"
                                       @onclick:stopPropagation="true">
                                        <MudIcon Icon="@Icons.Material.Outlined.Public" Style="font-size: 11px;" />
                                        <span>Wikidata</span>
                                    </a>
                                }
                                @if (!string.IsNullOrWhiteSpace(c.Year))
                                {
                                    <span class="isearch-result-year">@c.Year</span>
                                }
                            </div>
                        </div>

                        @* Match signals *@
                        <div class="isearch-result-signals">
                            @{
                                var (titleMatch, authorMatch, yearMatch) = ComputeMatchSignals(c);
                            }
                            <span class="isearch-signal @(titleMatch ? "isearch-signal--match" : "isearch-signal--miss")">
                                <MudIcon Icon="@(titleMatch ? Icons.Material.Outlined.Check : Icons.Material.Outlined.Close)"
                                         Style="font-size: 12px;" />
                                Title
                            </span>
                            <span class="isearch-signal @(authorMatch ? "isearch-signal--match" : "isearch-signal--miss")">
                                <MudIcon Icon="@(authorMatch ? Icons.Material.Outlined.Check : Icons.Material.Outlined.Close)"
                                         Style="font-size: 12px;" />
                                @CreatorLabel
                            </span>
                            <span class="isearch-signal @(yearMatch == "match" ? "isearch-signal--match" : yearMatch == "warn" ? "isearch-signal--warn" : "isearch-signal--miss")">
                                <MudIcon Icon="@(yearMatch == "match" ? Icons.Material.Outlined.Check : yearMatch == "warn" ? Icons.Material.Outlined.Warning : Icons.Material.Outlined.Close)"
                                         Style="font-size: 12px;" />
                                Year
                            </span>
@if (c.DescriptionFieldMatches is { Count: > 0 })
                            {
                                @foreach (var fm in c.DescriptionFieldMatches)
                                {
                                    <span class="isearch-signal @(fm.Matched ? "isearch-signal--match" : "isearch-signal--miss")"
                                          title="@(fm.Matched ? $"{DescriptionFieldLabel(fm.FieldKey)} found in description (score {fm.RawScore})" : $"{DescriptionFieldLabel(fm.FieldKey)} not found in description")">
                                        <MudIcon Icon="@(fm.Matched ? Icons.Material.Outlined.Check : Icons.Material.Outlined.Close)"
                                                 Style="font-size: 12px;" />
                                        @DescriptionFieldLabel(fm.FieldKey)
                                    </span>
                                }
                            }
                        </div>

                        @if (isSelected)
                        {
                            <button class="isearch-result-select-btn"
                                    @onclick:stopPropagation="true">
                                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 14px; color: var(--tl-status-info);" />
                            </button>
                        }
                    </div>
                }
            </div>
        }
@if (_selectedCandidate is not null)
        {
            <div class="isearch-comparison">
                <div class="isearch-comparison-col">
                    <span class="isearch-comparison-label">Your File</span>
                    <div class="isearch-comparison-field">
                        <span class="isearch-comparison-key">Title</span>
                        <span class="isearch-comparison-val">@(Item.Title ?? "-")</span>
                    </div>
                    <div class="isearch-comparison-field">
                        <span class="isearch-comparison-key">@CreatorLabel</span>
                        <span class="isearch-comparison-val">@(Item.Author ?? "-")</span>
                    </div>
                    <div class="isearch-comparison-field">
                        <span class="isearch-comparison-key">Year</span>
                        <span class="isearch-comparison-val">@(Item.Year ?? "-")</span>
                    </div>
                </div>
                <div class="isearch-comparison-col">
                    <span class="isearch-comparison-label">Selected Result</span>
                    <div class="isearch-comparison-field">
                        <span class="isearch-comparison-key">Title</span>
                        <span class="isearch-comparison-val">@(_selectedCandidate.Title ?? "-")</span>
                    </div>
                    <div class="isearch-comparison-field">
                        <span class="isearch-comparison-key">@CreatorLabel</span>
                        <span class="isearch-comparison-val">@(_selectedCandidate.Author ?? "-")</span>
                    </div>
                    <div class="isearch-comparison-field">
                        <span class="isearch-comparison-key">Year</span>
                        @{
                            var (_, _, ym) = ComputeMatchSignals(_selectedCandidate);
                            var yearClass = ym == "match" ? "isearch-comparison-val--match" : ym == "warn" ? "isearch-comparison-val--warn" : "";
                        }
                        <span class="isearch-comparison-val @yearClass">@(_selectedCandidate.Year ?? "-")</span>
                    </div>
                </div>
            </div>
        }
    </div>
<div class="isearch-workspace-actions">
        @if (_selectedCandidate is not null)
        {
            <button class="isearch-action-accept @(_confirmingRegister ? "isearch-action--confirming" : "")"
                    @onclick="HandleRegisterClick" disabled="@_registering">
                @if (_registering)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                         Style="width: 14px; height: 14px; color: var(--tl-status-success);" />
                    <span>Registering...</span>
                }
                else if (_confirmingRegister)
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Warning" Style="font-size: 14px;" />
                    <span>Confirm register?</span>
                }
                else if (_resultSuccess && _awaitingStage2)
                {
                    <MudIcon Icon="@Icons.Material.Outlined.HourglassTop" Style="font-size: 14px; color: var(--tl-accent-primary);" />
                    <span>Awaiting Wikidata</span>
                }
                else if (_resultSuccess && !string.IsNullOrEmpty(_resultMessage))
                {
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 14px; color: var(--tl-status-success);" />
                    <span>Identified</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 14px;" />
                    <span>Accept Match</span>
                }
            </button>
        }
        else
        {
            <button class="isearch-action-accept isearch-action-accept--disabled" disabled>
                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size: 14px;" />
                <span>Select a candidate to register</span>
            </button>
        }

        @if (!_resultSuccess)
        {
            <button class="isearch-action-provisional" @onclick="HandleProvisionalClick" disabled="@_registering">
                <MudIcon Icon="@Icons.Material.Outlined.EditNote" Style="font-size: 14px;" />
                <span>Mark Provisional</span>
            </button>

            <button class="isearch-action-reject @(_confirmingReject ? "isearch-action--confirming" : "")"
                    @onclick="HandleRejectClick" disabled="@_registering">
                <MudIcon Icon="@(_confirmingReject ? Icons.Material.Outlined.Warning : Icons.Material.Outlined.Block)"
                         Style="font-size: 14px;" />
                <span>@(_confirmingReject ? "Are you sure?" : "Reject")</span>
            </button>
        }

        @if (!string.IsNullOrEmpty(_resultMessage))
        {
            <div class="isearch-result @(_resultSuccess ? (_awaitingStage2 ? "isearch-result--pending" : "isearch-result--ok") : "isearch-result--err")">
                <MudIcon Icon="@(_resultSuccess ? (_awaitingStage2 ? Icons.Material.Outlined.HourglassTop : Icons.Material.Outlined.CheckCircle) : Icons.Material.Outlined.Error)"
                         Style="@(_awaitingStage2 ? "font-size: 13px; color: var(--tl-accent-primary);" : "font-size: 13px;")" />
                <span>@_resultMessage</span>
            </div>
        }
    </div>
}


@code {
    [Parameter, EditorRequired] public LibraryCatalogItemViewModel Item { get; set; } = default!;
    [Parameter] public LibraryItemDetailViewModel? Detail { get; set; }
    [Parameter] public string? SelectedCoverUrl { get; set; }
    [Parameter] public EventCallback OnIdentified { get; set; }
    [Parameter] public EventCallback OnMarkedProvisional { get; set; }
    [Parameter] public EventCallback OnRejected { get; set; }
    [Parameter] public EventCallback<(string? title, string? author, string? qid)> OnCandidateSelected { get; set; }

    private string _query = "";
    private string _mediaType = "";
    private bool _searching;
    private bool _hasSearched;
    private bool _registering;
    private List<CandidateViewModel> _candidates = [];
    private CandidateViewModel? _selectedCandidate;
    private string? _resultMessage;
    private bool _resultSuccess;
    private bool _awaitingStage2;
    private Guid? _lastItemId;
    private List<KeyValuePair<string, string>> _fileHintsForDisplay = [];

    private bool _confirmingReject;
    private bool _confirmingRegister;
    private bool _confirmingUnmatch;
    private readonly HashSet<string> _expandedDescriptions = new();
    private System.Threading.Timer? _rejectTimer;
    private System.Threading.Timer? _registerTimer;
    private System.Threading.Timer? _unmatchTimer;
    private async Task ShowCoverPopup(string? url, MouseEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(url)) return;
        await JS.InvokeVoidAsync("CoverPopup.show", url, e.ClientX, e.ClientY);
    }

    private async Task HideCoverPopup()
    {
        await JS.InvokeVoidAsync("CoverPopup.hide");
    }

    private bool IsAlreadyMatched =>
        !string.IsNullOrEmpty(Item.WikidataQid) &&
        !Item.WikidataQid.StartsWith("NF", StringComparison.OrdinalIgnoreCase);

    protected override void OnParametersSet()
    {
        if (Item.EntityId != _lastItemId)
        {
            _lastItemId = Item.EntityId;
            _query = Item.Title ?? "";
            _mediaType = Item.MediaType ?? "";
            _candidates = [];
            _selectedCandidate = null;
            _hasSearched = false;
            _resultMessage = null;
            _awaitingStage2 = false;

        }
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_query))
            await RunSearch();
    }

    private async Task RunSearch()
    {
        if (string.IsNullOrWhiteSpace(_query) || _searching) return;

        _searching = true;
        _selectedCandidate = null;
        _resultMessage = null;
        _candidates = [];
        StateHasChanged();

        try
        {
            var mt = string.IsNullOrEmpty(_mediaType) ? "Books" : _mediaType;
            var fileHints = BuildFileHints(mt);
            var hasHints = fileHints.Count > 0;
            _fileHintsForDisplay = fileHints
                .Where(kv => !string.IsNullOrWhiteSpace(kv.Value))
                .Select(kv => new KeyValuePair<string, string>(
                    kv.Key switch
                    {
                        "narrator"  => "Narrator",
                        "series"    => "Series",
                        "publisher" => "Publisher",
                        "director"  => "Director",
                        "cast"      => "Cast",
                        "language"  => "Language",
                        "genre"     => "Genre",
                        "album"     => "Album",
                        "label"     => "Label",
                        _           => kv.Key,
                    },
                    kv.Value))
                .ToList();
            var retailResults = await Orchestrator.SearchRetailAsync(
                _query, mt, maxCandidates: 10,
                localTitle: Item.Title,
                localAuthor: Item.Author,
                localYear: Item.Year,
                fileHints: hasHints ? fileHints : null);

            if (retailResults.Count > 0)
            {
                foreach (var c in retailResults)
                {
                    _candidates.Add(new CandidateViewModel
                    {
                        Title = c.Title,
                        Author = c.Author ?? c.Director,
                        Description = c.Description,
                        Year = c.Year,
                        CoverUrl = c.CoverUrl,
                        Confidence = c.Confidence,
                        CompositeScore = c.CompositeScore > 0 ? c.CompositeScore : c.Confidence,
                        DescriptionMatchScore = c.DescriptionMatchScore,
                        DescriptionFieldMatches = c.DescriptionFieldMatches,
                        ProviderName = c.ProviderName,
                        ProviderId = c.ProviderId,
                        ProviderItemId = c.ProviderItemId,
                    });
                }
            }
            else
            {
            }
            _candidates = _candidates.OrderByDescending(c => c.CompositeScore).ToList();
        }
        catch
        {
        }

        _searching = false;
        _hasSearched = true;
    }

    private async Task SelectCandidate(CandidateViewModel candidate)
    {
        _selectedCandidate = _selectedCandidate == candidate ? null : candidate;
        _resultMessage = null;
        await OnCandidateSelected.InvokeAsync(_selectedCandidate is not null
            ? (_selectedCandidate.Title, _selectedCandidate.Author, _selectedCandidate.Qid)
            : (null, null, null));
    }

    private async Task RegisterSelected()
    {
        if (_selectedCandidate is null || _registering) return;

        _registering = true;
        _resultMessage = null;
        StateHasChanged();

        try
        {
            var request = new ApplyMatchRequestDto
            {
                Qid = _selectedCandidate.Qid,
                Title = _selectedCandidate.Title,
                Year = _selectedCandidate.Year,
                Author = _selectedCandidate.Author,
                Description = _selectedCandidate.Description,
                CoverUrl = SelectedCoverUrl ?? _selectedCandidate.CoverUrl
            };

            var response = await Orchestrator.ApplyLibraryItemMatchAsync(Item.EntityId, request);
            if (response is not null)
            {
                _awaitingStage2 = response.HydrationTriggered;
                _resultMessage = _awaitingStage2
                    ? (response.Message ?? $"Match accepted - Wikidata lookup in progress")
                    : (response.Message ?? $"Identified - {response.ClaimsWritten} claims written");
                _resultSuccess = true;
                _candidates = [];
                _selectedCandidate = null;
                _hasSearched = false;
                _query = "";
                await OnIdentified.InvokeAsync();
            }
            else
            {
                _awaitingStage2 = false;
                _resultMessage = "Identification failed - no response from engine";
                _resultSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _resultMessage = $"Error: {ex.Message}";
            _resultSuccess = false;
        }

        _registering = false;
    }

    private async Task HandleProvisionalClick()
    {
        await OnMarkedProvisional.InvokeAsync();
    }

    private async Task HandleRegisterClick()
    {
        if (_confirmingRegister)
        {
            _confirmingRegister = false;
            _registerTimer?.Dispose();
            _registerTimer = null;
            await RegisterSelected();
            return;
        }
        _confirmingRegister = true;
        _registerTimer?.Dispose();
        _registerTimer = new System.Threading.Timer(_ =>
        {
            _confirmingRegister = false;
            _registerTimer = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, Timeout.Infinite);
    }

