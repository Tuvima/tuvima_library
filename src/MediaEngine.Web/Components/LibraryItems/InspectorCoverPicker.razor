@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject UIOrchestratorService Orchestrator
@inject IJSRuntime JS
@inject ILogger<InspectorCoverPicker> Logger

<div class="coverpicker">
    @if (_covers.Count == 0 && !_loading)
    {
}
    else
    {
@if (_aliases.Count > 1)
        {
            <div class="coverpicker-alias-row">
                <MudIcon Icon="@Icons.Material.Outlined.TravelExplore"
                         Class="tl-u-font-size-13px tl-u-color-tl-text-muted" />
                <AppNativeSelect Class="coverpicker-alias-select" OnChange="HandleAliasChanged">
                    @foreach (var alias in _aliases)
                    {
                        <option value="@alias" selected="@(alias == _activeSearchTitle)">@alias</option>
                    }
                </AppNativeSelect>
            </div>
        }

        <div class="coverpicker-strip">
            @foreach (var cover in _covers)
            {
                var isSelected = cover == _selectedCover;
                var isAudiobook = string.Equals(MediaType, "Audiobooks", StringComparison.OrdinalIgnoreCase);
                <div class="coverpicker-thumb @(isSelected ? "coverpicker-thumb--selected" : "") @(isAudiobook ? "coverpicker-thumb--square" : "")"
                     @onclick="() => SelectCover(cover)"
                     @onmouseenter="e => ShowCoverPopup(cover.Url, e)"
                     @onmouseleave="HideCoverPopup">
                    <div class="coverpicker-img-wrap">
                        <img src="@cover.Url" alt="" class="coverpicker-img" loading="lazy"
                             onerror="this.style.display='none';this.nextElementSibling&&(this.nextElementSibling.style.display='flex')" />
                        <div class="coverpicker-img-fallback tl-u-display-none" >
                            <MudIcon Icon="@Icons.Material.Outlined.BrokenImage"
                                     Class="tl-u-font-size-14px tl-u-color-tl-text-faint" />
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(cover.Label))
                    {
                        <span class="coverpicker-label">@cover.Label</span>
                    }
                    @if (isSelected)
                    {
                        <span class="coverpicker-check">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="tl-u-font-size-14px tl-u-color-tl-status-info" />
                        </span>
                    }
                </div>
            }

            @if (_loading)
            {
                <div class="coverpicker-thumb coverpicker-thumb--loading">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                         Class="tl-u-width-16px tl-u-height-16px tl-u-color-tl-text-muted" />
                </div>
            }

            @if (!_loading && _hasMore)
            {
                var isAudiobookMore = string.Equals(MediaType, "Audiobook", StringComparison.OrdinalIgnoreCase)
                                      || string.Equals(MediaType, "Audiobooks", StringComparison.OrdinalIgnoreCase);
                <AppNativeButton Class='@($"coverpicker-more {(isAudiobookMore ? " coverpicker-more--square" : "")}")' OnClick="LoadMore">
                    <MudIcon Icon="@Icons.Material.Outlined.Add" Class="tl-u-font-size-16px" />
                    <span>More</span>
                </AppNativeButton>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string? FileCoverUrl { get; set; }
    [Parameter] public string? CandidateTitle { get; set; }
    [Parameter] public string? CandidateAuthor { get; set; }
    [Parameter] public string? CandidateQid { get; set; }
    [Parameter] public string? MediaType { get; set; }
    [Parameter] public EventCallback<string?> OnCoverSelected { get; set; }

    private sealed class CoverOption
    {
        public string Url { get; init; } = "";
        public string? Label { get; init; }
        public string? ProviderName { get; init; }
    }

    private List<CoverOption> _covers = [];

    private async Task ShowCoverPopup(string? url, MouseEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(url)) return;
        await JS.InvokeVoidAsync("CoverPopup.show", url, e.ClientX, e.ClientY);
    }

    private async Task HideCoverPopup()
    {
        await JS.InvokeVoidAsync("CoverPopup.hide");
    }
    private CoverOption? _selectedCover;
    private bool _loading;
    private bool _hasMore;
    private string? _lastQuery;
    private List<RetailCandidateDto> _allRetailResults = [];
    private List<string> _aliases = [];
    private string? _activeSearchTitle;
    private string? _lastAliasQid;

    protected override async Task OnParametersSetAsync()
    {
        var query = BuildQuery();
        if (query == _lastQuery) return;

        _lastQuery = query;
        _covers = [];
        _selectedCover = null;
        _allRetailResults = [];
        _hasMore = false;
        _activeSearchTitle = CandidateTitle;
        if (CandidateQid != _lastAliasQid)
        {
            _lastAliasQid = CandidateQid;
            _aliases = [];
            if (!string.IsNullOrWhiteSpace(CandidateQid))
            {
                _ = LoadAliasesAsync(CandidateQid);
            }
        }

        if (string.IsNullOrWhiteSpace(CandidateTitle))
        {
            if (!string.IsNullOrEmpty(FileCoverUrl))
            {
                var fileCover = new CoverOption { Url = FileCoverUrl, Label = "From File" };
                _covers.Add(fileCover);
                _selectedCover = fileCover;
                await OnCoverSelected.InvokeAsync(fileCover.Url);
            }
            return;
        }
        if (!string.IsNullOrEmpty(FileCoverUrl))
        {
            var fileCover = new CoverOption { Url = FileCoverUrl, Label = "From File" };
            _covers.Add(fileCover);
            _selectedCover = fileCover;
            await OnCoverSelected.InvokeAsync(fileCover.Url);
        }
        await LoadRetailCovers();
    }

    private async Task LoadAliasesAsync(string qid)
    {
        try
        {
            _aliases = await Orchestrator.GetAliasesAsync(qid, CandidateTitle);
            _activeSearchTitle = _aliases.Count > 0 ? _aliases[0] : CandidateTitle;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not load aliases for cover search QID {Qid}.", qid);
        }
    }

    private async Task HandleAliasChanged(ChangeEventArgs e)
    {
        var selected = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(selected) || selected == _activeSearchTitle) return;

        _activeSearchTitle = selected;
        _covers.RemoveAll(c => c.Label != "From File");
        _allRetailResults = [];
        _hasMore = false;
        _selectedCover = _covers.FirstOrDefault(); // revert to file cover if present

        await LoadRetailCovers();
        StateHasChanged();
    }

    private async Task LoadRetailCovers()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var searchQuery = _activeSearchTitle ?? CandidateTitle ?? "";
            if (!string.IsNullOrWhiteSpace(CandidateAuthor))
                searchQuery += " " + CandidateAuthor;

            var mt = string.IsNullOrEmpty(MediaType) ? "Books" : MediaType;
            var result = await Orchestrator.SearchRetailAsync(searchQuery, mt, 20);
            _allRetailResults = result;

            AppendNextBatch();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Retail cover search failed for {Title} ({MediaType}).", _activeSearchTitle ?? CandidateTitle, MediaType);
        }

        _loading = false;
        if (_selectedCover is null && _covers.Count > 0)
        {
            _selectedCover = _covers[0];
            await OnCoverSelected.InvokeAsync(_selectedCover.Url);
        }
    }

    private void AppendNextBatch()
    {
        var existingRetailCount = _covers.Count(c => c.Label != "From File");
        var batchSize = existingRetailCount == 0 ? 4 : 5;
        var skip = existingRetailCount;

        var batch = _allRetailResults
            .Where(r => !string.IsNullOrEmpty(r.CoverUrl))
            .Skip(skip)
            .Take(batchSize)
            .ToList();

        foreach (var r in batch)
        {
            if (_covers.Any(c => c.Url == r.CoverUrl)) continue;
            _covers.Add(new CoverOption
            {
                Url = r.CoverUrl!,
                Label = null, // no label for provider covers
                ProviderName = r.ProviderName
            });
        }

        var totalAvailable = _allRetailResults.Count(r => !string.IsNullOrEmpty(r.CoverUrl));
        _hasMore = (skip + batchSize) < totalAvailable;
    }

    private async Task LoadMore()
    {
        AppendNextBatch();
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task SelectCover(CoverOption cover)
    {
        _selectedCover = cover;
        await OnCoverSelected.InvokeAsync(cover.Url);
    }

    private string? BuildQuery()
    {
        if (string.IsNullOrWhiteSpace(CandidateTitle)) return null;
        return $"{CandidateTitle}|{CandidateAuthor}|{CandidateQid}|{MediaType}";
    }
}