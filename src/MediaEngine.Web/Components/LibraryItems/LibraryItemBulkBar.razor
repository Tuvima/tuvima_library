<div class="library-item-bulk-bar">
    <AppChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
        @SelectedCount selected
    </AppChip>

    <AppButton Variant="Variant.Text" Size="Size.Small"
               OnClick="OnSelectAll" Disabled="@Processing"
               Style="color: var(--tl-text-muted); font-size: 0.75rem;">
        Select All (@TotalCount)
    </AppButton>
    <AppButton Variant="Variant.Text" Size="Size.Small"
               OnClick="OnDeselectAll" Disabled="@Processing"
               Style="color: var(--tl-text-muted); font-size: 0.75rem;">
        Deselect All
    </AppButton>

    <div style="flex: 1;"></div>

    @if (Processing)
    {
        <MudProgressCircular Indeterminate="true" Size="Size.Small"
                             Style="color: var(--tl-text-muted); width: 20px; height: 20px;" />
    }

    <AppButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Check" OnClick="OnApprove"
               Disabled="@Processing">
        Approve
    </AppButton>
    <AppButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Block" OnClick="OnReject"
               Disabled="@Processing">
        Reject
    </AppButton>
    <AppButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Warning" OnClick="OnDelete"
               Disabled="@Processing">
        Delete from Library
    </AppButton>
</div>

@code {
    [Parameter] public int SelectedCount { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public bool Processing { get; set; }
    [Parameter] public EventCallback OnApprove { get; set; }
    [Parameter] public EventCallback OnReject { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnSelectAll { get; set; }
    [Parameter] public EventCallback OnDeselectAll { get; set; }
}