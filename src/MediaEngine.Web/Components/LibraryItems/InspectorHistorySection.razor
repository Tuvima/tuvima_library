@using MediaEngine.Web.Models.ViewDTOs
@using MudBlazor

<div class="ihs-panel">
    @if (Loading)
    {
        <div class="ihs-loading">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ihs-spinner" />
        </div>
    }
    else if (History == null || History.Count == 0)
    {
        <div class="ihs-empty">No history yet</div>
    }
    else
    {
        var milestones = CondenseToMilestones(History);

        <div class="ihs-timeline">
            @for (int i = 0; i < milestones.Count; i++)
            {
                var m = milestones[i];
                var isLast = i == milestones.Count - 1;

                <div class="ihs-entry">
                    <div class="ihs-track">
                        <div class="ihs-dot" style="background: @m.DotBg;">
                            <div class="ihs-dot-inner" style="background: @m.DotCore;"></div>
                        </div>
                        @if (!isLast)
                        {
                            <div class="ihs-connector"></div>
                        }
                    </div>
                    <div class="ihs-content @(isLast ? "ihs-content--last" : "")">
                        <span class="ihs-label">@m.Label</span>
                        @if (!string.IsNullOrWhiteSpace(m.Detail))
                        {
                            <span class="ihs-detail">@m.Detail</span>
                        }
                        <span class="ihs-time">@FormatTimestamp(m.OccurredAt)</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<LibraryItemHistoryDto> History { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public int MaxEntries { get; set; } = 100;
    [Parameter] public EventCallback OnLoadMore { get; set; }

    private sealed record Milestone(string Label, string? Detail, DateTimeOffset OccurredAt, string DotBg, string DotCore);
    private static List<Milestone> CondenseToMilestones(List<LibraryItemHistoryDto> raw)
    {
        var milestones = new List<Milestone>();
        var ordered = raw.OrderBy(e => e.OccurredAt).ToList();
        var emitted = new HashSet<string>();

        foreach (var entry in ordered)
        {
            var phase = ClassifyPhase(entry.EventType);
            if (phase is null || !emitted.Add(phase))
                continue;

            var (label, detail, dotBg, dotCore) = phase switch
            {
                "picked_up"    => ("File picked up", (string?)null, "var(--tl-status-info-soft)", "var(--tl-status-info)"),
                "extracted"    => ("Metadata extracted", SummarizeExtraction(ordered), "var(--tl-status-info-soft)", "var(--tl-status-info)"),
                "searched"     => ("Searched for match", (string?)null, "var(--tl-status-info-soft)", "var(--tl-status-info)"),
                "retail_match" => ("Retail match identified", SummarizeRetailMatch(ordered), "var(--tl-status-info-soft)", "var(--tl-status-info)"),
                "matched"      => ("Wikidata match", SummarizeMatch(ordered), "var(--tl-status-success-soft)", "var(--tl-status-success)"),
                "no_match"     => ("No match found", (string?)null, "var(--tl-status-warning-soft)", "var(--tl-status-warning)"),
                "review"       => ("Sent for review", SummarizeReview(ordered), "var(--tl-status-warning-soft)", "var(--tl-status-warning)"),
                "cover_art"    => ("Cover art downloaded", (string?)null, "var(--tl-status-info-soft)", "var(--tl-status-info)"),
                "identified"   => ("Moved to Identified", SummarizeResolved(ordered), "var(--tl-status-success-soft)", "var(--tl-status-success)"),
                "rejected"     => ("Rejected", (string?)null, "var(--tl-status-danger-soft)", "var(--tl-status-danger)"),
                "recovered"    => ("Recovered", (string?)null, "var(--tl-status-success-soft)", "var(--tl-status-success)"),
                "person_enriched" => ("Author enriched", SummarizePersonEnrichment(ordered), "rgba(140,120,180,0.15)", "var(--tl-accent-primary)"),
                "manual_edit"  => ("Manually edited", (string?)null, "rgba(140,120,180,0.15)", "var(--tl-accent-primary)"),
                _              => (entry.Label, (string?)null, "rgba(140,120,180,0.12)", "var(--tl-text-muted)"),
            };

            milestones.Add(new Milestone(label, detail, entry.OccurredAt, dotBg, dotCore));
        }

        return milestones;
    }
    private static string? ClassifyPhase(string eventType) => eventType switch
    {
        "FileDetected" or "FileIngested" or "FileHashed"  => "picked_up",
        "MetadataExtracted" or "ConfidenceScored" or
            "EntityChainCreated" or "MovedToStaging"       => "extracted",
        "HydrationStarted" or "HydrationEnqueued"         => "searched",
        "RetailEnriched"                                   => "retail_match",
        "WikidataMatched" or "CollectionAssigned" or
            "CollectionCreated" or "HydrationCompleted"           => "matched",
        "WikidataMatchFailed"                              => "no_match",
        "ReviewItemCreated"                                => "review",
        "ReviewItemResolved" or "Promoted"                 => "identified",
        "CoverArtSaved" or "HeroBannerGenerated"           => "cover_art",
        "FileRejected"                                     => "rejected",
        "Recovered"                                        => "recovered",
        "MetadataManualOverride" or "MetadataWrittenToFile" => "manual_edit",
        "PersonHydrated"                                   => "person_enriched",
        "DuplicateSkipped"                                 => null,  // skip
        _                                                  => null,
    };

    private static string? SummarizeRetailMatch(List<LibraryItemHistoryDto> ordered)
    {
        var match = ordered.FirstOrDefault(e => e.EventType == "RetailEnriched");
        if (match?.Detail is not null)
        {
            var d = match.Detail.Trim();
            if (d.Length > 60) d = d[..57] + "...";
            if (d.Length >= 3) return d;
        }
        return null;
    }

    private static string? SummarizeResolved(List<LibraryItemHistoryDto> ordered)
    {
        var resolved = ordered.LastOrDefault(e =>
            e.EventType == "ReviewItemResolved" || e.EventType == "Promoted");
        if (resolved?.Detail is not null)
        {
            var d = resolved.Detail.Trim();
            if (d.Length > 60) d = d[..57] + "...";
            if (d.Length >= 3) return d;
        }
        return null;
    }

    private static string? SummarizeExtraction(List<LibraryItemHistoryDto> ordered)
    {
        var extracted = ordered.FirstOrDefault(e => e.EventType == "MetadataExtracted");
        if (extracted?.Detail is not null)
        {
            var d = extracted.Detail.Trim();
            if (d.Length > 60) d = d[..57] + "...";
            if (d.Length >= 3) return d;
        }
        return null;
    }

    private static string? SummarizeMatch(List<LibraryItemHistoryDto> ordered)
    {
        var match = ordered.FirstOrDefault(e => e.EventType == "WikidataMatched");
        if (match?.Detail is not null)
        {
            var d = match.Detail.Trim();
            if (d.Length > 60) d = d[..57] + "...";
            if (d.Length >= 3) return d;
        }
        return null;
    }

    private static string? SummarizeReview(List<LibraryItemHistoryDto> ordered)
    {
        var review = ordered.FirstOrDefault(e => e.EventType == "ReviewItemCreated");
        if (review?.Detail is not null)
        {
            var d = review.Detail.Trim();
            if (d.Length > 60) d = d[..57] + "...";
            if (d.Length >= 3) return d;
        }
        return null;
    }

    private static string? SummarizePersonEnrichment(List<LibraryItemHistoryDto> ordered)
    {
        var personEvents = ordered.Where(e => e.EventType == "PersonHydrated").ToList();
        if (personEvents.Count == 0) return null;
        if (personEvents.Count == 1 && personEvents[0].Detail is not null)
        {
            var d = personEvents[0].Detail!.Trim();
            if (d.Length > 60) d = d[..57] + "...";
            return d.Length >= 3 ? d : null;
        }
        return $"{personEvents.Count} people enriched";
    }

    private static string FormatTimestamp(DateTimeOffset time)
    {
        var local = time.ToLocalTime();
        var today = DateTimeOffset.Now.ToLocalTime().Date;
        if (local.Date == today)
            return $"Today, {local:h:mm tt}";
        if (local.Date == today.AddDays(-1))
            return $"Yesterday, {local:h:mm tt}";
        return local.ToString("MMM d, h:mm tt");
    }
}

<style>
    .ihs-panel {
        font-family: var(--app-font-sans, 'Nunito', sans-serif);
        padding: 14px 14px 14px 28px;
    }

    .ihs-loading {
        display: flex;
        justify-content: center;
        padding: 24px 0;
    }

    .ihs-spinner {
        color: rgba(200, 190, 220, 0.5) !important;
    }

    .ihs-empty {
        font-size: 11px;
        font-weight: 400;
        font-style: italic;
        color: rgba(200, 190, 220, 0.30);
        text-align: center;
        padding: 24px 0;
    }

    .ihs-timeline {
        display: flex;
        flex-direction: column;
    }

    .ihs-entry {
        display: flex;
        gap: 10px;
    }

    .ihs-track {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
        width: 18px;
    }

    .ihs-dot {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .ihs-dot-inner {
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }

    .ihs-connector {
        width: 1px;
        flex: 1;
        min-height: 6px;
        background: var(--tl-accent-primary-soft);
        margin: 4px 0;
    }

    .ihs-content {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding-bottom: 16px;
        flex: 1;
        min-width: 0;
    }

    .ihs-content--last {
        padding-bottom: 0;
    }

    .ihs-label {
        font-size: 11px;
        font-weight: 500;
        color: rgba(200, 190, 220, 0.70);
        line-height: 1.3;
    }

    .ihs-detail {
        font-size: 11px;
        font-weight: 300;
        color: rgba(200, 190, 220, 0.30);
        line-height: 1.3;
    }

    .ihs-time {
        font-size: 11px;
        font-weight: 300;
        color: rgba(200, 190, 220, 0.25);
        margin-top: 2px;
    }
</style>
