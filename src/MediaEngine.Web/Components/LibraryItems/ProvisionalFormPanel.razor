@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Services.Integration
@using MudBlazor

@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar
<div class="pfp-info-box">
    <div class="pfp-info-icon">
        <MudIcon Icon="@Icons.Material.Outlined.Info" Style="font-size: 13px; color: var(--tl-text-muted);" />
    </div>
    <span class="pfp-info-text">
        Marking as provisional - enter enough detail so users can find it and Wikidata can re-match when it becomes available.
    </span>
</div>
<div class="pfp-form-section">
    <span class="pfp-section-label">PROVISIONAL METADATA</span>

    @* Media type *@
    <div class="pfp-field">
        <label class="pfp-label">Media type</label>
        <AppNativeSelect Class="pfp-select" @bind="_mediaType">
            <option value="Books">Book</option>
            <option value="Audiobooks">Audiobook</option>
            <option value="Movies">Movie</option>
            <option value="TV">TV</option>
            <option value="Music">Music</option>
            <option value="Comics">Comic</option>
        </AppNativeSelect>
    </div>

    @* Title (required) *@
    <div class="pfp-field">
        <label class="pfp-label">Title <span class="pfp-required">*</span></label>
        <AppNativeInput Class="pfp-input" Type="text" Placeholder="Enter title..." @bind="_title" @bind:event="oninput" />
    </div>
<div class="pfp-field">
        <label class="pfp-label">@CreatorLabel</label>
        <AppNativeInput Class="pfp-input" Type="text" Placeholder="@($" Enter {CreatorLabel.ToLower()}...")" @bind="_creator" @bind:event="oninput" />
    </div>

    @* Year *@
    <div class="pfp-field">
        <label class="pfp-label">Year</label>
        <AppNativeInput Class="pfp-input" Type="text" Placeholder="e.g. 2024" @bind="_year" @bind:event="oninput" />
    </div>

    @* Description *@
    <div class="pfp-field">
        <label class="pfp-label">Description</label>
        <AppNativeTextarea Class="pfp-textarea" Placeholder="Optional short description..." Rows="3" @bind="_description" @bind:event="oninput"></AppNativeTextarea>
    </div>
<div class="pfp-type-fields">
        <span class="pfp-divider-label">Type-specific fields</span>

        @* Book *@
        @if (_mediaType == "Books")
        {
            <div class="pfp-field-row">
                <div class="pfp-field pfp-field--half">
                    <label class="pfp-label">ISBN / ASIN</label>
                    <AppNativeInput Class="pfp-input" Type="text" Placeholder="e.g. 978-..." @bind="_isbn" @bind:event="oninput" />
                </div>
                <div class="pfp-field pfp-field--half">
                    <label class="pfp-label">Page count</label>
                    <AppNativeInput Class="pfp-input" Type="text" Placeholder="e.g. 412" @bind="_pageCount" @bind:event="oninput" />
                </div>
            </div>
        }

        @* Audiobook *@
        @if (_mediaType == "Audiobooks")
        {
            <div class="pfp-field-row">
                <div class="pfp-field pfp-field--half">
                    <label class="pfp-label">Narrator</label>
                    <AppNativeInput Class="pfp-input" Type="text" Placeholder="Narrator name" @bind="_narrator" @bind:event="oninput" />
                </div>
                <div class="pfp-field pfp-field--half">
                    <label class="pfp-label">ISBN / ASIN</label>
                    <AppNativeInput Class="pfp-input" Type="text" Placeholder="e.g. B0..." @bind="_isbn" @bind:event="oninput" />
                </div>
            </div>
        }

        @* Movie *@
        @if (_mediaType == "Movies")
        {
            <div class="pfp-field-row">
                <div class="pfp-field pfp-field--half">
                    <label class="pfp-label">Director</label>
                    <AppNativeInput Class="pfp-input" Type="text" Placeholder="Director name" @bind="_director" @bind:event="oninput" />
                </div>
                <div class="pfp-field pfp-field--half">
                    <label class="pfp-label">Runtime</label>
                    <AppNativeInput Class="pfp-input" Type="text" Placeholder="e.g. 2h 35m" @bind="_runtime" @bind:event="oninput" />
                </div>
            </div>
        }

        @* TV *@
        @if (_mediaType == "TV")
        {
            <div class="pfp-field pfp-field--half">
                <label class="pfp-label">Seasons</label>
                <AppNativeInput Class="pfp-input" Type="text" Placeholder="e.g. 3" @bind="_seasons" @bind:event="oninput" />
            </div>
        }

        @* Music *@
        @if (_mediaType == "Music")
        {
            <div class="pfp-field pfp-field--half">
                <label class="pfp-label">Track count</label>
                <AppNativeInput Class="pfp-input" Type="text" Placeholder="e.g. 12" @bind="_trackCount" @bind:event="oninput" />
            </div>
        }

        @* Comic *@
        @if (_mediaType == "Comics")
        {
            <div class="pfp-field-row">
                <div class="pfp-field pfp-field--half">
                    <label class="pfp-label">Writer</label>
                    <AppNativeInput Class="pfp-input" Type="text" Placeholder="Writer name" @bind="_writer" @bind:event="oninput" />
                </div>
                <div class="pfp-field pfp-field--half">
                    <label class="pfp-label">Artist</label>
                    <AppNativeInput Class="pfp-input" Type="text" Placeholder="Artist name" @bind="_artist" @bind:event="oninput" />
                </div>
            </div>
        }
    </div>

    @* Re-check notice *@
    <div class="pfp-recheck-box">
        <MudIcon Icon="@Icons.Material.Outlined.Autorenew" Style="font-size: 12px; flex-shrink: 0; margin-top: 1px; color: rgba(133,183,235,0.6);" />
        <span>
            The system will automatically re-check Wikidata when new data becomes available and offer to upgrade this provisional entry.
        </span>
    </div>
</div>
<div class="pfp-actions-section">
    <AppNativeButton Class="pfp-btn-save" OnClick="SaveProvisional" Disabled="@(_saving || string.IsNullOrWhiteSpace(_title))">
        @if (_saving)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                 Style="width: 13px; height: 13px; color: rgba(192,184,224,0.7);" />
            <span>Saving...</span>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Outlined.BookmarkAdd" Style="font-size: 14px;" />
            <span>Save as provisional</span>
        }
    </AppNativeButton>

    <AppNativeButton Class="pfp-btn-cancel" OnClick="() => OnCancelled.InvokeAsync()" Disabled="@_saving">
        Cancel - back to resolve
    </AppNativeButton>
</div>

@code {
    [Parameter, EditorRequired] public LibraryCatalogItemViewModel Item { get; set; } = default!;
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancelled { get; set; }

    private string _mediaType = "Books";
    private string _title = "";
    private string _creator = "";
    private string _year = "";
    private string _description = "";
    private string _narrator = "";
    private string _isbn = "";
    private string _director = "";
    private string _runtime = "";
    private string _seasons = "";
    private string _trackCount = "";
    private string _host = "";
    private string _writer = "";
    private string _artist = "";
    private string _pageCount = "";

    private bool _saving;
    private Guid? _lastItemId;

    protected override void OnParametersSet()
    {
        if (Item.EntityId == _lastItemId) return;

        _lastItemId = Item.EntityId;
        _title = Item.Title ?? "";
        _creator = Item.Author ?? "";
        _mediaType = Item.MediaType is { Length: > 0 } mt ? mt : "Books";
        _year = "";
        _description = "";
        _narrator = "";
        _isbn = "";
        _director = "";
        _runtime = "";
        _seasons = "";
        _trackCount = "";
        _host = "";
        _writer = "";
        _artist = "";
        _pageCount = "";
    }

    private string CreatorLabel => _mediaType switch
    {
        "Books"      => "Author",
        "Audiobooks" => "Author",
        "Movies"     => "Director",
        "TV"         => "Creator",
        "Comics"     => "Writer",
        "Music"      => "Artist",
        _            => "Creator"
    };

    private async Task SaveProvisional()
    {
        if (string.IsNullOrWhiteSpace(_title))
        {
            Snackbar.Add("Title is required.", Severity.Warning);
            return;
        }

        _saving = true;
        StateHasChanged();

        var request = new ProvisionalMetadataRequestDto
        {
            MediaType   = _mediaType,
            Title       = _title,
            Creator     = _creator,
            Year        = _year,
            Description = _description,
            Narrator    = _narrator,
            Isbn        = _isbn,
            Director    = _director,
            Runtime     = _runtime,
            Seasons     = _seasons,
            TrackCount  = _trackCount,
            Host        = _host,
            Writer      = _writer,
            Artist      = _artist,
            PageCount   = _pageCount,
        };

        var success = await Orchestrator.MarkProvisionalAsync(Item.EntityId, request);
        _saving = false;

        if (success)
        {
            Snackbar.Add($"'{_title}' saved as provisional.", Severity.Success);
            await OnSaved.InvokeAsync();
        }
        else
        {
            Snackbar.Add("Failed to save provisional metadata.", Severity.Error);
        }
    }
}