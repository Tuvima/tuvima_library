@using MediaEngine.Web.Models.ViewDTOs
@using MudBlazor

<AppCssElement Tag="div" Class='@($"aic-row {(IsSelected ? "aic-row--selected" : "")} {(IsChecked ? "aic-row--checked" : "")}")'
     Css="@($"border-left: 3px solid {LibraryItemHelpers.GetStatusColor(Item.Status)};")"
     @onclick="HandleRowClick">
@if (ShowCheckbox)
    {
        <div class="aic-checkbox" @onclick="HandleCheckboxClick" @onclick:stopPropagation="true">
            <AppMaterialIcon Icon="@(IsChecked ? Icons.Material.Filled.CheckBox : Icons.Material.Outlined.CheckBoxOutlineBlank)" Css="@($"font-size: 18px; color: {(IsChecked ? "var(--tl-status-success)" : "var(--tl-text-faint)")};")"  />
        </div>
    }
<div class="aic-thumb-wrap">
        @if (!string.IsNullOrEmpty(Item.CoverUrl))
        {
            <div class="cover-hover-wrap tl-u-width-100pct tl-u-height-100pct" >
                <img src="@Item.CoverUrl" alt="@Item.Title" class="aic-thumb-img" loading="lazy" />
                <div class="cover-hover-popup">
                    <img src="@Item.CoverUrl" class="cover-hover-img" alt="" />
                </div>
            </div>
        }
        else
        {
            <div class="aic-thumb-fallback">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="aic-thumb-svg">
                    <rect x="3" y="2" width="14" height="20" rx="1.5"
                          fill="none" stroke="rgba(200,190,220,0.18)" stroke-width="1.2"
                          stroke-dasharray="3 2" />
                    <rect x="5" y="5" width="8" height="1" rx="0.5" fill="rgba(200,190,220,0.14)" />
                    <rect x="5" y="8" width="10" height="1" rx="0.5" fill="rgba(200,190,220,0.10)" />
                    <rect x="5" y="11" width="7" height="1" rx="0.5" fill="rgba(200,190,220,0.10)" />
                    <rect x="5" y="14" width="9" height="1" rx="0.5" fill="rgba(200,190,220,0.08)" />
                </svg>
            </div>
        }
@if (!string.IsNullOrEmpty(Item.MediaType))
        {
            <span class="aic-type-badge" title="@LibraryItemHelpers.FormatMediaType(Item.MediaType)">
                <MudIcon Icon="@LibraryItemHelpers.GetMediaTypeIcon(Item.MediaType)"
                         Class="tl-u-font-size-0-6rem tl-u-color-tl-text-primary" />
            </span>
        }
    </div>
<div class="aic-body">
        <div class="aic-title-row">
            <span class="aic-title">@Item.Title</span>

        </div>

        <div class="aic-meta-row">
            @* Author / year subtitle *@
            @if (!string.IsNullOrEmpty(SubtitleText))
            {
                <span class="aic-subtitle">@SubtitleText</span>
            }
@if (ShowTriggerChip && !string.IsNullOrEmpty(Item.ReviewTrigger))
            {
                var (trigLabel, trigColor, trigIcon) = LibraryItemHelpers.FormatReviewTrigger(Item.ReviewTrigger);
                <AppCssElement Tag="span" Class="aic-trigger-chip"
                      Css="@($"color: {trigColor}; border-color: {trigColor + "44"};")"
                      title="@GetTriggerTooltip(Item.ReviewTrigger)">
                    <AppMaterialIcon Icon="@trigIcon" Css="@($"font-size: 0.6rem; color: {trigColor};")"  />
                    @trigLabel
                </AppCssElement>
            }
        </div>
@if (Item.Status == "Rejected")
        {
            <div class="aic-rejected-row" @onclick:stopPropagation="true">
                <span class="aic-purge-badge">
                    <MudIcon Icon="@Icons.Material.Outlined.Timer" Class="tl-u-font-size-0-6rem" />
                    Purge in @PurgeCountdown
                </span>
                <AppNativeButton Class="aic-unreject-btn" OnClick="HandleUnreject" Title="Un-reject this item">
                    <MudIcon Icon="@Icons.Material.Outlined.Restore" Class="tl-u-font-size-0-75rem" />
                    Un-reject
                </AppNativeButton>
            </div>
        }
    </div>
<div class="aic-timestamp">@RelativeTime</div>
@if (Item.Status != "Rejected" && OnQuickReject.HasDelegate)
    {
        <div class="aic-quick-reject" @onclick:stopPropagation="true">
            @if (_confirmingReject)
            {
                <AppNativeButton Class="aic-reject-confirm" OnClick="HandleConfirmReject" Title="Confirm reject">
                    <MudIcon Icon="@Icons.Material.Outlined.Check" Class="tl-u-font-size-13px" />
                    <span>Sure?</span>
                </AppNativeButton>
                <AppNativeButton Class="aic-reject-cancel" OnClick="HandleCancelReject" Title="Cancel">
                    <MudIcon Icon="@Icons.Material.Outlined.Close" Class="tl-u-font-size-13px" />
                </AppNativeButton>
            }
            else
            {
                <AppNativeButton Class="aic-reject-btn" OnClick="HandleRejectClick" Title="Reject this item">
                    <MudIcon Icon="@Icons.Material.Outlined.Close" Class="tl-u-font-size-15px" />
                </AppNativeButton>
            }
        </div>
    }
</AppCssElement>

@code {
    [Parameter, EditorRequired] public LibraryCatalogItemViewModel Item { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsChecked { get; set; }
    [Parameter] public bool ShowCheckbox { get; set; }
    [Parameter] public EventCallback<LibraryCatalogItemViewModel> OnSelect { get; set; }
    [Parameter] public EventCallback<Guid> OnUnreject { get; set; }
    [Parameter] public EventCallback<Guid> OnCheckedChanged { get; set; }
    [Parameter] public bool ShowTriggerChip { get; set; } = true;
    [Parameter] public EventCallback<Guid> OnQuickReject { get; set; }

    private bool _confirmingReject;

    private string SubtitleText
    {
        get
        {
            var parts = new List<string>();
            if (!string.IsNullOrEmpty(Item.Author))   parts.Add(Item.Author);
            if (!string.IsNullOrEmpty(Item.Year))     parts.Add(Item.Year);
            return string.Join("  -  ", parts);
        }
    }

    private string RelativeTime
    {
        get
        {
            var diff = DateTimeOffset.Now - Item.CreatedAt;
            return diff switch
            {
                { TotalSeconds: < 60 }  => "just now",
                { TotalMinutes: < 60 }  => $"{(int)diff.TotalMinutes}m ago",
                { TotalHours: < 24 }    => $"{(int)diff.TotalHours}h ago",
                { TotalDays: < 7 }      => $"{(int)diff.TotalDays}d ago",
                _                       => Item.CreatedAt.ToLocalTime().ToString("MMM d"),
            };
        }
    }
    private string PurgeCountdown
    {
        get
        {
            var purgeAt = Item.CreatedAt.AddDays(7);
            var remaining = purgeAt - DateTimeOffset.Now;
            if (remaining <= TimeSpan.Zero) return "soon";
            if (remaining.TotalHours < 24)  return $"{(int)remaining.TotalHours}h";
            return $"{(int)remaining.TotalDays}d";
        }
    }

    private static string GetTriggerTooltip(string trigger) => trigger switch
    {
        "MultipleQidMatches"    => "Pick the correct Wikidata entity",
        "LowConfidence"         => "Below the confidence threshold",
        "RetailMatchFailed"     => "No retail match found",
        "AmbiguousMediaType"    => "Unclear media type - needs classification",
        "MissingQid"            => "Needs a manual match to Wikidata",
        "PlaceholderTitle"      => "Missing title metadata",
        "StagedUnidentifiable"  => "Cannot identify this file",
        "ArtworkUnconfirmed"    => "Verify the cover art is correct",
        "MetadataConflict"      => "Conflicting metadata from different sources",
        "UserFixMatch"          => "User requested correction",
        "ArbiterNeedsReview"    => "Review how this was grouped",
        "LanguageMismatch"      => "Foreign language - may need different provider",
        "UserReport"            => "Users flagged a problem with this item",
        _                       => string.Empty
    };

    private async Task HandleRowClick()
    {
        await OnSelect.InvokeAsync(Item);
    }

    private async Task HandleUnreject()
    {
        await OnUnreject.InvokeAsync(Item.EntityId);
    }

    private async Task HandleCheckboxClick()
    {
        await OnCheckedChanged.InvokeAsync(Item.EntityId);
    }

    private void HandleRejectClick()
    {
        _confirmingReject = true;
    }

    private async Task HandleConfirmReject()
    {
        _confirmingReject = false;
        await OnQuickReject.InvokeAsync(Item.EntityId);
    }

    private void HandleCancelReject()
    {
        _confirmingReject = false;
    }
}
