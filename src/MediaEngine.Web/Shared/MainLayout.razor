@namespace MediaEngine.Web.Shared
@inherits LayoutComponentBase
@inject ThemeService ThemeService
@inject DeviceContextService DeviceContext
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer State
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L
@inject ILogger<MainLayout> Logger
@implements IAsyncDisposable

@using MediaEngine.Web.Components.Listen
@using MediaEngine.Web.Models.ViewDTOs
@using MediaEngine.Web.Resources
@using Microsoft.Extensions.Localization

<MudThemeProvider Theme="@ThemeService.Theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider CloseOnEscapeKey="true" />
<MudSnackbarProvider />

@if (!DeviceContext.IsFeatureDisabled("command_palette"))
{
    <CommandPalette @ref="_palette" />
}

<a class="skip-to-content" href="#main-content">@L["Layout_SkipToContent"]</a>

<MudLayout Class="@LayoutShellClass">
    <MudAppBar Fixed="true" Elevation="0" Dense="true" Class="@AppBarClass">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="layout-shell__left-rail">
            <MudLink Href="/" Underline="Underline.None" Class="layout-shell__brand-link" aria-label="Tuvima Library">
                <span class="layout-shell__brand-lockup-shell" aria-hidden="true">
                    <AppLogo Variant="full"
                             Class="layout-shell__brand-lockup"
                             Style="width:100%;height:100%;display:block;" />
                </span>
            </MudLink>

            <nav class="layout-shell__desktop-nav" aria-label="Primary">
                @foreach (var link in _navLinks)
                {
                    <a href="@link.Path"
                       @key="link.Path"
                       class="@GetNavLinkClass(link.Path)"
                       aria-current="@(IsNavActive(link.Path) ? "page" : null)">
                        <span class="layout-shell__nav-link-label" style="@NavLabelStyle">
                            @L[link.LabelKey].Value.ToUpperInvariant()
                        </span>
                    </a>
                }
            </nav>
        </MudStack>

        <div class="layout-shell__search-shell">
            <MudTextField T="string"
                          @bind-Value="_searchTerm"
                          Placeholder="@L["Nav_SearchPlaceholder"]"
                          aria-label="@L["Nav_SearchPlaceholder"]"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Outlined.Search"
                          OnKeyDown="@HandleSearchKeyDown"
                          Class="layout-shell__search" />
        </div>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="layout-shell__actions">
            @if (_reviewCount > 0)
            {
                <MudBadge Overlap="true"
                          Content="@_reviewCount"
                          Color="Color.Warning"
                          Class="layout-shell__review-badge">
                    <MudIconButton Icon="@Icons.Material.Outlined.NotificationsNone"
                                   Color="Color.Inherit"
                                   Class="layout-shell__review-button"
                                   aria-label="@(_reviewCount > 0 ? L["Nav_ReviewPending", _reviewCount] : L["Nav_ReviewQueue"])"
                                   OnClick="@OpenReviewQueue" />
                </MudBadge>
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Outlined.NotificationsNone"
                               Color="Color.Inherit"
                               Class="layout-shell__review-button"
                               aria-label="@L["Nav_ReviewQueue"]"
                               OnClick="@OpenReviewQueue" />
            }

            <span class="layout-shell__account-spacer" aria-hidden="true"></span>

            <MudMenu AnchorOrigin="Origin.BottomRight"
                     TransformOrigin="Origin.TopRight"
                     Class="layout-shell__profile-menu"
                     Style="background:transparent !important; border:0 !important; box-shadow:none !important;"
                     PopoverClass="layout-shell__profile-popover"
                     ListClass="layout-shell__profile-menu-list">
                <ActivatorContent Context="menuContext">
                    <MudButton Variant="Variant.Text"
                               Color="Color.Inherit"
                               Class="layout-shell__profile-trigger"
                               aria-label="@_displayName"
                               OnClick="@menuContext.ToggleAsync">
                        <MudAvatar Size="Size.Medium"
                                   Style="@GetAvatarStyle()"
                                   Class="layout-shell__avatar">
                            @if (!string.IsNullOrWhiteSpace(_avatarImageUrl))
                            {
                                <img src="@_avatarImageUrl" alt="" style="width:100%;height:100%;object-fit:cover;" />
                            }
                            else
                            {
                                @_avatarInitial
                            }
                        </MudAvatar>
                        <span class="layout-shell__profile-copy">
                            <span class="layout-shell__profile-name">@_displayName</span>
                            <span class="layout-shell__profile-role">@_profileRole</span>
                        </span>
                        <MudIcon Icon="@Icons.Material.Outlined.KeyboardArrowDown"
                                 Class="layout-shell__profile-chevron" />
                    </MudButton>
                </ActivatorContent>

                <ChildContent>
                    <MudText Typo="Typo.overline" Class="px-4 pt-3">@L["TopBar_SignedInAs"]</MudText>
                    <MudText Typo="Typo.subtitle2" Class="px-4 pb-3">@_displayName</MudText>
                    @if (_profiles.Count > 1)
                    {
                        <MudDivider />
                        @foreach (var profile in _profiles)
                        {
                            <MudMenuItem Icon="@(profile.Id == _activeProfileId ? Icons.Material.Outlined.Check : Icons.Material.Outlined.Person)"
                                         @key="profile.Id"
                                         OnClick="@(() => SwitchProfileAsync(profile.Id))">
                                @profile.DisplayName
                            </MudMenuItem>
                        }
                    }
                    <MudDivider />
                    <MudMenuItem Href="/settings/review" ForceLoad="true" Target="_self" Icon="@Icons.Material.Outlined.RateReview">
                        @(_reviewCount > 0 ? L["Nav_ReviewPending", _reviewCount] : L["Nav_ReviewQueue"])
                    </MudMenuItem>
                    <MudMenuItem Href="/settings" ForceLoad="true" Target="_self" Icon="@Icons.Material.Outlined.Settings">
                        @L["Nav_Settings"]
                    </MudMenuItem>
                    <MudDivider />
                    <MudText Typo="Typo.caption" Class="px-4 py-3 layout-shell__menu-status">@_engineStatusSummary</MudText>
                </ChildContent>
            </MudMenu>
        </MudStack>
    </MudAppBar>

    @if (ShouldShowEngineStatusBanner)
    {
        <div class="layout-shell__engine-banner">
            <MudIcon Icon="@GetEngineStatusIcon()" Size="Size.Small" />
            <span>@GetEngineStatusBannerText()</span>
        </div>
    }

    <MudMainContent id="main-content" role="main" tabindex="-1" Class="@MainContentClass">
        <MudContainer MaxWidth="MaxWidth.False" Class="@MainContainerClass">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="discovery-hover-host" class="discovery-hover-host" aria-hidden="true"></div>

<ListenNowPlayingBar />

@code {
    private CommandPalette? _palette;
    private string _avatarColor = "var(--tl-accent-primary)";
    private string? _avatarImageUrl;
    private string _avatarInitial = "?";
    private string _currentPath = "/";
    private string _displayName = "User";
    private string _engineStatusSummary = string.Empty;
    private string _profileRole = "Profile";
    private string _searchTerm = string.Empty;
    private Guid? _activeProfileId;
    private int _reviewCount;
    private List<ProfileViewModel> _profiles = [];
    private DotNetObjectReference<MainLayout>? _dotNetRef;
    private const string NavLabelStyle = "font-family:'Montserrat',sans-serif;font-weight:400;font-size:1.02rem;letter-spacing:0.16em;line-height:1;text-transform:uppercase;";

    private readonly record struct ShellNavLink(string Path, string LabelKey);

    private static readonly ShellNavLink[] _navLinks =
    [
        new("/read", "Nav_Read"),
        new("/watch", "Nav_Watch"),
        new("/listen", "Nav_Listen"),
    ];

    private bool IsDetailShell => IsDetailPath(_currentPath);
    private string LayoutShellClass => IsDetailShell ? "app-bg app-bg--detail" : "app-bg";
    private string AppBarClass => IsDetailShell ? "layout-shell__appbar layout-shell__appbar--detail" : "layout-shell__appbar";
    private string MainContentClass => IsDetailShell ? "main-content-with-topbar main-content-with-topbar--detail" : "main-content-with-topbar";
    private string MainContainerClass => IsDetailShell ? "px-0 py-0" : "py-6 px-0";

    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override void OnInitialized()
    {
        DeviceContext.OnChanged += OnDeviceContextChanged;
        Nav.LocationChanged += OnLocationChanged;
        Orchestrator.OnEngineConnectionStateChanged += OnEngineConnectionStateChanged;
        SyncLocationState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var detectedDevice = await JS.InvokeAsync<string>("detectDeviceClass");
        await DeviceContext.InitialiseAsync(detectedDevice);

        if (!DeviceContext.IsFeatureDisabled("command_palette"))
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerCtrlK", _dotNetRef);
        }

        await JS.InvokeVoidAsync("setThemeClass");

        await SyncCultureAsync();
        await LoadActiveProfileAsync();
        await LoadReviewCountAsync();
        await LoadEngineStatusAsync();

        Orchestrator.OnReviewCountChanged += OnReviewCountChanged;
        Orchestrator.OnProfileChanged += OnProfileChanged;

        StateHasChanged();
    }

    [JSInvokable]
    public void OpenPalette() => _palette?.Open();

    private void OnDeviceContextChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        SyncLocationState();
        InvokeAsync(StateHasChanged);
    }

    private Task HandleSearchKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            HandleSearchSubmit();
        }

        return Task.CompletedTask;
    }

    private void HandleSearchSubmit()
    {
        var trimmedSearch = _searchTerm.Trim();
        var url = string.IsNullOrWhiteSpace(trimmedSearch)
            ? "/search"
            : $"/search?q={Uri.EscapeDataString(trimmedSearch)}";

        Nav.NavigateTo(url);
    }

    private void OpenReviewQueue()
    {
        Nav.NavigateTo("/settings/review");
    }

    private Task OpenReviewQueueAsync()
    {
        OpenReviewQueue();
        return Task.CompletedTask;
    }

    private Task OpenSettingsAsync()
    {
        Nav.NavigateTo("/settings");
        return Task.CompletedTask;
    }

    private string GetNavLinkClass(string path) =>
        IsNavActive(path)
            ? "layout-shell__nav-link layout-shell__nav-link--active"
            : "layout-shell__nav-link";

    private void SyncLocationState()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
        var trimmedPath = relativePath.Split('?', '#')[0].Trim('/');
        _currentPath = string.IsNullOrWhiteSpace(trimmedPath)
            ? "/"
            : $"/{trimmedPath}";

        if (!_currentPath.Equals("/search", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
        _searchTerm = query.TryGetValue("q", out var searchTerm)
            ? searchTerm.ToString()
            : string.Empty;
    }

    private async Task SyncCultureAsync()
    {
        try
        {
            var settings = await Orchestrator.GetServerGeneralAsync();
            if (settings is not null && !string.IsNullOrEmpty(settings.DisplayLanguage))
            {
                var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
                var desired = settings.DisplayLanguage.Split('-', '_')[0].ToLowerInvariant();
                if (!string.Equals(currentCulture, desired, StringComparison.OrdinalIgnoreCase))
                {
                    var redirectBack = Uri.EscapeDataString(Nav.Uri);
                    Nav.NavigateTo($"/culture/set?culture={Uri.EscapeDataString(settings.DisplayLanguage)}&redirectUri={redirectBack}", forceLoad: true);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to sync culture during initial layout render.");
        }
    }

    private async Task LoadActiveProfileAsync()
    {
        try
        {
            var profile = await Orchestrator.GetActiveProfileAsync();
            if (profile is null)
            {
                return;
            }

            _profiles = await Orchestrator.GetProfilesAsync();
            _activeProfileId = profile.Id;
            _avatarColor = profile.AvatarColor;
            _avatarImageUrl = profile.AvatarImageUrl;
            _displayName = string.IsNullOrWhiteSpace(profile.DisplayName)
                ? "User"
                : profile.DisplayName.Trim();
            _profileRole = string.IsNullOrWhiteSpace(profile.Role)
                ? "Profile"
                : profile.Role.Trim();
            _avatarInitial = GetAvatarInitial(_displayName);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load active profile for layout shell.");
        }
    }

    private async Task SwitchProfileAsync(Guid profileId)
    {
        var profile = await Orchestrator.SetActiveProfileAsync(profileId);
        if (profile is null)
        {
            return;
        }

        await LoadActiveProfileAsync();
        StateHasChanged();
    }

    private async Task LoadReviewCountAsync()
    {
        try
        {
            _reviewCount = await Orchestrator.RefreshReviewCountAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load review count for layout shell.");
        }
    }

    private async Task LoadEngineStatusAsync()
    {
        try
        {
            var status = await Orchestrator.GetSystemStatusAsync();
            _engineStatusSummary = BuildEngineStatusSummary(status);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load Engine status for layout shell.");
            _engineStatusSummary = BuildEngineStatusSummary(null);
        }
    }

    private void OnReviewCountChanged()
    {
        _reviewCount = Orchestrator.ReviewCount;
        InvokeAsync(StateHasChanged);
    }

    private void OnProfileChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadActiveProfileAsync();
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        DeviceContext.OnChanged -= OnDeviceContextChanged;
        Nav.LocationChanged -= OnLocationChanged;
        Orchestrator.OnReviewCountChanged -= OnReviewCountChanged;
        Orchestrator.OnProfileChanged -= OnProfileChanged;
        Orchestrator.OnEngineConnectionStateChanged -= OnEngineConnectionStateChanged;

        try
        {
            await JS.InvokeVoidAsync("unregisterCtrlK");
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogDebug(ex, "Failed to unregister Ctrl+K during layout disposal.");
        }

        _dotNetRef?.Dispose();
    }

    private string BuildEngineStatusSummary(SystemStatusViewModel? status)
    {
        var engineLabel = status?.IsHealthy == true
            ? L["TopBar_EngineOnline"]
            : L["TopBar_EngineUnavailable"];
        var liveUpdatesLabel = Orchestrator.IsIntercomConnected
            ? L["TopBar_LiveUpdatesConnected"]
            : L["TopBar_LiveUpdatesOffline"];

        return $"{engineLabel} - {liveUpdatesLabel}";
    }

    private bool ShouldShowEngineStatusBanner =>
        Orchestrator.EngineConnectionState is EngineConnectionState.Offline
            or EngineConnectionState.Degraded
            or EngineConnectionState.LiveUpdatesDisconnected;

    private string GetEngineStatusBannerText() => Orchestrator.EngineConnectionState switch
    {
        EngineConnectionState.Offline => L["TopBar_EngineUnavailable"],
        EngineConnectionState.Degraded => L["TopBar_EngineDegradedBanner"],
        EngineConnectionState.LiveUpdatesDisconnected => L["TopBar_LiveUpdatesOffline"],
        _ => _engineStatusSummary,
    };

    private void OnEngineConnectionStateChanged(EngineConnectionState state)
    {
        _engineStatusSummary = state switch
        {
            EngineConnectionState.Offline => BuildEngineStatusSummary(null),
            EngineConnectionState.Degraded => L["TopBar_EngineDegradedSummary"],
            EngineConnectionState.LiveUpdatesDisconnected => $"{L["TopBar_EngineOnline"]} - {L["TopBar_LiveUpdatesOffline"]}",
            EngineConnectionState.Online => $"{L["TopBar_EngineOnline"]} - {L["TopBar_LiveUpdatesConnected"]}",
            _ => _engineStatusSummary,
        };
        InvokeAsync(StateHasChanged);
    }

    private Color GetEngineStatusColor() =>
        _engineStatusSummary.Contains(L["TopBar_EngineOnline"].Value, StringComparison.OrdinalIgnoreCase)
            ? Color.Success
            : Color.Warning;

    private string GetEngineStatusIcon() =>
        _engineStatusSummary.Contains(L["TopBar_EngineOnline"].Value, StringComparison.OrdinalIgnoreCase)
            ? Icons.Material.Filled.CheckCircle
            : Icons.Material.Filled.ErrorOutline;

    private string GetEngineStatusLabel() =>
        _engineStatusSummary.Contains(L["TopBar_EngineOnline"].Value, StringComparison.OrdinalIgnoreCase)
            ? L["TopBar_EngineOnline"]
            : L["TopBar_EngineUnavailable"];

    private bool IsNavActive(string path) =>
        _currentPath.Equals(path, StringComparison.OrdinalIgnoreCase)
        || _currentPath.StartsWith(path + "/", StringComparison.OrdinalIgnoreCase);

    private static bool IsDetailPath(string path)
        => path.StartsWith("/watch/movie/", StringComparison.OrdinalIgnoreCase)
           || path.StartsWith("/watch/tv/", StringComparison.OrdinalIgnoreCase)
           || path.StartsWith("/details/", StringComparison.OrdinalIgnoreCase)
           || path.StartsWith("/book/", StringComparison.OrdinalIgnoreCase)
           || path.StartsWith("/collection/", StringComparison.OrdinalIgnoreCase);

    private static string GetAvatarInitial(string displayName)
    {
        var firstLetter = displayName.FirstOrDefault(static c => !char.IsWhiteSpace(c));
        return firstLetter == default
            ? "?"
            : char.ToUpperInvariant(firstLetter).ToString();
    }

    private string GetAvatarStyle()
    {
        var theme = ThemeService.Theme.PaletteDark;
        var foreground = GetAvatarForeground(_avatarColor, theme.TextPrimary.ToString(), theme.Background.ToString());
        return $"background:{_avatarColor}; color:{foreground};";
    }

    private static string GetAvatarForeground(string backgroundHex, string lightForeground, string darkForeground)
    {
        if (!TryParseHexColor(backgroundHex, out var r, out var g, out var b))
        {
            return lightForeground;
        }

        var luminance = (0.299 * r) + (0.587 * g) + (0.114 * b);
        return luminance >= 160 ? darkForeground : lightForeground;
    }

    private static bool TryParseHexColor(string input, out int red, out int green, out int blue)
    {
        red = green = blue = 0;
        if (string.IsNullOrWhiteSpace(input))
        {
            return false;
        }

        var value = input.Trim().TrimStart('#');
        if (value.Length == 3)
        {
            value = string.Concat(value.Select(character => $"{character}{character}"));
        }

        if (value.Length != 6)
        {
            return false;
        }

        return int.TryParse(value[..2], System.Globalization.NumberStyles.HexNumber, null, out red)
            && int.TryParse(value.Substring(2, 2), System.Globalization.NumberStyles.HexNumber, null, out green)
            && int.TryParse(value.Substring(4, 2), System.Globalization.NumberStyles.HexNumber, null, out blue);
    }
}

<style>
    .skip-to-content {
        position: fixed;
        top: 8px;
        left: 8px;
        z-index: 5000;
        padding: 8px 12px;
        border-radius: 6px;
        background: var(--tl-accent-primary);
        color: #080B14;
        font-weight: 700;
        transform: translateY(-160%);
        transition: transform 0.12s ease;
    }

    .skip-to-content:focus {
        transform: translateY(0);
    }

    .discovery-hover-host {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 4000;
    }

    .discovery-hover-host > .discovery-card-hover-panel {
        pointer-events: auto;
    }

    .layout-shell__engine-banner {
        position: fixed;
        top: 56px;
        left: 0;
        right: 0;
        z-index: 1100;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 32px;
        padding: 6px 16px;
        border-bottom: 1px solid rgba(255, 190, 92, 0.24);
        background: rgba(60, 42, 14, 0.92);
        color: var(--tl-text-primary);
        font-size: 0.82rem;
    }
</style>
