@namespace MediaEngine.Web.Shared
@inherits LayoutComponentBase
@inject ThemeService ThemeService
@inject DeviceContextService DeviceContext
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer State
@inject NavigationManager Nav
@implements IDisposable

@using MediaEngine.Web.Models.ViewDTOs

<MudThemeProvider Theme="@ThemeService.Theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@* Global Command Palette — mounted only when the feature is enabled for this device *@
@if (!DeviceContext.IsFeatureDisabled("command_palette"))
{
    <CommandPalette @ref="_palette" />
}

<MudLayout>
    @* ── Top Navigation Bar ── *@
    <TopBar Variant="@TopBarVariant"
            OnSearchRequested="@(() => _palette?.Toggle())"
            OnHamburgerClick="@(() => _mobileDrawerOpen = !_mobileDrawerOpen)"
            ReviewCount="@_reviewCount"
            AvatarColor="@_avatarColor"
            AvatarInitial="@_avatarInitial"
            DisplayName="@_displayName" />

    @* ── Mobile Navigation Drawer (slide-out, mobile only) ── *@
    @if (DeviceContext.IsMobile)
    {
        <MobileNavDrawer @bind-Open="@_mobileDrawerOpen" />
    }

    @* ── Left Navigation Dock (when config says visible) ── *@
    @if (ShowDock)
    {
        <LeftDock AvatarColor="@_avatarColor"
                  AvatarInitial="@_avatarInitial"
                  DisplayName="@_displayName"
                  ReviewCount="@_reviewCount" />
    }

    @* Full-width main content — top padding clears top bar, left clears dock *@
    <MudMainContent Class="@ContentClass">
        <MudContainer MaxWidth="@ContentMaxWidth" Class="py-6 px-4 px-md-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private CommandPalette? _palette;
    private bool _mobileDrawerOpen;

    // Profile state for the top bar and dock.
    private string _avatarColor = "#C9922E";
    private string _avatarInitial = "?";
    private string _displayName = "User";

    // Review queue badge count for notification bell.
    private int _reviewCount;

    // ── Top bar variant based on device class ─────────────────────────────

    private string TopBarVariant => DeviceContext.Settings.Shell.TopBarStyle;

    // ── Content area — top padding for top bar, left for dock ─────────────

    private bool ShowDock => DeviceContext.Settings.Shell.DockVisible;

    private string ContentClass
    {
        get
        {
            var classes = "main-content-with-topbar";
            if (ShowDock) classes += " main-content-with-dock";
            classes += $" {DeviceContext.Settings.ContentPadding}";
            return classes;
        }
    }

    private MaxWidth ContentMaxWidth =>
        DeviceContext.Settings.ContentMaxWidth switch
        {
            "Full" => MaxWidth.False,
            "ExtraLarge" => MaxWidth.ExtraLarge,
            "Large" => MaxWidth.Large,
            "Medium" => MaxWidth.Medium,
            _ => MaxWidth.ExtraLarge,
        };

    // ── Lifecycle ───────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        DeviceContext.OnChanged += OnDeviceContextChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Detect the device class from the browser.
            var detectedDevice = await JS.InvokeAsync<string>("detectDeviceClass");
            await DeviceContext.InitialiseAsync(detectedDevice);

            // Register Ctrl+K to open the Command Palette.
            if (!DeviceContext.IsFeatureDisabled("command_palette"))
            {
                await JS.InvokeVoidAsync("registerCtrlK", DotNetObjectReference.Create(this));
            }

            // Apply dark theme class to body.
            await JS.InvokeVoidAsync("setThemeClass");

            // Load the active profile.
            await LoadActiveProfileAsync();

            // Load review badge count and subscribe to changes.
            await LoadReviewCountAsync();
            Orchestrator.OnReviewCountChanged += OnReviewCountChanged;
            Orchestrator.OnProfileChanged     += OnProfileChanged;

            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OpenPalette() => _palette?.Open();

    private void OnDeviceContextChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadActiveProfileAsync()
    {
        try
        {
            var profile = await Orchestrator.GetActiveProfileAsync();
            if (profile is not null)
            {
                _avatarColor = profile.AvatarColor;
                _avatarInitial = profile.DisplayName.Length > 0
                    ? profile.DisplayName[0].ToString().ToUpper()
                    : "?";
                _displayName = profile.DisplayName;
                StateHasChanged();
            }
        }
        catch
        {
            // Engine may be offline — keep defaults.
        }
    }

    private async Task LoadReviewCountAsync()
    {
        try
        {
            _reviewCount = await Orchestrator.RefreshReviewCountAsync();
        }
        catch
        {
            // Engine may be offline — badge stays at 0.
        }
    }

    private void OnReviewCountChanged()
    {
        _reviewCount = Orchestrator.ReviewCount;
        InvokeAsync(StateHasChanged);
    }

    private void OnProfileChanged()
    {
        InvokeAsync(LoadActiveProfileAsync);
    }

    public void Dispose()
    {
        DeviceContext.OnChanged            -= OnDeviceContextChanged;
        Orchestrator.OnReviewCountChanged  -= OnReviewCountChanged;
        Orchestrator.OnProfileChanged      -= OnProfileChanged;
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;
}

<style>
    /* Dock is floating — no left padding offset needed */
    .main-content-with-dock {
        /* intentionally empty — floating dock does not push content */
    }

    /* Content area clears the fixed 64px top bar */
    .main-content-with-topbar {
        padding-top: 64px !important;
    }
</style>
