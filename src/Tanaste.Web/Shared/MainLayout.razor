@namespace Tanaste.Web.Shared
@inherits LayoutComponentBase
@inject ThemeService ThemeService
@inject DeviceContextService DeviceContext
@inject UIOrchestratorService Orchestrator
@inject UniverseStateContainer State
@inject NavigationManager Nav
@implements IDisposable

@using Tanaste.Web.Models.ViewDTOs

<MudThemeProvider Theme="@ThemeService.Theme" IsDarkMode="@_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@* Global Command Palette — mounted only when the feature is enabled for this device *@
@if (!DeviceContext.IsFeatureDisabled("command_palette"))
{
    <CommandPalette @ref="_palette" />
}

<MudLayout>
    @* ── Header: Logo left, Action Cluster right ── *@
    <MudAppBar Elevation="0" Class="@AppBarClass">

        @* Logo — anchored left as home link *@
        <MudLink Href="/" Underline="Underline.None" Class="d-flex align-center"
                 Style="text-decoration: none;">
            <img src="@LogoSrc" alt="Tanaste" class="tanaste-logo"
                 style="@LogoStyle" />
        </MudLink>

        <MudSpacer />

        @* Action Cluster — configurable icon buttons on the right *@
        @{
            var cluster = _navigationConfig.ActionCluster;
        }

        @foreach (var item in cluster.Items.Where(i => i.Enabled))
        {
            @if (item.Key == "cast" && !DeviceContext.IsFeatureDisabled("avatar_menu"))
            {
                <MudTooltip Text="Cast — Coming soon" Arrow="true" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Filled.Cast"
                                   Color="Color.Inherit"
                                   Disabled="true"
                                   title="Cast — Coming soon" />
                </MudTooltip>
            }
            else if (item.Key == "profile" && !DeviceContext.IsFeatureDisabled("avatar_menu"))
            {
                <MudAvatar Size="Size.Medium"
                           Style="@($"background: {_avatarColor}; cursor: pointer;")"
                           title="Settings"
                           @onclick="@(() => Nav.NavigateTo("/settings"))">
                    @_avatarInitial
                </MudAvatar>
            }
        }
    </MudAppBar>

    @* Full-width main content — padding and max-width driven by device context *@
    <MudMainContent Class="@ContentClass">
        <MudContainer MaxWidth="@ContentMaxWidth" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>

    @* Floating Navigation Tray — content-aware virtual library filter + search *@
    <NavigationTray Config="@_navigationConfig.Tray"
                    ActiveLibraryKey="@State.ActiveLibraryFilter?.Key"
                    AvailableMediaTypes="@State.AvailableMediaTypes"
                    OnLibrarySelected="@OnLibrarySelected"
                    OnSearchRequested="@(() => _palette?.Toggle())" />
</MudLayout>

@code {
    private bool _isDark = true;

    private CommandPalette? _palette;

    // Profile state for the header action cluster.
    private string _avatarColor   = "#7C4DFF";
    private string _avatarInitial = "?";

    // Navigation configuration — loaded from profile, falls back to defaults.
    private NavigationConfigViewModel _navigationConfig = NavigationDefaults.CreateDefault();

    // ── AppBar styling driven by Shell.AppBarStyle ──────────────────────────

    private string AppBarClass =>
        DeviceContext.Settings.Shell.AppBarStyle switch
        {
            "compact"   => "spatial-appbar spatial-appbar-compact",
            "oversized" => "spatial-appbar spatial-appbar-oversized",
            "minimal"   => "spatial-appbar spatial-appbar-minimal",
            _           => "spatial-appbar",
        };

    // ── Logo variant driven by Shell.LogoVariant ────────────────────────────

    private string LogoSrc =>
        DeviceContext.Settings.Shell.LogoVariant switch
        {
            "icon"           => "images/tanaste-icon.svg",
            "icon-large"     => "images/tanaste-icon.svg",
            "wordmark-large" => "images/tanaste-logo.svg",
            _                => "images/tanaste-logo.svg",
        };

    private string LogoStyle =>
        DeviceContext.Settings.Shell.LogoVariant switch
        {
            "icon"           => "height: 28px; display: block;",
            "icon-large"     => "height: 44px; display: block;",
            "wordmark-large" => "height: 48px; display: block;",
            _                => "height: 32px; display: block;",
        };

    // ── Content area driven by device context ───────────────────────────────

    private string ContentClass =>
        $"pt-16 {DeviceContext.Settings.ContentPadding}";

    private MaxWidth ContentMaxWidth =>
        DeviceContext.Settings.ContentMaxWidth switch
        {
            "Full"       => MaxWidth.False,
            "ExtraLarge" => MaxWidth.ExtraLarge,
            "Large"      => MaxWidth.Large,
            "Medium"     => MaxWidth.Medium,
            _            => MaxWidth.ExtraLarge,
        };

    // ── Lifecycle ───────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _isDark = ThemeService.IsDarkMode;
        ThemeService.OnThemeChanged += OnThemeUpdated;
        DeviceContext.OnChanged += OnDeviceContextChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Detect the device class from the browser (URL param → localStorage → auto).
            var detectedDevice = await JS.InvokeAsync<string>("detectDeviceClass");

            // Initialise the device context with resolved settings from the Engine.
            await DeviceContext.InitialiseAsync(detectedDevice);

            // Apply dark mode from resolved settings (device may force dark mode).
            if (DeviceContext.Settings.Constraints.ForceDarkMode && !ThemeService.IsDarkMode)
            {
                ThemeService.ToggleTheme();
                _isDark = true;
            }
            else
            {
                _isDark = ThemeService.IsDarkMode;
            }

            // Apply accent colour from resolved settings.
            if (!string.IsNullOrWhiteSpace(DeviceContext.Settings.AccentColor))
            {
                ThemeService.SetHubAccent(DeviceContext.Settings.AccentColor);
            }

            // Register Ctrl+K to open the Command Palette (only if enabled).
            if (!DeviceContext.IsFeatureDisabled("command_palette"))
            {
                await JS.InvokeVoidAsync("registerCtrlK", DotNetObjectReference.Create(this));
            }

            // Seed the body class so logos render correctly before any toggle.
            await JS.InvokeVoidAsync("setThemeClass", _isDark);

            // Load the active profile for the avatar dropdown.
            await LoadActiveProfileAsync();

            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OpenPalette() => _palette?.Open();

    private void OnThemeUpdated()
    {
        _isDark = ThemeService.IsDarkMode;
        InvokeAsync(StateHasChanged);
    }

    private void OnDeviceContextChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadActiveProfileAsync()
    {
        try
        {
            var profile = await Orchestrator.GetActiveProfileAsync();
            if (profile is not null)
            {
                _avatarColor = profile.AvatarColor;
                _avatarInitial = profile.DisplayName.Length > 0
                    ? profile.DisplayName[0].ToString().ToUpper()
                    : "?";
                _navigationConfig = NavigationDefaults.Deserialize(profile.NavigationConfig);
                StateHasChanged();
            }
        }
        catch
        {
            // Engine may be offline — keep defaults.
        }
    }

    private void OnLibrarySelected(VirtualLibrary? library)
    {
        State.SetActiveLibrary(library);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeUpdated;
        DeviceContext.OnChanged -= OnDeviceContextChanged;
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;
}
