@namespace Tanaste.Web.Components.Universe

@* "Last Journey" Smart Tile — Spatial Bento hero card.
   Supports multiple layouts driven by device context:
     "two-column"           → Default web: artwork (left) + info (right)
     "stacked"              → Mobile: vertical stack, centred
     "two-column-oversized" → Television: larger artwork, bigger text
     "hidden"               → Automotive: not rendered (parent handles this) *@

@if (Hub is not null && Layout != "hidden")
{
    <div class="hub-hero @LayoutClass" style="@HeroGlowStyle">
        <div class="hero-glass-overlay" />

        <div class="hero-inner">
            @* ── Artwork column ── *@
            <div class="hero-artwork">
                <div class="hero-artwork-placeholder"
                     style="background: linear-gradient(145deg, @(Hub.DominantHexColor)44, @(Hub.DominantHexColor)11);">
                    <MudIcon Icon="@Icons.Material.Filled.Movie"
                             Style="@($"font-size: {ArtworkIconSize}px; color: var(--tanaste-icon-soft);")" />
                </div>
            </div>

            @* ── Info column: title + progress ── *@
            <div class="hero-info">
                <MudText Typo="@TitleTypo" Class="mb-1" Style="font-weight: 600;">
                    @Hub.DisplayName: Last Journey
                </MudText>
                <MudText Typo="Typo.body1" Style="color: var(--tanaste-text-soft);" Class="mb-1">
                    Continue your Journey in @Hub.DisplayName
                </MudText>
                <MudText Typo="Typo.body2" Style="color: var(--tanaste-text-faint);" Class="mb-4">
                    @Hub.MediaTypes — @Hub.WorkCount @(Hub.WorkCount == 1 ? "work" : "works")
                </MudText>

                @* ── Progress indicators ── *@
                <MudStack Row="@(!IsStacked)" Spacing="3" Class="hero-progress-row">
                    <ProgressIndicator Icon="@Icons.Material.Filled.PlayCircle"
                                       Value="@WatchValue"
                                       Percent="@WatchPercent"
                                       Label="@WatchLabel" />

                    <ProgressIndicator Icon="@Icons.Material.Filled.MenuBook"
                                       Value="@ReadValue"
                                       Percent="@ReadPercent"
                                       Label="@ReadLabel" />

                    <ProgressIndicator Icon="@Icons.Material.Filled.Headphones"
                                       Value="@ListenValue"
                                       Percent="@ListenPercent"
                                       Label="@ListenLabel" />
                </MudStack>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public HubViewModel? Hub { get; set; }

    /// <summary>
    /// Layout variant driven by <c>DeviceContext.Settings.Pages.Home.HubHeroLayout</c>.
    /// Accepted values: "two-column" (default), "stacked", "two-column-oversized", "hidden".
    /// </summary>
    [Parameter] public string Layout { get; set; } = "two-column";

    // ── Layout helpers ─────────────────────────────────────────────────────────

    private bool IsStacked =>
        string.Equals(Layout, "stacked", StringComparison.OrdinalIgnoreCase);

    private bool IsOversized =>
        string.Equals(Layout, "two-column-oversized", StringComparison.OrdinalIgnoreCase);

    private string LayoutClass => Layout switch
    {
        "stacked"              => "hub-hero-stacked",
        "two-column-oversized" => "hub-hero-oversized",
        _                      => string.Empty,
    };

    private Typo TitleTypo => IsOversized ? Typo.h3 : Typo.h4;

    private int ArtworkIconSize => IsOversized ? 80 : 64;

    // ── Progress data (placeholder until UserState API exists) ────────────────

    private string WatchValue   => HasVideo  ? "—"  : "—";
    private double WatchPercent => 0;
    private string WatchLabel   => HasVideo  ? "Watch" : "No video";

    private string ReadValue    => HasBook   ? "—"  : "—";
    private double ReadPercent  => 0;
    private string ReadLabel    => HasBook   ? "Read"  : "No book";

    private string ListenValue  => HasAudio  ? "—"  : "—";
    private double ListenPercent => 0;
    private string ListenLabel  => HasAudio  ? "Listen" : "No audio";

    // ── Media type presence helpers ──────────────────────────────────────────

    private bool HasVideo => Hub?.Works.Any(w =>
        w.MediaType.Contains("video", StringComparison.OrdinalIgnoreCase) ||
        w.MediaType.Contains("movie", StringComparison.OrdinalIgnoreCase)) ?? false;

    private bool HasBook => Hub?.Works.Any(w =>
        w.MediaType.Contains("epub", StringComparison.OrdinalIgnoreCase) ||
        w.MediaType.Contains("book", StringComparison.OrdinalIgnoreCase)) ?? false;

    private bool HasAudio => Hub?.Works.Any(w =>
        w.MediaType.Contains("audio", StringComparison.OrdinalIgnoreCase)) ?? false;

    // ── Dynamic glow from hub accent colour ─────────────────────────────────

    private string HeroGlowStyle =>
        $"--hero-glow: {Hub?.DominantHexColor ?? "#7C4DFF"}33; " +
        $"--hero-border: {Hub?.DominantHexColor ?? "#7C4DFF"}40;";
}

<style>
    .hub-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        background: var(--tanaste-glass-inner-bg);
        border: 1px solid var(--hero-border, rgba(124, 77, 255, 0.25));
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow:
            0 8px 40px rgba(0, 0, 0, 0.40),
            0 0 80px var(--hero-glow, rgba(124, 77, 255, 0.20));
        margin-bottom: 2rem;
    }

    .hero-glass-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 80% 20%, var(--hero-glow, rgba(124, 77, 255, 0.15)), transparent 70%);
        pointer-events: none;
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        gap: 2rem;
        padding: 1.5rem 2rem;
        align-items: center;
    }

    .hero-artwork {
        flex-shrink: 0;
        width: 180px;
        height: 240px;
    }

    .hero-artwork-placeholder {
        width: 100%;
        height: 100%;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--tanaste-glass-border);
    }

    .hero-info {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .hero-progress-row {
        flex-wrap: wrap;
    }

    /* ── Stacked layout (mobile) ─────────────────────────────────────────── */
    .hub-hero-stacked .hero-inner {
        flex-direction: column;
        text-align: center;
        padding: 1.25rem;
    }

    .hub-hero-stacked .hero-artwork {
        width: 140px;
        height: 190px;
    }

    .hub-hero-stacked .hero-progress-row {
        justify-content: center;
    }

    /* ── Oversized layout (television) ───────────────────────────────────── */
    .hub-hero-oversized {
        border-radius: 40px;
    }

    .hub-hero-oversized .hero-inner {
        padding: 2.5rem 3rem;
        gap: 3rem;
    }

    .hub-hero-oversized .hero-artwork {
        width: 240px;
        height: 320px;
    }

    .hub-hero-oversized .hero-artwork-placeholder {
        border-radius: 28px;
    }

    /* Responsive fallback: stack on small viewports regardless of layout */
    @@media (max-width: 768px) {
        .hero-inner {
            flex-direction: column;
            text-align: center;
            padding: 1.25rem;
        }

        .hero-artwork {
            width: 140px;
            height: 190px;
        }

        .hero-progress-row {
            justify-content: center;
        }
    }
</style>
