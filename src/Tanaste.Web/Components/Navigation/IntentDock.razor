@namespace Tanaste.Web.Components.Navigation
@inject DeviceContextService DeviceContext
@implements IDisposable

@* Floating Intent Dock — fixed at the bottom centre of the viewport.
   Items and styling driven by device context (Shell.IntentDockItems + IntentDockStyle).
   Uses glassmorphic styling consistent with the Spatial Bento design. *@

<div class="intent-dock">
    <MudPaper Elevation="0" Class="@DockSurfaceClass">
        <MudStack Row="true" Spacing="@DockSpacing" AlignItems="AlignItems.Center"
                  Justify="Justify.Center" Class="@DockPadding">

            @foreach (var item in DockItems)
            {
                var intent = ParseIntent(item);
                <MudTooltip Text="@item" Arrow="true" Placement="Placement.Top">
                    <MudIconButton Icon="@GetDockIcon(item)"
                                   Size="@DockButtonSize"
                                   Color="@(ActiveIntent == intent ? Color.Primary : Color.Default)"
                                   Style="@DockButtonStyle(intent)"
                                   OnClick="@(() => SetIntent(intent))"
                                   title="@item" />
                </MudTooltip>
            }

        </MudStack>

        @* Active intent label *@
        <div class="intent-dock-label">
            <MudText Typo="Typo.caption"
                     Style="color: var(--tanaste-text-muted); text-align: center; padding-bottom: 6px;">
                @ActiveIntent.ToString()
            </MudText>
        </div>
    </MudPaper>
</div>

@code {
    /// <summary>The currently active intent filter.</summary>
    [Parameter] public DockIntent ActiveIntent { get; set; } = DockIntent.Hubs;

    /// <summary>Fires when the user selects a different intent.</summary>
    [Parameter] public EventCallback<DockIntent> OnIntentChanged { get; set; }

    // ── Device-driven dock configuration ────────────────────────────────────

    private IReadOnlyList<string> DockItems =>
        DeviceContext.Settings.Shell.IntentDockItems is { Count: > 0 }
            ? DeviceContext.Settings.Shell.IntentDockItems
            : ["Hubs", "Watch", "Read", "Listen"];

    private bool IsOversized =>
        string.Equals(DeviceContext.Settings.Shell.IntentDockStyle, "oversized", StringComparison.OrdinalIgnoreCase);

    private string DockSurfaceClass =>
        IsOversized
            ? "intent-dock-surface intent-dock-oversized"
            : "intent-dock-surface";

    private int DockSpacing => IsOversized ? 6 : 4;

    private string DockPadding => IsOversized ? "pa-3 px-8" : "pa-2 px-6";

    private Size DockButtonSize => IsOversized ? Size.Large : Size.Medium;

    // ── Lifecycle ───────────────────────────────────────────────────────────

    protected override void OnInitialized() =>
        DeviceContext.OnChanged += OnDeviceChanged;

    private void OnDeviceChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() =>
        DeviceContext.OnChanged -= OnDeviceChanged;

    // ── Helpers ─────────────────────────────────────────────────────────────

    private async Task SetIntent(DockIntent intent)
    {
        ActiveIntent = intent;
        await OnIntentChanged.InvokeAsync(intent);
    }

    private string DockButtonStyle(DockIntent intent)
    {
        var radius = IsOversized ? "20px" : "16px";
        return ActiveIntent == intent
            ? $"background: var(--tanaste-active-overlay); border-radius: {radius};"
            : $"border-radius: {radius};";
    }

    private static DockIntent ParseIntent(string name) =>
        name switch
        {
            "Hubs"   => DockIntent.Hubs,
            "Watch"  => DockIntent.Watch,
            "Read"   => DockIntent.Read,
            "Listen" => DockIntent.Listen,
            _        => DockIntent.Hubs,
        };

    private static string GetDockIcon(string name) =>
        name switch
        {
            "Hubs"   => Icons.Material.Filled.Hub,
            "Watch"  => Icons.Material.Filled.PlayCircle,
            "Read"   => Icons.Material.Filled.MenuBook,
            "Listen" => Icons.Material.Filled.Headphones,
            _        => Icons.Material.Filled.Hub,
        };

    public enum DockIntent { Hubs, Watch, Read, Listen }
}

<style>
    .intent-dock {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1200;
        pointer-events: auto;
    }

    .intent-dock-surface {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: var(--tanaste-glass-bg) !important;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--tanaste-glass-border);
        border-radius: 28px !important;
        box-shadow: var(--tanaste-shadow);
    }

    .intent-dock-oversized {
        border-radius: 36px !important;
    }

    .intent-dock-label {
        text-align: center;
    }
</style>
