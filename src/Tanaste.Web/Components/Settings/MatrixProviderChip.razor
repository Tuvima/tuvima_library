@namespace Tanaste.Web.Components.Settings
@using Tanaste.Web.Models

@* Compact provider chip rendered inside MudDropZone columns and the available providers row.
   Shows a coloured accent bar, priority badge, provider name, and status dot.
   Supports highlight/dim states for hover-driven column compatibility hints. *@

<div class="@ChipCssClass"
     style="--chip-accent: @Item.Color;"
     @onclick="@OnChipClicked"
     @onclick:stopPropagation="true">

    @* ── Accent bar ─────────────────────────── *@
    <div class="chip-accent-bar"></div>

    @* ── Priority badge (only in columns, not available row) ── *@
    @if (!IsDisabled)
    {
        <div class="chip-priority @(Position == 0 ? "primary" : "")">
            @(Position + 1)
        </div>
    }

    @* ── Provider icon ──────────────────────── *@
    <MudIcon Icon="@Item.Icon" Size="Size.Small"
             Style="@($"color: {Item.Color}; opacity: 0.9; flex-shrink: 0;")" />

    @* ── Provider name ──────────────────────── *@
    <div class="chip-name">
        <MudText Typo="Typo.body2"
                 Style="@(Position == 0 && !IsDisabled ? "font-weight: 600;" : "")">
            @Item.DisplayName
        </MudText>
    </div>

    @* ── Status dot ─────────────────────────── *@
    <div class="chip-status-dot"
         style="background-color: @(Item.Enabled ? "var(--mud-palette-success)" : "var(--tanaste-text-muted)");"
         title="@(Item.Enabled ? "Active" : "Disabled")">
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public MatrixItem Item { get; set; } = default!;

    /// <summary>0-based position within the column (used for badge).</summary>
    [Parameter] public int Position { get; set; }

    /// <summary>Whether this chip is in the available providers row (no priority badge).</summary>
    [Parameter] public bool IsDisabled { get; set; }

    /// <summary>Fires when the chip is clicked (opens provider flyout).</summary>
    [Parameter] public EventCallback OnEditClicked { get; set; }

    /// <summary>When true, this chip is highlighted (its provider is hovered and supports this column).</summary>
    [Parameter] public bool IsHighlighted { get; set; }

    /// <summary>When true, this chip is dimmed (another provider is hovered).</summary>
    [Parameter] public bool IsDimmed { get; set; }

    private string ChipCssClass
    {
        get
        {
            var cls = "matrix-chip";
            if (IsDisabled) cls += " disabled";
            if (IsHighlighted) cls += " highlighted";
            if (IsDimmed) cls += " dimmed";
            return cls;
        }
    }

    private async Task OnChipClicked()
    {
        if (OnEditClicked.HasDelegate)
            await OnEditClicked.InvokeAsync();
    }
}

<style>
    .matrix-chip {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border-radius: 10px;
        border: 1px solid var(--tanaste-glass-border);
        background: var(--tanaste-glass-bg);
        cursor: grab;
        user-select: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
        min-height: 36px;
    }

    .matrix-chip:hover {
        border-color: var(--chip-accent, var(--mud-palette-primary));
        box-shadow: 0 0 0 1px var(--chip-accent, var(--mud-palette-primary));
    }

    .matrix-chip:active {
        cursor: grabbing;
    }

    .matrix-chip.disabled {
        opacity: 0.8;
    }

    .matrix-chip.highlighted {
        border-color: var(--mud-palette-success);
        box-shadow: 0 0 0 2px rgba(76, 175, 80, 0.35);
    }

    .matrix-chip.dimmed {
        opacity: 0.25;
        pointer-events: none;
    }

    .chip-accent-bar {
        width: 4px;
        height: 20px;
        border-radius: 2px;
        background: var(--chip-accent, var(--mud-palette-primary));
        flex-shrink: 0;
    }

    .chip-priority {
        font-size: 0.6rem;
        font-weight: 700;
        min-width: 18px;
        height: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: var(--tanaste-glass-border);
        color: var(--tanaste-text-muted);
        flex-shrink: 0;
    }

    .chip-priority.primary {
        background: var(--mud-palette-primary);
        color: white;
    }

    .chip-name {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .chip-status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }
</style>
