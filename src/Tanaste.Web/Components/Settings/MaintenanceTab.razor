@namespace Tanaste.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar

@* Maintenance — Activity timeline, retention policy, and manual prune. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Section Header ──────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Build" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">Maintenance</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        System activity ledger, retention policy, and housekeeping tools.
    </MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else
    {
        @* ── Section 1: Recent Activity ──────────────────────────────────── *@

        <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Outlined.Timeline"
                         Color="Color.Primary" Class="mr-2" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600; flex: 1;">
                    Recent Activity
                </MudText>
                @if (_stats is not null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                             Style="opacity: 0.7;">
                        @_stats.TotalEntries.ToString("N0") entries
                    </MudChip>
                }
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               Color="Color.Default"
                               title="Refresh activity list"
                               OnClick="@RefreshAsync" />
            </MudStack>

            @if (_entries.Count == 0)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                    <MudIcon Icon="@Icons.Material.Filled.EventNote"
                             Size="Size.Large"
                             Style="font-size: 3rem; opacity: 0.3;" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                        No activity recorded yet. Events will appear here as the Engine
                        ingests files, refreshes metadata, and runs maintenance tasks.
                    </MudText>
                </MudStack>
            }
            else
            {
                <MudStack Spacing="0">
                    @foreach (var entry in _entries)
                    {
                        <div style="@TimelineRowStyle">
                            @* Timeline dot + line *@
                            <div style="display: flex; flex-direction: column; align-items: center; width: 36px; flex-shrink: 0;">
                                <MudIcon Icon="@ActionIcon(entry.ActionType)"
                                         Size="Size.Small"
                                         Color="@ActionColor(entry.ActionType)"
                                         Style="font-size: 1.1rem;" />
                                <div style="flex: 1; width: 1px; background: var(--tanaste-glass-border); margin-top: 4px;" />
                            </div>

                            @* Entry content *@
                            <div style="flex: 1; padding-bottom: 16px;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                        @ActionLabel(entry.ActionType)
                                    </MudText>
                                    @if (!string.IsNullOrEmpty(entry.HubName))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                                 Style="font-size: 0.7rem; height: 20px;">
                                            @entry.HubName
                                        </MudChip>
                                    }
                                    <MudSpacer />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @entry.RelativeTime
                                    </MudText>
                                </MudStack>
                                @if (!string.IsNullOrEmpty(entry.Detail))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary"
                                             Style="margin-top: 2px;">
                                        @entry.Detail
                                    </MudText>
                                }
                            </div>
                        </div>
                    }
                </MudStack>
            }
        </MudPaper>

        @* ── Section 2: Retention Policy ──────────────────────────────────── *@

        <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Outlined.DeleteSweep"
                         Color="Color.Primary" Class="mr-2" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                    Retention Policy
                </MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Activity entries older than the retention period are automatically
                pruned once per day. You can also trigger a manual cleanup below.
            </MudText>

            @if (_stats is not null)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Class="mb-4">
                    <MudText Typo="Typo.body2" Style="white-space: nowrap;">
                        Retention period:
                    </MudText>
                    <MudText Typo="Typo.h6" Color="Color.Primary">
                        @_stats.RetentionDays days
                    </MudText>
                </MudStack>
            }

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.CleaningServices"
                       OnClick="@TriggerPruneAsync"
                       Disabled="@_pruning">
                @(_pruning ? "Pruning..." : "Prune Now")
            </MudButton>

            @if (_lastPruneResult is not null)
            {
                <MudAlert Severity="Severity.Success" Class="mt-4">
                    Removed @_lastPruneResult.Deleted entries
                    (retention: @_lastPruneResult.RetentionDays days).
                </MudAlert>
            }
        </MudPaper>

        @* ── Section 3: Library Crawl (stub for Phase 3) ──────────────────── *@

        <MudPaper Elevation="0" Style="@InnerCardStyle" Class="mb-6">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Outlined.FindInPage"
                         Color="Color.Secondary" Class="mr-2" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                    Library Crawl
                </MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Scan the Library Root for tanaste.xml sidecars and rebuild the database
                from the filesystem. Coming in a future update.
            </MudText>
        </MudPaper>

        @* ── Section 4: Weekly Sync (stub for Phase 4) ────────────────────── *@

        <MudPaper Elevation="0" Style="@InnerCardStyle">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Outlined.Sync"
                         Color="Color.Secondary" Class="mr-2" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                    Weekly Sync
                </MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Periodic metadata refresh with artwork hash verification.
                Coming in a future update.
            </MudText>
        </MudPaper>
    }

</MudPaper>

@code {
    // ── Style constants ──────────────────────────────────────────────────────────

    private const string GlassStyle =
        "background: var(--tanaste-glass-bg); " +
        "border: 1px solid var(--tanaste-glass-border); " +
        "backdrop-filter: blur(10px); " +
        "-webkit-backdrop-filter: blur(10px); " +
        "border-radius: 32px; " +
        "padding: 32px;";

    private const string InnerCardStyle =
        "background: var(--tanaste-glass-inner-bg); " +
        "border: 1px solid var(--tanaste-glass-inner-border); " +
        "border-radius: 16px; " +
        "padding: 24px;";

    private const string TimelineRowStyle =
        "display: flex; gap: 12px; align-items: flex-start;";

    // ── State ────────────────────────────────────────────────────────────────────

    private bool _loading = true;
    private bool _pruning;
    private List<ActivityEntryViewModel> _entries = [];
    private ActivityStatsViewModel?      _stats;
    private PruneResultViewModel?        _lastPruneResult;

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();

        var entriesTask = Orchestrator.GetRecentActivityAsync(50);
        var statsTask   = Orchestrator.GetActivityStatsAsync();
        await Task.WhenAll(entriesTask, statsTask);

        _entries = entriesTask.Result;
        _stats   = statsTask.Result;
        _loading = false;
    }

    private async Task TriggerPruneAsync()
    {
        _pruning = true;
        _lastPruneResult = null;
        StateHasChanged();

        var result = await Orchestrator.TriggerPruneAsync();
        _pruning = false;

        if (result is not null)
        {
            _lastPruneResult = result;
            Snackbar.Add($"Pruned {result.Deleted} entries", Severity.Success);
            await RefreshAsync();   // Reload the timeline after pruning
        }
        else
        {
            Snackbar.Add("Prune failed — is the Engine running?", Severity.Error);
        }
    }

    // ── Action type display helpers ──────────────────────────────────────────────

    private static readonly Dictionary<string, (string Icon, string Label, Color Color)> ActionMeta = new()
    {
        ["FileIngested"]     = (Icons.Material.Filled.FilePresent,    "File Ingested",     Color.Success),
        ["MetadataHydrated"] = (Icons.Material.Filled.Science,        "Metadata Hydrated", Color.Info),
        ["HashVerified"]     = (Icons.Material.Filled.Fingerprint,    "Hash Verified",     Color.Info),
        ["PathUpdated"]      = (Icons.Material.Filled.DriveFileMove,  "Path Updated",      Color.Warning),
        ["SyncCompleted"]    = (Icons.Material.Filled.CloudDone,      "Sync Completed",    Color.Success),
        ["CrawlStarted"]    = (Icons.Material.Filled.Search,         "Crawl Started",     Color.Info),
        ["CrawlFinished"]   = (Icons.Material.Filled.SearchOff,      "Crawl Finished",    Color.Success),
        ["MetadataRefreshed"]= (Icons.Material.Filled.Autorenew,      "Metadata Refreshed",Color.Info),
        ["SidecarUpdated"]      = (Icons.Material.Filled.Description,     "Sidecar Updated",      Color.Default),
        ["ActivityPruned"]      = (Icons.Material.Filled.CleaningServices,"Activity Pruned",     Color.Warning),
        ["BridgeSyncUpdated"]   = (Icons.Material.Filled.Link,            "Bridge Sync Updated",  Color.Info),
        ["PersonHydrated"]      = (Icons.Material.Filled.Person,          "Person Hydrated",      Color.Success),
        ["WeeklySyncStarted"]   = (Icons.Material.Filled.Sync,            "Weekly Sync Started",  Color.Info),
        ["AffiliateGenerated"]  = (Icons.Material.Filled.LocalOffer,      "Affiliate Generated",  Color.Success),
    };

    private static string ActionIcon(string actionType) =>
        ActionMeta.TryGetValue(actionType, out var m) ? m.Icon : Icons.Material.Filled.Info;

    private static string ActionLabel(string actionType) =>
        ActionMeta.TryGetValue(actionType, out var m) ? m.Label : actionType;

    private static Color ActionColor(string actionType) =>
        ActionMeta.TryGetValue(actionType, out var m) ? m.Color : Color.Default;
}
