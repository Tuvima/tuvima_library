@namespace Tanaste.Web.Components.Settings

@* Universe Settings — permanent, read-only reference for the Wikidata universe provider.

   Wikidata is the permanent universe provider. It spans all media types and
   provides authoritative Q-identifiers, external bridge IDs, and deep
   enrichment data via SPARQL. This page is purely informational — no editing,
   no testing, no Engine connection required. It renders instantly from
   compiled default data. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Header ────────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Public" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">Universe Provider</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Wikidata is the permanent universe provider. It connects your library to the
        open knowledge graph — linking every book, film, and person to authoritative
        identifiers across all platforms.
    </MudText>

    @* ── Provider info card ────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Class="pa-4 mb-4" Style="@InfoCardStyle">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Outlined.Hub" Color="Color.Primary" />
            <div style="flex: 1;">
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Wikidata</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    https://www.wikidata.org
                </MudText>
            </div>
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                SPARQL
            </MudChip>
        </MudStack>
    </MudPaper>

    @* ── Bridges section ───────────────────────────────────────────────── *@
    <MudExpansionPanels Elevation="0" Dense="true" Class="mb-4"
                        Style="background: transparent;">
        <MudExpansionPanel Text="Bridge Identifiers"
                           MaxHeight="2000"
                           Style="background: transparent; border: 1px solid var(--tanaste-glass-border); border-radius: 16px;">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Link" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Bridge Identifiers</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                        @_bridges.Count
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Bridges connect Wikidata to your other providers. When Tanaste finds a
                    Wikidata entry for a work, it uses these bridge properties to cross-reference
                    with Apple Books, Open Library, and more. Order determines priority — the first
                    matching bridge wins.
                </MudText>

                <MudSimpleTable Dense="true" Hover="true"
                                Style="background: transparent;">
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th>Property</th>
                            <th>Target Provider</th>
                            <th>Request Field</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < _bridges.Count; i++)
                        {
                            var bridge = _bridges[i];
                            var idx = i;
                            <tr>
                                <td>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@(idx + 1)</MudText>
                                </td>
                                <td>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@bridge.PCode</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            — @GetBridgeLabel(bridge.PCode)
                                        </MudText>
                                    </MudStack>
                                </td>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                             Variant="Variant.Text">
                                        @GetTargetProvider(bridge.PCode)
                                    </MudChip>
                                </td>
                                <td>
                                    <code style="font-size: 0.8rem;">@bridge.RequestField</code>
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @* ── Property map section ──────────────────────────────────────────── *@
    <MudExpansionPanels Elevation="0" Dense="true"
                        Style="background: transparent;">
        <MudExpansionPanel Text="Property Map"
                           MaxHeight="4000"
                           Style="background: transparent; border: 1px solid var(--tanaste-glass-border); border-radius: 16px;">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Map" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Property Map</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                        @_propertyCount properties
                    </MudChip>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Wikidata properties mapped to Tanaste claim keys. Each property carries
                    a confidence value used during scoring. Bridge properties link to external
                    platforms.
                </MudText>

                @foreach (var category in _propertiesByCategory)
                {
                    <MudText Typo="Typo.overline" Color="Color.Primary" Class="mt-3 mb-1"
                             Style="letter-spacing: 0.08em;">
                        @category.Key
                    </MudText>

                    <MudSimpleTable Dense="true" Hover="true"
                                    Style="background: transparent; margin-bottom: 8px;">
                        <thead>
                            <tr>
                                <th>P-Code</th>
                                <th>Claim Key</th>
                                <th>Scope</th>
                                <th style="width: 80px;">Confidence</th>
                                <th style="width: 60px;">Enabled</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prop in category.Value)
                            {
                                <tr style="@(!prop.Enabled ? "opacity: 0.5;" : "")">
                                    <td>
                                        <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                            @prop.PCode
                                        </MudText>
                                    </td>
                                    <td>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <code style="font-size: 0.8rem;">@prop.ClaimKey</code>
                                            @if (prop.IsBridge)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                                         Variant="Variant.Outlined"
                                                         Style="font-size: 0.65rem;">
                                                    Bridge
                                                </MudChip>
                                            }
                                        </MudStack>
                                    </td>
                                    <td>
                                        <MudText Typo="Typo.caption">@prop.EntityScope</MudText>
                                    </td>
                                    <td>
                                        <MudText Typo="Typo.body2">@prop.Confidence.ToString("P0")</MudText>
                                    </td>
                                    <td>
                                        <MudIcon Icon="@(prop.Enabled
                                                          ? Icons.Material.Filled.CheckCircle
                                                          : Icons.Material.Filled.Cancel)"
                                                 Color="@(prop.Enabled ? Color.Success : Color.Error)"
                                                 Size="Size.Small" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
</MudPaper>

@code {
    // ── State (all compiled defaults — no Engine dependency) ────────────────

    private readonly List<BridgeEntry> _bridges =
    [
        new("P3861", "apple_books_id"),
        new("P3398", "audible_id"),
        new("P4947", "tmdb_id"),
        new("P345",  "imdb_id"),
        new("P1566", "asin"),
        new("P212",  "isbn"),
    ];

    private Dictionary<string, List<PropertyEntry>> _propertiesByCategory = new();
    private int _propertyCount;

    // ── Lifecycle ─────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        var allProps = GetDefaultProperties();
        _propertiesByCategory = allProps
            .GroupBy(p => p.Category)
            .OrderBy(g => CategoryOrder(g.Key))
            .ToDictionary(g => g.Key, g => g.OrderBy(p => p.PCode).ToList());
        _propertyCount = allProps.Count;
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    private static string GetBridgeLabel(string pCode) => pCode switch
    {
        "P3861" => "Apple Books ID",
        "P3398" => "Audible ID",
        "P4947" => "TMDB Movie ID",
        "P345"  => "IMDb ID",
        "P1566" => "ASIN",
        "P212"  => "ISBN-13",
        _       => pCode,
    };

    private static string GetTargetProvider(string pCode) => pCode switch
    {
        "P3861" => "Apple Books",
        "P3398" => "Audnexus",
        "P4947" => "TMDB",
        "P345"  => "IMDb",
        "P1566" => "Amazon",
        "P212"  => "Open Library",
        _       => "Unknown",
    };

    private static int CategoryOrder(string category) => category switch
    {
        "Core Identity"          => 0,
        "People"                 => 1,
        "Lore & Narrative"       => 2,
        "Bridges: Books"         => 3,
        "Bridges: Movies/TV"     => 4,
        "Bridges: Comics/Anime"  => 5,
        "Bridges: Music/Audio"   => 6,
        "Social Pivot"           => 7,
        _                        => 99,
    };

    private static List<PropertyEntry> GetDefaultProperties() =>
    [
        // Core Identity
        new("P31",   "instance_of",    "Core Identity", "Work",   0.9,  false, true),
        new("P1476", "title",          "Core Identity", "Work",   0.9,  false, true),
        new("P179",  "series",         "Core Identity", "Work",   0.9,  false, true),
        new("P1545", "series_position","Core Identity", "Work",   0.9,  false, true),
        new("P8345", "franchise",      "Core Identity", "Work",   0.9,  false, true),
        new("P577",  "year",           "Core Identity", "Work",   0.9,  false, true),
        new("P136",  "genre",          "Core Identity", "Work",   0.85, false, true),
        new("P7937", "form_of_work",   "Core Identity", "Work",   0.85, false, true),
        new("P364",  "original_language","Core Identity","Work",   0.85, false, true),
        new("P495",  "country_of_origin","Core Identity","Work",   0.85, false, true),

        // People
        new("P50",   "author",         "People", "Work",   0.9,  false, true),
        new("P110",  "illustrator",    "People", "Work",   0.9,  false, true),
        new("P57",   "director",       "People", "Work",   0.9,  false, true),
        new("P58",   "screenwriter",   "People", "Work",   0.9,  false, true),
        new("P161",  "cast_member",    "People", "Work",   0.9,  false, true),
        new("P86",   "composer",       "People", "Work",   0.9,  false, true),
        new("P18",   "headshot_url",   "People", "Person", 0.9,  false, true),
        new("P106",  "occupation",     "People", "Person", 0.85, false, true),
        new("P569",  "date_of_birth",  "People", "Person", 0.9,  false, true),
        new("P570",  "date_of_death",  "People", "Person", 0.9,  false, true),
        new("P27",   "citizenship",    "People", "Person", 0.85, false, true),

        // Lore & Narrative
        new("P674",  "characters",         "Lore & Narrative", "Work", 0.85, false, true),
        new("P840",  "narrative_location",  "Lore & Narrative", "Work", 0.85, false, true),
        new("P1441", "present_in_work",     "Lore & Narrative", "Work", 0.8,  false, true),
        new("P144",  "based_on",            "Lore & Narrative", "Work", 0.85, false, true),
        new("P4969", "derivative_work",     "Lore & Narrative", "Work", 0.8,  false, true),

        // Bridges: Books
        new("P3861", "apple_books_id", "Bridges: Books", "Work", 1.0, true, true),
        new("P212",  "isbn",           "Bridges: Books", "Work", 1.0, true, true),
        new("P2969", "goodreads_id",   "Bridges: Books", "Work", 1.0, true, true),
        new("P648",  "openlibrary_id", "Bridges: Books", "Work", 1.0, true, true),
        new("P8383", "storygraph_id",  "Bridges: Books", "Work", 1.0, true, true),

        // Bridges: Movies/TV
        new("P4947", "tmdb_id",  "Bridges: Movies/TV", "Work", 1.0, true, true),
        new("P345",  "imdb_id",  "Bridges: Movies/TV", "Work", 1.0, true, true),
        new("P1566", "asin",     "Bridges: Movies/TV", "Work", 1.0, true, true),
        new("P3398", "audible_id","Bridges: Movies/TV", "Work", 1.0, true, true),

        // Social Pivot
        new("P2003", "instagram", "Social Pivot", "Person", 0.9, false, true),
        new("P2002", "twitter",   "Social Pivot", "Person", 0.9, false, true),
        new("P7085", "tiktok",    "Social Pivot", "Person", 0.9, false, true),
        new("P856",  "website",   "Social Pivot", "Person", 0.9, false, true),
    ];

    // ── Records ──────────────────────────────────────────────────────────

    private sealed record BridgeEntry(string PCode, string RequestField);

    private sealed record PropertyEntry(
        string PCode, string ClaimKey, string Category,
        string EntityScope, double Confidence, bool IsBridge, bool Enabled);

    // ── Styles ───────────────────────────────────────────────────────────

    private const string GlassStyle =
        "background: var(--tanaste-glass-bg); " +
        "border: 1px solid var(--tanaste-glass-border); " +
        "backdrop-filter: blur(20px); " +
        "-webkit-backdrop-filter: blur(20px); " +
        "border-radius: 24px; " +
        "padding: 24px;";

    private const string InfoCardStyle =
        "background: var(--tanaste-glass-bg); " +
        "border: 1px solid var(--tanaste-glass-border); " +
        "border-left: 4px solid var(--mud-palette-primary); " +
        "backdrop-filter: blur(10px); " +
        "-webkit-backdrop-filter: blur(10px); " +
        "border-radius: 16px;";
}
