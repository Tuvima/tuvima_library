@namespace Tanaste.Web.Components.Settings
@using Tanaste.Web.Models
@using Tanaste.Web.Models.ViewDTOs
@inject UIOrchestratorService Orchestrator
@inject ISnackbar Snackbar

@* Metadata tab — simplified provider slot assignment.
   Users pick a Primary + up to 2 secondary providers per media type
   via drag-drop. All configuration complexity lives in JSON files. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Hub" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">Metadata</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Select providers for each media type. Drag a provider into a slot to set priority.
    </MudText>

    @* ── Loading / error ──────────────────────────────────────────────────── *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_engineDown)
    {
        <MudAlert Severity="Severity.Error" Class="mt-2">
            Cannot reach the Engine — please make sure it is running.
        </MudAlert>
    }
    else
    {
        @* ── Universe indicator ────────────────────────────────────────────── *@
        <MudPaper Elevation="0" Class="pa-3 mb-4"
                  Style="background: var(--tanaste-glass-bg); border: 1px solid var(--tanaste-glass-border); border-radius: 12px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <div class="provider-health-dot @(_wikidataReachable ? "health-online" : "health-offline")"
                     style="width: 12px; height: 12px;"></div>
                <MudText Typo="Typo.body1" Style="font-weight: 500;">
                    @(_wikidataReachable ? "Universe Connected" : "Universe Unavailable")
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex: 1;">
                    Wikidata provides cross-media identification, series data, and creator profiles.
                </MudText>
            </MudStack>
        </MudPaper>

        @* ── Media type tabs ──────────────────────────────────────────────── *@
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true"
                 ActivePanelIndexChanged="@OnTabChanged">
            @foreach (var mt in _mediaTypes)
            {
                <MudTabPanel Text="@mt">
                    <div class="slot-layout">
                        @* ── Left column: available providers ────────────── *@
                        <div class="slot-available-providers">
                            <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: var(--tanaste-text-muted);">
                                Available Providers
                            </MudText>
                            <MudDropContainer T="ProviderDragItem"
                                              Items="@GetDragItems(mt)"
                                              ItemsSelector="@((item, zone) => item.Zone == zone)"
                                              ItemDropped="@(args => OnItemDropped(args, mt))"
                                              Class="slot-drop-container">
                                <ChildContent>
                                    @* Available pool *@
                                    <MudDropZone T="ProviderDragItem"
                                                 Identifier="available"
                                                 Class="slot-available-zone"
                                                 AllowReorder="false"
                                                 CanDrop="@(_ => true)">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                                            Drag providers to the slots on the right.
                                        </MudText>
                                    </MudDropZone>

                                    @* ── Right area: slot drop zones ─────────── *@
                                    <div class="slot-zones-column">
                                        <MudDropZone T="ProviderDragItem"
                                                     Identifier="primary"
                                                     Class="slot-zone slot-zone-primary"
                                                     AllowReorder="false"
                                                     CanDrop="@(_ => true)">
                                            <MudText Typo="Typo.subtitle2" Style="color: var(--mud-palette-primary); font-weight: 600;">
                                                Primary — Automatic Match
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                This provider runs automatically when files are added.
                                            </MudText>
                                        </MudDropZone>

                                        <MudDropZone T="ProviderDragItem"
                                                     Identifier="secondary"
                                                     Class="slot-zone"
                                                     AllowReorder="false"
                                                     CanDrop="@(_ => true)">
                                            <MudText Typo="Typo.subtitle2" Style="color: var(--tanaste-text-muted);">
                                                Secondary — Manual Fallback 1
                                            </MudText>
                                        </MudDropZone>

                                        <MudDropZone T="ProviderDragItem"
                                                     Identifier="tertiary"
                                                     Class="slot-zone"
                                                     AllowReorder="false"
                                                     CanDrop="@(_ => true)">
                                            <MudText Typo="Typo.subtitle2" Style="color: var(--tanaste-text-muted);">
                                                Tertiary — Manual Fallback 2
                                            </MudText>
                                        </MudDropZone>
                                    </div>
                                </ChildContent>

                                <ItemRenderer>
                                    @{
                                        var provider = _providers.FirstOrDefault(p => p.Name == context.ProviderName);
                                        if (provider is not null)
                                        {
                                            <ProviderCard Provider="@provider"
                                                          IsSlotted="@(context.Zone != "available")"
                                                          OnRemove="@(() => RemoveFromSlot(context, mt))" />
                                        }
                                    }
                                </ItemRenderer>
                            </MudDropContainer>
                        </div>
                    </div>
                </MudTabPanel>
            }
        </MudTabs>
    }

</MudPaper>

@code {
    [Parameter] public string CurrentRole { get; set; } = "Administrator";

    private bool _loading = true;
    private bool _engineDown;
    private bool _wikidataReachable;

    private IReadOnlyList<ProviderStatusDto> _providers = [];
    private Dictionary<string, ProviderSlotDto> _slots = new();

    private static readonly string[] _mediaTypes =
        ["Books", "Audiobooks", "Comics", "Movies", "TV Shows"];

    // ── Lifecycle ──────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _providers = await Orchestrator.GetProviderStatusAsync();
            if (_providers.Count == 0)
            {
                _engineDown = true;
                return;
            }

            var slots = await Orchestrator.GetProviderSlotsAsync();
            _slots = slots ?? new Dictionary<string, ProviderSlotDto>();

            // Check Wikidata reachability.
            var wikidata = _providers.FirstOrDefault(p =>
                string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase));
            _wikidataReachable = wikidata?.IsReachable ?? false;
        }
        catch
        {
            _engineDown = true;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Media-type to provider mapping ────────────────────────────────────

    /// <summary>Maps media type tab names to ProviderStatusDto media type filter values.</summary>
    private static readonly Dictionary<string, string[]> MediaTypeFilterMap = new()
    {
        ["Books"]      = ["Epub"],
        ["Audiobooks"] = ["Audiobook"],
        ["Comics"]     = ["Comic"],
        ["Movies"]     = ["Movie"],
        ["TV Shows"]   = ["TvShow"],
    };

    /// <summary>
    /// Maps provider domain strings to media type filter values.
    /// Fallback when <c>MediaTypes</c> is empty (older config files without <c>can_handle</c>).
    /// </summary>
    private static readonly Dictionary<string, string[]> DomainFallbackMap =
        new(StringComparer.OrdinalIgnoreCase)
    {
        ["Ebook"]     = ["Epub"],
        ["Audiobook"] = ["Audiobook"],
        ["Video"]     = ["Movie", "TvShow"],
        ["Universal"] = ["Epub", "Audiobook", "Comic", "Movie", "TvShow"],
    };

    /// <summary>Returns providers that can handle the given media type, excluding wikidata/local_filesystem.</summary>
    private List<ProviderStatusDto> GetProvidersForMediaType(string mediaType)
    {
        if (!MediaTypeFilterMap.TryGetValue(mediaType, out var filterValues))
            return [];

        return _providers
            .Where(p => ProviderAccentMap.IsVisibleProvider(p.Name))
            .Where(p => !string.Equals(p.Name, "wikidata", StringComparison.OrdinalIgnoreCase))
            .Where(p => MatchesMediaType(p, filterValues))
            .ToList();
    }

    private static bool MatchesMediaType(ProviderStatusDto p, string[] filterValues)
    {
        // Primary: check explicit MediaTypes from can_handle config.
        if (p.MediaTypes is { Count: > 0 })
        {
            return p.MediaTypes.Any(mt =>
                filterValues.Any(fv => string.Equals(mt, fv, StringComparison.OrdinalIgnoreCase)));
        }

        // Fallback: derive from domain.
        if (!string.IsNullOrEmpty(p.Domain)
            && DomainFallbackMap.TryGetValue(p.Domain, out var domainTypes))
        {
            return domainTypes.Any(dt =>
                filterValues.Any(fv => string.Equals(dt, fv, StringComparison.OrdinalIgnoreCase)));
        }

        return false;
    }

    // ── Drag-drop model ──────────────────────────────────────────────────

    private List<ProviderDragItem> GetDragItems(string mediaType)
    {
        var available = GetProvidersForMediaType(mediaType);
        var slot = GetSlot(mediaType);
        var items = new List<ProviderDragItem>();

        foreach (var provider in available)
        {
            string zone = "available";
            if (string.Equals(provider.Name, slot.Primary, StringComparison.OrdinalIgnoreCase))
                zone = "primary";
            else if (string.Equals(provider.Name, slot.Secondary, StringComparison.OrdinalIgnoreCase))
                zone = "secondary";
            else if (string.Equals(provider.Name, slot.Tertiary, StringComparison.OrdinalIgnoreCase))
                zone = "tertiary";

            items.Add(new ProviderDragItem { ProviderName = provider.Name, Zone = zone });
        }

        return items;
    }

    private ProviderSlotDto GetSlot(string mediaType)
    {
        return _slots.TryGetValue(mediaType, out var slot) ? slot : new ProviderSlotDto();
    }

    private async Task OnItemDropped(MudItemDropInfo<ProviderDragItem> dropInfo, string mediaType)
    {
        if (dropInfo.Item is null) return;

        var providerName = dropInfo.Item.ProviderName;
        var targetZone = dropInfo.DropzoneIdentifier;
        var slot = GetSlot(mediaType);

        // Clear the provider from any existing slot.
        if (string.Equals(slot.Primary, providerName, StringComparison.OrdinalIgnoreCase))
            slot = slot with { Primary = null };
        if (string.Equals(slot.Secondary, providerName, StringComparison.OrdinalIgnoreCase))
            slot = slot with { Secondary = null };
        if (string.Equals(slot.Tertiary, providerName, StringComparison.OrdinalIgnoreCase))
            slot = slot with { Tertiary = null };

        // If dropping into a slot, also evict whoever was there.
        switch (targetZone)
        {
            case "primary":
                slot = slot with { Primary = providerName };
                break;
            case "secondary":
                slot = slot with { Secondary = providerName };
                break;
            case "tertiary":
                slot = slot with { Tertiary = providerName };
                break;
            // "available" = remove from all slots (already done above).
        }

        _slots[mediaType] = slot;
        await SaveSlotsAsync();
    }

    private async Task RemoveFromSlot(ProviderDragItem item, string mediaType)
    {
        var slot = GetSlot(mediaType);
        var name = item.ProviderName;

        if (string.Equals(slot.Primary, name, StringComparison.OrdinalIgnoreCase))
            slot = slot with { Primary = null };
        if (string.Equals(slot.Secondary, name, StringComparison.OrdinalIgnoreCase))
            slot = slot with { Secondary = null };
        if (string.Equals(slot.Tertiary, name, StringComparison.OrdinalIgnoreCase))
            slot = slot with { Tertiary = null };

        _slots[mediaType] = slot;
        await SaveSlotsAsync();
    }

    private async Task SaveSlotsAsync()
    {
        var ok = await Orchestrator.UpdateProviderSlotsAsync(_slots);
        if (ok)
            Snackbar.Add("Provider slots saved.", Severity.Success);
        else
            Snackbar.Add("Failed to save provider slots.", Severity.Error);

        StateHasChanged();
    }

    private void OnTabChanged(int _) { /* Re-render with new tab's data */ }

    // ── Drag item model ──────────────────────────────────────────────────

    private sealed class ProviderDragItem
    {
        public string ProviderName { get; set; } = string.Empty;
        public string Zone { get; set; } = "available";
    }

    // ── Glass style ──────────────────────────────────────────────────────

    private const string GlassStyle =
        "background: var(--tanaste-glass-bg); " +
        "border: 1px solid var(--tanaste-glass-border); " +
        "backdrop-filter: blur(20px); " +
        "-webkit-backdrop-filter: blur(20px); " +
        "border-radius: 32px; " +
        "padding: 32px;";
}

<style>
    /* ── Slot layout ──────────────────────────────────────────────── */
    .slot-layout {
        display: flex;
        gap: 24px;
        min-height: 300px;
    }

    .slot-available-providers {
        flex: 1;
        min-width: 0;
    }

    .slot-drop-container {
        display: flex;
        gap: 24px;
        min-height: 280px;
    }

    .slot-available-zone {
        flex: 2;
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 12px;
        border: 2px dashed var(--tanaste-glass-border);
        border-radius: 16px;
        min-height: 200px;
    }

    .slot-zones-column {
        flex: 3;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    /* ── Drop zone slots ──────────────────────────────────────────── */
    .slot-zone {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 16px;
        border: 2px dashed var(--tanaste-glass-border);
        border-radius: 16px;
        min-height: 80px;
        transition: border-color 0.15s ease, background 0.15s ease;
    }

    .slot-zone:hover {
        border-color: var(--mud-palette-primary);
        background: var(--tanaste-hover-overlay);
    }

    .slot-zone-primary {
        border-color: var(--mud-palette-primary);
        border-style: solid;
    }

    /* ── Health dot (shared with ProviderCard) ─────────────────── */
    .provider-health-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .health-online {
        background: #4CAF50;
        box-shadow: 0 0 4px rgba(76, 175, 80, 0.5);
    }

    .health-offline {
        background: #F44336;
        box-shadow: 0 0 4px rgba(244, 67, 54, 0.5);
    }

    /* ── Responsive ────────────────────────────────────────────── */
    @@media (max-width: 768px) {
        .slot-drop-container {
            flex-direction: column;
        }

        .slot-available-zone {
            min-height: 100px;
        }
    }
</style>
