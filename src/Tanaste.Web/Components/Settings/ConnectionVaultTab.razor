@namespace Tanaste.Web.Components.Settings
@using Tanaste.Web.Models
@inject UIOrchestratorService Orchestrator
@inject DeviceContextService DeviceContext
@inject ISnackbar Snackbar

@* Connection Vault — Metadata Prioritization Matrix with drag-and-drop
   provider priority configuration per media type. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Hub" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">Connection Vault</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Drag providers into each field column to set priority. Position 1 wins.
    </MudText>

    @* ── Loading / error ──────────────────────────────────────────────────── *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_engineDown)
    {
        <MudAlert Severity="Severity.Error" Class="mt-2">
            Cannot reach the Engine — please make sure it is running.
        </MudAlert>
    }
    else
    {
        @* ━━━━━━ SECTION 1: Metadata Prioritization Matrix ━━━━━━ *@
        <MudPaper Elevation="0" Class="pa-4 mb-4"
                  Style="background: var(--tanaste-glass-bg); border: 1px solid var(--tanaste-glass-border); border-radius: 16px;">

            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.GridView" Size="Size.Small"
                         Style="color: var(--tanaste-text-muted);" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                    Metadata Prioritization Matrix
                </MudText>
            </MudStack>

            @* ── Media type tabs ────────────────────────────────────── *@
            <MudTabs ActivePanelIndex="_activeTabIndex"
                     ActivePanelIndexChanged="@OnTabChanged"
                     Rounded="true" ApplyEffectsToContainer="true"
                     Class="mb-4"
                     MinimumTabWidth="80px">

                @foreach (var tab in MediaTypeTabs)
                {
                    <MudTabPanel Text="@tab.Label" Icon="@tab.Icon" BadgeColor="Color.Primary"
                                 BadgeDot="@_dirtyTabs.Contains(MediaTypeTabs.IndexOf(tab))">

                        <div class="@(_flyoutOpen ? "matrix-grayed-out" : "")">
                            @if (ActiveMatrixItems.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary"
                                         Style="font-style: italic; padding: 16px 0;">
                                    No providers configured for @tab.Label yet.
                                </MudText>
                            }
                            else
                            {
                                <MudDropContainer T="MatrixItem"
                                                  @ref="_dropContainer"
                                                  Items="@ActiveMatrixItems"
                                                  ItemsSelector="@((item, zone) => item.Zone == zone)"
                                                  ItemDropped="@OnItemDropped"
                                                  CanDropClass="matrix-can-drop"
                                                  NoDropClass="matrix-no-drop"
                                                  ApplyDropClassesOnDragStarted="true">
                                    <ChildContent>
                                        @* ── Column zones (horizontal scroll) ──── *@
                                        <div class="matrix-columns-scroll">
                                            <div class="matrix-columns">
                                                @foreach (var column in ActiveColumns.OrderBy(c => c.SortOrder))
                                                {
                                                    <div class="matrix-column">
                                                        @* Column header *@
                                                        <div class="matrix-column-header">
                                                            <MudIcon Icon="@column.Icon"
                                                                     Size="Size.Small"
                                                                     Color="Color.Primary" />
                                                            <MudText Typo="Typo.body2"
                                                                     Style="font-weight: 600; flex: 1; white-space: nowrap;">
                                                                @column.DisplayName
                                                            </MudText>
                                                            @if (column.IsGroup && IsAdmin)
                                                            {
                                                                <MudMenu Icon="@Icons.Material.Filled.UnfoldMore"
                                                                         Size="Size.Small"
                                                                         Dense="true"
                                                                         AnchorOrigin="Origin.BottomCenter"
                                                                         title="Extract individual fields">
                                                                    @foreach (var ck in column.ClaimKeys.OrderBy(k => FieldDictionary.GetDisplayName(k)))
                                                                    {
                                                                        var key = ck;
                                                                        <MudMenuItem OnClick="@(() => ExtractFieldFromUniverse(key))">
                                                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                                                <MudIcon Icon="@FieldDictionary.GetIcon(key)" Size="Size.Small" />
                                                                                <MudText Typo="Typo.body2">@FieldDictionary.GetDisplayName(key)</MudText>
                                                                            </MudStack>
                                                                        </MudMenuItem>
                                                                    }
                                                                </MudMenu>
                                                            }
                                                            @if (column.IsUserAdded && IsAdmin)
                                                            {
                                                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                                               Size="Size.Small"
                                                                               OnClick="@(() => RemoveColumn(column))"
                                                                               title="Remove this field column" />
                                                            }
                                                        </div>

                                                        @* Drop zone *@
                                                        <MudDropZone T="MatrixItem"
                                                                     Identifier="@column.ZoneId"
                                                                     AllowReorder="true"
                                                                     CanDrop="@(item => CanDropInColumn(item, column))"
                                                                     Class="matrix-drop-zone" />
                                                    </div>
                                                }

                                                @* ── Add field button ──────────────── *@
                                                @if (IsAdmin)
                                                {
                                                    <div class="matrix-add-column">
                                                        <MudMenu Icon="@Icons.Material.Filled.Add"
                                                                 Variant="Variant.Outlined"
                                                                 Color="Color.Primary"
                                                                 Size="Size.Small"
                                                                 Dense="true"
                                                                 AnchorOrigin="Origin.BottomCenter"
                                                                 title="Add a field column">
                                                            @foreach (var field in GetAddableFields())
                                                            {
                                                                var key = field.Key;
                                                                <MudMenuItem OnClick="@(() => AddColumn(key))">
                                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                                        <MudIcon Icon="@field.Value.Icon" Size="Size.Small" />
                                                                        <MudText Typo="Typo.body2">@field.Value.DisplayName</MudText>
                                                                    </MudStack>
                                                                </MudMenuItem>
                                                            }
                                                        </MudMenu>
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        @* ── Disabled / available providers pool ── *@
                                        <div class="matrix-disabled-pool">
                                            <MudText Typo="Typo.overline" Color="Color.Secondary"
                                                     Style="letter-spacing: 0.08em;" Class="mb-1">
                                                AVAILABLE PROVIDERS — drag into columns above
                                            </MudText>
                                            <MudDropZone T="MatrixItem"
                                                         Identifier="disabled"
                                                         AllowReorder="false"
                                                         Class="matrix-disabled-zone" />
                                        </div>
                                    </ChildContent>

                                    <ItemRenderer>
                                        @{
                                            var pos = GetItemPosition(context);
                                        }
                                        <MatrixProviderChip Item="@context"
                                                            Position="@pos"
                                                            IsDisabled="@(context.Zone == "disabled")"
                                                            OnEditClicked="@(() => OpenProviderFlyout(context))" />
                                    </ItemRenderer>
                                </MudDropContainer>

                                @* ── Save button ──────────────────────── *@
                                @if (_dirtyTabs.Contains(_activeTabIndex) && IsAdmin)
                                {
                                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Save"
                                                   OnClick="@SaveMatrixPrioritiesAsync"
                                                   Disabled="@_saving">
                                            @if (_saving)
                                            {
                                                <MudProgressCircular Size="Size.Small"
                                                                     Indeterminate="true" Class="mr-1" />
                                                @:Saving…
                                            }
                                            else
                                            {
                                                @:Save Priorities
                                            }
                                        </MudButton>
                                    </MudStack>
                                }
                            }
                        </div>
                    </MudTabPanel>
                }
            </MudTabs>
        </MudPaper>

        @* ━━━━━━ SECTION 2: Provider Connections ━━━━━━ *@
        <MudPaper Elevation="0" Class="pa-4 mb-4"
                  Style="background: var(--tanaste-glass-bg); border: 1px solid var(--tanaste-glass-border); border-radius: 16px;">

            <div class="section-header"
                 @onclick="@(() => _connectionsExpanded = !_connectionsExpanded)">
                <MudIcon Icon="@(_connectionsExpanded
                                  ? Icons.Material.Filled.ExpandMore
                                  : Icons.Material.Filled.ChevronRight)"
                         Size="Size.Small"
                         Style="color: var(--tanaste-text-muted);" />
                <MudIcon Icon="@Icons.Material.Filled.CloudSync" Size="Size.Small"
                         Style="color: var(--tanaste-text-muted);" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600; flex: 1;">
                    Provider Connections
                </MudText>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                         Color="Color.Default">
                    @_providers.Count
                </MudChip>
            </div>

            @if (_connectionsExpanded)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 mt-1">
                    Test endpoints, enable/disable providers, and configure connection settings.
                </MudText>

                <div class="provider-list">
                    @foreach (var provider in _providers)
                    {
                        var isExpanded = _expandedProvider == provider.Name;

                        <div class="provider-row @(isExpanded ? "expanded" : "")"
                             @key="@provider.Name">

                            <div class="provider-row-header"
                                 @onclick="@(() => OnRowClicked(provider))">

                                <div class="provider-status-dot"
                                     style="@StatusDotStyle(provider)"
                                     title="@StatusTitle(provider)"></div>

                                <div style="flex: 1; min-width: 0;">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                            @provider.DisplayName
                                        </MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                                 Color="Color.Default"
                                                 Style="font-size: 0.65rem;">
                                            @FormatDomain(provider.Domain)
                                        </MudChip>
                                    </MudStack>
                                    @if (provider.AvailableFields is { Count: > 0 })
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @provider.AvailableFields.Count fields available
                                        </MudText>
                                    }
                                </div>

                                @if (IsAdmin)
                                {
                                    <MudSwitch T="bool" Value="@provider.Enabled"
                                               ValueChanged="@(async val => await ToggleProviderAsync(provider.Name, val))"
                                               Color="Color.Primary"
                                               @onclick:stopPropagation="true" />
                                }

                                @if (!IsMobile)
                                {
                                    <MudIcon Icon="@(isExpanded
                                                      ? Icons.Material.Filled.ExpandLess
                                                      : Icons.Material.Filled.ExpandMore)"
                                             Size="Size.Small"
                                             Style="color: var(--tanaste-text-muted);" />
                                }
                            </div>

                            @if (isExpanded && !IsMobile)
                            {
                                <div class="provider-expanded-content">
                                    @if (IsWikidata(provider.Name))
                                    {
                                        <WikidataVaultPanel Provider="@provider"
                                                            IsAdmin="@HasAdminAccess"
                                                            OnTestClicked="@(() => TestProvider(provider.Name))"
                                                            OnSaveClicked="@(config => SaveProvider(provider.Name, config))"
                                                            TestResult="@GetTestResult(provider.Name)"
                                                            IsTesting="@IsProviderTesting(provider.Name)"
                                                            IsSaving="@_saving" />
                                    }
                                    else
                                    {
                                        <ProviderEditPanel Provider="@provider"
                                                           IsAdmin="@HasAdminAccess"
                                                           OnTestClicked="@(() => TestProvider(provider.Name))"
                                                           OnSaveClicked="@(config => SaveProvider(provider.Name, config))"
                                                           OnDeleteClicked="@(() => DeleteProvider(provider.Name))"
                                                           TestResult="@GetTestResult(provider.Name)"
                                                           IsTesting="@IsProviderTesting(provider.Name)"
                                                           IsSaving="@_saving" />
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </MudPaper>

        @* ━━━━━━ SECTION 3: Advanced Pipeline Config ━━━━━━ *@
        <MudPaper Elevation="0" Class="pa-4"
                  Style="background: var(--tanaste-glass-bg); border: 1px solid var(--tanaste-glass-border); border-radius: 16px;">

            <div class="section-header"
                 @onclick="@(() => _advancedExpanded = !_advancedExpanded)">
                <MudIcon Icon="@(_advancedExpanded
                                  ? Icons.Material.Filled.ExpandMore
                                  : Icons.Material.Filled.ChevronRight)"
                         Size="Size.Small"
                         Style="color: var(--tanaste-text-muted);" />
                <MudIcon Icon="@Icons.Material.Outlined.Tune" Size="Size.Small"
                         Style="color: var(--tanaste-text-muted);" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600; flex: 1;">
                    Advanced
                </MudText>
            </div>

            @if (_advancedExpanded)
            {
                <div class="mt-3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                        Pipeline concurrency, timeouts, and confidence thresholds.
                    </MudText>

                    @if (_hydrationSettings is not null)
                    {
                        <MudGrid Spacing="3">
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="int" Label="Stage Concurrency"
                                                 @bind-Value="_hydrationSettings.StageConcurrency"
                                                 Min="1" Max="10"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="int" Label="Stage 1 Timeout (seconds)"
                                                 @bind-Value="_hydrationSettings.Stage1TimeoutSeconds"
                                                 Min="5" Max="120"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="int" Label="Stage 2 Timeout (seconds)"
                                                 @bind-Value="_hydrationSettings.Stage2TimeoutSeconds"
                                                 Min="5" Max="120"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="int" Label="Stage 3 Timeout (seconds)"
                                                 @bind-Value="_hydrationSettings.Stage3TimeoutSeconds"
                                                 Min="5" Max="120"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="double" Label="Disambiguation Threshold"
                                                 @bind-Value="_hydrationSettings.DisambiguationThreshold"
                                                 Min="0.0" Max="1.0" Step="0.05"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Format="F2" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="double" Label="Auto-Review Threshold"
                                                 @bind-Value="_hydrationSettings.AutoReviewConfidenceThreshold"
                                                 Min="0.0" Max="1.0" Step="0.05"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Format="F2" />
                            </MudItem>
                        </MudGrid>

                        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@SaveHydrationSettingsAsync"
                                       Disabled="@(!IsAdmin || _saving)">
                                Save Configuration
                            </MudButton>
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-style: italic;">
                            Could not load pipeline configuration.
                        </MudText>
                    }
                </div>
            }
        </MudPaper>
    }
</MudPaper>

@* ── Mobile slide-over drawer ────────────────────────────────────────── *@
@if (IsMobile && _drawerProvider is not null)
{
    <MudDrawer Open="@_drawerOpen"
               OpenChanged="@OnDrawerOpenChanged"
               Anchor="Anchor.End"
               Width="100%"
               Overlay="true"
               Variant="DrawerVariant.Temporary"
               Style="@DrawerStyle">
        <div class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                               Color="Color.Default"
                               Size="Size.Medium"
                               OnClick="@CloseDrawer" />
                <MudText Typo="Typo.h6" Style="flex: 1;">@_drawerProvider.DisplayName</MudText>
            </MudStack>

            @if (IsWikidata(_drawerProvider.Name))
            {
                <WikidataVaultPanel Provider="@_drawerProvider"
                                    IsAdmin="@HasAdminAccess"
                                    OnTestClicked="@(() => TestProvider(_drawerProvider.Name))"
                                    OnSaveClicked="@(config => SaveProvider(_drawerProvider.Name, config))"
                                    TestResult="@GetTestResult(_drawerProvider.Name)"
                                    IsTesting="@IsProviderTesting(_drawerProvider.Name)"
                                    IsSaving="@_saving" />
            }
            else
            {
                <ProviderEditPanel Provider="@_drawerProvider"
                                   IsAdmin="@HasAdminAccess"
                                   OnTestClicked="@(() => TestProvider(_drawerProvider.Name))"
                                   OnSaveClicked="@(config => SaveProvider(_drawerProvider.Name, config))"
                                   OnDeleteClicked="@(() => DeleteProvider(_drawerProvider.Name))"
                                   TestResult="@GetTestResult(_drawerProvider.Name)"
                                   IsTesting="@IsProviderTesting(_drawerProvider.Name)"
                                   IsSaving="@_saving" />
            }
        </div>
    </MudDrawer>
}

@* ── Provider editing flyout (desktop) ───────────────────────────────── *@
@if (!IsMobile && _flyoutProvider is not null)
{
    <MudDrawer Open="@_flyoutOpen"
               OpenChanged="@OnFlyoutOpenChanged"
               Anchor="Anchor.End"
               Width="420px"
               Overlay="true"
               Variant="DrawerVariant.Temporary"
               Style="@DrawerStyle">
        <div class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Color="Color.Default"
                               Size="Size.Medium"
                               OnClick="@CloseFlyout" />
                <MudText Typo="Typo.h6" Style="flex: 1;">@_flyoutProvider.DisplayName</MudText>
            </MudStack>

            @if (IsWikidata(_flyoutProvider.Name))
            {
                <WikidataVaultPanel Provider="@_flyoutProvider"
                                    IsAdmin="@HasAdminAccess"
                                    OnTestClicked="@(() => TestProvider(_flyoutProvider.Name))"
                                    OnSaveClicked="@(config => SaveProvider(_flyoutProvider.Name, config))"
                                    TestResult="@GetTestResult(_flyoutProvider.Name)"
                                    IsTesting="@IsProviderTesting(_flyoutProvider.Name)"
                                    IsSaving="@_saving" />
            }
            else
            {
                <ProviderEditPanel Provider="@_flyoutProvider"
                                   IsAdmin="@HasAdminAccess"
                                   OnTestClicked="@(() => TestProvider(_flyoutProvider.Name))"
                                   OnSaveClicked="@(config => SaveProvider(_flyoutProvider.Name, config))"
                                   OnDeleteClicked="@(() => DeleteProvider(_flyoutProvider.Name))"
                                   TestResult="@GetTestResult(_flyoutProvider.Name)"
                                   IsTesting="@IsProviderTesting(_flyoutProvider.Name)"
                                   IsSaving="@_saving" />
            }
        </div>
    </MudDrawer>
}

@code {
    /// <summary>Current user role for authorisation gating.</summary>
    [Parameter] public string CurrentRole { get; set; } = "Administrator";

    // ── State ────────────────────────────────────────────────────────────────

    private bool _loading = true;
    private bool _engineDown;
    private bool _saving;

    private List<ProviderStatusDto> _providers = [];
    private string? _expandedProvider;

    // Collapsible sections.
    private bool _connectionsExpanded;
    private bool _advancedExpanded;

    // Matrix state.
    private int _activeTabIndex;
    private MudDropContainer<MatrixItem>? _dropContainer;
    private readonly Dictionary<int, List<MatrixItem>> _matrixItemsByTab = new();
    private readonly Dictionary<int, List<MatrixColumn>> _matrixColumnsByTab = new();
    private readonly HashSet<int> _dirtyTabs = [];

    // Pipeline config.
    private HydrationSettingsDto? _hydrationSettings;

    // Mobile drawer.
    private bool _drawerOpen;
    private ProviderStatusDto? _drawerProvider;

    // Desktop flyout.
    private bool _flyoutOpen;
    private ProviderStatusDto? _flyoutProvider;

    // Per-provider test results.
    private readonly Dictionary<string, ProviderTestResultDto> _testResults = new();
    private readonly HashSet<string> _testingProviders = [];

    // ── Media type tab definitions ─────────────────────────────────────────

    private static readonly List<MediaTypeTab> MediaTypeTabs =
    [
        new("Books",      "Ebook",     Icons.Material.Outlined.MenuBook),
        new("Audiobooks", "Audiobook", Icons.Material.Outlined.Headphones),
        new("Comics",     "Comic",     Icons.Material.Outlined.CollectionsBookmark),
        new("Movies",     "Video",     Icons.Material.Outlined.Movie),
        new("TV Shows",   "Video",     Icons.Material.Outlined.Tv),
    ];

    private sealed record MediaTypeTab(string Label, string DomainKey, string Icon);

    // ── Computed ────────────────────────────────────────────────────────────

    private bool HasAdminAccess =>
        string.Equals(CurrentRole, "Administrator", StringComparison.OrdinalIgnoreCase)
        || string.Equals(CurrentRole, "Curator", StringComparison.OrdinalIgnoreCase);

    private bool IsAdmin =>
        string.Equals(CurrentRole, "Administrator", StringComparison.OrdinalIgnoreCase);

    private bool IsMobile =>
        string.Equals(DeviceContext.Settings.Pages.ServerSettings.SidebarLayout,
                      "drawer", StringComparison.OrdinalIgnoreCase);

    private List<MatrixItem> ActiveMatrixItems =>
        _matrixItemsByTab.TryGetValue(_activeTabIndex, out var items) ? items : [];

    private List<MatrixColumn> ActiveColumns =>
        _matrixColumnsByTab.TryGetValue(_activeTabIndex, out var cols) ? cols : [];

    // ── Lifecycle ───────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadProvidersAsync();
        _ = LoadHydrationSettingsAsync();
    }

    private async Task LoadProvidersAsync()
    {
        _loading = true;
        _engineDown = false;

        try
        {
            var providers = await Orchestrator.GetProviderStatusAsync();
            if (providers is null || providers.Count == 0)
            {
                _engineDown = true;
                return;
            }

            _providers = providers.OrderBy(p => p.Name).ToList();
            BuildAllMatrices();
        }
        catch
        {
            _engineDown = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadHydrationSettingsAsync()
    {
        try { _hydrationSettings = await Orchestrator.GetHydrationSettingsAsync(); }
        catch { /* Non-fatal */ }
    }

    // ── Matrix building ────────────────────────────────────────────────────

    private void BuildAllMatrices()
    {
        _matrixItemsByTab.Clear();
        _matrixColumnsByTab.Clear();

        for (var i = 0; i < MediaTypeTabs.Count; i++)
        {
            var tab = MediaTypeTabs[i];
            var columns = FieldDictionary.GetDefaultColumns();
            var items = BuildMatrixItemsForTab(tab, columns);
            _matrixColumnsByTab[i] = columns;
            _matrixItemsByTab[i] = items;
        }
    }

    private List<MatrixItem> BuildMatrixItemsForTab(MediaTypeTab tab, List<MatrixColumn> columns)
    {
        var relevantProviders = GetRelevantProviders(tab.DomainKey);
        var items = new List<MatrixItem>();
        var seenDisplayNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        // Build a provider info lookup, deduplicating Apple Books.
        var providerInfos = new List<(ProviderStatusDto Provider, string DisplayName, string Color, string Icon)>();
        foreach (var provider in relevantProviders)
        {
            var displayName = ProviderAccentMap.GetDisplayName(provider.Name);
            if (!seenDisplayNames.Add(displayName)) continue;
            var (color, icon) = ProviderAccentMap.GetAccent(provider.Name);
            providerInfos.Add((provider, displayName, color, icon));
        }

        // For each column, find providers that have existing field weights and place them.
        foreach (var column in columns)
        {
            var columnItems = new List<(MatrixItem Item, double BestWeight)>();

            foreach (var (provider, displayName, color, icon) in providerInfos)
            {
                var supported = GetProviderFieldKeys(provider);
                var supportsColumn = column.ClaimKeys.Any(ck =>
                    supported.Contains(ck, StringComparer.OrdinalIgnoreCase));
                if (!supportsColumn) continue;

                // Find the best existing weight for any claim key in this column.
                var bestWeight = column.ClaimKeys
                    .Select(ck => GetFieldWeight(provider.Name, ck))
                    .Max();

                // Only place if there's a meaningful weight (provider was previously configured).
                if (bestWeight > 0.01)
                {
                    columnItems.Add((new MatrixItem
                    {
                        ProviderKey = provider.Name,
                        DisplayName = displayName,
                        Zone = column.ZoneId,
                        SupportedFields = new HashSet<string>(supported, StringComparer.OrdinalIgnoreCase),
                        Color = color,
                        Icon = icon,
                        Enabled = provider.Enabled,
                    }, bestWeight));
                }
            }

            // Sort by weight descending (highest = position 0).
            var ordered = columnItems.OrderByDescending(x => x.BestWeight).ToList();
            for (var i = 0; i < ordered.Count; i++)
            {
                ordered[i].Item.Order = i;
                items.Add(ordered[i].Item);
            }
        }

        // Providers not placed in any column go to the disabled pool.
        var placedKeys = items.Select(i => i.ProviderKey).ToHashSet(StringComparer.OrdinalIgnoreCase);
        foreach (var (provider, displayName, color, icon) in providerInfos)
        {
            if (placedKeys.Contains(provider.Name)) continue;
            var supported = GetProviderFieldKeys(provider);
            items.Add(new MatrixItem
            {
                ProviderKey = provider.Name,
                DisplayName = displayName,
                Zone = "disabled",
                Order = 0,
                SupportedFields = new HashSet<string>(supported, StringComparer.OrdinalIgnoreCase),
                Color = color,
                Icon = icon,
                Enabled = provider.Enabled,
            });
        }

        return items;
    }

    // ── MudDropContainer handlers ──────────────────────────────────────────

    private void OnItemDropped(MudItemDropInfo<MatrixItem> info)
    {
        var item = info.Item;
        if (item is null) return;
        var targetZone = info.DropzoneIdentifier;
        var sourceZone = item.Zone;

        // Update the item.
        item.Zone = targetZone;
        item.Order = info.IndexInZone;

        // Recalculate orders in the target zone.
        RecalculateOrders(targetZone);
        if (sourceZone != targetZone)
            RecalculateOrders(sourceZone);

        _dirtyTabs.Add(_activeTabIndex);
        StateHasChanged();
    }

    private void RecalculateOrders(string zone)
    {
        var zoneItems = ActiveMatrixItems
            .Where(i => i.Zone == zone)
            .OrderBy(i => i.Order)
            .ToList();

        for (var i = 0; i < zoneItems.Count; i++)
            zoneItems[i].Order = i;
    }

    private static bool CanDropInColumn(MatrixItem item, MatrixColumn column) =>
        column.ClaimKeys.Any(ck =>
            item.SupportedFields.Contains(ck, StringComparer.OrdinalIgnoreCase));

    private int GetItemPosition(MatrixItem item)
    {
        if (item.Zone == "disabled") return 0;
        return ActiveMatrixItems
            .Where(i => i.Zone == item.Zone)
            .OrderBy(i => i.Order)
            .ToList()
            .IndexOf(item);
    }

    // ── Tab switching ──────────────────────────────────────────────────────

    private void OnTabChanged(int newIndex)
    {
        _activeTabIndex = newIndex;
        _dropContainer?.Refresh();
    }

    // ── Column management ──────────────────────────────────────────────────

    private void ExtractFieldFromUniverse(string claimKey)
    {
        var universeCol = ActiveColumns.FirstOrDefault(c => c.ZoneId == "universe_info");
        if (universeCol is null || !universeCol.ClaimKeys.Contains(claimKey)) return;

        // Remove from Universe group.
        universeCol.ClaimKeys.Remove(claimKey);

        // Create new column.
        var newCol = new MatrixColumn
        {
            ZoneId = claimKey,
            DisplayName = FieldDictionary.GetDisplayName(claimKey),
            Icon = FieldDictionary.GetIcon(claimKey),
            ClaimKeys = [claimKey],
            IsGroup = false,
            IsUserAdded = true,
            SortOrder = ActiveColumns.Max(c => c.SortOrder) + 1,
        };
        ActiveColumns.Add(newCol);

        // Clone providers from Universe zone that support this field.
        var universeProviders = ActiveMatrixItems
            .Where(i => i.Zone == "universe_info"
                     && i.SupportedFields.Contains(claimKey, StringComparer.OrdinalIgnoreCase))
            .ToList();

        for (var i = 0; i < universeProviders.Count; i++)
        {
            var src = universeProviders[i];
            ActiveMatrixItems.Add(new MatrixItem
            {
                ProviderKey = src.ProviderKey,
                DisplayName = src.DisplayName,
                SupportedFields = src.SupportedFields,
                Color = src.Color,
                Icon = src.Icon,
                Enabled = src.Enabled,
                Zone = claimKey,
                Order = i,
            });
        }

        _dirtyTabs.Add(_activeTabIndex);
        _dropContainer?.Refresh();
    }

    private void RemoveColumn(MatrixColumn column)
    {
        // Move items back to disabled (remove duplicates — keep one per provider in disabled).
        var columnItems = ActiveMatrixItems.Where(i => i.Zone == column.ZoneId).ToList();
        foreach (var item in columnItems)
            ActiveMatrixItems.Remove(item);

        // If this was extracted from Universe, re-absorb the claim key.
        if (column.IsUserAdded && column.ClaimKeys.Count == 1)
        {
            var universeCol = ActiveColumns.FirstOrDefault(c => c.ZoneId == "universe_info");
            if (universeCol is not null && FieldDictionary.UniverseGroupFields.Contains(column.ClaimKeys[0]))
                universeCol.ClaimKeys.Add(column.ClaimKeys[0]);
        }

        ActiveColumns.Remove(column);
        _dirtyTabs.Add(_activeTabIndex);
        _dropContainer?.Refresh();
    }

    private void AddColumn(string claimKey)
    {
        if (ActiveColumns.Any(c => c.ZoneId == claimKey)) return;

        ActiveColumns.Add(new MatrixColumn
        {
            ZoneId = claimKey,
            DisplayName = FieldDictionary.GetDisplayName(claimKey),
            Icon = FieldDictionary.GetIcon(claimKey),
            ClaimKeys = [claimKey],
            IsGroup = false,
            IsUserAdded = true,
            SortOrder = ActiveColumns.Max(c => c.SortOrder) + 1,
        });

        _dirtyTabs.Add(_activeTabIndex);
        _dropContainer?.Refresh();
    }

    private IEnumerable<KeyValuePair<string, FieldDictionary.FieldInfo>> GetAddableFields()
    {
        var existingZones = ActiveColumns
            .Select(c => c.ZoneId)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var groupedFields = ActiveColumns
            .Where(c => c.IsGroup)
            .SelectMany(c => c.ClaimKeys)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return FieldDictionary.Fields
            .Where(f => !existingZones.Contains(f.Key) && !groupedFields.Contains(f.Key))
            .OrderBy(f => f.Value.Category)
            .ThenBy(f => f.Value.DisplayName);
    }

    // ── Save ───────────────────────────────────────────────────────────────

    private async Task SaveMatrixPrioritiesAsync()
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var tab = MediaTypeTabs[_activeTabIndex];
            var providerWeights = new Dictionary<string, Dictionary<string, double>>();

            foreach (var column in ActiveColumns)
            {
                var zoneItems = ActiveMatrixItems
                    .Where(i => i.Zone == column.ZoneId)
                    .OrderBy(i => i.Order)
                    .ToList();

                for (var position = 0; position < zoneItems.Count; position++)
                {
                    var item = zoneItems[position];
                    var realKey = ResolveProviderKeyForSave(item, tab.DomainKey);
                    var weight = PriorityToWeight(position);

                    if (!providerWeights.TryGetValue(realKey, out var weights))
                    {
                        var existing = _providers.FirstOrDefault(p => p.Name == realKey);
                        weights = existing?.FieldWeights is not null
                            ? new Dictionary<string, double>(existing.FieldWeights)
                            : new();
                        providerWeights[realKey] = weights;
                    }

                    foreach (var claimKey in column.ClaimKeys)
                    {
                        if (item.SupportedFields.Contains(claimKey, StringComparer.OrdinalIgnoreCase))
                            weights[claimKey] = weight;
                    }
                }
            }

            // Disabled providers: set weight to 0 for fields in visible columns.
            var allColumnFields = ActiveColumns
                .SelectMany(c => c.ClaimKeys)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            foreach (var item in ActiveMatrixItems.Where(i => i.Zone == "disabled"))
            {
                var realKey = ResolveProviderKeyForSave(item, tab.DomainKey);
                if (!providerWeights.TryGetValue(realKey, out var weights))
                {
                    var existing = _providers.FirstOrDefault(p => p.Name == realKey);
                    weights = existing?.FieldWeights is not null
                        ? new Dictionary<string, double>(existing.FieldWeights)
                        : new();
                    providerWeights[realKey] = weights;
                }

                foreach (var field in allColumnFields
                    .Where(f => item.SupportedFields.Contains(f, StringComparer.OrdinalIgnoreCase)))
                {
                    weights[field] = 0.0;
                }
            }

            // Save each provider.
            var allSuccess = true;
            foreach (var (providerName, weights) in providerWeights)
            {
                var config = new ProviderConfigUpdateDto { FieldWeights = weights };
                if (!await Orchestrator.SaveProviderConfigAsync(providerName, config))
                    allSuccess = false;
            }

            if (allSuccess)
            {
                Snackbar.Add($"Priorities saved for {tab.Label}.", Severity.Success);
                _dirtyTabs.Remove(_activeTabIndex);
                await LoadProvidersAsync();
            }
            else
            {
                Snackbar.Add("Some priorities failed to save.", Severity.Error);
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private static double PriorityToWeight(int position) =>
        Math.Max(0.15, 0.95 - (position * 0.10));

    private static string ResolveProviderKeyForSave(MatrixItem item, string domainKey) =>
        item.DisplayName.Equals("Apple Books", StringComparison.OrdinalIgnoreCase)
            ? domainKey.Equals("Audiobook", StringComparison.OrdinalIgnoreCase)
                ? "apple_books_audiobook"
                : "apple_books_ebook"
            : item.ProviderKey;

    // ── Provider helpers ───────────────────────────────────────────────────

    private List<ProviderStatusDto> GetRelevantProviders(string domainKey) =>
        _providers
            .Where(p =>
                string.Equals(p.Domain, domainKey, StringComparison.OrdinalIgnoreCase)
                || string.Equals(p.Domain, "Universal", StringComparison.OrdinalIgnoreCase))
            .ToList();

    private static IEnumerable<string> GetProviderFieldKeys(ProviderStatusDto provider)
    {
        if (provider.AvailableFields is { Count: > 0 })
            return provider.AvailableFields;
        if (provider.FieldWeights is { Count: > 0 })
            return provider.FieldWeights.Keys;
        return [];
    }

    private double GetFieldWeight(string providerName, string fieldKey)
    {
        var provider = _providers.FirstOrDefault(p => p.Name == providerName);
        if (provider?.FieldWeights?.TryGetValue(fieldKey, out var w) == true)
            return w;
        return 0.0;
    }

    private static bool IsWikidata(string name) =>
        string.Equals(name, "wikidata", StringComparison.OrdinalIgnoreCase);

    // ── Row interaction / flyout ────────────────────────────────────────────

    private void OnRowClicked(ProviderStatusDto provider)
    {
        if (IsMobile)
        {
            _drawerProvider = provider;
            _drawerOpen = true;
        }
        else
        {
            _expandedProvider = _expandedProvider == provider.Name ? null : provider.Name;
        }
    }

    private void OpenProviderFlyout(MatrixItem item)
    {
        var provider = _providers.FirstOrDefault(p => p.Name == item.ProviderKey);
        if (provider is null) return;

        if (IsMobile)
        {
            _drawerProvider = provider;
            _drawerOpen = true;
        }
        else
        {
            _flyoutProvider = provider;
            _flyoutOpen = true;
        }
    }

    private void OnFlyoutOpenChanged(bool open)
    {
        _flyoutOpen = open;
        if (!open) _flyoutProvider = null;
    }

    private void CloseFlyout()
    {
        _flyoutOpen = false;
        _flyoutProvider = null;
    }

    // ── Mobile drawer ──────────────────────────────────────────────────────

    private void OnDrawerOpenChanged(bool open)
    {
        _drawerOpen = open;
        if (!open) _drawerProvider = null;
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
        _drawerProvider = null;
    }

    // ── Provider actions ───────────────────────────────────────────────────

    private async Task ToggleProviderAsync(string name, bool enabled)
    {
        await Orchestrator.UpdateProviderAsync(name, enabled);
        await LoadProvidersAsync();
        StateHasChanged();
    }

    private async Task TestProvider(string name)
    {
        _testingProviders.Add(name);
        _testResults.Remove(name);
        StateHasChanged();

        try
        {
            var result = await Orchestrator.TestProviderAsync(name);
            if (result is not null)
                _testResults[name] = result;
        }
        finally
        {
            _testingProviders.Remove(name);
            StateHasChanged();
        }
    }

    private async Task SaveProvider(string name, ProviderConfigUpdateDto config)
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var success = await Orchestrator.SaveProviderConfigAsync(name, config);
            if (success)
            {
                Snackbar.Add($"{name} configuration saved.", Severity.Success);
                await LoadProvidersAsync();
                _expandedProvider = null;
                CloseFlyout();
                CloseDrawer();
            }
            else
            {
                Snackbar.Add($"Failed to save {name} configuration.", Severity.Error);
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteProvider(string name)
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var success = await Orchestrator.DeleteProviderAsync(name);
            if (success)
            {
                Snackbar.Add($"{name} has been disabled.", Severity.Info);
                await LoadProvidersAsync();
                _expandedProvider = null;
                CloseFlyout();
                CloseDrawer();
            }
            else
            {
                Snackbar.Add($"Failed to disable {name}.", Severity.Error);
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveHydrationSettingsAsync()
    {
        if (_hydrationSettings is null) return;

        _saving = true;
        StateHasChanged();

        try
        {
            var success = await Orchestrator.UpdateHydrationSettingsAsync(_hydrationSettings);
            Snackbar.Add(
                success ? "Pipeline configuration saved." : "Failed to save pipeline configuration.",
                success ? Severity.Success : Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Helpers ─────────────────────────────────────────────────────────────

    private ProviderTestResultDto? GetTestResult(string name) =>
        _testResults.TryGetValue(name, out var r) ? r : null;

    private bool IsProviderTesting(string name) => _testingProviders.Contains(name);

    private static string FormatDomain(string domain) =>
        domain switch
        {
            "Ebook"     => "Books",
            "Audiobook" => "Audiobooks",
            "Video"     => "Video",
            "Universal" => "Universal",
            _           => domain,
        };

    private static string StatusDotStyle(ProviderStatusDto p)
    {
        var color = p.Enabled && p.IsReachable
            ? "var(--mud-palette-success)"
            : !p.Enabled
                ? "var(--tanaste-text-muted)"
                : "var(--mud-palette-error)";

        return $"width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; background-color: {color};";
    }

    private static string StatusTitle(ProviderStatusDto p)
    {
        if (!p.Enabled) return "Disabled";
        return p.IsReachable ? "Connected" : "Unreachable";
    }

