@namespace Tanaste.Web.Components.Settings
@inject UIOrchestratorService Orchestrator
@inject DeviceContextService DeviceContext
@inject ISnackbar Snackbar

@* Connection Vault — media-type-grouped provider priority management.
   Universe (Wikidata) pinned at top. Providers grouped by media type
   with per-field priority ordering. Connection testing and pipeline
   config in collapsible sections below. *@

<MudPaper Elevation="0" Style="@GlassStyle">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Hub" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">Connection Vault</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Manage metadata providers and field priorities. Drag providers to set which source
        wins for each field. Expand Provider Connections to test endpoints.
    </MudText>

    @* ── Loading / error ──────────────────────────────────────────────────── *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_engineDown)
    {
        <MudAlert Severity="Severity.Error" Class="mt-2">
            Cannot reach the Engine — please make sure it is running.
        </MudAlert>
    }
    else
    {
        @* ── Universe Provider (Wikidata) — pinned ────────────────────── *@
        @if (GetWikidataProvider() is { } wikidata)
        {
            var isExpanded = _expandedProvider == wikidata.Name;

            <MudPaper Elevation="0" Class="pa-4 mb-4"
                      Style="background: var(--tanaste-glass-bg); border: 1px solid var(--tanaste-glass-border); border-left: 4px solid var(--mud-palette-primary); border-radius: 16px;">

                <div class="provider-row-header"
                     @onclick="@(() => ToggleExpanded(wikidata.Name))">

                    <div class="provider-status-dot"
                         style="@StatusDotStyle(wikidata)"
                         title="@StatusTitle(wikidata)"></div>

                    <div style="flex: 1; min-width: 0;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                @wikidata.DisplayName
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                     Color="Color.Primary" Style="font-size: 0.65rem;">
                                Universe Provider
                            </MudChip>
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            QID resolution, bridge identifiers, and person enrichment across all media types.
                        </MudText>
                    </div>

                    @if (IsAdmin)
                    {
                        <MudSwitch T="bool" Value="@wikidata.Enabled"
                                   ValueChanged="@(async val => await ToggleProviderAsync(wikidata.Name, val))"
                                   Color="Color.Primary"
                                   @onclick:stopPropagation="true" />
                    }

                    @if (!IsMobile)
                    {
                        <MudIcon Icon="@(isExpanded
                                          ? Icons.Material.Filled.ExpandLess
                                          : Icons.Material.Filled.ExpandMore)"
                                 Size="Size.Small"
                                 Style="color: var(--tanaste-text-muted);" />
                    }
                </div>

                @if (isExpanded && !IsMobile)
                {
                    <div class="provider-expanded-content">
                        <WikidataVaultPanel Provider="@wikidata"
                                            IsAdmin="@HasAdminAccess"
                                            OnTestClicked="@(() => TestProvider(wikidata.Name))"
                                            OnSaveClicked="@(config => SaveProvider(wikidata.Name, config))"
                                            TestResult="@GetTestResult(wikidata.Name)"
                                            IsTesting="@IsProviderTesting(wikidata.Name)"
                                            IsSaving="@_saving" />
                    </div>
                }
            </MudPaper>
        }

        @* ── Field Priorities — grouped by media type ─────────────────── *@
        <MudPaper Elevation="0" Class="pa-4 mb-4"
                  Style="background: var(--tanaste-glass-bg); border: 1px solid var(--tanaste-glass-border); border-radius: 16px;">

            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Sort" Size="Size.Small"
                         Style="color: var(--tanaste-text-muted);" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Field Priorities</MudText>
            </MudStack>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                Set which provider wins for each metadata field. Higher priority providers are
                preferred by the scoring engine.
            </MudText>

            @foreach (var group in _mediaTypeGroups)
            {
                var groupProviders = GetProvidersForMediaType(group.DomainKey);
                var isGroupExpanded = IsGroupExpanded(group.Key);

                <div class="media-type-group @(isGroupExpanded ? "expanded" : "")">
                    <div class="media-type-header"
                         @onclick="@(() => ToggleGroup(group.Key))">
                        <MudIcon Icon="@(isGroupExpanded
                                          ? Icons.Material.Filled.ExpandMore
                                          : Icons.Material.Filled.ChevronRight)"
                                 Size="Size.Small"
                                 Style="color: var(--tanaste-text-muted);" />
                        <MudIcon Icon="@group.Icon" Size="Size.Small"
                                 Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600; flex: 1;">
                            @group.Label
                        </MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                 Color="Color.Default">
                            @groupProviders.Count providers
                        </MudChip>
                    </div>

                    @if (isGroupExpanded)
                    {
                        <div class="media-type-content">
                            @if (groupProviders.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary"
                                         Style="font-style: italic; padding: 8px 0;">
                                    No providers configured for @group.Label yet.
                                </MudText>
                            }
                            else
                            {
                                var fields = BuildFieldPriorities(groupProviders);

                                @foreach (var field in fields)
                                {
                                    <div class="field-priority-row">
                                        <MudText Typo="Typo.body2"
                                                 Style="font-weight: 500; min-width: 140px; color: var(--tanaste-text-muted);">
                                            @FormatFieldName(field.FieldKey)
                                        </MudText>

                                        <div class="priority-chips">
                                            @for (var i = 0; i < field.Providers.Count; i++)
                                            {
                                                var entry = field.Providers[i];
                                                var idx = i; // capture for closure

                                                <div class="priority-entry">
                                                    <span class="priority-number">@(idx + 1)</span>
                                                    <MudChip T="string" Size="Size.Small"
                                                             Variant="Variant.Outlined"
                                                             Color="@(idx == 0 ? Color.Primary : Color.Default)"
                                                             Style="font-size: 0.75rem;">
                                                        @entry.DisplayName
                                                    </MudChip>

                                                    @if (IsAdmin && field.Providers.Count > 1)
                                                    {
                                                        <div class="priority-arrows">
                                                            @if (idx > 0)
                                                            {
                                                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                                                               Size="Size.Small"
                                                                               OnClick="@(() => MovePriority(group.Key, field.FieldKey, idx, -1))"
                                                                               Style="padding: 2px;" />
                                                            }
                                                            @if (idx < field.Providers.Count - 1)
                                                            {
                                                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                                                               Size="Size.Small"
                                                                               OnClick="@(() => MovePriority(group.Key, field.FieldKey, idx, 1))"
                                                                               Style="padding: 2px;" />
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (_dirtyGroups.Contains(group.Key) && IsAdmin)
                                {
                                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Save"
                                                   OnClick="@(() => SavePrioritiesAsync(group.Key))"
                                                   Disabled="@_saving">
                                            @if (_saving)
                                            {
                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                                @:Saving…
                                            }
                                            else
                                            {
                                                @:Save Priorities
                                            }
                                        </MudButton>
                                    </MudStack>
                                }
                            }
                        </div>
                    }
                </div>
            }
        </MudPaper>

        @* ── Provider Connections (collapsible) ───────────────────────── *@
        <MudPaper Elevation="0" Class="pa-4 mb-4"
                  Style="background: var(--tanaste-glass-bg); border: 1px solid var(--tanaste-glass-border); border-radius: 16px;">

            <div class="media-type-header"
                 @onclick="@(() => _connectionsExpanded = !_connectionsExpanded)">
                <MudIcon Icon="@(_connectionsExpanded
                                  ? Icons.Material.Filled.ExpandMore
                                  : Icons.Material.Filled.ChevronRight)"
                         Size="Size.Small"
                         Style="color: var(--tanaste-text-muted);" />
                <MudIcon Icon="@Icons.Material.Filled.CloudSync" Size="Size.Small"
                         Style="color: var(--tanaste-text-muted);" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600; flex: 1;">
                    Provider Connections
                </MudText>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                         Color="Color.Default">
                    @GetNonWikidataProviders().Count
                </MudChip>
            </div>

            @if (_connectionsExpanded)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 mt-1">
                    Test endpoints, enable/disable providers, and configure connection settings.
                </MudText>

                <div class="provider-list">
                    @foreach (var provider in GetNonWikidataProviders())
                    {
                        var isExpanded = _expandedProvider == provider.Name;

                        <div class="provider-row @(isExpanded ? "expanded" : "")"
                             @key="@provider.Name">

                            <div class="provider-row-header"
                                 @onclick="@(() => OnRowClicked(provider))">

                                <div class="provider-status-dot"
                                     style="@StatusDotStyle(provider)"
                                     title="@StatusTitle(provider)"></div>

                                <div style="flex: 1; min-width: 0;">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                            @provider.DisplayName
                                        </MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                                 Color="Color.Default"
                                                 Style="font-size: 0.65rem;">
                                            @FormatDomain(provider.Domain)
                                        </MudChip>
                                    </MudStack>
                                </div>

                                @if (IsAdmin)
                                {
                                    <MudSwitch T="bool" Value="@provider.Enabled"
                                               ValueChanged="@(async val => await ToggleProviderAsync(provider.Name, val))"
                                               Color="Color.Primary"
                                               @onclick:stopPropagation="true" />
                                }

                                @if (!IsMobile)
                                {
                                    <MudIcon Icon="@(isExpanded
                                                      ? Icons.Material.Filled.ExpandLess
                                                      : Icons.Material.Filled.ExpandMore)"
                                             Size="Size.Small"
                                             Style="color: var(--tanaste-text-muted);" />
                                }
                            </div>

                            @if (isExpanded && !IsMobile)
                            {
                                <div class="provider-expanded-content">
                                    <ProviderEditPanel Provider="@provider"
                                                       IsAdmin="@HasAdminAccess"
                                                       OnTestClicked="@(() => TestProvider(provider.Name))"
                                                       OnSampleClicked="@(() => FetchSample(provider.Name))"
                                                       OnSaveClicked="@(config => SaveProvider(provider.Name, config))"
                                                       OnDeleteClicked="@(() => DeleteProvider(provider.Name))"
                                                       TestResult="@GetTestResult(provider.Name)"
                                                       SampleResult="@GetSampleResult(provider.Name)"
                                                       IsTesting="@IsProviderTesting(provider.Name)"
                                                       IsFetchingSample="@IsProviderFetchingSample(provider.Name)"
                                                       IsSaving="@_saving" />
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </MudPaper>

        @* ── Advanced Pipeline Config (collapsible) ───────────────────── *@
        <MudPaper Elevation="0" Class="pa-4"
                  Style="background: var(--tanaste-glass-bg); border: 1px solid var(--tanaste-glass-border); border-radius: 16px;">

            <div class="media-type-header"
                 @onclick="@(() => _advancedExpanded = !_advancedExpanded)">
                <MudIcon Icon="@(_advancedExpanded
                                  ? Icons.Material.Filled.ExpandMore
                                  : Icons.Material.Filled.ChevronRight)"
                         Size="Size.Small"
                         Style="color: var(--tanaste-text-muted);" />
                <MudIcon Icon="@Icons.Material.Outlined.Tune" Size="Size.Small"
                         Style="color: var(--tanaste-text-muted);" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600; flex: 1;">
                    Advanced
                </MudText>
            </div>

            @if (_advancedExpanded)
            {
                <div class="mt-3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                        Pipeline concurrency, timeouts, and confidence thresholds.
                    </MudText>

                    @if (_hydrationSettings is not null)
                    {
                        <MudGrid Spacing="3">
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="int" Label="Stage Concurrency"
                                                 @bind-Value="_hydrationSettings.StageConcurrency"
                                                 Min="1" Max="10"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="int" Label="Stage 1 Timeout (seconds)"
                                                 @bind-Value="_hydrationSettings.Stage1TimeoutSeconds"
                                                 Min="5" Max="120"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="int" Label="Stage 2 Timeout (seconds)"
                                                 @bind-Value="_hydrationSettings.Stage2TimeoutSeconds"
                                                 Min="5" Max="120"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="int" Label="Stage 3 Timeout (seconds)"
                                                 @bind-Value="_hydrationSettings.Stage3TimeoutSeconds"
                                                 Min="5" Max="120"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="double" Label="Disambiguation Threshold"
                                                 @bind-Value="_hydrationSettings.DisambiguationThreshold"
                                                 Min="0.0" Max="1.0" Step="0.05"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 Format="F2" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="double" Label="Auto-Review Threshold"
                                                 @bind-Value="_hydrationSettings.AutoReviewConfidenceThreshold"
                                                 Min="0.0" Max="1.0" Step="0.05"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 Format="F2" />
                            </MudItem>
                        </MudGrid>

                        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@SaveHydrationSettingsAsync"
                                       Disabled="@(!IsAdmin || _saving)">
                                Save Configuration
                            </MudButton>
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-style: italic;">
                            Could not load pipeline configuration.
                        </MudText>
                    }
                </div>
            }
        </MudPaper>
    }
</MudPaper>

@* ── Mobile slide-over drawer ────────────────────────────────────────── *@
@if (IsMobile && _drawerProvider is not null)
{
    <MudDrawer Open="@_drawerOpen"
               OpenChanged="@OnDrawerOpenChanged"
               Anchor="Anchor.End"
               Width="100%"
               Overlay="true"
               Variant="DrawerVariant.Temporary"
               Style="@DrawerStyle">
        <div class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                               Color="Color.Default"
                               Size="Size.Medium"
                               OnClick="@CloseDrawer" />
                <MudText Typo="Typo.h6" Style="flex: 1;">@_drawerProvider.DisplayName</MudText>
            </MudStack>

            @if (IsWikidata(_drawerProvider.Name))
            {
                <WikidataVaultPanel Provider="@_drawerProvider"
                                    IsAdmin="@HasAdminAccess"
                                    OnTestClicked="@(() => TestProvider(_drawerProvider.Name))"
                                    OnSaveClicked="@(config => SaveProvider(_drawerProvider.Name, config))"
                                    TestResult="@GetTestResult(_drawerProvider.Name)"
                                    IsTesting="@IsProviderTesting(_drawerProvider.Name)"
                                    IsSaving="@_saving" />
            }
            else
            {
                <ProviderEditPanel Provider="@_drawerProvider"
                                   IsAdmin="@HasAdminAccess"
                                   OnTestClicked="@(() => TestProvider(_drawerProvider.Name))"
                                   OnSampleClicked="@(() => FetchSample(_drawerProvider.Name))"
                                   OnSaveClicked="@(config => SaveProvider(_drawerProvider.Name, config))"
                                   OnDeleteClicked="@(() => DeleteProvider(_drawerProvider.Name))"
                                   TestResult="@GetTestResult(_drawerProvider.Name)"
                                   SampleResult="@GetSampleResult(_drawerProvider.Name)"
                                   IsTesting="@IsProviderTesting(_drawerProvider.Name)"
                                   IsFetchingSample="@IsProviderFetchingSample(_drawerProvider.Name)"
                                   IsSaving="@_saving" />
            }
        </div>
    </MudDrawer>
}

@code {
    /// <summary>Current user role for authorisation gating.</summary>
    [Parameter] public string CurrentRole { get; set; } = "Administrator";

    // ── State ────────────────────────────────────────────────────────────────

    private bool _loading = true;
    private bool _engineDown;
    private bool _saving;

    private List<ProviderStatusDto> _providers = [];
    private string? _expandedProvider;

    // Collapsible sections.
    private bool _connectionsExpanded;
    private bool _advancedExpanded;
    private readonly Dictionary<string, bool> _groupExpansion = new()
    {
        ["books"] = true,
        ["audiobooks"] = true,
        ["comics"] = false,
        ["movies"] = false,
        ["tvshows"] = false,
    };

    // Priority tracking — tracks which groups have unsaved changes.
    private readonly HashSet<string> _dirtyGroups = [];

    // Mutable priority state: groupKey → fieldKey → ordered list of (providerName, displayName).
    private readonly Dictionary<string, Dictionary<string, List<PriorityEntry>>> _priorities = new();

    // Pipeline config.
    private HydrationSettingsDto? _hydrationSettings;

    // Mobile drawer.
    private bool _drawerOpen;
    private ProviderStatusDto? _drawerProvider;

    // Per-provider test/sample results.
    private readonly Dictionary<string, ProviderTestResultDto> _testResults = new();
    private readonly Dictionary<string, ProviderSampleResultDto> _sampleResults = new();
    private readonly HashSet<string> _testingProviders = [];
    private readonly HashSet<string> _fetchingSampleProviders = [];

    // ── Media type group definitions ─────────────────────────────────────────

    private static readonly MediaTypeGroup[] _mediaTypeGroups =
    [
        new("books",      "Books",      "Ebook",     Icons.Material.Outlined.MenuBook),
        new("audiobooks", "Audiobooks", "Audiobook", Icons.Material.Outlined.Headphones),
        new("comics",     "Comics",     "Comic",     Icons.Material.Outlined.CollectionsBookmark),
        new("movies",     "Movies",     "Video",     Icons.Material.Outlined.Movie),
        new("tvshows",    "TV Shows",   "Video",     Icons.Material.Outlined.Tv),
    ];

    private sealed record MediaTypeGroup(string Key, string Label, string DomainKey, string Icon);
    private sealed record PriorityEntry(string ProviderName, string DisplayName);

    // ── Computed ──────────────────────────────────────────────────────────────

    private bool HasAdminAccess =>
        string.Equals(CurrentRole, "Administrator", StringComparison.OrdinalIgnoreCase)
        || string.Equals(CurrentRole, "Curator", StringComparison.OrdinalIgnoreCase);

    private bool IsAdmin =>
        string.Equals(CurrentRole, "Administrator", StringComparison.OrdinalIgnoreCase);

    private bool IsMobile =>
        string.Equals(DeviceContext.Settings.Pages.ServerSettings.SidebarLayout,
                      "drawer", StringComparison.OrdinalIgnoreCase);

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadProvidersAsync();
        _ = LoadHydrationSettingsAsync();
    }

    private async Task LoadProvidersAsync()
    {
        _loading = true;
        _engineDown = false;

        try
        {
            var providers = await Orchestrator.GetProviderStatusAsync();
            if (providers is null || providers.Count == 0)
            {
                _engineDown = true;
                return;
            }

            _providers = providers
                .Where(p => !string.Equals(p.Name, "local_filesystem", StringComparison.OrdinalIgnoreCase))
                .OrderBy(p => p.Name)
                .ToList();

            BuildPriorities();
        }
        catch
        {
            _engineDown = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadHydrationSettingsAsync()
    {
        try
        {
            _hydrationSettings = await Orchestrator.GetHydrationSettingsAsync();
        }
        catch
        {
            // Non-fatal — Advanced section shows fallback message.
        }
    }

    // ── Priority model ───────────────────────────────────────────────────────

    private void BuildPriorities()
    {
        _priorities.Clear();

        foreach (var group in _mediaTypeGroups)
        {
            var groupProviders = GetProvidersForMediaType(group.DomainKey);
            var fields = new Dictionary<string, List<PriorityEntry>>();

            // Collect all fields and their providers.
            foreach (var provider in groupProviders)
            {
                if (provider.FieldWeights is null) continue;

                foreach (var (fieldKey, weight) in provider.FieldWeights)
                {
                    if (!fields.ContainsKey(fieldKey))
                        fields[fieldKey] = [];

                    fields[fieldKey].Add(new PriorityEntry(provider.Name, provider.DisplayName));
                }
            }

            // Sort each field's providers by their existing weight (descending = highest priority first).
            foreach (var (fieldKey, entries) in fields)
            {
                fields[fieldKey] = entries
                    .OrderByDescending(e =>
                    {
                        var p = groupProviders.FirstOrDefault(p => p.Name == e.ProviderName);
                        return p?.FieldWeights?.TryGetValue(fieldKey, out var w) == true ? w : 0;
                    })
                    .ToList();
            }

            _priorities[group.Key] = fields;
        }
    }

    private List<FieldPriorityView> BuildFieldPriorities(List<ProviderStatusDto> groupProviders)
    {
        var fields = new Dictionary<string, List<PriorityEntry>>();

        foreach (var provider in groupProviders)
        {
            if (provider.FieldWeights is null) continue;

            foreach (var (fieldKey, _) in provider.FieldWeights)
            {
                if (!fields.ContainsKey(fieldKey))
                    fields[fieldKey] = [];

                fields[fieldKey].Add(new PriorityEntry(provider.Name, provider.DisplayName));
            }
        }

        // Sort by weight descending within each field.
        var result = new List<FieldPriorityView>();
        foreach (var (fieldKey, entries) in fields.OrderBy(kv => FieldSortOrder(kv.Key)))
        {
            // Check if we have a cached priority order from user edits.
            var groupKey = _mediaTypeGroups
                .FirstOrDefault(g => GetProvidersForMediaType(g.DomainKey)
                    .Any(p => entries.Any(e => e.ProviderName == p.Name)))?.Key;

            List<PriorityEntry> ordered;
            if (groupKey is not null
                && _priorities.TryGetValue(groupKey, out var groupFields)
                && groupFields.TryGetValue(fieldKey, out var cached))
            {
                ordered = cached;
            }
            else
            {
                ordered = entries
                    .OrderByDescending(e =>
                    {
                        var p = groupProviders.FirstOrDefault(p => p.Name == e.ProviderName);
                        return p?.FieldWeights?.TryGetValue(fieldKey, out var w) == true ? w : 0;
                    })
                    .ToList();
            }

            result.Add(new FieldPriorityView { FieldKey = fieldKey, Providers = ordered });
        }

        return result;
    }

    private sealed class FieldPriorityView
    {
        public string FieldKey { get; init; } = string.Empty;
        public List<PriorityEntry> Providers { get; set; } = [];
    }

    // ── Priority reordering ──────────────────────────────────────────────────

    private void MovePriority(string groupKey, string fieldKey, int index, int direction)
    {
        if (!_priorities.TryGetValue(groupKey, out var fields)) return;
        if (!fields.TryGetValue(fieldKey, out var entries)) return;

        var newIndex = index + direction;
        if (newIndex < 0 || newIndex >= entries.Count) return;

        // Swap.
        (entries[index], entries[newIndex]) = (entries[newIndex], entries[index]);
        _dirtyGroups.Add(groupKey);
        StateHasChanged();
    }

    private async Task SavePrioritiesAsync(string groupKey)
    {
        if (!_priorities.TryGetValue(groupKey, out var fields)) return;

        _saving = true;
        StateHasChanged();

        try
        {
            // Collect updated field weights per provider.
            var providerWeights = new Dictionary<string, Dictionary<string, double>>();

            foreach (var (fieldKey, entries) in fields)
            {
                for (var i = 0; i < entries.Count; i++)
                {
                    var weight = PriorityToWeight(i);
                    var providerName = entries[i].ProviderName;

                    if (!providerWeights.ContainsKey(providerName))
                    {
                        // Start from existing weights.
                        var existing = _providers.FirstOrDefault(p => p.Name == providerName);
                        providerWeights[providerName] = existing?.FieldWeights is not null
                            ? new Dictionary<string, double>(existing.FieldWeights)
                            : new();
                    }

                    providerWeights[providerName][fieldKey] = weight;
                }
            }

            // Save each affected provider.
            var allSuccess = true;
            foreach (var (providerName, weights) in providerWeights)
            {
                var config = new ProviderConfigUpdateDto { FieldWeights = weights };
                var success = await Orchestrator.SaveProviderConfigAsync(providerName, config);
                if (!success) allSuccess = false;
            }

            if (allSuccess)
            {
                Snackbar.Add($"Priorities saved for {groupKey}.", Severity.Success);
                _dirtyGroups.Remove(groupKey);
                await LoadProvidersAsync();
            }
            else
            {
                Snackbar.Add("Some priorities failed to save.", Severity.Error);
            }
        }
        finally
        {
            _saving = false;
        }
    }

    /// <summary>Maps a 0-based priority position to a field weight value.</summary>
    private static double PriorityToWeight(int position) =>
        Math.Max(0.15, 0.95 - (position * 0.10));

    // ── Provider helpers ─────────────────────────────────────────────────────

    private List<ProviderStatusDto> GetProvidersForMediaType(string domainKey) =>
        _providers
            .Where(p => !IsWikidata(p.Name)
                && string.Equals(p.Domain, domainKey, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private List<ProviderStatusDto> GetNonWikidataProviders() =>
        _providers.Where(p => !IsWikidata(p.Name)).ToList();

    private ProviderStatusDto? GetWikidataProvider() =>
        _providers.FirstOrDefault(p => IsWikidata(p.Name));

    private static bool IsWikidata(string name) =>
        string.Equals(name, "wikidata", StringComparison.OrdinalIgnoreCase);

    // ── Group expansion ──────────────────────────────────────────────────────

    private bool IsGroupExpanded(string key) =>
        _groupExpansion.TryGetValue(key, out var expanded) && expanded;

    private void ToggleGroup(string key)
    {
        if (_groupExpansion.TryGetValue(key, out var expanded))
            _groupExpansion[key] = !expanded;
        else
            _groupExpansion[key] = true;
    }

    // ── Row interaction ──────────────────────────────────────────────────────

    private void ToggleExpanded(string name)
    {
        if (IsMobile)
        {
            var provider = _providers.FirstOrDefault(p => p.Name == name);
            if (provider is not null)
            {
                _drawerProvider = provider;
                _drawerOpen = true;
            }
        }
        else
        {
            _expandedProvider = _expandedProvider == name ? null : name;
        }
    }

    private void OnRowClicked(ProviderStatusDto provider)
    {
        if (IsMobile)
        {
            _drawerProvider = provider;
            _drawerOpen = true;
        }
        else
        {
            _expandedProvider = _expandedProvider == provider.Name ? null : provider.Name;
        }
    }

    // ── Mobile drawer ────────────────────────────────────────────────────────

    private void OnDrawerOpenChanged(bool open)
    {
        _drawerOpen = open;
        if (!open) _drawerProvider = null;
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
        _drawerProvider = null;
    }

    // ── Provider actions ─────────────────────────────────────────────────────

    private async Task ToggleProviderAsync(string name, bool enabled)
    {
        await Orchestrator.UpdateProviderAsync(name, enabled);
        await LoadProvidersAsync();
        StateHasChanged();
    }

    private async Task TestProvider(string name)
    {
        _testingProviders.Add(name);
        _testResults.Remove(name);
        StateHasChanged();

        try
        {
            var result = await Orchestrator.TestProviderAsync(name);
            if (result is not null)
                _testResults[name] = result;
        }
        finally
        {
            _testingProviders.Remove(name);
            StateHasChanged();
        }
    }

    private async Task FetchSample(string name)
    {
        _fetchingSampleProviders.Add(name);
        _sampleResults.Remove(name);
        StateHasChanged();

        try
        {
            var result = await Orchestrator.FetchProviderSampleAsync(
                name, "The Fellowship of the Ring", "J.R.R. Tolkien",
                isbn: "9780547928210");
            if (result is not null)
                _sampleResults[name] = result;
        }
        finally
        {
            _fetchingSampleProviders.Remove(name);
            StateHasChanged();
        }
    }

    private async Task SaveProvider(string name, ProviderConfigUpdateDto config)
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var success = await Orchestrator.SaveProviderConfigAsync(name, config);
            if (success)
            {
                Snackbar.Add($"{name} configuration saved.", Severity.Success);
                await LoadProvidersAsync();
                _expandedProvider = null;
                CloseDrawer();
            }
            else
            {
                Snackbar.Add($"Failed to save {name} configuration.", Severity.Error);
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteProvider(string name)
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var success = await Orchestrator.DeleteProviderAsync(name);
            if (success)
            {
                Snackbar.Add($"{name} has been disabled.", Severity.Info);
                await LoadProvidersAsync();
                _expandedProvider = null;
                CloseDrawer();
            }
            else
            {
                Snackbar.Add($"Failed to disable {name}.", Severity.Error);
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveHydrationSettingsAsync()
    {
        if (_hydrationSettings is null) return;

        _saving = true;
        StateHasChanged();

        try
        {
            var success = await Orchestrator.UpdateHydrationSettingsAsync(_hydrationSettings);
            Snackbar.Add(
                success ? "Pipeline configuration saved." : "Failed to save pipeline configuration.",
                success ? Severity.Success : Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private ProviderTestResultDto? GetTestResult(string name) =>
        _testResults.TryGetValue(name, out var r) ? r : null;

    private ProviderSampleResultDto? GetSampleResult(string name) =>
        _sampleResults.TryGetValue(name, out var r) ? r : null;

    private bool IsProviderTesting(string name) => _testingProviders.Contains(name);
    private bool IsProviderFetchingSample(string name) => _fetchingSampleProviders.Contains(name);

    private static string FormatFieldName(string key) =>
        key switch
        {
            "cover" => "Cover Art",
            "title" => "Title",
            "author" => "Author",
            "description" => "Description",
            "narrator" => "Narrator",
            "series" => "Series",
            "series_position" => "Series Position",
            "year" => "Year",
            "isbn" => "ISBN",
            "asin" => "ASIN",
            "rating" => "Rating",
            "page_count" => "Page Count",
            "publisher" => "Publisher",
            "genre" => "Genre",
            "language" => "Language",
            _ => key.Replace("_", " ").ToUpperInvariant() switch
            {
                var k when k.Length > 0 => char.ToUpperInvariant(key[0]) + key[1..].Replace("_", " "),
                _ => key,
            },
        };

    /// <summary>Sort order for fields — most important first.</summary>
    private static int FieldSortOrder(string key) =>
        key switch
        {
            "cover" => 0,
            "title" => 1,
            "author" => 2,
            "description" => 3,
            "narrator" => 4,
            "series" => 5,
            "series_position" => 6,
            "year" => 7,
            "isbn" => 8,
            "rating" => 9,
            _ => 100,
        };

    private static string FormatDomain(string domain) =>
        domain switch
        {
            "Ebook" => "Books",
            "Audiobook" => "Audiobooks",
            "Video" => "Video",
            "Universal" => "Universal",
            _ => domain,
        };

    private static string StatusDotStyle(ProviderStatusDto p)
    {
        var color = p.Enabled && p.IsReachable
            ? "var(--mud-palette-success)"
            : !p.Enabled
                ? "var(--tanaste-text-muted)"
                : "var(--mud-palette-error)";

        return $"width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; background-color: {color};";
    }

    private static string StatusTitle(ProviderStatusDto p)
    {
        if (!p.Enabled) return "Disabled";
        return p.IsReachable ? "Connected" : "Unreachable";
    }

