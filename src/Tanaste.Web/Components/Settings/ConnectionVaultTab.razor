        "background: var(--tanaste-glass-bg); " +
        "border: 1px solid var(--tanaste-glass-border); " +
        "backdrop-filter: blur(20px); " +
        "-webkit-backdrop-filter: blur(20px); " +
        "border-radius: 24px; " +
